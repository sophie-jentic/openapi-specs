{
  "openapi": "3.0.3",
  "info": {
    "title": "Plivo SMS API",
    "version": "1.0.0",
    "description": "Plivo provides cloud communications APIs for SMS, MMS, and WhatsApp messaging to 200+ countries. Also supports voice calls.",
    "x-jentic-source-url": "https://www.plivo.com/docs/sms/api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.plivo.com/v1/Account/{auth_id}",
      "variables": {
        "auth_id": {
          "default": "YOUR_AUTH_ID"
        }
      }
    }
  ],
  "paths": {
    "/Message": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send a message",
        "description": "Send SMS, MMS, or WhatsApp message",
        "tags": [
          "Messages"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "src": {
                    "type": "string",
                    "description": "Sender number"
                  },
                  "dst": {
                    "type": "string",
                    "description": "Destination number(s)"
                  },
                  "text": {
                    "type": "string",
                    "description": "Message text"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "sms",
                      "mms",
                      "whatsapp"
                    ]
                  },
                  "url": {
                    "type": "string",
                    "description": "Callback URL"
                  },
                  "media_urls": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "src",
                  "dst",
                  "text"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listMessages",
        "summary": "List messages",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List messages"
      }
    },
    "/Message/{message_uuid}": {
      "get": {
        "operationId": "getMessage",
        "summary": "Get message details",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "message_uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get message details"
      }
    },
    "/Message/{message_uuid}/Media": {
      "get": {
        "operationId": "listMessageMedia",
        "summary": "List MMS media",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "message_uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List MMS media"
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Messages"
    }
  ]
}
