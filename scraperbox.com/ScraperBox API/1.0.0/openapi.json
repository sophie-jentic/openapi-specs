{
  "openapi": "3.1.0",
  "info": {
    "title": "ScraperBox API",
    "version": "1.0.0",
    "description": "ScraperBox provides a web scraping API with proxy management, JavaScript rendering, and anti-bot detection bypass capabilities.",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.scraperbox.com",
      "description": "ScraperBox API endpoint"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/scrape": {
      "get": {
        "summary": "Scrape Web Page",
        "description": "Scrape any web page with automatic proxy rotation, JavaScript rendering, and CAPTCHA handling.",
        "operationId": "scrapeGet",
        "parameters": [
          {
            "$ref": "#/components/parameters/token"
          },
          {
            "$ref": "#/components/parameters/url"
          },
          {
            "$ref": "#/components/parameters/render_js"
          },
          {
            "$ref": "#/components/parameters/country"
          },
          {
            "$ref": "#/components/parameters/proxy_type"
          },
          {
            "$ref": "#/components/parameters/timeout"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response containing the scraped HTML content",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                },
                "example": "<!DOCTYPE html><html>...</html>"
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        },
        "tags": [
          "scrape"
        ]
      },
      "post": {
        "summary": "Scrape Web Page (POST)",
        "description": "Scrape a web page using POST method. Useful for submitting form data or making POST requests to the target URL.",
        "operationId": "scrapePost",
        "parameters": [
          {
            "$ref": "#/components/parameters/token"
          },
          {
            "$ref": "#/components/parameters/url"
          },
          {
            "$ref": "#/components/parameters/render_js"
          },
          {
            "$ref": "#/components/parameters/country"
          },
          {
            "$ref": "#/components/parameters/proxy_type"
          },
          {
            "$ref": "#/components/parameters/timeout"
          }
        ],
        "requestBody": {
          "description": "Request body to forward to the target URL",
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response containing the scraped content",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        },
        "tags": [
          "scrape"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "Your ScraperBox API token for authentication"
      }
    },
    "parameters": {
      "token": {
        "name": "token",
        "in": "query",
        "required": true,
        "description": "Your ScraperBox API token (required for all requests)",
        "schema": {
          "type": "string"
        },
        "example": "your_api_token_here"
      },
      "url": {
        "name": "url",
        "in": "query",
        "required": true,
        "description": "The target URL to scrape",
        "schema": {
          "type": "string",
          "format": "uri"
        },
        "example": "https://example.com"
      },
      "render_js": {
        "name": "render_js",
        "in": "query",
        "required": false,
        "description": "Enable JavaScript rendering for dynamic websites. Set to 'true' to enable. Default: false",
        "schema": {
          "type": "boolean",
          "default": false
        },
        "example": true
      },
      "country": {
        "name": "country",
        "in": "query",
        "required": false,
        "description": "2-letter ISO country code for geolocation targeting (e.g., 'us', 'uk', 'de')",
        "schema": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2
        },
        "example": "us"
      },
      "proxy_type": {
        "name": "proxy_type",
        "in": "query",
        "required": false,
        "description": "Type of proxy to use (datacenter or residential). Default: datacenter",
        "schema": {
          "type": "string",
          "enum": [
            "datacenter",
            "residential"
          ],
          "default": "datacenter"
        },
        "example": "datacenter"
      },
      "timeout": {
        "name": "timeout",
        "in": "query",
        "required": false,
        "description": "Request timeout in seconds (10-120). Default: 60",
        "schema": {
          "type": "integer",
          "minimum": 10,
          "maximum": 120,
          "default": 60
        },
        "example": 60
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - missing or invalid parameters",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Invalid or missing URL parameter"
                }
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API token",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Invalid API token"
                }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden - insufficient credits or account restrictions",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Insufficient API credits"
                }
              }
            }
          }
        }
      },
      "RateLimitExceeded": {
        "description": "Rate limit exceeded",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Rate limit exceeded. Please try again later."
                }
              }
            }
          }
        }
      },
      "ServerError": {
        "description": "Server error or scraping failure",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Failed to scrape the target URL"
                }
              }
            }
          }
        }
      }
    }
  },
  "externalDocs": {
    "description": "ScraperBox website",
    "url": "https://scraperbox.com"
  },
  "tags": [
    {
      "name": "scrape"
    }
  ]
}
