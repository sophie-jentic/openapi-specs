{
  "openapi": "3.0.3",
  "info": {
    "title": "Envestnet API",
    "version": "1.0",
    "description": "Envestnet is a wealth management and financial data technology platform. The APIs provide access to financial data aggregation, account management, portfolio analytics, transaction categorization, and wealth management features for financial advisors and institutions. Envestnet Yodlee provides account aggregation and data enrichment APIs.",
    "x-jentic-source-url": "https://developer.envestnet.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.yodlee.com/ysl/{version}",
      "variables": {
        "version": {
          "default": "v1",
          "description": "API version"
        }
      }
    },
    {
      "url": "https://api.envestnet.com/v1"
    }
  ],
  "paths": {
    "/user/register": {
      "post": {
        "operationId": "registerUser",
        "summary": "Register a new user",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user"
                ],
                "properties": {
                  "user": {
                    "type": "object",
                    "properties": {
                      "loginName": {
                        "type": "string"
                      },
                      "email": {
                        "type": "string"
                      },
                      "name": {
                        "type": "object",
                        "properties": {
                          "first": {
                            "type": "string"
                          },
                          "last": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Register a new user"
      }
    },
