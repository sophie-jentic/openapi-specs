{
  "openapi": "3.0.3",
  "info": {
    "title": "Blip API",
    "version": "1.0.0",
    "description": "Blip chatbot platform API using LIME protocol for sending messages, notifications, and commands to manage bot resources and extensions.",
    "x-jentic-source-url": "https://docs.blip.ai/#introduction",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{contractId}.http.msging.net",
      "variables": {
        "contractId": {
          "default": "your-bot-id",
          "description": "Your bot contract identifier"
        }
      }
    }
  ],
  "paths": {
    "/messages": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send a message to a user",
        "tags": [
          "Messages"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Message"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Message accepted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "description": "Send a message to a user"
      }
    },
    "/notifications": {
      "post": {
        "operationId": "sendNotification",
        "summary": "Send a notification about message status",
        "tags": [
          "Notifications"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Notification"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Notification accepted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Send a notification about message status"
      }
    },
    "/commands": {
      "post": {
        "operationId": "sendCommand",
        "summary": "Send a command to query or manipulate server resources",
        "tags": [
          "Commands"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Command"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Command response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Send a command to query or manipulate server resources"
      }
    }
  },
  "components": {
    "schemas": {
      "Message": {
        "type": "object",
        "required": [
          "id",
          "to",
          "type",
          "content"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "content": {
            "type": "object"
          }
        }
      },
      "Notification": {
        "type": "object",
        "required": [
          "id",
          "to",
          "event"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "event": {
            "type": "string",
            "enum": [
              "accepted",
              "dispatched",
              "received",
              "consumed",
              "failed"
            ]
          },
          "reason": {
            "type": "object",
            "properties": {
              "code": {
                "type": "integer"
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      },
      "Command": {
        "type": "object",
        "required": [
          "id",
          "method",
          "uri"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "method": {
            "type": "string",
            "enum": [
              "get",
              "set",
              "merge",
              "delete",
              "subscribe",
              "unsubscribe",
              "observe"
            ]
          },
          "uri": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "resource": {
            "type": "object"
          }
        }
      },
      "CommandResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "method": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "resource": {
            "type": "object"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Commands"
    },
    {
      "name": "Messages"
    },
    {
      "name": "Notifications"
    }
  ]
}
