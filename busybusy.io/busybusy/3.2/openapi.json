  "paths": {
    "/api-key": {
      "get": {
        "summary": "List API keys",
        "description": "Retrieve all API keys",
        "operationId": "listApiKeys",
        "parameters": [
          {
            "name": "_version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "default": "3.2"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of API keys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ApiKey"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "api-key"
        ]
      },
      "post": {
        "summary": "Create API key",
        "description": "Create a new API key",
        "operationId": "createApiKey",
        "parameters": [
          {
            "name": "_version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "default": "3.2"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "permissions": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "API key created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKey"
                }
              }
            }
          }
        },
        "tags": [
          "api-key"
        ]
      },
      "patch": {
        "summary": "Update API key",
        "description": "Update an existing API key",
        "operationId": "updateApiKey",
        "parameters": [
          {
            "name": "_version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "default": "3.2"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "disabled_on": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "API key updated"
          }
        },
        "tags": [
          "api-key"
        ]
      }
    },
