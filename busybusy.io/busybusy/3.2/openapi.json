{
  "openapi": "3.0.3",
  "info": {
    "title": "BusyBusy REST API",
    "version": "3.2",
    "description": "BusyBusy REST API for time tracking, project management, and workforce operations. Supports API key management, equipment tracking, certifications, cost codes, and more.",
