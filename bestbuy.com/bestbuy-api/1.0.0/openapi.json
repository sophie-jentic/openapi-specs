{
  "openapi": "3.0.3",
  "info": {
    "title": "Best Buy API",
    "description": "The Best Buy Developer API provides programmatic access to Best Buy's product catalog, store locations, product recommendations, and open box listings.",
    "version": "1.0.0",
    "contact": {
      "name": "Best Buy Developer Support",
      "url": "https://bestbuyapis.github.io/api-documentation/"
    }
  },
  "servers": [
    {
      "url": "https://api.bestbuy.com",
      "description": "Best Buy API Production Server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/v1/products": {
      "get": {
        "operationId": "getProducts",
        "summary": "Get Products",
        "description": "Retrieve a collection of products. Supports search, filtering, sorting, and pagination.",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "description": "Response format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml"
              ],
              "default": "xml"
            }
          },
          {
            "name": "show",
            "in": "query",
            "description": "Comma-separated list of attributes to return, or 'all' for all attributes",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort attribute and direction (e.g., 'name.asc' or 'salePrice.dsc')",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of results per page (1-100)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "cursorMark",
            "in": "query",
            "description": "Cursor mark for large result set pagination (use instead of page for >10 pages)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search term to filter products",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "facet",
            "in": "query",
            "description": "Facet attribute for summary counting",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "apiKey",
            "in": "query",
            "description": "API key for authentication",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with product collection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductCollection"
                }
              }
            }
          },
          "400": {
            "description": "Malformed request"
          },
          "403": {
            "description": "Invalid API key or rate limit exceeded"
          }
        }
      }
    },
    "/v1/products/{sku}.json": {
      "get": {
        "operationId": "getProductBySku",
        "summary": "Get Product by SKU",
        "description": "Retrieve details for a specific product by its SKU number.",
