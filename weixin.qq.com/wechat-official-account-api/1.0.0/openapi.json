    "/cgi-bin/qrcode/create": {
      "post": {
        "operationId": "createQrCode",
        "summary": "Create a QR code",
        "description": "Creates a temporary or permanent QR code for the official account.",
        "tags": [
          "QR Codes"
        ],
        "parameters": [
          {
            "name": "access_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "expire_seconds": {
                    "type": "integer",
                    "description": "Expiry in seconds (max 2592000 for temporary)"
                  },
                  "action_name": {
                    "type": "string",
                    "enum": [
                      "QR_SCENE",
                      "QR_STR_SCENE",
                      "QR_LIMIT_SCENE",
                      "QR_LIMIT_STR_SCENE"
                    ]
                  },
                  "action_info": {
                    "type": "object",
                    "properties": {
                      "scene": {
                        "type": "object",
                        "properties": {
                          "scene_id": {
                            "type": "integer"
                          },
                          "scene_str": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "QR code created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ticket": {
                      "type": "string"
                    },
                    "expire_seconds": {
                      "type": "integer"
                    },
                    "url": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CustomMessage": {
        "type": "object",
        "required": [
          "touser",
          "msgtype"
        ],
        "properties": {
          "touser": {
            "type": "string",
            "description": "Recipient OpenID"
          },
          "msgtype": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "voice",
              "video",
              "music",
              "news",
              "mpnews",
              "msgmenu",
              "miniprogrampage"
            ]
          },
          "text": {
            "type": "object",
            "properties": {
              "content": {
                "type": "string"
              }
            }
          },
          "image": {
            "type": "object",
            "properties": {
              "media_id": {
                "type": "string"
              }
            }
          },
          "voice": {
            "type": "object",
            "properties": {
              "media_id": {
                "type": "string"
              }
            }
          },
          "video": {
            "type": "object",
            "properties": {
              "media_id": {
                "type": "string"
              },
              "thumb_media_id": {
                "type": "string"
              },
              "title": {
                "type": "string"
