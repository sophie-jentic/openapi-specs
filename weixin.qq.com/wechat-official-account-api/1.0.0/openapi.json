{
  "openapi": "3.0.3",
  "info": {
    "title": "WeChat Official Account API",
    "version": "1.0.0",
    "description": "WeChat Official Account Platform API for managing official accounts, sending messages, managing users, menus, and media assets.",
    "x-jentic-source-url": "https://developers.weixin.qq.com/doc/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.weixin.qq.com"
    }
  ],
  "paths": {
    "/cgi-bin/token": {
      "get": {
        "operationId": "getAccessToken",
        "summary": "Get access token",
        "description": "Obtains an access token for calling other APIs. Tokens are valid for 7200 seconds.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "grant_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "client_credential"
              ]
            },
            "description": "Must be client_credential"
          },
          {
            "name": "appid",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "App ID"
          },
          {
            "name": "secret",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "App secret"
          }
        ],
        "responses": {
          "200": {
            "description": "Access token response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string"
                    },
                    "expires_in": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cgi-bin/message/custom/send": {
      "post": {
        "operationId": "sendCustomMessage",
        "summary": "Send a custom message",
        "description": "Sends a custom message to a user who has interacted within 48 hours.",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "access_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomMessage"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cgi-bin/message/template/send": {
      "post": {
        "operationId": "sendTemplateMessage",
        "summary": "Send a template message",
        "description": "Sends a template message to a user.",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "access_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TemplateMessage"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errcode": {
                      "type": "integer"
                    },
                    "errmsg": {
                      "type": "string"
                    },
                    "msgid": {
                      "type": "integer",
                      "format": "int64"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cgi-bin/message/mass/sendall": {
      "post": {
        "operationId": "sendMassMessage",
        "summary": "Send a mass message",
        "description": "Sends a mass message to all followers or a specific tag group.",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "access_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "filter": {
                    "type": "object",
                    "properties": {
                      "is_to_all": {
                        "type": "boolean"
                      },
                      "tag_id": {
                        "type": "integer"
                      }
                    }
                  },
                  "msgtype": {
                    "type": "string",
                    "enum": [
                      "mpnews",
                      "text",
                      "voice",
                      "image",
                      "mpvideo"
                    ]
                  },
                  "text": {
                    "type": "object",
                    "properties": {
                      "content": {
                        "type": "string"
                      }
                    }
                  },
                  "mpnews": {
                    "type": "object",
                    "properties": {
                      "media_id": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mass message sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errcode": {
                      "type": "integer"
                    },
                    "errmsg": {
                      "type": "string"
                    },
                    "msg_id": {
                      "type": "integer",
                      "format": "int64"
                    },
                    "msg_data_id": {
                      "type": "integer",
                      "format": "int64"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cgi-bin/user/info": {
      "get": {
        "operationId": "getUserInfo",
        "summary": "Get user info",
        "description": "Retrieves information about a follower.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "access_token",
            "in": "query",
