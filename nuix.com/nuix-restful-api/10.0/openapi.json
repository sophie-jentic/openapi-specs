{
  "openapi": "3.0.3",
  "info": {
    "title": "Nuix RESTful API",
    "version": "10.0",
    "description": "Nuix is an investigation and eDiscovery platform for processing, analyzing, and reviewing unstructured data. The RESTful API enables programmatic access to case management, data processing, searching, tagging, item management, and export operations.",
    "x-jentic-source-url": "https://developer.nuix.com/latest/reference/restapireference.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}:{port}/nuix-restful-service/svc",
      "variables": {
        "host": {
          "default": "localhost"
        },
        "port": {
          "default": "8443"
        }
      }
    }
  ],
  "paths": {
    "/cases": {
      "get": {
        "operationId": "listCases",
        "summary": "List all cases",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "Case list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Case"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all cases"
      },
      "post": {
        "operationId": "createCase",
        "summary": "Create a new case",
        "tags": [
          "Cases"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCaseRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Case created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a new case"
      }
    },
    "/cases/{caseId}": {
      "get": {
        "operationId": "getCase",
        "summary": "Get case details",
        "tags": [
          "Cases"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Case details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Case"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get case details"
      },
      "delete": {
        "operationId": "deleteCase",
        "summary": "Delete a case",
        "tags": [
          "Cases"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Case deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Delete a case"
      }
    },
    "/cases/{caseId}/items": {
      "get": {
        "operationId": "listItems",
        "summary": "List items in a case",
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Nuix search query"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List items in a case"
      }
    },
    "/cases/{caseId}/items/{itemId}": {
      "get": {
        "operationId": "getItem",
        "summary": "Get item details",
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item details"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get item details"
      }
    },
    "/cases/{caseId}/items/{itemId}/text": {
      "get": {
        "operationId": "getItemText",
        "summary": "Get item text content",
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item text",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get item text content"
      }
    },
    "/cases/{caseId}/items/{itemId}/binary": {
      "get": {
        "operationId": "getItemBinary",
        "summary": "Get item binary content",
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Binary content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get item binary content"
      }
    },
    "/cases/{caseId}/items/{itemId}/properties": {
      "get": {
        "operationId": "getItemProperties",
        "summary": "Get item metadata properties",
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item properties"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get item metadata properties"
      }
    },
    "/cases/{caseId}/items/{itemId}/tags": {
      "get": {
        "operationId": "getItemTags",
        "summary": "Get item tags",
        "tags": [
          "Tagging"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tags"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get item tags"
      },
      "post": {
        "operationId": "addItemTag",
        "summary": "Add tag to item",
        "tags": [
          "Tagging"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tag": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tag added"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Add tag to item"
      },
      "delete": {
        "operationId": "removeItemTag",
        "summary": "Remove tag from item",
        "tags": [
          "Tagging"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tag removed"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Remove tag from item"
      }
    },
    "/cases/{caseId}/search": {
      "post": {
        "operationId": "searchCase",
        "summary": "Search items in a case",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "query"
                ],
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "sortBy": {
                    "type": "string"
                  },
                  "sortOrder": {
                    "type": "string",
                    "enum": [
                      "asc",
                      "desc"
                    ]
                  },
                  "offset": {
                    "type": "integer"
                  },
                  "limit": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Search items in a case"
      }
    },
    "/cases/{caseId}/process": {
      "post": {
        "operationId": "processData",
        "summary": "Start data processing",
        "tags": [
          "Processing"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sources": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "path": {
                          "type": "string"
                        },
                        "type": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "settings": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Processing started"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Start data processing"
      }
    },
    "/cases/{caseId}/export": {
      "post": {
        "operationId": "exportData",
        "summary": "Export case data",
        "tags": [
          "Export"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "native",
                      "pdf",
                      "tiff",
                      "text"
                    ]
                  },
                  "outputPath": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Export started"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Export case data"
      }
    },
    "/cases/{caseId}/tags": {
      "get": {
        "operationId": "listTags",
        "summary": "List all tags in a case",
        "tags": [
          "Tagging"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tag list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all tags in a case"
      }
    },
    "/cases/{caseId}/production-sets": {
      "get": {
        "operationId": "listProductionSets",
        "summary": "List production sets",
        "tags": [
          "Production"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Production sets"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List production sets"
      },
      "post": {
        "operationId": "createProductionSet",
        "summary": "Create a production set",
        "tags": [
          "Production"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "query": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Production set created"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a production set"
      }
    },
    "/jobs": {
      "get": {
        "operationId": "listJobs",
        "summary": "List processing jobs",
        "tags": [
          "Jobs"
        ],
        "responses": {
          "200": {
            "description": "Job list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List processing jobs"
      }
    },
    "/jobs/{jobId}": {
      "get": {
        "operationId": "getJob",
        "summary": "Get job status",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job details"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get job status"
      },
      "delete": {
        "operationId": "cancelJob",
        "summary": "Cancel a job",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job cancelled"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Cancel a job"
      }
    }
  },
  "components": {
    "schemas": {
      "Case": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "createdDate": {
            "type": "string",
            "format": "date-time"
          },
          "investigator": {
            "type": "string"
          },
          "itemCount": {
            "type": "integer"
          },
          "location": {
            "type": "string"
          }
        }
      },
      "CreateCaseRequest": {
        "type": "object",
        "required": [
          "name",
          "location"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "investigator": {
            "type": "string"
          },
          "location": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "statusCode": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Cases"
    },
    {
      "name": "Export"
    },
    {
      "name": "Items"
    },
    {
      "name": "Jobs"
    },
    {
      "name": "Processing"
    },
    {
      "name": "Production"
    },
    {
      "name": "Search"
    },
    {
      "name": "Tagging"
    }
  ]
}
