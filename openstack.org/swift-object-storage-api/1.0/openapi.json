              "type": "string"
            }
          },
          {
            "name": "multipart-manifest",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "get"
              ]
            },
            "description": "Get manifest for large object"
          }
        ],
        "responses": {
          "200": {
            "description": "Object content",
