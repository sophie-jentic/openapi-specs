          },
          {
            "name": "container",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Container name (1-256 chars)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Limit results"
          },
          {
            "name": "marker",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Pagination marker"
          },
          {
            "name": "end_marker",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "End marker"
          },
          {
            "name": "prefix",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Object name prefix filter"
          },
          {
            "name": "delimiter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Directory delimiter"
          },
          {
            "name": "path",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Pseudo path filter (use prefix/delimiter instead)"
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "plain"
              ]
            }
          },
          {
            "name": "reverse",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Reverse sort"
          },
          {
            "name": "X-Auth-Token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Newest",
            "in": "header",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object listing",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ObjectSummary"
                  }
                }
              }
            }
          },
          "204": {
            "description": "No objects"
          },
          "404": {
            "description": "Container not found"
          }
        }
      },
      "put": {
        "operationId": "createContainer",
        "summary": "Create container",
        "description": "Creates a container. Does not require a request body and ignores any content.",
        "tags": [
          "Containers"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "container",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Auth-Token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Container-Read",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Read ACL"
          },
          {
            "name": "X-Container-Write",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Write ACL"
          },
          {
            "name": "X-Storage-Policy",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Storage policy"
          },
          {
            "name": "X-Versions-Location",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Versioning container"
          }
        ],
        "responses": {
          "201": {
            "description": "Container created"
          },
          "202": {
            "description": "Container already existed"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "updateContainerMetadata",
        "summary": "Create, update, or delete container metadata",
        "tags": [
          "Containers"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "container",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Auth-Token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Container-Read",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Container-Write",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Metadata updated"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Container not found"
          }
        },
        "description": "Create, update, or delete container metadata"
      },
      "head": {
        "operationId": "showContainerMetadata",
        "summary": "Show container metadata",
        "tags": [
          "Containers"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "path",
