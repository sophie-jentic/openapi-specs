          },
          "404": {
            "description": "Container not found"
          },
          "409": {
            "description": "Conflict - container not empty"
          }
        }
      }
    },
    "/v1/{account}/{container}/{object}": {
      "get": {
        "operationId": "downloadObject",
        "summary": "Get object content and metadata",
        "description": "Downloads the object content and gets the object metadata.",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "container",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "object",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Object name"
          },
          {
            "name": "X-Auth-Token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Newest",
            "in": "header",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "temp_url_sig",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Temp URL signature"
          },
          {
            "name": "temp_url_expires",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Temp URL expiry"
          },
          {
            "name": "Range",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Byte range"
          },
          {
            "name": "If-Match",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "If-None-Match",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "If-Modified-Since",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "If-Unmodified-Since",
            "in": "header",
            "required": false,
