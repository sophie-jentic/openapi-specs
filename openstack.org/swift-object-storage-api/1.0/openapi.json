{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenStack Swift Object Storage API",
    "version": "1.0",
    "description": "OpenStack Swift (Object Storage) provides a RESTful API for storing and retrieving objects (files) organized in containers under accounts. It supports features like large object uploads, temporary URLs, versioning, ACLs, and metadata management.",
    "x-jentic-source-url": "https://docs.openstack.org/api-ref/object-store/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{swift-endpoint}"
    }
  ],
  "paths": {
    "/info": {
      "get": {
        "operationId": "listCapabilities",
        "summary": "List activated capabilities",
        "description": "Lists the activated capabilities for this version of the OpenStack Object Storage API.",
        "tags": [
          "Discoverability"
        ],
        "parameters": [
          {
            "name": "swiftinfo_sig",
            "in": "query",
            "description": "HMAC for admin-only info access",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "swiftinfo_expires",
            "in": "query",
            "description": "Expiry time for swiftinfo_sig (UNIX epoch)",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Capabilities listing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Capabilities"
                }
              }
            }
          }
        }
      }
    },
    "/v1/{account}": {
      "get": {
        "operationId": "listContainers",
        "summary": "Show account details and list containers",
        "description": "Shows details for an account and lists containers, sorted by name.",
        "tags": [
          "Accounts"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique account name (project/tenant)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Limit number of results"
          },
          {
            "name": "marker",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "List items greater than this value"
          },
          {
            "name": "end_marker",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "List items less than this value"
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "plain"
              ]
            },
            "description": "Response format"
          },
          {
            "name": "prefix",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by prefix"
          },
          {
            "name": "delimiter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Delimiter for pseudo-directory hierarchy"
          },
          {
            "name": "reverse",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Reverse sort order"
          },
          {
            "name": "X-Auth-Token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Authentication token"
          },
          {
            "name": "X-Newest",
            "in": "header",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Query all replicas for newest"
          }
        ],
        "responses": {
          "200": {
            "description": "Container listing",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Container"
                  }
                }
              }
            }
          },
          "204": {
            "description": "No containers found"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "updateAccountMetadata",
        "summary": "Create, update, or delete account metadata",
        "description": "Creates, updates, or deletes account metadata using X-Account-Meta-{name} headers.",
        "tags": [
          "Accounts"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account name"
          },
          {
            "name": "X-Auth-Token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Authentication token"
          },
          {
            "name": "X-Account-Meta-Temp-URL-Key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Secret key for temporary URLs"
          },
          {
            "name": "X-Account-Meta-Temp-URL-Key-2",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Second secret key for temp URLs"
          }
        ],
        "responses": {
          "204": {
            "description": "Metadata updated successfully"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "head": {
        "operationId": "showAccountMetadata",
        "summary": "Show account metadata",
        "description": "Shows metadata for an account including container count, object count, and bytes used.",
        "tags": [
          "Accounts"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account name"
          },
          {
            "name": "X-Auth-Token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Authentication token"
          }
        ],
        "responses": {
          "204": {
            "description": "Account metadata in response headers"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteAccount",
        "summary": "Delete account",
        "description": "Deletes the specified account. Requires reseller admin token and allow_account_management config.",
        "tags": [
          "Accounts"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account name"
          },
          {
            "name": "X-Auth-Token",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Reseller admin auth token"
          }
        ],
        "responses": {
          "204": {
            "description": "Account marked for deletion"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - non-admin token"
          },
          "404": {
            "description": "Account not found"
          }
        }
      }
    },
    "/v1/{account}/{container}": {
      "get": {
        "operationId": "listObjects",
        "summary": "Show container details and list objects",
        "description": "Shows details for a container and lists objects sorted by name.",
