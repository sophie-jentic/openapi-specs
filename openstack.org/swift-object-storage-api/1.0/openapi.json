          }
        },
        "description": "Show container metadata"
      },
      "delete": {
        "operationId": "deleteContainer",
        "summary": "Delete container",
        "description": "Deletes an empty container.",
        "tags": [
          "Containers"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
