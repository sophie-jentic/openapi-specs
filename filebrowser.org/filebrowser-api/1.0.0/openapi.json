{
  "openapi": "3.0.3",
  "info": {
    "title": "FileBrowser API",
    "version": "1.0.0",
    "description": "FileBrowser provides a file managing interface within a specified directory. It can be used to upload, delete, preview, rename and edit files. This REST API powers the web interface.",
    "x-jentic-source-url": "https://filebrowser.org/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080/api"
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "operationId": "login",
        "summary": "Authenticate and get JWT token",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JWT token returned as plain text",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "403": {
            "description": "Wrong credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Authenticate and get JWT token"
      }
    },
    "/signup": {
      "post": {
        "operationId": "signup",
        "summary": "Create a new user account (if signup is enabled)",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account created"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Signup disabled"
          }
        },
        "description": "Create a new user account (if signup is enabled)"
      }
    },
    "/renew": {
      "post": {
        "operationId": "renewToken",
        "summary": "Renew JWT authentication token",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "New JWT token",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Renew JWT authentication token"
      }
    },
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List all users",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "description": "List all users"
      },
      "post": {
        "operationId": "createUser",
        "summary": "Create a new user",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a new user"
      }
    },
    "/users/{id}": {
      "get": {
        "operationId": "getUser",
        "summary": "Get user by ID",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "User ID"
          }
        ],
        "responses": {
          "200": {
            "description": "User details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get user by ID"
      },
      "put": {
        "operationId": "updateUser",
        "summary": "Update user by ID",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "User ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update user by ID"
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete user by ID",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "User ID"
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "description": "Delete user by ID"
      }
    },
    "/resources/{path}": {
      "get": {
        "operationId": "getResource",
        "summary": "Get file or directory listing",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "File or directory path"
          }
        ],
        "responses": {
          "200": {
            "description": "File info or directory listing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileInfo"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get file or directory listing"
      },
      "post": {
        "operationId": "createResource",
        "summary": "Upload a file or create a directory",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Target path"
          },
          {
            "name": "override",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Override existing file"
          }
        ],
        "requestBody": {
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resource created"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "409": {
            "description": "Conflict - file already exists"
          }
        },
        "description": "Upload a file or create a directory"
      },
      "put": {
        "operationId": "updateResource",
        "summary": "Update a file's content",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "File path"
          }
        ],
        "requestBody": {
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File updated"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "description": "Update a file's content"
      },
      "patch": {
        "operationId": "patchResource",
        "summary": "Rename or move a resource",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Source path"
          },
          {
            "name": "action",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "rename",
                "copy"
              ]
            },
            "description": "Action to perform"
          },
          {
            "name": "destination",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Destination path"
          }
        ],
        "responses": {
          "200": {
            "description": "Resource modified"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "description": "Rename or move a resource"
      },
      "delete": {
        "operationId": "deleteResource",
        "summary": "Delete a file or directory",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Path to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Resource deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Delete a file or directory"
      }
    },
    "/raw/{path}": {
      "get": {
        "operationId": "downloadFile",
        "summary": "Download raw file content or archive of directory",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "File path"
          },
          {
            "name": "files",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of files to include in archive"
          },
          {
            "name": "algo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "zip",
                "tar",
                "targz",
                "tarbz2",
                "tarxz",
                "tarlz4",
                "tarsz",
                "tarbr",
                "tarzst"
              ],
              "default": "zip"
            },
            "description": "Archive algorithm"
          },
          {
            "name": "inline",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false"
              ]
            },
            "description": "Display inline instead of download"
          }
        ],
        "responses": {
          "200": {
            "description": "File content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Download raw file content or archive of directory"
      }
    },
    "/tus/{path}": {
      "post": {
        "operationId": "tusCreateUpload",
        "summary": "Create a TUS resumable upload",
        "tags": [
          "TUS Upload"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Upload target path"
          }
        ],
        "responses": {
          "200": {
            "description": "Upload created"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a TUS resumable upload"
      },
      "head": {
        "operationId": "tusGetUploadStatus",
        "summary": "Get TUS upload offset/status",
        "tags": [
          "TUS Upload"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Upload path"
          }
        ],
        "responses": {
          "200": {
            "description": "Upload status with Upload-Offset header"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get TUS upload offset/status"
      },
      "patch": {
        "operationId": "tusUploadChunk",
        "summary": "Upload a TUS chunk",
        "tags": [
          "TUS Upload"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Upload path"
          }
        ],
        "requestBody": {
          "content": {
            "application/offset+octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chunk uploaded"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Upload a TUS chunk"
      },
      "delete": {
        "operationId": "tusDeleteUpload",
        "summary": "Cancel a TUS upload",
        "tags": [
          "TUS Upload"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Upload path"
          }
        ],
        "responses": {
          "200": {
            "description": "Upload cancelled"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Cancel a TUS upload"
      }
    },
    "/usage/{path}": {
      "get": {
        "operationId": "getDiskUsage",
        "summary": "Get disk usage for a path",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Directory path"
          }
        ],
        "responses": {
          "200": {
            "description": "Disk usage info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiskUsage"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get disk usage for a path"
      }
    },
    "/shares": {
      "get": {
        "operationId": "listShares",
        "summary": "List all share links",
        "tags": [
          "Shares"
        ],
        "responses": {
          "200": {
            "description": "List of shares",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Share"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all share links"
      }
    },
    "/share/{path}": {
      "get": {
        "operationId": "getSharesForPath",
        "summary": "Get share links for a specific path",
        "tags": [
          "Shares"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Resource path"
          }
        ],
        "responses": {
          "200": {
            "description": "Shares for the path",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Share"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get share links for a specific path"
      },
      "post": {
        "operationId": "createShare",
        "summary": "Create a share link for a path",
        "tags": [
          "Shares"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Resource path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShareCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Share created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Share"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a share link for a path"
      },
      "delete": {
        "operationId": "deleteShare",
        "summary": "Delete a share link",
        "tags": [
          "Shares"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Share hash or path"
          }
        ],
        "responses": {
          "200": {
            "description": "Share deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete a share link"
      }
    },
    "/settings": {
      "get": {
        "operationId": "getSettings",
        "summary": "Get server settings",
        "tags": [
          "Settings"
        ],
        "responses": {
          "200": {
            "description": "Server settings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Settings"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get server settings"
      },
      "put": {
        "operationId": "updateSettings",
        "summary": "Update server settings",
        "tags": [
          "Settings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Settings"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings updated"
          },
          "401": {
            "description": "Unauthorized"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Update server settings"
      }
    },
    "/search/{path}": {
      "get": {
        "operationId": "searchFiles",
        "summary": "Search files by name",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Directory to search in"
          },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FileInfo"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Search files by name"
      }
    },
    "/preview/{size}/{path}": {
      "get": {
        "operationId": "getPreview",
        "summary": "Get image thumbnail preview",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "size",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "thumb",
                "big"
              ]
            },
            "description": "Preview size"
          },
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Image file path"
          }
        ],
        "responses": {
          "200": {
            "description": "Image preview",
            "content": {
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get image thumbnail preview"
      }
    },
    "/command/{path}": {
      "get": {
        "operationId": "runCommand",
        "summary": "Execute a configured command on a path",
        "tags": [
          "Commands"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Target path"
          }
        ],
        "responses": {
          "200": {
            "description": "Command output"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "description": "Execute a configured command on a path"
      }
    },
    "/subtitle/{path}": {
      "get": {
        "operationId": "getSubtitle",
        "summary": "Get subtitle file for a video",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
