{
  "openapi": "3.0.3",
  "info": {
    "title": "Mailosaur API",
    "version": "1.0.0",
    "description": "Mailosaur is a service for email and SMS testing. The API provides operations for managing servers, messages, and analysis.",
    "x-jentic-source-url": "https://mailosaur.com/docs/api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://mailosaur.com/api"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use your API key as the username and leave the password blank"
      }
    },
    "schemas": {
      "Server": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "users": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "messages": {
            "type": "integer"
          }
        }
      },
      "ServerList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Server"
            }
          }
        }
      },
      "ServerCreateRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "from": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageAddress"
            }
          },
          "to": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageAddress"
            }
          },
          "cc": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageAddress"
            }
          },
          "bcc": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageAddress"
            }
          },
          "subject": {
            "type": "string"
          },
          "received": {
            "type": "string",
            "format": "date-time"
          },
          "html": {
            "$ref": "#/components/schemas/MessageContent"
          },
          "text": {
            "$ref": "#/components/schemas/MessageContent"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            }
          },
          "metadata": {
            "$ref": "#/components/schemas/MessageMetadata"
          },
          "server": {
            "type": "string"
          }
        }
      },
      "MessageAddress": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "MessageContent": {
        "type": "object",
        "properties": {
          "links": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Link"
            }
          },
          "codes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Code"
            }
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Image"
            }
          },
          "body": {
            "type": "string"
          }
        }
      },
      "Link": {
        "type": "object",
        "properties": {
          "href": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      },
      "Code": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string"
          }
        }
      },
      "Image": {
        "type": "object",
        "properties": {
          "src": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          }
        }
      },
      "Attachment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "contentType": {
            "type": "string"
          },
          "fileName": {
            "type": "string"
          },
          "contentId": {
            "type": "string"
          },
          "length": {
            "type": "integer"
          }
        }
      },
      "MessageMetadata": {
        "type": "object",
        "properties": {
          "headers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageHeader"
            }
          }
        }
      },
      "MessageHeader": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "MessageList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageSummary"
            }
          }
        }
      },
      "MessageSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "from": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageAddress"
            }
          },
          "to": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageAddress"
            }
          },
          "subject": {
            "type": "string"
          },
          "received": {
            "type": "string",
            "format": "date-time"
          },
          "server": {
            "type": "string"
          }
        }
      },
      "SearchCriteria": {
        "type": "object",
        "properties": {
          "sentFrom": {
            "type": "string"
          },
          "sentTo": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "match": {
            "type": "string",
            "enum": [
              "ALL",
              "ANY"
            ]
          }
        }
      },
      "MessageCreateRequest": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "send": {
            "type": "boolean"
          },
          "subject": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AttachmentInput"
            }
          }
        },
        "required": [
          "to"
        ]
      },
      "AttachmentInput": {
        "type": "object",
        "properties": {
          "fileName": {
            "type": "string"
          },
          "contentType": {
            "type": "string"
          },
          "content": {
            "type": "string",
            "description": "Base64 encoded content"
          }
        }
      },
      "MessageForwardRequest": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "html": {
            "type": "string"
          }
        },
        "required": [
          "to"
        ]
      },
      "MessageReplyRequest": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "html": {
            "type": "string"
          }
        }
      },
      "SpamAnalysisResult": {
        "type": "object",
        "properties": {
          "score": {
            "type": "number"
          },
          "result": {
            "$ref": "#/components/schemas/SpamFilterResults"
          }
        }
      },
      "SpamFilterResults": {
        "type": "object",
        "properties": {
          "spamAssassin": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SpamAssassinRule"
            }
          }
        }
      },
      "SpamAssassinRule": {
        "type": "object",
        "properties": {
          "score": {
            "type": "number"
          },
          "rule": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "OtpResult": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "PreviewList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Preview"
            }
          }
        }
      },
      "Preview": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "emailClient": {
            "type": "string"
          },
          "disableImages": {
            "type": "boolean"
          }
        }
      },
      "PreviewRequest": {
        "type": "object",
        "properties": {
          "emailClient": {
            "type": "string"
          },
          "disableImages": {
            "type": "boolean"
          }
        },
        "required": [
          "emailClient"
        ]
      },
      "Device": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "DeviceList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Device"
            }
          }
        }
      },
      "UsageAccountLimits": {
        "type": "object",
        "properties": {
          "servers": {
            "type": "integer"
          },
          "users": {
            "type": "integer"
          },
          "email": {
            "type": "integer"
          },
          "sms": {
            "type": "integer"
          }
        }
      },
      "UsageTransactionList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UsageTransaction"
            }
          }
        }
      },
      "UsageTransaction": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "email": {
            "type": "integer"
          },
          "sms": {
            "type": "integer"
          }
        }
      }
    }
  },
