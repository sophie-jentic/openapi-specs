{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "cielo-24 API",
    "description": "cielo24 solves accessibility, multimedia search, discovery and video intelligence needs. Our searchable captions™, media data solutions transform your multimedia files to become as searchable as text by adding rich media data to optimize, tag and index your video and media assets",
    "contact": {
      "url": "https://cielo24.com/support/developers/"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/fehguy/cielo24-api/1.0.0"
  },
  "paths": {
    "/account/login": {
      "get": {
        "operationId": "login",
        "tags": [
          "Account"
        ],
        "description": "logs into the system",
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "description": "username",
            "type": "string"
          },
          {
            "name": "password",
            "in": "query",
            "description": "password",
            "type": "string"
          },
          {
            "name": "v",
            "in": "query",
            "description": "api version",
            "type": "integer",
            "format": "int32",
            "default": 1
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "$ref": "#/definitions/ApiTokenResponse"
            }
          }
        }
      }
    },
    "/job/new": {
      "get": {
        "operationId": "createJob",
        "tags": [
          "Job"
        ],
        "description": "creates a new job",
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "description": "The API token used for this session",
            "type": "string"
          },
          {
            "name": "v",
            "in": "query",
            "description": "version of api to use",
            "enum": [
              1
            ],
            "required": true,
            "type": "integer",
            "format": "int32"
          }
        ],
        "responses": {
          "200": {
            "description": "New job response",
            "schema": {
              "$ref": "#/definitions/JobResponse"
            }
          }
        }
      }
    },
    "/job/add_media": {
      "get": {
        "operationId": "addMediaToJob",
        "tags": [
          "Job"
        ],
        "description": "adds media to a job",
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "description": "token to use",
            "type": "string",
            "required": true
          },
          {
            "name": "job_id",
            "in": "query",
            "description": "job id to use",
            "type": "string",
            "required": true
          },
          {
            "name": "v",
            "in": "query",
            "description": "version of api to use",
            "enum": [
              1
            ],
            "required": true,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "media_url",
            "in": "query",
            "description": "URL of external media to add to job",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "New job response",
            "schema": {
              "$ref": "#/definitions/TaskIdResponse"
            }
          }
        }
      }
    },
    "/job/get_elementlist": {
      "get": {
        "operationId": "getMediaIntelligence",
        "tags": [
          "Job"
        ],
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "description": "token to use",
            "type": "string",
            "required": true
          },
          {
            "name": "job_id",
            "in": "query",
            "description": "job id to use",
            "type": "string",
            "required": true
          },
          {
            "name": "v",
            "in": "query",
            "description": "version of api to use",
            "enum": [
              1
            ],
            "required": true,
            "type": "integer",
            "format": "int32"
          }
        ],
        "responses": {
          "200": {
            "description": "start job response",
            "schema": {
              "$ref": "#/definitions/MediaIntelligence"
            }
          }
        },
        "description": "GET /job/get_elementlist"
      }
    },
    "/job/perform_transcription": {
      "get": {
        "operationId": "startJob",
        "tags": [
          "Job"
        ],
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "description": "token to use",
            "type": "string",
            "required": true
          },
          {
            "name": "job_id",
            "in": "query",
            "description": "job id to use",
            "type": "string",
            "required": true
          },
          {
            "name": "v",
            "in": "query",
            "description": "version of api to use",
            "enum": [
              1
            ],
            "required": true,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "target_language",
            "in": "query",
            "description": "language to transcribe to",
            "type": "string",
            "enum": [
              "en"
            ]
          },
          {
            "name": "transcription_fidelity",
            "in": "query",
            "description": "fidelity of output",
            "type": "string",
            "default": "MECHANICAL",
            "enum": [
              "MECHANICAL",
              "EXTERNAL",
              "PREMIUM",
              "PROFESSIONAL"
            ]
          },
          {
            "name": "priority",
            "in": "query",
            "description": "how important is this one",
            "type": "string",
            "enum": [
              "STANDARD",
              "PRIORITY"
            ],
            "default": "STANDARD"
          },
          {
            "name": "generate_media_intelligence_iwp",
            "in": "query",
            "description": "sets media intelligence",
            "type": "string",
            "required": false,
            "enum": [
              "PREMIUM",
              "INTERIM_PROFESSIONAL",
              "PROFESSIONAL",
              "SPEAKER_ID",
              "FINAL",
              "MECHANICAL",
              "CUSTOMER_APPROVED_RETURN",
              "CUSTOMER_APPROVED_TRANSLATION"
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "start job response",
            "schema": {
              "$ref": "#/definitions/TaskIdResponse"
            }
          }
        },
        "description": "GET /job/perform_transcription"
      }
    },
    "/job/get_transcript": {
      "get": {
        "operationId": "getTranscript",
        "tags": [
          "Job"
        ],
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "description": "token to use",
            "type": "string",
            "required": true
          },
          {
            "name": "job_id",
            "in": "query",
            "description": "job id to use",
            "type": "string",
            "required": true
          },
          {
            "name": "v",
            "in": "query",
            "description": "version of api to use",
            "enum": [
              1
            ],
            "required": true,
            "type": "integer",
            "format": "int32"
          }
        ],
        "responses": {
          "200": {
            "description": "get",
            "schema": {
              "type": "string"
            }
          },
          "400": {
            "description": "transcript not available",
            "schema": {
              "$ref": "#/definitions/TranscriptError"
            }
          }
        },
        "description": "GET /job/get_transcript"
      }
    },
    "/job/delete": {
      "get": {
        "operationId": "deleteJob",
        "tags": [
          "Job"
        ],
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
