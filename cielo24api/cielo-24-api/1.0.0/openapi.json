            "type": "string",
            "required": true
          },
          {
            "name": "job_id",
            "in": "query",
            "description": "job id to use",
            "type": "string",
            "required": true
          },
          {
            "name": "v",
            "in": "query",
            "description": "version of api to use",
            "enum": [
              1
            ],
            "required": true,
            "type": "integer",
            "format": "int32"
          }
        ],
        "responses": {
          "200": {
            "description": "get",
            "schema": {
              "$ref": "#/definitions/TaskIdResponse"
            }
          }
        },
        "description": "GET /job/delete"
      }
    },
    "/job/info": {
      "get": {
        "operationId": "getJobStatus",
        "tags": [
          "Job"
        ],
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "description": "token to use",
            "type": "string",
            "required": true
          },
          {
            "name": "job_id",
            "in": "query",
            "description": "job id to use",
            "type": "string",
            "required": true
          },
          {
            "name": "v",
            "in": "query",
            "description": "version of api to use",
            "enum": [
              1
            ],
            "required": true,
            "type": "integer",
            "format": "int32"
          }
        ],
        "responses": {
          "200": {
            "description": "job status",
            "schema": {
              "$ref": "#/definitions/JobStatus"
            }
          }
        },
        "description": "GET /job/info"
      }
    }
  },
