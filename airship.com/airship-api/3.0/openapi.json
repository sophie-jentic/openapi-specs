  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Auth using App Key as username and either Master Secret or App Secret as password."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string"
          },
          "error_code": {
            "type": "integer"
          },
          "details": {
            "type": "object"
          }
        }
      },
      "PushRequest": {
        "type": "object",
        "properties": {
          "audience": {
            "type": "object",
            "description": "Audience selector (all, tag, channel, named_user, etc.)"
          },
          "notification": {
            "type": "object",
            "description": "Notification payload",
            "properties": {
              "alert": {
                "type": "string"
              }
            }
          },
          "device_types": {
            "oneOf": [
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "string",
                "enum": [
                  "all"
                ]
              }
            ]
          }
        },
        "required": [
          "audience",
          "notification",
          "device_types"
        ]
      },
      "PushResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "operation_id": {
            "type": "string"
          },
          "push_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "message_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "content_urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ChannelListResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "channels": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Channel"
            }
          },
          "next_page": {
            "type": "string"
          }
        }
      },
      "ChannelResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "channel": {
            "$ref": "#/components/schemas/Channel"
          }
        }
      },
      "Channel": {
        "type": "object",
        "properties": {
          "channel_id": {
            "type": "string"
          },
          "device_type": {
            "type": "string"
          },
          "installed": {
            "type": "boolean"
          },
          "opt_in": {
            "type": "boolean"
          },
          "push_address": {
            "type": "string"
          },
          "named_user_id": {
            "type": "string"
          },
          "alias": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tag_groups": {
            "type": "object"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "last_registration": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TagRequest": {
        "type": "object",
        "properties": {
          "audience": {
            "type": "object",
            "properties": {
              "ios_channel": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "android_channel": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "add": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "remove": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "set": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "NamedUserListResponse": {
        "type": "object",
        "properties": {
