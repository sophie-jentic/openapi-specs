                  "channel_id",
                  "device_type"
                ],
                "properties": {
                  "channel_id": {
                    "type": "string"
                  },
                  "device_type": {
                    "type": "string"
                  },
                  "named_user_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Disassociation complete",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
