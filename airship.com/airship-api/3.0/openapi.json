{
  "openapi": "3.0.3",
  "info": {
    "title": "Airship REST API",
    "version": "3.0",
    "description": "Airship provides a REST API for sending push notifications, managing channels, named users, segments, and more. The API uses HTTP Basic Auth with app key and master secret.",
    "x-jentic-source-url": "https://www.airship.com/docs/developer/rest-api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://go.urbanairship.com/api",
      "description": "Airship API server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Push",
      "description": "Send push notifications"
    },
    {
      "name": "Channels",
      "description": "Manage device channels"
    },
    {
      "name": "Named Users",
      "description": "Manage named users"
    },
    {
      "name": "Segments",
      "description": "Manage audience segments"
    },
    {
      "name": "Tags",
      "description": "Manage tags and tag groups"
    },
    {
      "name": "Feeds",
      "description": "Event feeds and response reporting"
    }
  ],
  "paths": {
    "/push": {
      "post": {
        "operationId": "sendPush",
        "summary": "Send a push notification",
        "description": "Send a push notification to a specified audience. Accepts an array of push objects, each with audience, notification, and device_types.",
        "tags": [
          "Push"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Push accepted",
            "content": {
              "application/vnd.urbanairship+json; version=3;": {
                "schema": {
                  "$ref": "#/components/schemas/PushResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/push/validate": {
      "post": {
        "operationId": "validatePush",
        "summary": "Validate a push payload",
        "description": "Validate a push payload without sending it. Returns 200 if valid.",
        "tags": [
          "Push"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Valid push payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/channels": {
      "get": {
        "operationId": "listChannels",
        "summary": "List channels",
        "description": "List all channels associated with the application.",
        "tags": [
          "Channels"
        ],
        "parameters": [
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "UUID of the first channel to return (for pagination)"
