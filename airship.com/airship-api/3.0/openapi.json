    "/reports/responses/list": {
      "get": {
        "operationId": "listResponseReports",
        "summary": "List response reports",
        "description": "Get a listing of push response reports.",
        "tags": [
          "Feeds"
        ],
        "parameters": [
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start datetime"
          },
          {
            "name": "end",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End datetime"
          }
        ],
        "responses": {
          "200": {
            "description": "Response reports"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
