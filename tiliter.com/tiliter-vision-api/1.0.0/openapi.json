{
  "openapi": "3.0.3",
  "info": {
    "title": "Tiliter Vision AI - Agent API",
    "version": "1.0.0",
    "description": "AI-powered vision analysis API for retail and industrial applications. Supports multiple agents for cleanliness scoring, damage detection, label reading, object counting, and more.",
    "x-jentic-source-url": "https://api.ai.vision.tiliter.com/docs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.ai.vision.tiliter.com"
    }
  ],
  "paths": {
    "/api/v1/inference/{agent_code}": {
      "post": {
        "operationId": "runInference",
        "summary": "Execute AI vision agent",
        "description": "Execute AI vision analysis using the specified agent",
        "tags": [
          "Inference"
        ],
        "parameters": [
          {
            "name": "agent_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "cleanliness-score",
                "damage-detector",
                "label-reader-validator",
                "object-counter",
                "specific-object-validator",
                "receipt-processor",
                "text-extractor"
              ]
            },
            "description": "Agent type to use"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InferenceResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "InferenceResult": {
        "type": "object",
        "properties": {
          "agent_code": {
            "type": "string"
          },
          "result": {
            "type": "object"
          },
          "confidence": {
            "type": "number"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "X-API-Key",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Inference"
    }
  ]
}
