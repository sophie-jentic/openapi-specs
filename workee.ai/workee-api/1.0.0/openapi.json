{
  "openapi": "3.0.3",
  "info": {
    "title": "Workee API",
    "version": "1.0.0",
    "description": "Workee API for managing Zapier webhook connections and triggers.",
    "x-jentic-source-url": "https://workee.net/zapier-api-documentation.html",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://workee.ai"
    }
  ],
  "paths": {
    "/zapier/connections/test": {
      "get": {
        "operationId": "testConnection",
        "summary": "Test Zapier connection",
        "tags": [
          "Connections"
        ],
        "responses": {
          "200": {
            "description": "Valid connection"
          },
          "400": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error"
          }
        },
        "description": "Test Zapier connection"
      }
    },
    "/zapier/connections/subscribe": {
      "post": {
        "operationId": "subscribe",
        "summary": "Subscribe trigger",
        "tags": [
          "Connections"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "targetUrl": {
                    "type": "string"
                  },
                  "triggerType": {
                    "type": "string"
                  }
                },
                "required": [
                  "targetUrl",
                  "triggerType"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Subscribed successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Subscribe trigger"
      }
    },
    "/zapier/connections/unsubscribe": {
      "post": {
        "operationId": "unsubscribe",
        "summary": "Unsubscribe trigger",
        "tags": [
          "Connections"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "targetUrl": {
                    "type": "string"
                  },
                  "triggerType": {
                    "type": "string"
                  }
                },
                "required": [
                  "targetUrl",
                  "triggerType"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Unsubscribed successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Unsubscribe trigger"
      }
    },
    "/zapier/connections/sample-data": {
      "get": {
        "operationId": "getSampleData",
        "summary": "Get sample data",
        "tags": [
          "Connections"
        ],
        "parameters": [
          {
            "name": "triggerType",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get sample data"
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Connections"
    }
  ]
}
