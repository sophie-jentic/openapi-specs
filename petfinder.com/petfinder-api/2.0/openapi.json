          {
            "name": "distance",
            "in": "query",
            "description": "Distance in miles from location (max 500, default 100)",
            "schema": {
              "type": "integer",
              "maximum": 500,
              "default": 100
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "2-letter US state abbreviation or CA province",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "country",
            "in": "query",
            "description": "Country code (US or CA)",
            "schema": {
              "type": "string",
              "enum": [
                "US",
                "CA"
              ]
            }
          },
          {
            "name": "query",
            "in": "query",
            "description": "Full-text search query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order: recent, -recent, distance, -distance",
            "schema": {
              "type": "string",
              "enum": [
                "recent",
                "-recent",
                "distance",
                "-distance"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results per page (default 20, max 100)",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with organization listings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganizationsResponse"
