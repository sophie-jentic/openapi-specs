{
  "openapi": "3.0.3",
  "info": {
    "title": "Petfinder API",
    "description": "The Petfinder API v2 provides access to Petfinder's database of adoptable pets and animal welfare organizations. It allows searching for pets by type, breed, size, gender, age, color, coat, status, location, and more. Authentication uses OAuth 2.0 client credentials flow.",
    "version": "2.0",
    "contact": {
      "name": "Petfinder",
      "url": "https://www.petfinder.com/developers/"
    },
    "termsOfService": "https://www.petfinder.com/developers/terms-of-service/"
  },
  "servers": [
    {
      "url": "https://api.petfinder.com/v2",
      "description": "Petfinder API v2 production server"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/oauth2/token": {
      "post": {
        "operationId": "getOAuthToken",
        "summary": "Get OAuth2 access token",
        "description": "Obtain an access token using client credentials grant type. The token is valid for 3600 seconds (1 hour).",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type",
                  "client_id",
                  "client_secret"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "client_credentials"
                    ],
                    "description": "OAuth2 grant type"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Your Petfinder API key"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Your Petfinder API secret"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful token response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid client credentials"
          }
        },
        "tags": [
          "oauth2"
        ]
      }
    },
    "/animals": {
      "get": {
        "operationId": "getAnimals",
        "summary": "Search animals",
        "description": "Search for adoptable animals. Returns paginated results with various filter options.",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "description": "Type of animal (e.g., dog, cat, rabbit, small-furry, horse, bird, scales-fins-other, barnyard)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "breed",
            "in": "query",
            "description": "Breed name(s), comma-separated for multiple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Size: small, medium, large, xlarge. Comma-separated for multiple.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "gender",
            "in": "query",
            "description": "Gender: male, female, unknown. Comma-separated for multiple.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "age",
            "in": "query",
            "description": "Age: baby, young, adult, senior. Comma-separated for multiple.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "color",
            "in": "query",
            "description": "Color of the animal",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "coat",
            "in": "query",
            "description": "Coat length: short, medium, long, wire, hairless, curly. Comma-separated for multiple.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Adoption status: adoptable, adopted, found",
            "schema": {
              "type": "string",
              "enum": [
                "adoptable",
                "adopted",
                "found"
              ]
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "Name of the animal",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "organization",
            "in": "query",
            "description": "Organization ID(s), comma-separated for multiple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "good_with_children",
            "in": "query",
            "description": "Filter by good with children",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "good_with_dogs",
            "in": "query",
            "description": "Filter by good with dogs",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "good_with_cats",
            "in": "query",
            "description": "Filter by good with cats",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "house_trained",
            "in": "query",
            "description": "Filter by house trained status",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "declawed",
            "in": "query",
            "description": "Filter by declawed status",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "special_needs",
            "in": "query",
            "description": "Filter by special needs",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Location (city, state; latitude,longitude; or postal code)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "distance",
            "in": "query",
            "description": "Distance in miles from location (requires location parameter, max 500, default 100)",
            "schema": {
              "type": "integer",
              "maximum": 500,
              "default": 100
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order: recent, -recent, distance, -distance, random",
            "schema": {
              "type": "string",
              "enum": [
                "recent",
                "-recent",
                "distance",
                "-distance",
                "random"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number (default 1)",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results per page (default 20, max 100)",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with animal listings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimalsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "animals"
        ]
      }
    },
    "/animals/{id}": {
      "get": {
        "operationId": "getAnimal",
        "summary": "Get a specific animal",
        "description": "Retrieve details for a specific animal by ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Animal ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with animal details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SingleAnimalResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Animal not found"
          }
        },
        "tags": [
          "animals"
        ]
      }
    },
    "/types": {
      "get": {
        "operationId": "getAnimalTypes",
        "summary": "Get animal types",
        "description": "Returns all available animal types (e.g., Dog, Cat, Rabbit).",
        "responses": {
          "200": {
            "description": "Successful response with animal types",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TypesResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "types"
        ]
      }
    },
    "/types/{type}": {
      "get": {
        "operationId": "getAnimalType",
        "summary": "Get a specific animal type",
        "description": "Returns details for a specific animal type including available coats, colors, and genders.",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "description": "Animal type name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with type details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SingleTypeResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Type not found"
          }
        },
        "tags": [
          "types"
        ]
      }
    },
    "/types/{type}/breeds": {
      "get": {
        "operationId": "getBreeds",
        "summary": "Get breeds for a type",
        "description": "Returns all available breeds for a specific animal type.",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "description": "Animal type name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with breed list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BreedsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Type not found"
          }
        },
        "tags": [
          "types"
        ]
      }
    },
    "/organizations": {
      "get": {
        "operationId": "getOrganizations",
        "summary": "Search organizations",
