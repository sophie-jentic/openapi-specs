{
  "openapi": "3.0.3",
  "info": {
    "title": "Broadcom Layer7 API Gateway Management API",
    "version": "1.0.0",
    "description": "Broadcom Layer7 API Gateway REST Management API (RESTMAN) for managing gateway entities including services, policies, cluster-wide properties, certificates, JDBC connections, encapsulated assertions, and other gateway configuration objects.",
    "x-jentic-source-url": "https://techdocs.broadcom.com/us/en/ca-enterprise-software/layer7-api-management/api-gateway/11-0.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{gateway-host}:8443/restman/1.0",
      "variables": {
        "gateway-host": {
          "default": "gateway.example.com"
        }
      }
    }
  ],
  "paths": {
    "/services": {
      "get": {
        "operationId": "listServices",
        "summary": "List published services",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of services",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List published services"
      },
      "post": {
        "operationId": "createService",
        "summary": "Create a service",
        "tags": [
          "Services"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ServiceInput"
              }
            },
            "application/xml": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a service"
      }
    },
