            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Latitude"
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Longitude"
          },
          {
            "name": "distance",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25
            },
            "description": "Distance in miles"
          },
          {
            "name": "API_KEY",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Observation"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/aq/observation/monitoringSite/current": {
      "get": {
        "operationId": "getCurrentObservationsByMonitoringSite",
        "summary": "Get current observations by monitoring site",
        "description": "Returns current air quality observations for a given monitoring site.",
        "tags": [
          "Observations"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "required": true,
