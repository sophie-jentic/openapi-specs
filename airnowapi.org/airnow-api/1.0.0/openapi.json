{
  "openapi": "3.0.3",
  "info": {
    "title": "AirNow API",
    "version": "1.0.0",
    "description": "The AirNow API provides access to real-time and forecast air quality data for the United States. Data includes Air Quality Index (AQI) observations, forecasts, and historical data by zip code, latitude/longitude, and monitoring site.",
    "x-jentic-source-url": "https://docs.airnowapi.org/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.airnowapi.org"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Observations",
      "description": "Current air quality observations"
    },
    {
      "name": "Forecasts",
      "description": "Air quality forecasts"
    },
    {
      "name": "Historical",
      "description": "Historical air quality data"
    }
  ],
  "paths": {
    "/aq/observation/zipCode/current": {
      "get": {
        "operationId": "getCurrentObservationsByZipCode",
        "summary": "Get current observations by zip code",
        "description": "Returns current air quality observations for a given zip code.",
        "tags": [
          "Observations"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "application/json",
                "text/csv",
                "application/xml"
              ]
            },
            "description": "Output format"
          },
          {
            "name": "zipCode",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Zip code"
          },
          {
            "name": "distance",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25
            },
            "description": "Distance in miles to search"
          },
          {
            "name": "API_KEY",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Observation"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/aq/observation/latLong/current": {
      "get": {
        "operationId": "getCurrentObservationsByLatLong",
