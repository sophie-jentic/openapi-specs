          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/aq/data": {
      "get": {
        "operationId": "getHistoricalObservationsByZipCode",
        "summary": "Get historical observations by zip code",
        "description": "Returns historical air quality observations for a given zip code and date range.",
        "tags": [
          "Historical"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "application/json",
                "text/csv",
                "application/xml"
              ]
            }
          },
          {
            "name": "zipCode",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startDate",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date (YYYY-MM-DDT00-0000)"
          },
          {
            "name": "endDate",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date (YYYY-MM-DDT00-0000)"
          },
          {
            "name": "parameters",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "OZONE",
                "PM25",
                "PM10",
                "CO",
                "NO2",
                "SO2"
              ]
            },
            "description": "Air quality parameter"
          },
          {
            "name": "distance",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25
            }
          },
          {
            "name": "API_KEY",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Observation"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "API_KEY",
        "description": "AirNow API key. Register at https://docs.airnowapi.org/"
      }
    },
    "schemas": {
      "Observation": {
        "type": "object",
        "properties": {
          "DateObserved": {
            "type": "string",
            "description": "Date of observation"
          },
          "HourObserved": {
            "type": "integer",
            "description": "Hour of observation"
          },
          "LocalTimeZone": {
            "type": "string",
            "description": "Local time zone"
          },
          "ReportingArea": {
            "type": "string",
            "description": "Name of reporting area"
          },
          "StateCode": {
            "type": "string",
            "description": "State code"
          },
          "Latitude": {
            "type": "number",
            "format": "double"
          },
          "Longitude": {
            "type": "number",
            "format": "double"
          },
          "ParameterName": {
            "type": "string",
            "description": "Pollutant name (e.g., O3, PM2.5)"
          },
          "AQI": {
            "type": "integer",
            "description": "Air Quality Index value"
          },
          "Category": {
            "type": "object",
            "properties": {
              "Number": {
                "type": "integer",
                "description": "Category number (1-6)"
              },
              "Name": {
                "type": "string",
                "description": "Category name (e.g., Good, Moderate)"
              }
            }
          }
        }
      },
      "Forecast": {
        "type": "object",
        "properties": {
          "DateIssue": {
            "type": "string"
          },
          "DateForecast": {
            "type": "string"
          },
          "ReportingArea": {
            "type": "string"
          },
          "StateCode": {
            "type": "string"
          },
          "Latitude": {
            "type": "number",
            "format": "double"
          },
          "Longitude": {
            "type": "number",
            "format": "double"
          },
          "ParameterName": {
            "type": "string"
          },
          "AQI": {
            "type": "integer"
          },
          "Category": {
            "type": "object",
            "properties": {
              "Number": {
                "type": "integer"
              },
              "Name": {
                "type": "string"
              }
            }
          },
          "ActionDay": {
            "type": "boolean"
          },
          "Discussion": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "WebServiceError": {
            "type": "string"
          },
          "Message": {
            "type": "string"
          }
        }
      }
    }
  }
}
