{
  "openapi": "3.0.3",
  "info": {
    "title": "Cloudinary API",
    "version": "1.0.0",
    "description": "Cloudinary media management API for uploading, transforming, optimizing, and delivering images and videos. Includes Upload API, Admin API, and Search API.",
    "x-jentic-source-url": "https://cloudinary.com/documentation/image_upload_api_reference",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.cloudinary.com/v1_1/{cloud_name}",
      "variables": {
        "cloud_name": {
          "default": "demo"
        }
      }
    }
  ],
  "paths": {
    "/image/upload": {
      "post": {
        "operationId": "uploadImage",
        "summary": "Upload an image",
        "description": "Upload an image to Cloudinary. Supports URL, file, base64, or multipart upload.",
        "tags": [
          "Upload"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "description": "File to upload (URL, path, or base64)"
                  },
                  "upload_preset": {
                    "type": "string"
                  },
                  "public_id": {
                    "type": "string"
                  },
                  "folder": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "string"
                  },
                  "transformation": {
                    "type": "string"
                  },
                  "eager": {
                    "type": "string"
                  },
                  "notification_url": {
                    "type": "string"
                  },
                  "overwrite": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/video/upload": {
      "post": {
        "operationId": "uploadVideo",
        "summary": "Upload a video",
        "tags": [
          "Upload"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string"
                  },
                  "upload_preset": {
                    "type": "string"
                  },
                  "public_id": {
                    "type": "string"
                  },
                  "resource_type": {
                    "type": "string",
                    "default": "video"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Upload a video"
      }
    },
