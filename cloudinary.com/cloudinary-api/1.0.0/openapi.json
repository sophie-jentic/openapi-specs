    "/image/explicit": {
      "post": {
        "operationId": "explicitImage",
        "summary": "Apply operations to existing image",
        "description": "Apply eager transformations, set access control, or update metadata on an existing uploaded image.",
        "tags": [
          "Upload"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "public_id": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string"
                  },
                  "eager": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "string"
                  }
                },
                "required": [
                  "public_id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
