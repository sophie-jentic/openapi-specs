            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "expression": {
                    "type": "string"
                  },
                  "max_results": {
                    "type": "integer"
                  },
                  "next_cursor": {
                    "type": "string"
                  },
                  "sort_by": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "with_field": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
