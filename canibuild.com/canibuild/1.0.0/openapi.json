{
  "openapi": "3.0.3",
  "info": {
    "title": "canibuild API",
    "description": "API for construction permit and zoning information",
    "version": "1.0.0",
    "x-jentic-source-url": "https://canibuild.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.canibuild.com"
    }
  ],
