                  "projectType": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "permits"
        ]
      }
    },
    "/zoning": {
      "get": {
        "operationId": "getZoning",
        "summary": "Get zoning information",
        "description": "Get zoning information",
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
