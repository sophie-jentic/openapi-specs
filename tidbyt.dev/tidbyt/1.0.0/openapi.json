{
  "openapi": "3.0.3",
  "info": {
    "title": "Tidbyt API",
    "version": "1.0.0",
    "description": "API for managing Tidbyt devices and app installations",
    "x-jentic-source-url": "https://tidbyt.dev/docs/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.tidbyt.com/v0",
      "description": "Tidbyt API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/devices": {
      "get": {
        "summary": "List Devices",
        "operationId": "listDevices",
        "description": "Retrieve a list of registered Tidbyt devices",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Device"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "devices"
        ]
      }
    },
    "/devices/{deviceId}": {
      "get": {
        "summary": "Get Device",
        "operationId": "getDevice",
        "description": "Retrieve a specific device by ID",
        "parameters": [
          {
            "name": "deviceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Device"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "devices"
        ]
      }
    },
    "/devices/{deviceId}/push": {
      "post": {
        "summary": "Push to Device",
        "operationId": "pushToDevice",
        "description": "Push a rendered image to a device",
        "parameters": [
          {
            "name": "deviceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "devices"
        ]
      }
    },
    "/devices/{deviceId}/installations": {
      "get": {
        "summary": "List Installations",
        "operationId": "listInstallations",
        "description": "List app installations on a device",
        "parameters": [
          {
            "name": "deviceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Installation"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "devices"
        ]
      },
      "post": {
        "summary": "Create Installation",
        "operationId": "createInstallation",
        "description": "Create a new app installation on a device",
        "parameters": [
          {
            "name": "deviceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InstallationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Installation"
                }
              }
            }
          }
        },
        "tags": [
          "devices"
        ]
      }
    },
    "/devices/{deviceId}/installations/{installationId}": {
      "get": {
        "summary": "Get Installation",
        "operationId": "getInstallation",
        "description": "Get a specific installation",
        "parameters": [
          {
            "name": "deviceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "installationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Installation"
                }
              }
            }
          }
        },
        "tags": [
          "devices"
        ]
      },
      "put": {
        "summary": "Update Installation",
        "operationId": "updateInstallation",
        "description": "Update an installation",
        "parameters": [
          {
            "name": "deviceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "installationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InstallationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "tags": [
          "devices"
        ]
      },
      "delete": {
        "summary": "Delete Installation",
        "operationId": "deleteInstallation",
        "description": "Remove an installation from a device",
        "parameters": [
          {
            "name": "deviceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "installationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        },
        "tags": [
          "devices"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API token from Tidbyt account"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Device": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "last_seen": {
            "type": "string",
            "format": "date-time"
          },
          "brightness": {
            "type": "integer"
          }
        }
      },
      "PushRequest": {
        "type": "object",
        "required": [
          "image"
        ],
        "properties": {
          "image": {
            "type": "string",
            "description": "Base64-encoded WebP image"
          },
          "background": {
            "type": "boolean"
          }
        }
      },
      "Installation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "app_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "config": {
            "type": "object"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "InstallationRequest": {
        "type": "object",
        "required": [
          "app_id"
        ],
        "properties": {
          "app_id": {
            "type": "string"
          },
          "config": {
            "type": "object"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "devices"
    }
  ]
}
