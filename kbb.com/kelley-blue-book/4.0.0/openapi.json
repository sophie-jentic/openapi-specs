{
  "openapi": "3.0.3",
  "info": {
    "title": "Kelley Blue Book API",
    "description": "Access vehicle information, pricing, configuration, and valuation data from Kelley Blue Book. Includes vehicle makes, models, trims, pricing, and VIN decoding.",
    "version": "4.0.0",
    "x-jentic-source-url": "http://developer.kbb.com/#!/data/1-Default",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.kbb.com/v4",
      "description": "KBB API Production Server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Vehicles",
      "description": "Vehicle makes, models, and trims"
    },
    {
      "name": "Pricing",
      "description": "Vehicle pricing and valuations"
    },
    {
      "name": "VIN",
      "description": "VIN decoding and lookup"
    },
    {
      "name": "Configuration",
      "description": "Vehicle configuration options"
    }
  ],
  "paths": {
    "/years": {
      "get": {
        "tags": [
          "Vehicles"
        ],
        "summary": "List available years",
        "description": "Retrieve a list of available vehicle model years.",
        "operationId": "listYears",
        "responses": {
          "200": {
            "description": "List of years",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/YearsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/makes": {
      "get": {
        "tags": [
          "Vehicles"
        ],
        "summary": "List vehicle makes",
        "description": "Retrieve all vehicle makes, optionally filtered by year.",
        "operationId": "listMakes",
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "required": false,
            "description": "Filter makes by model year",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of vehicle makes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MakesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/models": {
      "get": {
        "tags": [
          "Vehicles"
        ],
        "summary": "List vehicle models",
        "description": "Retrieve vehicle models filtered by make and optionally by year.",
        "operationId": "listModels",
        "parameters": [
          {
            "name": "makeId",
            "in": "query",
            "required": true,
            "description": "The make ID to filter models by",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "year",
            "in": "query",
            "required": false,
            "description": "Filter models by year",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of vehicle models",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/trims": {
      "get": {
        "tags": [
          "Vehicles"
        ],
        "summary": "List vehicle trims",
        "description": "Retrieve available trims for a specific model.",
        "operationId": "listTrims",
        "parameters": [
          {
            "name": "modelId",
            "in": "query",
            "required": true,
            "description": "The model ID to filter trims by",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "year",
            "in": "query",
            "required": true,
            "description": "The model year",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of vehicle trims",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrimsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/vehicles/{vehicleId}": {
      "get": {
        "tags": [
          "Vehicles"
        ],
        "summary": "Get vehicle details",
        "description": "Retrieve detailed information about a specific vehicle by its ID.",
        "operationId": "getVehicle",
        "parameters": [
          {
            "name": "vehicleId",
            "in": "path",
            "required": true,
            "description": "Unique vehicle identifier",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Vehicle details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VehicleDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Vehicle not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/vehicles/{vehicleId}/configuration": {
      "get": {
        "tags": [
          "Configuration"
        ],
        "summary": "Get vehicle configuration options",
        "description": "Retrieve available configuration options including colors, packages, and options for a vehicle.",
        "operationId": "getVehicleConfiguration",
        "parameters": [
          {
            "name": "vehicleId",
            "in": "path",
            "required": true,
            "description": "Unique vehicle identifier",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Vehicle configuration options",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigurationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/pricing/fair-market-range": {
      "get": {
        "tags": [
          "Pricing"
        ],
        "summary": "Get fair market range pricing",
        "description": "Retrieve the fair market price range for a vehicle based on configuration, mileage, and condition.",
        "operationId": "getFairMarketRange",
        "parameters": [
          {
            "name": "vehicleId",
            "in": "query",
            "required": true,
            "description": "Unique vehicle identifier",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "mileage",
            "in": "query",
            "required": false,
            "description": "Vehicle mileage in miles",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "condition",
            "in": "query",
            "required": false,
            "description": "Vehicle condition",
            "schema": {
              "type": "string",
              "enum": [
                "excellent",
                "very-good",
                "good",
                "fair"
              ]
            }
          },
          {
            "name": "zipCode",
            "in": "query",
            "required": false,
            "description": "ZIP code for regional pricing",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Fair market range pricing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PricingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/pricing/trade-in": {
      "get": {
        "tags": [
          "Pricing"
        ],
        "summary": "Get trade-in value",
        "description": "Retrieve the trade-in value for a vehicle.",
        "operationId": "getTradeInValue",
        "parameters": [
          {
            "name": "vehicleId",
            "in": "query",
            "required": true,
            "description": "Unique vehicle identifier",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "mileage",
            "in": "query",
            "required": false,
            "description": "Vehicle mileage in miles",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "condition",
            "in": "query",
            "required": false,
            "description": "Vehicle condition",
            "schema": {
              "type": "string",
              "enum": [
                "excellent",
                "very-good",
                "good",
                "fair"
              ]
            }
          },
          {
            "name": "zipCode",
            "in": "query",
            "required": false,
            "description": "ZIP code for regional pricing",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trade-in value",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PricingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/vin/{vin}": {
      "get": {
        "tags": [
          "VIN"
        ],
        "summary": "Decode VIN",
        "description": "Decode a Vehicle Identification Number (VIN) to retrieve vehicle information.",
        "operationId": "decodeVin",
        "parameters": [
          {
            "name": "vin",
            "in": "path",
            "required": true,
            "description": "17-character Vehicle Identification Number",
            "schema": {
              "type": "string",
              "pattern": "^[A-HJ-NPR-Z0-9]{17}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "VIN decoded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VinResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid VIN format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "VIN not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/vin/batch": {
      "post": {
        "tags": [
          "VIN"
        ],
        "summary": "Batch VIN decode",
        "description": "Decode multiple VINs in a single request.",
        "operationId": "batchDecodeVin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchVinRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch VIN decode results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchVinResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key provided as a query parameter"
      }
    },
    "schemas": {
      "Make": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique make identifier"
          },
          "name": {
            "type": "string",
            "description": "Make name (e.g., Toyota, Ford)"
          }
        }
      },
      "Model": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique model identifier"
          },
          "name": {
            "type": "string",
            "description": "Model name"
          },
          "makeId": {
            "type": "integer",
            "description": "Associated make ID"
          }
        }
      },
      "Trim": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique trim identifier"
          },
          "name": {
            "type": "string",
            "description": "Trim name"
          },
          "modelId": {
            "type": "integer",
            "description": "Associated model ID"
          },
          "year": {
            "type": "integer",
            "description": "Model year"
          }
        }
      },
      "VehicleDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique vehicle identifier"
          },
          "year": {
            "type": "integer",
            "description": "Model year"
          },
          "make": {
            "$ref": "#/components/schemas/Make"
          },
          "model": {
            "$ref": "#/components/schemas/Model"
          },
          "trim": {
            "$ref": "#/components/schemas/Trim"
          },
          "engine": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Engine type"
              },
              "displacement": {
                "type": "string",
                "description": "Engine displacement"
              },
              "horsepower": {
                "type": "integer",
                "description": "Engine horsepower"
              },
              "fuelType": {
                "type": "string",
                "description": "Fuel type"
              }
            }
          },
          "transmission": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Transmission type"
              },
              "speeds": {
                "type": "integer",
                "description": "Number of speeds"
              }
            }
          },
          "drivetrain": {
            "type": "string",
            "description": "Drivetrain type (FWD, RWD, AWD, 4WD)"
          },
          "bodyType": {
            "type": "string",
            "description": "Body type (sedan, SUV, truck, etc.)"
          },
          "msrp": {
            "type": "number",
            "format": "double",
            "description": "Manufacturer's suggested retail price"
          }
        }
      },
      "ConfigurationOption": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Option identifier"
          },
          "name": {
            "type": "string",
            "description": "Option name"
          },
          "category": {
            "type": "string",
            "description": "Option category (color, package, accessory)"
          },
          "price": {
            "type": "number",
            "format": "double",
            "description": "Option price"
          }
        }
      },
      "PriceRange": {
        "type": "object",
        "properties": {
          "low": {
            "type": "number",
            "format": "double",
            "description": "Low end of price range"
          },
          "high": {
            "type": "number",
            "format": "double",
            "description": "High end of price range"
          },
          "average": {
            "type": "number",
            "format": "double",
            "description": "Average price"
          }
        }
      },
      "VinInfo": {
        "type": "object",
        "properties": {
          "vin": {
            "type": "string",
            "description": "The decoded VIN"
          },
          "year": {
            "type": "integer",
            "description": "Model year"
          },
          "make": {
            "type": "string",
            "description": "Vehicle make"
          },
          "model": {
            "type": "string",
            "description": "Vehicle model"
          },
          "trim": {
            "type": "string",
            "description": "Vehicle trim"
          },
          "vehicleId": {
            "type": "integer",
            "description": "KBB vehicle identifier"
          },
          "bodyType": {
            "type": "string",
            "description": "Body type"
          },
          "engine": {
            "type": "string",
            "description": "Engine description"
          },
          "transmission": {
            "type": "string",
            "description": "Transmission description"
          },
          "drivetrain": {
            "type": "string",
            "description": "Drivetrain type"
          }
        }
      },
      "YearsResponse": {
        "type": "object",
        "properties": {
          "years": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        }
      },
      "MakesResponse": {
        "type": "object",
        "properties": {
          "makes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Make"
            }
          }
        }
      },
      "ModelsResponse": {
        "type": "object",
        "properties": {
          "models": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Model"
            }
          }
        }
      },
      "TrimsResponse": {
        "type": "object",
        "properties": {
          "trims": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Trim"
            }
          }
        }
      },
      "VehicleDetailResponse": {
        "type": "object",
        "properties": {
          "vehicle": {
            "$ref": "#/components/schemas/VehicleDetail"
          }
        }
      },
      "ConfigurationResponse": {
        "type": "object",
        "properties": {
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConfigurationOption"
            }
          }
        }
      },
      "PricingResponse": {
        "type": "object",
        "properties": {
          "vehicleId": {
            "type": "integer",
            "description": "Vehicle identifier"
          },
          "priceRange": {
            "$ref": "#/components/schemas/PriceRange"
          },
          "condition": {
            "type": "string",
            "description": "Vehicle condition used for pricing"
          },
          "mileage": {
            "type": "integer",
            "description": "Mileage used for pricing"
          },
          "zipCode": {
            "type": "string",
            "description": "ZIP code used for regional adjustment"
          }
        }
      },
      "VinResponse": {
        "type": "object",
        "properties": {
          "vehicle": {
            "$ref": "#/components/schemas/VinInfo"
          }
        }
      },
      "BatchVinRequest": {
        "type": "object",
        "required": [
          "vins"
        ],
        "properties": {
          "vins": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of VINs to decode",
            "maxItems": 50
          }
        }
      },
      "BatchVinResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VinInfo"
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "vin": {
                  "type": "string"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message"
              }
            }
          }
        }
      }
    }
  }
}
