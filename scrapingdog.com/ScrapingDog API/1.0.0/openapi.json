{
  "openapi": "3.1.0",
  "info": {
    "title": "ScrapingDog API",
    "version": "1.0.0",
    "description": "ScrapingDog is a scalable web scraping API for data extraction. It provides proxy rotation, JavaScript rendering, and CAPTCHA handling capabilities.",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.scrapingdog.com",
      "description": "ScrapingDog API endpoint"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/scrape": {
      "get": {
        "summary": "Scrape Web Page",
        "description": "Scrape any web page with automatic proxy rotation and JavaScript rendering support.",
        "operationId": "scrapeGet",
        "parameters": [
          {
            "$ref": "#/components/parameters/api_key"
          },
          {
            "$ref": "#/components/parameters/url"
          },
          {
            "$ref": "#/components/parameters/dynamic"
          },
          {
            "$ref": "#/components/parameters/premium"
          },
          {
            "$ref": "#/components/parameters/country"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response containing the scraped HTML content",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                },
                "example": "<!DOCTYPE html><html>...</html>"
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        },
        "tags": [
          "scrape"
        ]
      },
      "post": {
        "summary": "Scrape Web Page (POST)",
        "description": "Scrape a web page using POST method. Useful for submitting form data to the target URL.",
        "operationId": "scrapePost",
        "parameters": [
          {
            "$ref": "#/components/parameters/api_key"
          },
          {
            "$ref": "#/components/parameters/url"
          },
          {
            "$ref": "#/components/parameters/dynamic"
          },
          {
            "$ref": "#/components/parameters/premium"
          },
          {
            "$ref": "#/components/parameters/country"
          }
        ],
        "requestBody": {
          "description": "Request body to forward to the target URL",
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response containing the scraped content",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        },
        "tags": [
          "scrape"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Your ScrapingDog API key for authentication"
      }
    },
    "parameters": {
      "api_key": {
        "name": "api_key",
        "in": "query",
        "required": true,
        "description": "Your ScrapingDog API key (required for all requests)",
        "schema": {
          "type": "string"
        },
        "example": "your_api_key_here"
      },
      "url": {
        "name": "url",
        "in": "query",
        "required": true,
        "description": "The target URL to scrape",
        "schema": {
          "type": "string",
          "format": "uri"
        },
        "example": "https://example.com"
      },
      "dynamic": {
        "name": "dynamic",
        "in": "query",
        "required": false,
        "description": "Enable JavaScript rendering for dynamic websites. Set to 'true' to enable. Default: false",
        "schema": {
          "type": "boolean",
          "default": false
        },
        "example": true
      },
      "premium": {
        "name": "premium",
        "in": "query",
        "required": false,
        "description": "Use premium residential proxies for better success rates. Set to 'true' to enable. Default: false",
        "schema": {
          "type": "boolean",
          "default": false
        },
        "example": true
      },
      "country": {
        "name": "country",
        "in": "query",
        "required": false,
        "description": "2-letter ISO country code for geolocation targeting (e.g., 'us', 'uk', 'de')",
        "schema": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2
        },
        "example": "us"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - missing or invalid parameters",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Invalid or missing URL parameter"
                }
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Invalid API key"
                }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden - insufficient credits or account restrictions",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Insufficient API credits"
                }
              }
            }
          }
        }
      },
      "RateLimitExceeded": {
        "description": "Rate limit exceeded",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Rate limit exceeded. Please try again later."
                }
              }
            }
          }
        }
      },
      "ServerError": {
        "description": "Server error or scraping failure",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Failed to scrape the target URL"
                }
              }
            }
          }
        }
      }
    }
  },
  "externalDocs": {
    "description": "ScrapingDog website",
    "url": "https://www.scrapingdog.com"
  },
  "tags": [
    {
      "name": "scrape"
    }
  ]
}
