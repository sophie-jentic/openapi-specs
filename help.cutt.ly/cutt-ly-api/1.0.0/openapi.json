{
  "openapi": "3.0.3",
  "info": {
    "title": "Cutt.ly URL Shortener API",
    "version": "1.0.0",
    "description": "Cutt.ly is a URL shortening service that provides an API for shortening URLs and retrieving click statistics.",
    "x-jentic-source-url": "https://cutt.ly",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://cutt.ly/api",
      "description": "Cutt.ly API"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "URL Shortening",
      "description": "Shorten and manage URLs"
    }
  ],
  "paths": {
    "/api.php": {
      "get": {
        "operationId": "shortenUrl",
        "summary": "Shorten a URL",
        "description": "Shortens a given URL using the Cutt.ly service. Returns the shortened URL along with status information.",
        "tags": [
          "URL Shortening"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Your Cutt.ly API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "short",
            "in": "query",
            "required": true,
            "description": "The URL to shorten",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "description": "Custom alias for the shortened URL",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with shortened URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShortenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key passed as query parameter"
      }
    },
    "schemas": {
      "ShortenResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "Status code: 1=URL already shortened, 2=not a valid URL, 3=preferred alias already taken, 4=invalid API key, 5=URL has been previously shortened, 6=URL from blocked domain, 7=OK"
              },
              "fullLink": {
                "type": "string",
                "description": "The original URL"
              },
              "date": {
                "type": "string",
                "description": "Date when the URL was shortened"
              },
              "shortLink": {
                "type": "string",
                "description": "The shortened URL"
              },
              "title": {
                "type": "string",
                "description": "Title of the page at the original URL"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "auth": {
            "type": "boolean"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
