{
  "openapi": "3.0.3",
  "info": {
    "title": "Backendless API",
    "version": "1.0.0",
    "description": "Backendless is a Backend-as-a-Service platform providing REST APIs for user management, data persistence, file storage, messaging, geo-location, counters, logging, and more.",
    "x-jentic-source-url": "https://backendless.com/docs/rest/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.backendless.com/{application-id}/{REST-api-key}",
      "variables": {
        "application-id": {
          "default": "YOUR_APP_ID"
        },
        "REST-api-key": {
          "default": "YOUR_REST_KEY"
        }
      }
    }
  ],
