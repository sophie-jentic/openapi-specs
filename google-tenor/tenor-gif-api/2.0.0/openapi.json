{
  "openapi": "3.1.0",
  "info": {
    "title": "Tenor GIF API",
    "description": "The Tenor GIF API v2 provides programmatic access to search, discover, and share GIFs and stickers from Tenor's library. Endpoints include search, featured content, categories, autocomplete, search suggestions, trending terms, and share registration.",
    "version": "2.0.0",
    "contact": {
      "name": "Google Developers",
      "url": "https://developers.google.com/tenor"
    },
    "license": {
      "name": "Google APIs Terms of Service",
      "url": "https://developers.google.com/terms"
    }
  },
  "servers": [
    {
      "url": "https://tenor.googleapis.com/v2",
      "description": "Tenor API v2 production server"
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "searchGifs",
        "summary": "Search for GIFs",
        "description": "Search for GIFs and stickers matching the given search term. Returns a list of GIF Response Objects ordered by relevancy.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "A search string.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/ClientKey"
          },
          {
            "$ref": "#/components/parameters/Country"
          },
          {
            "$ref": "#/components/parameters/Locale"
          },
          {
            "$ref": "#/components/parameters/ContentFilter"
          },
          {
            "$ref": "#/components/parameters/MediaFilter"
          },
          {
            "$ref": "#/components/parameters/ArRange"
          },
          {
            "name": "searchfilter",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of GIF content types to filter. Values include 'sticker' and '-sticker' (to exclude stickers).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "random",
            "in": "query",
            "required": false,
            "description": "If true, randomize the order of the response results.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "$ref": "#/components/parameters/Pos"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with search results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Client error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "search"
        ]
      }
    },
    "/featured": {
      "get": {
        "operationId": "getFeaturedGifs",
        "summary": "Get featured GIFs",
        "description": "Returns a list of the current global featured GIFs. Tenor updates the featured stream regularly throughout the day.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ClientKey"
          },
          {
            "$ref": "#/components/parameters/Country"
          },
          {
            "$ref": "#/components/parameters/Locale"
          },
          {
            "$ref": "#/components/parameters/ContentFilter"
          },
          {
            "$ref": "#/components/parameters/MediaFilter"
          },
          {
            "$ref": "#/components/parameters/ArRange"
          },
          {
            "name": "searchfilter",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of GIF content types to filter.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "$ref": "#/components/parameters/Pos"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with featured GIFs.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Client error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "featured"
        ]
      }
    },
    "/categories": {
      "get": {
        "operationId": "getCategories",
        "summary": "Get GIF categories",
        "description": "Returns a list of GIF categories associated with the provided type. Each category includes a representative GIF.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ClientKey"
          },
          {
            "$ref": "#/components/parameters/Country"
          },
          {
            "$ref": "#/components/parameters/Locale"
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "The type of categories to return. Determines the category list type.",
            "schema": {
              "type": "string",
              "enum": [
                "featured",
                "trending"
              ]
            }
          },
          {
            "$ref": "#/components/parameters/ContentFilter"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with categories.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CategoriesResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Client error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "categories"
        ]
      }
    },
    "/search_suggestions": {
      "get": {
        "operationId": "getSearchSuggestions",
        "summary": "Get search suggestions",
        "description": "Returns a list of alternative search terms related to the given search term.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "A search string.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/ClientKey"
          },
          {
            "$ref": "#/components/parameters/Country"
          },
          {
            "$ref": "#/components/parameters/Locale"
          },
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with search suggestions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StringResultsResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Client error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "search_suggestions"
        ]
      }
    },
    "/autocomplete": {
      "get": {
        "operationId": "autocomplete",
        "summary": "Autocomplete search terms",
        "description": "Returns a list of completed search terms given a partial search term. The list is sorted by Tenor's AI and ranked by relevancy.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "A partial search string to autocomplete.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/ClientKey"
          },
          {
            "$ref": "#/components/parameters/Country"
          },
          {
            "$ref": "#/components/parameters/Locale"
          },
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with autocomplete suggestions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StringResultsResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Client error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "autocomplete"
        ]
      }
    },
    "/trending_terms": {
      "get": {
        "operationId": "getTrendingTerms",
        "summary": "Get trending search terms",
        "description": "Returns a list of the current trending search terms. The list is updated periodically and sorted by trending rank.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ClientKey"
          },
          {
            "$ref": "#/components/parameters/Country"
          },
          {
            "$ref": "#/components/parameters/Locale"
          },
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with trending search terms.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StringResultsResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Client error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "trending_terms"
        ]
      }
    },
    "/registershare": {
      "get": {
        "operationId": "registerShare",
        "summary": "Register a GIF share",
        "description": "Register that a user shared a GIF or sticker. This improves search result ranking for the shared content.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The ID of the GIF Response Object that was shared.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/ClientKey"
          },
          {
            "$ref": "#/components/parameters/Country"
          },
          {
            "$ref": "#/components/parameters/Locale"
          },
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "The search string that led to the share.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Share registered successfully. No response body."
          },
          "4XX": {
            "description": "Client error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "registershare"
        ]
      }
    }
  },
  "components": {
    "parameters": {
      "ApiKey": {
        "name": "key",
        "in": "query",
        "required": true,
        "description": "API key for authentication.",
        "schema": {
          "type": "string"
        }
      },
      "ClientKey": {
        "name": "client_key",
        "in": "query",
        "required": false,
        "description": "A client-specified string that represents the integration. Helps differentiate integrations using the same API key.",
        "schema": {
          "type": "string"
        }
      },
      "Country": {
        "name": "country",
        "in": "query",
        "required": false,
        "description": "ISO 3166-1 country code to influence content. Default is US.",
        "schema": {
          "type": "string",
          "default": "US"
        }
      },
      "Locale": {
        "name": "locale",
        "in": "query",
        "required": false,
        "description": "Language locale in xx_YY format. Default is en_US.",
        "schema": {
          "type": "string",
          "default": "en_US"
        }
      },
      "ContentFilter": {
        "name": "contentfilter",
        "in": "query",
        "required": false,
        "description": "Content safety filter level.",
        "schema": {
          "type": "string",
          "enum": [
            "off",
            "low",
            "medium",
            "high"
          ],
          "default": "off"
        }
      },
      "MediaFilter": {
        "name": "media_filter",
        "in": "query",
        "required": false,
        "description": "Comma-separated list of response media format types to return. Reduces response size by only including requested formats.",
        "schema": {
          "type": "string"
        }
      },
      "ArRange": {
        "name": "ar_range",
        "in": "query",
        "required": false,
        "description": "Filter by aspect ratio range.",
        "schema": {
          "type": "string",
          "enum": [
            "all",
            "wide",
            "standard"
          ],
          "default": "all"
        }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "Maximum number of results to return. Default is 20, maximum is 50.",
        "schema": {
          "type": "integer",
          "default": 20,
          "minimum": 1,
          "maximum": 50
        }
      },
      "Pos": {
        "name": "pos",
        "in": "query",
        "required": false,
        "description": "A pagination token from a previous response's 'next' field to retrieve the next set of results.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "SearchResponse": {
        "type": "object",
        "description": "Response containing GIF results with pagination.",
        "properties": {
          "next": {
            "type": "string",
            "description": "A position identifier to use for the next request to retrieve the next set of results."
          },
          "results": {
            "type": "array",
            "description": "Array of GIF Response Objects.",
            "items": {
              "$ref": "#/components/schemas/ResponseObject"
            }
          }
        },
        "required": [
          "results"
        ]
      },
      "CategoriesResponse": {
        "type": "object",
        "description": "Response containing GIF categories.",
        "properties": {
          "tags": {
            "type": "array",
            "description": "Array of Category Objects.",
            "items": {
              "$ref": "#/components/schemas/CategoryObject"
            }
          }
        },
        "required": [
          "tags"
        ]
      },
      "StringResultsResponse": {
        "type": "object",
        "description": "Response containing a list of string results.",
        "properties": {
          "results": {
            "type": "array",
            "description": "Array of string results.",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "results"
        ]
      },
      "ResponseObject": {
        "type": "object",
        "description": "Represents a single GIF or sticker result.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Tenor result identifier."
          },
          "created": {
            "type": "number",
            "format": "double",
            "description": "Unix timestamp of when the post was created."
          },
          "title": {
            "type": "string",
            "description": "Title of the post."
          },
          "content_description": {
            "type": "string",
            "description": "Textual description of the content, suitable for accessibility."
          },
          "tags": {
            "type": "array",
            "description": "Tags associated with the post.",
            "items": {
              "type": "string"
            }
          },
          "media_formats": {
            "type": "object",
            "description": "Dictionary mapping content format names to Media Objects. Possible keys include gif, mediumgif, tinygif, nanogif, mp4, loopedmp4, tinymp4, nanomp4, webm, tinywebm, nanowebm, webp_transparent, tinywebp_transparent, nanowebp_transparent, gif_transparent, tinygif_transparent, nanogif_transparent.",
            "additionalProperties": {
              "$ref": "#/components/schemas/MediaObject"
            }
          },
          "itemurl": {
            "type": "string",
            "format": "uri",
            "description": "Full URL to view the post on tenor.com."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Short URL to view the post on tenor.com."
          },
          "hasaudio": {
            "type": "boolean",
            "description": "True if the post contains audio (applicable to video formats)."
          },
          "hascaption": {
            "type": "boolean",
            "description": "True if the post has embedded captions."
          },
          "flags": {
            "type": "string",
            "description": "Comma-separated list of flags indicating content type (e.g., sticker, static)."
          },
          "bg_color": {
            "type": "string",
            "description": "Most common background pixel color of the content, as a hex string."
          }
        },
        "required": [
          "id",
          "media_formats"
        ]
      },
      "CategoryObject": {
        "type": "object",
        "description": "Represents a GIF category.",
        "properties": {
          "searchterm": {
            "type": "string",
            "description": "Translated search term that corresponds to the category."
          },
          "path": {
            "type": "string",
            "format": "uri",
            "description": "URL to search for this category's GIFs."
          },
          "image": {
            "type": "string",
            "format": "uri",
            "description": "URL to a representative GIF for this category."
          },
          "name": {
            "type": "string",
            "description": "Translated name of the category for display."
          }
        },
        "required": [
          "searchterm",
          "path",
          "image",
          "name"
        ]
      },
      "MediaObject": {
        "type": "object",
        "description": "Represents a specific media format of a GIF result.",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the media source."
          },
          "dims": {
            "type": "array",
            "description": "Width and height of the media in pixels.",
            "items": {
              "type": "integer"
            },
            "minItems": 2,
            "maxItems": 2
          },
          "duration": {
            "type": "number",
            "format": "double",
            "description": "Duration of the media loop in seconds. 0 for static content."
          },
          "size": {
            "type": "integer",
            "description": "File size of the media in bytes."
          }
        },
        "required": [
          "url",
          "dims",
          "duration",
          "size"
        ]
      },
      "Error": {
        "type": "object",
        "description": "Error response in standard Google API error format.",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "integer",
                "description": "HTTP status code."
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message."
              },
              "status": {
                "type": "string",
                "description": "Error status string."
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "key",
        "in": "query",
        "description": "Tenor API key obtained from Google Cloud Console."
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "autocomplete"
    },
    {
      "name": "categories"
    },
    {
      "name": "featured"
    },
    {
      "name": "registershare"
    },
    {
      "name": "search"
    },
    {
      "name": "search_suggestions"
    },
    {
      "name": "trending_terms"
    }
  ]
}
