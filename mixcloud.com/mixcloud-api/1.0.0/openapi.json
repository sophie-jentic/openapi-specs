    "/{username}/{cloudcast_slug}/favorite/": {
      "post": {
        "operationId": "favoriteCloudcast",
        "summary": "Favorite a Cloudcast",
        "description": "Add a cloudcast to the authenticated user's favorites. Requires OAuth2.",
        "tags": [
          "Actions"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cloudcast_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully favorited",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object"
                    }
                  }
