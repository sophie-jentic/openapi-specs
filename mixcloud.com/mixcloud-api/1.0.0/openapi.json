  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "biog": {
            "type": "string",
            "description": "User biography"
          },
          "pictures": {
            "$ref": "#/components/schemas/Pictures"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "is_pro": {
            "type": "boolean"
          },
          "is_premium": {
            "type": "boolean"
          },
          "follower_count": {
            "type": "integer"
          },
          "following_count": {
            "type": "integer"
          },
          "cloudcast_count": {
            "type": "integer"
          },
          "favorite_count": {
            "type": "integer"
          },
          "listen_count": {
            "type": "integer"
          },
          "created_time": {
            "type": "string",
            "format": "date-time"
          },
          "updated_time": {
            "type": "string",
            "format": "date-time"
          },
          "cover_pictures": {
            "type": "object"
          },
          "picture_primary_color": {
            "type": "string"
          }
        }
      },
      "Cloudcast": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "user": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string"
              },
              "username": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            }
          },
          "pictures": {
            "$ref": "#/components/schemas/Pictures"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          },
          "audio_length": {
            "type": "integer",
            "description": "Duration in seconds"
          },
          "play_count": {
            "type": "integer"
          },
          "favorite_count": {
            "type": "integer"
          },
          "listener_count": {
            "type": "integer"
          },
          "repost_count": {
            "type": "integer"
          },
          "comment_count": {
            "type": "integer"
          },
          "created_time": {
            "type": "string",
            "format": "date-time"
