{
  "openapi": "3.0.3",
  "info": {
    "title": "Mixcloud API",
    "description": "The Mixcloud API provides access to Mixcloud's music streaming platform, including cloudcasts (mixes/shows), user profiles, followers, favorites, and upload functionality. Uses OAuth 2.0 for write operations.",
    "version": "1.0.0",
    "contact": {
      "name": "Mixcloud",
      "url": "https://www.mixcloud.com/developers/"
    },
    "termsOfService": "https://www.mixcloud.com/terms/",
    "x-jentic-source-url": "https://www.mixcloud.com/developers/"
  },
  "servers": [
    {
      "url": "https://api.mixcloud.com",
      "description": "Mixcloud API server"
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "User profile operations"
    },
    {
      "name": "Cloudcasts",
      "description": "Cloudcast (mix/show) operations"
    },
    {
      "name": "Search",
      "description": "Search operations"
    },
    {
      "name": "Upload",
      "description": "Upload operations"
    },
    {
      "name": "Social",
      "description": "Social features (follow, favorite, repost)"
    },
    {
      "name": "Categories",
      "description": "Category and tag operations"
    }
  ],
  "paths": {
    "/{username}": {
      "get": {
        "operationId": "getUser",
        "summary": "Get user profile",
        "description": "Retrieve a user's profile information including name, bio, picture, and counts.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The user's Mixcloud username"
          }
        ],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/{username}/cloudcasts": {
      "get": {
        "operationId": "getUserCloudcasts",
        "summary": "Get user's cloudcasts",
        "description": "Retrieve a paginated list of cloudcasts uploaded by the specified user.",
        "tags": [
          "Cloudcasts"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The user's Mixcloud username"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            },
            "description": "Number of results per page"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Pagination offset"
          },
          {
            "name": "since",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter cloudcasts created after this date"
          }
        ],
        "responses": {
          "200": {
            "description": "List of cloudcasts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CloudcastList"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/{username}/{cloudcast_slug}": {
      "get": {
        "operationId": "getCloudcast",
        "summary": "Get cloudcast details",
        "description": "Retrieve detailed information about a specific cloudcast.",
        "tags": [
          "Cloudcasts"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cloudcast_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The cloudcast's URL slug"
          }
        ],
        "responses": {
          "200": {
            "description": "Cloudcast details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cloudcast"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/{username}/followers": {
      "get": {
        "operationId": "getUserFollowers",
        "summary": "Get user's followers",
        "description": "Retrieve a paginated list of users who follow the specified user.",
        "tags": [
          "Social"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of followers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserList"
                }
              }
            }
          }
        }
      }
    },
    "/{username}/following": {
      "get": {
        "operationId": "getUserFollowing",
        "summary": "Get users followed by user",
        "description": "Retrieve a paginated list of users that the specified user follows.",
        "tags": [
          "Social"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of followed users",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserList"
                }
              }
            }
          }
        }
      }
    },
    "/{username}/favorites": {
      "get": {
        "operationId": "getUserFavorites",
        "summary": "Get user's favorite cloudcasts",
        "description": "Retrieve cloudcasts that the user has favorited.",
        "tags": [
          "Social"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of favorited cloudcasts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CloudcastList"
                }
              }
            }
          }
        }
      }
    },
    "/{username}/listens": {
      "get": {
        "operationId": "getUserListens",
        "summary": "Get user's listen history",
        "description": "Retrieve the user's listening history.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Listen history",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CloudcastList"
                }
              }
            }
          }
        }
      }
    },
    "/{username}/{cloudcast_slug}/comments": {
      "get": {
        "operationId": "getCloudcastComments",
        "summary": "Get cloudcast comments",
        "description": "Retrieve comments on a specific cloudcast.",
        "tags": [
          "Cloudcasts"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cloudcast_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of comments",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommentList"
                }
              }
            }
          }
        }
      }
    },
    "/{username}/{cloudcast_slug}/listeners": {
      "get": {
        "operationId": "getCloudcastListeners",
        "summary": "Get cloudcast listeners",
        "description": "Retrieve users who have listened to a specific cloudcast.",
        "tags": [
          "Cloudcasts"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cloudcast_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of listeners",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserList"
                }
              }
            }
          }
        }
      }
    },
    "/{username}/{cloudcast_slug}/similar": {
      "get": {
        "operationId": "getSimilarCloudcasts",
        "summary": "Get similar cloudcasts",
        "description": "Retrieve cloudcasts similar to the specified one.",
        "tags": [
          "Cloudcasts"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cloudcast_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of similar cloudcasts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CloudcastList"
                }
              }
            }
          }
        }
      }
    },
    "/{username}/follow": {
      "post": {
        "operationId": "followUser",
        "summary": "Follow a user",
        "description": "Follow the specified user. Requires OAuth authentication.",
        "tags": [
          "Social"
        ],
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully followed user"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "unfollowUser",
        "summary": "Unfollow a user",
        "description": "Unfollow the specified user. Requires OAuth authentication.",
        "tags": [
          "Social"
        ],
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully unfollowed user"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/{username}/{cloudcast_slug}/favorite": {
      "post": {
        "operationId": "favoriteCloudcast",
        "summary": "Favorite a cloudcast",
        "description": "Add a cloudcast to the authenticated user's favorites. Requires OAuth authentication.",
        "tags": [
          "Social"
        ],
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cloudcast_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully favorited cloudcast"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "unfavoriteCloudcast",
        "summary": "Unfavorite a cloudcast",
        "description": "Remove a cloudcast from the authenticated user's favorites.",
        "tags": [
          "Social"
        ],
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cloudcast_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully unfavorited cloudcast"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/{username}/{cloudcast_slug}/repost": {
      "post": {
        "operationId": "repostCloudcast",
        "summary": "Repost a cloudcast",
        "description": "Repost a cloudcast to the authenticated user's stream.",
        "tags": [
          "Social"
        ],
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cloudcast_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully reposted cloudcast"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "unrepostCloudcast",
        "summary": "Remove repost",
        "description": "Remove a cloudcast repost from the authenticated user's stream.",
        "tags": [
          "Social"
        ],
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cloudcast_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully removed repost"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/upload": {
      "post": {
        "operationId": "uploadCloudcast",
        "summary": "Upload a cloudcast",
        "description": "Upload a new cloudcast (mix/show) to Mixcloud. Requires OAuth authentication.",
        "tags": [
          "Upload"
        ],
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "mp3",
                  "name"
                ],
                "properties": {
                  "mp3": {
                    "type": "string",
                    "format": "binary",
                    "description": "The audio file to upload"
                  },
                  "name": {
                    "type": "string",
                    "description": "Name of the cloudcast"
                  },
                  "picture": {
                    "type": "string",
                    "format": "binary",
                    "description": "Cover image for the cloudcast"
                  },
                  "description": {
                    "type": "string",
                    "description": "Description of the cloudcast"
                  },
                  "tags": {
                    "type": "string",
                    "description": "Comma-separated tags"
                  },
                  "publish_date": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Scheduled publish date"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        },
                        "key": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "search",
        "summary": "Search Mixcloud",
        "description": "Search for cloudcasts, users, and tags on Mixcloud.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "cloudcast",
                "user",
                "tag"
              ]
            },
            "description": "Type of content to search for"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          }
        }
      }
    },
    "/categories": {
      "get": {
        "operationId": "getCategories",
        "summary": "Get all categories",
        "description": "Retrieve the list of available content categories.",
        "tags": [
          "Categories"
        ],
        "responses": {
          "200": {
            "description": "List of categories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Category"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/me": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get authenticated user",
        "description": "Retrieve the profile of the currently authenticated user.",
        "tags": [
          "Users"
        ],
        "security": [
          {
            "oauth2": [
              "read"
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "Authenticated user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/discover/{tag}": {
      "get": {
        "operationId": "discoverByTag",
        "summary": "Discover cloudcasts by tag",
        "description": "Retrieve popular cloudcasts for a given tag or genre.",
        "tags": [
          "Categories"
        ],
        "parameters": [
          {
            "name": "tag",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Tag or genre slug"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cloudcasts matching the tag",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CloudcastList"
                }
              }
            }
          }
        }
      }
    },
    "/popular/hot": {
      "get": {
        "operationId": "getHotCloudcasts",
        "summary": "Get hot/popular cloudcasts",
        "description": "Retrieve currently trending cloudcasts on Mixcloud.",
        "tags": [
          "Cloudcasts"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hot cloudcasts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CloudcastList"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "description": "Mixcloud OAuth 2.0 authentication. Register your app at https://www.mixcloud.com/developers/ to get client_id and client_secret.",
        "flows": {
          "authorizationCode": {
