  "components": {
    "schemas": {
      "SearchJobResponse": {
        "type": "object",
        "properties": {
          "sid": {
            "type": "string"
          },
          "dispatchState": {
            "type": "string"
          },
          "doneProgress": {
            "type": "number"
          },
          "resultCount": {
            "type": "integer"
          },
          "scanCount": {
            "type": "integer"
          },
          "isDone": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Splunk username and password"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Splunk session token"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    },
    {
      "bearerAuth": []
    }
  ]
}