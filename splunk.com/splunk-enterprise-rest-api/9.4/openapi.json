{
  "openapi": "3.0.3",
  "info": {
    "title": "Splunk Enterprise REST API",
    "version": "9.4",
    "description": "Splunk Enterprise REST API for managing searches, data inputs, configurations, knowledge objects, indexes, deployments, and system settings. Provides full programmatic access to Splunk platform features.",
    "x-jentic-source-url": "https://dev.splunk.com/enterprise/reference"
  },
  "servers": [
    {
      "url": "https://{splunk-host}:8089/services",
      "variables": {
        "splunk-host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/search/jobs": {
      "post": {
        "operationId": "createSearchJob",
        "summary": "Create a new search job",
        "description": "Starts a new search job with the given SPL search string.",
        "tags": [
          "Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "search": {
                    "type": "string",
                    "description": "SPL search string"
                  },
                  "earliest_time": {
                    "type": "string"
                  },
                  "latest_time": {
                    "type": "string"
                  },
                  "exec_mode": {
                    "type": "string",
                    "enum": [
                      "blocking",
                      "oneshot",
                      "normal"
                    ]
                  }
                },
                "required": [
                  "search"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Search job created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchJobResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listSearchJobs",
        "summary": "List search jobs",
        "description": "Returns a list of current search jobs for the authenticated user.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "count",
            "in": "query",
            "description": "Max results to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 30
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Index of first result",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search/jobs/{search_id}": {
      "get": {
        "operationId": "getSearchJob",
        "summary": "Get search job status",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchJobResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteSearchJob",
        "summary": "Cancel/delete a search job",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job deleted"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search/jobs/{search_id}/results": {
      "get": {
        "operationId": "getSearchResults",
        "summary": "Get search job results",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "count",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "output_mode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "csv"
              ],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search/jobs/{search_id}/control": {
      "post": {
        "operationId": "controlSearchJob",
        "summary": "Control a search job (pause, unpause, finalize, cancel)",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "pause",
                      "unpause",
                      "finalize",
                      "cancel"
                    ]
                  }
                },
                "required": [
                  "action"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Action performed"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/saved/searches": {
      "get": {
        "operationId": "listSavedSearches",
        "summary": "List saved searches",
        "tags": [
          "Saved Searches"
        ],
        "responses": {
