      "post": {
        "operationId": "createHttpEventCollectorToken",
        "summary": "Create an HEC token",
        "tags": [
          "Data Inputs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "index": {
                    "type": "string"
                  },
                  "sourcetype": {
                    "type": "string"
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Token created"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
