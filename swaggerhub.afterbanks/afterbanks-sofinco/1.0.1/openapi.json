{
  "swagger": "2.0",
  "info": {
    "description": "M\u00e9todos API para Afterbanks - Sofinco",
    "version": "1.0.1",
    "title": "API",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Afterbanks/Afterbanks-Sofinco/1.0.1/swagger.json",
    "contact": {}
  },
  "securityDefinitions": {
    "basicAuth": {
      "type": "basic"
    }
  },
  "paths": {
    "/getJsonFromLog": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "tags": [
          "Logs"
        ],
        "summary": "Listado de logs en formato json",
        "operationId": "jsonLogs",
        "description": "Obt\u00e9n el listado completo de logs del identificador o de la fecha especificado/a, en formato json.\n",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "servicekey",
            "description": "Licencia que identifica al cliente. Si no tienes una, puedes solicitarla en https://www.afterbanks.com.",
            "required": true,
            "type": "string"
          },
          {
            "in": "query",
            "name": "id",
            "description": "String que identifica la solicitud realizada. Obligatorio cuando no se especifica el par\u00e1metro \"date_start\"",
            "required": true,
            "type": "string"
          },
          {
            "in": "query",
            "name": "date_start",
            "description": "Fecha desde la que se quieran obtener logs, formato aaaa-mm-dd. Obligatorio cuando no se especifica el par\u00e1metro \"id\"",
            "type": "string",
            "required": true
          },
          {
            "in": "query",
            "name": "date_end",
            "description": "Fecha hasta que se quieran obtener logs, formato aaaa-mm-dd, con un m\u00e1ximo de 90 d\u00edas con respecto al par\u00e1metro \"date_start\".",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Resultados que coincidan con los criterios de b\u00fasqueda.",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/RegistroLog"
              }
            }
          },
          "404": {
            "description": "No autorizado"
          },
          "409": {
            "description": "Error en el proceso de b\u00fasqueda.",
            "schema": {
              "$ref": "#/definitions/RespuestaError"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "RegistroLog": {
      "type": "object",
      "required": [
        "id",
        "date",
        "message"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "id"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "example": "2016-08-29 09:12:33"
        },
        "message": {
          "type": "string",
          "format": "log"
        }
      }
    },
    "RespuestaError": {
      "type": "object",
      "required": [
        "error"
      ],
      "properties": {
        "error": {
          "type": "string",
          "format": "message"
        }
      }
    }
  },
  "host": "virtserver.swaggerhub.com",
  "basePath": "/Afterbanks/Afterbanks-Sofinco/1.0.1",
  "schemes": [
    "https"
  ],
  "tags": [
    {
      "name": "Logs"
    }
  ]
}
