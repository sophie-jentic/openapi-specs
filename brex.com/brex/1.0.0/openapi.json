  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token - OAuth2 token issued by Brex"
      }
    },
    "schemas": {
      "CardExpense": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "memo": {
            "type": "string",
            "nullable": true
          },
          "merchant_data": {
            "$ref": "#/components/schemas/MerchantData"
          },
          "budget_id": {
            "type": "string",
            "nullable": true
          },
          "amount": {
            "$ref": "#/components/schemas/Money"
          },
          "expense_date": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string"
          },
          "user_id": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "nullable": true
          },
          "receipts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Receipt"
            }
          }
        }
      },
      "PageCardExpense": {
        "type": "object",
        "properties": {
          "next_cursor": {
            "type": "string",
            "nullable": true
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CardExpense"
            }
          }
        }
      },
      "UpdateCardExpenseRequest": {
        "type": "object",
        "properties": {
          "memo": {
            "type": "string"
          },
          "budget_id": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        }
      },
      "ReceiptMatchRequest": {
        "type": "object",
        "properties": {
          "receipt": {
            "type": "string",
            "format": "binary"
          }
        }
      },
      "MerchantData": {
        "type": "object",
        "properties": {
          "raw_descriptor": {
            "type": "string"
          },
          "mcc": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Money": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "integer",
            "description": "Amount in minor units"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "Receipt": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "download_uris": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CardTransaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "card_id": {
            "type": "string"
          },
          "amount": {
            "$ref": "#/components/schemas/Money"
          },
          "initiated_at_date": {
