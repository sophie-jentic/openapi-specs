    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "api_key",
        "description": "Main or monitor-specific API key"
      }
    },
    "schemas": {
      "Monitor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "friendly_name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "type": {
            "type": "integer"
          },
          "status": {
            "type": "integer"
          },
          "interval": {
            "type": "integer"
          },
          "create_datetime": {
            "type": "integer"
          }
        }
      },
      "AlertContact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "friendly_name": {
            "type": "string"
          },
          "type": {
            "type": "integer"
          },
          "status": {
            "type": "integer"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "MWindow": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "friendly_name": {
            "type": "string"
          },
          "type": {
            "type": "integer"
