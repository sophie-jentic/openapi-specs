{
  "openapi": "3.0.3",
  "info": {
    "title": "UptimeRobot API",
    "version": "2.0.0",
    "description": "UptimeRobot monitors websites and services for uptime. The API provides operations for managing monitors, alert contacts, maintenance windows, and public status pages.",
