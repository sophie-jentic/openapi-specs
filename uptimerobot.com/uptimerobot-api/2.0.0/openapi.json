            "type": "integer"
          },
          "status": {
            "type": "integer"
          }
        }
      },
      "PSP": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "friendly_name": {
            "type": "string"
          },
          "monitors": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "standard_url": {
            "type": "string"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          }
        }
      }
