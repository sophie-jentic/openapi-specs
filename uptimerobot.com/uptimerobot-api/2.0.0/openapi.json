  "paths": {
    "/getMonitors": {
      "post": {
        "summary": "Get monitors",
        "operationId": "getMonitors",
        "tags": [
          "Monitors"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "monitors": {
                    "type": "string"
                  },
                  "types": {
                    "type": "string"
                  },
                  "statuses": {
                    "type": "string"
                  },
                  "custom_uptime_ratios": {
                    "type": "string"
                  },
                  "all_time_uptime_ratio": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  },
                  "logs": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  },
                  "response_times": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  },
                  "alert_contacts": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  },
                  "offset": {
                    "type": "integer"
                  },
                  "limit": {
                    "type": "integer"
                  },
                  "search": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stat": {
                      "type": "string"
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    },
                    "monitors": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Monitor"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get monitors"
      }
    },
