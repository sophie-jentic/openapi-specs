{
  "openapi": "3.0.3",
  "info": {
    "title": "iZooto API",
    "description": "iZooto web push notification API for sending push notifications to website subscribers. iZooto is an Owned Audience Marketing Platform enabling publishers to send contextual messages on Web, App, and Messenger.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://help.izooto.com/docs/izooto-platform",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.izooto.com/v2",
      "description": "iZooto API server"
    }
  ],
  "paths": {
    "/notifications": {
      "post": {
        "operationId": "sendNotification",
        "tags": [
          "Notifications"
        ],
        "summary": "Send a web push notification",
        "description": "Send a web push notification to subscribers. The notification includes a title, message, landing URL, and optional icon.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendNotificationRequest"
              },
              "example": {
                "title": "New article published",
                "message": "Check out our latest content!",
                "url": "https://yourwebsite.com/article",
                "icon": "https://yourwebsite.com/icon.png"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notification sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/subscribers": {
      "get": {
        "operationId": "listSubscribers",
        "tags": [
          "Subscribers"
        ],
        "summary": "List subscribers",
        "description": "Get a list of all subscribers for your website.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "List of subscribers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subscribers": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Subscriber"
                      }
                    },
                    "total": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Auth-Key",
        "description": "iZooto API key"
      }
    },
    "schemas": {
      "SendNotificationRequest": {
        "type": "object",
        "required": [
          "title",
          "message",
          "url"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Title of the push notification (required)"
          },
          "message": {
            "type": "string",
            "description": "Body message of the push notification (required)"
          },
          "url": {
            "type": "string",
            "description": "Landing URL when notification is clicked (required)"
          },
          "icon": {
            "type": "string",
            "description": "HTTPS URL of the notification icon"
          },
          "image": {
            "type": "string",
            "description": "HTTPS URL of a large image for the notification"
          },
          "segment_id": {
            "type": "string",
            "description": "Target a specific subscriber segment"
          }
        }
      },
      "NotificationResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Notification ID"
          },
          "status": {
            "type": "string",
            "enum": [
              "sent",
              "queued",
              "failed"
            ]
          },
          "recipients": {
            "type": "integer",
            "description": "Number of recipients"
          }
        }
      },
      "Subscriber": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "device_type": {
            "type": "string"
          },
          "browser": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Notifications"
    },
    {
      "name": "Subscribers"
    }
  ]
}
