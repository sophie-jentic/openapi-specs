          },
          "absence": {
            "$ref": "#/components/schemas/AbsenceInput"
          },
          "group": {
            "$ref": "#/components/schemas/GroupInput"
          },
          "customField": {
            "$ref": "#/components/schemas/CustomFieldInput"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Date for time entry operations (YYYY-MM-DD)."
          },
          "from": {
            "type": "string",
            "format": "date",
            "description": "Start date for time entry list/export operations (YYYY-MM-DD)."
          },
          "to": {
            "type": "string",
            "format": "date",
            "description": "End date for time entry list/export operations (YYYY-MM-DD)."
          },
          "hours": {
            "type": "number",
            "description": "Number of hours for a time entry."
          },
          "comment": {
            "type": "string",
            "description": "Comment for a time entry."
          },
          "memo": {
            "type": "string",
            "description": "Rejection reason sent to the employee via email (used with time_entry.reject)."
          },
          "show": {
            "type": "string",
            "description": "Report type for export. Default 'all'."
          },
          "keys": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Column keys for export."
          },
          "statusFilters": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "d",
                "s",
                "a",
                "r",
                "l"
              ]
            },
            "description": "Time record status filters: [d]raft, [s]ubmitted, [a]pproved, [r]ejected, [l]ocked."
          },
          "gids": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Group IDs filter for export."
          },
          "outputFormat": {
            "type": "string",
            "enum": [
              "array"
            ],
            "description": "Output format for export. Use 'array' for array of arrays, otherwise CSV."
          },
          "force": {
            "type": "boolean",
            "description": "Force deletion even when the group has been assigned to entities."
          }
        }
      },
      "CompanyInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "xid": {
            "type": "string"
          },
