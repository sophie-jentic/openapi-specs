    },
    {
      "name": "TimeEntry",
      "description": "Manage time entries"
    },
    {
      "name": "TimeExport",
      "description": "Export time entries"
    }
  ],
  "paths": {
    "/api/v2": {
      "post": {
        "operationId": "invokeService",
        "summary": "Invoke a Beebole API service",
        "description": "All Beebole API operations are invoked via a single POST endpoint. The 'service' field in the JSON body determines the operation to perform. Services follow the pattern 'entity.action' (e.g., 'company.list', 'time_entry.create', 'person.get'). Available services include: absence.create, absence.get, absence.update, absence.list, absence.activate, absence.deactivate, absence.add_group, absence.remove_group, absence.groups, company.create, company.get, company.update, company.list, company.activate, company.deactivate, company.attach_specific_task, company.detach_specific_task, company.specific_tasks, company.enable_specific_tasks, company.disable_specific_tasks, company.attach_member, company.detach_member, company.members, company.add_group, company.remove_group, company.groups, company.set_custom_field_value, company.clear_custom_field_value, company.custom_fields, person.create, person.get, person.update, person.list, person.leaders, person.activate, person.deactivate, person.add_group, person.remove_group, person.groups, person.set_custom_field_value, person.clear_custom_field_value, person.custom_fields, project.create, project.get, project.update, project.list, project.activate, project.deactivate, project.attach_specific_task, project.detach_specific_task, project.specific_tasks, project.enable_specific_tasks, project.disable_specific_tasks, project.attach_member, project.detach_member, project.members, project.attach_manager, project.detach_manager, project.managers, project.add_group, project.remove_group, project.groups, project.set_custom_field_value, project.clear_custom_field_value, project.custom_fields, subproject.create, subproject.get, subproject.update, subproject.list, subproject.activate, subproject.deactivate, subproject.attach_specific_task, subproject.detach_specific_task, subproject.specific_tasks, subproject.enable_specific_tasks, subproject.disable_specific_tasks, subproject.attach_member, subproject.detach_member, subproject.members, subproject.add_group, subproject.remove_group, subproject.groups, subproject.set_custom_field_value, subproject.clear_custom_field_value, subproject.custom_fields, task.create, task.get, task.update, task.list, task.activate, task.deactivate, task.add_group, task.remove_group, task.groups, group.create, group.get, group.update, group.delete, group.list, group.assignments, group.tree, custom_field.list, time_entry.get_entities, time_entry.get_tasks, time_entry.create, time_entry.update, time_entry.get, time_entry.delete, time_entry.list, time_entry.submit, time_entry.approve, time_entry.reject, time_entry.lock, time_entry.unlock, time_entry.export, time_entry.get_job_info.",
        "tags": [
          "Absence",
          "Company",
          "Person",
          "Project",
          "Subproject",
          "Task",
          "Group",
          "CustomField",
          "TimeEntry",
          "TimeExport"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ServiceRequest"
              },
              "examples": {
                "companyList": {
                  "summary": "List companies",
                  "value": {
                    "service": "company.list"
                  }
                },
                "companyCreate": {
                  "summary": "Create a company",
                  "value": {
                    "service": "company.create",
                    "company": {
                      "name": "myCompany",
                      "corporate": true
                    }
                  }
                },
                "companyGet": {
                  "summary": "Get a company",
                  "value": {
                    "service": "company.get",
                    "id": 233
                  }
                },
                "personCreate": {
                  "summary": "Create a person",
                  "value": {
                    "service": "person.create",
                    "person": {
                      "name": "Rosa Parks",
                      "company": {
                        "id": 233
                      },
                      "email": "rosa.parks@example.com",
                      "userGroup": "employee"
                    }
                  }
                },
                "timeEntryCreate": {
                  "summary": "Create a time entry",
                  "value": {
                    "service": "time_entry.create",
                    "subproject": {
                      "id": 37
                    },
                    "task": {
                      "id": 17
                    },
                    "date": "2017-08-05",
                    "hours": 8,
                    "comment": "some comment"
                  }
                },
                "timeEntryList": {
                  "summary": "List time entries",
                  "value": {
                    "service": "time_entry.list",
                    "person": {
                      "id": 2
                    },
                    "from": "2017-09-01",
                    "to": "2017-09-30"
                  }
                },
                "timeEntryExport": {
                  "summary": "Export time entries",
                  "value": {
                    "service": "time_entry.export",
                    "from": "2017-10-01",
                    "to": "2017-10-30",
                    "show": "all",
                    "keys": [
                      "company",
                      "companyId",
                      "hours"
                    ],
                    "statusFilters": [
                      "l",
                      "a"
                    ],
                    "outputFormat": "array"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response. The response body varies depending on the service invoked. Always contains a 'status' field with value 'ok' or 'error'.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use your API token as the username and 'x' as the password. The API token can be found in the API Token module on your home screen."
