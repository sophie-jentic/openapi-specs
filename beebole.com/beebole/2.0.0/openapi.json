    },
    "schemas": {
      "ServiceRequest": {
        "type": "object",
        "required": [
          "service"
        ],
        "description": "Base request object for all Beebole API calls. Additional properties depend on the service being invoked.",
        "properties": {
          "service": {
            "type": "string",
            "description": "The service to invoke, in the format 'entity.action' (e.g., 'company.list', 'time_entry.create')."
          },
          "id": {
            "type": "integer",
            "description": "Entity ID for get, update, delete, activate, deactivate, and group assignment operations."
          },
          "xid": {
            "type": "string",
            "description": "External ID. Can be used instead of 'id' to integrate with external systems."
          },
          "company": {
            "$ref": "#/components/schemas/CompanyInput"
          },
          "person": {
            "$ref": "#/components/schemas/PersonInput"
          },
          "project": {
