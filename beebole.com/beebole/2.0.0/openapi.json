{
  "openapi": "3.0.3",
  "info": {
    "title": "Beebole API",
    "version": "2.0.0",
    "description": "Beebole time tracking API. A fully documented API for integrating with the Beebole time tracking tool. All requests are HTTP POST to a single endpoint with a JSON body containing a 'service' field that specifies the operation. Supports management of absences, companies, persons, projects, subprojects, tasks, groups, custom fields, and time entries.",
    "x-jentic-source-url": "https://beebole.com/help/api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://beebole-apps.com",
      "description": "Beebole API Server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Absence",
      "description": "Manage absence types"
    },
    {
      "name": "Company",
      "description": "Manage companies"
    },
