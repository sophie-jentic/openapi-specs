{
  "openapi": "3.0.3",
  "info": {
    "title": "Outscraper API",
    "version": "1.0.0",
    "description": "Outscraper provides APIs for scraping Google Maps, Google Search, and other Google services. Extract business data, reviews, contacts, and more.",
    "x-jentic-source-url": "https://app.outscraper.com/api-docs",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.app.outscraper.com",
      "description": "Outscraper API"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "paths": {
    "/maps/search-v3": {
      "get": {
        "operationId": "googleMapsSearch",
        "tags": [
          "Google Maps"
        ],
        "summary": "Search Google Maps places",
        "description": "Scrape Google Maps for places matching the query. Returns business information including name, address, phone, website, ratings, and more.",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query (e.g., 'restaurants in Manhattan, NY, US'). Can be comma-separated for multiple queries."
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en"
            },
            "description": "Language code for results"
          },
          {
            "name": "region",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Country code for region-specific results"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            },
            "description": "Maximum number of results per query"
          },
          {
            "name": "extract_contacts",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Extract emails and contacts from business websites"
          },
          {
            "name": "enrichments",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Data enrichment services to apply"
          },
          {
            "name": "async",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Run request asynchronously"
          }
        ],
        "responses": {
          "200": {
            "description": "Google Maps places results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GoogleMapsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/maps/reviews-v3": {
      "get": {
        "operationId": "googleMapsReviews",
        "tags": [
          "Google Maps"
        ],
        "summary": "Get Google Maps reviews",
        "description": "Retrieve reviews for a place on Google Maps.",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Place URL, google_id, or search query"
          },
          {
            "name": "reviewsLimit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 500
            },
            "description": "Number of reviews to retrieve"
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "most_relevant",
                "newest",
                "highest_rating",
                "lowest_rating"
              ],
              "default": "most_relevant"
            }
          },
          {
            "name": "ignoreEmpty",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Ignore reviews without text"
          },
          {
            "name": "async",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Reviews results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/emails-and-contacts": {
      "get": {
        "operationId": "emailsAndContacts",
        "tags": [
          "Emails & Contacts"
        ],
        "summary": "Find emails and contacts",
        "description": "Find emails, phones, and social profiles from domains or company names.",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Domain name or company name"
          },
          {
            "name": "async",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Emails and contacts results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmailsContactsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/maps/photos": {
      "get": {
        "operationId": "googleMapsPhotos",
        "tags": [
          "Google Maps"
        ],
        "summary": "Get Google Maps photos",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Place URL, google_id, or search query"
          },
          {
            "name": "photosLimit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "async",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Photos results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhotosResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get Google Maps photos"
      }
    },
    "/requests/{id}": {
      "get": {
        "operationId": "getRequest",
        "tags": [
          "Requests"
        ],
        "summary": "Get request status/results",
        "description": "Retrieve the status or results of an async request.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request status and results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "Outscraper API key"
      }
    },
    "schemas": {
      "GoogleMapsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GoogleMapsPlace"
            }
          }
        }
      },
      "GoogleMapsPlace": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "name_for_emails": {
            "type": "string"
          },
          "subtypes": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "website": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string"
          },
          "street": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "state": {
            "type": "string",
            "nullable": true
          },
          "state_code": {
            "type": "string",
            "nullable": true
          },
          "postal_code": {
            "type": "string",
            "nullable": true
          },
          "country": {
            "type": "string",
            "nullable": true
          },
          "country_code": {
            "type": "string",
            "nullable": true
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "rating": {
            "type": "number",
            "nullable": true
          },
          "reviews": {
            "type": "integer",
            "nullable": true
          },
          "reviews_link": {
            "type": "string",
            "nullable": true
          },
          "business_status": {
            "type": "string",
            "nullable": true
          },
          "place_id": {
            "type": "string"
          },
          "google_id": {
            "type": "string"
          },
          "cid": {
            "type": "string",
            "nullable": true
          },
          "verified": {
            "type": "boolean",
            "nullable": true
          },
          "photo": {
            "type": "string",
            "nullable": true
          },
          "working_hours": {
            "type": "object",
            "nullable": true
          },
          "email_1": {
            "type": "string",
            "nullable": true
          },
          "email_2": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ReviewsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PlaceWithReviews"
            }
          }
        }
      },
      "PlaceWithReviews": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "place_id": {
            "type": "string"
          },
          "rating": {
            "type": "number"
          },
          "reviews": {
            "type": "integer"
          },
          "reviews_data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Review"
            }
          }
        }
      },
      "Review": {
        "type": "object",
        "properties": {
          "review_id": {
            "type": "string"
          },
          "author_title": {
            "type": "string"
          },
          "author_id": {
            "type": "string"
          },
          "author_image": {
            "type": "string"
          },
          "author_reviews_count": {
            "type": "integer"
          },
          "review_text": {
            "type": "string"
          },
          "review_rating": {
            "type": "integer"
          },
          "review_likes": {
            "type": "integer"
          },
          "review_datetime_utc": {
            "type": "string"
          },
          "review_timestamp": {
            "type": "integer"
          },
          "owner_answer": {
            "type": "string",
            "nullable": true
          },
          "owner_answer_timestamp_datetime_utc": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "EmailsContactsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EmailsContactsResult"
            }
          }
        }
      },
      "EmailsContactsResult": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string"
          },
          "email_1": {
            "type": "string",
            "nullable": true
          },
          "email_2": {
            "type": "string",
            "nullable": true
          },
          "email_3": {
            "type": "string",
            "nullable": true
          },
          "phone_1": {
            "type": "string",
            "nullable": true
          },
          "Facebook": {
            "type": "string",
            "nullable": true
          },
          "Instagram": {
            "type": "string",
            "nullable": true
          },
          "Twitter": {
            "type": "string",
            "nullable": true
          },
          "Linkedin": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PhotosResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PhotosResult"
            }
          }
        }
      },
      "PhotosResult": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "photos_data": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "RequestStatusResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "Pending",
              "In progress",
              "Completed",
              "Failed"
            ]
          },
          "data": {
            "type": "array"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Emails & Contacts"
    },
    {
      "name": "Google Maps"
    },
    {
      "name": "Requests"
    }
  ]
}
