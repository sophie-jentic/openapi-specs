    "/usermanagement/users/{userId}": {
      "get": {
        "operationId": "getUser",
        "summary": "Get user details",
        "description": "Returns details of a specific user",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
