{
  "openapi": "3.0.0",
  "info": {
    "title": "ScrapeNinja Web Scraping API",
    "description": "High-performance web scraping API with smart retries and proxy rotation, with multiple proxy geos, and with two scraping engines under the hood: high performance engine with Chrome browser TLS fingerprint, but without JavaScript execution and real browser overhead; and real Chrome browser engine, with JS and CSS evaluation and screenshots, when high performance engine features are not enough.",
    "version": "1.0.0",
    "contact": {
      "name": "ScrapeNinja",
      "url": "https://scrapeninja.net"
    }
  },
  "servers": [
    {
      "url": "https://scrapeninja.apiroad.net",
      "description": "APIRoad Server"
    },
    {
      "url": "https://scrapeninja.p.rapidapi.com",
      "description": "RapidAPI Server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-RapidAPI-Key",
        "description": "API key for authentication. Use X-Apiroad-Key if using APIRoad."
      }
    },
    "schemas": {
      "ScrapeRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "description": "URL to scrape",
            "example": "https://example.com"
          },
          "headers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Custom headers to send with the request. By default, regular Chrome browser headers are sent to the target URL.",
            "example": [
              "X-Header: some-random-header"
            ]
          },
          "retryNum": {
            "type": "integer",
            "description": "Amount of attempts.",
            "example": 1
          },
          "geo": {
            "type": "string",
            "description": "Geo location for basic proxy pools (you can purchase premium ScrapeNinja proxies for wider country selection and higher proxy quality).",
            "example": "eu",
            "default": "us"
          },
          "proxy": {
            "type": "string",
            "description": "Premium or your own proxy URL (overrides `geo` field).",
            "example": "http://user:pw@host:port"
          },
          "followRedirects": {
            "type": "integer",
            "description": "Follow redirects.",
            "example": 0,
            "default": 1
          },
          "timeout": {
            "type": "integer",
            "description": "Timeout per attempt, in seconds. Each retry will take [timeout] number of seconds.",
            "example": 8,
            "default": 10
          },
          "textNotExpected": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Text which will trigger a retry from another proxy address.",
            "example": [
              "random-captcha-text-which-might-appear"
            ]
          },
          "statusNotExpected": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "HTTP response statuses which will trigger a retry from another proxy address.",
            "example": [
              403,
              429
            ],
            "default": [
              403,
              502
            ]
          },
          "extractor": {
            "type": "string",
            "description": "Custom JS function to extract JSON values from scraped HTML. Write&test your own extractor on https://scrapeninja.net/cheerio-sandbox/",
            "example": "function(input, cheerio) {\n    let $ = cheerio.load(input);\n return $('h1.title').text(); }"
          }
        }
      },
      "ScrapeJsRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "description": "URL to scrape",
            "example": "https://example.com"
          },
          "waitForSelector": {
            "type": "string",
            "description": "CSS selector to wait to appear in DOM tree before page is considered as loaded.",
            "example": "h1.some-class"
          },
          "postWaitTime": {
            "type": "integer",
            "description": "Wait for specified amount of seconds after page load (from 1 to 12s). Use this only if ScrapeNinja failed to wait for required page elements automatically.",
            "example": 5
          },
          "dumpIframe": {
            "type": "string",
            "description": "If some particular iframe needs to be dumped, specify its `name` HTML value in this argument.",
            "example": "icims_content_iframe"
          },
          "waitForSelectorIframe": {
            "type": "string",
            "description": "If `dumpIframe` is activated, this property allows to wait for CSS selector inside this iframe.",
            "example": ".iCIMS_PagingBatch"
          },
          "extractorTargetIframe": {
            "type": "boolean",
            "description": "If `dumpIframe` is activated, this property allows to run JS extractor function against iframe HTML instead of running it against base body.",
            "example": true
          },
          "headers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Custom headers to send with the request.",
            "example": [
              "X-Header: some-random-header"
            ]
          },
          "retryNum": {
            "type": "integer",
            "description": "Amount of attempts.",
            "example": 1
          },
          "geo": {
            "type": "string",
            "description": "Geo location for basic proxy pools.",
            "example": "eu",
            "default": "us"
          },
          "proxy": {
            "type": "string",
            "description": "Premium or your own proxy URL (overrides `geo` field).",
            "example": "http://user:pw@host:port"
          },
          "timeout": {
            "type": "integer",
            "description": "Timeout per attempt, in seconds.",
            "example": 8,
            "default": 16
          },
          "textNotExpected": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Text which will trigger a retry from another proxy address.",
            "example": [
              "random-captcha-text-which-might-appear"
            ]
          },
          "statusNotExpected": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "HTTP response statuses which will trigger a retry from another proxy address.",
            "example": [
              403,
              429
            ],
            "default": [
              403,
              502
            ]
          },
          "blockImages": {
            "type": "boolean",
            "description": "Block images from loading. This will speed up page loading and reduce bandwidth usage.",
            "example": true
          },
          "blockMedia": {
            "type": "boolean",
            "description": "Block (CSS, fonts) from loading. This will speed up page loading and reduce bandwidth usage.",
            "example": true
          },
          "screenshot": {
            "type": "boolean",
            "description": "Take a screenshot of the page. Pass \"false\" to increase the speed of the request.",
            "example": true
          },
          "catchAjaxHeadersUrlMask": {
            "type": "string",
            "description": "Useful to dump some XHR response. Pass URL mask here."
          },
          "viewport": {
            "type": "object",
            "description": "Advanced. Set custom viewport size. By default, viewport size is 1920x1080.",
            "properties": {
              "width": {
                "type": "integer",
                "example": 1920
              },
              "height": {
                "type": "integer",
                "example": 1080
              },
              "deviceScaleFactor": {
                "type": "integer",
                "example": 3
              },
              "hasTouch": {
                "type": "boolean",
                "example": false
              },
              "isMobile": {
                "type": "boolean",
                "example": false
              },
              "isLandscape": {
                "type": "boolean",
                "example": false
              }
            }
          },
          "extractor": {
            "type": "string",
            "description": "Custom JS function to extract JSON values from scraped HTML.",
            "example": "function(input, cheerio) {\n    let $ = cheerio.load(input);\n return $('h1.title').text(); }"
          }
        }
      },
      "ScrapeResponse": {
        "type": "object",
        "properties": {
          "info": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer",
                "example": 200
              },
              "finalUrl": {
                "type": "string",
                "example": "https://example.com/url"
              },
              "headers": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "content-type: xxx",
                  "header2: val2"
                ]
              }
            }
          },
          "body": {
            "type": "string",
            "description": "HTML body of the rendered page.",
            "example": "<html><body><h1>Hello World!</h1></body></html>"
          }
        }
      },
      "ScrapeJsResponse": {
        "type": "object",
        "properties": {
          "info": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer",
                "example": 200
              },
              "finalUrl": {
                "type": "string",
                "example": "https://example.com/url"
              },
              "catchedAjax": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "example": "https://example.com/api/data.json"
                  },
                  "method": {
                    "type": "string",
                    "example": "GET"
                  },
                  "headers": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      "content-type: xxx",
                      "header2: val2"
                    ]
                  },
                  "body": {
                    "type": "string",
                    "example": "<html><body><h1>Hello World!</h1></body></html>"
                  },
                  "bodyIframe": {
                    "type": "string",
                    "description": "If `dumpIframe` is activated, this property contains iframe HTML.",
                    "example": "<html><body><h1>Iframe content</h1></body></html>"
                  },
                  "status": {
                    "type": "integer",
                    "example": 200
                  },
                  "responseHeaders": {
                    "type": "object",
                    "example": {
                      "content-type": "application/json"
                    }
                  }
                }
              },
              "headers": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "content-type: xxx",
                  "header2: val2"
                ]
              },
              "screenshot": {
                "type": "string",
                "description": "Base64 encoded screenshot"
              },
              "pageCookies": {
                "type": "array",
                "description": "Cookies from the page"
              }
            }
          },
          "body": {
            "type": "string",
            "description": "HTML body of the rendered page.",
            "example": "<html><body><h1>Hello World!</h1></body></html>"
          }
        }
      }
    }
  },
  "paths": {
    "/scrape": {
      "post": {
        "operationId": "scrape",
        "summary": "Non-JS scraping",
        "description": "Use high-performance web scraping endpoint with Chrome browser TLS fingerprint, but without JavaScript execution and real browser overhead.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeResponse"
                }
              }
            }
          }
        },
        "tags": [
          "scrape"
        ]
      }
    },
    "/scrape-js": {
      "post": {
        "operationId": "scrape-js",
        "summary": "Scraping with JS rendering",
        "description": "Launches real Chrome browser engine, use only when /scrape endpoint features are not enough.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScrapeJsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeJsResponse"
                }
              }
            }
          }
        },
        "tags": [
          "scrape-js"
        ]
      }
    },
    "/v2/scrape-js": {
      "post": {
        "operationId": "scrape-js-v2",
        "summary": "Scraping with JS rendering (v2)",
        "description": "Launches real Chrome browser engine with better success rate for websites protected by Cloudflare, Datadome, Kasada, PermimeterX. Only available via APIRoad.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScrapeJsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeJsResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ]
      }
    }
  },
  "tags": [
    {
      "name": "scrape"
    },
    {
      "name": "scrape-js"
    },
    {
      "name": "v2"
    }
  ]
}
