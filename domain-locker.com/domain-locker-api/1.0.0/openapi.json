{
  "openapi": "3.0.3",
  "info": {
    "title": "Domain Locker API",
    "version": "1.0.0",
    "description": "Domain Locker is a self-hosted domain management tool to track domains, their SSL certificates, DNS records, registrar info, WHOIS data, and expiration dates. The API provides programmatic access to domain management.",
    "x-jentic-source-url": "https://domain-locker.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000/api"
    }
  ],
  "paths": {
    "/domains": {
      "get": {
        "operationId": "listDomains",
        "summary": "List all tracked domains",
        "tags": [
          "Domains"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Domain list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "domains": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Domain"
                      }
                    },
                    "total": {
                      "type": "integer"
                    },
                    "page": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all tracked domains"
      },
      "post": {
        "operationId": "addDomain",
        "summary": "Add a domain to track",
        "tags": [
          "Domains"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DomainInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Domain added",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Domain"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Add a domain to track"
      }
    },
    "/domains/{domain}": {
      "get": {
        "operationId": "getDomain",
        "summary": "Get domain details",
        "tags": [
          "Domains"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Domain name"
          }
        ],
        "responses": {
          "200": {
            "description": "Domain details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DomainDetailed"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get domain details"
      },
      "put": {
        "operationId": "updateDomain",
        "summary": "Update domain info",
        "tags": [
          "Domains"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DomainInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Domain updated"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update domain info"
      },
      "delete": {
        "operationId": "deleteDomain",
        "summary": "Remove a domain from tracking",
        "tags": [
          "Domains"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Domain removed"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Remove a domain from tracking"
      }
    },
    "/domains/{domain}/refresh": {
      "post": {
        "operationId": "refreshDomain",
        "summary": "Force refresh domain data (SSL, DNS, WHOIS)",
        "tags": [
          "Domains"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Refresh initiated"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Force refresh domain data (SSL, DNS, WHOIS)"
      }
    },
    "/domains/{domain}/ssl": {
      "get": {
        "operationId": "getDomainSSL",
        "summary": "Get SSL certificate info",
        "tags": [
          "SSL"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SSL info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SSLInfo"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get SSL certificate info"
      }
    },
    "/domains/{domain}/dns": {
      "get": {
        "operationId": "getDomainDNS",
        "summary": "Get DNS records",
        "tags": [
          "DNS"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "DNS records",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DNSRecord"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get DNS records"
      }
    },
    "/domains/{domain}/whois": {
      "get": {
        "operationId": "getDomainWhois",
        "summary": "Get WHOIS data",
        "tags": [
          "WHOIS"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "WHOIS data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WhoisData"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get WHOIS data"
      }
    },
    "/tags": {
      "get": {
        "operationId": "listTags",
        "summary": "List all tags",
        "tags": [
          "Tags"
        ],
        "responses": {
          "200": {
            "description": "Tag list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Tag"
                  }
                }
              }
            }
          }
        },
        "description": "List all tags"
      },
      "post": {
        "operationId": "createTag",
        "summary": "Create a tag",
        "tags": [
          "Tags"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "color": {
                    "type": "string"
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tag created"
          }
        },
        "description": "Create a tag"
      }
    },
    "/notifications": {
      "get": {
        "operationId": "listNotifications",
        "summary": "List notification settings",
        "tags": [
          "Notifications"
        ],
        "responses": {
          "200": {
            "description": "Notification settings"
          }
        },
        "description": "List notification settings"
      },
      "put": {
        "operationId": "updateNotifications",
        "summary": "Update notification settings",
        "tags": [
          "Notifications"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        },
        "description": "Update notification settings"
      }
    },
    "/stats": {
      "get": {
        "operationId": "getStats",
        "summary": "Get dashboard statistics",
        "tags": [
          "Dashboard"
        ],
        "responses": {
          "200": {
            "description": "Statistics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total_domains": {
                      "type": "integer"
                    },
                    "expiring_soon": {
                      "type": "integer"
                    },
                    "ssl_issues": {
                      "type": "integer"
                    },
                    "dns_changes": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get dashboard statistics"
      }
    }
  },
  "components": {
    "schemas": {
      "Domain": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string"
          },
          "registrar": {
            "type": "string"
          },
          "expiry_date": {
            "type": "string",
            "format": "date"
          },
          "created_date": {
            "type": "string",
            "format": "date"
          },
          "ssl_expiry": {
            "type": "string",
            "format": "date"
          },
          "ssl_issuer": {
            "type": "string"
          },
          "ip_address": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "expiring",
              "expired",
              "issue"
            ]
          },
          "last_checked": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DomainDetailed": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Domain"
          },
          {
            "type": "object",
            "properties": {
              "dns_records": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/DNSRecord"
                }
              },
              "ssl_info": {
                "$ref": "#/components/schemas/SSLInfo"
              },
              "whois": {
                "$ref": "#/components/schemas/WhoisData"
              },
              "history": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          }
        ]
      },
      "DomainInput": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "domain"
        ]
      },
      "SSLInfo": {
        "type": "object",
        "properties": {
          "issuer": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "valid_from": {
            "type": "string",
            "format": "date-time"
          },
          "valid_to": {
            "type": "string",
            "format": "date-time"
          },
          "serial_number": {
            "type": "string"
          },
          "fingerprint": {
            "type": "string"
          },
          "protocol": {
            "type": "string"
          }
        }
      },
      "DNSRecord": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "A",
              "AAAA",
              "CNAME",
              "MX",
              "NS",
              "TXT",
              "SOA",
              "SRV",
              "CAA"
            ]
          },
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "ttl": {
            "type": "integer"
          },
          "priority": {
            "type": "integer"
          }
        }
      },
      "WhoisData": {
        "type": "object",
        "properties": {
          "registrar": {
            "type": "string"
          },
          "creation_date": {
            "type": "string",
            "format": "date"
          },
          "expiration_date": {
            "type": "string",
            "format": "date"
          },
          "updated_date": {
            "type": "string",
            "format": "date"
          },
          "name_servers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dnssec": {
            "type": "string"
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "color": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "DNS"
    },
    {
      "name": "Dashboard"
    },
    {
      "name": "Domains"
    },
    {
      "name": "Notifications"
    },
    {
      "name": "SSL"
    },
    {
      "name": "Tags"
    },
    {
      "name": "WHOIS"
    }
  ]
}
