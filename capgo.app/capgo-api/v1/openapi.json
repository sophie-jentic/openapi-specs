          }
        }
      },
      "AppInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          }
        }
      },
      "ChannelInput": {
        "type": "object",
        "required": [
          "app_id",
          "name"
        ],
        "properties": {
          "app_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "public": {
            "type": "boolean"
          },
          "disableAutoUpdateUnderNative": {
            "type": "boolean"
          },
          "disableAutoUpdate": {
            "type": "string"
          },
          "ios": {
            "type": "boolean"
          },
          "android": {
