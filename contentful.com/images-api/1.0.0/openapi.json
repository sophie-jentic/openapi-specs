{
  "openapi": "3.0.0",
  "info": {
    "title": "Contentful Images API",
    "description": "The Contentful Images API allows you to resize, crop, and transform images on-the-fly using URL parameters. Images are served from the Contentful CDN with various transformation options including format conversion, quality adjustment, and smart cropping.",
    "version": "1.0.0",
    "contact": {
      "name": "Contentful",
      "url": "https://www.contentful.com"
    }
  },
  "servers": [
    {
      "url": "https://images.ctfassets.net",
      "description": "Contentful Images CDN (Global)"
    },
    {
      "url": "https://images.eu.ctfassets.net",
      "description": "Contentful Images CDN (EU)"
    }
  ],
  "paths": {
    "/{space_id}/{asset_id}/{token}/{filename}": {
      "get": {
        "summary": "Get Transformed Image",
        "description": "Retrieve an image with optional transformations applied. All transformation parameters are optional and can be combined.",
        "operationId": "getTransformedImage",
        "parameters": [
          {
            "name": "space_id",
            "in": "path",
            "required": true,
            "description": "Contentful space ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "asset_id",
            "in": "path",
            "required": true,
            "description": "Asset identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "token",
            "in": "path",
            "required": true,
            "description": "Asset access token",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filename",
            "in": "path",
            "required": true,
            "description": "Image filename",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "w",
            "in": "query",
            "required": false,
            "description": "Width in pixels (max 4000)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4000
            }
          },
          {
            "name": "h",
            "in": "query",
            "required": false,
            "description": "Height in pixels (max 4000)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4000
            }
          },
          {
            "name": "fm",
            "in": "query",
            "required": false,
            "description": "Output format",
            "schema": {
              "type": "string",
              "enum": [
                "jpg",
                "png",
                "webp",
                "gif",
                "avif",
                "tiff"
              ]
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Quality percentage (1-100)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "fit",
            "in": "query",
            "required": false,
            "description": "Resizing behavior",
            "schema": {
              "type": "string",
              "enum": [
                "pad",
                "fill",
                "scale",
                "crop",
                "thumb"
              ]
            }
          },
          {
            "name": "f",
            "in": "query",
            "required": false,
            "description": "Focus area for cropping",
            "schema": {
              "type": "string",
              "enum": [
                "center",
                "top",
                "right",
                "left",
                "bottom",
                "top_right",
                "top_left",
                "bottom_right",
                "bottom_left",
                "face",
                "faces"
              ]
            }
          },
          {
            "name": "r",
            "in": "query",
            "required": false,
            "description": "Corner radius in pixels or 'max' for circle/ellipse",
            "schema": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "string",
                  "enum": [
                    "max"
                  ]
                }
              ]
            }
          },
          {
            "name": "bg",
            "in": "query",
            "required": false,
            "description": "Background color in RGB format (e.g., rgb:9090ff)",
            "schema": {
              "type": "string",
              "pattern": "^rgb:[0-9a-fA-F]{6}$"
            },
            "example": "rgb:9090ff"
          },
          {
            "name": "fl",
            "in": "query",
            "required": false,
            "description": "Format-specific flags",
            "schema": {
              "type": "string",
              "enum": [
                "progressive",
                "png8"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully transformed image",
            "content": {
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/webp": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/gif": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/avif": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/tiff": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Image not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "default"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "sys": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "example": "Error"
              },
              "id": {
                "type": "string",
                "example": "NotFound"
              }
            }
          },
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "details": {
            "type": "object",
            "description": "Additional error details"
          }
        }
      }
    }
  },
  "x-technical-constraints": {
    "maxUploadSize": "100 MB",
    "maxDimensions": "4000x4000 pixels",
    "avifLimit": "9 Megapixel source images",
    "note": "Images exceeding limits are treated as standard assets without transformation"
  },
  "tags": [
    {
      "name": "default"
    }
  ]
}
