          "internalName": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "metacriticLink": {
            "type": "string"
          },
          "dealID": {
            "type": "string"
          },
          "storeID": {
            "type": "string"
          },
          "gameID": {
            "type": "string"
          },
          "salePrice": {
            "type": "string"
          },
          "normalPrice": {
            "type": "string"
          },
          "isOnSale": {
            "type": "string"
          },
          "savings": {
            "type": "string"
          },
          "metacriticScore": {
            "type": "string"
          },
          "steamRatingText": {
            "type": "string"
          },
          "steamRatingPercent": {
            "type": "string"
          },
          "steamRatingCount": {
            "type": "string"
          },
          "steamAppID": {
            "type": "string"
          },
          "releaseDate": {
            "type": "integer"
          },
          "lastChange": {
            "type": "integer"
          },
          "dealRating": {
            "type": "string"
          },
          "thumb": {
            "type": "string"
          }
        }
      },
      "DealDetails": {
        "type": "object",
        "properties": {
          "gameInfo": {
            "type": "object",
            "properties": {
              "storeID": {
                "type": "string"
              },
              "gameID": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "steamAppID": {
                "type": "string"
              },
              "salePrice": {
                "type": "string"
              },
              "retailPrice": {
                "type": "string"
              },
              "steamRatingText": {
                "type": "string"
              },
              "metacriticScore": {
                "type": "string"
              },
              "thumb": {
                "type": "string"
              }
            }
          },
          "cheaperStores": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "dealID": {
                  "type": "string"
                },
                "storeID": {
                  "type": "string"
                },
                "salePrice": {
                  "type": "string"
                },
                "retailPrice": {
                  "type": "string"
                }
              }
            }
          },
          "cheapestPrice": {
            "type": "object",
            "properties": {
              "price": {
                "type": "string"
              },
              "date": {
                "type": "integer"
              }
            }
          }
        }
      },
      "GameSearch": {
        "type": "object",
        "properties": {
          "gameID": {
            "type": "string"
          },
          "steamAppID": {
            "type": "string"
          },
          "cheapest": {
            "type": "string"
          },
          "cheapestDealID": {
            "type": "string"
          },
          "external": {
            "type": "string"
          },
          "internalName": {
            "type": "string"
          },
          "thumb": {
            "type": "string"
          }
        }
      },
      "GameDetails": {
        "type": "object",
        "properties": {
          "info": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "steamAppID": {
                "type": "string",
                "nullable": true
              },
              "thumb": {
                "type": "string"
              }
            }
          },
          "cheapestPriceEver": {
            "type": "object",
            "properties": {
              "price": {
                "type": "string"
              },
              "date": {
                "type": "integer"
              }
            }
          },
          "deals": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "storeID": {
                  "type": "string"
                },
                "dealID": {
                  "type": "string"
                },
                "price": {
                  "type": "string"
                },
                "retailPrice": {
                  "type": "string"
                },
                "savings": {
                  "type": "string"
                }
              }
