  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "API key provided via custom HTTP header"
      },
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication using API key as username (no password required)"
      }
    },
    "parameters": {
      "LimitParam": {
        "name": "limit",
        "in": "query",
        "description": "Maximum number of objects to return (1-100, default: 50)",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 50
        }
      },
      "OffsetParam": {
        "name": "offset",
        "in": "query",
        "description": "Index of the first element to return (default: 0)",
        "schema": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      },
      "SortParam": {
        "name": "sort",
        "in": "query",
        "description": "Sort results by attribute (prefix with '-' for descending order)",
        "schema": {
          "type": "string"
        },
        "example": "changedAt"
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Unauthorized - Invalid or missing API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "BadRequestError": {
        "description": "Bad Request - Invalid input",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFoundError": {
