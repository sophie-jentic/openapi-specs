{
  "openapi": "3.0.3",
  "info": {
    "title": "Illumina Connected Analytics API",
    "version": "1.0.0",
    "description": "Genomics analysis platform API for CWL and Nextflow pipeline execution",
    "x-jentic-source-url": "https://help.ica.illumina.com/reference/r-api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://ica.illumina.com/ica/rest/api",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Projects",
      "description": "Project management"
    },
    {
      "name": "Analysis",
      "description": "Pipeline execution and analysis"
    },
    {
      "name": "Storage",
      "description": "Storage management"
    },
    {
      "name": "Pipelines",
      "description": "Pipeline management"
    }
  ],
  "paths": {
    "/projects": {
      "get": {
        "tags": [
          "Projects"
        ],
        "summary": "List projects with cursor-based pagination",
        "operationId": "listProjects",
        "parameters": [
          {
            "name": "includeHiddenProjects",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pageToken",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Project"
                      }
                    },
                    "nextPageToken": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "List projects with cursor-based pagination"
      }
    },
    "/analysisStorages": {
      "get": {
        "tags": [
          "Storage"
        ],
        "summary": "Retrieve available storage options for analyses",
        "operationId": "getAnalysisStorages",
        "responses": {
          "200": {
            "description": "Storage options",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "storages": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Retrieve available storage options for analyses"
      }
    },
    "/projects/{projectId}/analysis:cwl": {
      "post": {
        "tags": [
          "Analysis"
        ],
        "summary": "Start CWL pipeline execution",
        "operationId": "startCwlAnalysis",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "analysisStorageId": {
                    "type": "string"
                  },
                  "pipelineId": {
                    "type": "string"
                  },
                  "userReference": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "CWL analysis started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Analysis"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Start CWL pipeline execution"
      }
    },
    "/projects/{projectId}/analysis:nextflow": {
      "post": {
        "tags": [
          "Analysis"
        ],
        "summary": "Start Nextflow pipeline execution",
        "operationId": "startNextflowAnalysis",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "analysisStorageId": {
                    "type": "string"
                  },
                  "pipelineId": {
                    "type": "string"
                  },
                  "userReference": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Nextflow analysis started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Analysis"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Start Nextflow pipeline execution"
      }
    },
    "/projects/{projectId}/analyses": {
      "get": {
        "tags": [
          "Analysis"
        ],
        "summary": "Retrieve analysis list with offset-based pagination",
        "operationId": "listAnalyses",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pageOffset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of analyses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Analysis"
                      }
                    },
                    "totalItemCount": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Retrieve analysis list with offset-based pagination"
      }
    },
    "/projects/{projectId}/analyses/{analysisId}/outputs": {
      "get": {
        "tags": [
          "Analysis"
        ],
        "summary": "Fetch analysis outputs",
        "operationId": "getAnalysisOutputs",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "analysisId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Analysis outputs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "outputs": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Fetch analysis outputs"
      }
    },
    "/storageCredentials": {
      "get": {
        "tags": [
          "Storage"
        ],
        "summary": "Retrieve stored credential credentials list",
        "operationId": "listStorageCredentials",
        "responses": {
          "200": {
            "description": "List of storage credentials",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Retrieve stored credential credentials list"
      },
      "post": {
        "tags": [
          "Storage"
        ],
        "summary": "Store external S3 bucket credentials",
        "operationId": "createStorageCredentials",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accessKeyId": {
                    "type": "string"
                  },
                  "secretAccessKey": {
                    "type": "string"
                  },
                  "bucketName": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Credentials stored",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Store external S3 bucket credentials"
      }
    },
    "/pipelines/{pipelineId}:deprecate": {
      "post": {
        "tags": [
          "Pipelines"
        ],
        "summary": "Mark pipeline as deprecated",
        "operationId": "deprecatePipeline",
        "parameters": [
          {
            "name": "pipelineId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pipeline deprecated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Mark pipeline as deprecated"
      }
    },
    "/pipelines/{pipelineId}:archive": {
      "post": {
        "tags": [
          "Pipelines"
        ],
        "summary": "Archive pipeline",
        "operationId": "archivePipeline",
        "parameters": [
          {
            "name": "pipelineId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pipeline archived",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Archive pipeline"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "Analysis": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userReference": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "API key is missing or invalid",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}
