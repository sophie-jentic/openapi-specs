  "components": {
    "schemas": {
      "Person": {
        "type": "object",
        "properties": {
          "handle": {
            "type": "string"
          },
          "gramps_id": {
            "type": "string"
          },
          "gender": {
            "type": "integer"
          },
          "primary_name": {
            "type": "object",
            "properties": {
              "first_name": {
                "type": "string"
              },
              "surname_list": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "surname": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "birth_ref_index": {
            "type": "integer"
          },
          "death_ref_index": {
            "type": "integer"
          },
          "event_ref_list": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "family_list": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "parent_family_list": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "media_list": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "tag_list": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "note_list": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "change": {
            "type": "integer"
          }
        }
      },
      "PersonInput": {
        "type": "object",
        "properties": {
          "gender": {
            "type": "integer",
            "enum": [
              0,
              1,
              2
            ]
          },
          "primary_name": {
            "type": "object",
            "properties": {
              "first_name": {
                "type": "string"
              },
              "surname_list": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "surname": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Family": {
        "type": "object",
        "properties": {
          "handle": {
            "type": "string"
          },
          "gramps_id": {
            "type": "string"
          },
          "father_handle": {
            "type": "string"
          },
          "mother_handle": {
            "type": "string"
          },
          "child_ref_list": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "type": {
            "type": "string"
          }
        }
      },
      "FamilyInput": {
        "type": "object",
        "properties": {
          "father_handle": {
            "type": "string"
          },
          "mother_handle": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "EventInput": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "date": {
            "type": "object"
          },
          "place": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token from POST /api/token"
      }
    }
  },
