{
  "openapi": "3.0.3",
  "info": {
    "title": "CallerAPI",
    "version": "1.0.0",
    "description": "CallerAPI provides phone number intelligence services including spam score, HLR lookup, KYC/identity verification, ported date, porting history, online presence detection, and daily spam report subscriptions via webhooks.",
    "x-jentic-source-url": "https://docs.callerapi.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.callerapi.com",
      "description": "CallerAPI Production"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Lookup",
      "description": "Phone number lookup operations"
    },
    {
      "name": "Reports",
      "description": "Daily spam reports and webhooks"
    },
    {
      "name": "Upload",
      "description": "Upload data"
    },
    {
      "name": "Account",
      "description": "Account information"
    }
  ],
  "paths": {
    "/api/v1/spam-score": {
      "get": {
        "operationId": "getSpamScoreHlr",
        "tags": [
          "Lookup"
        ],
        "summary": "Get spam score and HLR data for a phone number",
        "description": "Returns spam score, HLR (Home Location Register) data, and carrier information for a given phone number.",
        "parameters": [
          {
            "name": "phone",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Phone number in E.164 format"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "ISO 3166-1 alpha-2 country code"
          }
        ],
        "responses": {
          "200": {
            "description": "Spam score and HLR data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpamScoreResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/kyc": {
      "get": {
        "operationId": "getKycIdentity",
        "tags": [
          "Lookup"
        ],
        "summary": "Get KYC / user identity data for a phone number",
        "description": "Returns identity/KYC information associated with a phone number, including name, address, and carrier details.",
        "parameters": [
          {
            "name": "phone",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Phone number in E.164 format"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "ISO country code"
          }
        ],
        "responses": {
          "200": {
            "description": "KYC identity data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KycResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ported-date": {
      "get": {
        "operationId": "getPortedDate",
        "tags": [
          "Lookup"
        ],
        "summary": "Get the date a phone number was last ported",
        "parameters": [
          {
            "name": "phone",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Phone number in E.164 format"
          }
        ],
        "responses": {
          "200": {
            "description": "Ported date information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PortedDateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get the date a phone number was last ported"
      }
    },
    "/api/v1/porting-history": {
      "get": {
        "operationId": "getPortingHistory",
        "tags": [
          "Lookup"
        ],
        "summary": "Get the porting history of a phone number",
        "parameters": [
          {
            "name": "phone",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Phone number in E.164 format"
          }
        ],
        "responses": {
          "200": {
            "description": "Porting history",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PortingHistoryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get the porting history of a phone number"
      }
    },
    "/api/v1/online-presence": {
      "get": {
        "operationId": "getOnlinePresence",
        "tags": [
          "Lookup"
        ],
        "summary": "Detect online presence of a phone number",
        "description": "Checks whether a phone number is registered on various messaging platforms and social networks.",
        "parameters": [
          {
            "name": "phone",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Phone number in E.164 format"
          }
        ],
        "responses": {
          "200": {
            "description": "Online presence data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OnlinePresenceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/reports/daily": {
      "get": {
        "operationId": "fetchDailySpamReports",
        "tags": [
          "Reports"
        ],
        "summary": "Fetch daily spam reports",
        "description": "Retrieve daily spam reports for monitored phone numbers.",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Date to fetch reports for (YYYY-MM-DD)"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily spam reports",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailyReportsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/webhooks/subscribe": {
      "post": {
        "operationId": "subscribeToDailyReports",
        "tags": [
          "Reports"
        ],
        "summary": "Subscribe to daily spam reports via webhook",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscribeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription created"
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Subscribe to daily spam reports via webhook"
      }
    },
    "/api/v1/webhooks/unsubscribe": {
      "post": {
        "operationId": "unsubscribeFromDailyReports",
        "tags": [
          "Reports"
        ],
        "summary": "Unsubscribe from daily spam reports",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "webhook_id": {
                    "type": "string",
                    "description": "ID of the webhook subscription to remove"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Unsubscribed"
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Unsubscribe from daily spam reports"
      }
    },
    "/api/v1/webhooks": {
      "get": {
        "operationId": "listWebhookSubscriptions",
        "tags": [
          "Reports"
        ],
        "summary": "List all webhook subscriptions",
        "responses": {
          "200": {
            "description": "List of webhook subscriptions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WebhookSubscription"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List all webhook subscriptions"
      }
    },
    "/api/v1/webhooks/dispatch": {
      "post": {
        "operationId": "manualDispatchReports",
        "tags": [
          "Reports"
        ],
        "summary": "Manually dispatch reports to a webhook",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "webhook_id": {
                    "type": "string"
                  },
                  "date": {
                    "type": "string",
                    "format": "date"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reports dispatched"
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Manually dispatch reports to a webhook"
      }
    },
    "/api/v1/webhooks/test": {
      "post": {
        "operationId": "testWebhook",
        "tags": [
          "Reports"
        ],
        "summary": "Send a test payload to a webhook URL",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "webhook_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Test webhook sent"
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Send a test payload to a webhook URL"
      }
    },
    "/api/v1/upload/spam-reports": {
      "post": {
        "operationId": "uploadSpamReports",
        "tags": [
          "Upload"
        ],
        "summary": "Upload spam reports in bulk",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadSpamReportsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reports uploaded"
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Upload spam reports in bulk"
      }
    },
    "/api/v1/upload/contacts": {
      "post": {
        "operationId": "uploadContacts",
        "tags": [
          "Upload"
        ],
        "summary": "Upload contacts for monitoring",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadContactsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contacts uploaded"
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Upload contacts for monitoring"
      }
    },
    "/api/v1/account/balance": {
      "get": {
        "operationId": "getAccountBalance",
        "tags": [
          "Account"
        ],
        "summary": "Get account balance and email",
        "responses": {
          "200": {
            "description": "Account balance info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountBalanceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get account balance and email"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "CallerAPI API key"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "SpamScoreResponse": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string"
          },
          "spam_score": {
            "type": "number"
          },
          "spam_risk": {
            "type": "string"
          },
          "carrier": {
            "type": "string",
            "nullable": true
          },
          "line_type": {
            "type": "string",
            "nullable": true
          },
          "country": {
            "type": "string"
          },
          "hlr": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "mcc": {
                "type": "string"
              },
              "mnc": {
                "type": "string"
              },
              "network": {
                "type": "string"
              },
              "ported": {
                "type": "boolean"
              },
              "roaming": {
                "type": "boolean"
              }
            }
          }
        }
      },
      "KycResponse": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "carrier": {
            "type": "string",
            "nullable": true
          },
          "line_type": {
            "type": "string",
            "nullable": true
          },
          "country": {
            "type": "string"
          }
        }
      },
      "PortedDateResponse": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string"
          },
          "ported": {
            "type": "boolean"
          },
          "ported_date": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "carrier": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PortingHistoryResponse": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string"
          },
          "history": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string",
                  "format": "date"
                },
                "from_carrier": {
                  "type": "string"
                },
                "to_carrier": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "OnlinePresenceResponse": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string"
          },
          "platforms": {
            "type": "object",
            "additionalProperties": {
              "type": "boolean"
            },
            "description": "Map of platform names to presence booleans (e.g. whatsapp, telegram, viber)"
          }
        }
      },
      "DailyReportsResponse": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "reports": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "phone": {
                  "type": "string"
                },
                "spam_score": {
                  "type": "number"
                },
                "reports_count": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "WebhookSubscribeRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook URL to receive reports"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Event types to subscribe to"
          }
        }
      },
      "WebhookSubscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UploadSpamReportsRequest": {
        "type": "object",
        "required": [
          "reports"
        ],
        "properties": {
          "reports": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "phone": {
                  "type": "string"
                },
                "spam_score": {
                  "type": "number"
                },
                "reason": {
                  "type": "string",
                  "nullable": true
                }
              }
            }
          }
        }
      },
      "UploadContactsRequest": {
        "type": "object",
        "required": [
          "contacts"
        ],
        "properties": {
          "contacts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "phone": {
                  "type": "string"
                },
                "name": {
                  "type": "string",
                  "nullable": true
                },
                "label": {
                  "type": "string",
                  "nullable": true
                }
              }
            }
          }
        }
      },
      "AccountBalanceResponse": {
        "type": "object",
        "properties": {
          "balance": {
            "type": "number"
          },
          "email": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          }
        }
      }
    }
  }
}
