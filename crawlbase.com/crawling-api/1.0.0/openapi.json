{
  "openapi": "3.0.3",
  "info": {
    "title": "Crawlbase Crawling API",
    "version": "1.0.0",
    "description": "Crawlbase provides a web scraping and crawling API that handles proxies, CAPTCHAs, and browser rendering. Send a URL and receive the HTML content. Supports JavaScript rendering via the JS token.",
    "x-jentic-source-url": "https://crawlbase.com/docs/crawling-api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.crawlbase.com"
    }
  ],
  "tags": [
    {
      "name": "Crawling",
      "description": "Web page crawling and scraping"
    },
    {
      "name": "Screenshots",
      "description": "Web page screenshot capture"
    },
    {
      "name": "Storage",
      "description": "Access previously crawled data"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "crawlUrl",
        "summary": "Crawl a URL (GET)",
        "description": "Crawl a web page by providing a URL. Returns the HTML content. Use the Normal token for static pages or JS token for JavaScript-rendered pages.",
        "tags": [
          "Crawling"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token (Normal for static, JS for JavaScript rendering)"
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "description": "URL to crawl (must be URL-encoded)"
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "html",
                "json",
                "markdown",
                "text"
              ]
            },
            "description": "Response format"
          },
          {
            "name": "user_agent",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Custom User-Agent string"
          },
          {
            "name": "device",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "desktop",
                "mobile"
              ]
            },
            "description": "Device type for rendering"
          },
          {
            "name": "page_wait",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 30000
            },
            "description": "Milliseconds to wait for JS rendering (JS token only)"
          },
          {
            "name": "ajax_wait",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Wait for AJAX requests to complete (JS token only)"
          },
          {
            "name": "css_click_selector",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "CSS selector of element to click before capture (JS token only)"
          },
          {
            "name": "get_cookies",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include cookies in response headers"
          },
          {
            "name": "get_headers",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include original response headers"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            },
            "description": "Two-letter country code for geotargeting"
          },
          {
            "name": "store",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Store the crawled page for later retrieval"
          },
          {
            "name": "screenshot",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Take a screenshot of the page (JS token only)"
          },
          {
            "name": "screenshot_selector",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "CSS selector of element to screenshot"
          },
          {
            "name": "autoparse",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Auto-parse structured data from the page"
          }
        ],
        "responses": {
          "200": {
            "description": "Page content retrieved successfully",
            "headers": {
              "pc_status": {
                "schema": {
                  "type": "integer"
                },
                "description": "Crawlbase status code (200=success)"
              },
              "original_status": {
                "schema": {
                  "type": "integer"
                },
                "description": "Original HTTP status code from target"
              },
              "url": {
                "schema": {
                  "type": "string"
                },
                "description": "Final URL after redirects"
              },
              "rid": {
                "schema": {
                  "type": "string"
                },
                "description": "Request ID for storage retrieval"
              }
            },
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CrawlJsonResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "crawlUrlPost",
        "summary": "Crawl a URL (POST)",
        "description": "Crawl a web page by submitting POST data. Useful for form submissions and API calls.",
        "tags": [
          "Crawling"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "description": "URL to crawl"
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "html",
                "json",
                "markdown",
                "text"
              ]
            },
            "description": "Response format"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            },
            "description": "Country code for geotargeting"
          },
          {
            "name": "store",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Store the crawled page"
          },
          {
            "name": "autoparse",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Auto-parse structured data"
          }
        ],
        "requestBody": {
          "description": "POST data to send to the target URL",
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Crawl successful",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CrawlJsonResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/storage/{rid}": {
      "get": {
        "operationId": "getStoredCrawl",
        "summary": "Retrieve stored crawl data",
        "description": "Retrieve previously crawled and stored page data using the request ID (RID).",
        "tags": [
          "Storage"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          },
          {
            "name": "rid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Request ID from a previous crawl with store=true"
          }
        ],
        "responses": {
          "200": {
            "description": "Stored page content",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid RID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Stored data not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteStoredCrawl",
        "summary": "Delete stored crawl data",
        "description": "Delete previously stored crawl data by its request ID.",
        "tags": [
          "Storage"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          },
          {
            "name": "rid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Request ID to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Data deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "Crawlbase API token (Normal or JS)"
      }
    },
    "schemas": {
      "CrawlJsonResponse": {
        "type": "object",
        "properties": {
          "original_status": {
            "type": "integer"
          },
          "pc_status": {
            "type": "integer"
          },
          "url": {
            "type": "string"
          },
          "body": {
            "type": "string",
            "description": "Page HTML content"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "pc_status": {
            "type": "integer"
          }
        }
      }
    }
  }
}
