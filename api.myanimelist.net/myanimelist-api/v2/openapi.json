        "parameters": [
          {
            "name": "anime_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Delete my anime list item"
      }
    },
