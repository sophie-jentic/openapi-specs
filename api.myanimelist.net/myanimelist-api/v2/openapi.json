    "/anime/{anime_id}/my_list_status": {
      "patch": {
        "operationId": "update_anime_list_status",
        "summary": "Update my anime list status",
        "tags": [
          "User Animelist"
        ],
        "parameters": [
          {
            "name": "anime_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "watching",
                      "completed",
                      "on_hold",
                      "dropped",
                      "plan_to_watch"
                    ]
                  },
                  "is_rewatching": {
                    "type": "boolean"
                  },
                  "score": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 10
                  },
                  "num_watched_episodes": {
                    "type": "integer"
                  },
                  "priority": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 2
                  },
                  "num_times_rewatched": {
                    "type": "integer"
                  },
                  "rewatch_value": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 5
                  },
                  "tags": {
                    "type": "string"
                  },
                  "comments": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeListStatus"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update my anime list status"
      },
      "delete": {
        "operationId": "delete_anime_list_item",
        "summary": "Delete my anime list item",
        "tags": [
          "User Animelist"
