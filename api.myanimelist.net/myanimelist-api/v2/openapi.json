{
  "openapi": "3.0.3",
  "info": {
    "title": "MyAnimeList API",
    "version": "2",
    "description": "MyAnimeList API v2 for anime, manga, user lists, rankings, forums, and user profiles.",
    "x-jentic-source-url": "https://myanimelist.net/apiconfig/references/api/v2",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.myanimelist.net/v2"
    }
  ],
  "paths": {
    "/anime": {
      "get": {
        "operationId": "anime_list",
        "summary": "Get anime list",
        "description": "Search for anime.",
        "tags": [
          "Anime"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of fields to include"
          },
          {
            "name": "nsfw",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/anime/{anime_id}": {
      "get": {
        "operationId": "anime_details",
        "summary": "Get anime details",
        "tags": [
          "Anime"
        ],
        "parameters": [
          {
            "name": "anime_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Anime not found"
          }
