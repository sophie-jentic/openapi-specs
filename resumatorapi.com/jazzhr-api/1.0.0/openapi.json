{
  "openapi": "3.0.3",
  "info": {
    "title": "JazzHR API",
    "version": "1.0.0",
    "description": "JazzHR (formerly Resumator) API for managing applicants, jobs, users, contacts, activities, tasks, notes, files, categories, and questionnaires in the JazzHR recruiting platform.",
