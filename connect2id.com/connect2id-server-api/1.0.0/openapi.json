{
  "openapi": "3.0.3",
  "info": {
    "title": "Connect2id Server API",
    "version": "1.0.0",
    "description": "Connect2id is an OAuth 2.0 / OpenID Connect server. The API provides standard OAuth/OIDC endpoints plus management APIs for clients, sessions, and authorization.",
    "x-jentic-source-url": "https://connect2id.com/products/server/docs/api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "variables": {
        "host": {
          "default": "c2id.example.com",
          "description": "Connect2id server hostname"
        }
      }
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Master API token or access token"
      },
      "clientAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Client credentials (client_id:client_secret)"
      }
    },
    "schemas": {
      "ClientRegistration": {
        "type": "object",
        "properties": {
          "client_id": {
            "type": "string"
          },
          "client_secret": {
            "type": "string"
          },
          "client_name": {
            "type": "string"
          },
          "redirect_uris": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "grant_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "response_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scope": {
            "type": "string"
          },
          "token_endpoint_auth_method": {
            "type": "string"
          },
          "software_id": {
            "type": "string"
          },
          "software_version": {
            "type": "string"
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string",
            "enum": [
              "Bearer",
              "DPoP"
            ]
          },
          "expires_in": {
            "type": "integer"
          },
          "refresh_token": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "id_token": {
            "type": "string"
          }
        }
      },
      "TokenIntrospection": {
        "type": "object",
        "properties": {
          "active": {
            "type": "boolean"
          },
          "scope": {
            "type": "string"
          },
          "client_id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "token_type": {
            "type": "string"
          },
          "exp": {
            "type": "integer"
          },
          "iat": {
            "type": "integer"
          },
          "nbf": {
            "type": "integer"
          },
          "sub": {
            "type": "string"
          },
          "aud": {
            "type": "string"
          },
          "iss": {
            "type": "string"
          }
        }
      },
      "UserInfo": {
        "type": "object",
        "properties": {
          "sub": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "given_name": {
            "type": "string"
          },
          "family_name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "email_verified": {
            "type": "boolean"
          },
          "phone_number": {
            "type": "string"
          },
          "address": {
            "type": "object"
          }
        }
      },
      "ServerMetadata": {
        "type": "object",
        "properties": {
          "issuer": {
            "type": "string"
          },
          "authorization_endpoint": {
            "type": "string"
          },
          "token_endpoint": {
            "type": "string"
          },
          "userinfo_endpoint": {
            "type": "string"
          },
          "jwks_uri": {
            "type": "string"
          },
          "registration_endpoint": {
            "type": "string"
          },
          "scopes_supported": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "response_types_supported": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "grant_types_supported": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "token_endpoint_auth_methods_supported": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "introspection_endpoint": {
            "type": "string"
          },
          "revocation_endpoint": {
            "type": "string"
          },
          "pushed_authorization_request_endpoint": {
            "type": "string"
          },
          "end_session_endpoint": {
            "type": "string"
          }
        }
      },
      "JWKSet": {
        "type": "object",
        "properties": {
          "keys": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kty": {
                  "type": "string"
                },
                "use": {
                  "type": "string"
                },
                "kid": {
                  "type": "string"
                },
                "alg": {
                  "type": "string"
                },
                "n": {
                  "type": "string"
                },
                "e": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "AuthorizationSession": {
        "type": "object",
        "properties": {
          "sid": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "client": {
            "type": "object"
          },
          "scope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "claims": {
            "type": "object"
          },
          "sub_session": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "error_description": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/.well-known/openid-configuration": {
      "get": {
        "summary": "OpenID Connect Discovery",
        "operationId": "discovery",
        "tags": [
          "Discovery"
        ],
        "description": "Returns the OpenID Provider metadata",
        "responses": {
          "200": {
            "description": "Provider metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerMetadata"
                }
              }
            }
          }
        }
      }
    },
    "/jwks.json": {
      "get": {
        "summary": "JSON Web Key Set",
        "operationId": "jwks",
        "tags": [
          "Discovery"
        ],
        "description": "Returns the server's public JWK set for verifying tokens",
        "responses": {
          "200": {
            "description": "JWK Set",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JWKSet"
                }
              }
            }
          }
        }
      }
    },
    "/authorize": {
      "get": {
        "summary": "Authorization endpoint",
        "operationId": "authorize",
        "tags": [
          "Authorization"
        ],
        "description": "OAuth 2.0 / OpenID Connect authorization endpoint",
        "parameters": [
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "code",
                "token",
                "id_token",
                "code id_token",
                "code token",
                "code id_token token"
              ]
            }
          },
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scope",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "nonce",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code_challenge",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code_challenge_method",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "S256",
                "plain"
              ]
            }
          },
          {
            "name": "prompt",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "none",
                "login",
                "consent",
                "select_account",
                "create"
              ]
            }
          },
          {
            "name": "max_age",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "acr_values",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "claims",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "request",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "JWT request object"
            }
          },
          {
            "name": "request_uri",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "response_mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "query",
                "fragment",
                "form_post",
                "jwt"
              ]
            }
          },
          {
            "name": "dpop_jkt",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id_token_hint",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "login_hint",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to callback URI"
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/token": {
      "post": {
        "summary": "Token endpoint",
        "operationId": "token",
        "tags": [
          "Token"
        ],
        "description": "Exchange authorization code for tokens, refresh tokens, or client credentials",
        "security": [
          {
            "clientAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "authorization_code",
                      "refresh_token",
                      "client_credentials",
                      "urn:ietf:params:oauth:grant-type:device_code",
                      "urn:ietf:params:oauth:grant-type:jwt-bearer"
                    ]
                  },
                  "code": {
                    "type": "string"
                  },
                  "redirect_uri": {
                    "type": "string"
                  },
                  "refresh_token": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  },
                  "code_verifier": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/token/introspect": {
      "post": {
        "summary": "Token introspection",
        "operationId": "introspect",
        "tags": [
          "Token"
        ],
        "security": [
          {
            "clientAuth": []
          },
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "token_type_hint": {
                    "type": "string",
                    "enum": [
                      "access_token",
                      "refresh_token"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Introspection result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenIntrospection"
                }
              }
            }
          }
        },
        "description": "Token introspection"
      }
    },
    "/token/revoke": {
      "post": {
        "summary": "Token revocation",
        "operationId": "revoke",
        "tags": [
          "Token"
        ],
        "security": [
          {
            "clientAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "token_type_hint": {
                    "type": "string",
                    "enum": [
                      "access_token",
                      "refresh_token"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token revoked"
          }
        },
        "description": "Token revocation"
      }
    },
    "/userinfo": {
      "get": {
        "summary": "UserInfo endpoint",
        "operationId": "userinfo_get",
        "tags": [
          "UserInfo"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User claims",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserInfo"
                }
              }
            }
          }
        },
        "description": "UserInfo endpoint"
      },
      "post": {
        "summary": "UserInfo endpoint (POST)",
        "operationId": "userinfo_post",
        "tags": [
          "UserInfo"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User claims",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserInfo"
                }
              }
            }
          }
        },
        "description": "UserInfo endpoint (POST)"
      }
    },
    "/par": {
      "post": {
        "summary": "Pushed authorization request",
        "operationId": "par",
        "tags": [
          "Authorization"
        ],
        "security": [
          {
            "clientAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "response_type": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "redirect_uri": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  },
                  "state": {
                    "type": "string"
                  },
                  "code_challenge": {
                    "type": "string"
                  },
                  "code_challenge_method": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "PAR response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "request_uri": {
                      "type": "string"
                    },
                    "expires_in": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Pushed authorization request"
      }
    },
    "/clients": {
      "post": {
        "summary": "Register a client",
        "operationId": "clients_register",
        "tags": [
          "Client Registration"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientRegistration"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Client registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientRegistration"
                }
              }
            }
          }
        },
        "description": "Register a client"
      }
    },
    "/clients/{clientId}": {
      "get": {
        "summary": "Retrieve client registration",
        "operationId": "clients_get",
        "tags": [
          "Client Registration"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Client registration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientRegistration"
                }
              }
            }
          }
        },
        "description": "Retrieve client registration"
      },
      "put": {
        "summary": "Update client registration",
        "operationId": "clients_update",
        "tags": [
          "Client Registration"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientRegistration"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientRegistration"
                }
              }
            }
          }
        },
        "description": "Update client registration"
      },
      "delete": {
        "summary": "Delete client registration",
        "operationId": "clients_delete",
        "tags": [
          "Client Registration"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          }
        },
        "description": "Delete client registration"
      }
    },
    "/session/end": {
      "get": {
        "summary": "End session (logout)",
        "operationId": "endSession",
        "tags": [
          "Session"
        ],
        "parameters": [
          {
            "name": "id_token_hint",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "post_logout_redirect_uri",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect after logout"
          }
        },
        "description": "End session (logout)"
      }
    },
    "/authz-sessions": {
      "post": {
        "summary": "Create authorization session",
        "operationId": "authzSessions_create",
        "tags": [
          "Authorization Sessions"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session created",
            "content": {
              "application/json": {
                "schema": {
