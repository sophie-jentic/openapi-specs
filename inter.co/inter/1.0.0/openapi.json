{
  "openapi": "3.0.3",
  "info": {
    "title": "Banco Inter API",
    "description": "Banco Inter Empresas API for banking services including statements, balances, payments, Pix transactions, billing, and CNAB file processing. Provides comprehensive banking operations for Brazilian businesses.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developers.inter.co/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.inter.co",
      "description": "Inter production API server"
    },
    {
      "url": "https://sandbox.inter.co",
      "description": "Inter sandbox API server for testing"
    }
  ],
  "security": [
    {
      "oauth2": []
    },
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/oauth/v2/token": {
      "post": {
        "summary": "Get OAuth token",
        "description": "Obtain OAuth 2.0 access token for API authentication",
        "operationId": "getToken",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type",
                  "client_id",
                  "client_secret"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "client_credentials"
                    ]
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_secret": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string"
                    },
                    "token_type": {
                      "type": "string"
                    },
                    "expires_in": {
                      "type": "integer"
                    },
                    "scope": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/banking/v2/extrato": {
      "get": {
        "summary": "Get account statement",
        "description": "Retrieve account statement for a specific period",
        "operationId": "getStatement",
        "tags": [
          "Banking"
        ],
        "parameters": [
          {
            "name": "dataInicio",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date (YYYY-MM-DD)"
          },
          {
            "name": "dataFim",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date (YYYY-MM-DD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Statement retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Statement"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/banking/v2/saldo": {
      "get": {
        "summary": "Get account balance",
        "description": "Retrieve current account balance",
        "operationId": "getBalance",
        "tags": [
          "Banking"
        ],
        "parameters": [
          {
            "name": "dataSaldo",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Balance date (optional, defaults to current date)"
          }
        ],
        "responses": {
          "200": {
            "description": "Balance retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Balance"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/banking/v2/pagamento": {
      "post": {
        "summary": "Create payment",
        "description": "Process immediate or scheduled payment",
        "operationId": "createPayment",
        "tags": [
          "Payments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Payment created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/banking/v2/pagamento/{codigoPagamento}": {
      "get": {
        "summary": "Get payment details",
        "description": "Retrieve details of a specific payment",
        "operationId": "getPayment",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "codigoPagamento",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/pix/v2/cob": {
      "post": {
        "summary": "Create Pix charge",
        "description": "Create immediate or scheduled Pix charge",
        "operationId": "createPixCharge",
        "tags": [
          "Pix"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PixChargeRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pix charge created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PixChargeResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "get": {
        "summary": "List Pix charges",
        "description": "Retrieve list of Pix charges",
        "operationId": "listPixCharges",
        "tags": [
          "Pix"
        ],
        "parameters": [
          {
            "name": "inicio",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "fim",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of Pix charges",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cobs": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/PixCharge"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pix/v2/cob/{txid}": {
      "get": {
        "summary": "Get Pix charge",
        "description": "Retrieve details of a specific Pix charge",
        "operationId": "getPixCharge",
        "tags": [
          "Pix"
        ],
        "parameters": [
          {
            "name": "txid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pix charge details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PixCharge"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "summary": "Update Pix charge",
        "description": "Update an existing Pix charge",
        "operationId": "updatePixCharge",
        "tags": [
          "Pix"
        ],
        "parameters": [
          {
            "name": "txid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PixChargeUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pix charge updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PixCharge"
                }
              }
            }
          }
        }
      }
    },
    "/pix/v2/pix": {
      "get": {
        "summary": "List Pix payments",
        "description": "Retrieve list of Pix payments received",
        "operationId": "listPixPayments",
        "tags": [
          "Pix"
        ],
        "parameters": [
          {
            "name": "inicio",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "fim",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of Pix payments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pix": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/PixPayment"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pix/v2/pix/{e2eid}": {
      "get": {
        "summary": "Get Pix payment",
        "description": "Retrieve details of a specific Pix payment",
        "operationId": "getPixPayment",
        "tags": [
          "Pix"
        ],
        "parameters": [
          {
            "name": "e2eid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "End-to-end ID of the Pix payment"
          }
        ],
        "responses": {
          "200": {
            "description": "Pix payment details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PixPayment"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/cobranca/v2/boletos": {
      "post": {
        "summary": "Create boleto",
        "description": "Create a new boleto (Brazilian bank slip) with barcode and QR code",
        "operationId": "createBoleto",
        "tags": [
          "Billing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BoletoRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Boleto created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoletoResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "get": {
        "summary": "List boletos",
        "description": "Retrieve list of boletos",
        "operationId": "listBoletos",
        "tags": [
          "Billing"
        ],
        "parameters": [
          {
            "name": "dataInicial",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "dataFinal",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of boletos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "boletos": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Boleto"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/cobranca/v2/boletos/{nossoNumero}": {
      "get": {
        "summary": "Get boleto",
        "description": "Retrieve details of a specific boleto",
        "operationId": "getBoleto",
        "tags": [
          "Billing"
        ],
        "parameters": [
          {
            "name": "nossoNumero",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Boleto details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Boleto"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "post": {
        "summary": "Cancel boleto",
        "description": "Cancel an existing boleto",
        "operationId": "cancelBoleto",
        "tags": [
          "Billing"
        ],
        "parameters": [
          {
            "name": "nossoNumero",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "motivoCancelamento"
                ],
                "properties": {
                  "motivoCancelamento": {
                    "type": "string",
                    "enum": [
                      "ACERTOS",
                      "APEDIDOCLIENTE",
                      "PAGODIRETOAOCLIENTE"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Boleto cancelled"
          }
        }
      }
    },
    "/cnab/v2/arquivos": {
      "post": {
        "summary": "Upload CNAB file",
        "description": "Upload CNAB banking file for processing",
        "operationId": "uploadCnabFile",
        "tags": [
          "CNAB"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "File uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "codigoArquivo": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List CNAB files",
        "description": "Retrieve list of CNAB files",
        "operationId": "listCnabFiles",
        "tags": [
          "CNAB"
        ],
        "responses": {
          "200": {
            "description": "List of files",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "arquivos": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "codigoArquivo": {
                            "type": "string"
                          },
                          "nomeArquivo": {
                            "type": "string"
                          },
                          "dataUpload": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "status": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "/oauth/v2/token",
            "scopes": {
              "extrato.read": "Read account statements",
              "boleto.write": "Create and manage boletos",
              "pix.write": "Create Pix charges",
              "pix.read": "Read Pix transactions"
            }
          }
        }
      },
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-inter-conta-corrente",
        "description": "Account number for API operations"
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Unauthorized - Invalid or missing credentials",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "BadRequest": {
        "description": "Bad request - Invalid parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "Statement": {
        "type": "object",
        "properties": {
          "transacoes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "dataEntrada": {
                  "type": "string",
                  "format": "date"
                },
                "tipoTransacao": {
                  "type": "string"
                },
                "valor": {
                  "type": "number"
                },
                "titulo": {
                  "type": "string"
                },
                "descricao": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Balance": {
        "type": "object",
        "properties": {
          "disponivel": {
            "type": "number"
          },
          "bloqueado": {
            "type": "number"
          }
        }
      },
      "PaymentRequest": {
        "type": "object",
        "required": [
          "valor",
          "dataPagamento"
        ],
        "properties": {
          "valor": {
            "type": "number"
          },
          "dataPagamento": {
            "type": "string",
            "format": "date"
          },
          "codigoBarras": {
            "type": "string"
          },
          "descricao": {
            "type": "string"
          }
        }
      },
      "PaymentResponse": {
        "type": "object",
        "properties": {
          "codigoPagamento": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Payment": {
        "type": "object",
        "properties": {
          "codigoPagamento": {
            "type": "string"
          },
          "valor": {
            "type": "number"
          },
          "dataPagamento": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "PixChargeRequest": {
        "type": "object",
        "required": [
          "calendario",
          "valor"
        ],
        "properties": {
          "calendario": {
            "type": "object",
            "properties": {
              "expiracao": {
                "type": "integer",
                "description": "Expiration in seconds"
              }
            }
          },
          "devedor": {
            "type": "object",
            "properties": {
              "cpf": {
                "type": "string"
              },
              "cnpj": {
                "type": "string"
              },
              "nome": {
                "type": "string"
              }
            }
          },
          "valor": {
            "type": "object",
            "properties": {
              "original": {
                "type": "string"
              }
            }
          },
          "chave": {
            "type": "string",
            "description": "Pix key"
          },
          "solicitacaoPagador": {
            "type": "string"
          }
        }
      },
      "PixChargeResponse": {
        "type": "object",
        "properties": {
          "txid": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "PixCharge": {
        "type": "object",
        "properties": {
          "txid": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "valor": {
            "type": "object"
          },
          "pixCopiaECola": {
            "type": "string"
          }
        }
      },
      "PixChargeUpdate": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "PixPayment": {
        "type": "object",
        "properties": {
          "endToEndId": {
            "type": "string"
          },
          "txid": {
            "type": "string"
          },
          "valor": {
            "type": "string"
          },
          "horario": {
            "type": "string",
            "format": "date-time"
          },
          "pagador": {
            "type": "object"
          }
        }
      },
      "BoletoRequest": {
        "type": "object",
        "required": [
          "seuNumero",
          "valorNominal",
          "dataVencimento",
          "pagador"
        ],
        "properties": {
          "seuNumero": {
            "type": "string"
          },
          "valorNominal": {
            "type": "number"
          },
          "dataVencimento": {
            "type": "string",
            "format": "date"
          },
          "numDiasAgenda": {
            "type": "integer"
          },
          "pagador": {
            "type": "object",
            "properties": {
              "cpfCnpj": {
                "type": "string"
              },
              "nome": {
                "type": "string"
              },
              "endereco": {
                "type": "string"
              },
              "cidade": {
                "type": "string"
              },
              "uf": {
                "type": "string"
              },
              "cep": {
                "type": "string"
              }
            }
          },
          "mensagem": {
            "type": "object",
            "properties": {
              "linha1": {
                "type": "string"
              }
            }
          }
        }
      },
      "BoletoResponse": {
        "type": "object",
        "properties": {
          "nossoNumero": {
            "type": "string"
          },
          "codigoBarras": {
            "type": "string"
          },
          "linhaDigitavel": {
            "type": "string"
          },
          "qrCode": {
            "type": "string"
          }
        }
      },
      "Boleto": {
        "type": "object",
        "properties": {
          "nossoNumero": {
            "type": "string"
          },
          "seuNumero": {
            "type": "string"
