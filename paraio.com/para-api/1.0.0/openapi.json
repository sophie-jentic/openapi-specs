    "/{type}/search/{querytype}": {
      "get": {
        "operationId": "searchObjects",
        "summary": "Search for objects",
        "description": "Full-text search across objects of a given type",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "querytype",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "id",
                "ids",
                "nested",
                "nearby",
                "prefix",
                "similar",
                "tagged",
                "in",
                "terms",
                "wildcard",
                "count",
                "findlinks"
              ]
            }
          },
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
