{
  "openapi": "3.0.3",
  "info": {
    "title": "Para API",
    "version": "1.0.0",
    "description": "Para is an open-source backend framework/server. It provides a RESTful API for CRUD operations, full-text search, user management, social sign-in, and more.",
    "x-jentic-source-url": "https://paraio.org/docs/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://paraio.com/v1"
    }
  ],
  "paths": {
    "/jwt_auth": {
      "post": {
        "operationId": "signIn",
        "summary": "Sign in and obtain JWT token",
        "description": "Authenticate with the API and receive a JWT access token",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appid": {
                    "type": "string"
                  },
                  "provider": {
                    "type": "string"
                  },
                  "token": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "jwt": {
                      "type": "object",
                      "properties": {
                        "access_token": {
                          "type": "string"
                        },
                        "expires": {
                          "type": "integer"
                        },
                        "refresh": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{type}": {
