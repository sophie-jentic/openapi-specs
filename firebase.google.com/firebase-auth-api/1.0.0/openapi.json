{
  "openapi": "3.0.3",
  "info": {
    "title": "Firebase Auth REST API",
    "version": "1.0.0",
    "description": "The Firebase Auth REST API allows you to manage users and authentication using Google Identity Toolkit. Supports email/password auth, OAuth/IdP sign-in, custom token auth, account management, and email verification.",
    "x-jentic-source-url": "https://firebase.google.com/docs/reference/rest/auth",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://identitytoolkit.googleapis.com/v1",
      "description": "Identity Toolkit API v1"
    }
  ],
  "paths": {
    "/accounts:signUp": {
      "post": {
        "operationId": "signUpWithEmailPassword",
        "summary": "Sign up with email/password",
        "description": "Creates a new email/password user account.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "Firebase Web API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password",
                  "returnSecureToken"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  },
                  "returnSecureToken": {
                    "type": "boolean",
                    "default": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts:signInWithPassword": {
      "post": {
        "operationId": "signInWithEmailPassword",
        "summary": "Sign in with email/password",
        "description": "Signs in a user with email and password.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "Firebase Web API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password",
                  "returnSecureToken"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  },
                  "returnSecureToken": {
                    "type": "boolean",
                    "default": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sign in successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts:signInWithIdp": {
      "post": {
        "operationId": "signInWithIdp",
        "summary": "Sign in with OAuth/IdP",
        "description": "Signs in a user using credentials from an Identity Provider (e.g. Google, Facebook).",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "Firebase Web API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "requestUri",
                  "postBody",
                  "returnSecureToken",
                  "returnIdpCredential"
                ],
                "properties": {
                  "requestUri": {
                    "type": "string"
                  },
                  "postBody": {
                    "type": "string"
                  },
                  "returnSecureToken": {
                    "type": "boolean",
                    "default": true
                  },
                  "returnIdpCredential": {
                    "type": "boolean",
                    "default": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sign in successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts:signInWithCustomToken": {
      "post": {
        "operationId": "signInWithCustomToken",
        "summary": "Sign in with custom token",
        "description": "Signs in a user using a custom token generated by your server.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "Firebase Web API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "returnSecureToken"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "returnSecureToken": {
                    "type": "boolean",
                    "default": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sign in successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts:lookup": {
      "post": {
        "operationId": "getUserData",
        "summary": "Get user data",
        "description": "Returns account info for a user identified by their ID token.",
        "tags": [
          "Account Management"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "Firebase Web API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "idToken"
                ],
                "properties": {
                  "idToken": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User data returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserDataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts:update": {
      "post": {
        "operationId": "updateAccount",
        "summary": "Update account",
        "description": "Updates a user's profile information (display name, photo URL, email, password).",
        "tags": [
          "Account Management"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "Firebase Web API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "idToken"
                ],
                "properties": {
                  "idToken": {
                    "type": "string"
                  },
                  "displayName": {
                    "type": "string"
                  },
                  "photoUrl": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  },
                  "returnSecureToken": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts:delete": {
      "post": {
        "operationId": "deleteAccount",
        "summary": "Delete account",
        "description": "Deletes a user account.",
        "tags": [
          "Account Management"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "Firebase Web API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "idToken"
                ],
                "properties": {
                  "idToken": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts:sendOobCode": {
      "post": {
        "operationId": "sendOobCode",
        "summary": "Send email verification or password reset",
        "description": "Sends an out-of-band confirmation code (email verification or password reset).",
        "tags": [
          "Account Management"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "Firebase Web API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "requestType"
                ],
                "properties": {
                  "requestType": {
                    "type": "string",
                    "enum": [
                      "VERIFY_EMAIL",
                      "PASSWORD_RESET"
                    ]
                  },
                  "idToken": {
                    "type": "string",
                    "description": "Required for VERIFY_EMAIL"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Required for PASSWORD_RESET"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts:createAuthUri": {
      "post": {
        "operationId": "createAuthUri",
        "summary": "Create auth URI",
        "description": "Fetches providers associated with an email and creates a redirect URI for IdP sign-in.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "Firebase Web API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "identifier",
                  "continueUri"
                ],
                "properties": {
                  "identifier": {
                    "type": "string",
                    "format": "email"
                  },
                  "continueUri": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Auth URI created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "allProviders": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "registered": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "description": "Firebase ID token"
          },
          "email": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "expiresIn": {
            "type": "string",
            "description": "Token expiration time in seconds"
          },
          "localId": {
            "type": "string",
            "description": "Firebase user UID"
          },
          "registered": {
            "type": "boolean"
          }
        }
      },
      "UserDataResponse": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "localId": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "emailVerified": {
                  "type": "boolean"
                },
                "displayName": {
                  "type": "string"
                },
                "photoUrl": {
                  "type": "string"
                },
                "providerUserInfo": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                },
                "passwordHash": {
                  "type": "string"
                },
                "passwordUpdatedAt": {
                  "type": "number"
                },
                "validSince": {
                  "type": "string"
                },
                "disabled": {
                  "type": "boolean"
                },
                "lastLoginAt": {
                  "type": "string"
                },
                "createdAt": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "integer"
              },
              "message": {
                "type": "string"
              },
              "errors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "domain": {
                      "type": "string"
                    },
                    "reason": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "name": "key",
        "in": "query",
        "description": "Firebase Web API key passed as query parameter"
      }
    }
  },
  "security": [
    {
      "ApiKey": []
    }
  ],
  "tags": [
    {
      "name": "Account Management"
    },
    {
      "name": "Authentication"
    }
  ]
}
