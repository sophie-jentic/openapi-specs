{
  "openapi": "3.0.3",
  "info": {
    "title": "Blockchain.com Explorer API",
    "description": "Blockchain.com provides APIs for querying Bitcoin blockchain data including blocks, transactions, addresses, exchange rates, and real-time statistics. All values in the blockchain data are in Satoshi (1 BTC = 100,000,000 Satoshi).",
    "version": "1.0.0",
    "contact": {
      "name": "Blockchain.com",
      "url": "https://www.blockchain.com/explorer/api"
    }
  },
  "servers": [
    {
      "url": "https://blockchain.info",
      "description": "Blockchain.com API"
    }
  ],
  "paths": {
    "/rawblock/{block_hash}": {
      "get": {
        "summary": "Get single block by hash",
        "description": "Returns a single block in JSON format.",
        "operationId": "getRawBlock",
        "tags": [
          "Blockchain Data"
        ],
        "parameters": [
          {
            "name": "block_hash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The block hash"
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "hex"
              ]
            },
            "description": "Set to 'hex' to get binary block in hex format"
          }
        ],
        "responses": {
          "200": {
            "description": "Block data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Block"
                }
              }
            }
          }
        }
      }
    },
    "/rawtx/{tx_hash}": {
      "get": {
        "summary": "Get single transaction by hash",
        "description": "Returns a single transaction in JSON format.",
        "operationId": "getRawTransaction",
        "tags": [
          "Blockchain Data"
        ],
        "parameters": [
          {
            "name": "tx_hash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The transaction hash"
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "hex"
              ]
            },
            "description": "Set to 'hex' to get raw transaction in hex format"
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transaction"
                }
              }
            }
          }
        }
      }
    },
    "/block-height/{block_height}": {
      "get": {
        "summary": "Get blocks at a specific height",
        "description": "Returns blocks at the specified height. Sometimes more than one block is mined at the same height.",
        "operationId": "getBlockHeight",
        "tags": [
          "Blockchain Data"
        ],
        "parameters": [
          {
            "name": "block_height",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The block height"
          },
          {
            "name": "format",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "json"
              ]
            },
            "description": "Must be set to 'json'"
          }
        ],
        "responses": {
          "200": {
            "description": "Blocks at height",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "blocks": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Block"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rawaddr/{bitcoin_address}": {
      "get": {
        "summary": "Get single address data",
        "description": "Returns information about a single Bitcoin address including transactions.",
        "operationId": "getRawAddress",
        "tags": [
          "Blockchain Data"
        ],
        "parameters": [
          {
            "name": "bitcoin_address",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Bitcoin address"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            },
            "description": "Number of transactions to return (default and max: 50)"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Pagination offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Address data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Address"
                }
              }
            }
          }
        }
      }
    },
    "/multiaddr": {
      "get": {
        "summary": "Get multiple address data",
        "description": "Returns information about multiple Bitcoin addresses.",
        "operationId": "getMultiAddress",
        "tags": [
          "Blockchain Data"
        ],
        "parameters": [
          {
            "name": "active",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Pipe-separated list of Bitcoin addresses (e.g. addr1|addr2)"
          },
          {
            "name": "n",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 100
            },
            "description": "Number of transactions per address (default: 50, max: 100)"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Pagination offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Multiple address data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "addresses": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Address"
                      }
                    },
                    "txs": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Transaction"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/unspent": {
      "get": {
        "summary": "Get unspent outputs for an address",
        "description": "Returns unspent transaction outputs for a Bitcoin address.",
        "operationId": "getUnspentOutputs",
        "tags": [
          "Blockchain Data"
        ],
        "parameters": [
          {
            "name": "active",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Bitcoin address"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 250,
              "maximum": 1000
            },
            "description": "Number of outputs to return (default: 250, max: 1000)"
          },
          {
            "name": "confirmations",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Minimum confirmations filter"
          }
        ],
        "responses": {
          "200": {
            "description": "Unspent outputs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "unspent_outputs": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/UnspentOutput"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/balance": {
      "get": {
        "summary": "Get address balance",
        "description": "Returns the balance for one or more Bitcoin addresses.",
        "operationId": "getBalance",
        "tags": [
          "Blockchain Data"
        ],
        "parameters": [
          {
            "name": "active",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Pipe-separated list of Bitcoin addresses"
          }
        ],
        "responses": {
          "200": {
            "description": "Balance data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "properties": {
                      "final_balance": {
                        "type": "integer",
                        "description": "Balance in satoshi"
                      },
                      "n_tx": {
                        "type": "integer",
                        "description": "Number of transactions"
                      },
                      "total_received": {
                        "type": "integer",
                        "description": "Total received in satoshi"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/latestblock": {
      "get": {
        "summary": "Get latest block",
        "description": "Returns the latest block on the main chain.",
        "operationId": "getLatestBlock",
        "tags": [
          "Blockchain Data"
        ],
        "responses": {
          "200": {
            "description": "Latest block data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "hash": {
                      "type": "string"
                    },
                    "time": {
                      "type": "integer"
                    },
                    "block_index": {
                      "type": "integer"
                    },
                    "height": {
                      "type": "integer"
                    },
                    "txIndexes": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/unconfirmed-transactions": {
      "get": {
        "summary": "Get unconfirmed transactions",
        "description": "Returns unconfirmed transactions.",
        "operationId": "getUnconfirmedTransactions",
        "tags": [
          "Blockchain Data"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "json"
              ]
            }
          }
