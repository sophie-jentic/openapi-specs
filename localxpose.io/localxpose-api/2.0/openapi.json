                }
              }
            }
          }
        },
        "description": "Get current user information"
      }
    },
    "/user/access-token": {
      "post": {
        "operationId": "generateAccessToken",
        "summary": "Generate new access token",
        "tags": [
          "User"
        ],
        "responses": {
          "200": {
            "description": "New token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Generate new access token"
      }
    },
    "/tunnels/{id}/requests": {
      "get": {
        "operationId": "listTunnelRequests",
        "summary": "List tunnel request logs",
        "description": "View HTTP request inspection logs for a tunnel",
        "tags": [
          "Tunnels"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request logs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "method": {
                        "type": "string"
                      },
                      "path": {
                        "type": "string"
                      },
                      "status": {
                        "type": "integer"
                      },
                      "timestamp": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "duration": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Tunnel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "http",
              "https",
              "tcp",
              "udp",
              "tls"
            ]
          },
          "name": {
            "type": "string"
          },
          "subdomain": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "local_address": {
            "type": "string"
          },
          "local_port": {
            "type": "integer"
          },
          "remote_port": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "running",
              "stopped",
              "error"
            ]
          },
          "region": {
            "type": "string"
          },
          "public_url": {
            "type": "string",
            "format": "uri"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TunnelCreate": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "http",
              "https",
              "tcp",
              "udp",
              "tls"
            ]
          },
          "name": {
            "type": "string"
          },
          "subdomain": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "local_address": {
            "type": "string",
            "default": "127.0.0.1"
          },
          "local_port": {
            "type": "integer"
          },
          "region": {
            "type": "string",
            "enum": [
              "us",
              "eu",
              "ap",
              "sa"
            ]
          },
          "reserved_domain": {
            "type": "string"
          },
          "basic_auth": {
            "type": "string",
            "description": "username:password for tunnel access"
          }
        }
      },
      "Domain": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "subdomain",
              "custom"
            ]
          },
          "verified": {
            "type": "boolean"
          },
          "cname_target": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DomainCreate": {
        "type": "object",
        "required": [
          "name",
          "type"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "subdomain",
              "custom"
            ]
          }
        }
      },
      "UserInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "plan": {
            "type": "string"
          },
          "tunnels_limit": {
            "type": "integer"
          },
          "domains_limit": {
            "type": "integer"
          },
          "bandwidth_limit": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "data": {}
            }
          },
          "status": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "LocalXpose access token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Domains"
    },
    {
      "name": "Tunnels"
    },
    {
      "name": "User"
    }
  ]
}
