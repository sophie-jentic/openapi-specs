            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Stop a tunnel"
      }
    },
    "/domains": {
      "get": {
        "operationId": "listDomains",
        "summary": "List reserved domains",
        "description": "List all custom/reserved domains for the authenticated user",
        "tags": [
          "Domains"
        ],
        "responses": {
          "200": {
            "description": "Domain list",
            "content": {
