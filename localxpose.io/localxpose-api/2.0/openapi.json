              }
            }
          }
        }
      },
      "post": {
        "operationId": "reserveDomain",
        "summary": "Reserve a domain",
        "description": "Reserve a custom subdomain or bring your own domain",
        "tags": [
          "Domains"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DomainCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Domain reserved",
