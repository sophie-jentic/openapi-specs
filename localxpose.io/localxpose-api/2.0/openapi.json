{
  "openapi": "3.0.3",
  "info": {
    "title": "LocalXpose API",
    "version": "2.0",
    "description": "LocalXpose is a reverse proxy/tunneling service that exposes localhost services to the internet. The API provides management of tunnels, domains, and account settings.",
    "x-jentic-source-url": "https://localxpose.io/docs",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.localxpose.io/api/v2"
    }
  ],
  "paths": {
    "/tunnels": {
      "get": {
        "operationId": "listTunnels",
        "summary": "List active tunnels",
        "description": "Retrieve a list of all active tunnels for the authenticated user",
        "tags": [
          "Tunnels"
        ],
        "responses": {
          "200": {
            "description": "Tunnel list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Tunnel"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createTunnel",
        "summary": "Create a new tunnel",
        "description": "Create a new tunnel to expose a local service",
        "tags": [
          "Tunnels"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TunnelCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tunnel created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Tunnel"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tunnels/{id}": {
