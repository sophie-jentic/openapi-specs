    "/user": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current user information",
        "tags": [
          "User"
        ],
        "responses": {
          "200": {
            "description": "User info",
            "content": {
              "application/json": {
                "schema": {
