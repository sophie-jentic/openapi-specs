    },
    "/api/v1/paths/{path}/set-attribute": {
      "post": {
        "operationId": "setAttribute",
        "summary": "Set file or directory attributes",
        "description": "Sets attributes on a file or directory such as pinning, TTL, or permissions.",
        "tags": [
          "Path"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Path to update"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pinned": {
                    "type": "boolean"
                  },
                  "ttl": {
                    "type": "integer",
                    "description": "Time-to-live in milliseconds"
                  },
                  "ttlAction": {
                    "type": "string",
                    "enum": [
                      "DELETE",
                      "FREE"
                    ]
                  },
                  "persisted": {
                    "type": "boolean"
                  },
                  "recursive": {
                    "type": "boolean"
                  },
                  "owner": {
                    "type": "string"
                  },
                  "group": {
                    "type": "string"
                  },
                  "permission": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Attributes set"
