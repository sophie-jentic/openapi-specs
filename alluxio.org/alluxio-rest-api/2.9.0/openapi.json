                "type": "object",
                "properties": {
                  "src": {
                    "type": "string",
                    "description": "Under storage URI (e.g., s3://bucket/path, hdfs://host/path)"
                  },
                  "readOnly": {
                    "type": "boolean",
                    "default": false
                  },
                  "properties": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "src"
