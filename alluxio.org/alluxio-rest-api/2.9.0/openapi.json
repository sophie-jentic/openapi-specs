{
  "openapi": "3.0.3",
  "info": {
    "title": "Alluxio REST API",
    "version": "2.9.0",
    "description": "REST API for Alluxio distributed data orchestration system. Provides proxy-based filesystem operations including reading and writing files, listing directories, creating directories, mounting and unmounting under storage systems, and managing file metadata. The proxy REST API translates HTTP requests into Alluxio filesystem operations.",
    "x-jentic-source-url": "https://docs.alluxio.io/os/restdoc/2.9/proxy/index.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:39999"
    }
  ],
  "paths": {
    "/api/v1/paths/{path}/create-file": {
      "post": {
        "operationId": "createFile",
        "summary": "Create a new file",
        "description": "Creates a new file at the specified path in the Alluxio filesystem. Returns a stream ID for writing data.",
        "tags": [
          "File"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Alluxio file path (URL-encoded)"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "recursive": {
                    "type": "boolean",
                    "default": true,
                    "description": "Create parent directories if needed"
                  },
                  "blockSizeBytes": {
                    "type": "integer",
                    "description": "Block size in bytes"
                  },
                  "writeTier": {
                    "type": "integer",
                    "description": "Target storage tier"
                  },
                  "writeType": {
                    "type": "string",
                    "enum": [
                      "MUST_CACHE",
                      "CACHE_THROUGH",
                      "THROUGH",
                      "ASYNC_THROUGH"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File created, returns stream ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "streamId": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/paths/{path}/open-file": {
      "post": {
        "operationId": "openFile",
        "summary": "Open a file for reading",
        "description": "Opens an existing file for reading. Returns a stream ID for reading data.",
        "tags": [
          "File"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Alluxio file path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "readType": {
                    "type": "string",
                    "enum": [
                      "NO_CACHE",
                      "CACHE",
                      "CACHE_PROMOTE"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File opened, returns stream ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "streamId": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/streams/{streamId}/read": {
      "post": {
        "operationId": "readStream",
        "summary": "Read data from a stream",
        "description": "Reads data from an open file stream. Returns the file content as bytes.",
        "tags": [
          "Stream"
        ],
        "parameters": [
          {
            "name": "streamId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Stream ID from open-file"
          }
        ],
        "responses": {
          "200": {
            "description": "File data",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/streams/{streamId}/write": {
      "post": {
        "operationId": "writeStream",
        "summary": "Write data to a stream",
        "description": "Writes data to an open file stream.",
        "tags": [
          "Stream"
        ],
        "parameters": [
          {
            "name": "streamId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Stream ID from create-file"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data written successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/streams/{streamId}/close": {
      "post": {
        "operationId": "closeStream",
        "summary": "Close a stream",
        "description": "Closes an open file stream and releases resources.",
        "tags": [
          "Stream"
        ],
        "parameters": [
          {
            "name": "streamId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Stream ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Stream closed"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
