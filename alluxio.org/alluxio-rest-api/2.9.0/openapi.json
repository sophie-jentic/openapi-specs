  "components": {
    "schemas": {
      "FileInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "ufsPath": {
            "type": "string",
            "description": "Under filesystem path"
          },
          "fileId": {
            "type": "integer"
          },
          "length": {
            "type": "integer",
            "description": "File size in bytes"
          },
          "blockSizeBytes": {
            "type": "integer"
