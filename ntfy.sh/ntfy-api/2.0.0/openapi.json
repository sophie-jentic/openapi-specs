    "/v1/stats": {
      "get": {
        "operationId": "getStats",
        "summary": "Get server statistics",
        "description": "Returns server statistics including number of messages and topics.",
        "tags": [
          "Server"
        ],
        "responses": {
          "200": {
            "description": "Server statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Stats"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/v1/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "Health check",
        "description": "Returns server health status. Returns 200 if the server is healthy.",
        "tags": [
          "Server"
        ],
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server is unhealthy"
          }
        }
      }
    },
    "/v1/info": {
      "get": {
        "operationId": "getServerInfo",
        "summary": "Get server information",
        "description": "Returns server configuration and capabilities.",
        "tags": [
