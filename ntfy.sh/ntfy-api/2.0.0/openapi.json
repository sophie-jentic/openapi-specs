            "schema": {
              "type": "string"
            },
            "description": "Topic name to subscribe to"
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Return messages since timestamp or duration"
          }
        ],
        "responses": {
          "101": {
            "description": "Switching protocols to WebSocket"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
