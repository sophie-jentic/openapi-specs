{
  "openapi": "3.0.3",
  "info": {
    "title": "ntfy API",
    "version": "2.0.0",
    "description": "ntfy (pronounced 'notify') is a simple HTTP-based pub-sub notification service. It allows sending push notifications to phones and desktops via PUT/POST requests. Topics are created on the fly and require no sign-up.",
    "x-jentic-source-url": "https://docs.ntfy.sh/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://ntfy.sh",
      "description": "Public ntfy server"
    }
  ],
  "tags": [
    {
      "name": "Publish",
      "description": "Send notifications to topics"
    },
    {
      "name": "Subscribe",
      "description": "Subscribe to notification topics"
    },
    {
      "name": "Account",
      "description": "User account management"
    },
    {
      "name": "Server",
      "description": "Server health and info"
    }
  ],
  "paths": {
    "/{topic}": {
      "post": {
        "operationId": "publishMessage",
        "summary": "Publish a message to a topic",
        "description": "Send a notification message to a topic. The message body becomes the notification content. Various headers control the notification behavior.",
        "tags": [
          "Publish"
        ],
        "parameters": [
          {
            "name": "topic",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Topic name to publish to"
          },
          {
            "name": "X-Title",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Notification title (aliases: Title, ti, t)"
          },
          {
            "name": "X-Priority",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "1",
                "2",
                "3",
                "4",
                "5",
                "min",
                "low",
                "default",
                "high",
                "max",
                "urgent"
              ]
            },
            "description": "Message priority (1=min, 5=max)"
          },
          {
            "name": "X-Tags",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated tags/emojis (aliases: Tags, tag, ta)"
          },
          {
            "name": "X-Click",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "description": "URL to open on notification click"
          },
          {
            "name": "X-Icon",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "description": "URL of notification icon (JPEG/PNG)"
          },
          {
            "name": "X-Actions",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Action buttons definition string"
          },
          {
            "name": "X-Attach",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "description": "URL of file to attach"
          },
          {
            "name": "X-Email",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "format": "email"
            },
            "description": "Email address to forward notification to"
          },
          {
            "name": "X-Delay",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Delay delivery (e.g., '30min', '2h', 'tomorrow 10am')"
          },
          {
            "name": "X-Markdown",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "yes",
                "no",
                "true",
                "false",
                "1",
                "0"
              ]
            },
            "description": "Enable Markdown formatting in the message body"
          },
          {
            "name": "X-Cache",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "yes",
                "no"
              ]
            },
            "description": "Control message caching"
          },
          {
            "name": "X-Firebase",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "yes",
                "no"
              ]
            },
            "description": "Control Firebase forwarding"
          },
          {
            "name": "X-Call",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Phone number for voice call notification"
          }
        ],
        "requestBody": {
          "description": "Message body (plain text or markdown)",
          "content": {
            "text/plain": {
              "schema": {
                "type": "string"
              }
            },
            "text/markdown": {
              "schema": {
                "type": "string"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PublishRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message published successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "Request entity too large"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      },
      "put": {
        "operationId": "publishMessagePut",
        "summary": "Publish a message via PUT (with file attachment)",
        "description": "Send a notification with a file attachment. The request body is the file content. Use the Filename header to set the attachment filename.",
        "tags": [
          "Publish"
        ],
        "parameters": [
          {
            "name": "topic",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Topic name to publish to"
          },
          {
            "name": "X-Filename",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filename for the attachment (aliases: Filename, File, f)"
          },
          {
            "name": "X-Title",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Notification title"
          },
          {
            "name": "X-Message",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Notification message (since body is the file)"
          },
          {
            "name": "X-Priority",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Message priority"
          },
          {
            "name": "X-Tags",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated tags"
          }
        ],
        "requestBody": {
          "description": "File content to attach",
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message with attachment published",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "413": {
            "description": "Attachment too large"
          }
        }
      }
    },
    "/": {
      "post": {
        "operationId": "publishMessageJson",
        "summary": "Publish a message via JSON body",
        "description": "Send a notification using a JSON body that includes the topic and all message parameters.",
        "tags": [
          "Publish"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PublishRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message published successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/{topic}/json": {
      "get": {
        "operationId": "subscribeJson",
        "summary": "Subscribe to topic (JSON stream)",
        "description": "Subscribe to a topic and receive notifications as a newline-delimited JSON stream. The connection is kept alive and new messages are streamed as they arrive.",
        "tags": [
          "Subscribe"
        ],
        "parameters": [
          {
            "name": "topic",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Topic name to subscribe to"
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Return messages since timestamp, duration, or message ID (e.g., '10m', '2023-01-01T00:00:00Z', 'p1234')"
          },
          {
            "name": "poll",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                1
              ]
            },
            "description": "Set to 1 to return cached messages and close connection"
          },
          {
            "name": "scheduled",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                1
              ]
            },
            "description": "Set to 1 to include scheduled/delayed messages"
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter expression for messages"
          }
        ],
        "responses": {
          "200": {
            "description": "Newline-delimited JSON stream of messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/{topic}/sse": {
      "get": {
        "operationId": "subscribeSse",
        "summary": "Subscribe to topic (SSE stream)",
        "description": "Subscribe to a topic and receive notifications as Server-Sent Events (SSE). Compatible with the EventSource browser API.",
        "tags": [
          "Subscribe"
        ],
        "parameters": [
          {
            "name": "topic",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Topic name to subscribe to"
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Return messages since timestamp, duration, or message ID"
          },
          {
            "name": "poll",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                1
              ]
            },
            "description": "Set to 1 to return cached messages and close connection"
          },
          {
            "name": "scheduled",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                1
              ]
            },
            "description": "Include scheduled/delayed messages"
          }
        ],
        "responses": {
          "200": {
            "description": "Server-Sent Events stream",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/{topic}/raw": {
      "get": {
        "operationId": "subscribeRaw",
        "summary": "Subscribe to topic (raw stream)",
        "description": "Subscribe to a topic and receive notifications as raw text, one per line.",
        "tags": [
          "Subscribe"
        ],
        "parameters": [
          {
            "name": "topic",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Topic name to subscribe to"
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Return messages since timestamp, duration, or message ID"
          },
          {
            "name": "poll",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                1
              ]
            },
            "description": "Set to 1 to return cached messages and close connection"
          }
        ],
        "responses": {
          "200": {
            "description": "Raw text stream of messages",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/{topic}/ws": {
      "get": {
        "operationId": "subscribeWebsocket",
        "summary": "Subscribe to topic (WebSocket)",
        "description": "Subscribe to a topic via WebSocket. Receives JSON-encoded messages.",
        "tags": [
          "Subscribe"
        ],
        "parameters": [
          {
            "name": "topic",
            "in": "path",
