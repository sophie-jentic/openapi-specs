  "components": {
    "schemas": {
      "Image": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateImageRequest": {
        "type": "object",
        "required": [
          "prompt"
        ],
        "properties": {
          "prompt": {
            "type": "string"
          },
          "width": {
            "type": "integer",
            "minimum": 520,
            "maximum": 2160,
            "default": 1600
          },
          "height": {
            "type": "integer",
            "minimum": 520,
            "maximum": 2160,
            "default": 1600
          },
          "quality": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "default": 2
          },
          "creativity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "default": 2
          },
          "hasWatermark": {
            "type": "boolean",
            "default": true
          },
          "baseModel": {
            "type": "string"
          },
          "resolution": {
            "type": "string",
            "enum": [
              "1k",
              "hd",
              "4k"
            ]
          }
        }
      },
      "CreateVideoRequest": {
        "type": "object",
        "required": [
          "prompt"
        ],
        "properties": {
          "prompt": {
            "type": "string"
          },
          "originalImageCompletionId": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          },
          "webhookUrl": {
            "type": "string"
          }
        }
      },
      "ImageEditRequest": {
        "type": "object",
        "required": [
          "mode",
          "prompt"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "context",
              "in",
              "out",
              "skin"
            ]
          },
          "prompt": {
            "type": "string"
          },
          "originalImageCompletionId": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "webhookUrl": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
