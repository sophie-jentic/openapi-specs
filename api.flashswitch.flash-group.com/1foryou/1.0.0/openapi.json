  "components": {
    "schemas": {
      "1foryouPurchaseRequest": {
        "required": [
          "acquirer",
          "amount",
          "requestId"
        ],
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string",
            "description": "Client-provided unique transaction identifier",
            "example": "bacdeae9-baa0-4da9-bd3f-284c44c14cdf"
          },
          "amount": {
            "type": "number",
            "description": "The value (minor denomination) of the voucher to be purchased",
            "example": 1000.0
          },
          "acquirer": {
            "type": "object",
            "properties": {
              "account": {
                "type": "object",
                "properties": {
                  "accountNumber": {
                    "type": "string",
                    "description": "The account number that was provided to you by your integration specialist. Note that the account number for transacting against sandbox or production may differ",
                    "example": "100100100011"
                  }
                }
              },
              "entityTag": {
                "type": "string",
                "description": "Client-provided metadata about the transaction. The content will be agreed upon with your integration specialist",
                "example": "entityReferenceTag"
              }
            },
            "description": "Container of information about the entity which is transacting on behalf of a customer"
          }
        }
      },
      "1foryouRedeemRequest": {
        "required": [
          "acquirer",
          "amount",
          "customerContact",
          "requestId",
          "voucherPin"
