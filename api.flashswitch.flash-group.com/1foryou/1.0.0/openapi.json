          "voucherPin": {
            "type": "string",
            "description": "The pin of the voucher to be redeemed",
            "example": "1109167509116501"
          },
          "amount": {
            "type": "number",
            "description": "The value (minor denomination) of the voucher to be redeemed. 0 will redeem the full value of the voucher. If partially redeemed, a new voucher will be issued for the balance of the original voucher",
            "example": 900.0
          },
          "customerContact": {
            "type": "object",
            "properties": {
              "mechanism": {
                "type": "string",
                "description": "The selected preferred communication mechanism",
                "enum": [
                  "SMS"
                ]
              },
              "address": {
                "type": "string",
                "description": "The appropriate address (per selected delivery mechanism) of the customer",
                "example": "27835249137"
              }
            },
            "description": "Receipt delivery definition of the customer to whom the change voucher will be issued. The requirement will be in accordance with your agreement for delivery of the receipt. A null value should be passed if not required"
