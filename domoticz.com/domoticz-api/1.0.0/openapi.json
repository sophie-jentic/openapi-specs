{
  "openapi": "3.0.3",
  "info": {
    "title": "Domoticz API",
    "version": "1.0.0",
    "description": "Domoticz is a home automation system. Its JSON API provides control over devices, scenes, hardware, and configuration. The API uses query parameters with a 'type' parameter to select the operation.",
    "x-jentic-source-url": "https://www.domoticz.com/wiki/Domoticz_API/JSON_URL%27s",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/json.htm": {
      "get": {
        "operationId": "apiRequest",
        "summary": "Generic Domoticz API request endpoint",
        "description": "All Domoticz API calls use this single endpoint with different query parameters. The 'type' parameter selects the operation category.",
        "tags": [
          "General"
        ],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "devices",
                "scenes",
                "command",
                "plans",
                "setused",
                "settings",
                "hardware",
                "users",
                "notifications",
                "events",
                "graph",
                "lightlog",
                "textlog",
                "scenelog"
              ]
            },
            "description": "API operation type"
          },
          {
            "name": "rid",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Device/scene/plan ID"
          },
          {
            "name": "param",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sub-command parameter"
          },
          {
            "name": "idx",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Device index"
          },
          {
            "name": "switchcmd",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "On",
                "Off",
                "Toggle",
                "Set Level",
                "Stop"
              ]
            },
            "description": "Switch command"
          },
          {
            "name": "level",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Dimmer level (0-100)"
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "light",
                "weather",
                "temperature",
                "utility",
                "wind",
                "rain",
                "uv",
                "baro"
              ]
            },
            "description": "Device filter"
          },
          {
            "name": "used",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false"
              ]
            },
            "description": "Filter used/unused devices"
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sort order"
          },
          {
            "name": "plan",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Plan/room ID filter"
          },
          {
            "name": "range",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "day",
                "week",
                "month",
                "year"
              ]
            },
            "description": "Time range for graphs"
          },
          {
            "name": "sensor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sensor type filter"
          },
          {
            "name": "svalue",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sensor value to set"
          },
          {
            "name": "nvalue",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Numeric value to set"
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Device/scene name"
          },
          {
            "name": "description",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Description"
          },
          {
            "name": "htype",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Hardware type"
          },
          {
            "name": "extra",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Extra parameters"
          },
          {
            "name": "color",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Color JSON for RGB lights"
          },
          {
            "name": "username",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Username (base64 encoded)"
          },
          {
            "name": "password",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Password (base64 encoded)"
          }
        ],
        "responses": {
          "200": {
            "description": "API response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DomoticzResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/json.htm?type=devices": {
      "get": {
        "operationId": "listDevices",
        "summary": "List all devices",
        "tags": [
          "Devices"
        ],
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "light",
                "weather",
                "temperature",
                "utility",
                "wind",
                "rain",
                "uv",
                "baro"
              ]
            }
          },
          {
            "name": "used",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false"
              ]
            }
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Name",
                "ID"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Device list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Device"
                      }
                    },
                    "status": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all devices"
      }
    },
