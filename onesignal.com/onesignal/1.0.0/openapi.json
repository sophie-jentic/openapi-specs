{
  "openapi": "3.0.0",
  "info": {
    "title": "OneSignal API",
    "version": "1.0.0",
    "description": "OneSignal is a customer engagement platform for push notifications, email, SMS, and in-app messaging. This API allows you to send messages, manage users, create segments, and track delivery.",
    "contact": {
      "name": "OneSignal Support",
      "url": "https://onesignal.com"
    }
  },
  "servers": [
    {
      "url": "https://api.onesignal.com"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/notifications": {
      "post": {
        "summary": "Create notification",
        "description": "Send push notifications, emails, or SMS messages to your users",
        "operationId": "createNotification",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "app_id"
                ],
                "properties": {
                  "app_id": {
                    "type": "string",
                    "description": "Your OneSignal application identifier"
                  },
                  "include_aliases": {
                    "type": "object",
                    "description": "Target users by external_id, onesignal_id, or custom alias (max 20,000)",
                    "additionalProperties": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  },
                  "included_segments": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Target predefined user segments"
                  },
                  "filters": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    },
                    "description": "Build real-time audiences with AND/OR logic (max 200 entries)",
                    "maxItems": 200
                  },
                  "contents": {
                    "type": "object",
                    "description": "Message body for push/SMS in multiple languages",
                    "additionalProperties": {
                      "type": "string"
                    },
                    "example": {
                      "en": "English message",
                      "es": "Mensaje en español"
                    }
                  },
                  "headings": {
                    "type": "object",
                    "description": "Push notification headings in multiple languages",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "subtitle": {
                    "type": "object",
                    "description": "Push notification subtitle",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "email_subject": {
                    "type": "string",
                    "description": "Email subject line"
                  },
                  "email_body": {
                    "type": "string",
                    "description": "Email HTML body content"
                  },
                  "email_preheader": {
                    "type": "string",
                    "description": "Email preheader text"
                  },
                  "email_from_name": {
                    "type": "string",
                    "description": "Email sender name"
                  },
                  "email_reply_to": {
                    "type": "string",
                    "description": "Email reply-to address"
                  },
                  "target_channel": {
                    "type": "string",
                    "enum": [
                      "push",
                      "email",
                      "sms"
                    ],
                    "description": "Specify the channel to send to"
                  },
                  "excluded_segments": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Remove users from included segments"
                  },
                  "include_subscription_ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Target specific subscriptions (max 20,000)",
                    "maxItems": 20000
                  },
                  "email_to": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Direct email addresses (max 20,000)",
                    "maxItems": 20000
                  },
                  "include_phone_numbers": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Phone numbers in E.164 format (max 20,000)",
                    "maxItems": 20000
                  },
                  "send_after": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Schedule delivery for a specific time (ISO 8601 format, UTC)"
                  },
                  "delayed_option": {
                    "type": "string",
                    "enum": [
                      "timezone",
                      "last-active"
                    ],
                    "description": "Per-user delivery optimization"
                  },
                  "delivery_time_of_day": {
                    "type": "string",
                    "description": "Consistent daily delivery time (e.g., '9:00AM')",
                    "example": "9:00AM"
                  },
                  "data": {
                    "type": "object",
                    "description": "Custom data payload",
                    "additionalProperties": true
                  },
                  "url": {
                    "type": "string",
                    "description": "URL to open when notification is clicked"
                  },
                  "ios_attachments": {
                    "type": "object",
                    "description": "iOS rich media attachments"
                  },
                  "big_picture": {
                    "type": "string",
                    "description": "Android big picture URL"
                  },
                  "buttons": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "text": {
                          "type": "string"
                        },
                        "icon": {
                          "type": "string"
                        }
                      }
                    },
                    "description": "Action buttons for notifications"
                  },
                  "priority": {
                    "type": "integer",
                    "description": "Delivery priority (0-10)"
                  },
                  "template_id": {
                    "type": "string",
                    "description": "Template identifier for email/SMS"
                  },
                  "sms_media_urls": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "SMS media URLs"
                  },
                  "sms_from": {
                    "type": "string",
                    "description": "SMS sender number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notification created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Message identifier for tracking"
                    },
                    "recipients": {
                      "type": "integer",
                      "description": "Number of recipients"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          },
          "429": {
            "description": "Too many requests - rate limit exceeded"
          }
        },
        "tags": [
          "notifications"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key authentication. Use format: 'Key YOUR_API_KEY'"
      }
    }
  },
  "tags": [
    {
      "name": "notifications"
    }
  ]
}
