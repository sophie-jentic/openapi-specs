{
  "openapi": "3.0.3",
  "info": {
    "title": "Persona API",
    "version": "2023-01-05",
    "description": "Persona provides identity verification infrastructure for businesses. Use the Persona API to create verifications (inquiries), manage accounts, access cases, retrieve documents, and perform risk/fraud checks.",
    "x-jentic-source-url": "https://docs.withpersona.com/openapi.json",
    "contact": {
      "url": "https://withpersona.com",
      "email": "support@withpersona.com"
    },
    "termsOfService": "https://withpersona.com/terms"
  },
  "servers": [
    {
      "url": "https://withpersona.com/api/v1",
      "description": "Persona API v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Inquiries",
      "description": "Identity verification inquiries"
    },
    {
      "name": "Accounts",
      "description": "Manage accounts"
    },
    {
      "name": "Reports",
      "description": "Risk and background check reports"
    },
    {
      "name": "Documents",
      "description": "Identity documents"
    },
    {
      "name": "Cases",
      "description": "Manage cases"
    },
    {
      "name": "Verifications",
      "description": "Individual verification steps"
    },
    {
      "name": "Events",
      "description": "Webhook events"
    },
    {
      "name": "Transactions",
      "description": "Transaction records"
    }
  ],
  "paths": {
    "/inquiries": {
      "get": {
        "operationId": "listInquiries",
        "tags": [
          "Inquiries"
        ],
        "summary": "List all Inquiries",
        "description": "Returns a list of inquiries.",
        "parameters": [
          {
            "name": "filter[reference-id]",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by reference ID"
          },
          {
            "name": "filter[account-id]",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[status]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "created",
                "pending",
                "completed",
                "expired",
                "failed",
                "needs_review",
                "approved",
                "declined"
              ]
            }
          },
          {
            "name": "page[size]",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page[before]",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page[after]",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InquiryList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      },
      "post": {
        "operationId": "createInquiry",
        "tags": [
          "Inquiries"
        ],
        "summary": "Create an Inquiry",
        "description": "Create a new inquiry for identity verification.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InquiryCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InquiryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "422": {
            "description": "Unprocessable entity"
          }
        }
      }
    },
    "/inquiries/{inquiry-id}": {
      "get": {
        "operationId": "retrieveInquiry",
        "tags": [
          "Inquiries"
        ],
        "summary": "Retrieve an Inquiry",
        "parameters": [
          {
            "name": "inquiry-id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InquiryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Retrieve an Inquiry"
      }
    },
    "/inquiries/{inquiry-id}/approve": {
      "post": {
        "operationId": "approveInquiry",
        "tags": [
          "Inquiries"
        ],
        "summary": "Approve an Inquiry",
        "parameters": [
          {
            "name": "inquiry-id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "meta": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not found"
          },
          "409": {
            "description": "Conflict"
          }
        },
        "description": "Approve an Inquiry"
      }
    },
    "/inquiries/{inquiry-id}/decline": {
      "post": {
        "operationId": "declineInquiry",
        "tags": [
          "Inquiries"
        ],
        "summary": "Decline an Inquiry",
        "parameters": [
          {
            "name": "inquiry-id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "meta": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not found"
          },
          "409": {
            "description": "Conflict"
          }
        },
        "description": "Decline an Inquiry"
      }
    },
