  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Persona API key. Include as Bearer token in Authorization header."
      }
    },
    "schemas": {
      "InquiryCreateRequest": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "default": "inquiry"
              },
              "attributes": {
                "type": "object",
                "properties": {
                  "inquiry-template-id": {
                    "type": "string"
                  },
                  "inquiry-template-version-id": {
                    "type": "string"
                  },
                  "reference-id": {
                    "type": "string"
                  },
                  "note": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "InquiryResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "id": {
                "type": "string"
              },
              "attributes": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "created",
                      "pending",
                      "completed",
                      "expired",
                      "failed",
                      "needs_review",
                      "approved",
                      "declined"
                    ]
                  },
                  "reference-id": {
                    "type": "string"
                  },
                  "created-at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "completed-at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "name-first": {
                    "type": "string"
                  },
                  "name-last": {
                    "type": "string"
                  },
                  "email-address": {
                    "type": "string"
                  },
                  "phone-number": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "InquiryList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InquiryResponse/properties/data"
            }
          },
          "meta": {
            "type": "object"
          }
        }
      },
      "AccountCreateRequest": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "default": "account"
              },
              "attributes": {
                "type": "object",
                "properties": {
                  "reference-id": {
                    "type": "string"
                  },
                  "country-code": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "AccountUpdateRequest": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "default": "account"
              },
              "attributes": {
                "type": "object",
                "properties": {
                  "name-first": {
                    "type": "string"
                  },
                  "name-last": {
                    "type": "string"
                  },
                  "email-address": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
