                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        },
        "tags": [
          "notes"
        ]
      },
      "post": {
        "summary": "Create a note",
        "description": "Create a new note in Slite",
        "operationId": "createNote",
