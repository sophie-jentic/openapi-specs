    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token for server-side API access"
      },
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://login.coinbase.com/oauth2/auth",
            "tokenUrl": "https://login.coinbase.com/oauth2/token",
            "scopes": {
              "wallet:accounts:read": "Read accounts",
              "wallet:transactions:read": "Read transactions",
              "wallet:transactions:send": "Send transactions"
            }
          }
        }
      }
    }
