            "type": "string"
          },
          "address_id": {
            "type": "string"
          },
          "from_amount": {
            "type": "string"
          },
          "from_asset_id": {
            "type": "string"
          },
          "to_amount": {
            "type": "string"
          },
          "to_asset_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "transaction": {
            "type": "object"
          }
        }
      },
      "Asset": {
        "type": "object",
        "properties": {
          "asset_id": {
            "type": "string"
          },
          "network_id": {
            "type": "string"
          },
          "contract_address": {
            "type": "string"
          },
          "decimals": {
            "type": "integer"
          }
        }
      },
