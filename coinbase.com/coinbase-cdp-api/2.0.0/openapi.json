          },
          "network_id": {
            "type": "string"
          },
          "wallet_id": {
            "type": "string"
          },
          "address_id": {
            "type": "string"
          },
          "destination": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "asset_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "broadcast",
              "complete",
              "failed"
            ]
          },
          "transaction_hash": {
            "type": "string"
          }
        }
      },
      "Trade": {
        "type": "object",
        "properties": {
          "trade_id": {
            "type": "string"
          },
