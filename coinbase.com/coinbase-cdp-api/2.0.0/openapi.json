        "type": "object",
        "properties": {
          "network_id": {
            "type": "string",
            "description": "Blockchain network ID"
          }
        }
      },
      "CreateTransferRequest": {
        "type": "object",
        "required": [
          "amount",
          "asset_id",
          "destination",
          "network_id"
        ],
        "properties": {
          "amount": {
            "type": "string"
          },
          "asset_id": {
            "type": "string"
          },
          "destination": {
            "type": "string"
          },
          "network_id": {
            "type": "string"
          }
        }
      },
      "CreateTradeRequest": {
        "type": "object",
        "required": [
          "amount",
          "from_asset_id",
          "to_asset_id"
