  "components": {
    "schemas": {
      "ApiResult": {
        "type": "object",
        "properties": {
          "values": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "integer"
          },
          "countFetched": {
            "type": "integer"
          },
          "countMatched": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error_code": {
            "type": "integer"
          },
          "error_message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "name": "X-Civi-Auth",
        "in": "header",
        "description": "CiviCRM API key and site key: 'Bearer api_key'"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "JWT or API key authentication"
      }
    }
  },
