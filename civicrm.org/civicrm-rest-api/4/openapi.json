{
  "openapi": "3.0.3",
  "info": {
    "title": "CiviCRM REST API",
    "version": "4",
    "description": "CiviCRM is an open-source constituent relationship management system for nonprofits, civic sector organizations, and advocacy groups. The API v4 provides CRUD access to contacts, activities, contributions, memberships, events, mailings, and more via a REST interface.",
    "x-jentic-source-url": "https://docs.civicrm.org/dev/en/latest/api/v4/rest/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{site}/civicrm/ajax/api4",
      "variables": {
        "site": {
          "default": "example.org",
          "description": "Your CiviCRM site domain"
        }
      }
    }
  ],
  "paths": {
    "/Contact/get": {
      "get": {
        "operationId": "getContacts",
        "summary": "Get contacts",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "select",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated field names"
          },
          {
            "name": "where",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "JSON-encoded where clauses"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "orderBy",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Contact list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get contacts"
      }
    },
    "/Contact/create": {
      "post": {
        "operationId": "createContact",
        "summary": "Create a contact",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "values": {
                    "type": "object",
                    "properties": {
                      "contact_type": {
                        "type": "string",
                        "enum": [
                          "Individual",
                          "Organization",
                          "Household"
                        ]
                      },
                      "first_name": {
                        "type": "string"
                      },
                      "last_name": {
                        "type": "string"
                      },
                      "email_primary.email": {
                        "type": "string"
                      },
                      "organization_name": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact created"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Create a contact"
      }
    },
    "/Contact/update": {
      "post": {
        "operationId": "updateContact",
        "summary": "Update a contact",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "where": {
                    "type": "array",
                    "items": {
                      "type": "array"
                    }
                  },
                  "values": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact updated"
          }
        },
        "description": "Update a contact"
      }
    },
