    "/ajax/api4/{entity}/getFields": {
      "post": {
        "operationId": "getEntityFields",
        "summary": "Get entity fields",
        "description": "Retrieve the list of fields available for a given entity.",
        "tags": [
          "Generic"
        ],
        "parameters": [
          {
            "name": "entity",
            "in": "path",
            "required": true,
            "description": "CiviCRM entity name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of fields for the entity",
