{
  "openapi": "3.0.3",
  "info": {
    "title": "CiviCRM REST API v4",
    "version": "4.0.0",
    "description": "CiviCRM APIv4 provides a standardized REST interface for accessing and managing CiviCRM data entities such as Contacts, Activities, Events, Contributions, Memberships, and more. The API uses entity-action patterns where you specify the entity and action in the URL path. Authentication is via API key or session-based authentication.",
    "x-jentic-source-url": "https://docs.civicrm.org/dev/en/latest/api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{your-site}/civicrm",
      "description": "CiviCRM REST API base URL (self-hosted)",
      "variables": {
        "your-site": {
          "default": "example.org",
          "description": "Your CiviCRM site domain"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Contacts",
      "description": "Manage CiviCRM contacts"
    },
    {
      "name": "Activities",
      "description": "Manage activities"
    },
    {
      "name": "Contributions",
      "description": "Manage contributions/donations"
    },
    {
      "name": "Events",
      "description": "Manage events"
    },
    {
      "name": "Memberships",
      "description": "Manage memberships"
    },
    {
      "name": "Generic",
      "description": "Generic entity operations"
    }
  ],
  "paths": {
    "/ajax/api4/{entity}/{action}": {
      "post": {
        "operationId": "executeEntityAction",
        "summary": "Execute an entity action via REST",
        "description": "Execute any CiviCRM APIv4 action on a given entity. Common actions include get, create, update, delete, save, replace, and getActions. The request body contains the action parameters including where clauses, values, limit, offset, orderBy, and select.",
        "tags": [
          "Generic"
        ],
        "parameters": [
          {
            "name": "entity",
            "in": "path",
            "required": true,
            "description": "CiviCRM entity name (e.g., Contact, Activity, Contribution, Event, Membership)",
            "schema": {
              "type": "string"
            },
            "example": "Contact"
          },
          {
            "name": "action",
            "in": "path",
            "required": true,
            "description": "Action to perform (e.g., get, create, update, delete, save, replace, getActions, getFields)",
            "schema": {
              "type": "string"
            },
            "example": "get"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful API response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - insufficient permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ajax/api4/Contact/get": {
      "post": {
        "operationId": "getContacts",
        "summary": "Get contacts",
        "description": "Retrieve a list of contacts with optional filtering, sorting, and field selection.",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiRequest"
              },
              "example": {
                "select": [
                  "id",
                  "display_name",
                  "email_primary.email"
                ],
                "where": [
                  [
                    "contact_type",
                    "=",
                    "Individual"
                  ]
                ],
                "limit": 25
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ajax/api4/Contact/create": {
      "post": {
        "operationId": "createContact",
        "summary": "Create a contact",
        "description": "Create a new contact in CiviCRM.",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiRequest"
              },
              "example": {
                "values": {
                  "contact_type": "Individual",
                  "first_name": "John",
                  "last_name": "Doe"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ajax/api4/Contact/update": {
      "post": {
        "operationId": "updateContact",
        "summary": "Update a contact",
        "description": "Update an existing contact. Requires 'where' clause to identify the record(s) to update and 'values' with the fields to change.",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiRequest"
              },
              "example": {
                "where": [
                  [
                    "id",
                    "=",
                    123
                  ]
                ],
                "values": {
                  "first_name": "Jane"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ajax/api4/Contact/delete": {
      "post": {
        "operationId": "deleteContact",
        "summary": "Delete a contact",
        "description": "Delete one or more contacts matching the where clause.",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiRequest"
              },
              "example": {
                "where": [
                  [
                    "id",
                    "=",
                    123
                  ]
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
