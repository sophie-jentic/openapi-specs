  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Civi-Auth",
        "description": "CiviCRM API key authentication. Can also use Bearer token or Basic auth depending on your CiviCRM configuration."
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication for CiviCRM REST API"
      }
    },
    "schemas": {
      "ApiRequest": {
        "type": "object",
        "description": "Standard CiviCRM APIv4 request parameters",
        "properties": {
          "select": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of fields to return"
          },
          "where": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {}
            },
            "description": "Array of conditions, each as [field, operator, value]"
          },
          "values": {
            "type": "object",
            "description": "Key-value pairs for create/update operations",
            "additionalProperties": true
          },
          "orderBy": {
            "type": "object",
            "description": "Fields to sort by with ASC or DESC direction",
            "additionalProperties": {
              "type": "string",
              "enum": [
                "ASC",
                "DESC"
              ]
            }
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of results to return",
            "default": 25
          },
          "offset": {
            "type": "integer",
            "description": "Number of results to skip",
            "default": 0
          },
          "having": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {}
            },
            "description": "Array of HAVING conditions for aggregate queries"
          },
          "groupBy": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Fields to group results by"
          },
          "join": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {}
            },
            "description": "Join definitions for related entities"
          },
          "chain": {
            "type": "object",
            "description": "Chained API calls to execute on each result",
            "additionalProperties": true
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "values": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "description": "Array of result records"
          },
          "count": {
            "type": "integer",
            "description": "Number of records returned"
          },
          "countFetched": {
            "type": "integer",
            "description": "Number of records fetched from database"
          },
          "countMatched": {
            "type": "integer",
            "description": "Total number of records matching the query"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error_code": {
            "type": "integer"
          },
          "error_message": {
            "type": "string"
          },
          "debug": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "security": [
    {
      "apiKey": []
    },
    {
      "bearerAuth": []
    }
  ]
}
