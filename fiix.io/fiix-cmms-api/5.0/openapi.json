{
  "openapi": "3.0.3",
  "info": {
    "title": "Fiix CMMS API",
    "version": "5.0",
    "description": "Fiix (by Rockwell Automation) is a cloud-based Computerized Maintenance Management System (CMMS). The REST API provides CRUD operations on all Fiix objects including assets, work orders, parts, purchase orders, locations, and users. Uses a single endpoint with operation-based JSON requests.",
    "x-jentic-source-url": "https://fiixlabs.github.io/api-documentation/guide.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{tenant}.machinemetrics.io/api/v2",
      "variables": {
        "tenant": {
          "default": "your-tenant",
          "description": "Fiix tenant subdomain"
        }
      }
    }
  ],
  "paths": {
    "/rpc": {
      "post": {
        "operationId": "executeRpc",
        "summary": "Execute an RPC operation",
        "description": "All Fiix API operations are sent as POST to /rpc. The 'name' field determines the action: FindRequest, AddRequest, ChangeRequest, RemoveRequest, GetBarcodeRequest, etc.",
        "tags": [
          "Operations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RpcRequest"
              },
              "examples": {
                "findAssets": {
                  "summary": "Find assets",
                  "value": {
                    "name": "FindRequest",
                    "fields": [
                      "id",
                      "strName",
                      "strDescription",
                      "strMake",
                      "strModel"
                    ],
                    "filters": [
                      {
                        "ql": "intCategoryID = ?",
                        "parameters": [
                          "12"
                        ]
                      }
                    ],
                    "className": "Asset",
                    "maxObjects": 50,
                    "startIndex": 0
                  }
                },
                "addWorkOrder": {
                  "summary": "Create a work order",
                  "value": {
                    "name": "AddRequest",
                    "className": "WorkOrder",
                    "fields": [
                      "strCode",
                      "strDescription",
                      "intSiteID",
                      "intRequestedByUserID"
                    ],
                    "object": {
                      "strCode": "WO-001",
                      "strDescription": "Pump repair",
                      "intSiteID": 1
                    }
                  }
                },
                "changeWorkOrder": {
                  "summary": "Update a work order",
                  "value": {
                    "name": "ChangeRequest",
                    "className": "WorkOrder",
                    "fields": [
                      "strDescription"
                    ],
                    "object": {
                      "id": 123,
                      "strDescription": "Updated description"
                    }
                  }
                },
                "removeWorkOrder": {
                  "summary": "Delete a work order",
                  "value": {
                    "name": "RemoveRequest",
                    "className": "WorkOrder",
                    "object": {
                      "id": 123
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RpcResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
