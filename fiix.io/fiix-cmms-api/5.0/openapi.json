            "type": "integer"
          }
        }
      },
      "Part": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "strName": {
            "type": "string"
          },
          "strDescription": {
            "type": "string"
          },
          "strCode": {
            "type": "string"
          },
          "dblQuantity": {
            "type": "number"
          },
          "dblUnitCost": {
            "type": "number"
          }
        }
      },
      "PurchaseOrder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "strCode": {
            "type": "string"
          },
          "intSupplierID": {
            "type": "integer"
          },
          "intPurchaseOrderStatusID": {
            "type": "integer"
          }
