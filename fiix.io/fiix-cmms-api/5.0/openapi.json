  "components": {
    "schemas": {
      "RpcRequest": {
        "type": "object",
        "required": [
          "name",
          "className"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "FindRequest",
              "AddRequest",
              "ChangeRequest",
              "RemoveRequest",
              "GetBarcodeRequest"
            ]
          },
          "className": {
            "type": "string",
            "description": "Fiix object class name (Asset, WorkOrder, Part, etc.)"
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "filters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ql": {
                  "type": "string"
                },
                "parameters": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "object": {
            "type": "object"
          },
          "maxObjects": {
            "type": "integer"
          },
          "startIndex": {
            "type": "integer"
          }
        }
      },
      "RpcResponse": {
        "type": "object",
        "properties": {
          "objects": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "totalObjects": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          }
        }
      },
