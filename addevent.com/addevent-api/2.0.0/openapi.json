                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "apple": {
                          "type": "string",
                          "format": "uri"
                        },
                        "google": {
                          "type": "string",
                          "format": "uri"
                        },
                        "outlook": {
                          "type": "string",
                          "format": "uri"
                        },
                        "outlookcom": {
                          "type": "string",
                          "format": "uri"
                        },
