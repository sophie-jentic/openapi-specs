{
  "openapi": "3.0.3",
  "info": {
    "title": "Aletheia Financial API",
    "description": "Access real-time stock data, crypto quotes, and financial information",
    "version": "2.0.0",
    "contact": {
      "name": "Aletheia Support",
      "url": "https://aletheiaapi.com"
    }
  },
  "servers": [
    {
      "url": "https://api.aletheiaapi.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/StockData": {
      "get": {
        "summary": "Stock Data",
        "description": "Access summary or statistical data for stocks, bonds, options, crypto, and more. Version 1 (deprecated) and version 2 available via Accept-Version header.",
        "operationId": "getStockData",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "description": "Security ticker symbol (e.g., MSFT, AAPL)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "summary",
            "in": "query",
            "description": "Include summary data (v1 only)",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "statistics",
            "in": "query",
            "description": "Include statistical data (v1 only)",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "Comma-separated field names to reduce response size (v2 only, e.g., Price,MarketCap,DayHigh,DayLow)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Accept-Version",
            "in": "header",
            "description": "API version (1 or 2)",
            "schema": {
              "type": "string",
              "enum": [
                "1",
                "2"
              ],
              "default": "1"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StockDataResponse"
                }
              }
            }
          }
        },
        "tags": [
          "StockData"
        ]
      }
    },
    "/Crypto": {
      "get": {
        "summary": "Crypto Quote",
        "description": "Get real-time cryptocurrency data",
        "operationId": "getCrypto",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "description": "Cryptocurrency trading symbol (e.g., BTC, DOGE, XRP)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CryptoResponse"
                }
              }
            }
          }
        },
        "tags": [
          "Crypto"
        ]
      }
    },
    "/v2/consumption": {
      "get": {
        "summary": "API Consumption",
        "description": "Track API call usage by endpoint for the current month",
        "operationId": "getConsumption",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConsumptionResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ]
      }
    },
    "/version": {
      "get": {
        "summary": "API Version",
        "description": "Returns the actively deployed service version",
        "operationId": "getVersion",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "version": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "version"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "StockDataResponse": {
        "type": "object",
        "properties": {
          "Symbol": {
            "type": "string"
          },
          "Name": {
            "type": "string"
          },
          "Price": {
            "type": "number",
            "format": "double"
          },
          "Change": {
            "type": "number",
            "format": "double"
          },
          "ChangePercent": {
            "type": "number",
            "format": "double"
          },
          "MarketCap": {
            "type": "number",
            "format": "double"
          },
          "Volume": {
            "type": "number",
            "format": "double"
          },
          "DayHigh": {
            "type": "number",
            "format": "double"
          },
          "DayLow": {
            "type": "number",
            "format": "double"
          },
          "YearHigh": {
            "type": "number",
            "format": "double"
          },
          "YearLow": {
            "type": "number",
            "format": "double"
          },
          "PERatio": {
            "type": "number",
            "format": "double"
          },
          "DividendYield": {
            "type": "number",
            "format": "double"
          },
          "EPS": {
            "type": "number",
            "format": "double"
          },
          "Beta": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "CryptoResponse": {
        "type": "object",
        "properties": {
          "Symbol": {
            "type": "string"
          },
          "Name": {
            "type": "string"
          },
          "Price": {
            "type": "number",
            "format": "double"
          },
          "Change": {
            "type": "number",
            "format": "double"
          },
          "ChangePercent": {
            "type": "number",
            "format": "double"
          },
          "MarketCap": {
            "type": "number",
            "format": "double"
          },
          "Volume": {
            "type": "number",
            "format": "double"
          },
          "High24h": {
            "type": "number",
            "format": "double"
          },
          "Low24h": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "ConsumptionResponse": {
        "type": "object",
        "properties": {
          "calls": {
            "type": "integer",
            "description": "Total calls across all services in current month"
          },
          "endpoints": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "name": {
                  "type": "string"
                },
                "calls": {
                  "type": "integer"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Crypto"
    },
    {
      "name": "StockData"
    },
    {
      "name": "v2"
    },
    {
      "name": "version"
    }
  ]
}
