{
  "openapi": "3.0.0",
  "info": {
    "title": "Checkly Public API",
    "version": "v1",
    "description": "Checkly Public API for managing monitoring infrastructure, retrieving account information, and exporting analytics. Authentication uses API keys via Bearer auth. Rate limit: 600 requests per 60 seconds for most routes.",
    "x-jentic-source-url": "https://www.checklyhq.com/v2/api-docs",
    "contact": {
      "url": "https://www.checklyhq.com"
    }
  },
  "servers": [
    {
      "url": "https://api.checklyhq.com",
      "description": "Checkly API"
    }
  ],
  "security": [
    {
      "Bearer": []
    }
  ],
  "tags": [
    {
      "name": "Checks",
      "description": "Manage checks"
    },
    {
      "name": "Check Groups",
      "description": "Manage check groups"
    },
    {
      "name": "Alert Channels",
      "description": "Manage alert channels"
    },
    {
      "name": "Dashboards",
      "description": "Manage dashboards"
    },
    {
      "name": "Snippets",
      "description": "Manage snippets"
    },
    {
      "name": "Analytics",
      "description": "Retrieve analytics data"
    }
  ],
  "paths": {
    "/v1/checks": {
      "get": {
        "operationId": "getV1Checks",
        "tags": [
          "Checks"
        ],
        "summary": "List all checks",
        "description": "Lists all current checks in your account.",
        "parameters": [
          {
            "name": "x-checkly-account",
            "in": "header",
            "schema": {
              "type": "string",
              "description": "Your Checkly account ID, found at https://app.checklyhq.com/settings/account/general"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "description": "Limit the number of results",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "number",
              "description": "Page number",
              "default": 1
            }
          },
          {
            "name": "apiCheckUrlFilterPattern",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "Filters results by URL string (domain). Only returns API checks.",
              "minLength": 1
            }
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "checkType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "AGENTIC",
                "API",
                "BROWSER",
                "HEARTBEAT",
                "ICMP",
                "MULTI_STEP",
                "TCP",
                "PLAYWRIGHT",
                "URL",
                "DNS"
              ]
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "Filters checks by name using case-insensitive partial match"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "passing",
                "failing",
                "degraded"
              ]
            }
          },
          {
            "name": "applyGroupSettings",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false,
              "description": "Return group checks with group settings applied"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Check"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForbiddenError"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TooManyRequestsError"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "postV1Checks",
        "tags": [
          "Checks"
        ],
        "summary": "Create a check",
        "description": "Creates a new check in your account.",
        "parameters": [
          {
            "name": "x-checkly-account",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Check"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "429": {
            "description": "Too Many Requests"
          }
        }
      }
    },
    "/v1/checks/{id}": {
      "get": {
        "operationId": "getV1ChecksById",
        "tags": [
          "Checks"
        ],
        "summary": "Get a check by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-checkly-account",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Check"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not found"
          },
          "429": {
            "description": "Too Many Requests"
          }
        },
        "description": "Get a check by ID"
      },
      "put": {
        "operationId": "putV1ChecksById",
        "tags": [
          "Checks"
        ],
        "summary": "Update a check",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-checkly-account",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Check"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not found"
          },
          "429": {
            "description": "Too Many Requests"
          }
        },
        "description": "Update a check"
      },
      "delete": {
        "operationId": "deleteV1ChecksById",
        "tags": [
          "Checks"
        ],
        "summary": "Delete a check",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-checkly-account",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No content - deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not found"
          },
          "429": {
            "description": "Too Many Requests"
          }
        },
        "description": "Delete a check"
      }
    },
    "/v1/checks/{id}/trigger": {
      "post": {
        "operationId": "postV1ChecksIdTrigger",
        "tags": [
          "Checks"
        ],
        "summary": "Trigger a check run",
        "description": "Triggers a single check to run immediately.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-checkly-account",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Check triggered"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not found"
          },
          "429": {
            "description": "Too Many Requests"
          }
        }
      }
    },
    "/v1/check-groups": {
      "get": {
        "operationId": "getV1CheckGroups",
        "tags": [
          "Check Groups"
        ],
        "summary": "List check groups",
        "parameters": [
          {
            "name": "x-checkly-account",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "number",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of check groups",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CheckGroup"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Too Many Requests"
          }
        },
        "description": "List check groups"
      }
    },
    "/v1/alert-channels": {
      "get": {
        "operationId": "getV1AlertChannels",
        "tags": [
          "Alert Channels"
        ],
        "summary": "List alert channels",
        "parameters": [
          {
            "name": "x-checkly-account",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "number",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of alert channels"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Too Many Requests"
          }
        },
        "description": "List alert channels"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Bearer",
        "description": "The Checkly Public API uses API keys to authenticate requests. Get your API Key at https://app.checklyhq.com/settings/user/api-keys.\n\nAuthentication uses the Bearer auth method in the Authorization header. Example:\ncurl -H \"Authorization: Bearer [apiKey]\" -H \"X-Checkly-Account: [accountId]\""
      }
    },
    "schemas": {
      "Check": {
        "type": "object",
        "required": [
          "checkType"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "checkType": {
            "type": "string",
            "description": "The type of the check.",
            "enum": [
              "AGENTIC",
              "API",
              "BROWSER",
              "HEARTBEAT",
              "ICMP",
              "MULTI_STEP",
              "TCP",
              "PLAYWRIGHT",
              "URL",
              "DNS"
            ]
          },
          "activated": {
            "type": "boolean"
          },
          "muted": {
            "type": "boolean"
          },
          "groupId": {
            "type": "integer"
          },
          "frequency": {
            "type": "integer"
          },
          "locations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CheckInput": {
        "type": "object",
        "required": [
          "name",
          "checkType"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "checkType": {
            "type": "string",
            "enum": [
              "API",
              "BROWSER",
              "HEARTBEAT",
              "ICMP",
              "MULTI_STEP",
              "TCP",
              "URL",
              "DNS"
            ]
          },
          "activated": {
            "type": "boolean",
            "default": true
          },
          "muted": {
            "type": "boolean",
            "default": false
          },
          "frequency": {
            "type": "integer"
          },
          "locations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CheckGroup": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "activated": {
            "type": "boolean"
          },
          "muted": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "UnauthorizedError": {
        "type": "object",
        "required": [
          "statusCode",
          "error"
        ],
        "properties": {
          "statusCode": {
            "type": "number",
            "enum": [
              401
            ]
          },
          "error": {
            "type": "string",
            "enum": [
              "Unauthorized"
            ]
          },
          "message": {
            "type": "string",
            "example": "Bad Token"
          }
        }
      },
      "ForbiddenError": {
        "type": "object",
        "required": [
          "statusCode",
          "error"
        ],
        "properties": {
          "statusCode": {
            "type": "number",
            "enum": [
              403
            ]
          },
          "error": {
            "type": "string",
            "enum": [
              "Forbidden"
            ]
          },
          "message": {
            "type": "string",
            "example": "Forbidden"
          }
        }
      },
      "TooManyRequestsError": {
        "type": "object",
        "required": [
          "statusCode",
          "error"
        ],
        "properties": {
          "statusCode": {
            "type": "number",
            "enum": [
              429
            ]
          },
          "error": {
            "type": "string",
            "enum": [
              "Too Many Requests"
            ]
          },
          "message": {
            "type": "string",
            "example": "Too Many Requests"
          }
        }
      }
    }
  }
}
