{
  "openapi": "3.0.0",
  "servers": [
    {
      "description": "Betala Staging",
      "url": "http://reporting.betala-staging.no/api/v2.0"
    },
    {
      "description": "Betala Production",
      "url": "http://reporting.betala.no/api/v2.0"
    }
  ],
  "info": {
    "description": "This is the documentation of the PowerBI APIs that are available in Betala.",
    "version": "1.0.0",
    "title": "Betala PowerBI APIs",
    "contact": {
      "email": "zakaria@hoopla.no"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/zak-betala/Betala_PowerBI_integration/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "betala-powerbi",
      "description": "Operations available for the betala Power BI integration."
    },
    {
      "name": "powerbi-integration"
    }
  ],
  "paths": {
    "/powerbi_data/{organization_id}": {
      "get": {
        "security": [
          {
            "apiKeyAuth": []
          }
        ],
        "tags": [
          "powerbi-integration"
        ],
        "summary": "search organization sales data",
        "operationId": "SearchOrganizationSalesData",
        "description": "By passing in the appropriate options, you can search for\nthe sales data of the organization. This will be used by Power BI to make the accounting reports.\n",
        "parameters": [
          {
            "in": "path",
            "name": "organization_id",
            "description": "organization id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "string",
              "example": "288953420"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results matching criteria",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "items": {
                    "$ref": "#/components/schemas/SearchResults"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad input parameter"
          },
          "401": {
            "description": "Not authorized to access to the sales data"
          },
          "403": {
            "description": "Authentication required"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SearchResults": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "Purchase.PurchaseId": {
              "type": "string",
              "example": "1c10b824-fb7c-4cec-bad3-e4898eb7936e"
            },
            "Purchase.DeviceId": {
              "type": "string",
              "example": "4494bdac01e6bf05"
            },
            "Purchase.CreatedDate": {
              "type": "string",
              "example": "2023-01-10 23:24:36.984+00"
            },
            "Purchase.FinalizedDate": {
              "type": "string",
              "example": "2023-01-10 23:24:55.9+00"
            },
            "SalesPointGroup.SalesPointGroupId": {
              "type": "string",
              "example": "5404"
            },
            "SalesPointGroup.Name": {
              "type": "string",
              "example": "sales groupe 1"
            },
            "SalesPoint.SalesPointId": {
              "type": "string",
              "example": "10628"
            },
            "SalesPoint.Name": {
              "type": "string",
              "example": "Sales point 1"
            },
            "Product.ProductId": {
              "type": "string",
              "example": "105912"
            },
            "Product.productName": {
              "type": "string",
              "example": "product a"
            },
            "Product.VAT": {
              "type": "string",
              "example": "5000"
            },
            "Product.Price": {
              "type": "string",
              "example": "25000"
            },
            "Transaction.TransactionId": {
              "type": "string",
              "example": "7137615"
            },
            "Transaction.TransactionType": {
              "type": "string",
              "example": "BAX"
            },
            "Transaction.Amount": {
              "type": "string",
              "example": "25000"
            },
            "Transaction.Successful": {
              "type": "string",
              "example": "t"
            },
            "Transaction.TerminalId": {
              "type": "string",
              "example": "84847866"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-POWER-BI-SECRET",
        "description": "Please provide your Betala Power BI Secret API key"
      }
    }
  }
}
