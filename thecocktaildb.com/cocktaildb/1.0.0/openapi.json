{
  "openapi": "3.0.0",
  "info": {
    "title": "TheCocktailDB API",
    "description": "An open, crowd-sourced database of drinks and cocktails from around the world",
    "version": "1.0.0",
    "contact": {
      "url": "https://www.thecocktaildb.com"
    }
  },
  "servers": [
    {
      "url": "https://www.thecocktaildb.com/api/json/v1/{apiKey}",
      "variables": {
        "apiKey": {
          "default": "1",
          "description": "API key - use '1' for testing/development"
        }
      }
    }
  ],
  "paths": {
    "/search.php": {
      "get": {
        "summary": "Search cocktails",
        "operationId": "searchCocktails",
        "parameters": [
          {
            "name": "s",
            "in": "query",
            "description": "Search cocktail by name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "f",
            "in": "query",
            "description": "Search cocktails by first letter",
            "schema": {
              "type": "string",
              "maxLength": 1
            }
          },
          {
            "name": "i",
            "in": "query",
            "description": "Search ingredient by name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "drinks": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Cocktail"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/lookup.php": {
      "get": {
        "summary": "Lookup cocktail or ingredient details",
        "operationId": "lookupDetails",
        "parameters": [
          {
            "name": "i",
            "in": "query",
            "description": "Lookup cocktail details by ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "iid",
            "in": "query",
            "description": "Lookup ingredient by ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "drinks": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Cocktail"
                      }
                    },
                    "ingredients": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Ingredient"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/random.php": {
      "get": {
        "summary": "Get a random cocktail",
        "operationId": "getRandomCocktail",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "drinks": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Cocktail"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/filter.php": {
      "get": {
        "summary": "Filter cocktails",
        "operationId": "filterCocktails",
        "parameters": [
          {
            "name": "i",
            "in": "query",
            "description": "Filter by ingredient",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "a",
            "in": "query",
            "description": "Filter by alcoholic status",
            "schema": {
              "type": "string",
              "enum": ["Alcoholic", "Non_Alcoholic", "Optional alcohol"]
            }
          },
          {
            "name": "c",
            "in": "query",
            "description": "Filter by category",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "g",
            "in": "query",
            "description": "Filter by glass type",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "drinks": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "strDrink": {
                            "type": "string"
                          },
                          "strDrinkThumb": {
                            "type": "string"
                          },
                          "idDrink": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/list.php": {
      "get": {
        "summary": "List categories, glasses, ingredients, or alcoholic filters",
        "operationId": "listOptions",
        "parameters": [
          {
            "name": "c",
            "in": "query",
            "description": "List categories",
            "schema": {
              "type": "string",
              "enum": ["list"]
            }
          },
          {
            "name": "g",
            "in": "query",
            "description": "List glasses",
            "schema": {
              "type": "string",
              "enum": ["list"]
            }
          },
          {
            "name": "i",
            "in": "query",
            "description": "List ingredients",
            "schema": {
              "type": "string",
              "enum": ["list"]
            }
          },
          {
            "name": "a",
            "in": "query",
            "description": "List alcoholic filters",
            "schema": {
              "type": "string",
              "enum": ["list"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "drinks": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Cocktail": {
        "type": "object",
        "properties": {
          "idDrink": {
            "type": "string"
          },
          "strDrink": {
            "type": "string"
          },
          "strDrinkAlternate": {
            "type": "string",
            "nullable": true
          },
          "strTags": {
            "type": "string",
            "nullable": true
          },
          "strVideo": {
            "type": "string",
            "nullable": true
          },
          "strCategory": {
            "type": "string"
          },
          "strIBA": {
            "type": "string",
            "nullable": true
          },
          "strAlcoholic": {
            "type": "string"
          },
          "strGlass": {
            "type": "string"
          },
          "strInstructions": {
            "type": "string"
          },
          "strDrinkThumb": {
            "type": "string"
          },
          "strIngredient1": {
            "type": "string",
            "nullable": true
          },
          "strIngredient2": {
            "type": "string",
            "nullable": true
          },
          "strIngredient3": {
            "type": "string",
            "nullable": true
          },
          "strIngredient4": {
            "type": "string",
            "nullable": true
          },
          "strIngredient5": {
            "type": "string",
            "nullable": true
          },
          "strMeasure1": {
            "type": "string",
            "nullable": true
          },
          "strMeasure2": {
            "type": "string",
            "nullable": true
          },
          "strMeasure3": {
            "type": "string",
            "nullable": true
          },
          "strMeasure4": {
            "type": "string",
            "nullable": true
          },
          "strMeasure5": {
            "type": "string",
            "nullable": true
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "Ingredient": {
        "type": "object",
        "properties": {
          "idIngredient": {
            "type": "string"
          },
          "strIngredient": {
            "type": "string"
          },
          "strDescription": {
            "type": "string",
            "nullable": true
          },
          "strType": {
            "type": "string",
            "nullable": true
          },
          "strAlcohol": {
            "type": "string",
            "nullable": true
          },
          "strABV": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
  }
}
