{
  "openapi": "3.0.3",
  "info": {
    "title": "Copy.ai Workflows API",
    "version": "1.0.0",
    "description": "The Copy.ai Workflows API allows you to trigger workflow runs, get workflow run details, and register webhooks for workflow events.",
    "x-jentic-source-url": "https://docs.copy.ai/docs",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.copy.ai/api",
      "description": "Copy.ai API"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "paths": {
    "/webhook": {
      "post": {
        "operationId": "registerWebhook",
        "summary": "Register a webhook",
        "tags": [
          "Webhooks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Register a webhook"
      },
      "get": {
        "operationId": "listWebhooks",
        "summary": "Get all webhooks",
        "tags": [
          "Webhooks"
        ],
        "responses": {
          "200": {
            "description": "List of webhooks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get all webhooks"
      }
    },
    "/webhook/{webhook_id}": {
      "get": {
        "operationId": "getWebhook",
        "summary": "Get a specific webhook",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "webhook_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Webhook ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get a specific webhook"
      },
      "delete": {
        "operationId": "removeWebhook",
        "summary": "Remove a webhook",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "webhook_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Webhook ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook removed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Remove a webhook"
      }
    },
    "/workflow/{workflow_id}/run": {
      "post": {
        "operationId": "startWorkflowRun",
        "summary": "Start a workflow run",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Workflow ID (e.g. WCFG-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowRunRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow run started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowRunCreatedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Start a workflow run"
      },
      "get": {
        "operationId": "listWorkflowRuns",
        "summary": "Get all workflow runs",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Workflow ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of workflow runs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowRunListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get all workflow runs"
      }
    },
    "/workflow/{workflow_id}/run/{run_id}": {
      "get": {
        "operationId": "getWorkflowRun",
        "summary": "Get a specific workflow run",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Workflow ID"
          },
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Workflow run ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Workflow run details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowRunResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get a specific workflow run"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "x-copy-ai-api-key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "WebhookRequest": {
        "type": "object",
        "required": [
          "url",
          "eventType"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to receive webhook events"
          },
          "eventType": {
            "type": "string",
            "enum": [
              "workflowRun.completed"
            ],
            "description": "Event type to subscribe to"
          },
          "workflowId": {
            "type": "string",
            "description": "Optional workflow ID to filter events. If omitted, events for all workflows will be sent."
          }
        }
      },
      "WebhookData": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Webhook ID"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook URL"
          },
          "eventType": {
            "type": "string",
            "description": "Event type"
          },
          "workflowId": {
            "type": "string",
            "description": "Associated workflow ID"
          }
        }
      },
      "WebhookResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/WebhookData"
          }
        }
      },
      "WebhookListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WebhookData"
            }
          }
        }
      },
      "WorkflowRunRequest": {
        "type": "object",
        "properties": {
          "startVariables": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Input variables for the workflow run"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "description": "Optional metadata for the run"
          }
        }
      },
      "WorkflowRunCreatedResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/WorkflowRunCreated"
          }
        }
      },
      "WorkflowRunCreated": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Run ID"
          }
        }
      },
      "WorkflowRunResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/WorkflowRunData"
          }
        }
      },
      "WorkflowRunListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkflowRunData"
            }
          }
        }
      },
      "WorkflowRunData": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Run ID"
          },
          "input": {
            "type": "object",
            "additionalProperties": true,
            "description": "Input variables"
          },
          "status": {
            "type": "string",
            "enum": [
              "PROCESSING",
              "COMPLETE",
              "FAILED"
            ],
            "description": "Current status of the workflow run"
          },
          "output": {
            "type": "object",
            "additionalProperties": true,
            "description": "Output variables"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Webhooks"
    },
    {
      "name": "Workflows"
    }
  ]
}
