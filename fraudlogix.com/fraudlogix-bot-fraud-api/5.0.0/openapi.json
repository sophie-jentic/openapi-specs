{
  "openapi": "3.0.3",
  "info": {
    "title": "Fraudlogix Bot & Fraud API",
    "version": "5.0.0",
    "description": "Fraudlogix IP risk lookup API for detecting bots, fraud, proxies, VPNs, and other malicious activity by IP address.",
    "x-jentic-source-url": "https://www.fraudlogix.com/wp-content/uploads/2025/02/fraudlogix_BOT-FRAUD-API.pdf",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://iplist.fraudlogix.com"
    }
  ],
  "paths": {
    "/v5": {
      "get": {
        "operationId": "lookupIPRisk",
        "summary": "IP Risk Lookup",
        "description": "Queries risk-related data for a specified IP address, including malicious activity detection, proxy identification, VPN status, and additional security metrics.",
        "tags": [
          "IP Risk"
        ],
        "parameters": [
          {
            "name": "ip",
            "in": "query",
            "required": true,
            "description": "The IP address to analyze",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IPRiskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IPRiskResponse": {
        "type": "object",
        "properties": {
          "IP": {
            "type": "string"
          },
          "RecentlySeen": {
            "type": "string"
          },
          "RiskScore": {
            "type": "number"
          },
          "MaskedDevices": {
            "type": "integer"
          },
          "Proxy": {
            "type": "string"
          },
          "TOR": {
            "type": "string"
          },
          "VPN": {
            "type": "string"
          },
          "DataCenter": {
            "type": "string"
          },
          "SearchEngineBot": {
            "type": "string"
          },
          "AbnormalTraffic": {
            "type": "string"
          },
          "ASN": {
            "type": "string"
          },
          "Organization": {
            "type": "string"
          },
          "ISP": {
            "type": "string"
          },
          "City": {
            "type": "string"
          },
          "Country": {
            "type": "string"
          },
          "CountryCode": {
            "type": "string"
          },
          "Region": {
            "type": "string"
          },
          "Timezone": {
            "type": "string"
          },
          "ConnectionType": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "IP Risk"
    }
  ]
}
