{
  "openapi": "3.0.3",
  "info": {
    "title": "WeCanTrack API",
    "description": "Automatically place subids in affiliate links to attribute affiliate conversions to click data. The WeCanTrack API provides access to conversion data, click tracking, transaction management, and affiliate network integration.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.wecantrack.com",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.wecantrack.com",
      "description": "WeCanTrack API server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Conversions",
      "description": "Conversion data and attribution"
    },
    {
      "name": "Clicks",
      "description": "Click tracking data"
    },
    {
      "name": "Transactions",
      "description": "Transaction management"
    },
    {
      "name": "Networks",
      "description": "Affiliate network integration"
    },
    {
      "name": "Websites",
      "description": "Website management"
    },
    {
      "name": "Reports",
      "description": "Reporting and analytics"
    }
  ],
  "paths": {
    "/v1/conversions": {
      "get": {
        "tags": [
          "Conversions"
        ],
        "summary": "List conversions",
        "operationId": "listConversions",
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date for the date range (YYYY-MM-DD)"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date for the date range (YYYY-MM-DD)"
          },
          {
            "name": "website_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by website ID"
          },
          {
            "name": "network_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by affiliate network ID"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "approved",
                "declined"
              ]
            },
            "description": "Filter by conversion status"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 200
            },
            "description": "Number of results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "List of conversions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversionListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List conversions"
      }
    },
    "/v1/conversions/{conversionId}": {
      "get": {
        "tags": [
          "Conversions"
        ],
        "summary": "Get a specific conversion",
        "operationId": "getConversion",
        "parameters": [
          {
            "name": "conversionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Conversion identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Conversion details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Conversion"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get a specific conversion"
      }
    },
    "/v1/clicks": {
      "get": {
        "tags": [
          "Clicks"
        ],
        "summary": "List click data",
        "operationId": "listClicks",
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date (YYYY-MM-DD)"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date (YYYY-MM-DD)"
          },
          {
            "name": "website_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by website ID"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 200
            },
            "description": "Results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "List of clicks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClickListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List click data"
      }
    },
    "/v1/transactions": {
      "get": {
        "tags": [
          "Transactions"
