            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of transactions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List transactions"
      }
    },
    "/v1/networks": {
      "get": {
        "tags": [
          "Networks"
        ],
        "summary": "List connected affiliate networks",
        "operationId": "listNetworks",
        "responses": {
          "200": {
            "description": "List of affiliate networks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NetworkListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List connected affiliate networks"
      }
    },
    "/v1/websites": {
      "get": {
        "tags": [
          "Websites"
        ],
        "summary": "List tracked websites",
        "operationId": "listWebsites",
        "responses": {
          "200": {
            "description": "List of websites",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebsiteListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List tracked websites"
      }
    },
    "/v1/reports/summary": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Get summary report",
        "operationId": "getSummaryReport",
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date (YYYY-MM-DD)"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date (YYYY-MM-DD)"
          },
          {
            "name": "group_by",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "day",
                "week",
                "month",
                "website",
                "network"
              ]
            },
            "description": "Group results by dimension"
          },
          {
            "name": "website_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by website ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Summary report data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SummaryReportResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get summary report"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "WeCanTrack API key for authentication"
      }
    },
    "schemas": {
      "ConversionListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Conversion"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "Conversion": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Conversion identifier"
          },
          "click_id": {
            "type": "string",
            "description": "Associated click identifier"
          },
          "website_id": {
            "type": "string",
            "description": "Website identifier"
          },
          "network_id": {
            "type": "string",
            "description": "Affiliate network identifier"
          },
          "network_name": {
            "type": "string",
            "description": "Affiliate network name"
          },
          "advertiser": {
            "type": "string",
            "description": "Advertiser name"
          },
          "commission": {
            "type": "number",
            "format": "double",
            "description": "Commission amount"
          },
          "currency": {
            "type": "string",
            "description": "Currency code (e.g., EUR, USD)"
          },
          "order_value": {
            "type": "number",
            "format": "double",
            "description": "Order value"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "approved",
              "declined"
            ],
            "description": "Conversion status"
          },
          "conversion_date": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time of conversion"
          },
          "click_date": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time of the attributed click"
          },
          "sub_id": {
            "type": "string",
            "description": "Sub-ID used for attribution"
          },
          "landing_page": {
            "type": "string",
            "description": "Landing page URL"
          },
          "referrer_url": {
            "type": "string",
            "description": "Referrer URL"
          },
          "source": {
            "type": "string",
            "description": "Traffic source"
          },
          "medium": {
            "type": "string",
            "description": "Traffic medium"
          },
          "campaign": {
            "type": "string",
            "description": "Campaign name"
          }
        }
      },
      "ClickListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Click"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "Click": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Click identifier"
          },
          "website_id": {
            "type": "string",
            "description": "Website identifier"
          },
          "sub_id": {
            "type": "string",
            "description": "Sub-ID placed in the affiliate link"
          },
          "affiliate_link": {
            "type": "string",
            "description": "Affiliate link URL"
          },
          "landing_page": {
            "type": "string",
            "description": "Landing page URL"
          },
          "referrer_url": {
            "type": "string",
            "description": "Referrer URL"
          },
          "click_date": {
            "type": "string",
            "format": "date-time",
            "description": "Click timestamp"
          },
          "user_agent": {
            "type": "string",
            "description": "Browser user agent"
          },
          "ip_address": {
            "type": "string",
            "description": "Visitor IP address"
          },
          "source": {
            "type": "string",
            "description": "Traffic source"
          },
          "medium": {
            "type": "string",
            "description": "Traffic medium"
          },
          "campaign": {
            "type": "string",
            "description": "Campaign name"
          }
        }
      },
      "TransactionListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Transaction identifier"
          },
          "conversion_id": {
            "type": "string",
            "description": "Associated conversion ID"
          },
          "network_id": {
            "type": "string",
            "description": "Network identifier"
          },
          "network_name": {
            "type": "string",
            "description": "Network name"
          },
          "advertiser": {
            "type": "string",
            "description": "Advertiser name"
          },
          "commission": {
            "type": "number",
            "format": "double",
            "description": "Commission amount"
          },
          "currency": {
            "type": "string",
            "description": "Currency code"
          },
          "order_value": {
            "type": "number",
            "format": "double",
            "description": "Order value"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "approved",
              "declined"
            ],
            "description": "Transaction status"
          },
          "transaction_date": {
            "type": "string",
            "format": "date-time",
            "description": "Transaction date"
          }
        }
      },
      "NetworkListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Network"
            }
          }
        }
      },
      "Network": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Network identifier"
          },
          "name": {
            "type": "string",
            "description": "Network name"
          },
          "status": {
            "type": "string",
            "description": "Connection status"
          },
          "connected_at": {
            "type": "string",
            "format": "date-time",
            "description": "Connection date"
          }
        }
      },
      "WebsiteListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Website"
            }
          }
        }
      },
      "Website": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Website identifier"
          },
          "name": {
            "type": "string",
            "description": "Website name"
          },
          "url": {
            "type": "string",
            "description": "Website URL"
          },
          "status": {
            "type": "string",
            "description": "Tracking status"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation date"
          }
        }
      },
      "SummaryReportResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SummaryRecord"
            }
          }
        }
      },
      "SummaryRecord": {
        "type": "object",
        "properties": {
          "period": {
            "type": "string",
            "description": "Time period or grouping label"
          },
          "clicks": {
            "type": "integer",
            "description": "Total clicks"
          },
          "conversions": {
            "type": "integer",
            "description": "Total conversions"
          },
          "commission": {
            "type": "number",
            "format": "double",
            "description": "Total commission"
          },
          "order_value": {
            "type": "number",
            "format": "double",
            "description": "Total order value"
          },
          "conversion_rate": {
            "type": "number",
            "format": "double",
            "description": "Conversion rate percentage"
          },
          "currency": {
            "type": "string",
            "description": "Currency code"
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "current_page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          },
          "total_pages": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error type"
          },
          "message": {
            "type": "string",
            "description": "Detailed error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  }
}
