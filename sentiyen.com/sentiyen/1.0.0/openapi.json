{
  "openapi": "3.0.3",
  "info": {
    "title": "Sentiyen API",
    "description": "Sentiyen AI-powered Q&A API for building conversational interfaces. Supports streaming and non-streaming message generation with references and followup questions.",
    "version": "3.0.0",
    "x-jentic-source-url": "https://sentiyen.readme.io/reference/about-the-sentiyen-api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.sentiyen.com",
      "description": "Sentiyen API server"
    }
  ],
  "paths": {
    "/chat/message": {
      "post": {
        "operationId": "createChatMessage",
        "tags": [
          "Messaging"
        ],
        "summary": "Send a chat message (non-streaming)",
        "description": "Generate an answer to a user question in a single API call. Returns the generated answer, IDs, and references. Pass the messageId if it was created, or the message and conversation details.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Answer generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/chat/message/followup-suggestions": {
      "post": {
        "operationId": "getFollowupSuggestions",
        "tags": [
          "Messaging"
        ],
        "summary": "Generate followup question suggestions",
        "description": "Generate suggested followup questions for a given message.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FollowupSuggestionsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Followup suggestions generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FollowupSuggestionsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/chat/message/feedback": {
      "post": {
        "operationId": "recordMessageFeedback",
        "tags": [
          "Messaging"
        ],
        "summary": "Record user feedback for a message",
        "description": "Record feedback given by the user for the generated answer.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeedbackRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Feedback recorded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Sentiyen API key"
      }
    },
    "schemas": {
      "ChatMessageRequest": {
        "type": "object",
        "properties": {
          "messageId": {
            "type": "string",
            "description": "Optional message ID if created in advance"
          },
          "message": {
            "type": "string",
            "description": "The user's question or message"
          },
          "conversationId": {
            "type": "string",
            "description": "ID of the conversation context"
          },
          "context": {
            "type": "object",
            "description": "Additional context for the message",
            "additionalProperties": true
          }
        }
      },
      "ChatMessageResponse": {
        "type": "object",
        "properties": {
          "messageId": {
            "type": "string"
          },
          "conversationId": {
            "type": "string"
          },
          "answer": {
            "type": "string",
            "description": "The generated answer"
          },
          "references": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Reference"
            }
          }
        }
      },
      "Reference": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        }
      },
      "FollowupSuggestionsRequest": {
        "type": "object",
        "properties": {
          "messageId": {
            "type": "string"
          },
          "conversationId": {
            "type": "string"
          }
        }
      },
      "FollowupSuggestionsResponse": {
        "type": "object",
        "properties": {
          "suggestions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "FeedbackRequest": {
        "type": "object",
        "properties": {
          "messageId": {
            "type": "string"
          },
          "rating": {
            "type": "integer",
            "description": "User rating for the answer"
          },
          "feedback": {
            "type": "string",
            "description": "Text feedback"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Messaging"
    }
  ]
}
