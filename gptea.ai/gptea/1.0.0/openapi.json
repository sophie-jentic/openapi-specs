{
  "openapi": "3.0.3",
  "info": {
    "title": "GPTea API",
    "version": "1.0.0",
    "description": "GPTea API for AI-powered tea recommendations and brewing assistance",
    "x-jentic-source-url": "https://app.gptea.ai/api/api-docs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://app.gptea.ai/api",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Tea",
      "description": "Tea operations"
    },
    {
      "name": "Brewing",
      "description": "Brewing recommendations"
    },
    {
      "name": "User",
      "description": "User management"
    }
  ],
  "paths": {
    "/teas": {
      "get": {
        "tags": [
          "Tea"
        ],
        "summary": "List Teas",
        "description": "Retrieve a list of available teas",
        "operationId": "listTeas",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by tea category"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of teas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Tea"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/teas/{teaId}": {
      "get": {
        "tags": [
          "Tea"
        ],
        "summary": "Get Tea",
        "description": "Retrieve details of a specific tea",
        "operationId": "getTea",
        "parameters": [
          {
            "name": "teaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tea details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Tea"
                }
              }
            }
          }
        }
      }
    },
    "/brewing/recommend": {
      "post": {
        "tags": [
          "Brewing"
        ],
        "summary": "Get Brewing Recommendation",
        "description": "Get AI-powered brewing recommendations for a tea",
        "operationId": "getBrewingRecommendation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BrewingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Brewing recommendation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrewingRecommendation"
                }
              }
            }
          }
        }
      }
    },
    "/user/preferences": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Get User Preferences",
        "description": "Retrieve user's tea preferences",
        "operationId": "getUserPreferences",
        "responses": {
          "200": {
            "description": "User preferences",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserPreferences"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "User"
        ],
        "summary": "Update User Preferences",
        "description": "Update user's tea preferences",
        "operationId": "updateUserPreferences",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserPreferences"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Preferences updated"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Tea": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "origin": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "caffeine_level": {
            "type": "string"
          }
        }
      },
      "BrewingRequest": {
        "type": "object",
        "required": [
          "tea_id"
        ],
        "properties": {
          "tea_id": {
            "type": "string"
          },
          "water_volume": {
            "type": "number"
          },
          "preferences": {
            "type": "object"
          }
        }
      },
      "BrewingRecommendation": {
        "type": "object",
        "properties": {
          "temperature": {
            "type": "number"
          },
          "steep_time": {
            "type": "integer"
          },
          "water_volume": {
            "type": "number"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "UserPreferences": {
        "type": "object",
        "properties": {
          "favorite_categories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "strength_preference": {
            "type": "string"
          },
          "caffeine_preference": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}
