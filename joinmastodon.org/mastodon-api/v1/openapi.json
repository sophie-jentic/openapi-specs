{
  "openapi": "3.0.3",
  "info": {
    "title": "Mastodon API",
    "version": "1.0.0",
    "description": "Mastodon is a decentralized social network. This API provides REST endpoints for posting statuses, interacting with content (favouriting, boosting, bookmarking), managing accounts, and more.",
    "x-jentic-source-url": "https://docs.joinmastodon.org/methods/statuses/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{instance}/api/v1",
      "variables": {
        "instance": {
          "default": "mastodon.social",
          "description": "Mastodon instance hostname"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/statuses": {
      "post": {
        "operationId": "createStatus",
        "tags": [
          "Statuses"
        ],
        "summary": "Post a new status",
        "description": "Publish a status with the given parameters.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/StatusCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status posted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable entity",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "getMultipleStatuses",
        "tags": [
          "Statuses"
        ],
        "summary": "View multiple statuses",
        "parameters": [
          {
            "name": "id[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Array of status IDs"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of Status entities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Status"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "View multiple statuses"
      }
    },
