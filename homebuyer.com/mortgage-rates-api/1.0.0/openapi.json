{
  "openapi": "3.0.3",
  "info": {
    "title": "Homebuyer.com Mortgage Rates API",
    "version": "1.0.0",
    "description": "Provides programmatic access to mortgage rates, economic calendar data, and market statistics. Beta: This API is in public beta. Rate limits and features may change.",
    "x-jentic-source-url": "https://homebuyer.com/api-docs",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.homebuyer.com",
      "description": "Primary endpoint"
    },
    {
      "url": "https://homebuyer.com/api/v1",
      "description": "Alternative endpoint"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/rates": {
      "get": {
        "operationId": "getMortgageRates",
        "tags": [
          "Rates"
        ],
        "summary": "Get current mortgage rates",
        "description": "Returns current mortgage rate information based on state, FICO score, loan-to-value, product type, occupancy, property type, loan term, and loan purpose.",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "description": "2-letter US state code",
            "schema": {
              "type": "string",
              "default": "CO",
              "example": "CA"
            },
            "required": false
          },
          {
            "name": "fico",
            "in": "query",
            "description": "FICO score tier (1-5)",
            "schema": {
              "type": "string",
              "default": "1"
            },
            "required": false
          },
          {
            "name": "ltv",
            "in": "query",
            "description": "Loan-to-Value tier (1-2)",
            "schema": {
              "type": "string",
              "default": "1"
            },
            "required": false
          },
          {
            "name": "product_type",
            "in": "query",
            "description": "Loan product type (e.g. conventional, fha, va)",
            "schema": {
              "type": "string",
              "default": "conventional"
            },
            "required": false
          },
          {
            "name": "occupancy",
            "in": "query",
            "description": "Property occupancy type (e.g. primary, secondary, investment)",
            "schema": {
              "type": "string",
              "default": "primary"
            },
            "required": false
          },
          {
            "name": "property_type",
            "in": "query",
            "description": "Type of property (e.g. single_family, condo, townhome)",
            "schema": {
              "type": "string",
              "default": "single_family"
            },
            "required": false
          },
          {
            "name": "loan_term",
            "in": "query",
            "description": "Loan term in years (e.g. 30, 20, 15, 10)",
            "schema": {
              "type": "string",
              "default": "30"
            },
            "required": false
          },
          {
            "name": "loan_purpose",
            "in": "query",
            "description": "Purpose of the loan (e.g. purchase, refinance)",
            "schema": {
              "type": "string",
              "default": "purchase"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Current mortgage rate data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Missing or invalid API key."
          },
          "429": {
            "description": "Rate Limited. Exceeded 100 requests/minute or 1,000 requests/hour."
          },
          "500": {
            "description": "Server Error"
          },
          "503": {
            "description": "Service Unavailable"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication. Can also be passed as Authorization: Bearer {key} or query param api_key or secret."
      }
    },
    "schemas": {
      "RateResponse": {
        "type": "object",
        "properties": {
          "rate_30yr": {
            "type": "number",
            "description": "30-year fixed mortgage rate as a percentage"
          },
          "parameters": {
            "type": "object",
            "description": "Echo of request parameters with labels"
          },
          "rate_change_weekly": {
            "type": "number",
            "nullable": true,
            "description": "Weekly rate change in percentage points"
          },
          "rate_change_line": {
            "type": "string",
            "nullable": true,
            "description": "Human-readable change line (e.g. 'down 0.125% this week')"
          },
          "last_updated": {
            "type": "string",
            "description": "Date of last rate update (YYYY-MM-DD)"
          },
          "national_average_rate": {
            "type": "number",
            "nullable": true,
            "description": "National average 30-year fixed rate (Freddie Mac PMMS)"
          },
          "optimal_blue_rate": {
            "type": "number",
            "nullable": true,
            "description": "FRED Optimal Blue 30-year rate, ≤80 LTV, 740+ FICO"
          },
          "optimal_blue_last_updated": {
            "type": "string",
            "nullable": true,
            "description": "Date of Optimal Blue rate (YYYY-MM-DD)"
          },
          "freddie_mac_rate": {
            "type": "number",
            "nullable": true,
            "description": "Freddie Mac PMMS 30-year fixed rate (national average)"
          },
          "freddie_mac_last_updated": {
            "type": "string",
            "nullable": true,
            "description": "Date of Freddie Mac rate (YYYY-MM-DD)"
          },
          "disclaimer": {
            "type": "string",
            "nullable": true,
            "description": "Optional disclaimer for display"
          },
          "metadata": {
            "type": "object",
            "description": "API version and documentation link"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Rates"
    }
  ]
}
