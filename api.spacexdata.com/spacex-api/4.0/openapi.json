    "/launches": {
      "get": {
        "operationId": "getAllLaunches",
        "summary": "Get all launches",
        "responses": {
          "200": {
            "description": "Array of all launches",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Launch"
                  }
                }
              }
            }
          }
        },
        "description": "Get all launches",
        "tags": [
          "launches"
        ]
      }
    },
    "/launches/{id}": {
      "get": {
        "operationId": "getLaunch",
        "summary": "Get a launch by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Launch details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Launch"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a launch by ID",
        "tags": [
          "launches"
        ]
      }
    },
