{
  "openapi": "3.0.3",
  "info": {
    "title": "7Targets API",
    "version": "1.0.0",
    "description": "AI Sales Assistant API for managing leads and assistants. Automate lead creation, updates, and follow-up management.",
    "x-jentic-source-url": "https://7targets.ai/help/integrate/api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.7targets.com"
    }
  ],
  "paths": {
    "/leads": {
      "post": {
        "operationId": "createLead",
        "summary": "Create a Lead",
        "description": "Creates or assigns a lead to an assistant",
        "tags": [
          "Leads"
        ],
        "parameters": [
          {
            "name": "7ts-user-identifier",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User identifier header"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LeadRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Lead created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Lead"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateLead",
        "summary": "Update a Lead",
        "description": "Modifies lead attributes or changes sequence assignment",
        "tags": [
          "Leads"
        ],
        "parameters": [
          {
            "name": "7ts-user-identifier",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User identifier header"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LeadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lead updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Lead"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/leads/stop/followup": {
      "put": {
        "operationId": "stopFollowup",
        "summary": "Stop Followup for Lead",
        "description": "Halts scheduled follow-up messages for a lead",
        "tags": [
          "Leads"
        ],
        "parameters": [
          {
            "name": "7ts-user-identifier",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User identifier header"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LeadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Followup stopped",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Lead"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/leads/assistant": {
      "get": {
        "operationId": "getAssistants",
        "summary": "Get Assistants",
        "description": "Retrieves paginated list of configured assistants",
        "tags": [
          "Assistants"
        ],
        "parameters": [
          {
            "name": "7ts-user-identifier",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User identifier header"
          },
          {
            "name": "searchString",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Search filter"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Page number"
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Page size"
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "lastModifiedDate,desc"
            },
            "description": "Sort order"
          }
        ],
        "responses": {
          "200": {
            "description": "Assistants list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssistantListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LeadRequest": {
        "type": "object",
        "required": [
          "name",
          "email",
          "assistantEmail"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Lead first name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Lead email address"
          },
          "assistantEmail": {
            "type": "string",
            "format": "email",
            "description": "Assistant email to assign lead to"
          },
          "lastName": {
            "type": "string",
            "description": "Lead last name"
          },
          "source": {
            "type": "string",
            "description": "Lead source"
          },
          "context": {
            "type": "string",
            "description": "Context for the lead"
          },
          "phone": {
            "type": "string",
            "description": "Phone number"
          },
          "scheduleId": {
            "type": "string",
            "description": "Schedule ID"
          },
          "scheduleName": {
            "type": "string",
            "description": "Schedule name"
          },
          "additionalInformationLine": {
            "type": "string",
            "description": "Additional info"
          },
          "customFields": {
            "type": "object",
            "description": "Custom field key-value pairs"
          }
        }
      },
      "Lead": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "assistantEmail": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "nextScheduleTime": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "AssistantListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Assistant"
            }
          },
          "totalCount": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          }
        }
      },
      "Assistant": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "lastModifiedDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token obtained from OAuth2 token endpoint"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Assistants"
    },
    {
      "name": "Leads"
    }
  ]
}
