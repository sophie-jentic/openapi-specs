{
  "openapi": "3.0.3",
  "info": {
    "title": "BusinessLogic API",
    "version": "1.0.0",
    "description": "BusinessLogic.online allows you to create APIs from Excel spreadsheets. The API enables executing webservices, retrieving input/output JSON schemas, and listing available webservices. Authentication uses an API key.",
    "x-jentic-source-url": "https://www.businesslogic.online/docs/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.businesslogic.online/api",
      "description": "BusinessLogic API"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Webservices",
      "description": "Execute and manage webservices"
    }
  ],
  "paths": {
    "/webservices": {
      "get": {
        "operationId": "listWebservices",
        "tags": [
          "Webservices"
        ],
        "summary": "List all available webservices",
        "description": "Returns a list of all webservices available in your account.",
        "responses": {
          "200": {
            "description": "List of webservices",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WebserviceSummary"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/webservices/{webservice_id}/execute": {
      "post": {
        "operationId": "executeWebservice",
        "tags": [
          "Webservices"
        ],
        "summary": "Execute a webservice",
        "description": "Execute a webservice with the given input parameters. The input schema varies per webservice and can be retrieved via the schema endpoint.",
        "parameters": [
          {
            "name": "webservice_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Webservice ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Input parameters as defined by the webservice's input JSON schema",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Execution result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Output as defined by the webservice's output JSON schema",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/webservices/{webservice_id}/schema": {
      "get": {
        "operationId": "getWebserviceSchema",
        "tags": [
          "Webservices"
        ],
        "summary": "Get JSON schema for a webservice",
        "description": "Returns the JSON schema that describes the input parameters and output format for a webservice. Can be used to build and validate forms.",
        "parameters": [
          {
            "name": "webservice_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Webservice ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Webservice schema",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebserviceSchema"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Api-Key",
        "description": "BusinessLogic API key"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "WebserviceSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Webservice unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Webservice name"
          },
          "description": {
            "type": "string",
            "description": "Webservice description"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "WebserviceSchema": {
        "type": "object",
        "properties": {
          "input": {
            "type": "object",
            "description": "JSON Schema describing expected input parameters",
            "additionalProperties": true
          },
          "output": {
            "type": "object",
            "description": "JSON Schema describing the output format",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
