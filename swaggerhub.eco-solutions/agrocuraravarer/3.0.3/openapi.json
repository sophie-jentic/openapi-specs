    "/commodity-profile/{commodityProfileId}/crops": {
      "get": {
        "security": [
          {
            "AuthToken": []
          }
        ],
        "tags": [
          "Commodity Crop/Field"
        ],
        "summary": "Fetch commodity profile aggregated field data of crops by year",
        "parameters": [
          {
            "in": "path",
            "name": "commodityProfileId",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The ID of the commodity profile to fetch field data from"
          },
          {
            "in": "query",
            "name": "year",
            "schema": {
              "type": "number"
            },
            "required": false,
            "description": "The year to fetch field data from, if empty current year is fetched"
          },
          {
            "in": "query",
            "name": "search",
            "schema": {
              "type": "string"
            },
            "required": false,
            "description": "Search for crops. Case-insensitive and searches in the whole string"
          }
        ],
        "responses": {
          "200": {
            "description": "aggregated field data of crops",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "totalAcres": {
                      "type": "number"
                    },
                    "totalAcresOwned": {
                      "type": "number"
                    },
                    "totalAcresRented": {
                      "type": "number"
                    },
                    "totalYield": {
                      "type": "number"
                    },
                    "crops": {
                      "type": "array",
                      "items": {
                        "allOf": [
                          {
                            "$ref": "#/components/schemas/AggregatedCropData"
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          },
          "202": {
            "description": "processing field data, please resend request in a few minutes"
          },
          "400": {
            "description": "Customer does not have CVR"
          },
          "401": {
            "description": "unauthorized"
          },
          "404": {
            "description": "commodity profile not found"
          },
          "500": {
            "description": "internal error"
          }
        },
        "description": "Fetch commodity profile aggregated field data of crops by year",
        "operationId": "get-commodity-profile-by-commodityprofileid-crops"
      }
    },
    "/commodity-profile/{commodityProfileId}/crops/{cropId}": {
      "get": {
        "security": [
          {
            "AuthToken": []
          }
        ],
        "tags": [
          "Commodity Crop/Field"
        ],
        "summary": "Fetch aggregated data grouped by crop type (Afgroede)",
        "parameters": [
          {
            "in": "path",
            "name": "commodityProfileId",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The ID of the commodity profile to fetch field data from"
          },
          {
            "in": "path",
            "name": "cropId",
            "schema": {
              "type": "number"
            },
            "required": true,
            "description": "The ID of the crop to fetch field data from (Afgkode)"
          },
          {
            "in": "query",
            "name": "year",
            "schema": {
              "type": "number"
            },
            "required": false,
            "description": "The year to fetch field data from, if empty current year is fetched"
          },
          {
            "in": "query",
            "name": "pageIndex",
            "schema": {
              "type": "number",
              "default": 1
            },
            "required": false,
            "description": "page index (first page is 1), if empty pageIndex is set to 1"
          },
          {
            "in": "query",
            "name": "pageSize",
            "schema": {
              "type": "number",
              "default": 10
            },
            "required": false,
            "description": "page size, if empty pageSize is set to 10"
          }
        ],
        "responses": {
          "200": {
            "description": "crop data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fields": {
                      "type": "array",
                      "items": {
                        "allOf": [
                          {
                            "$ref": "#/components/schemas/Field"
                          }
                        ]
                      }
                    },
                    "totalFields": {
                      "type": "number"
                    },
                    "pageIndex": {
                      "type": "number"
                    },
                    "pageSize": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          },
          "202": {
            "description": "processing field data, please resend request in a few minutes"
          },
          "400": {
            "description": "Customer does not have CVR"
          },
          "401": {
            "description": "unauthorized"
          },
          "404": {
            "description": "commodity profile not found"
          },
          "500": {
            "description": "internal error"
          }
        },
        "description": "Fetch aggregated data grouped by crop type (Afgroede)",
        "operationId": "get-commodity-profile-by-commodityprofileid-crops-by-cropid"
      }
    },
