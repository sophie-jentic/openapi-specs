  "paths": {
    "/customer-auth/request-otp": {
      "post": {
        "tags": [
          "Customer Auth"
        ],
        "summary": "Request OTP code for customer to login",
        "requestBody": {
          "required": true,
          "description": "Auth identifier (email or phone number)",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthIdentifier"
              },
              "examples": {
                "Email": {
                  "value": {
                    "authId": "marcus@ecos.dk"
                  }
                },
                "Phone": {
                  "value": {
                    "authId": "81450074"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "otp sent"
          },
          "401": {
            "description": "no customers with that authId"
          },
          "422": {
            "description": "authId is required"
          },
          "500": {
            "description": "internal error"
          }
        },
        "description": "Request OTP code for customer to login",
        "operationId": "post-customer-auth-request-otp"
      }
    },
    "/customer-auth/login": {
      "post": {
        "tags": [
          "Customer Auth"
        ],
        "summary": "Login to the customer profile",
        "requestBody": {
          "required": true,
          "description": "Auth identifier (email or phone number)",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "authId": "marcus@ecos.dk",
                "otp": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "successfully logged in",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    },
                    "customers": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "_id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "cvr": {
                            "type": "string"
                          },
                          "commodityLicense": {
                            "type": "boolean"
                          },
                          "investmentLicense": {
                            "type": "boolean"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "unauthorized (wrong login)"
          },
          "422": {
            "description": "authId is required"
          },
          "500": {
            "description": "internal error"
          }
        },
        "description": "Login to the customer profile",
        "operationId": "post-customer-auth-login"
      }
    },
    "/customer-auth/current": {
      "get": {
        "security": [
          {
            "AuthToken": []
          }
        ],
        "tags": [
          "Customer Auth"
        ],
        "summary": "Fetches the currently logged in user from the token",
        "responses": {
          "200": {
            "description": "user data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    },
                    "customers": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "_id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "cvr": {
                            "type": "string"
                          },
                          "commodityLicense": {
                            "type": "boolean"
                          },
                          "investmentLicense": {
                            "type": "boolean"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "token invalid"
          },
          "500": {
            "description": "internal error"
          }
        },
        "description": "Fetches the currently logged in user from the token",
        "operationId": "get-customer-auth-current"
      }
    },
    "/commodity-profile/{commodityProfileId}/fields/{year}/refresh": {
      "post": {
        "security": [
          {
            "AuthToken": []
          }
        ],
        "tags": [
          "Commodity Crop/Field"
        ],
        "summary": "Update empty field data by the given year",
        "parameters": [
          {
            "in": "path",
            "name": "commodityProfileId",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The ID of the commodity profile to fetch field data from"
          },
          {
            "in": "path",
            "name": "year",
            "schema": {
              "type": "number"
            },
            "required": true,
            "description": "The year where the fielddata should be updated"
          }
        ],
        "responses": {
          "202": {
            "description": "refreshing field data"
          },
          "400": {
            "description": "There is data for the given year. Can't overwrite existing field data"
          },
          "500": {
            "description": "internal error"
          }
        },
        "description": "Update empty field data by the given year",
        "operationId": "post-commodity-profile-by-commodityprofileid-fields-by-year-refresh"
      }
    },
