{
  "openapi": "3.0.0",
  "servers": [
    {
      "url": "https://crm.agrocura.dk/api",
      "description": "Production server"
    }
  ],
  "info": {
    "description": "API Documentation for PengeProfilen to integrate with Agrocura CRM. <br>For demo purposes please use customerId '5e9eaccff1ca663a888ea470'",
    "version": "1.0.0",
    "title": "AgrocuraCRM PengeProfilen API",
    "contact": {
      "name": "Marcus J\u00f8rgensen",
      "email": "marcus@ecos.dk"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/eCo-Solutions/AgrocuraCRMPengeprofilen/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "Customer"
    }
  ],
  "paths": {
    "/customers/pengeprofilen/{customerId}/addActivity": {
      "post": {
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "tags": [
          "Customer"
        ],
        "summary": "creates pengeprofil activity",
        "parameters": [
          {
            "in": "path",
            "name": "customerId",
            "description": "customer to create activity for",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAcitivty"
              },
              "example": {
                "title": "Notifikation om skift til variabelt F5 l\u00e5n",
                "description": "Det kan betale sig at skifte til et variabelt F5 l\u00e5n. Beregninger er s\u00e5ledes..."
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "activity added"
          },
          "400": {
            "description": "bad input parameters"
          },
          "401": {
            "description": "unauthorized"
          },
          "500": {
            "description": "internal error"
          }
        },
        "description": "creates pengeprofil activity",
        "operationId": "post-customers-pengeprofilen-by-customerid-addactivity"
      }
    },
    "/customers/pengeprofilen/{customerId}": {
      "delete": {
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "tags": [
          "Customer"
        ],
        "summary": "deletes customer pengeprofil reference",
        "parameters": [
          {
            "in": "path",
            "name": "customerId",
            "description": "customer to delete reference from",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "reference deleted"
          },
          "401": {
            "description": "unauthorized"
          },
          "500": {
            "description": "internal error"
          }
        },
        "description": "deletes customer pengeprofil reference",
        "operationId": "delete-customers-pengeprofilen-by-customerid"
      }
    }
  },
  "components": {
    "schemas": {
      "CreateAcitivty": {
        "title": "NewActivity",
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Title of activity"
          },
          "description": {
            "type": "string",
            "description": "Description of activity written in plain-text. Line-breaks with '\\n'"
          }
        },
        "required": [
          "title",
          "description"
        ]
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  }
}
