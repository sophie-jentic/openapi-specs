{
  "openapi": "3.1.0",
  "info": {
    "title": "Admin API",
    "version": "1.0.0",
    "description": "Unleash Admin API for managing feature flags, addons, API tokens, and feature lifecycle.",
    "x-jentic-source-url": "https://docs.getunleash.io/openapi.json?api=415509f2-5d27-416b-a2ae-cc6bedf9ce08",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://unleash.example.com"
    }
  ],
  "security": [
    {
      "Authorization": []
    }
  ],
  "paths": {
    "/api/admin/addons": {
      "get": {
        "operationId": "get-addons",
        "summary": "Get all addons and providers",
        "description": "Retrieve all addons and providers that are defined on this Unleash instance.",
        "tags": [
          "Addons"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "API key needed to access this API",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of addons and providers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddonsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authorization information is missing or invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "create-addon",
        "summary": "Create a new addon",
        "description": "Create an addon instance. The addon must use one of the providers available on this Unleash instance.",
        "tags": [
          "Addons"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "API key needed to access this API",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Addon creation payload",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddonCreateUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Addon created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Addon"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/addons/{id}": {
      "get": {
        "operationId": "get-addon",
        "summary": "Get a specific addon",
        "description": "Retrieve information about the addon whose ID matches the ID in the request URL.",
        "tags": [
          "Addons"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Addon details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Addon"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "update-addon",
        "summary": "Update an addon",
        "description": "Update the addon with a specific ID.",
        "tags": [
          "Addons"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddonCreateUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated addon",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Addon"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "delete-addon",
        "summary": "Delete an addon",
        "description": "Delete the addon specified by the ID in the request path.",
        "tags": [
          "Addons"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Addon deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/api-tokens": {
      "get": {
        "operationId": "get-all-api-tokens",
        "summary": "Get API tokens",
        "description": "Retrieves all API tokens that exist in the Unleash instance.",
        "tags": [
          "API Tokens"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of API tokens",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiTokensList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "create-api-token",
        "summary": "Create API token",
        "description": "Create an API token of a specific type: one of client, admin, frontend, backend.",
        "tags": [
          "API Tokens"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateApiToken"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "API token created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiToken"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/archive/{featureName}": {
      "delete": {
        "operationId": "delete-feature",
        "summary": "Archives a feature",
        "description": "This endpoint archives the specified feature.",
        "tags": [
          "Archive"
        ],
        "parameters": [
          {
            "name": "featureName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Feature archived"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/archive/revive/{featureName}": {
      "post": {
        "operationId": "revive-feature",
        "summary": "Revives a feature",
        "description": "This endpoint revives the specified feature from archive.",
        "tags": [
          "Archive"
        ],
        "parameters": [
          {
            "name": "featureName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Feature revived"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/insights": {
      "get": {
        "operationId": "get-instance-insights",
        "summary": "Get instance information",
        "description": "Gets high level information about the usage of this Unleash instance, including user, project, and flag information.",
        "tags": [
          "Admin UI"
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "The beginning of the date range in yyyy-MM-dd format",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "to",
            "in": "query",
            "description": "The end of the date range in yyyy-MM-dd format",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Instance insights data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InstanceInsights"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Authorization": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      }
    },
    "schemas": {
      "Addon": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "provider": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "config": {
            "type": "object"
          }
        }
      },
      "AddonCreateUpdate": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "config": {
            "type": "object"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AddonsResponse": {
        "type": "object",
        "properties": {
          "addons": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Addon"
            }
          },
          "providers": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ApiToken": {
        "type": "object",
        "properties": {
          "secret": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "client",
              "admin",
              "frontend",
              "backend"
            ]
          },
          "environment": {
            "type": "string"
          },
          "project": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ApiTokensList": {
        "type": "object",
        "properties": {
          "tokens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiToken"
            }
          }
        }
      },
      "CreateApiToken": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "username": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "client",
              "admin",
              "frontend",
              "backend"
            ]
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "environment": {
            "type": "string"
          },
          "project": {
            "type": "string"
          }
        }
      },
      "InstanceInsights": {
        "type": "object",
        "properties": {
          "users": {
            "type": "object"
          },
          "featureToggles": {
            "type": "object"
          },
          "projects": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "API Tokens"
    },
    {
      "name": "Addons"
    },
    {
      "name": "Admin UI"
    },
    {
      "name": "Archive"
    }
  ]
}
