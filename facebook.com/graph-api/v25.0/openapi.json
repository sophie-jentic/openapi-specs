{
  "openapi": "3.0.3",
  "info": {
    "title": "Facebook Graph API",
    "description": "The Facebook Graph API is the primary way for apps to read and write to the Facebook social graph. It provides a simple, consistent view of the graph, uniformly representing objects (users, photos, posts, comments, etc.) and connections between them (friends, photo tags, post comments, etc.).",
    "version": "v25.0",
    "contact": {
      "name": "Meta for Developers",
      "url": "https://developers.facebook.com/docs/graph-api/"
    },
    "x-source-docs": "https://developers.facebook.com/docs/graph-api/reference/"
  },
  "servers": [
    {
      "url": "https://graph.facebook.com/v25.0",
      "description": "Facebook Graph API v25.0"
    }
  ],
  "security": [
    {
      "accessToken": []
    }
  ],
  "paths": {
    "/me": {
      "get": {
        "operationId": "getMe",
        "summary": "Get current user or page",
        "description": "Returns the user or page associated with the current access token.",
        "tags": [
          "User"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/fields"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/{user-id}": {
      "get": {
        "operationId": "getUser",
        "summary": "Get a user",
        "description": "Returns information about a specific user. The user must have granted your app permissions to access the requested fields.",
        "tags": [
          "User"
        ],
        "parameters": [
          {
            "name": "user-id",
            "in": "path",
            "required": true,
            "description": "The user ID or 'me' for the current user.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/fields"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "updateUser",
        "summary": "Update a user",
        "description": "Updates user information. Limited to test users and certain fields.",
        "tags": [
          "User"
        ],
        "parameters": [
          {
            "name": "user-id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "emoji_color_pref": {
                    "type": "integer",
                    "format": "int64",
                    "description": "Emoji color preference setting"
                  },
                  "firstname": {
                    "type": "string",
                    "description": "Person's first name"
                  },
                  "lastname": {
                    "type": "string",
                    "description": "Person's last name"
                  },
                  "name": {
                    "type": "string",
                    "description": "Account name (test accounts only)"
                  },
                  "password": {
                    "type": "string",
                    "description": "Account password (test accounts only)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete a test user",
        "description": "Removes a test user or dissociates from pages/ad accounts.",
