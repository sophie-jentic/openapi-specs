                }
              }
            }
          }
        }
      }
    },
    "/{user-id}/feed": {
      "get": {
        "operationId": "getUserFeed",
        "summary": "Get a user's feed",
        "description": "Returns posts from the user's feed.",
        "tags": [
          "User",
          "Post"
        ],
        "parameters": [
          {
            "name": "user-id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
