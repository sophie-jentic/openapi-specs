{
  "openapi": "3.0.0",
  "info": {
    "title": "Random Stuff API",
    "description": "Random Stuff API provides various random data generation endpoints including AI responses, jokes, memes, anime information, facts, animal images, and image manipulation services.",
    "version": "4.0.0",
    "contact": {
      "name": "PGamerX",
      "url": "https://rsa-api.xyz"
    }
  },
  "servers": [
    {
      "url": "https://api.pgamerx.com/v4",
      "description": "Production API Server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "JokeResponse": {
        "type": "object",
        "properties": {
          "joke": {
            "type": "string",
            "description": "The joke text"
          },
          "category": {
            "type": "string",
            "description": "Category of the joke"
          }
        }
      },
      "FactResponse": {
        "type": "object",
        "properties": {
          "fact": {
            "type": "string",
            "description": "Random fact"
          },
          "source": {
            "type": "string",
            "description": "Source of the fact"
          }
        }
      },
      "ImageResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the image"
          },
          "type": {
            "type": "string",
            "description": "Type of image"
          }
        }
      },
      "AIResponse": {
        "type": "object",
        "properties": {
          "response": {
            "type": "string",
            "description": "AI generated response"
          },
          "id": {
            "type": "string",
            "description": "Conversation ID"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  },
  "paths": {
    "/joke": {
      "get": {
        "operationId": "getJoke",
        "summary": "Get random joke",
        "description": "Returns a random joke",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "any",
                "programming",
                "general",
                "knock-knock"
              ]
            },
            "description": "Type of joke to retrieve"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JokeResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "joke"
        ]
      }
    },
    "/fact": {
      "get": {
        "operationId": "getFact",
        "summary": "Get random fact",
        "description": "Returns a random fact",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FactResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "fact"
        ]
      }
    },
    "/animal/{type}": {
      "get": {
        "operationId": "getAnimalImage",
        "summary": "Get animal image",
        "description": "Returns a random animal image URL",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "dog",
                "cat",
                "panda",
                "fox",
                "bird",
                "koala"
              ]
            },
            "description": "Type of animal"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Animal type not found"
          }
        },
        "tags": [
          "animal"
        ]
      }
    },
    "/meme": {
      "get": {
        "operationId": "getMeme",
        "summary": "Get random meme",
        "description": "Returns a random meme",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "meme"
        ]
      }
    },
    "/ai/response": {
      "post": {
        "operationId": "getAIResponse",
        "summary": "Get AI response",
        "description": "Get an AI-generated response to a message",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "message"
                ],
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "Message to send to AI"
                  },
                  "id": {
                    "type": "string",
                    "description": "Conversation ID for context"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AIResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "ai"
        ]
      }
    },
    "/image/filter": {
      "post": {
        "operationId": "applyImageFilter",
        "summary": "Apply filter to image",
        "description": "Apply various filters and effects to an image",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url",
                  "filter"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of the image to process"
                  },
                  "filter": {
                    "type": "string",
                    "enum": [
                      "blur",
                      "grayscale",
                      "invert",
                      "sepia",
                      "brightness"
                    ],
                    "description": "Filter to apply"
                  },
                  "intensity": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100,
                    "description": "Filter intensity (0-100)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "image"
        ]
      }
    }
  },
  "tags": [
    {
      "name": "ai"
    },
    {
      "name": "animal"
    },
    {
      "name": "fact"
    },
    {
      "name": "image"
    },
    {
      "name": "joke"
    },
    {
      "name": "meme"
    }
  ]
}
