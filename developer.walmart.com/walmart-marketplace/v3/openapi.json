{
  "openapi": "3.0.3",
  "info": {
    "title": "Walmart Marketplace",
    "version": "v3",
    "description": "Walmart Marketplace API for sellers. Manage items, orders, inventory, prices, fulfillment, returns, and more on the Walmart Marketplace.",
    "contact": {
      "url": "https://developer.walmart.com"
    },
    "x-jentic-source-url": "https://developer.walmart.com/api/us/mp/items"
  },
  "servers": [
    {
      "url": "https://marketplace.walmartapis.com"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v3/items": {
      "get": {
        "operationId": "getAllItems",
        "summary": "All items",
        "description": "Get a list of all items on the marketplace.",
        "tags": [
          "Item Management"
        ],
        "parameters": [
          {
            "name": "nextCursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Cursor for pagination"
          },
          {
            "name": "sku",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemName",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 200
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v3/items/{itemId}": {
      "get": {
        "operationId": "getAnItem",
        "summary": "An item",
        "description": "Retrieves an item and its details from the Walmart Marketplace Catalog.",
        "tags": [
          "Item Management"
        ],
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemDetails"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "retireAnItem",
        "summary": "Retire an item",
        "description": "Retires (deletes) an item from the Walmart Marketplace.",
        "tags": [
          "Item Management"
        ],
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item retired successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sku": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v3/orders": {
      "get": {
        "operationId": "getAllOrders",
        "summary": "All orders",
        "description": "Retrieves all orders for a Walmart Marketplace seller.",
        "tags": [
          "Order Management"
        ],
        "parameters": [
          {
            "name": "createdStartDate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "createdEndDate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 200
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of orders",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v3/orders/{purchaseOrderId}": {
      "get": {
        "operationId": "getAnOrder",
        "summary": "An order",
        "description": "Retrieves an order and its details from the Walmart Marketplace.",
        "tags": [
          "Order Management"
        ],
        "parameters": [
          {
            "name": "purchaseOrderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v3/orders/{purchaseOrderId}/shipping": {
      "post": {
        "operationId": "shippingUpdates",
        "summary": "Ship Order Lines",
        "description": "Updates the order status to 'Shipped' and lets Walmart know when tracking info is available.",
        "tags": [
          "Order Management"
        ],
        "parameters": [
          {
            "name": "purchaseOrderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShipOrderLinesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order shipped",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v3/inventory": {
      "get": {
        "operationId": "getInventory",
        "summary": "Inventory",
        "description": "Retrieves inventory for a given item.",
        "tags": [
          "Inventory Management"
        ],
        "parameters": [
          {
            "name": "sku",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Inventory details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InventoryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "put": {
        "operationId": "updateInventoryForAnItem",
        "summary": "Update inventory",
        "description": "Updates the inventory for a given item.",
        "tags": [
          "Inventory Management"
        ],
        "parameters": [
          {
            "name": "sku",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateInventoryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inventory updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InventoryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v3/prices": {
      "put": {
        "operationId": "updatePrice",
        "summary": "Update pricing for a single item",
        "description": "Updates the regular price for a given item.",
        "tags": [
          "Price Management"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePriceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Price updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ItemPriceResponse": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token obtained using Walmart API credentials"
      }
    },
    "schemas": {
      "ItemListResponse": {
        "type": "object",
        "properties": {
          "totalItems": {
            "type": "integer"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemDetails"
            }
          },
          "nextCursor": {
            "type": "string"
          }
        }
      },
      "ItemDetails": {
        "type": "object",
        "properties": {
          "mart": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "condition": {
            "type": "string"
          },
          "wpid": {
            "type": "string"
          },
          "upc": {
            "type": "string"
          },
          "gtin": {
            "type": "string"
          },
          "productName": {
            "type": "string"
          },
          "shelf": {
            "type": "string"
          },
          "productType": {
            "type": "string"
          },
          "price": {
            "$ref": "#/components/schemas/Price"
          },
          "publishedStatus": {
            "type": "string"
          },
          "lifecycleStatus": {
            "type": "string"
          }
        }
      },
      "Price": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          }
        }
      },
      "OrderListResponse": {
        "type": "object",
        "properties": {
          "list": {
            "type": "object",
            "properties": {
              "meta": {
                "type": "object",
                "properties": {
                  "totalCount": {
                    "type": "integer"
                  },
                  "limit": {
                    "type": "integer"
                  },
                  "nextCursor": {
                    "type": "string"
                  }
                }
              },
              "elements": {
                "type": "object",
                "properties": {
                  "order": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Order"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "purchaseOrderId": {
            "type": "string"
          },
          "customerOrderId": {
            "type": "string"
          },
          "customerEmailId": {
            "type": "string"
          },
          "orderDate": {
            "type": "string",
            "format": "date-time"
          },
          "shippingInfo": {
            "type": "object"
          },
          "orderLines": {
            "type": "object"
          }
        }
      },
      "ShipOrderLinesRequest": {
        "type": "object",
        "properties": {
          "orderShipment": {
            "type": "object"
          }
        }
      },
      "InventoryResponse": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string"
          },
          "quantity": {
            "type": "object",
            "properties": {
              "unit": {
                "type": "string"
              },
              "amount": {
                "type": "integer"
              }
            }
          }
        }
      },
      "UpdateInventoryRequest": {
        "type": "object",
        "properties": {
          "inventory": {
            "type": "object",
            "properties": {
              "sku": {
                "type": "string"
              },
              "quantity": {
                "type": "object",
                "properties": {
                  "unit": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      },
      "UpdatePriceRequest": {
        "type": "object",
        "properties": {
          "pricing": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "currentPriceType": {
                  "type": "string"
                },
                "currentPrice": {
                  "$ref": "#/components/schemas/Price"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string"
                },
                "field": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Inventory Management"
    },
    {
      "name": "Item Management"
    },
    {
      "name": "Order Management"
    },
    {
      "name": "Price Management"
    }
  ]
}
