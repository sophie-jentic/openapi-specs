{
  "openapi": "3.0.3",
  "info": {
    "title": "Financial Modeling Prep API",
    "description": "Comprehensive financial data API providing stock fundamentals, market data, historical prices, financial statements, and more",
    "version": "3.0.0",
    "contact": {
      "name": "Financial Modeling Prep Support",
      "url": "https://site.financialmodelingprep.com"
    }
  },
  "servers": [
    {
      "url": "https://financialmodelingprep.com/api/v3",
      "description": "API v3 server"
    },
    {
      "url": "https://financialmodelingprep.com/api/v4",
      "description": "API v4 server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
