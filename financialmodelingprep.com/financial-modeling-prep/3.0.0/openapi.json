              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Quote"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/historical-price-full/{symbol}": {
      "get": {
        "summary": "Historical Prices",
        "description": "Get full historical stock prices",
        "operationId": "getHistoricalPrices",
