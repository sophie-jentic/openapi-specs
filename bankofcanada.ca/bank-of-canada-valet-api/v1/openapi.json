{
  "openapi": "3.0.3",
  "info": {
    "title": "Bank of Canada Valet API",
    "version": "1.0.0",
    "description": "The Bank of Canada Valet API provides access to Bank of Canada data including exchange rates, interest rates, bond yields, and other financial series. No authentication required.",
    "x-jentic-source-url": "https://www.bankofcanada.ca/valet/observations/FXUSDCAD/json",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://www.bankofcanada.ca/valet"
    }
  ],
  "paths": {
    "/lists/series/json": {
      "get": {
        "operationId": "listSeries",
        "tags": [
          "Lists"
        ],
        "summary": "List all available data series",
        "description": "Returns a list of all series available in the Bank of Canada Valet API.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SeriesListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/lists/groups/json": {
      "get": {
        "operationId": "listGroups",
        "tags": [
          "Lists"
        ],
        "summary": "List all available data groups",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GroupListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all available data groups"
      }
    },
    "/observations/{seriesCodes}/json": {
      "get": {
        "operationId": "getObservations",
        "tags": [
          "Observations"
        ],
        "summary": "Get observations for one or more series",
        "description": "Returns observations for the specified series codes. Multiple series can be specified comma-separated.",
        "parameters": [
          {
            "name": "seriesCodes",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated series codes (e.g. FXUSDCAD,FXEURCAD)"
          },
          {
            "name": "start_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date in YYYY-MM-DD format"
          },
          {
            "name": "end_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date in YYYY-MM-DD format"
          },
          {
            "name": "recent",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Return only the most recent N observations"
          },
          {
            "name": "recent_weeks",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Return observations for the most recent N weeks"
          },
          {
            "name": "recent_months",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Return observations for the most recent N months"
          },
          {
            "name": "recent_years",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Return observations for the most recent N years"
          },
          {
            "name": "order_dir",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            },
            "description": "Sort direction for results"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObservationsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/observations/group/{groupCode}/json": {
      "get": {
        "operationId": "getGroupObservations",
        "tags": [
          "Observations"
        ],
        "summary": "Get observations for all series in a group",
        "parameters": [
          {
            "name": "groupCode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The group code (e.g. FX_RATES_DAILY)"
          },
          {
            "name": "start_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "recent",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObservationsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get observations for all series in a group"
      }
    },
    "/series/{seriesCode}/json": {
      "get": {
        "operationId": "getSeriesDetail",
        "tags": [
          "Series"
        ],
        "summary": "Get details about a specific series",
        "parameters": [
          {
            "name": "seriesCode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SeriesDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get details about a specific series"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "noAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "access_token",
        "description": "No authentication required - all endpoints are public"
      }
    },
    "schemas": {
      "Terms": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "SeriesInfo": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "dimension": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            }
          }
        }
      },
      "ObservationValue": {
        "type": "object",
        "properties": {
          "v": {
            "type": "string",
            "description": "Observed value"
          }
        }
      },
      "Observation": {
        "type": "object",
        "description": "An observation record keyed by date field (d) and series codes",
        "properties": {
          "d": {
            "type": "string",
            "format": "date"
          }
        },
        "additionalProperties": {
          "$ref": "#/components/schemas/ObservationValue"
        }
      },
      "ObservationsResponse": {
        "type": "object",
        "properties": {
          "terms": {
            "$ref": "#/components/schemas/Terms"
          },
          "seriesDetail": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/SeriesInfo"
            }
          },
          "observations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Observation"
            }
          }
        }
      },
      "SeriesListResponse": {
        "type": "object",
        "properties": {
          "terms": {
            "$ref": "#/components/schemas/Terms"
          },
          "series": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/SeriesInfo"
            }
          }
        }
      },
      "GroupListResponse": {
        "type": "object",
        "properties": {
          "terms": {
            "$ref": "#/components/schemas/Terms"
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "groupCode": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "SeriesDetailResponse": {
        "type": "object",
        "properties": {
          "terms": {
            "$ref": "#/components/schemas/Terms"
          },
          "seriesDetails": {
            "$ref": "#/components/schemas/SeriesInfo"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Lists"
    },
    {
      "name": "Observations"
    },
    {
      "name": "Series"
    }
  ]
}
