{
  "openapi": "3.0.3",
  "info": {
    "title": "Tavily API",
    "version": "1.0.0",
    "description": "Tavily is a search API built for AI agents and LLMs. It provides fast, accurate, and real-time search results optimized for AI-powered applications.",
    "x-jentic-source-url": "https://docs.tavily.com/docs/rest-api/api-reference",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.tavily.com",
      "description": "Tavily API"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/search": {
      "post": {
        "operationId": "search",
        "tags": [
          "Search"
        ],
        "summary": "Search the web",
        "description": "Execute a search query and receive real-time, accurate results. Optimized for AI agents and LLMs.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/extract": {
      "post": {
        "operationId": "extract",
        "tags": [
          "Extract"
        ],
        "summary": "Extract content from URLs",
        "description": "Extract raw content from one or more URLs.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExtractRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Extracted content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExtractResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key in the format: Bearer {api_key}"
      }
    },
    "schemas": {
      "SearchRequest": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "The search query"
          },
          "search_depth": {
            "type": "string",
            "enum": [
              "basic",
              "advanced"
            ],
            "default": "basic",
            "description": "The depth of the search. 'advanced' provides more comprehensive results but takes longer."
          },
          "topic": {
            "type": "string",
            "enum": [
              "general",
              "news"
            ],
            "default": "general",
            "description": "The category of the search"
          },
          "days": {
            "type": "integer",
            "description": "Number of days back to search (only for topic=news)"
          },
          "max_results": {
            "type": "integer",
            "default": 5,
            "minimum": 1,
            "maximum": 20,
            "description": "Maximum number of results to return"
          },
          "include_images": {
            "type": "boolean",
            "default": false,
            "description": "Include images in results"
          },
          "include_image_descriptions": {
            "type": "boolean",
            "default": false,
            "description": "Include descriptions for images"
          },
          "include_answer": {
            "type": "boolean",
            "default": false,
            "description": "Include a short AI-generated answer to the query"
          },
          "include_raw_content": {
            "type": "boolean",
            "default": false,
            "description": "Include the raw content of each search result"
          },
          "include_domains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Domains to specifically include in results"
          },
          "exclude_domains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Domains to exclude from results"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "answer": {
            "type": "string",
            "description": "AI-generated short answer (if include_answer=true)"
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchImage"
            }
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchResult"
            }
          },
          "response_time": {
            "type": "number",
            "description": "Time taken to generate the response in seconds"
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "raw_content": {
            "type": "string",
            "description": "Full raw content (if include_raw_content=true)"
          },
          "score": {
            "type": "number",
            "description": "Relevance score"
          },
          "published_date": {
            "type": "string",
            "description": "Publication date (for news)"
          }
        }
      },
      "SearchImage": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "ExtractRequest": {
        "type": "object",
        "required": [
          "urls"
        ],
        "properties": {
          "urls": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of URLs to extract content from"
          }
        }
      },
      "ExtractResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExtractResult"
            }
          },
          "failed_results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExtractFailedResult"
            }
          },
          "response_time": {
            "type": "number"
          }
        }
      },
      "ExtractResult": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "raw_content": {
            "type": "string"
          }
        }
      },
      "ExtractFailedResult": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "description": "Error details"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Extract"
    },
    {
      "name": "Search"
    }
  ]
}
