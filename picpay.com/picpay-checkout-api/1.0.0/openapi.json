{
  "openapi": "3.0.3",
  "info": {
    "title": "PicPay Business Checkout API",
    "version": "1.0.0",
    "description": "PicPay digital payments API for Brazilian commerce. Supports payment initiation via QR codes, status checking, refunds, and cancellations for the PicPay digital wallet.",
    "x-jentic-source-url": "https://developers-business.picpay.com/wallet/en/checkout/resources/api-reference",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://appws.picpay.com/ecommerce/public"
    }
  ],
  "paths": {
    "/payments": {
      "post": {
        "operationId": "createPayment",
        "summary": "Create a payment request",
        "description": "Initiate a PicPay payment. Returns a payment URL and QR code for the customer.",
        "tags": [
          "Payments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/{referenceId}/status": {
      "get": {
        "operationId": "getPaymentStatus",
        "summary": "Check payment status",
        "description": "Check the current status of a payment by reference ID",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "referenceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/{referenceId}/cancellations": {
      "post": {
        "operationId": "cancelPayment",
        "summary": "Cancel a payment",
        "description": "Request cancellation/refund of a payment",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "referenceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "authorizationId": {
                    "type": "string",
                    "description": "Authorization ID for partial refunds"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cancellation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CancellationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/{referenceId}/refunds": {
      "post": {
        "operationId": "refundPayment",
        "summary": "Refund a payment",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "referenceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "number",
                    "description": "Partial refund amount in BRL"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refund result"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Refund a payment"
      }
    },
    "/notifications": {
      "post": {
        "operationId": "handleNotification",
        "summary": "Receive payment notification (webhook)",
        "description": "Endpoint to receive PicPay payment status notifications. Implement this on your server.",
        "tags": [
          "Notifications"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NotificationPayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notification acknowledged"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PaymentRequest": {
        "type": "object",
        "required": [
          "referenceId",
          "callbackUrl",
          "value"
        ],
        "properties": {
          "referenceId": {
            "type": "string",
            "description": "Your unique order/payment reference"
          },
          "callbackUrl": {
            "type": "string",
            "description": "URL for payment status callbacks"
          },
          "returnUrl": {
            "type": "string",
            "description": "URL to redirect after payment"
          },
          "value": {
            "type": "number",
            "description": "Payment amount in BRL"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "Payment expiration"
          },
          "buyer": {
            "type": "object",
            "properties": {
              "firstName": {
                "type": "string"
              },
              "lastName": {
                "type": "string"
              },
              "document": {
                "type": "string",
                "description": "CPF"
              },
              "email": {
                "type": "string",
                "format": "email"
              },
              "phone": {
                "type": "string"
              }
            }
          }
        }
      },
      "PaymentResponse": {
        "type": "object",
        "properties": {
          "referenceId": {
            "type": "string"
          },
          "paymentUrl": {
            "type": "string",
            "description": "URL for payment page"
          },
          "qrcode": {
            "type": "object",
            "properties": {
              "content": {
                "type": "string",
                "description": "QR code content"
              },
              "base64": {
                "type": "string",
                "description": "QR code image as base64"
              }
            }
          }
        }
      },
      "PaymentStatusResponse": {
        "type": "object",
        "properties": {
          "referenceId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "created",
              "expired",
              "analysis",
              "paid",
              "completed",
              "refunded",
              "chargeback"
            ]
          },
          "authorizationId": {
            "type": "string"
          }
        }
      },
      "CancellationResponse": {
        "type": "object",
        "properties": {
          "referenceId": {
            "type": "string"
          },
          "cancellationId": {
            "type": "string"
          }
        }
      },
      "NotificationPayload": {
        "type": "object",
        "properties": {
          "referenceId": {
            "type": "string"
          },
          "authorizationId": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-picpay-token",
        "description": "PicPay merchant API token"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Notifications"
    },
    {
      "name": "Payments"
    }
  ]
}
