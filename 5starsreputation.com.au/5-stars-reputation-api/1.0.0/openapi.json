{
  "openapi": "3.0.3",
  "info": {
    "title": "5 Stars Reputation API",
    "version": "1.0.0",
    "description": "5 Stars Reputation integration API for managing locations, importing reviews, and importing contacts.",
    "x-jentic-source-url": "https://5starsreputation.com.au/integrationapi/doc",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://5starsreputation.com.au"
    }
  ],
  "paths": {
    "/integrationapi/location": {
      "post": {
        "operationId": "getLocation",
        "summary": "Read location details",
        "description": "Get information about the location associated with the API key.",
        "tags": [
          "Locations"
        ],
        "responses": {
          "200": {
            "description": "Location details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LocationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/integrationapi/importreview": {
      "post": {
        "operationId": "importReview",
        "summary": "Import a review",
        "description": "Import a review from an external source such as Google Business.",
        "tags": [
          "Reviews"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportReviewRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Review imported",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/integrationapi/importcontact": {
      "post": {
        "operationId": "importContact",
        "summary": "Import a contact",
        "description": "Import a contact for SMS or email campaigns.",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportContactRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact imported",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LocationResponse": {
        "type": "object",
        "properties": {
          "location": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "company_id": {
                "type": "string"
              },
              "location_name": {
                "type": "string"
              },
              "main_address": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "state": {
                "type": "string"
              },
              "zipcode": {
                "type": "string"
              },
              "phone": {
                "type": "string"
              },
              "website": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "is_active": {
                "type": "string"
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "ImportReviewRequest": {
        "type": "object",
        "required": [
          "stars_count",
          "text",
          "identifier"
        ],
        "properties": {
          "stars_count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "text": {
            "type": "string"
          },
          "identifier": {
            "type": "string"
          },
          "create_time": {
            "type": "string",
            "format": "date-time"
          },
          "reviewer_name": {
            "type": "string"
          },
          "reply_text": {
            "type": "string"
          },
          "reply_time": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ImportContactRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "ImportResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "X-API-KEY",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Contacts"
    },
    {
      "name": "Locations"
    },
    {
      "name": "Reviews"
    }
  ]
}
