{
  "openapi": "3.0.3",
  "info": {
    "title": "Exist.io API",
    "version": "2.0.0",
    "description": "Exist.io is a personal analytics platform that aggregates data from various services. The API allows you to read user profiles, attributes, attribute values, insights, correlations, averages, and write data to attributes you own.",
    "x-jentic-source-url": "https://developer.exist.io/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://exist.io",
      "description": "Exist.io API server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "User profile management"
    },
    {
      "name": "Attributes",
      "description": "User attributes and templates"
    },
    {
      "name": "Attribute Ownership",
      "description": "Acquire and release attribute ownership (OAuth2 clients)"
    },
    {
      "name": "Writing Data",
      "description": "Write attribute values"
    },
    {
      "name": "Insights",
      "description": "User insights"
    },
    {
      "name": "Averages",
      "description": "Attribute averages"
    },
    {
      "name": "Correlations",
      "description": "Attribute correlations"
    }
  ],
  "paths": {
    "/api/2/accounts/profile": {
      "get": {
        "operationId": "getUserProfile",
        "summary": "Get profile for user",
        "description": "Returns basic details and personal preferences for the authenticated user.",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfile"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/2/attributes/templates": {
      "get": {
        "operationId": "getAttributeTemplates",
        "summary": "Get attribute templates",
        "description": "Retrieve a list of the attribute templates Exist supports.",
        "tags": [
          "Attributes"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page index"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Results per page"
          },
          {
            "name": "include_low_priority",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include attributes with priority >= 10"
          },
          {
            "name": "groups",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of groups to filter by"
          }
        ],
        "responses": {
          "200": {
            "description": "Paged list of attribute templates",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedAttributeTemplates"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/attributes": {
      "get": {
        "operationId": "getUserAttributes",
        "summary": "Get a user's attributes",
        "description": "Retrieve a list of the user's attributes without values. Results limited to your read scopes.",
        "tags": [
          "Attributes"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "groups",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated groups filter"
          },
          {
            "name": "attributes",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated attributes filter"
          },
          {
            "name": "exclude_custom",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Only show templated attributes"
          },
          {
            "name": "manual",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Filter by manual attribute"
          },
          {
            "name": "include_inactive",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include inactive attributes"
          },
          {
            "name": "include_low_priority",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "owned",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Only attributes owned by this client"
          }
        ],
        "responses": {
          "200": {
            "description": "Paged list of user attributes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedUserAttributes"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/attributes/with-values": {
      "get": {
        "operationId": "getAttributesWithValues",
        "summary": "Get attributes with values",
        "description": "Returns a paged list of the user's attributes and their recent values.",
        "tags": [
          "Attributes"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "days",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 31,
              "default": 1
            },
            "description": "Number of day values to include"
          },
          {
            "name": "date_max",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Maximum date in values (yyyy-mm-dd)"
          },
          {
            "name": "groups",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attributes",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "templates",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated attribute templates filter"
          },
          {
            "name": "manual",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paged list of attributes with values",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedAttributesWithValues"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/attributes/values": {
      "get": {
        "operationId": "getAttributeValues",
        "summary": "Get a specific attribute's values",
        "description": "Returns a paged list of all values from a specific attribute.",
        "tags": [
          "Attributes"
        ],
        "parameters": [
          {
            "name": "attribute",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Attribute name"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "date_max",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paged list of attribute values",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedAttributeValues"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/attributes/owned": {
      "get": {
        "operationId": "getOwnedAttributes",
        "summary": "List owned attributes",
        "description": "Retrieve a list of the user's attributes owned by your service.",
        "tags": [
          "Attribute Ownership"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "groups",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attributes",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "exclude_custom",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "manual",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "include_inactive",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "include_low_priority",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paged list of owned attributes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedUserAttributes"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/attributes/acquire": {
      "post": {
        "operationId": "acquireAttributes",
        "summary": "Acquire attributes",
        "description": "Acquire ownership of user attributes. Allows writing values for these attributes. Maximum 35 objects.",
        "tags": [
          "Attribute Ownership"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "maxItems": 35,
                "items": {
                  "$ref": "#/components/schemas/AcquireAttributeRequest"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "success_objects",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Return full attribute object for each successful acquisition"
          }
        ],
        "responses": {
          "200": {
            "description": "All attributes processed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttributeOwnershipResponse"
                }
              }
            }
          },
          "202": {
            "description": "Some attributes failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttributeOwnershipResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/attributes/release": {
      "post": {
        "operationId": "releaseAttributes",
        "summary": "Release attributes",
        "description": "Release ownership of user attributes. Maximum 35 objects.",
        "tags": [
          "Attribute Ownership"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "maxItems": 35,
                "items": {
                  "type": "object",
                  "required": [
                    "name"
                  ],
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Attribute name"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "All attributes released successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttributeOwnershipResponse"
                }
              }
            }
          },
          "202": {
            "description": "Some attributes failed"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/attributes/update": {
      "post": {
        "operationId": "updateAttributeValues",
        "summary": "Update attribute values",
        "description": "Write values for attributes you own. Send a JSON array of objects with attribute name, date, and value.",
        "tags": [
          "Writing Data"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AttributeValueUpdate"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "All values updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttributeUpdateResponse"
                }
              }
            }
          },
          "202": {
            "description": "Some values failed"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/attributes/increment": {
      "post": {
        "operationId": "incrementAttributeValues",
        "summary": "Increment attribute values",
        "description": "Increment integer attribute values. Useful for adding to counts.",
        "tags": [
          "Writing Data"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AttributeValueUpdate"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "All values incremented successfully"
          },
          "202": {
            "description": "Some values failed"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/insights": {
      "get": {
        "operationId": "getInsights",
        "summary": "Get all insights",
        "description": "Returns a paged list of the user's insights. Results limited to your read scopes.",
        "tags": [
          "Insights"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "date_min",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Oldest date inclusive (YYYY-mm-dd)"
          },
          {
            "name": "date_max",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Most recent date inclusive"
          },
          {
            "name": "priority",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                1,
                2,
                3,
                4
              ]
            },
            "description": "1=today, 4=last month"
          }
        ],
        "responses": {
          "200": {
            "description": "Paged list of insights",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedInsights"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/averages": {
      "get": {
        "operationId": "getAverages",
        "summary": "Get averages",
        "description": "Returns the most recent average values for each attribute, one set per week.",
        "tags": [
          "Averages"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "date_min",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date_max",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "groups",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attributes",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include_historical",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include historical averages"
          }
        ],
        "responses": {
          "200": {
            "description": "Paged list of averages",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedAverages"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/correlations": {
      "get": {
        "operationId": "getCorrelations",
        "summary": "Get all correlations",
        "description": "Returns a paged list of all correlations generated in the last week.",
        "tags": [
          "Correlations"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "strong",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Only strong correlations"
          },
          {
            "name": "confident",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Only five-star confidence"
          },
          {
            "name": "attribute",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by attribute name"
          }
        ],
        "responses": {
          "200": {
            "description": "Paged list of correlations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedCorrelations"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/2/correlations/combo": {
      "get": {
        "operationId": "getCorrelationCombo",
        "summary": "Find a specific correlation combination",
        "description": "Takes parameters for two related attributes and returns one or zero correlations.",
        "tags": [
          "Correlations"
        ],
        "parameters": [
          {
            "name": "attribute",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "First attribute name"
          },
          {
            "name": "attribute2",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Second attribute name"
          }
        ],
        "responses": {
          "200": {
            "description": "Correlation found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Correlation"
                }
              }
            }
          },
          "404": {
            "description": "No correlation found"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth2 Bearer token. Obtain via OAuth2 flow at https://exist.io/oauth2/access_token"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string"
          },
          "error": {
            "type": "string"
          },
          "error_code": {
            "type": "string"
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "avatar": {
            "type": "string",
            "format": "uri"
          },
          "timezone": {
            "type": "string"
          },
          "local_time": {
            "type": "string",
            "format": "date-time"
          },
          "imperial_distance": {
            "type": "boolean"
          },
          "imperial_weight": {
            "type": "boolean"
          },
          "imperial_energy": {
            "type": "boolean"
          },
          "imperial_liquid": {
            "type": "boolean"
          },
          "imperial_temperature": {
            "type": "boolean"
          },
          "trial": {
            "type": "boolean"
          },
          "delinquent": {
            "type": "boolean"
          }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          }
        }
      },
      "Service": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      },
      "AttributeTemplate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "group": {
            "$ref": "#/components/schemas/Group"
          },
          "priority": {
            "type": "integer"
          },
          "value_type": {
            "type": "integer"
          },
          "value_type_description": {
            "type": "string"
          }
        }
      },
      "UserAttribute": {
        "type": "object",
        "properties": {
          "template": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "group": {
            "$ref": "#/components/schemas/Group"
          },
          "service": {
            "$ref": "#/components/schemas/Service"
          },
          "active": {
            "type": "boolean"
          },
          "priority": {
            "type": "integer"
          },
          "manual": {
            "type": "boolean"
          },
          "value_type": {
            "type": "integer"
          },
          "value_type_description": {
            "type": "string"
          },
          "available_services": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Service"
            }
          }
        }
      },
      "AttributeValue": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
