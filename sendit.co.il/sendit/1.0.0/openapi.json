{
  "openapi": "3.0.3",
  "info": {
    "title": "Sendit SMS API",
    "version": "1.0.0",
    "description": "Sendit SMS API for sending SMS messages and managing campaigns. Send individual messages or bulk campaigns with scheduling capabilities.",
    "x-jentic-source-url": "https://senditil.docs.apiary.io",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://sendit.co.il/api/v1"
    }
  ],
  "security": [
    {
      "ApiKey": []
    }
  ],
  "components": {
    "schemas": {
      "SendSMSRequest": {
        "type": "object",
        "required": [
          "recipients",
          "sender",
          "message"
        ],
        "properties": {
          "campaign_name": {
            "type": "string",
            "description": "Optional campaign name"
          },
          "recipients": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of recipient phone numbers in format 05XXXXXXXX or 9725XXXXXXXX"
          },
          "sender": {
            "type": "string",
            "description": "Sender name or ID"
          },
          "message": {
            "type": "string",
            "description": "SMS message text"
          },
          "unsubscribe_method": {
            "type": "string",
            "enum": [
              "link",
              "reply",
              "none",
              "custom"
            ],
            "description": "Unsubscribe method for recipients"
          },
          "send_at": {
            "type": "string",
            "format": "date-time",
            "description": "Scheduled send time in ISO8601 or Y-m-d H:i:s format"
          },
          "custom_id": {
            "type": "string",
            "description": "Custom identifier for tracking"
          }
        }
      },
      "SendSMSResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "recipients_count": {
            "type": "integer"
          }
        }
      },
      "MessageStatusResponse": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "sent_at": {
            "type": "string",
            "format": "date-time"
          },
          "delivered_at": {
            "type": "string",
            "format": "date-time"
          },
          "recipient": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "paths": {
    "/sms/send": {
      "post": {
        "summary": "Send SMS or campaign",
        "description": "Send SMS messages to one or more recipients. Supports scheduled sending and campaign management.",
        "operationId": "sendSMS",
        "tags": [
          "SMS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendSMSRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendSMSResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/sms/status/{message_id}": {
      "get": {
        "summary": "Get message status",
        "description": "Retrieve delivery status of a sent SMS message",
        "operationId": "getMessageStatus",
        "tags": [
          "SMS"
        ],
        "parameters": [
          {
            "name": "message_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Message ID returned from send operation"
          }
        ],
        "responses": {
          "200": {
            "description": "Message status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          },
          "404": {
            "description": "Message not found"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "SMS",
      "description": "SMS sending and campaign management"
    }
  ]
}
