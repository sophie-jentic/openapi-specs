{
  "openapi": "3.0.3",
  "info": {
    "title": "Gremlin API",
    "version": "1.0",
    "description": "Gremlin is a chaos engineering platform that enables teams to proactively test system resilience by injecting failures. The API provides programmatic access to attacks, scenarios, status checks, targets/clients, teams, and schedules.",
    "x-jentic-source-url": "https://www.gremlin.com/docs/api-reference/overview",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.gremlin.com/v1"
    }
  ],
  "paths": {
    "/attacks": {
      "get": {
        "operationId": "listAttacks",
        "summary": "List attacks",
        "tags": [
          "Attacks"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "source",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "Api",
                "Webapp",
                "Scenario",
                "Schedule"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Attack list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Attack"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List attacks"
      },
      "post": {
        "operationId": "createAttack",
        "summary": "Create a new attack",
        "tags": [
          "Attacks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAttackRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Attack created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "description": "Attack GUID"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a new attack"
      }
    },
    "/attacks/{attackGuid}": {
      "get": {
        "operationId": "getAttack",
        "summary": "Get attack details",
        "tags": [
          "Attacks"
        ],
        "parameters": [
          {
            "name": "attackGuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Attack details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Attack"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get attack details"
      },
      "delete": {
        "operationId": "haltAttack",
        "summary": "Halt an active attack",
        "tags": [
          "Attacks"
        ],
        "parameters": [
          {
            "name": "attackGuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Attack halted"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Halt an active attack"
      }
    },
    "/attacks/active": {
      "get": {
        "operationId": "listActiveAttacks",
        "summary": "List active attacks",
        "tags": [
          "Attacks"
        ],
        "responses": {
          "200": {
            "description": "Active attacks"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List active attacks"
      },
      "delete": {
        "operationId": "haltAllAttacks",
        "summary": "Halt all active attacks",
        "tags": [
          "Attacks"
        ],
        "responses": {
          "200": {
            "description": "All attacks halted"
          }
        },
        "description": "Halt all active attacks"
      }
    },
    "/scenarios": {
