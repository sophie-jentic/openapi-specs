          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List scenarios"
      },
      "post": {
        "operationId": "createScenario",
        "summary": "Create a scenario",
        "tags": [
          "Scenarios"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateScenarioRequest"
