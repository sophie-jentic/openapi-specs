        "description": "Delete a scenario"
      }
    },
    "/scenarios/{scenarioId}/runs": {
      "post": {
        "operationId": "runScenario",
        "summary": "Run a scenario",
        "tags": [
          "Scenarios"
        ],
        "parameters": [
          {
            "name": "scenarioId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Scenario run started"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Run a scenario"
      },
      "get": {
        "operationId": "listScenarioRuns",
        "summary": "List runs for a scenario",
        "tags": [
          "Scenarios"
        ],
        "parameters": [
          {
            "name": "scenarioId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Scenario runs"
          }
        },
        "description": "List runs for a scenario"
      }
    },
    "/clients": {
      "get": {
        "operationId": "listClients",
        "summary": "List Gremlin agent clients (targets)",
        "tags": [
          "Clients"
        ],
        "responses": {
          "200": {
            "description": "Client list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Client"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List Gremlin agent clients (targets)"
      }
    },
    "/clients/{clientId}": {
      "get": {
        "operationId": "getClient",
        "summary": "Get client details",
        "tags": [
          "Clients"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Client details"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get client details"
      }
    },
    "/schedules": {
      "get": {
        "operationId": "listSchedules",
        "summary": "List schedules",
        "tags": [
          "Schedules"
        ],
        "responses": {
          "200": {
            "description": "Schedule list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List schedules"
      },
      "post": {
        "operationId": "createSchedule",
        "summary": "Create a schedule",
        "tags": [
          "Schedules"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "target_definition": {
                    "type": "object"
                  },
                  "attack_definition": {
                    "type": "object"
                  },
                  "schedule": {
                    "type": "object",
                    "properties": {
                      "cron": {
                        "type": "string"
                      },
                      "timezone": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Schedule created"
          }
        },
        "description": "Create a schedule"
      }
    },
    "/schedules/{scheduleId}": {
      "get": {
        "operationId": "getSchedule",
        "summary": "Get schedule details",
        "tags": [
          "Schedules"
        ],
        "parameters": [
          {
            "name": "scheduleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Schedule details"
          }
        },
        "description": "Get schedule details"
      },
      "delete": {
        "operationId": "deleteSchedule",
        "summary": "Delete a schedule",
        "tags": [
          "Schedules"
        ],
        "parameters": [
          {
            "name": "scheduleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Schedule deleted"
          }
        },
        "description": "Delete a schedule"
      }
    },
    "/orgs/teams": {
      "get": {
        "operationId": "listTeams",
        "summary": "List teams in organization",
        "tags": [
          "Teams"
        ],
        "responses": {
          "200": {
            "description": "Team list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List teams in organization"
      }
    },
    "/orgs/teams/{teamId}": {
      "get": {
        "operationId": "getTeam",
        "summary": "Get team details",
        "tags": [
          "Teams"
        ],
        "parameters": [
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Team details"
          }
        },
        "description": "Get team details"
      }
    },
    "/status": {
      "get": {
        "operationId": "getStatus",
        "summary": "Get Gremlin status checks",
        "tags": [
          "Status"
        ],
        "responses": {
          "200": {
            "description": "Status checks"
          }
        },
        "description": "Get Gremlin status checks"
      }
    },
    "/reports/attacks": {
      "get": {
        "operationId": "getAttackReport",
        "summary": "Get attack reports",
        "tags": [
          "Reports"
        ],
        "parameters": [
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Attack report data"
          }
        },
        "description": "Get attack reports"
      }
    }
  },
  "components": {
    "schemas": {
      "Attack": {
        "type": "object",
        "properties": {
          "guid": {
            "type": "string"
          },
          "stage": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "target": {
            "$ref": "#/components/schemas/Target"
          }
        }
      },
      "CreateAttackRequest": {
        "type": "object",
        "required": [
          "command",
          "target"
        ],
        "properties": {
          "command": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "cpu",
                  "memory",
                  "disk",
                  "io",
                  "network",
                  "process_killer",
                  "time_travel",
                  "shutdown",
                  "blackhole",
                  "latency",
                  "packet_loss",
                  "dns"
                ]
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "commandType": {
                "type": "string",
                "enum": [
                  "Resource",
                  "State",
                  "Network"
                ]
              }
            }
          },
          "target": {
            "$ref": "#/components/schemas/Target"
          }
        }
      },
      "Target": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "Exact",
              "Random",
              "Percent"
            ]
          },
          "exact": {
            "type": "integer"
          },
          "percent": {
            "type": "integer"
          },
          "hosts": {
            "type": "object",
            "properties": {
              "ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "containers": {
            "type": "object",
            "properties": {
              "ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "kubernetes": {
            "type": "object"
          }
        }
      },
      "Scenario": {
        "type": "object",
        "properties": {
          "guid": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "hypothesis": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "state": {
            "type": "string"
          }
        }
      },
      "CreateScenarioRequest": {
        "type": "object",
        "required": [
          "name",
          "steps"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "hypothesis": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "attacks": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CreateAttackRequest"
                  }
                },
                "delay": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "Client": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "hostname": {
            "type": "string"
          },
          "os": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "lastSeen": {
            "type": "string",
            "format": "date-time"
          },
          "containers": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Gremlin API key as Bearer token"
      },
      "companyAuth": {
        "type": "apiKey",
        "name": "X-Gremlin-Team-Id",
        "in": "header",
        "description": "Team ID header"
      }
    }
  },
  "security": [
    {
      "bearerAuth": [],
      "companyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Attacks"
    },
    {
      "name": "Clients"
    },
    {
      "name": "Reports"
    },
    {
      "name": "Scenarios"
    },
    {
      "name": "Schedules"
    },
    {
      "name": "Status"
    },
    {
      "name": "Teams"
    }
  ]
}
