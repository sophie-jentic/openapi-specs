            "description": "Not found"
          }
        },
        "description": "Get scenario details"
      },
      "put": {
        "operationId": "updateScenario",
        "summary": "Update a scenario",
        "tags": [
          "Scenarios"
        ],
        "parameters": [
          {
            "name": "scenarioId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateScenarioRequest"
