{
  "openapi": "3.0.3",
  "info": {
    "title": "Bluesky AT Protocol API",
    "description": "Bluesky application Lexicon APIs (app.bsky.*). Public endpoints which do not require authentication can be made directly against the public Bluesky AppView API at https://public.api.bsky.app. Authenticated requests are usually proxied via the users PDS using service proxy headers.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.bsky.app/docs/category/http-reference",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://public.api.bsky.app",
      "description": "Public Bluesky AppView API (unauthenticated)"
    },
    {
      "url": "https://bsky.social",
      "description": "Bluesky PDS (authenticated requests)"
    }
  ],
  "security": [],
  "tags": [
    {
      "name": "Actor",
      "description": "Actor/profile operations"
    },
    {
      "name": "Feed",
      "description": "Feed and post operations"
    },
    {
      "name": "Notification",
      "description": "Notification operations"
    },
    {
      "name": "Graph",
      "description": "Social graph operations"
    },
    {
      "name": "Session",
      "description": "Session management"
    }
  ],
  "paths": {
    "/xrpc/app.bsky.actor.getProfile": {
      "get": {
        "tags": [
          "Actor"
        ],
        "summary": "Get Profile",
        "description": "Get detailed profile view of an actor. Does not require auth, but contains relevant metadata with auth.",
        "operationId": "getProfile",
        "parameters": [
          {
            "name": "actor",
            "in": "query",
            "required": true,
            "description": "Handle or DID of account to fetch profile of",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns detailed profile view",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileViewDetailed"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/xrpc/app.bsky.actor.getProfiles": {
      "get": {
        "tags": [
          "Actor"
        ],
        "summary": "Get Profiles",
        "description": "Get detailed profile views of multiple actors.",
        "operationId": "getProfiles",
        "parameters": [
          {
            "name": "actors",
            "in": "query",
            "required": true,
            "description": "Handles or DIDs of accounts to fetch (max 25)",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "maxItems": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns list of detailed profile views",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "profiles"
                  ],
                  "properties": {
                    "profiles": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ProfileViewDetailed"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/xrpc/app.bsky.actor.searchActors": {
      "get": {
        "tags": [
          "Actor"
        ],
        "summary": "Search Actors",
        "description": "Find actors (users) matching search criteria. Does not require auth.",
        "operationId": "searchActors",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Search query string; syntax, entity types, and other features are announced in feed generators",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns matching actors",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "actors"
                  ],
                  "properties": {
                    "cursor": {
                      "type": "string"
                    },
                    "actors": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ProfileView"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/xrpc/app.bsky.feed.getTimeline": {
      "get": {
        "tags": [
          "Feed"
        ],
        "summary": "Get Timeline",
        "description": "Get a view of the requesting accounts home timeline. Requires auth.",
