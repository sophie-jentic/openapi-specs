    "/xrpc/com.atproto.repo.createRecord": {
      "post": {
        "tags": [
          "Feed"
        ],
        "summary": "Create Record",
        "description": "Create a single new repository record. Requires auth, implemented by PDS. Used to create posts, likes, reposts, follows, etc.",
        "operationId": "createRecord",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "repo",
                  "collection",
                  "record"
                ],
                "properties": {
                  "repo": {
                    "type": "string",
                    "description": "The handle or DID of the repo (aka, current account)."
                  },
                  "collection": {
                    "type": "string",
                    "description": "The NSID of the record collection."
                  },
                  "rkey": {
                    "type": "string",
                    "description": "The Record Key."
                  },
                  "validate": {
                    "type": "boolean",
                    "description": "Can be set to false to skip Lexicon schema validation of record data."
                  },
                  "record": {
                    "type": "object",
                    "description": "The record itself."
                  }
                }
              }
            }
