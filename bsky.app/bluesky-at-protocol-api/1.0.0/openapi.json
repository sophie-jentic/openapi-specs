{
  "openapi": "3.0.3",
  "info": {
    "title": "Bluesky AT Protocol API",
    "version": "1.0.0",
    "description": "Bluesky social network API based on the AT Protocol (atproto). Uses XRPC (a Lexicon-based RPC framework), not standard REST/OpenAPI. This spec provides a minimal representation of key XRPC endpoints. The canonical API definitions are AT Protocol Lexicon schemas at github.com/bluesky-social/atproto.",
    "x-jentic-source-url": "https://docs.bsky.app/docs/category/http-reference",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://bsky.social/xrpc"
    }
  ],
  "paths": {
    "/com.atproto.server.createSession": {
      "post": {
        "operationId": "createSession",
        "summary": "Sign in and create an authentication session",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "identifier": {
                    "type": "string",
                    "description": "Handle or DID"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": [
                  "identifier",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "did": {
                      "type": "string"
                    },
                    "handle": {
                      "type": "string"
                    },
                    "accessJwt": {
                      "type": "string"
                    },
                    "refreshJwt": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Sign in and create an authentication session"
      }
    },
    "/com.atproto.server.refreshSession": {
      "post": {
        "operationId": "refreshSession",
        "summary": "Refresh an authentication session",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Session refreshed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "did": {
                      "type": "string"
                    },
                    "handle": {
                      "type": "string"
                    },
                    "accessJwt": {
                      "type": "string"
                    },
                    "refreshJwt": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Refresh an authentication session"
      }
    },
    "/app.bsky.feed.getTimeline": {
      "get": {
        "operationId": "getTimeline",
        "summary": "Get the authenticated user's timeline",
        "tags": [
          "Feed"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 100
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Timeline feed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cursor": {
                      "type": "string"
                    },
                    "feed": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get the authenticated user's timeline"
      }
    },
    "/app.bsky.feed.getAuthorFeed": {
      "get": {
        "operationId": "getAuthorFeed",
        "summary": "Get posts by a specific author",
        "tags": [
          "Feed"
        ],
        "parameters": [
          {
            "name": "actor",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
