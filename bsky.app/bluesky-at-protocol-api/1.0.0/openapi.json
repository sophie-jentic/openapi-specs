    "/com.atproto.repo.uploadBlob": {
      "post": {
        "operationId": "uploadBlob",
        "summary": "Upload a blob (image/media)",
        "tags": [
          "Repository"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "*/*": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Blob uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "blob": {
                      "type": "object"
                    }
                  }
