        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "repo": {
                    "type": "string"
                  },
                  "collection": {
                    "type": "string"
                  },
                  "rkey": {
                    "type": "string"
                  }
                },
                "required": [
                  "repo",
                  "collection",
                  "rkey"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
