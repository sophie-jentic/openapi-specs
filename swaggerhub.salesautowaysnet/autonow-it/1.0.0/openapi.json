{
  "openapi": "3.0.1",
  "info": {
    "title": "AUTONOW-IT - Italy",
    "description": "Web Service which allows you to query the official database in real time by simply entering a license plate or a VIN. You allow your ecosystem to identify in one click the official data of a vehicle among the 80M license plates in Italy.The API allows you to identify and get all the car information you need, in addition to an identifier like K-type for auto parts compatibility with the TecDoc catalog.",
    "termsOfService": "https://auto-ways.net/",
    "contact": {
      "email": "contact@auto-ways.net"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/SALESAUTOWAYSNET/AUTONOW-IT/1.0.0/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/SALESAUTOWAYSNET/AUTONOW-IT/1.0.0"
    },
    {
      "url": "https://app.auto-ways.net/api/v1"
    }
  ],
  "tags": [
    {
      "name": "Auto Now",
      "description": "Request your demo for free",
      "externalDocs": {
        "description": "here",
        "url": "https://auto-ways.net/demo"
      }
    },
    {
      "name": "car-info"
    }
  ],
  "paths": {
    "/it": {
      "get": {
        "tags": [
          "car-info"
        ],
        "summary": "Find car by plate  , country  (IT)",
        "description": "Return vehicle data from license plate",
        "operationId": "getCarByPlate_it",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "description": "Your token, use your real token or request a free token for fee here https://auto-ways.net/demo ",
            "required": true,
            "schema": {
              "type": "string",
              "default": "4a486e221ea6d4a888671242b5fe0fed"
            }
          },
          {
            "name": "plaque",
            "in": "query",
            "description": "car plate ",
            "required": true,
            "schema": {
              "type": "string",
              "default": "FG995BB"
            }
          },
          {
            "name": "output_lang",
            "in": "query",
            "description": "Define the API output language (fr,en)",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "example": {
                  "error": false,
                  "data": {
                    "AWN_immat": "fg995bb",
                    "AWN_VIN": "ZFA31200003781372",
                    "AWN_marque": "FIAT",
                    "AWN_modele": "PANDA Van",
