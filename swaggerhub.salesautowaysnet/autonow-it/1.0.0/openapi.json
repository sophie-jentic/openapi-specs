                    "AWN_numero_de_serie": "03781372",
                    "AWN_nbr_cylindres": "4",
                    "AWN_nbr_cylindre_energie": "1248",
                    "AWN_collection": "NON",
                    "AWN_puissance_KW": "59",
                    "AWN_code_moteur": "225A2000",
                    "AWN_nbr_de_places": "2",
                    "AWN_nbr_soupapes": "4",
