{
  "openapi": "3.0.3",
  "info": {
    "title": "Loggly API",
    "version": "1.0.0",
    "description": "Loggly log management API for searching logs, retrieving events, managing tags, saved searches, and alerts.",
    "x-jentic-source-url": "https://documentation.solarwinds.com/en/success_center/loggly/content/admin/api-overview.htm",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{subdomain}.loggly.com",
      "variables": {
        "subdomain": {
          "default": "logs-01",
          "description": "Loggly subdomain"
        }
      }
    },
    {
      "url": "https://logs-01.loggly.com",
      "description": "Log submission endpoint"
    }
  ],
  "tags": [
    {
      "name": "Search",
      "description": "Log search and retrieval"
    },
    {
      "name": "Submission",
      "description": "Log submission"
    },
    {
      "name": "Tags",
      "description": "Tag management"
    },
    {
      "name": "Saved Searches",
      "description": "Saved search management"
    },
    {
      "name": "Alerts",
      "description": "Alert management"
    },
    {
      "name": "Account",
      "description": "Account information"
    }
  ],
  "paths": {
    "/inputs/{token}/tag/{tags}": {
      "post": {
        "operationId": "submitLogEvent",
        "summary": "Submit log event",
        "description": "Submit a log event with optional tags.",
        "tags": [
          "Submission"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Customer token"
          },
          {
            "name": "tags",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated tags"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            },
            "text/plain": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/apiv2/search": {
      "get": {
        "operationId": "searchLogs",
        "summary": "Search logs",
        "description": "Search logs using Loggly query syntax. Returns an RSID for fetching results.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Start time (e.g. -24h, ISO8601)"
          },
          {
            "name": "until",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "End time"
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search initiated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rsid": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/apiv2/events": {
      "get": {
        "operationId": "getEvents",
        "summary": "Get search events",
        "description": "Retrieve events for a completed search using RSID.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "rsid",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Result set ID from search"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv",
                "text"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total_events": {
                      "type": "integer"
                    },
                    "page": {
                      "type": "integer"
                    },
                    "events": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/apiv2/fields": {
      "get": {
        "operationId": "getFieldStats",
        "summary": "Get field statistics",
        "description": "Get field value statistics for a search.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "rsid",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "facet_size",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Fields",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/apiv2/customer": {
      "get": {
        "operationId": "getAccountInfo",
        "summary": "Get account information",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Account info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tokens": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "subdomain": {
                      "type": "string"
                    },
                    "subscription": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get account information"
      }
    },
    "/apiv2/customer/tokens": {
      "get": {
        "operationId": "listTokens",
        "summary": "List customer tokens",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Tokens",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tokens": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List customer tokens"
      }
    },
    "/apiv2/saved-searches": {
      "get": {
        "operationId": "listSavedSearches",
        "summary": "List saved searches",
        "tags": [
          "Saved Searches"
        ],
        "responses": {
          "200": {
            "description": "Searches",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "saved_searches": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/SavedSearch"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List saved searches"
      },
      "post": {
        "operationId": "createSavedSearch",
        "summary": "Create saved search",
        "tags": [
          "Saved Searches"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "query"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "query": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SavedSearch"
                }
              }
            }
          }
        },
        "description": "Create saved search"
      }
    },
    "/apiv2/saved-searches/{id}": {
      "get": {
        "operationId": "getSavedSearch",
        "summary": "Get saved search",
        "tags": [
          "Saved Searches"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SavedSearch"
                }
              }
            }
          }
        },
        "description": "Get saved search"
      },
      "put": {
        "operationId": "updateSavedSearch",
        "summary": "Update saved search",
        "tags": [
          "Saved Searches"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        },
        "description": "Update saved search"
      },
      "delete": {
        "operationId": "deleteSavedSearch",
        "summary": "Delete saved search",
        "tags": [
          "Saved Searches"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          }
        },
        "description": "Delete saved search"
      }
    },
    "/apiv2/alerts": {
      "get": {
        "operationId": "listAlerts",
        "summary": "List alerts",
        "tags": [
          "Alerts"
        ],
        "responses": {
          "200": {
            "description": "Alerts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "alerts": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Alert"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List alerts"
      },
      "post": {
        "operationId": "createAlert",
        "summary": "Create alert",
        "tags": [
          "Alerts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "query"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "query": {
                    "type": "string"
                  },
                  "threshold_value": {
                    "type": "integer"
                  },
                  "threshold_type": {
                    "type": "string",
                    "enum": [
                      "count",
                      "unique_count"
                    ]
                  },
                  "time_range": {
                    "type": "string"
                  },
                  "notification_type": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Alert"
                }
              }
            }
          }
        },
        "description": "Create alert"
      }
    },
    "/apiv2/alerts/{id}": {
      "get": {
        "operationId": "getAlert",
        "summary": "Get alert",
        "tags": [
          "Alerts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alert",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Alert"
                }
              }
            }
          }
        },
        "description": "Get alert"
      },
      "put": {
        "operationId": "updateAlert",
        "summary": "Update alert",
        "tags": [
          "Alerts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        },
        "description": "Update alert"
      },
      "delete": {
        "operationId": "deleteAlert",
        "summary": "Delete alert",
        "tags": [
          "Alerts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          }
        },
        "description": "Delete alert"
      }
    }
  },
  "components": {
    "schemas": {
      "SavedSearch": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "context": {
            "type": "object"
          }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "threshold_value": {
            "type": "integer"
          },
          "threshold_type": {
            "type": "string"
          },
          "time_range": {
            "type": "string"
          },
          "notification_type": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Loggly API token"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
