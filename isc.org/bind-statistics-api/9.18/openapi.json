{
  "openapi": "3.0.3",
  "info": {
    "title": "ISC BIND Statistics API",
    "version": "9.18",
    "description": "ISC BIND 9 statistics channel REST API. Provides access to server statistics, zone information, traffic data, and runtime status via HTTP/JSON. The statistics channel is enabled by configuring the statistics-channels block in named.conf.",
    "x-jentic-source-url": "https://www.isc.org/bind/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://{bind-host}:8053"
    }
  ],
  "paths": {
    "/json/v1": {
      "get": {
        "operationId": "getAllStatistics",
        "summary": "Get all server statistics",
        "description": "Returns complete server statistics including opcodes, query types, resolver statistics, socket I/O, zone maintenance, and more.",
        "tags": [
          "Statistics"
        ],
        "responses": {
          "200": {
            "description": "Complete statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerStatistics"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/json/v1/server": {
      "get": {
        "operationId": "getServerStatistics",
        "summary": "Get server-level statistics",
        "description": "Returns server-level counters including opcodes, query types (qtypes), name server statistics, and zone maintenance statistics.",
        "tags": [
          "Statistics"
        ],
        "responses": {
          "200": {
            "description": "Server statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerStats"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/json/v1/zones": {
      "get": {
        "operationId": "getZoneStatistics",
        "summary": "Get zone statistics",
        "description": "Returns statistics for all configured zones including serial numbers, query counts per zone, and zone transfer statistics.",
        "tags": [
          "Zones"
        ],
        "responses": {
          "200": {
            "description": "Zone statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZoneStats"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/json/v1/net": {
      "get": {
        "operationId": "getNetworkStatistics",
        "summary": "Get network I/O statistics",
        "description": "Returns network socket statistics including UDP/TCP socket counts, connections, and traffic data.",
        "tags": [
          "Network"
        ],
        "responses": {
          "200": {
            "description": "Network stats",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NetworkStats"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/json/v1/mem": {
      "get": {
        "operationId": "getMemoryStatistics",
        "summary": "Get memory usage statistics",
        "description": "Returns memory allocation and usage statistics for the BIND server process.",
        "tags": [
          "Memory"
        ],
        "responses": {
          "200": {
            "description": "Memory stats",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemoryStats"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/json/v1/tasks": {
      "get": {
        "operationId": "getTaskStatistics",
        "summary": "Get task manager statistics",
        "description": "Returns internal task manager statistics including worker thread count and task queue information.",
        "tags": [
          "Tasks"
        ],
        "responses": {
          "200": {
            "description": "Task stats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/json/v1/traffic": {
      "get": {
        "operationId": "getTrafficStatistics",
        "summary": "Get traffic statistics",
        "description": "Returns DNS traffic statistics including queries per second, response sizes, and transport-level statistics.",
        "tags": [
          "Traffic"
        ],
        "responses": {
          "200": {
            "description": "Traffic statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrafficStats"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/json/v1/status": {
      "get": {
        "operationId": "getServerStatus",
        "summary": "Get server status",
        "description": "Returns BIND server status including version, uptime, boot time, and configuration time.",
        "tags": [
          "Status"
        ],
        "responses": {
          "200": {
            "description": "Server status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerStatus"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/xml/v3": {
      "get": {
        "operationId": "getAllStatisticsXml",
        "summary": "Get all statistics (XML format)",
        "description": "Returns complete statistics in XML format for backward compatibility.",
        "tags": [
          "Statistics"
        ],
        "responses": {
          "200": {
            "description": "Complete statistics in XML",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ServerStatistics": {
        "type": "object",
        "properties": {
          "json-stats-version": {
            "type": "string"
          },
          "boot-time": {
            "type": "string",
            "format": "date-time"
          },
          "config-time": {
            "type": "string",
            "format": "date-time"
          },
          "current-time": {
            "type": "string",
            "format": "date-time"
          },
          "version": {
            "type": "string"
          },
          "opcodes": {
            "type": "object"
          },
          "qtypes": {
            "type": "object"
          },
          "nsstats": {
            "type": "object"
          },
          "zonestats": {
            "type": "object"
          },
          "resstats": {
            "type": "object"
          },
          "views": {
            "type": "object"
          },
          "socketstats": {
            "type": "object"
          },
          "taskmgr": {
            "type": "object"
          },
          "memory": {
            "type": "object"
          },
          "traffic": {
            "type": "object"
          }
        }
      },
      "ServerStats": {
        "type": "object",
        "properties": {
          "opcodes": {
            "type": "object",
            "description": "Opcode counters (QUERY, IQUERY, STATUS, NOTIFY, UPDATE)"
          },
          "qtypes": {
            "type": "object",
            "description": "Query type counters (A, AAAA, MX, NS, SOA, etc.)"
          },
          "nsstats": {
            "type": "object",
            "description": "Name server statistics counters"
          },
          "zonestats": {
            "type": "object",
            "description": "Zone maintenance counters"
          },
          "resstats": {
            "type": "object",
            "description": "Resolver statistics"
          }
        }
      },
      "ZoneStats": {
        "type": "object",
        "properties": {
          "views": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "zones": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/components/schemas/ZoneInfo"
                  }
                }
              }
            }
          }
        }
      },
      "ZoneInfo": {
        "type": "object",
        "properties": {
          "class": {
            "type": "string"
          },
          "serial": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "enum": [
              "master",
              "slave",
              "stub",
              "static-stub",
              "redirect"
            ]
          },
          "rcodes": {
            "type": "object"
          },
          "qrysuccess": {
            "type": "integer"
          },
          "qryfailure": {
            "type": "integer"
          }
        }
      },
      "NetworkStats": {
        "type": "object",
        "properties": {
          "socketstats": {
            "type": "object",
            "properties": {
              "udp4": {
                "type": "object"
              },
              "udp6": {
                "type": "object"
              },
              "tcp4": {
                "type": "object"
              },
              "tcp6": {
                "type": "object"
              }
            }
          }
        }
      },
      "MemoryStats": {
        "type": "object",
        "properties": {
          "TotalUse": {
            "type": "integer"
          },
          "InUse": {
            "type": "integer"
          },
          "BlockSize": {
            "type": "integer"
          },
          "ContextSize": {
            "type": "integer"
          },
          "Lost": {
            "type": "integer"
          },
          "contexts": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "TrafficStats": {
        "type": "object",
        "properties": {
          "dns-udp-requests-sizes-received-ipv4": {
            "type": "object"
          },
          "dns-udp-responses-sizes-sent-ipv4": {
            "type": "object"
          },
          "dns-tcp-requests-sizes-received-ipv4": {
            "type": "object"
          },
          "dns-tcp-responses-sizes-sent-ipv4": {
            "type": "object"
          }
        }
      },
      "ServerStatus": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string"
          },
          "boot-time": {
            "type": "string",
            "format": "date-time"
          },
          "config-time": {
            "type": "string",
            "format": "date-time"
          },
          "current-time": {
            "type": "string",
            "format": "date-time"
          },
          "uptime": {
            "type": "integer",
            "description": "Uptime in seconds"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "aclBased": {
        "type": "http",
        "scheme": "basic",
        "description": "Access is typically controlled via ACLs in named.conf (allow-from). Basic auth can be configured optionally."
      }
    }
  },
  "security": [
    {
      "aclBased": []
    }
  ],
  "tags": [
    {
      "name": "Memory"
    },
    {
      "name": "Network"
    },
    {
      "name": "Statistics"
    },
    {
      "name": "Status"
    },
    {
      "name": "Tasks"
    },
    {
      "name": "Traffic"
    },
    {
      "name": "Zones"
    }
  ]
}
