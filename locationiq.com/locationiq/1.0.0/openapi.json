            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "lon",
            "in": "query",
            "required": true,
            "description": "Longitude of the center point.",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "required": false,
