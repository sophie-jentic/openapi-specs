{
  "openapi": "3.0.3",
  "info": {
    "title": "FOIA.gov API",
    "version": "1.0.0",
    "description": "Freedom of Information Act API providing access to agency components, FOIA request forms, and annual reports.",
    "x-jentic-source-url": "https://www.foia.gov/developer/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.foia.gov"
    }
  ],
  "paths": {
    "/api/agency_components": {
      "get": {
        "operationId": "listAgencyComponents",
        "summary": "List agency FOIA components",
        "description": "Retrieves information about federal agency FOIA components in JSON API format",
        "tags": [
          "Agency Components"
        ],
        "parameters": [
          {
            "name": "fields[agency_component]",
            "in": "query",
            "description": "Agency component fields to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields[agency]",
            "in": "query",
            "description": "Parent agency fields to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include",
            "in": "query",
            "description": "Include related resources",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgencyComponentListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/agency_components/{id}": {
      "get": {
        "operationId": "getAgencyComponent",
        "summary": "Get agency component details",
        "tags": [
          "Agency Components"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID of agency component",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgencyComponentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get agency component details"
      }
    },
    "/api/agency_components/{id}/request_form": {
      "get": {
        "operationId": "getRequestForm",
        "summary": "Get FOIA request form for agency component",
        "tags": [
          "Agency Components"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestFormResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get FOIA request form for agency component"
      }
    },
    "/api/annual-report-xml/{agency_abbreviation}/{year}": {
      "get": {
        "operationId": "getAnnualReport",
        "summary": "Get annual FOIA report in XML",
        "tags": [
          "Reports"
        ],
        "parameters": [
          {
            "name": "agency_abbreviation",
            "in": "path",
            "required": true,
            "description": "Agency code (e.g., DOJ)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "year",
            "in": "path",
            "required": true,
            "description": "Report year",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Annual report in XML format",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get annual FOIA report in XML"
      }
    }
  },
  "components": {
    "schemas": {
      "AgencyComponent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "attributes": {
            "type": "object"
          }
        }
      },
      "AgencyComponentListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgencyComponent"
            }
          }
        }
      },
      "AgencyComponentResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/AgencyComponent"
          }
        }
      },
      "RequestFormResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "ApiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Agency Components"
    },
    {
      "name": "Reports"
    }
  ]
}
