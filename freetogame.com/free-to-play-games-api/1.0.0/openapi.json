{
  "openapi": "3.0.3",
  "info": {
    "title": "FreeToGame API",
    "version": "1.0.0",
    "description": "Access a comprehensive database of free-to-play games and free MMO games. Provides information about game titles, genres, descriptions, developers, publishers, release dates, official websites, and more. No authentication required. Free for personal and commercial use with attribution to FreeToGame.com.",
    "x-jentic-source-url": "https://www.freetogame.com/api-doc",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://www.freetogame.com/api",
      "description": "FreeToGame API"
    }
  ],
  "paths": {
    "/games": {
      "get": {
        "operationId": "getGames",
        "tags": [
          "Games"
        ],
        "summary": "Retrieve a list of all free-to-play games",
        "description": "Returns a list of all available free-to-play games. Optionally filter by category, platform, or sort results.",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "description": "Filter by game category or tag (e.g. mmorpg, shooter, pvp, mmofps)",
            "schema": {
              "type": "string",
              "example": "shooter"
            },
            "required": false
          },
          {
            "name": "platform",
            "in": "query",
            "description": "Filter by platform: pc, browser, or all",
            "schema": {
              "type": "string",
              "enum": [
                "pc",
                "browser",
                "all"
              ],
              "default": "all"
            },
            "required": false
          },
          {
            "name": "sort-by",
            "in": "query",
            "description": "Sort games by: release-date, popularity, alphabetical, or relevance",
            "schema": {
              "type": "string",
              "enum": [
                "release-date",
                "popularity",
                "alphabetical",
                "relevance"
              ]
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "A list of free-to-play games",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GameSummary"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Object not found: Game or endpoint not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/game": {
      "get": {
        "operationId": "getGameById",
        "tags": [
          "Games"
        ],
        "summary": "Return details from a specific game by ID",
        "description": "Retrieve detailed information about a specific free-to-play game by its ID.",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The game ID",
            "schema": {
              "type": "integer",
              "example": 452
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Game details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Game not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/filter": {
      "get": {
        "operationId": "filterGames",
        "tags": [
          "Games"
        ],
        "summary": "Filter games by multiple tags",
        "description": "Filter games by multiple tags for personalized results.",
        "parameters": [
          {
            "name": "tag",
            "in": "query",
            "required": true,
            "description": "Dot-separated list of tags (e.g. 3d.mmorpg.fantasy.pvp)",
            "schema": {
              "type": "string",
              "example": "3d.mmorpg.fantasy.pvp"
            }
          },
          {
            "name": "platform",
            "in": "query",
            "description": "Filter by platform: pc, browser, or all",
            "schema": {
              "type": "string"
            },
            "required": false
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort games",
            "schema": {
              "type": "string"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Filtered list of games",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GameSummary"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "noAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "No authentication required. This is a public API."
      }
    },
    "schemas": {
      "GameSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Game ID"
          },
          "title": {
            "type": "string",
            "description": "Game title"
          },
          "thumbnail": {
            "type": "string",
            "description": "URL to game thumbnail"
          },
          "short_description": {
            "type": "string",
            "description": "Short description of the game"
          },
          "game_url": {
            "type": "string",
            "description": "URL to the game's page"
          },
          "genre": {
            "type": "string",
            "description": "Game genre"
          },
          "platform": {
            "type": "string",
            "description": "Platform (PC Windows or Web Browser)"
          },
          "publisher": {
            "type": "string"
          },
          "developer": {
            "type": "string"
          },
          "release_date": {
            "type": "string",
            "description": "Release date"
          },
          "freetogame_profile_url": {
            "type": "string"
          }
        }
      },
      "GameDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "thumbnail": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "short_description": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "game_url": {
            "type": "string"
          },
          "genre": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "platform": {
            "type": "string"
          },
          "publisher": {
            "type": "string"
          },
          "developer": {
            "type": "string"
          },
          "release_date": {
            "type": "string"
          },
          "freetogame_profile_url": {
            "type": "string"
          },
          "minimum_system_requirements": {
            "type": "object",
            "properties": {
              "os": {
                "type": "string"
              },
              "processor": {
                "type": "string"
              },
              "memory": {
                "type": "string"
              },
              "graphics": {
                "type": "string"
              },
              "storage": {
                "type": "string"
              }
            }
          },
          "screenshots": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "image": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "status_message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Games"
    }
  ]
}
