    "title": "CommCare HQ API",
    "version": "0.5.0",
    "description": "CommCare HQ REST API for managing cases, forms, users, applications, and other data in CommCare mobile data collection platform by Dimagi.",
    "x-jentic-source-url": "https://confluence.dimagi.com/display/commcarepublic/CommCare+API+Overview",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.commcarehq.org",
      "description": "CommCare HQ Production"
    }
  ],
  "security": [
    {
      "BasicAuth": []
    },
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Cases",
      "description": "Case data management"
    },
    {
      "name": "Forms",
      "description": "Form submission data"
    },
    {
      "name": "Users",
      "description": "Mobile and web user management"
    },
    {
      "name": "Applications",
      "description": "Application management"
    },
    {
      "name": "Lookups",
      "description": "Lookup tables/fixtures"
    },
    {
      "name": "Reports",
      "description": "Reporting endpoints"
    },
    {
      "name": "Messaging",
      "description": "SMS and messaging"
    },
    {
      "name": "Data",
      "description": "Bulk data and data forwarding"
    }
  ],
  "paths": {
    "/a/{domain}/api/v0.5/case": {
      "post": {
        "operationId": "createOrUpdateCase",
        "tags": [
          "Cases"
        ],
        "summary": "Create or update a case via XML",
        "description": "Submit case data to create or update cases.",
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "CommCare project domain"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Case created/updated"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/a/{domain}/api/v0.5/case/{caseId}": {
      "get": {
