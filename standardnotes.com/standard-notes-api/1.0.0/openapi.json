{
  "openapi": "3.0.3",
  "info": {
    "title": "Standard Notes API",
    "version": "1.0.0",
    "description": "Standard Notes is a safe, end-to-end encrypted notes app. The sync API handles user registration, authentication, session management, item synchronization, and file valet tokens.",
    "x-jentic-source-url": "https://standardnotes.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "variables": {
        "host": {
          "default": "api.standardnotes.com"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "User registration and authentication"
    },
    {
      "name": "Sessions",
      "description": "Session management"
    },
    {
      "name": "Items",
      "description": "Item sync and management"
    },
    {
      "name": "Users",
      "description": "User account operations"
    },
    {
      "name": "Files",
      "description": "File valet token operations"
    }
  ],
  "paths": {
    "/v1/users": {
      "post": {
        "tags": [
          "Auth"
        ],
        "operationId": "registerUser",
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password",
                  "pw_nonce",
                  "version"
                ],
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string",
                    "description": "Server password (derived from master password)"
                  },
                  "pw_nonce": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  },
                  "origination": {
                    "type": "string"
                  },
                  "api": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registration successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "$ref": "#/components/schemas/User"
                    },
                    "token": {
                      "type": "string"
                    },
                    "session": {
                      "$ref": "#/components/schemas/Session"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [],
        "description": "Register a new user"
      }
    },
    "/v1/users/{userUuid}/attributes/credentials": {
      "put": {
        "tags": [
          "Users"
        ],
        "operationId": "changeCredentials",
        "summary": "Change user password/credentials",
        "parameters": [
          {
            "name": "userUuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User UUID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "current_password",
                  "new_password",
                  "pw_nonce"
                ],
                "properties": {
                  "current_password": {
                    "type": "string"
                  },
                  "new_password": {
                    "type": "string"
                  },
                  "pw_nonce": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  },
                  "origination": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Credentials updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "$ref": "#/components/schemas/User"
                    },
                    "session": {
                      "$ref": "#/components/schemas/Session"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Change user password/credentials"
      }
    },
