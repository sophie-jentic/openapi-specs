{
  "openapi": "3.0.3",
  "info": {
    "title": "Toss Payments API",
    "version": "1.0.0",
    "description": "Toss Payments API enables payment processing, authorization, retrieval, and cancellation for Korean payment methods including cards, virtual accounts, mobile payments, and more.",
    "x-jentic-source-url": "https://docs.tosspayments.com/en/api-guide",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.tosspayments.com"
    }
  ],
  "paths": {
    "/v1/payments": {
      "post": {
        "operationId": "createPayment",
        "summary": "Create a payment",
        "description": "Create a payment window as an alternative to the SDK",
        "tags": [
          "Payments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/payments/confirm": {
      "post": {
        "operationId": "confirmPayment",
        "summary": "Confirm a payment",
        "description": "Authorize and confirm a payment after customer approval",
        "tags": [
          "Payments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "paymentKey",
                  "orderId",
                  "amount"
                ],
                "properties": {
                  "paymentKey": {
                    "type": "string"
                  },
                  "orderId": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/payments/{paymentKey}": {
      "get": {
        "operationId": "getPayment",
        "summary": "Retrieve a payment",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "paymentKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Retrieve a payment"
      }
    },
    "/v1/payments/{paymentKey}/cancel": {
      "post": {
        "operationId": "cancelPayment",
        "summary": "Cancel a payment",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "paymentKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "cancelReason"
                ],
                "properties": {
                  "cancelReason": {
                    "type": "string"
                  },
                  "cancelAmount": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Cancel a payment"
      }
    },
    "/v1/payments/orders/{orderId}": {
      "get": {
        "operationId": "getPaymentByOrderId",
        "summary": "Retrieve payment by order ID",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Retrieve payment by order ID"
      }
    },
    "/v1/billing/authorizations/card": {
      "post": {
        "operationId": "issueBillingKey",
        "summary": "Issue a billing key with card details",
        "tags": [
          "Billing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerKey": {
                    "type": "string"
                  },
                  "cardNumber": {
                    "type": "string"
                  },
                  "cardExpirationYear": {
                    "type": "string"
                  },
                  "cardExpirationMonth": {
                    "type": "string"
                  },
                  "customerIdentityNumber": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Issue a billing key with card details"
      }
    },
    "/v1/billing/{billingKey}": {
      "post": {
        "operationId": "chargeBillingKey",
        "summary": "Charge using a billing key",
        "tags": [
          "Billing"
        ],
        "parameters": [
          {
            "name": "billingKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "amount",
                  "customerKey",
                  "orderId",
                  "orderName"
                ],
                "properties": {
                  "amount": {
                    "type": "number"
                  },
                  "customerKey": {
                    "type": "string"
                  },
                  "orderId": {
                    "type": "string"
                  },
                  "orderName": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Charge using a billing key"
      }
    }
  },
  "components": {
    "schemas": {
      "Payment": {
        "type": "object",
        "properties": {
          "paymentKey": {
            "type": "string"
          },
          "orderId": {
            "type": "string"
          },
          "orderName": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "totalAmount": {
            "type": "number"
          },
          "currency": {
            "type": "string",
            "default": "KRW"
          },
          "method": {
            "type": "string"
          },
          "requestedAt": {
            "type": "string",
            "format": "date-time"
          },
          "approvedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PaymentCreateRequest": {
        "type": "object",
        "required": [
          "method",
          "amount",
          "orderId",
          "orderName"
        ],
        "properties": {
          "method": {
            "type": "string",
            "description": "Payment method enum"
          },
          "amount": {
            "type": "number",
            "description": "Charge amount"
          },
          "currency": {
            "type": "string",
            "default": "KRW"
          },
          "orderId": {
            "type": "string",
            "description": "Unique order ID (6-64 chars)"
          },
          "orderName": {
            "type": "string",
            "description": "Order name (max 100 chars)"
          },
          "successUrl": {
            "type": "string",
            "description": "Redirect URL on success"
          },
          "failUrl": {
            "type": "string",
            "description": "Redirect URL on failure"
          },
          "flowMode": {
            "type": "string",
            "enum": [
              "DEFAULT",
              "DIRECT"
            ]
          },
          "easyPay": {
            "type": "string",
            "description": "Digital wallet provider code"
          },
          "cardCompany": {
            "type": "string",
            "description": "Card company code"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic auth with Base64-encoded secret key"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Billing"
    },
    {
      "name": "Payments"
    }
  ]
}
