          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Story": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "uuid": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "full_slug": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "published_at": {
            "type": "string",
            "format": "date-time"
          },
          "first_published_at": {
            "type": "string",
            "format": "date-time"
          },
          "content": {
            "type": "object",
            "description": "Story content (component fields)"
          },
          "position": {
            "type": "integer"
          },
          "is_startpage": {
            "type": "boolean"
          },
          "parent_id": {
            "type": "integer",
            "nullable": true
          },
          "group_id": {
            "type": "string"
          },
          "tag_list": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "lang": {
            "type": "string"
          },
          "alternates": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "sort_by_date": {
            "type": "string",
            "nullable": true
          },
          "meta_data": {
            "type": "object"
          }
        }
      },
      "StoryListResponse": {
        "type": "object",
        "properties": {
          "stories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Story"
            }
          },
          "cv": {
            "type": "integer"
          },
          "rels": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "StoryResponse": {
        "type": "object",
        "properties": {
          "story": {
            "$ref": "#/components/schemas/Story"
          },
          "cv": {
            "type": "integer"
          },
          "rels": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Datasource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "dimensions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "name": {
                  "type": "string"
                },
                "entry_value": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "DatasourceListResponse": {
        "type": "object",
        "properties": {
          "datasources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Datasource"
            }
          }
        }
      },
      "DatasourceEntry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "dimension_value": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "DatasourceEntryListResponse": {
        "type": "object",
        "properties": {
          "datasource_entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DatasourceEntry"
            }
          }
        }
      },
      "Link": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "uuid": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "is_folder": {
            "type": "boolean"
          },
          "parent_id": {
            "type": "integer",
            "nullable": true
          },
          "published": {
            "type": "boolean"
          },
          "position": {
            "type": "integer"
          },
          "is_startpage": {
            "type": "boolean"
          },
          "real_path": {
            "type": "string"
          }
        }
      },
      "LinksResponse": {
        "type": "object",
        "properties": {
          "links": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "taggings_count": {
            "type": "integer"
          }
        }
      },
      "TagListResponse": {
        "type": "object",
        "properties": {
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tag"
            }
          }
        }
      },
      "SpaceResponse": {
        "type": "object",
        "properties": {
          "space": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "domain": {
