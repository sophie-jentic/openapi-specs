                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Query refund status"
      }
    },
    "/wallet/balance": {
      "post": {
        "operationId": "getWalletBalance",
        "summary": "Get wallet balance",
        "tags": [
          "Wallet"
        ],
        "parameters": [
          {
