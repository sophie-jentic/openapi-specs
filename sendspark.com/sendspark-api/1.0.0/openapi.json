  },
  "components": {
    "schemas": {
      "DynamicCampaignInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "templateId": {
            "type": "string"
          }
        }
      },
      "ProspectInput": {
        "type": "object",
        "properties": {
          "contactName": {
            "type": "string"
          },
          "contactEmail": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "jobTitle": {
            "type": "string"
          },
          "backgroundUrl": {
            "type": "string"
          }
        }
      },
      "BulkProspectInput": {
        "type": "object",
        "properties": {
          "prospects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProspectInput"
            }
          },
          "processAndAuthorizeCharge": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      },
      "apiSecret": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-secret"
      }
    }
  },
  "security": [
    {
      "apiKey": [],
      "apiSecret": []
    }
  ],
  "tags": [
