  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "TrackResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        }
      },
      "QueryRequest": {
        "type": "object",
        "properties": {
          "project": "str",
          "from": {
            "type": "integer",
            "description": "Start timestamp (ms)"
          },
          "to": {
            "type": "integer",
            "description": "End timestamp (ms)"
          },
          "segments": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "filters": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "TrendsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string"
                },
                "count": {
                  "type": "integer"
                },
                "visitors": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "ProfilesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Profile"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "Profile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "properties": {
            "type": "object"
          },
          "last_seen": {
            "type": "string",
