{
  "openapi": "3.0.3",
  "info": {
    "title": "Woopra API",
    "version": "1.0.0",
    "description": "Woopra real-time customer analytics platform API. Includes HTTP Tracking API for sending events and identifying visitors, Data Export APIs for querying analytics data (trends, profiles, journeys, retention, attribution, activity), and Profile CRUD API.",
    "x-jentic-source-url": "https://docs.woopra.com/reference/getting-started-with-tracking-sdks",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://www.woopra.com"
    }
  ],
  "paths": {
    "/track/ce": {
      "get": {
        "operationId": "trackEvent",
        "summary": "Track a custom event",
        "description": "Track a custom event for a visitor. Pass event properties as query parameters with ce_ prefix.",
        "tags": [
          "Tracking"
        ],
        "parameters": [
          {
            "name": "host",
            "in": "query",
            "description": "Website domain",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cookie",
            "in": "query",
            "description": "Visitor cookie/ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ce_name",
            "in": "query",
            "description": "Event name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ce_url",
            "in": "query",
            "description": "Page URL",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ce_title",
            "in": "query",
            "description": "Page title",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ip",
            "in": "query",
            "description": "Visitor IP address",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timestamp",
            "in": "query",
            "description": "Event timestamp (ms)",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "timeout",
            "in": "query",
            "description": "Visit timeout in seconds",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1800
            }
          },
          {
            "name": "browser",
            "in": "query",
            "description": "Browser name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "os",
            "in": "query",
            "description": "Operating system",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "device",
            "in": "query",
            "description": "Device type",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "referer",
            "in": "query",
            "description": "Referrer URL",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "description": "Browser language",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Event tracked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/track/identify": {
      "get": {
        "operationId": "identifyVisitor",
        "summary": "Identify a visitor",
        "description": "Associate visitor properties with a visitor cookie. Pass visitor properties as query parameters with cv_ prefix.",
        "tags": [
          "Tracking"
        ],
        "parameters": [
          {
            "name": "host",
            "in": "query",
            "description": "Website domain",
            "required": true,
            "schema": {
