{
  "openapi": "3.0.3",
  "info": {
    "title": "Lunatask API",
    "description": "Lunatask is a privacy-focused productivity app. The API provides access to manage tasks, notes, habits, journal entries, and people. Note: Lunatask API does not provide a way to read end-to-end encrypted data such as names of entities, notes, and other encrypted fields.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://lunatask.app/api/overview",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.lunatask.app/v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/ping": {
      "get": {
        "summary": "Ping",
        "description": "Test endpoint to confirm authentication is working.",
        "operationId": "ping",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "pong"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tasks": {
      "get": {
        "summary": "List Tasks",
        "description": "Retrieve all tasks, optionally filtered by source.",
        "operationId": "listTasks",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "source",
            "in": "query",
            "description": "Filter by source identifier.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "source_id",
            "in": "query",
            "description": "Filter by source ID.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tasks": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Task"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "summary": "Create Task",
        "description": "Create a new task. Returns 204 No Content when duplicate source/source_id exists for incomplete tasks in the same area.",
        "operationId": "createTask",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "task": {
                      "$ref": "#/components/schemas/Task"
                    }
                  }
                }
              }
            }
          },
          "204": {
            "description": "Duplicate task exists, no content returned"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/tasks/{id}": {
      "get": {
        "summary": "Retrieve Task",
        "description": "Retrieve a single task by ID.",
        "operationId": "getTask",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Task UUID.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "task": {
                      "$ref": "#/components/schemas/Task"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Task not found"
          }
        }
      },
      "put": {
        "summary": "Update Task",
        "description": "Update an existing task by ID.",
        "operationId": "updateTask",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Task UUID.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "task": {
                      "$ref": "#/components/schemas/Task"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Task not found"
          },
          "422": {
            "description": "Validation error"
          }
        }
      },
      "delete": {
        "summary": "Delete Task",
        "description": "Delete a task by ID.",
        "operationId": "deleteTask",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Task UUID.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted task returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "task": {
                      "$ref": "#/components/schemas/Task"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Task not found"
          }
        }
      }
    },
    "/notes": {
      "get": {
        "summary": "List Notes",
        "description": "Retrieve all notes, optionally filtered by source.",
        "operationId": "listNotes",
        "tags": [
          "Notes"
        ],
        "parameters": [
          {
            "name": "source",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "source_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of notes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "notes": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Note"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "summary": "Create Note",
        "description": "Create a new note. Returns 204 No Content if a note with the same source/source_id already exists in the same notebook.",
        "operationId": "createNote",
        "tags": [
          "Notes"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NoteCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Note created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "note": {
                      "$ref": "#/components/schemas/Note"
                    }
                  }
                }
              }
            }
          },
          "204": {
            "description": "Duplicate note exists"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/notes/{id}": {
      "put": {
        "summary": "Update Note",
        "description": "Update an existing note. Updating content replaces the entire content due to end-to-end encryption.",
        "operationId": "updateNote",
        "tags": [
          "Notes"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NoteUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Note updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "note": {
                      "$ref": "#/components/schemas/Note"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Note not found"
          }
        }
      },
      "delete": {
        "summary": "Delete Note",
        "description": "Delete a note by ID.",
        "operationId": "deleteNote",
        "tags": [
          "Notes"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted note returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "note": {
                      "$ref": "#/components/schemas/Note"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Note not found"
          }
        }
      }
    },
    "/habits/{id}/track": {
      "post": {
        "summary": "Track Habit Activity",
        "description": "Record a habit activity for a specific date.",
        "operationId": "trackHabit",
        "tags": [
          "Habits"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Habit UUID.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "performed_on"
                ],
                "properties": {
                  "performed_on": {
                    "type": "string",
                    "format": "date",
                    "description": "ISO-8601 formatted date when the activity was performed."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Activity tracked",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing date"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/journal_entries": {
      "post": {
        "summary": "Create Journal Entry",
        "description": "Create a new journal entry for a specific date.",
        "operationId": "createJournalEntry",
        "tags": [
          "Journal"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JournalEntryCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Journal entry created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "journal_entry": {
                      "$ref": "#/components/schemas/JournalEntry"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/people": {
      "get": {
        "summary": "List People",
        "description": "Retrieve all people, optionally filtered by source.",
        "operationId": "listPeople",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "source",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "source_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of people",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "people": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Person"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "summary": "Create Person",
        "description": "Create a new person/relationship. Returns 204 if person with same source/source_id already exists.",
        "operationId": "createPerson",
        "tags": [
          "People"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PersonCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Person created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "person": {
                      "$ref": "#/components/schemas/Person"
                    }
                  }
                }
              }
            }
          },
          "204": {
            "description": "Duplicate person exists"
          },
          "401": {
            "description": "Unauthorized"
          },
          "402": {
            "description": "Free plan people limit reached"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/people/{id}": {
      "get": {
        "summary": "Retrieve Person",
        "description": "Retrieve a single person by ID.",
        "operationId": "getPerson",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Person details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "person": {
                      "$ref": "#/components/schemas/Person"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Person not found"
          }
        }
      },
      "delete": {
        "summary": "Delete Person",
        "description": "Delete a person by ID.",
        "operationId": "deletePerson",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted person returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "person": {
                      "$ref": "#/components/schemas/Person"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Person not found"
          }
        }
      }
    },
    "/person_timeline_notes": {
      "post": {
        "summary": "Create Person Timeline Note",
        "description": "Create a timeline note linked to a person.",
        "operationId": "createPersonTimelineNote",
        "tags": [
          "People"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PersonTimelineNoteCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Timeline note created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "person_timeline_note": {
                      "$ref": "#/components/schemas/PersonTimelineNote"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token generated from the Lunatask desktop app settings."
      }
    },
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "area_id": {
            "type": "string",
            "format": "uuid"
          },
          "goal_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": [
              "later",
              "next",
              "started",
              "waiting",
              "completed"
            ]
          },
          "previous_status": {
            "type": "string",
            "nullable": true
          },
          "estimate": {
            "type": "integer",
            "nullable": true,
            "description": "Duration in minutes."
          },
          "priority": {
            "type": "integer",
            "minimum": -2,
            "maximum": 2,
            "description": "Priority from -2 (lowest) to 2 (highest). 0 is default."
          },
          "progress": {
            "type": "integer",
            "nullable": true
          },
          "motivation": {
            "type": "string",
            "enum": [
              "must",
              "should",
              "want",
              "unknown"
            ]
          },
          "eisenhower": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4,
            "description": "Eisenhower matrix quadrant (1-4) or 0 (uncategorized)."
          },
          "sources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Source"
            }
          },
          "scheduled_on": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TaskCreate": {
        "type": "object",
        "properties": {
          "area_id": {
            "type": "string",
            "format": "uuid",
            "description": "The area of life list where the task should be created."
          },
          "goal_id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "note": {
            "type": "string",
            "description": "Markdown-formatted content."
          },
          "status": {
            "type": "string",
            "enum": [
              "later",
              "next",
              "started",
              "waiting",
              "completed"
            ]
          },
          "motivation": {
            "type": "string",
            "enum": [
              "must",
              "should",
              "want",
              "unknown"
            ]
          },
          "eisenhower": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4
          },
          "estimate": {
            "type": "integer"
          },
          "priority": {
            "type": "integer",
            "minimum": -2,
            "maximum": 2
          },
          "scheduled_on": {
            "type": "string",
            "format": "date"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time"
          },
          "source": {
            "type": "string"
          },
          "source_id": {
            "type": "string"
          }
        }
      },
      "TaskUpdate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "later",
              "next",
              "started",
              "waiting",
              "completed"
            ]
          },
          "motivation": {
            "type": "string",
            "enum": [
              "must",
              "should",
              "want",
              "unknown"
            ]
          },
          "eisenhower": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4
          },
          "estimate": {
            "type": "integer"
          },
          "priority": {
            "type": "integer",
            "minimum": -2,
            "maximum": 2
          },
          "scheduled_on": {
            "type": "string",
            "format": "date"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Note": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "notebook_id": {
            "type": "string",
            "format": "uuid"
          },
          "date_on": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "sources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Source"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "NoteCreate": {
        "type": "object",
        "properties": {
          "notebook_id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "content": {
            "type": "string",
            "description": "Markdown-formatted content."
          },
          "date_on": {
            "type": "string",
            "format": "date"
          },
          "source": {
            "type": "string"
          },
          "source_id": {
            "type": "string"
          }
        }
      },
      "NoteUpdate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "content": {
            "type": "string",
            "description": "Replaces entire content due to E2E encryption."
          },
          "notebook_id": {
            "type": "string",
            "format": "uuid"
          },
          "date_on": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "JournalEntryCreate": {
        "type": "object",
        "required": [
          "date_on"
        ],
        "properties": {
