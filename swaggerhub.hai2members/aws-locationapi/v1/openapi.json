        "parameters": [
          {
            "name": "locationId",
            "in": "path",
            "description": "ID of location that needs to be updated",
            "required": true,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "name",
            "in": "formData",
            "description": "Updated name of the location",
            "required": false,
            "type": "string"
