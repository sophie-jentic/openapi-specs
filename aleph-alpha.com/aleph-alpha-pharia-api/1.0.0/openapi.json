{
  "openapi": "3.0.3",
  "info": {
    "title": "Aleph Alpha PhariaAI API",
    "version": "1.0.0",
    "description": "Aleph Alpha PhariaAI inference API for text generation, completion, embeddings, semantic similarity, question answering, summarization, and tokenization using Luminous models.",
    "x-jentic-source-url": "https://docs.aleph-alpha.com/phariaai-dev-guide/latest/pharia-openapi/index.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.aleph-alpha.com"
    }
  ],
  "paths": {
    "/complete": {
      "post": {
        "operationId": "complete",
        "summary": "Text completion",
        "description": "Generate text completions using a Luminous model",
        "tags": [
          "Completion"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompletionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Completion result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompletionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chat/completions": {
      "post": {
        "operationId": "chatCompletion",
        "summary": "Chat completion",
        "description": "Generate chat-style completions with message history",
        "tags": [
          "Chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chat completion",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/embed": {
      "post": {
        "operationId": "embed",
        "summary": "Create embeddings",
        "description": "Generate vector embeddings for text input",
        "tags": [
          "Embeddings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmbedRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Embeddings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmbedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/semantic_embed": {
      "post": {
        "operationId": "semanticEmbed",
        "summary": "Semantic embeddings",
        "description": "Generate semantically optimized embeddings for search and similarity",
        "tags": [
          "Embeddings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SemanticEmbedRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Semantic embeddings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmbedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/evaluate": {
      "post": {
        "operationId": "evaluate",
        "summary": "Evaluate text",
        "description": "Evaluate the likelihood of a completion given a prompt",
        "tags": [
          "Evaluation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "model",
                  "prompt",
                  "completion_expected"
                ],
                "properties": {
                  "model": {
                    "type": "string"
                  },
                  "prompt": {
                    "type": "string"
                  },
                  "completion_expected": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Evaluation result"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/qa": {
      "post": {
        "operationId": "questionAnswer",
        "summary": "Question answering",
        "description": "Answer questions based on provided documents",
        "tags": [
          "Q&A"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QARequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Answer",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QAResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/summarize": {
      "post": {
        "operationId": "summarize",
        "summary": "Summarize text",
        "description": "Generate a summary of the input text",
        "tags": [
          "Summarization"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "model",
                  "document"
                ],
                "properties": {
                  "model": {
                    "type": "string"
                  },
                  "document": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Summary"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tokenize": {
      "post": {
        "operationId": "tokenize",
        "summary": "Tokenize text",
        "description": "Split text into tokens",
        "tags": [
          "Tokenization"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "model",
                  "prompt"
                ],
                "properties": {
                  "model": {
                    "type": "string"
                  },
                  "prompt": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token list"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/detokenize": {
      "post": {
        "operationId": "detokenize",
        "summary": "Detokenize tokens",
        "description": "Convert token IDs back to text",
        "tags": [
          "Tokenization"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "model",
                  "token_ids"
                ],
                "properties": {
                  "model": {
                    "type": "string"
                  },
                  "token_ids": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/models_available": {
      "get": {
        "operationId": "listModels",
        "summary": "List available models",
        "tags": [
          "Models"
        ],
        "responses": {
          "200": {
            "description": "Available models"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List available models"
      }
    },
    "/users/me/tokens": {
      "get": {
        "operationId": "getTokenUsage",
        "summary": "Get token usage",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Token usage stats"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get token usage"
      }
    }
  },
  "components": {
    "schemas": {
      "CompletionRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Model name (e.g., luminous-supreme, luminous-base)"
          },
          "prompt": {
            "type": "string"
          },
          "maximum_tokens": {
            "type": "integer",
            "default": 64
          },
          "temperature": {
            "type": "number",
            "default": 0.0,
            "minimum": 0,
            "maximum": 1
          },
          "top_k": {
            "type": "integer"
          },
          "top_p": {
            "type": "number"
          },
          "stop_sequences": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "repetition_penalties_include_prompt": {
            "type": "boolean",
            "default": false
          },
          "best_of": {
            "type": "integer"
          },
          "n": {
            "type": "integer",
            "default": 1
          },
          "log_probs": {
            "type": "integer"
          },
          "tokens": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "CompletionResponse": {
        "type": "object",
        "properties": {
          "model_version": {
            "type": "string"
          },
          "completions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "completion": {
                  "type": "string"
                },
                "log_probs": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                },
                "finish_reason": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ChatRequest": {
        "type": "object",
        "required": [
          "model",
          "messages"
        ],
        "properties": {
          "model": {
            "type": "string"
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string",
                  "enum": [
                    "system",
                    "user",
                    "assistant"
                  ]
                },
                "content": {
                  "type": "string"
                }
              }
            }
          },
          "maximum_tokens": {
            "type": "integer"
          },
          "temperature": {
            "type": "number"
          },
          "stream": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "choices": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "index": {
                  "type": "integer"
                },
                "message": {
                  "type": "object",
                  "properties": {
                    "role": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                },
                "finish_reason": {
                  "type": "string"
                }
              }
            }
          },
          "usage": {
            "type": "object",
            "properties": {
              "prompt_tokens": {
                "type": "integer"
              },
              "completion_tokens": {
                "type": "integer"
              },
              "total_tokens": {
                "type": "integer"
              }
            }
          }
        }
      },
      "EmbedRequest": {
        "type": "object",
        "required": [
          "model",
          "prompts",
          "layers",
          "pooling"
        ],
        "properties": {
          "model": {
            "type": "string"
          },
          "prompts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "layers": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "pooling": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "mean",
                "max",
                "last_token",
                "abs_max"
              ]
            }
          }
        }
      },
      "EmbedResponse": {
        "type": "object",
        "properties": {
          "model_version": {
            "type": "string"
          },
          "embeddings": {
            "type": "object"
          }
        }
      },
      "SemanticEmbedRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt",
          "representation"
        ],
        "properties": {
          "model": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "representation": {
            "type": "string",
            "enum": [
              "symmetric",
              "document",
              "query"
            ]
          },
          "compress_to_size": {
            "type": "integer"
          }
        }
      },
      "QARequest": {
        "type": "object",
        "required": [
          "model",
          "query",
          "documents"
        ],
        "properties": {
          "model": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "documents": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                }
              }
            }
          },
          "max_answers": {
            "type": "integer",
            "default": 1
          }
        }
      },
      "QAResponse": {
        "type": "object",
        "properties": {
          "answers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "answer": {
                  "type": "string"
                },
                "score": {
                  "type": "number"
                },
                "evidence": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Aleph Alpha API token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Account"
    },
    {
      "name": "Chat"
    },
    {
      "name": "Completion"
    },
    {
      "name": "Embeddings"
    },
    {
      "name": "Evaluation"
    },
    {
      "name": "Models"
    },
    {
      "name": "Q&A"
    },
    {
      "name": "Summarization"
    },
    {
      "name": "Tokenization"
    }
  ]
}
