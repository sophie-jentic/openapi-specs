{
  "openapi": "3.0.0",
  "info": {
    "title": "Brainshop.ai API",
    "description": "Brainshop.ai is an AI-powered chatbot platform that provides natural language processing capabilities. Use this API to send messages and receive intelligent responses.",
    "version": "1.0.0",
    "contact": {
      "name": "Brainshop.ai",
      "url": "https://brainshop.ai"
    }
  },
  "servers": [
    {
      "url": "https://api.brainshop.ai",
      "description": "Brainshop.ai Production API Server"
    }
  ],
  "paths": {
    "/get": {
      "get": {
        "summary": "Send Message to AI Brain",
        "description": "Send a message to the AI brain and receive an intelligent response",
        "operationId": "sendMessage",
        "parameters": [
          {
            "name": "bid",
            "in": "query",
            "required": true,
            "description": "Brain ID - unique identifier for your AI brain",
            "schema": {
              "type": "string"
            },
            "example": "178"
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            },
            "example": "sX5A57n8kN9dfdLH"
          },
          {
            "name": "uid",
            "in": "query",
            "required": true,
            "description": "Unique user identifier to maintain conversation context",
            "schema": {
              "type": "string"
            },
            "example": "user123"
          },
          {
            "name": "msg",
            "in": "query",
            "required": true,
            "description": "The message/query to send to the AI",
            "schema": {
              "type": "string"
            },
            "example": "Hello, how are you?"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with AI-generated reply",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cnt": {
                      "type": "string",
                      "description": "The AI-generated response message"
                    }
                  }
                },
                "example": {
                  "cnt": "Hello! I'm doing great, thanks for asking. How can I help you today?"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key or Brain ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests - rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "get"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message describing what went wrong"
          },
          "message": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "get"
    }
  ]
}
