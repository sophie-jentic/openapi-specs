{
  "openapi": "3.0.3",
  "info": {
    "title": "Meet Xara AI API",
    "version": "1.0.0",
    "description": "Meet Xara AI API for intelligent meeting assistance and communication automation. AI-powered meeting transcription, summarization, and action item extraction.",
    "x-jentic-source-url": "https://ai-api.xylox.co/api-docs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://ai-api.xylox.co/v1"
    }
  ],
  "security": [
    {
      "ApiKey": []
    }
  ],
  "components": {
    "schemas": {
      "TranscriptionRequest": {
        "type": "object",
        "required": [
          "audio_url"
        ],
        "properties": {
          "audio_url": {
            "type": "string",
            "description": "URL to audio file"
          },
          "language": {
            "type": "string",
            "description": "Language code (e.g., 'en', 'es')"
          },
          "speaker_detection": {
            "type": "boolean",
            "description": "Enable speaker diarization"
          }
        }
      },
      "TranscriptionResponse": {
        "type": "object",
        "properties": {
          "transcription_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "speakers": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "duration": {
            "type": "number"
          }
        }
      },
      "SummaryRequest": {
        "type": "object",
        "required": [
          "transcription_id"
        ],
        "properties": {
          "transcription_id": {
            "type": "string"
          },
          "summary_type": {
            "type": "string",
            "enum": [
              "brief",
              "detailed",
              "bullet_points"
            ],
            "description": "Type of summary to generate"
          }
        }
      },
      "SummaryResponse": {
        "type": "object",
        "properties": {
          "summary_id": {
            "type": "string"
          },
          "transcription_id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "key_points": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "action_items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "task": {
                  "type": "string"
                },
                "assignee": {
                  "type": "string"
                },
                "due_date": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ActionItemsResponse": {
        "type": "object",
        "properties": {
          "transcription_id": {
            "type": "string"
          },
          "action_items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "task": {
                  "type": "string"
                },
                "assignee": {
                  "type": "string"
                },
                "priority": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "paths": {
    "/transcriptions": {
      "post": {
        "summary": "Create transcription",
        "description": "Transcribe audio from a meeting or conversation with optional speaker detection",
        "operationId": "createTranscription",
        "tags": [
          "Transcriptions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranscriptionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Transcription created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptionResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List transcriptions",
        "description": "Get a list of all transcriptions",
        "operationId": "listTranscriptions",
        "tags": [
          "Transcriptions"
        ],
        "responses": {
          "200": {
            "description": "List of transcriptions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TranscriptionResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transcriptions/{transcription_id}": {
      "get": {
        "summary": "Get transcription",
        "description": "Retrieve a specific transcription",
        "operationId": "getTranscription",
        "tags": [
          "Transcriptions"
        ],
        "parameters": [
          {
            "name": "transcription_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transcription details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/summaries": {
      "post": {
        "summary": "Generate summary",
        "description": "Generate an AI summary from a transcription with key points and action items",
        "operationId": "createSummary",
        "tags": [
          "Summaries"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SummaryRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Summary generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SummaryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transcriptions/{transcription_id}/action-items": {
      "get": {
        "summary": "Extract action items",
        "description": "Extract action items from a meeting transcription",
        "operationId": "getActionItems",
        "tags": [
          "Action Items"
        ],
        "parameters": [
          {
            "name": "transcription_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Action items extracted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActionItemsResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Transcriptions",
      "description": "Audio transcription"
    },
    {
      "name": "Summaries",
      "description": "Meeting summarization"
    },
    {
      "name": "Action Items",
      "description": "Action item extraction"
    }
  ]
}
