{
  "openapi": "3.0.3",
  "info": {
    "title": "Jaeger Query API",
    "version": "1.0.0",
    "description": "Jaeger is a distributed tracing platform. The Query API provides HTTP endpoints for retrieving traces, services, operations, and dependencies from the Jaeger backend. The HTTP JSON API is used by the Jaeger UI and is available on the jaeger-query service (default port 16686). Note: This API is labeled 'internal' by Jaeger and subject to change.",
    "x-jentic-source-url": "https://www.jaegertracing.io/docs/1.76/architecture/apis/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:16686",
      "description": "Jaeger Query service (default)"
    }
  ],
  "tags": [
    {
      "name": "Traces",
      "description": "Trace retrieval and search"
    },
    {
      "name": "Services",
      "description": "Service discovery"
    },
    {
      "name": "Operations",
      "description": "Operation discovery"
    },
    {
      "name": "Dependencies",
      "description": "Service dependency graph"
    },
    {
      "name": "Sampling",
      "description": "Remote sampling configuration"
    },
    {
      "name": "Metrics",
      "description": "Service performance metrics (SPM)"
    }
  ],
  "paths": {
    "/api/traces/{traceId}": {
      "get": {
        "operationId": "getTrace",
        "summary": "Get a trace by ID",
        "description": "Retrieves a single trace by its trace ID (hex string).",
        "tags": [
          "Traces"
        ],
        "parameters": [
          {
            "name": "traceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Trace ID as hex string"
          }
        ],
        "responses": {
          "200": {
            "description": "Trace data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TraceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Trace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/traces": {
      "get": {
        "operationId": "searchTraces",
        "summary": "Search for traces",
        "description": "Searches for traces matching the given criteria. Returns a list of matching traces.",
        "tags": [
          "Traces"
        ],
        "parameters": [
          {
            "name": "service",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Service name to search for"
          },
          {
            "name": "operation",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Operation name filter"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Start time in microseconds since epoch"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "End time in microseconds since epoch"
          },
          {
            "name": "minDuration",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Minimum trace duration (e.g., '1.2s', '100ms', '500us')"
          },
          {
            "name": "maxDuration",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Maximum trace duration"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            },
            "description": "Maximum number of traces to return"
          },
          {
            "name": "tags",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Tags filter as JSON map, e.g., {\"key\":\"value\"}"
          },
          {
            "name": "lookback",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Lookback period (e.g., '1h', '2d')"
          }
        ],
        "responses": {
          "200": {
            "description": "List of matching traces",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TracesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/services": {
      "get": {
        "operationId": "getServices",
        "summary": "Get all services",
        "description": "Returns a list of all known service names that have reported traces.",
        "tags": [
          "Services"
        ],
        "responses": {
          "200": {
            "description": "List of service names",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServicesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/services/{service}/operations": {
      "get": {
        "operationId": "getOperations",
        "summary": "Get operations for a service",
        "description": "Returns a list of all known operations for the given service.",
        "tags": [
          "Operations"
        ],
        "parameters": [
          {
            "name": "service",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Service name"
          },
          {
            "name": "spanKind",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by span kind (e.g., 'server', 'client')"
          }
        ],
        "responses": {
          "200": {
            "description": "List of operations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/dependencies": {
      "get": {
        "operationId": "getDependencies",
        "summary": "Get service dependency graph",
        "description": "Returns the service dependency graph for the given time range. The result is a list of edges (caller, callee, callCount).",
        "tags": [
          "Dependencies"
        ],
        "parameters": [
          {
            "name": "endTs",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "End timestamp in milliseconds since epoch"
          },
          {
            "name": "lookback",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Lookback duration in milliseconds"
          }
        ],
        "responses": {
          "200": {
            "description": "Dependency graph",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DependenciesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/sampling": {
      "get": {
        "operationId": "getSamplingStrategy",
        "summary": "Get sampling strategy for a service",
        "description": "Returns the sampling strategy configuration for the given service. Part of Jaeger's Remote Sampling protocol.",
        "tags": [
          "Sampling"
        ],
        "parameters": [
          {
            "name": "service",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Service name to get sampling strategy for"
          }
        ],
        "responses": {
          "200": {
            "description": "Sampling strategy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SamplingStrategy"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/metrics/latencies": {
      "get": {
        "operationId": "getLatencyMetrics",
        "summary": "Get latency metrics",
        "description": "Returns latency metrics (P50, P75, P95, P99) for the specified service and time range. Part of the Service Performance Monitoring (SPM) feature.",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "name": "service",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Service name"
          },
          {
            "name": "quantile",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "enum": [
                0.5,
                0.75,
                0.95,
                0.99
              ]
            },
            "description": "Quantile to retrieve"
          },
          {
            "name": "endTs",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "End timestamp (ms since epoch)"
          },
          {
            "name": "lookback",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Lookback in ms"
          },
          {
            "name": "step",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Step interval in ms"
          },
          {
            "name": "ratePer",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Rate per seconds"
          }
        ],
        "responses": {
          "200": {
            "description": "Latency metrics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetricsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/metrics/calls": {
      "get": {
        "operationId": "getCallMetrics",
        "summary": "Get call rate metrics",
        "description": "Returns call rate metrics for the specified service and time range.",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "name": "service",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Service name"
          },
          {
            "name": "endTs",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "End timestamp (ms since epoch)"
          },
          {
            "name": "lookback",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Lookback in ms"
          },
          {
            "name": "step",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Step interval in ms"
          },
          {
            "name": "ratePer",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Rate per seconds"
          }
        ],
        "responses": {
          "200": {
            "description": "Call rate metrics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetricsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/metrics/errors": {
      "get": {
        "operationId": "getErrorMetrics",
        "summary": "Get error rate metrics",
        "description": "Returns error rate metrics for the specified service and time range.",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "name": "service",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Service name"
          },
          {
            "name": "endTs",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "End timestamp (ms since epoch)"
          },
          {
            "name": "lookback",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Lookback in ms"
          },
          {
            "name": "step",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Step interval in ms"
          },
          {
            "name": "ratePer",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Rate per seconds"
          }
        ],
        "responses": {
          "200": {
            "description": "Error rate metrics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetricsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/metrics/minstep": {
      "get": {
        "operationId": "getMinStep",
        "summary": "Get minimum step duration",
        "description": "Returns the minimum step duration supported by the backend metrics store.",
        "tags": [
          "Metrics"
        ],
        "responses": {
          "200": {
            "description": "Minimum step value",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "min_step": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TraceResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Trace"
            }
          },
          "total": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StructuredError"
            }
          }
        }
      },
      "TracesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Trace"
            }
          },
          "total": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StructuredError"
            }
          }
        }
      },
      "Trace": {
        "type": "object",
        "properties": {
          "traceID": {
            "type": "string",
            "description": "Trace ID as hex string"
          },
          "spans": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Span"
            }
          },
          "processes": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Process"
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Span": {
        "type": "object",
        "properties": {
          "traceID": {
            "type": "string"
          },
          "spanID": {
            "type": "string"
          },
          "operationName": {
            "type": "string"
          },
          "references": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SpanReference"
            }
          },
          "startTime": {
            "type": "integer",
            "format": "int64",
            "description": "Start time in microseconds"
          },
          "duration": {
            "type": "integer",
            "format": "int64",
            "description": "Duration in microseconds"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KeyValue"
            }
          },
          "logs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SpanLog"
            }
          },
          "processID": {
            "type": "string"
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "flags": {
            "type": "integer"
          }
        }
      },
      "SpanReference": {
        "type": "object",
        "properties": {
          "refType": {
            "type": "string",
            "enum": [
              "CHILD_OF",
              "FOLLOWS_FROM"
            ]
          },
          "traceID": {
            "type": "string"
          },
          "spanID": {
            "type": "string"
          }
        }
      },
      "SpanLog": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "integer",
            "format": "int64"
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KeyValue"
            }
          }
        }
      },
      "KeyValue": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "string",
              "bool",
              "int64",
              "float64",
              "binary"
            ]
          },
          "value": {
            "description": "Value of the appropriate type"
          }
        }
      },
      "Process": {
        "type": "object",
        "properties": {
          "serviceName": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KeyValue"
            }
          }
        }
      },
      "ServicesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of service names"
          },
          "total": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StructuredError"
            }
          }
        }
      },
      "OperationsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Operation"
            }
          },
          "total": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StructuredError"
            }
          }
        }
      },
      "Operation": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Operation name"
          },
          "spanKind": {
            "type": "string",
            "description": "Span kind (server, client, etc.)"
          }
        }
      },
      "DependenciesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DependencyLink"
            }
          },
          "total": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StructuredError"
            }
          }
        }
      },
      "DependencyLink": {
        "type": "object",
        "properties": {
          "parent": {
            "type": "string",
            "description": "Caller service name"
          },
          "child": {
            "type": "string",
            "description": "Callee service name"
          },
          "callCount": {
            "type": "integer",
            "description": "Number of calls between services"
          }
        }
      },
      "SamplingStrategy": {
        "type": "object",
        "properties": {
          "strategyType": {
            "type": "string",
            "enum": [
              "PROBABILISTIC",
              "RATE_LIMITING"
            ],
            "description": "Type of sampling strategy"
          },
          "probabilisticSampling": {
            "type": "object",
            "properties": {
              "samplingRate": {
                "type": "number"
              }
            }
          },
          "rateLimitingSampling": {
            "type": "object",
            "properties": {
              "maxTracesPerSecond": {
                "type": "integer"
              }
            }
          },
          "operationSampling": {
            "type": "object",
            "properties": {
              "defaultSamplingProbability": {
                "type": "number"
              },
              "defaultLowerBoundTracesPerSecond": {
                "type": "number"
              },
              "perOperationStrategies": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "operation": {
                      "type": "string"
                    },
                    "probabilisticSampling": {
                      "type": "object",
                      "properties": {
                        "samplingRate": {
                          "type": "number"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "MetricsResponse": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "help": {
            "type": "string"
          },
          "metrics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MetricPoint"
            }
          }
        }
      },
      "MetricPoint": {
        "type": "object",
        "properties": {
          "labels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          },
