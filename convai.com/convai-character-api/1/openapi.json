{
  "openapi": "3.0.3",
  "info": {
    "title": "Convai Character API",
    "version": "1.0.0",
    "description": "Convai's Character API allows developers to create, update, retrieve, clone, and delete AI characters for interactive experiences. Requires Professional Plan or above.",
    "x-jentic-source-url": "https://docs.convai.com/api-docs/api-reference/core-api-reference/character-crafting-apis/character-api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.convai.com",
      "description": "Convai API"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Characters",
      "description": "Create and manage Convai AI characters."
    }
  ],
  "paths": {
    "/character/create": {
      "post": {
        "summary": "Create a character",
        "operationId": "createCharacter",
        "description": "Dynamically create a new AI character by providing basic information such as name, voice type, and backstory.",
        "tags": [
          "Characters"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCharacterRequest"
              },
              "example": {
                "charName": "Raymond",
                "voiceType": "MALE",
                "backstory": "Raymond Reddington is a criminal mastermind who turned himself in after 20+ years of evading the FBI."
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "A new character has been created with the necessary details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateCharacterResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - The registration of the new character has failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "API Key validation has failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/character/update": {
      "post": {
        "summary": "Update a character",
        "operationId": "updateCharacter",
        "description": "Update existing details of a character. Only pass the character information that needs to be updated; the rest will remain unchanged.",
        "tags": [
          "Characters"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCharacterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The details have been updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateCharacterResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - The update was unsuccessful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "API Key validation has failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/character/get": {
      "post": {
        "summary": "Get character details",
        "operationId": "getCharacter",
        "description": "Retrieve all information about a character. You can search by charID or charName.",
        "tags": [
          "Characters"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetCharacterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns all the information of the corresponding character.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CharacterDetailsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Failed to fetch the information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - API key validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/clone_character": {
      "post": {
        "summary": "Clone a character",
        "operationId": "cloneCharacter",
        "description": "Clone an existing character. Optionally clone the character's Knowledge Base (KB) as well.",
        "tags": [
          "Characters"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CloneCharacterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Character is successfully cloned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CloneCharacterResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - API key validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/character/delete": {
      "post": {
        "summary": "Delete a character",
        "operationId": "deleteCharacter",
        "description": "Delete an existing character. This action is irreversible and once deleted, the character cannot be recovered.",
        "tags": [
          "Characters"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeleteCharacterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Character successfully deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - API key validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "CONVAI-API-KEY",
        "description": "The unique API key provided for every user. Found under the Key icon when logged into your Convai account."
      }
    },
    "schemas": {
      "CreateCharacterRequest": {
        "type": "object",
        "required": [
          "charName",
          "voiceType",
          "backstory"
        ],
        "properties": {
          "charName": {
            "type": "string",
            "description": "Name of the new character being created."
          },
          "voiceType": {
            "type": "string",
            "description": "The type of voice the character is expected to have. Refer to the Voice List API for supported voices."
          },
          "backstory": {
            "type": "string",
            "description": "Basic background information of the character to start with."
          },
          "actions": {
            "type": "string",
            "description": "A list of actions for the character to choose from, to be performed based on interactions with the user."
          }
        }
      },
      "CreateCharacterResponse": {
        "type": "object",
        "properties": {
          "charID": {
            "type": "string",
            "description": "Character ID for the newly created character."
          }
        }
      },
      "UpdateCharacterRequest": {
        "type": "object",
        "required": [
          "charID"
        ],
        "properties": {
          "charID": {
            "type": "string",
            "description": "Character ID of the character to update."
          },
          "charName": {
            "type": "string",
            "description": "New name of the character."
          },
          "backstory": {
            "type": "string",
            "description": "Updated backstory for the character."
          },
          "voiceType": {
            "type": "string",
            "description": "New voice type for the character. Refer to the Voice List API for supported voices."
          },
          "action": {
            "type": "string",
            "description": "New list of actions for the character."
          },
          "languageCodes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "The list of language codes the character needs to support. Refer to the Language List API for available languages."
          }
        }
      },
      "UpdateCharacterResponse": {
        "type": "object",
        "properties": {
          "STATUS": {
            "type": "string",
            "example": "SUCCESS"
          }
        }
      },
      "GetCharacterRequest": {
        "type": "object",
        "properties": {
          "charID": {
            "type": "string",
            "description": "Character ID of the character for which to fetch all the details."
          },
          "charName": {
            "type": "string",
            "description": "Name of the character to search for."
          }
        }
      },
      "CharacterDetailsResponse": {
        "type": "object",
        "properties": {
          "character_name": {
            "type": "string"
          },
          "user_id": {
            "type": "string"
          },
          "character_id": {
            "type": "string"
          },
          "voice_type": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "backstory": {
            "type": "string"
          }
        }
      },
      "CloneCharacterRequest": {
        "type": "object",
        "required": [
          "charID"
        ],
        "properties": {
          "charID": {
            "type": "string",
            "description": "ID of the character to clone."
          },
          "KB": {
            "type": "boolean",
            "description": "True if the Knowledge Base should be cloned as well. Default is False.",
            "default": false
          }
        }
      },
      "CloneCharacterResponse": {
        "type": "object",
        "properties": {
          "charID": {
            "type": "string",
            "description": "ID of the newly created cloned character."
          }
        }
      },
      "DeleteCharacterRequest": {
        "type": "object",
        "required": [
          "charID"
        ],
        "properties": {
          "charID": {
            "type": "string",
            "description": "ID of the character to delete."
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "STATUS": {
            "type": "string",
            "example": "SUCCESS"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "INTERNAL_ERROR": {
            "type": "string"
          },
          "ERROR": {
            "type": "string"
          }
        }
      },
      "ApiErrorResponse": {
        "type": "object",
        "properties": {
          "API_ERROR": {
            "type": "string"
          }
        }
      }
    }
  }
}
