{
  "openapi": "3.0.3",
  "info": {
    "title": "DHL Shipment Tracking - Unified API",
    "version": "1.5.8",
    "description": "The DHL Unified Shipment Tracking API enables retrieval of real-time shipment status, service provider identification, and delivery address verification across all DHL divisions including Express, Parcel, eCommerce, and Freight.",
    "x-jentic-source-url": "https://developer.dhl.com/api-reference/shipment-tracking",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api-eu.dhl.com/track",
      "description": "Production"
    },
    {
      "url": "https://api-test.dhl.com/track",
      "description": "Test"
    }
  ],
  "paths": {
    "/shipments": {
      "get": {
        "operationId": "getTrackingShipment",
        "summary": "Track shipments",
        "description": "Retrieves up-to-the-minute shipment status reports including location, delivery time, travel history, and proof of delivery.",
        "tags": [
          "Tracking"
        ],
        "parameters": [
          {
            "name": "trackingNumber",
            "in": "query",
            "description": "The tracking number for the shipment. Also searches piece IDs and references.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "service",
            "in": "query",
            "description": "Hint for which DHL service provider to query.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "dgf",
                "dsc",
                "ecommerce",
                "ecommerce-apac",
                "ecommerce-europe",
                "ecommerce-ppl",
                "ecommerce-iberia",
                "express",
                "freight",
                "parcel-de",
                "parcel-nl",
                "parcel-pl",
                "parcel-uk",
                "post-de",
                "post-international",
                "sameday",
                "svb"
              ]
            }
          },
          {
            "name": "requesterCountryCode",
            "in": "query",
            "description": "ISO 3166-1 alpha-2 country code of the requester for display options.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "originCountryCode",
            "in": "query",
            "description": "ISO 3166-1 alpha-2 country code of shipment origin.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "recipientPostalCode",
            "in": "query",
            "description": "Postal code of the recipient. Enables detailed info for DE/NL parcels.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "description": "ISO 639-1 language code for localized messages.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results per page.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful retrieval of shipment tracking data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Shipment not found",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TrackingResponse": {
        "type": "object",
        "properties": {
          "shipments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Shipment"
            }
          }
        }
      },
      "Shipment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Shipment tracking ID"
          },
          "service": {
            "type": "string",
            "description": "DHL service type"
          },
          "origin": {
            "$ref": "#/components/schemas/Address"
          },
          "destination": {
            "$ref": "#/components/schemas/Address"
          },
          "status": {
            "$ref": "#/components/schemas/Status"
          },
          "estimatedTimeOfDelivery": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated delivery time in ISO 8601 format"
          },
          "estimatedTimeOfDeliveryRemark": {
            "type": "string",
            "description": "Remark about estimated delivery"
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TrackingEvent"
            }
          },
          "details": {
            "$ref": "#/components/schemas/ShipmentDetails"
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "countryCode": {
            "type": "string"
          },
          "postalCode": {
            "type": "string"
          },
          "addressLocality": {
            "type": "string"
          }
        }
      },
      "Status": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "location": {
            "$ref": "#/components/schemas/Address"
          },
          "statusCode": {
            "type": "string",
            "enum": [
              "delivered",
              "failure",
              "pre-transit",
              "transit",
              "unknown"
            ]
          },
          "status": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "TrackingEvent": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "location": {
            "$ref": "#/components/schemas/Address"
          },
          "statusCode": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "ShipmentDetails": {
        "type": "object",
        "properties": {
          "product": {
            "type": "object",
            "properties": {
              "productName": {
                "type": "string"
              }
            }
          },
          "weight": {
            "type": "object",
            "properties": {
              "value": {
                "type": "number"
              },
              "unitText": {
                "type": "string"
              }
            }
          },
          "dimensions": {
            "type": "object",
            "properties": {
              "length": {
                "type": "number"
              },
              "width": {
                "type": "number"
              },
              "height": {
                "type": "number"
              },
              "unitText": {
                "type": "string"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "name": "DHL-API-Key",
        "in": "header",
        "description": "Consumer Key from DHL Developer Portal MyApps dashboard"
      }
    }
  },
  "security": [
    {
      "ApiKey": []
    }
  ],
  "tags": [
    {
      "name": "Tracking"
    }
  ]
}
