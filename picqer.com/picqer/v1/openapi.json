  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use your API key as the username with any password"
      }
    },
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "idproduct": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "productcode": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "fixedstockprice": {
            "type": "number"
          },
          "stock": {
            "type": "integer"
          },
          "freestock": {
            "type": "integer"
          },
          "barcode": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "length": {
            "type": "number"
          },
          "width": {
            "type": "number"
          },
          "height": {
            "type": "number"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "CreateProductRequest": {
        "type": "object",
        "required": [
          "name",
          "productcode"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "productcode": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "barcode": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "idorder": {
            "type": "integer"
          },
          "orderid": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "idcustomer": {
            "type": "integer"
          },
          "delivery_name": {
            "type": "string"
          },
          "delivery_address": {
            "type": "string"
          },
          "total_price": {
            "type": "number"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": [
          "orderid"
        ],
        "properties": {
          "orderid": {
            "type": "string"
          },
          "idcustomer": {
            "type": "integer"
          },
          "delivery_name": {
            "type": "string"
          },
          "delivery_address": {
            "type": "string"
          },
          "products": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderProduct"
            }
          }
        }
      },
      "OrderProduct": {
        "type": "object",
        "properties": {
          "idproduct": {
            "type": "integer"
          },
          "productcode": {
            "type": "string"
          },
          "amount": {
            "type": "integer"
          },
          "price": {
            "type": "number"
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "idcustomer": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "firstname": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "zipcode": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        }
      },
      "CreateCustomerRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "firstname": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "zipcode": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        }
      },
      "Picklist": {
        "type": "object",
        "properties": {
          "idpicklist": {
            "type": "integer"
          },
          "idorder": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "closed": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Warehouse": {
        "type": "object",
        "properties": {
          "idwarehouse": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "PicqerWebhook": {
        "type": "object",
        "properties": {
          "idwebhook": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "event": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "CreateWebhookRequest": {
        "type": "object",
        "required": [
          "name",
          "url",
          "event"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "event": {
            "type": "string",
            "description": "Event type e.g. orders.completed, products.freestockchanged"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Error response",
        "properties": {
          "message": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
