{
  "openapi": "3.0.3",
  "info": {
    "title": "Tenovi Hardware Integration (HWI) API",
    "version": "1",
    "description": "The Tenovi Hardware Integration (HWI) API allows third-party clients to interact with remote patient monitoring (RPM) devices, gateways, fulfillment workflows, supplies, and more. Clients can receive measurement data from Tenovi devices via webhooks, activate/deactivate devices, manage patients, and handle fulfillment workflows.",
    "x-jentic-source-url": "https://docs.tenovi.com/hwi-api/overview/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api2.tenovi.com"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/hwi/hwi-devices": {
      "get": {
        "operationId": "listHwiDevices",
        "tags": [
          "Devices"
        ],
        "summary": "List HWI devices",
        "description": "Returns a list of all HWI devices associated with the client account.",
        "responses": {
          "200": {
            "description": "List of HWI devices",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HwiDevice"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      },
      "post": {
        "operationId": "activateHwiDevice",
        "tags": [
          "Devices"
        ],
        "summary": "Activate (request) an HWI device",
        "description": "Activates a new HWI device. Supports three use cases: (1) device given on-site with known Gateway ID, (2) device to be shipped by client's staff, (3) device to be dropshipped by Tenovi.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HwiDeviceActivationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Device activated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HwiDevice"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid device name or missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/hwi/hwi-devices/{id}": {
      "get": {
        "operationId": "getHwiDevice",
        "tags": [
          "Devices"
        ],
        "summary": "Get a specific HWI device",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Unique HWI device ID (UUID)",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "HWI device details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HwiDevice"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get a specific HWI device"
      },
      "delete": {
        "operationId": "deleteHwiDevice",
        "tags": [
          "Devices"
        ],
        "summary": "Delete/deactivate an HWI device",
        "description": "Removes the device from the account. Devices attached to fulfilled fulfillment requests cannot be deleted.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Unique HWI device ID (UUID)",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Device deleted successfully"
          },
          "400": {
            "description": "Bad request - device cannot be deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/hwi/patients": {
      "get": {
        "operationId": "listPatients",
        "tags": [
          "Patients"
        ],
        "summary": "List patient records",
        "description": "Returns a list of patient records associated with the client account.",
        "responses": {
          "200": {
            "description": "List of patients",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Patient"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createPatient",
        "tags": [
          "Patients"
        ],
        "summary": "Create a patient record",
        "description": "Creates a new patient record to attach devices, issue fulfillment requests, and validate shipping addresses.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Patient created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patient"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/hwi/hwi-device-types": {
      "get": {
        "operationId": "listDeviceTypes",
        "tags": [
          "Devices"
        ],
        "summary": "List available device types",
        "description": "Returns a list of valid device types and names associated with the client's account.",
        "responses": {
          "200": {
            "description": "List of device types",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DeviceType"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/hwi/webhooks": {
      "get": {
        "operationId": "listWebhooks",
        "tags": [
          "Webhooks"
        ],
        "summary": "List configured webhooks",
        "description": "Returns a list of configured measurement and fulfillment webhooks.",
        "responses": {
          "200": {
            "description": "List of webhooks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Webhook"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createWebhook",
        "tags": [
          "Webhooks"
        ],
        "summary": "Create a webhook",
        "description": "Creates a new webhook for receiving measurement or fulfillment data.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HwiDevice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique HWI device identifier"
          },
          "status": {
            "type": "string",
            "description": "Device status (e.g. Connected, Delivered, Pending Shipment, Dropship Requested)"
          },
          "connected_on": {
            "type": "string",
            "format": "date-time"
          },
          "unlinked_on": {
            "type": "string",
            "format": "date-time"
          },
          "last_measurement": {
            "type": "string",
            "format": "date-time"
          },
          "device": {
            "$ref": "#/components/schemas/DeviceDetail"
          },
          "patient_id": {
            "type": "string",
            "description": "External patient ID"
          },
          "patient_phone_number": {
            "type": "string"
          },
          "patient": {
            "$ref": "#/components/schemas/Patient"
          }
        }
      },
      "DeviceDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "description": "Device name (must match a device type on the account)",
            "example": "Tenovi BPM \u2013 L"
          },
          "hardware_uuid": {
            "type": "string",
            "nullable": true,
            "description": "Gateway ID or IMEI of the device"
          },
          "sensor_code": {
            "type": "string",
            "description": "Numeric sensor code for the device type"
          },
          "sensor_id": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "shared_hardware_uuid": {
            "type": "boolean"
          },
          "fulfillment_request": {
            "$ref": "#/components/schemas/FulfillmentRequest"
          }
        }
      },
      "FulfillmentRequest": {
        "type": "object",
        "properties": {
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "shipping_status": {
            "type": "string"
          },
          "shipping_name": {
            "type": "string"
          },
          "shipping_address": {
            "type": "string"
          },
          "shipping_city": {
            "type": "string"
          },
          "shipping_state": {
            "type": "string"
          },
          "shipping_zip_code": {
            "type": "string"
          },
          "shipped_on_behalf_of": {
            "type": "string"
          },
          "shipping_tracking_link": {
            "type": "string",
            "format": "uri"
          },
          "ship_gateway_only": {
            "type": "boolean"
          },
          "require_signature": {
            "type": "boolean"
          },
          "shipped_on": {
            "type": "string",
            "format": "date-time"
          },
          "delivered_on": {
            "type": "string",
            "format": "date-time"
          },
          "requested_by": {
            "type": "string"
          },
          "client_notes": {
            "type": "string"
          },
          "notify_emails": {
            "type": "string"
          },
          "fulfilled": {
            "type": "boolean"
          },
          "client_will_fulfill": {
            "type": "boolean"
          },
          "flagged_by_client": {
            "type": "boolean"
          }
        }
      },
      "Patient": {
        "type": "object",
        "properties": {
          "external_id": {
            "type": "string",
            "description": "Client-assigned unique identifier for the patient"
          },
          "name": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "physician": {
            "type": "string"
          },
          "clinic_name": {
            "type": "string"
          },
          "care_manager": {
            "type": "string"
          },
          "sms_opt_in": {
            "type": "boolean"
          }
        }
      },
      "PatientCreateRequest": {
        "type": "object",
        "required": [
          "external_id"
        ],
        "properties": {
          "external_id": {
            "type": "string",
            "description": "Client-assigned unique identifier (required)"
          },
          "name": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "physician": {
            "type": "string"
          },
          "clinic_name": {
            "type": "string"
          },
          "care_manager": {
            "type": "string"
          },
          "sms_opt_in": {
            "type": "boolean"
          }
        }
      },
      "HwiDeviceActivationRequest": {
        "type": "object",
        "required": [
          "device"
        ],
        "properties": {
          "device": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Device name (must match a device type on account)",
                "example": "Tenovi BPM"
              },
              "hardware_uuid": {
                "type": "string",
                "nullable": true,
                "description": "Gateway ID or IMEI. Set to null for shipment use cases."
              },
              "fulfillment_request": {
                "type": "object",
                "properties": {
                  "client_will_fulfill": {
                    "type": "boolean"
                  },
                  "notify_emails": {
                    "type": "string",
                    "description": "Comma-separated email addresses for shipping updates"
                  },
                  "require_signature": {
                    "type": "boolean"
                  },
                  "shipping_name": {
                    "type": "string"
                  },
                  "shipping_address": {
                    "type": "string"
                  },
                  "shipping_city": {
                    "type": "string"
                  },
                  "shipping_state": {
                    "type": "string"
                  },
                  "shipping_zip_code": {
                    "type": "string"
                  },
                  "ship_gateway_only": {
                    "type": "boolean"
                  }
                }
              }
            }
          },
          "patient": {
            "type": "object",
            "properties": {
              "external_id": {
                "type": "string"
              },
              "phone_number": {
                "type": "string"
              },
              "physician": {
                "type": "string"
              }
            }
          }
        }
      },
      "DeviceType": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Device name used in activation requests",
            "example": "Tenovi BPM \u2013 L"
          },
          "sensor_code": {
            "type": "string",
            "description": "Sensor code",
            "example": "10"
          }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook endpoint URL"
          },
          "type": {
            "type": "string",
            "description": "Webhook type (measurement or fulfillment)"
          }
        }
      },
      "WebhookCreateRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook endpoint URL"
          },
          "type": {
            "type": "string",
            "description": "Webhook type (measurement or fulfillment)"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "detail": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "tags": [
    {
      "name": "Devices"
    },
    {
      "name": "Patients"
    },
    {
      "name": "Webhooks"
    }
  ]
}
