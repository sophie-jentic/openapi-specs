{
  "openapi": "3.0.3",
  "info": {
    "title": "Chimp Rewriter API",
    "version": "1.0.0",
    "description": "ChimpRewriter is an article spinner/rewriter API. It provides text rewriting and spinning capabilities. The API uses POST requests with form-encoded parameters. Note: The chimprewriter.com site was returning HTTP 522 at documentation fetch time; this spec is based on limited archived information.",
    "x-jentic-source-url": "https://chimprewriter.com/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.chimprewriter.com",
      "description": "ChimpRewriter API server"
    }
  ],
  "tags": [
    {
      "name": "Rewriting",
      "description": "Text rewriting and spinning operations"
    }
  ],
  "paths": {
    "/ChimpRewrite": {
      "post": {
        "operationId": "rewriteText",
        "summary": "Rewrite/spin text",
        "description": "Submit text to be rewritten or spun using ChimpRewriter's article spinning engine.",
        "tags": [
          "Rewriting"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "apikey",
                  "text"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Account email address"
                  },
                  "apikey": {
                    "type": "string",
                    "description": "API key from ChimpRewriter account"
                  },
                  "text": {
                    "type": "string",
                    "description": "The text content to rewrite"
                  },
                  "quality": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5,
                    "description": "Rewrite quality level (1=most readable, 5=most unique)"
                  },
                  "posmatch": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 4,
                    "description": "Part of speech matching level"
                  },
                  "protectedterms": {
                    "type": "string",
                    "description": "Comma-separated terms to protect from rewriting"
                  },
                  "rewrite": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "1 to return rewritten article, 0 for spintax"
                  },
                  "sentencerewrite": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Enable sentence-level rewriting"
                  },
                  "grammarcheck": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Enable grammar checking"
                  },
                  "reorderparagraphs": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Reorder paragraphs"
                  },
                  "replacephrases": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Replace phrases"
                  },
                  "language": {
                    "type": "string",
                    "description": "Language code (e.g., en, es, fr, de)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rewritten text",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "Rewritten/spun text result"
                }
              }
            }
          },
          "400": {
            "description": "Bad request or error",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/ChimpRewriteBatch": {
      "post": {
        "operationId": "rewriteTextBatch",
        "summary": "Batch rewrite text",
        "description": "Submit multiple texts for batch rewriting.",
        "tags": [
          "Rewriting"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "apikey",
                  "text"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "apikey": {
                    "type": "string"
                  },
                  "text": {
                    "type": "string",
                    "description": "Multiple texts separated by delimiter"
                  },
                  "quality": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "posmatch": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 4
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch rewritten texts",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    }
  }
}
