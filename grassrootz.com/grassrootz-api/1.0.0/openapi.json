{
  "openapi": "3.0.3",
  "info": {
    "title": "Grassrootz API",
    "version": "1.0.0",
    "description": "The Grassrootz API provides comprehensive REST endpoints for fundraising, events, fitness tracking, and more. Before you can interact with Grassrootz API you will need an API key which must be requested from a support representative.\n\n## Authentication\n\nThe system uses a dual-key approach:\n- **ClientKey**: Required for public endpoints  \n- **ClientSecret**: Required alongside ClientKey for private/authenticated endpoints\n\nAccess keys grant the same permissions as an Organization Administrator in the admin portal.",
    "contact": {
      "url": "https://grassrootz.readme.io/reference/getting-started-with-your-api"
    }
  },
  "servers": [
    {
      "url": "https://api.grassrootz.com"
    }
  ],
  "security": [
    {
      "ClientKey": [],
      "ClientSecret": []
    }
  ],
