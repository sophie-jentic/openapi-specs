{
  "openapi": "3.0.3",
  "info": {
    "title": "Corrently Energy API",
    "version": "2.0.0",
    "description": "Corrently Energy API provides real-time data about renewable energy availability, CO2 emissions, electricity pricing, and solar energy predictions for German zip codes. The Gr\u00fcnstromIndex (Green Power Index) helps optimize energy consumption for sustainability.",
    "x-jentic-source-url": "https://api.corrently.io",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.corrently.io/v2.0"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    },
    {
      "tokenParam": []
    }
  ],
  "tags": [
    {
      "name": "Green Power Index",
      "description": "Gr\u00fcnstromIndex (GSI) endpoints for renewable energy predictions"
    },
    {
      "name": "CO2",
      "description": "CO2 emission predictions and offsets"
    },
    {
      "name": "Solar",
      "description": "Solar energy production predictions"
    },
    {
      "name": "Market",
      "description": "Electricity market data"
    },
    {
      "name": "Account",
      "description": "Stromkonto (electricity account) management"
    }
  ],
  "paths": {
    "/gsi/prediction": {
      "get": {
        "operationId": "getGsiPrediction",
        "summary": "Get Gr\u00fcnstromIndex prediction",
        "description": "Returns hourly forecasts showing renewable energy availability, CO2 emissions, and energy prices for a German zip code.",
        "tags": [
          "Green Power Index"
        ],
        "parameters": [
          {
            "name": "zip",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9]{5}$"
            },
            "description": "German ZIP code (Postleitzahl)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful prediction data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GsiPrediction"
                }
              }
            }
          },
          "400": {
            "description": "Invalid ZIP code",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gsi/bestHour": {
      "get": {
        "operationId": "getBestHour",
        "summary": "Find the best hour for energy consumption",
        "description": "Find the best hour for energy consumption based on renewable energy availability and low CO2 emissions.",
        "tags": [
          "Green Power Index"
        ],
        "parameters": [
          {
            "name": "zip",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9]{5}$"
            },
            "description": "German ZIP code"
          },
          {
            "name": "hours",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 24,
              "minimum": 1,
              "maximum": 168
            },
            "description": "Number of hours to look ahead"
          }
        ],
        "responses": {
          "200": {
            "description": "Best hour recommendation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BestHour"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gsi/marketdata": {
      "get": {
        "operationId": "getMarketData",
        "summary": "Get current electricity market data",
        "description": "Get current electricity market data and pricing information for a German location.",
        "tags": [
          "Market"
        ],
        "parameters": [
          {
            "name": "zip",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9]{5}$"
            },
            "description": "German ZIP code"
          }
        ],
        "responses": {
          "200": {
            "description": "Market data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketData"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/switchboard/gsiCO2": {
      "get": {
        "operationId": "getCo2Prediction",
        "summary": "Get CO2 emission predictions",
        "description": "Get CO2 emission predictions for electricity consumption in Germany by ZIP code.",
        "tags": [
          "CO2"
        ],
        "parameters": [
          {
            "name": "zip",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9]{5}$"
            },
            "description": "German ZIP code"
          }
        ],
        "responses": {
          "200": {
            "description": "CO2 prediction data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Co2Prediction"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/solar/prediction": {
      "get": {
        "operationId": "getSolarPrediction",
        "summary": "Get solar energy production predictions",
        "description": "Get solar energy production predictions for a specific solar installation at a given location.",
        "tags": [
          "Solar"
        ],
        "parameters": [
          {
            "name": "zip",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9]{5}$"
            },
            "description": "German ZIP code"
          },
          {
            "name": "kwp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "minimum": 0.1,
              "maximum": 1000
            },
            "description": "Solar panel capacity in kilowatt peak (kWp)"
          }
        ],
        "responses": {
          "200": {
            "description": "Solar prediction data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SolarPrediction"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stromkonto/balances": {
      "get": {
        "operationId": "getStromkontoBalance",
        "summary": "Get Stromkonto balance",
        "description": "Get Stromkonto (electricity account) balance information for a given account.",
        "tags": [
          "Account"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Account balance",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StromkontoBalance"
                }
              }
            }
          },
          "400": {
            "description": "Invalid account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tree/calculateCO2": {
      "get": {
        "operationId": "calculateCo2Offset",
        "summary": "Calculate CO2 offset",
        "description": "Calculate CO2 offset requirements and available compensation options.",
        "tags": [
          "CO2"
        ],
        "parameters": [
          {
            "name": "co2_kg",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "minimum": 0.1
            },
            "description": "Amount of CO2 in kilograms to offset"
          },
          {
            "name": "activity_type",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Type of activity (e.g., flight, car, heating)"
          }
        ],
        "responses": {
          "200": {
            "description": "Offset calculation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Co2Offset"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token from console.corrently.io"
      },
      "tokenParam": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "API token appended as query parameter"
      }
    },
    "schemas": {
      "GsiPrediction": {
        "type": "object",
        "properties": {
          "forecast": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "timeStamp": {
                  "type": "integer"
                },
                "gsi": {
                  "type": "number",
                  "description": "Green power index 0-100"
                },
                "co2_g_oekostrom": {
                  "type": "number"
                },
                "co2_g_standard": {
                  "type": "number"
                },
                "energyprice": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
      "BestHour": {
        "type": "object",
        "properties": {
          "timeStamp": {
            "type": "integer"
          },
          "gsi": {
            "type": "number"
          },
          "co2_g_oekostrom": {
            "type": "number"
          }
        }
      },
      "MarketData": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object"
          }
        }
      },
      "Co2Prediction": {
        "type": "object",
        "properties": {
          "forecast": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "timeStamp": {
                  "type": "integer"
                },
                "co2_g": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
      "SolarPrediction": {
        "type": "object",
        "properties": {
          "forecast": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "timeStamp": {
                  "type": "integer"
                },
                "wh": {
                  "type": "number",
                  "description": "Predicted watt-hours"
                }
              }
            }
          }
        }
      },
      "StromkontoBalance": {
        "type": "object",
        "properties": {
          "account": {
            "type": "string"
          },
          "balance": {
            "type": "number"
          }
        }
      },
      "Co2Offset": {
        "type": "object",
        "properties": {
          "co2_kg": {
            "type": "number"
          },
          "trees": {
            "type": "number"
          },
          "cost": {
            "type": "number"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
