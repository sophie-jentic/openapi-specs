  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use your API key as the username and 'x' as the password"
      }
    },
    "schemas": {
      "Subscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "state": {
            "type": "string"
          },
          "customer": {
            "$ref": "#/components/schemas/Customer"
          },
          "product": {
            "$ref": "#/components/schemas/Product"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "activated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SubscriptionRequest": {
        "type": "object",
        "required": [
          "product_id",
          "customer_id"
        ],
        "properties": {
          "product_id": {
            "type": "integer"
          },
          "customer_id": {
            "type": "integer"
          },
          "payment_collection_method": {
            "type": "string"
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "organization": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CustomerRequest": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "email"
        ],
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "organization": {
            "type": "string"
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "handle": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price_in_cents": {
            "type": "integer"
          },
          "interval": {
            "type": "integer"
          },
          "interval_unit": {
            "type": "string",
            "enum": [
              "day",
              "month"
            ]
          }
        }
      },
      "ProductRequest": {
        "type": "object",
        "required": [
          "name",
          "price_in_cents",
          "interval",
          "interval_unit"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "handle": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price_in_cents": {
            "type": "integer"
          },
          "interval": {
            "type": "integer"
          },
          "interval_unit": {
            "type": "string"
          }
        }
      },
      "Invoice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "subscription_id": {
            "type": "integer"
          },
          "total_amount_in_cents": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Component": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "unit_name": {
            "type": "string"
          },
          "allocated_quantity": {
            "type": "integer"
          }
        }
      },
      "Charge": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "amount_in_cents": {
            "type": "integer"
          },
          "memo": {
            "type": "string"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "ChargeRequest": {
        "type": "object",
        "required": [
          "amount",
          "memo"
        ],
        "properties": {
          "amount": {
            "type": "number"
          },
          "memo": {
            "type": "string"
          }
        }
      },
      "PaymentProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "customer_id": {
            "type": "integer"
          },
          "payment_type": {
            "type": "string"
          },
          "masked_card_number": {
            "type": "string"
          }
        }
      },
      "PaymentProfileRequest": {
        "type": "object",
        "required": [
          "customer_id"
        ],
        "properties": {
          "customer_id": {
            "type": "integer"
          },
          "card_number": {
            "type": "string"
          },
          "expiration_month": {
            "type": "integer"
          },
          "expiration_year": {
            "type": "integer"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "responses": {
      "ErrorResponse": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "UnauthorizedError": {
        "description": "Authentication required",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Subscriptions",
      "description": "Subscription management operations"
    },
    {
      "name": "Customers",
      "description": "Customer management operations"
    },
    {
      "name": "Products",
      "description": "Product catalog operations"
    },
    {
      "name": "Invoices",
      "description": "Invoice operations"
    },
    {
      "name": "Components",
      "description": "Component operations"
    },
    {
      "name": "Charges",
      "description": "One-time charge operations"
    },
    {
      "name": "Payment Profiles",
      "description": "Payment profile management"
    }
  ]
}
