    "/subscriptions/{subscription_id}/charges.json": {
      "post": {
        "summary": "Create Charge",
        "description": "Create a one-time charge for a subscription",
        "operationId": "createCharge",
        "tags": [
          "Charges"
        ],
        "parameters": [
          {
            "name": "subscription_id",
            "in": "path",
