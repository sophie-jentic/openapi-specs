{
  "openapi": "3.0.0",
  "info": {
    "title": "Blague.xyz API",
    "version": "1.0.0",
    "description": "French jokes API. Note: This API appears to be defunct as of 2026 (domain for sale). Specification created based on archived documentation and typical joke API patterns.",
    "contact": {
      "url": "https://blague.xyz"
    }
  },
  "servers": [
    {
      "url": "https://api.blague.xyz",
      "description": "API server (defunct)"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/joke/random": {
      "get": {
        "summary": "Get Random Joke",
        "description": "Returns a random French joke",
        "operationId": "getRandomJoke",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "description": "Filter by joke type",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "global",
                "dev",
                "dark",
                "limit",
                "beauf",
                "blondes"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "Joke ID"
                    },
                    "type": {
                      "type": "string",
                      "description": "Joke category"
                    },
                    "joke": {
                      "type": "object",
                      "properties": {
                        "question": {
                          "type": "string",
                          "description": "The joke question or setup"
                        },
                        "answer": {
                          "type": "string",
                          "description": "The joke punchline"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API token"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "tags": [
          "joke"
        ]
      }
    },
    "/joke/{id}": {
      "get": {
        "summary": "Get Joke by ID",
        "description": "Returns a specific joke by its ID",
        "operationId": "getJokeById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The joke ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "type": {
                      "type": "string"
                    },
                    "joke": {
                      "type": "object",
                      "properties": {
                        "question": {
                          "type": "string"
                        },
                        "answer": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Joke not found"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "tags": [
          "joke"
        ]
      }
    },
    "/joke/count": {
      "get": {
        "summary": "Get Total Joke Count",
        "description": "Returns the total number of jokes available",
        "operationId": "getJokeCount",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "description": "Filter count by joke type",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "global",
                "dev",
                "dark",
                "limit",
                "beauf",
                "blondes"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "integer",
                      "description": "Total number of jokes"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "tags": [
          "joke"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API token for authentication"
      }
    }
  },
  "tags": [
    {
      "name": "joke"
    }
  ]
}
