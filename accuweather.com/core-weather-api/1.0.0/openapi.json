{
  "openapi": "3.0.3",
  "info": {
    "title": "AccuWeather Core Weather API",
    "version": "1.0.0",
    "description": "AccuWeather API providing current conditions, forecasts, and location search for weather data worldwide.",
    "x-jentic-source-url": "https://developer.accuweather.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://dataservice.accuweather.com"
    }
  ],
  "tags": [
    {
      "name": "Locations",
      "description": "Search for locations and get location keys"
    },
    {
      "name": "Current Conditions",
      "description": "Get current weather conditions"
    },
    {
      "name": "Forecasts",
      "description": "Get weather forecasts"
    }
  ],
  "paths": {
    "/locations/v1/cities/search": {
      "get": {
        "operationId": "searchCities",
        "summary": "Search for cities",
        "description": "Search for cities by text query. Returns location keys that can be used for other API calls.",
        "tags": [
          "Locations"
        ],
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "description": "AccuWeather API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "City search text",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "description": "Language code (e.g., en-us, fr-fr)",
            "schema": {
              "type": "string",
              "default": "en-us"
            }
          },
          {
            "name": "details",
            "in": "query",
            "required": false,
            "description": "Include full details in the response",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Integer value to skip results",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful city search",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Location"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/locations/v1/cities/autocomplete": {
      "get": {
        "operationId": "autocompleteCities",
        "summary": "Autocomplete city search",
        "description": "Returns a list of cities that match the autocomplete text query.",
        "tags": [
          "Locations"
        ],
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Autocomplete text",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en-us"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Autocomplete results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AutocompleteResult"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/locations/v1/cities/geoposition/search": {
      "get": {
        "operationId": "searchByGeoposition",
        "summary": "Search location by geoposition",
        "description": "Search for a location by latitude and longitude.",
        "tags": [
          "Locations"
        ],
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Comma-separated latitude,longitude (e.g., 40.714,-74.006)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en-us"
            }
          },
          {
            "name": "details",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "toplevel",
            "in": "query",
            "required": false,
            "description": "Return only top-level city results",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Location found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Location"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/locations/v1/{locationKey}": {
      "get": {
        "operationId": "getLocation",
        "summary": "Get location by key",
        "description": "Retrieve location details by location key.",
        "tags": [
          "Locations"
        ],
        "parameters": [
          {
            "name": "locationKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en-us"
            }
          },
          {
            "name": "details",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Location details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Location"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/currentconditions/v1/{locationKey}": {
      "get": {
        "operationId": "getCurrentConditions",
        "summary": "Get current conditions",
        "description": "Returns current weather conditions for a specific location.",
        "tags": [
          "Current Conditions"
        ],
        "parameters": [
          {
            "name": "locationKey",
            "in": "path",
            "required": true,
            "description": "Location key from the Locations API",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en-us"
            }
          },
          {
            "name": "details",
            "in": "query",
            "required": false,
            "description": "Include full details (wind, UV index, visibility, etc.)",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Current conditions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CurrentCondition"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/forecasts/v1/daily/1day/{locationKey}": {
      "get": {
        "operationId": "getDailyForecast1Day",
        "summary": "Get 1-day daily forecast",
        "description": "Returns daily forecast for the next day for a specific location.",
        "tags": [
          "Forecasts"
        ],
        "parameters": [
          {
            "name": "locationKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en-us"
            }
          },
          {
            "name": "details",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "metric",
            "in": "query",
            "required": false,
            "description": "Return values in metric units",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily forecast",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailyForecastResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/forecasts/v1/daily/5day/{locationKey}": {
      "get": {
        "operationId": "getDailyForecast5Day",
