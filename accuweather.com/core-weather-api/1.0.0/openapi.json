              "default": "en-us"
            }
          },
          {
            "name": "details",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "metric",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "5-day daily forecast",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailyForecastResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/forecasts/v1/hourly/12hour/{locationKey}": {
      "get": {
        "operationId": "getHourlyForecast12Hour",
        "summary": "Get 12-hour hourly forecast",
        "description": "Returns hourly forecast for the next 12 hours.",
        "tags": [
          "Forecasts"
        ],
        "parameters": [
          {
            "name": "locationKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
