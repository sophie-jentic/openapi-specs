              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Location": {
        "type": "object",
        "properties": {
          "Key": {
            "type": "string",
            "description": "Location key for use in other API calls"
          },
          "LocalizedName": {
            "type": "string",
            "description": "Localized display name of the location"
          },
          "EnglishName": {
            "type": "string",
            "description": "English name of the location"
          },
          "Type": {
            "type": "string",
            "description": "Location type (e.g., City)"
          },
          "Country": {
            "type": "object",
            "properties": {
              "ID": {
                "type": "string"
              },
              "LocalizedName": {
                "type": "string"
              },
              "EnglishName": {
                "type": "string"
              }
            }
          },
          "AdministrativeArea": {
            "type": "object",
            "properties": {
              "ID": {
                "type": "string"
              },
              "LocalizedName": {
                "type": "string"
              },
              "EnglishName": {
                "type": "string"
              }
            }
          },
          "GeoPosition": {
            "type": "object",
            "properties": {
              "Latitude": {
                "type": "number",
                "format": "double"
              },
              "Longitude": {
                "type": "number",
                "format": "double"
              },
              "Elevation": {
                "type": "object",
                "properties": {
                  "Metric": {
                    "$ref": "#/components/schemas/UnitValue"
                  },
                  "Imperial": {
                    "$ref": "#/components/schemas/UnitValue"
                  }
                }
              }
            }
          },
          "TimeZone": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "string"
              },
              "Name": {
                "type": "string"
              },
              "GmtOffset": {
                "type": "number"
              },
              "IsDaylightSaving": {
                "type": "boolean"
              }
            }
          },
          "Rank": {
            "type": "integer",
            "description": "City rank"
          }
        }
      },
      "AutocompleteResult": {
        "type": "object",
        "properties": {
          "Version": {
            "type": "integer"
          },
          "Key": {
            "type": "string"
          },
          "Type": {
            "type": "string"
          },
          "Rank": {
            "type": "integer"
          },
          "LocalizedName": {
            "type": "string"
          },
          "Country": {
            "type": "object",
            "properties": {
              "ID": {
                "type": "string"
              },
              "LocalizedName": {
                "type": "string"
              }
            }
          },
          "AdministrativeArea": {
            "type": "object",
            "properties": {
              "ID": {
                "type": "string"
              },
              "LocalizedName": {
                "type": "string"
              }
            }
          }
        }
      },
      "CurrentCondition": {
        "type": "object",
        "properties": {
          "LocalObservationDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "EpochTime": {
            "type": "integer"
          },
          "WeatherText": {
            "type": "string",
            "description": "Phrase describing the current weather"
          },
          "WeatherIcon": {
            "type": "integer",
            "description": "Weather icon number"
          },
          "HasPrecipitation": {
            "type": "boolean"
          },
          "PrecipitationType": {
            "type": "string",
            "nullable": true
          },
          "IsDayTime": {
            "type": "boolean"
          },
          "Temperature": {
            "type": "object",
            "properties": {
              "Metric": {
                "$ref": "#/components/schemas/UnitValue"
              },
              "Imperial": {
                "$ref": "#/components/schemas/UnitValue"
              }
            }
          },
          "MobileLink": {
            "type": "string"
          },
          "Link": {
            "type": "string"
          }
        }
      },
      "DailyForecastResponse": {
        "type": "object",
        "properties": {
          "Headline": {
            "type": "object",
            "properties": {
              "EffectiveDate": {
                "type": "string",
                "format": "date-time"
              },
              "EffectiveEpochDate": {
                "type": "integer"
              },
              "Severity": {
                "type": "integer"
              },
              "Text": {
                "type": "string"
              },
              "Category": {
                "type": "string"
              },
              "EndDate": {
                "type": "string",
                "format": "date-time",
                "nullable": true
              },
              "EndEpochDate": {
                "type": "integer",
                "nullable": true
              },
              "MobileLink": {
                "type": "string"
              },
              "Link": {
                "type": "string"
              }
            }
          },
          "DailyForecasts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DailyForecast"
            }
          }
        }
      },
      "DailyForecast": {
        "type": "object",
        "properties": {
          "Date": {
            "type": "string",
            "format": "date-time"
          },
          "EpochDate": {
            "type": "integer"
          },
          "Temperature": {
            "type": "object",
            "properties": {
              "Minimum": {
                "$ref": "#/components/schemas/UnitValue"
              },
              "Maximum": {
                "$ref": "#/components/schemas/UnitValue"
              }
            }
          },
          "Day": {
            "$ref": "#/components/schemas/DayNightForecast"
          },
          "Night": {
            "$ref": "#/components/schemas/DayNightForecast"
          },
          "Sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "MobileLink": {
            "type": "string"
          },
          "Link": {
            "type": "string"
          }
        }
      },
      "DayNightForecast": {
        "type": "object",
        "properties": {
          "Icon": {
            "type": "integer"
          },
          "IconPhrase": {
            "type": "string"
          },
          "HasPrecipitation": {
            "type": "boolean"
          },
          "PrecipitationType": {
            "type": "string",
            "nullable": true
          },
          "PrecipitationIntensity": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "HourlyForecast": {
        "type": "object",
        "properties": {
          "DateTime": {
            "type": "string",
            "format": "date-time"
          },
          "EpochDateTime": {
            "type": "integer"
          },
          "WeatherIcon": {
            "type": "integer"
          },
          "IconPhrase": {
            "type": "string"
          },
          "HasPrecipitation": {
            "type": "boolean"
          },
          "IsDaylight": {
            "type": "boolean"
          },
          "Temperature": {
            "$ref": "#/components/schemas/UnitValue"
          },
          "PrecipitationProbability": {
            "type": "integer"
          },
          "MobileLink": {
            "type": "string"
          },
          "Link": {
            "type": "string"
          }
        }
      },
      "UnitValue": {
        "type": "object",
        "properties": {
          "Value": {
            "type": "number",
            "format": "double"
          },
          "Unit": {
            "type": "string"
          },
          "UnitType": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "Code": {
            "type": "string"
          },
          "Message": {
            "type": "string"
          },
          "Reference": {
            "type": "string"
          }
        }
      }
    }
  }
}
