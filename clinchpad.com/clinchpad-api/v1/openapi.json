{
  "openapi": "3.0.3",
  "info": {
    "title": "ClinchPad API",
    "description": "ClinchPad is a simple sales CRM and pipeline management tool. The API provides access to leads, pipelines, users, contacts, organizations, notes, and products.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://clinchpad.com/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.clinchpad.com/api/v1",
      "description": "ClinchPad API v1"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/leads": {
      "get": {
        "operationId": "listLeads",
        "summary": "List leads",
        "description": "Retrieve a paginated list of leads.",
        "tags": [
          "Leads"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "pipeline_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by pipeline ID"
          },
          {
            "name": "stage_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by stage ID"
          },
          {
            "name": "user_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by user ID"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "won",
                "lost"
              ]
            },
            "description": "Filter by lead status"
          }
        ],
        "responses": {
          "200": {
            "description": "List of leads",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Lead"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createLead",
        "summary": "Create a lead",
        "description": "Create a new lead in a pipeline.",
        "tags": [
          "Leads"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LeadCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Lead created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Lead"
                }
              }
            }
          }
        }
      }
    },
    "/leads/{leadId}": {
      "get": {
        "operationId": "getLead",
        "summary": "Get a lead",
        "description": "Retrieve a specific lead by ID.",
        "tags": [
          "Leads"
        ],
        "parameters": [
          {
            "name": "leadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Lead details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Lead"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateLead",
        "summary": "Update a lead",
        "description": "Update an existing lead.",
        "tags": [
          "Leads"
        ],
        "parameters": [
          {
            "name": "leadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LeadCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lead updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Lead"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteLead",
        "summary": "Delete a lead",
        "description": "Delete a specific lead.",
        "tags": [
          "Leads"
        ],
        "parameters": [
          {
            "name": "leadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead ID"
          }
        ],
        "responses": {
          "204": {
            "description": "Lead deleted successfully"
          }
        }
      }
    },
    "/leads/{leadId}/notes": {
      "get": {
        "operationId": "getLeadNotes",
        "summary": "Get notes for a lead",
        "description": "Retrieve notes attached to a specific lead.",
        "tags": [
          "Notes"
        ],
        "parameters": [
          {
            "name": "leadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of notes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Note"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createLeadNote",
        "summary": "Create a note for a lead",
        "description": "Add a note to a specific lead.",
        "tags": [
          "Notes"
        ],
        "parameters": [
          {
            "name": "leadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NoteCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Note created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Note"
                }
              }
            }
          }
        }
      }
    },
