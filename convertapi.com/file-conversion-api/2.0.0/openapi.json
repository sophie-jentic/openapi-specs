{
  "openapi": "3.0.3",
  "info": {
    "title": "ConvertAPI",
    "version": "2.0.0",
    "description": "ConvertAPI is a file conversion service that provides a REST API for converting files between various formats. Supports documents, images, web pages, and more. The API uses a simple pattern: POST to /convert/{source-format}/to/{destination-format}.",
    "x-jentic-source-url": "https://docs.convertapi.com",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://v2.convertapi.com"
    }
  ],
  "security": [
    {
      "secretAuth": []
    },
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Conversion",
      "description": "File format conversion endpoints"
    },
    {
      "name": "Account",
      "description": "Account and usage information"
    },
    {
      "name": "Files",
      "description": "File upload and management"
    }
  ],
  "paths": {
    "/convert/{sourceFormat}/to/{destinationFormat}": {
      "post": {
        "operationId": "convertFile",
        "summary": "Convert a file from one format to another",
        "description": "Convert a file by uploading it or providing a URL. The source and destination formats are specified in the URL path. Returns the converted file(s).",
        "tags": [
          "Conversion"
        ],
        "parameters": [
          {
            "name": "sourceFormat",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Source file format (e.g., docx, pdf, html, jpg)"
          },
          {
            "name": "destinationFormat",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Destination file format (e.g., pdf, jpg, png, docx)"
          },
          {
            "name": "Secret",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "API secret for authentication (alternative to Bearer token)"
          },
          {
            "name": "Token",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "API token for authentication (alternative to Secret)"
          },
          {
            "name": "StoreFile",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "When true, stores the converted file and returns a download URL valid for 3 hours"
          },
          {
            "name": "FileName",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Custom output file name"
          },
          {
            "name": "Timeout",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 900,
              "minimum": 10,
              "maximum": 1200
            },
            "description": "Conversion timeout in seconds"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "File": {
                    "type": "string",
                    "format": "binary",
                    "description": "File to convert"
                  },
                  "File.Url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of the file to convert (alternative to uploading)"
                  }
                }
              }
            },
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "Parameters": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "Name": {
                          "type": "string"
                        },
                        "Value": {}
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversion successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversionResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters or file format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/info": {
      "get": {
        "operationId": "getConverterInfo",
        "summary": "Get information about all available converters",
        "description": "Returns a list of all available file converters with supported formats, parameters and descriptions.",
        "tags": [
          "Conversion"
        ],
        "responses": {
          "200": {
            "description": "List of available converters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ConverterInfo"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user": {
      "get": {
        "operationId": "getUserInfo",
        "summary": "Get user account information",
        "description": "Returns account information including remaining seconds and active subscription details.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "User account information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserInfo"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/upload": {
      "post": {
        "operationId": "uploadFile",
        "summary": "Upload a file for later conversion",
        "description": "Uploads a file to ConvertAPI's temporary storage. Returns a file ID that can be used in subsequent conversion requests.",
        "tags": [
          "Files"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "File to upload"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "secretAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "Secret",
        "description": "API secret key for authentication"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    },
    "schemas": {
      "ConversionResult": {
        "type": "object",
        "properties": {
          "ConversionCost": {
            "type": "integer",
            "description": "Cost of conversion in seconds"
          },
          "Files": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "FileName": {
                  "type": "string"
                },
                "FileSize": {
                  "type": "integer"
                },
                "FileData": {
                  "type": "string",
                  "description": "Base64 encoded file data (when StoreFile is false)"
                },
                "Url": {
                  "type": "string",
                  "format": "uri",
                  "description": "Download URL (when StoreFile is true)"
                }
              }
            }
          }
        }
      },
      "ConverterInfo": {
        "type": "object",
        "properties": {
          "Name": {
            "type": "string"
          },
          "Title": {
            "type": "string"
          },
          "Description": {
            "type": "string"
          },
          "Tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "SourceFileFormats": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "SourceExtensions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "DestinationFileFormats": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "DestinationExtensions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ConverterGroup": {
            "type": "string"
          },
          "ConverterParameterGroups": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "Name": {
                  "type": "string"
                },
                "ConverterParameters": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "Name": {
                        "type": "string"
                      },
                      "Label": {
                        "type": "string"
                      },
                      "Description": {
                        "type": "string"
                      },
                      "Type": {
                        "type": "string"
                      },
                      "Required": {
                        "type": "boolean"
                      },
                      "Default": {}
                    }
                  }
                }
              }
            }
          }
        }
      },
      "UserInfo": {
        "type": "object",
        "properties": {
          "SecondsLeft": {
            "type": "integer"
          },
          "Active": {
            "type": "boolean"
          },
          "Email": {
            "type": "string"
          }
        }
      },
      "UploadResult": {
        "type": "object",
        "properties": {
          "FileId": {
            "type": "string"
          },
          "FileName": {
            "type": "string"
          },
          "FileSize": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "Code": {
            "type": "integer"
          },
          "Message": {
            "type": "string"
          }
        }
      }
    }
  }
}
