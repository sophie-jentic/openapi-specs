{
  "openapi": "3.0.3",
  "info": {
    "title": "Newsletter2Go API",
    "description": "Newsletter2Go API for email marketing campaigns and contact management. This API uses OAuth 2.0 for authentication and follows REST principles.",
    "version": "1.0.0",
    "contact": {
      "url": "https://www.newsletter2go.com"
    }
  },
  "servers": [
    {
      "url": "https://api.newsletter2go.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "OAuth2": []
    }
  ],
  "paths": {
    "/oauth/v2/token": {
      "post": {
        "summary": "Get OAuth token",
        "description": "Retrieve or refresh an access token for API authentication",
        "operationId": "getToken",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "password",
                      "refresh_token"
                    ]
                  },
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "refresh_token": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string"
                    },
                    "refresh_token": {
                      "type": "string"
                    },
                    "expires_in": {
                      "type": "integer"
                    },
                    "token_type": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid credentials"
          }
        },
        "tags": [
          "oauth"
        ]
      }
    },
    "/lists": {
      "get": {
        "summary": "Get all lists",
        "description": "Retrieve all mailing lists",
        "operationId": "getLists",
        "parameters": [
          {
            "name": "_limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Limit number of results"
          },
          {
            "name": "_offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Offset for pagination"
          },
          {
            "name": "_fields",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of fields to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "lists"
        ]
      },
      "post": {
        "summary": "Create a new list",
        "description": "Create a new mailing list",
        "operationId": "createList",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "List created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "lists"
        ]
      }
    },
    "/lists/{list_id}": {
      "get": {
        "summary": "Get specific list",
        "description": "Retrieve details of a specific mailing list",
        "operationId": "getList",
        "parameters": [
          {
            "name": "list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "404": {
            "description": "List not found"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "lists"
        ]
      },
      "patch": {
        "summary": "Update list",
        "description": "Update an existing mailing list",
        "operationId": "updateList",
        "parameters": [
          {
            "name": "list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "List not found"
          }
        },
        "tags": [
          "lists"
        ]
      },
      "delete": {
        "summary": "Delete list",
        "description": "Delete a mailing list",
        "operationId": "deleteList",
        "parameters": [
          {
            "name": "list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "List not found"
          }
        },
        "tags": [
          "lists"
        ]
      }
    },
    "/recipients/global": {
      "get": {
        "summary": "Get all recipients",
        "description": "Retrieve all recipients across all lists",
        "operationId": "getAllRecipients",
        "parameters": [
          {
            "name": "_limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "_offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "recipients"
        ]
      }
    },
    "/lists/{list_id}/recipients": {
      "get": {
        "summary": "Get list recipients",
        "description": "Retrieve recipients for a specific list",
        "operationId": "getListRecipients",
        "parameters": [
          {
            "name": "list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "_offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "List not found"
          }
        },
        "tags": [
          "lists"
        ]
      }
    },
    "/lists/{list_id}/recipients/{recipient_id}": {
      "get": {
        "summary": "Get recipient details",
        "description": "Retrieve details of a specific recipient",
        "operationId": "getRecipient",
        "parameters": [
          {
            "name": "list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "recipient_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Recipient not found"
          }
        },
        "tags": [
          "lists"
        ]
      },
      "delete": {
        "summary": "Delete recipient",
        "description": "Delete a recipient from a list",
        "operationId": "deleteRecipient",
        "parameters": [
          {
            "name": "list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "recipient_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recipient deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Recipient not found"
          }
        },
        "tags": [
          "lists"
        ]
      }
    },
    "/recipients": {
      "post": {
        "summary": "Create or update recipients",
        "description": "Create new recipients or update existing ones",
        "operationId": "createRecipients",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "type": "string",
                      "format": "email"
                    },
                    "first_name": {
                      "type": "string"
                    },
                    "last_name": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Recipients created/updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "recipients"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "password": {
            "tokenUrl": "https://api.newsletter2go.com/oauth/v2/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "ListsResponse": {
        "type": "object",
        "properties": {
          "info": {
            "type": "object",
            "properties": {
              "count": {
                "type": "integer"
              }
            }
          },
          "value": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "lists"
    },
    {
      "name": "oauth"
    },
    {
      "name": "recipients"
    }
  ]
}
