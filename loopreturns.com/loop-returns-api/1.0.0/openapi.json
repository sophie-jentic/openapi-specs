                }
              }
            }
          }
        },
        "description": "List webhooks"
      },
      "post": {
        "operationId": "createWebhook",
        "summary": "Create a webhook",
        "tags": [
          "Webhooks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url",
                  "topic"
                ],
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "topic": {
                    "type": "string",
                    "enum": [
                      "return.created",
                      "return.updated",
                      "return.processed",
                      "return.closed",
                      "label.created"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created webhook"
          },
          "400": {
            "description": "Bad request",
