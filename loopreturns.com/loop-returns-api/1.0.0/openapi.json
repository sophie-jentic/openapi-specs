  "components": {
    "schemas": {
      "Return": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "order_id": {
            "type": "string"
          },
          "order_name": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "open",
              "closed",
              "expired",
              "pending"
            ]
          },
          "line_items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReturnLineItem"
            }
          },
          "destination": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "label": {
            "type": "object",
            "properties": {
              "tracking_number": {
                "type": "string"
              },
              "carrier": {
                "type": "string"
              }
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ReturnsList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Return"
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "page": {
                "type": "integer"
              },
              "per_page": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              }
            }
          }
        }
      },
      "ReturnLineItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "variant_id": {
            "type": "string"
          },
          "product_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "quantity": {
            "type": "integer"
          },
          "reason": {
            "type": "string"
          },
          "outcome": {
            "type": "string",
            "enum": [
              "refund",
              "exchange",
              "store_credit"
            ]
          }
        }
      },
      "CreateReturnRequest": {
        "type": "object",
        "required": [
          "order_id",
          "line_items"
        ],
        "properties": {
          "order_id": {
            "type": "string"
          },
          "line_items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "variant_id",
                "quantity",
                "reason"
              ],
              "properties": {
                "variant_id": {
                  "type": "string"
                },
                "quantity": {
                  "type": "integer"
                },
                "reason": {
                  "type": "string"
                },
                "outcome": {
                  "type": "string",
                  "enum": [
                    "refund",
                    "exchange",
                    "store_credit"
                  ]
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Authorization",
        "description": "Loop Returns API key"
      }
    }
  },
  "security": [
