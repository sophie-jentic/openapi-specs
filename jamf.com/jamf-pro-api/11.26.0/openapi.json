{
  "openapi": "3.1.0",
  "info": {
    "title": "Jamf Pro API",
    "description": "Jamf Pro API provides endpoints for managing Apple devices (macOS, iOS, iPadOS, tvOS). It includes both the modern Jamf Pro API and the Classic API. This spec covers the modern Jamf Pro API (v1) with core endpoints for authentication, computers, mobile devices, users, groups, policies, and more. The Classic API uses XML and is documented separately.",
    "version": "11.26.0",
    "contact": {
      "name": "Jamf",
      "url": "https://developer.jamf.com"
    },
    "x-jentic-source-url": "https://developer.jamf.com/jamf-pro/reference/jamf-pro-api"
  },
  "servers": [
    {
      "url": "https://{instance}.jamfcloud.com",
      "description": "Jamf Pro Cloud instance",
      "variables": {
        "instance": {
          "default": "your-instance",
          "description": "Your Jamf Pro instance name"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Token-based authentication"
    },
    {
      "name": "Computers",
      "description": "Computer (Mac) management"
    },
    {
      "name": "Computer Inventory",
      "description": "Computer inventory collection"
    },
    {
      "name": "Mobile Devices",
      "description": "Mobile device management"
    },
    {
      "name": "Users",
      "description": "User management"
    },
    {
      "name": "Departments",
      "description": "Department management"
    },
    {
      "name": "Buildings",
      "description": "Building management"
    },
    {
      "name": "Categories",
      "description": "Category management"
    },
    {
      "name": "Scripts",
      "description": "Script management"
    },
    {
      "name": "Computer Groups",
      "description": "Computer group management"
    },
    {
      "name": "Policies",
      "description": "Policy management"
    },
    {
      "name": "Configuration Profiles",
      "description": "Configuration profile management"
    },
    {
      "name": "Self Service",
      "description": "Self Service settings"
    }
  ],
  "paths": {
    "/api/v1/auth/token": {
      "post": {
        "operationId": "createAuthToken",
        "summary": "Create authentication token",
        "description": "Creates a bearer token using Basic authentication (username/password). The token is valid for 30 minutes.",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Token created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    },
                    "expires": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/keep-alive": {
      "post": {
        "operationId": "keepAliveToken",
        "summary": "Refresh authentication token",
        "description": "Invalidates existing token and generates a new token.",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Token refreshed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    },
                    "expires": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/invalidate-token": {
      "post": {
        "operationId": "invalidateToken",
        "summary": "Invalidate authentication token",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "204": {
            "description": "Token invalidated"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Invalidate authentication token"
      }
    },
    "/api/v1/computers-inventory": {
      "get": {
        "operationId": "listComputerInventory",
        "summary": "List computer inventory",
        "description": "Returns a paginated list of computer inventory records.",
        "tags": [
          "Computer Inventory"
        ],
        "parameters": [
          {
            "name": "section",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "GENERAL",
                  "DISK_ENCRYPTION",
                  "PURCHASING",
                  "APPLICATIONS",
                  "STORAGE",
                  "USER_AND_LOCATION",
                  "CONFIGURATION_PROFILES",
                  "PRINTERS",
                  "SERVICES",
                  "HARDWARE",
                  "LOCAL_USER_ACCOUNTS",
                  "CERTIFICATES",
                  "ATTACHMENTS",
                  "PLUGINS",
                  "PACKAGE_RECEIPTS",
                  "FONTS",
                  "SECURITY",
                  "OPERATING_SYSTEM",
                  "LICENSED_SOFTWARE",
                  "IBEACONS",
                  "SOFTWARE_UPDATES",
                  "EXTENSION_ATTRIBUTES",
                  "CONTENT_CACHING",
                  "GROUP_MEMBERSHIPS"
                ]
              }
            },
            "description": "Sections to return"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "page-size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 2000
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "RSQL filter expression"
          }
        ],
        "responses": {
          "200": {
            "description": "Computer inventory list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "totalCount": {
                      "type": "integer"
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ComputerInventory"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
