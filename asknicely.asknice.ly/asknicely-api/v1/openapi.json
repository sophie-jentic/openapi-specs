{
  "openapi": "3.0.3",
  "info": {
    "title": "AskNicely API",
    "version": "v1",
    "description": "AskNicely NPS, CSAT & CX API for retrieving NPS scores and managing customer feedback data. Get NPS results with optional filtering by custom fields.",
    "contact": {
      "url": "https://asknicely.asknice.ly"
    },
    "x-jentic-source-url": "https://asknicely.asknice.ly/help/apidocs"
  },
  "servers": [
    {
      "url": "https://{subdomain}.asknice.ly/api/v1",
      "variables": {
        "subdomain": {
          "default": "YOUR_SUBDOMAIN",
          "description": "Your AskNicely subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/getnps/{days}": {
      "get": {
        "operationId": "getNpsScore",
        "summary": "Get NPS Score",
        "description": "Get your current NPS score for a given number of days. Optionally filter by multiple custom fields.",
        "tags": [
          "NPS"
        ],
        "parameters": [
          {
            "name": "days",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "default": 30
            },
            "description": "Number of days since today to calculate NPS score on, default is 30"
          },
          {
            "name": "filters[]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "style": "form",
            "explode": true,
            "description": "Custom field names to filter by, e.g. filters[]=country_c&filters[]=city_c. Must match in number and order with values[]."
          },
          {
            "name": "values[]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "style": "form",
            "explode": true,
            "description": "Custom field values to filter by, e.g. values[]=Canada&values[]=Vancouver. Must match in number and order with filters[]."
          }
        ],
        "responses": {
          "200": {
            "description": "NPS score result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NpsScoreResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-apikey",
        "description": "Your AskNicely API key"
      }
    },
    "schemas": {
      "NpsScoreResponse": {
        "type": "object",
        "properties": {
          "NPS": {
            "type": "string",
            "description": "The calculated NPS score as a string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "NPS"
    }
  ]
}
