  "components": {
    "schemas": {
      "Character": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Character name"
          },
          "image": {
            "type": "string",
            "format": "uri",
            "description": "URL of the character image"
          },
          "gender": {
            "type": "string",
            "description": "Character gender"
          },
          "hair": {
            "type": "string",
            "description": "Hair color/style"
          },
          "age": {
            "type": "string",
            "description": "Character age or age range"
          },
          "allOccupations": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "All occupations held by the character"
          },
          "occupation": {
            "type": "string",
            "description": "Primary occupation"
          },
          "nicknames": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Character nicknames"
          },
          "relatives": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "relationship": {
                  "type": "string"
                },
                "wikiUrl": {
                  "type": "string",
                  "format": "uri"
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              }
            },
            "description": "Family relationships"
          },
          "firstEpisode": {
            "type": "string",
            "description": "First episode appearance"
          },
          "voicedBy": {
            "type": "string",
            "description": "Voice actor"
          },
          "wikiUrl": {
            "type": "string",
            "format": "uri",
            "description": "Fandom wiki URL"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "API URL for this character"
          }
        }
      },
      "Episode": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Episode title"
          },
          "description": {
            "type": "string",
            "description": "Episode description/synopsis"
          },
          "productionCode": {
            "type": "string",
            "description": "Production code"
          },
          "airDate": {
            "type": "string",
            "description": "Air date"
          },
          "season": {
            "type": "integer",
            "description": "Season number"
          },
          "episode": {
            "type": "integer",
            "description": "Episode number within the season"
          },
          "totalViewers": {
            "type": "string",
            "description": "Total viewers"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "API URL for this episode"
          },
          "wikiUrl": {
            "type": "string",
            "format": "uri",
            "description": "Fandom wiki URL"
          }
        }
      },
      "StoreNextDoor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Store name"
          },
          "image": {
            "type": "string",
            "format": "uri",
            "description": "Image URL"
          },
          "season": {
            "type": "integer",
            "description": "Season number"
          },
          "episode": {
            "type": "integer",
            "description": "Episode number"
          },
          "episodeUrl": {
