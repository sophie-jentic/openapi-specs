      "PestControlTruck": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Pest control company name"
          },
          "image": {
            "type": "string",
            "format": "uri",
            "description": "Image URL"
          },
          "season": {
            "type": "integer",
            "description": "Season number"
          },
          "episode": {
            "type": "integer",
            "description": "Episode number"
          },
          "episodeUrl": {
            "type": "string",
