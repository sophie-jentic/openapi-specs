    "/job/perform_transcription": {
      "get": {
        "tags": [
          "Job"
        ],
        "operationId": "startJob",
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "description": "token to use",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "job_id",
            "in": "query",
            "description": "job id to use",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "v",
            "in": "query",
            "description": "version of api to use",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32",
              "enum": [
                1
              ]
            }
          },
          {
            "name": "target_language",
            "in": "query",
            "description": "language to transcribe to",
            "schema": {
              "type": "string",
              "enum": [
                "en"
              ]
            }
          },
          {
            "name": "transcription_fidelity",
            "in": "query",
            "description": "fidelity of output",
            "schema": {
              "type": "string",
              "default": "MECHANICAL",
              "enum": [
                "MECHANICAL",
                "EXTERNAL",
                "PREMIUM",
                "PROFESSIONAL"
              ]
            }
          },
          {
            "name": "priority",
            "in": "query",
            "description": "how important is this one",
            "schema": {
              "type": "string",
              "default": "STANDARD",
              "enum": [
                "STANDARD",
                "PRIORITY"
              ]
            }
          },
          {
            "name": "generate_media_intelligence_iwp",
            "in": "query",
            "description": "sets media intelligence",
            "schema": {
              "type": "string",
              "enum": [
                "PREMIUM",
                "INTERIM_PROFESSIONAL",
                "PROFESSIONAL",
                "SPEAKER_ID",
                "FINAL",
                "MECHANICAL",
                "CUSTOMER_APPROVED_RETURN",
                "CUSTOMER_APPROVED_TRANSLATION"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "start job response",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TaskIdResponse"
                }
              }
            }
          }
        },
        "description": "GET /job/perform_transcription"
      }
    },
