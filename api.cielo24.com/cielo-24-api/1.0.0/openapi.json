    {
      "url": "https://api.cielo24.com/api"
    }
  ],
  "paths": {
    "/account/login": {
      "get": {
        "tags": [
          "Account"
        ],
        "description": "logs into the system",
        "operationId": "login",
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "description": "username",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "password",
            "in": "query",
            "description": "password",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "v",
            "in": "query",
            "description": "api version",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiTokenResponse"
                }
              }
            }
          }
        }
      }
    },
    "/job/new": {
      "get": {
        "tags": [
          "Job"
        ],
        "description": "creates a new job",
        "operationId": "createJob",
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "description": "The API token used for this session",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "v",
            "in": "query",
            "description": "version of api to use",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32",
              "enum": [
                1
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "New job response",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/JobResponse"
                }
              }
            }
          }
        }
      }
    },
    "/job/add_media": {
      "get": {
        "tags": [
          "Job"
        ],
        "description": "adds media to a job",
        "operationId": "addMediaToJob",
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "description": "token to use",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "job_id",
            "in": "query",
            "description": "job id to use",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "v",
            "in": "query",
            "description": "version of api to use",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32",
              "enum": [
                1
              ]
            }
          },
          {
            "name": "media_url",
            "in": "query",
            "description": "URL of external media to add to job",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "New job response",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TaskIdResponse"
                }
              }
            }
          }
        }
      }
    },
