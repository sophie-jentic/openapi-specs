{
  "openapi": "3.0.3",
  "info": {
    "title": "HG Brasil Weather API",
    "description": "Provides weather forecast data for cities in Brazil, including current conditions and extended forecasts with temperature, humidity, wind, and precipitation data.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://hgbrasil.com/status/weather",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.hgbrasil.com",
      "description": "HG Brasil API server"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    {
      "name": "Weather",
      "description": "Weather forecast and current conditions"
    }
  ],
  "paths": {
    "/weather": {
      "get": {
        "operationId": "getWeather",
        "summary": "Get weather data",
        "description": "Retrieve current weather conditions and forecast for a location in Brazil. Location can be specified by city name, WOEID, coordinates, or IP-based geolocation.",
        "tags": [
          "Weather"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API authentication key"
          },
          {
            "name": "city_name",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "City name in format 'City,State' (e.g., 'S\u00e3o Paulo,SP')"
          },
          {
            "name": "woeid",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Where On Earth ID for the location"
          },
          {
            "name": "lat",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Latitude coordinate"
          },
          {
            "name": "lon",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Longitude coordinate"
          },
          {
            "name": "user_ip",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "IP address for geolocation-based lookup. Use 'remote' for automatic detection."
          },
          {
            "name": "locale",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "pt",
                "en"
              ],
              "default": "pt"
            },
            "description": "Response language (pt for Portuguese, en for English)"
          },
          {
            "name": "sdk_version",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "SDK version identifier"
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json-cors"
              ],
              "default": "json-cors"
            },
            "description": "Response format for CORS-enabled requests"
          }
        ],
        "responses": {
          "200": {
            "description": "Weather data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WeatherResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key passed as a query parameter"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "valid_key": {
            "type": "boolean",
            "description": "Whether the provided API key is valid"
          }
        }
      },
      "WeatherResponse": {
        "type": "object",
        "properties": {
          "by": {
            "type": "string",
            "description": "Method used to identify location (e.g., city_name, woeid, coordinates)"
          },
          "valid_key": {
            "type": "boolean",
            "description": "Indicates if the API key is valid"
          },
          "results": {
            "$ref": "#/components/schemas/WeatherResults"
          },
          "execution_time": {
            "type": "number",
            "description": "API execution time in seconds"
          },
          "from_cache": {
            "type": "boolean",
            "description": "Whether the data was served from cache"
          }
        }
      },
      "WeatherResults": {
        "type": "object",
        "properties": {
          "temp": {
            "type": "integer",
            "description": "Current temperature in Celsius"
          },
          "date": {
            "type": "string",
            "description": "Current date"
          },
          "time": {
            "type": "string",
            "description": "Current time"
          },
          "condition_code": {
            "type": "string",
            "description": "Weather condition code"
          },
          "description": {
            "type": "string",
            "description": "Weather condition description"
          },
          "currently": {
            "type": "string",
            "description": "Time of day (e.g., dia, noite)"
          },
          "cid": {
            "type": "string",
            "description": "City identifier"
          },
          "city": {
            "type": "string",
            "description": "City name"
          },
          "img_id": {
            "type": "string",
            "description": "Weather icon ID"
          },
          "humidity": {
            "type": "integer",
            "description": "Relative humidity percentage"
          },
          "cloudiness": {
            "type": "number",
            "description": "Cloud coverage percentage"
          },
          "rain": {
            "type": "number",
            "description": "Precipitation in mm"
          },
          "wind_speedy": {
            "type": "string",
            "description": "Wind speed with unit"
          },
          "wind_direction": {
            "type": "integer",
            "description": "Wind direction in degrees"
          },
          "wind_cardinal": {
            "type": "string",
            "description": "Wind cardinal direction"
          },
          "sunrise": {
            "type": "string",
            "description": "Sunrise time"
          },
          "sunset": {
            "type": "string",
            "description": "Sunset time"
          },
          "moon_phase": {
            "type": "string",
            "description": "Current moon phase"
          },
          "condition_slug": {
            "type": "string",
            "description": "Weather condition slug"
          },
          "city_name": {
            "type": "string",
            "description": "Full city name"
          },
          "timezone": {
            "type": "string",
            "description": "Timezone of the location"
          },
          "latitude": {
            "type": "number",
            "format": "double",
            "description": "Latitude"
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "description": "Longitude"
          },
          "forecast": {
            "type": "array",
            "description": "Extended forecast (up to 16 days)",
            "items": {
              "$ref": "#/components/schemas/ForecastDay"
            }
          }
        }
      },
      "ForecastDay": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "description": "Forecast date"
          },
          "weekday": {
            "type": "string",
            "description": "Day of week"
          },
          "max": {
            "type": "integer",
            "description": "Maximum temperature in Celsius"
          },
          "min": {
            "type": "integer",
            "description": "Minimum temperature in Celsius"
          },
          "cloudiness": {
            "type": "number",
            "description": "Cloud coverage percentage"
          },
          "rain": {
            "type": "number",
            "description": "Rain amount in mm"
          },
          "rain_probability": {
            "type": "integer",
            "description": "Probability of rain in percentage"
          },
          "wind_speedy": {
            "type": "string",
            "description": "Wind speed with unit"
          },
          "humidity": {
            "type": "integer",
            "description": "Humidity percentage"
          },
          "description": {
            "type": "string",
            "description": "Weather condition description"
          },
          "condition": {
            "type": "string",
            "description": "Weather condition slug"
          }
        }
      }
    }
  }
}
