{
  "openapi": "3.0.3",
  "info": {
    "title": "Arbeitsagentur Jobsuche API",
    "description": "The Arbeitsagentur Jobsuche API provides access to job listings from the German Federal Employment Agency (Bundesagentur f\u00fcr Arbeit). It allows searching for job offers with various filters including location, profession, employment type, and more.",
    "version": "1.0.0",
    "contact": {
      "name": "Bundesagentur f\u00fcr Arbeit",
      "url": "https://jobsuche.api.bund.dev/"
    },
    "license": {
      "name": "Data licence Germany \u2013 attribution \u2013 Version 2.0",
      "url": "https://www.govdata.de/dl-de/by-2-0"
    },
    "x-jentic-source-url": "https://jobsuche.api.bund.dev/"
  },
  "externalDocs": {
    "description": "GitHub Repository",
    "url": "https://github.com/bundesAPI/jobsuche-api"
  },
  "servers": [
    {
      "url": "https://rest.arbeitsagentur.de/jobboerse/jobsuche-service",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Job Search",
      "description": "Search for job listings"
    },
    {
      "name": "Resources",
      "description": "Retrieve associated resources such as company logos"
    }
  ],
  "paths": {
    "/pc/v4/jobs": {
      "get": {
        "operationId": "searchJobs",
        "summary": "Search job listings",
        "description": "Search for available job offers using various filter parameters including keywords, location, career field, employment type, and more.",
        "tags": [
          "Job Search"
        ],
        "parameters": [
          {
            "name": "was",
            "in": "query",
            "description": "Free text search for job title or keywords",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "wo",
            "in": "query",
            "description": "Free text search for location",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "berufsfeld",
            "in": "query",
            "description": "Career field filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Number of results per page",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "arbeitgeber",
            "in": "query",
            "description": "Employer name filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "veroeffentlichtseit",
            "in": "query",
            "description": "Number of days since publication (0-100)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            }
          },
          {
            "name": "zeitarbeit",
            "in": "query",
            "description": "Include temporary agency jobs (default: true)",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "angebotsart",
            "in": "query",
            "description": "Offer type: 1=WORK, 2=SELF_EMPLOYED, 4=TRAINING, 34=INTERNSHIP",
            "schema": {
              "type": "integer",
              "enum": [
                1,
                2,
                4,
                34
              ]
            }
          },
          {
            "name": "befristung",
            "in": "query",
            "description": "Contract duration: 1=Limited, 2=Permanent. Semicolon-separated for multiple values.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "arbeitszeit",
            "in": "query",
            "description": "Working time model: vz=FULLTIME, tz=PARTTIME, snw=SHIFT_NIGHT_WEEKEND, ho=REMOTE, mj=MINIJOB",
            "schema": {
              "type": "string",
              "enum": [
                "vz",
                "tz",
                "snw",
                "ho",
                "mj"
              ]
            }
          },
          {
            "name": "behinderung",
            "in": "query",
            "description": "Filter for disability-suitable positions",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "corona",
            "in": "query",
            "description": "Filter for COVID-context positions only",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "umkreis",
            "in": "query",
            "description": "Search radius in kilometers",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful job search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/pc/v4/app/jobs": {
      "get": {
        "operationId": "searchJobsApp",
        "summary": "Search job listings (mobile app variant)",
        "description": "Mobile application variant of the job search endpoint with identical parameters and response format.",
        "tags": [
          "Job Search"
        ],
        "parameters": [
          {
            "name": "was",
            "in": "query",
            "description": "Free text search for job title or keywords",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "wo",
            "in": "query",
            "description": "Free text search for location",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "berufsfeld",
            "in": "query",
            "description": "Career field filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Number of results per page",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "arbeitgeber",
            "in": "query",
            "description": "Employer name filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "veroeffentlichtseit",
            "in": "query",
            "description": "Number of days since publication (0-100)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            }
          },
          {
            "name": "zeitarbeit",
            "in": "query",
            "description": "Include temporary agency jobs (default: true)",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "angebotsart",
            "in": "query",
            "description": "Offer type: 1=WORK, 2=SELF_EMPLOYED, 4=TRAINING, 34=INTERNSHIP",
            "schema": {
              "type": "integer",
              "enum": [
                1,
                2,
                4,
                34
              ]
            }
          },
          {
            "name": "befristung",
            "in": "query",
            "description": "Contract duration: 1=Limited, 2=Permanent. Semicolon-separated for multiple values.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "arbeitszeit",
            "in": "query",
            "description": "Working time model: vz=FULLTIME, tz=PARTTIME, snw=SHIFT_NIGHT_WEEKEND, ho=REMOTE, mj=MINIJOB",
            "schema": {
              "type": "string",
              "enum": [
                "vz",
                "tz",
                "snw",
                "ho",
                "mj"
              ]
            }
          },
          {
            "name": "behinderung",
            "in": "query",
            "description": "Filter for disability-suitable positions",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "corona",
            "in": "query",
            "description": "Filter for COVID-context positions only",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "umkreis",
            "in": "query",
            "description": "Search radius in kilometers",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful job search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/ed/v1/arbeitgeberlogo/{hashID}": {
      "get": {
        "operationId": "getEmployerLogo",
        "summary": "Get employer logo",
        "description": "Retrieve the company logo image for a given employer hash ID.",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "hashID",
            "in": "path",
            "required": true,
            "description": "The hash ID of the employer",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Employer logo image",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "Logo not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "JobSearchResponse": {
        "type": "object",
        "properties": {
          "stellenangebote": {
            "type": "array",
            "description": "Array of job listings",
            "items": {
              "$ref": "#/components/schemas/JobListing"
            }
          },
          "maxErgebnisse": {
            "type": "string",
            "description": "Maximum number of results available"
          },
          "page": {
            "type": "string",
            "description": "Current page number"
          },
          "size": {
            "type": "string",
            "description": "Number of results per page"
          },
          "facetten": {
            "type": "array",
            "description": "Filter facets with counts",
            "items": {
              "$ref": "#/components/schemas/Facet"
            }
          }
        }
      },
      "JobListing": {
        "type": "object",
        "properties": {
          "hashId": {
            "type": "string",
            "description": "Unique hash identifier for the job"
          },
          "beruf": {
            "type": "string",
            "description": "Job profession/title"
          },
          "refnr": {
            "type": "string",
            "description": "Reference number"
          },
          "arbeitgeber": {
            "type": "string",
            "description": "Employer name"
          },
          "titel": {
            "type": "string",
            "description": "Job title"
          },
          "aktuelleVeroeffentlichungsdatum": {
            "type": "string",
            "format": "date-time",
            "description": "Current publication date"
          },
          "eintrittsdatum": {
            "type": "string",
            "format": "date",
            "description": "Start date"
          },
          "arbeitsort": {
            "$ref": "#/components/schemas/WorkLocation"
          },
          "modifikationsTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Last modification timestamp"
          }
        }
      },
      "WorkLocation": {
        "type": "object",
        "properties": {
          "plz": {
            "type": "string",
            "description": "Postal code"
          },
          "ort": {
            "type": "string",
            "description": "City"
          },
          "strasse": {
            "type": "string",
            "description": "Street address"
          },
          "region": {
            "type": "string",
            "description": "Region/state"
          },
          "land": {
            "type": "string",
            "description": "Country"
          },
          "koordinaten": {
            "$ref": "#/components/schemas/Coordinates"
          }
        }
      },
      "Coordinates": {
        "type": "object",
        "properties": {
          "lat": {
            "type": "number",
            "format": "double",
            "description": "Latitude"
          },
          "lon": {
            "type": "number",
            "format": "double",
            "description": "Longitude"
          }
        }
      },
      "Facet": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Facet name (e.g., befristung, arbeitszeit, branche)"
          },
          "counts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string"
                },
                "count": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}
