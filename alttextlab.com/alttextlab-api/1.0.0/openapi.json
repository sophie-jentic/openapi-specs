{
  "openapi": "3.0.3",
  "info": {
    "title": "AltTextLab API",
    "version": "1.0.0",
    "description": "AI-powered alternative text generation API for images, supporting 130+ languages and e-commerce mode.",
    "x-jentic-source-url": "https://www.alttextlab.com/docs/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://app.alttextlab.com/api/v1"
    }
  ],
  "paths": {
    "/alt-text/generate": {
      "post": {
        "operationId": "generateAltText",
        "summary": "Generate alt text for image",
        "description": "Generates AI-powered alternative text for images, customizable by language, writing style, and optional product information.",
        "tags": [
          "Alt Text"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateAltTextRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AltTextResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GenerateAltTextRequest": {
        "type": "object",
        "properties": {
          "imageUrl": {
            "type": "string",
            "description": "Public URL of the image to process"
          },
          "lang": {
            "type": "string",
            "description": "Language code (e.g. en, pl, de)"
          },
          "style": {
            "type": "string",
            "enum": [
              "descriptive",
              "neutral",
              "matter-of-fact",
              "minimal"
            ]
          },
          "ecommerce": {
            "type": "object",
            "properties": {
              "productName": {
                "type": "string"
              },
              "brand": {
                "type": "string"
              },
              "color": {
                "type": "string"
              },
              "material": {
                "type": "string"
              }
            }
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "imageUrl"
        ]
      },
      "AltTextResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "lang": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "result": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "generated",
              "failed"
            ]
          },
          "style": {
            "type": "string"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Alt Text"
    }
  ]
}
