{
  "openapi": "3.0.0",
  "info": {
    "title": "SheetDB API",
    "version": "1.0.0",
    "description": "Turn Google Spreadsheets into JSON REST APIs with full CRUD operations (formerly Sheetsu, now SheetDB)",
    "contact": {
      "name": "SheetDB Support",
      "url": "https://sheetdb.io"
    }
  },
  "servers": [
    {
      "url": "https://sheetdb.io/api/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/{api_id}": {
      "get": {
        "summary": "Get spreadsheet content",
        "description": "Returns an array with all data from the spreadsheet",
        "operationId": "getContent",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "description": "Unique API ID for your spreadsheet",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sheet",
            "in": "query",
            "description": "Specific sheet/tab name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of rows to return",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of rows to skip",
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "description": "Column name to sort by",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort_order",
            "in": "query",
            "description": "Sort order",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc",
                "random"
              ]
            }
          },
          {
            "name": "sort_method",
            "in": "query",
            "description": "Sort method type",
            "schema": {
              "type": "string",
              "enum": [
                "date"
              ]
            }
          },
          {
            "name": "sort_date_format",
            "in": "query",
            "description": "Date format for date sorting (e.g., Y-m-d)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cast_numbers",
            "in": "query",
            "description": "Comma-separated list of columns to cast to numbers",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "single_object",
            "in": "query",
            "description": "Return single row as object instead of array",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "description": "Value Render Option setting",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "API ID not found"
          }
        },
        "tags": [
          "default"
        ]
      },
      "post": {
        "summary": "Create new rows",
        "description": "Appends new rows to the spreadsheet",
        "operationId": "createRows",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "description": "Unique API ID for your spreadsheet",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sheet",
            "in": "query",
            "description": "Specific sheet/tab name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "return_values",
            "in": "query",
            "description": "Return the newly created rows in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "description": "Value Input Option setting",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "type": "array",
                    "description": "Array of row objects to append",
                    "items": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Rows created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "created": {
                      "type": "integer",
                      "description": "Number of rows created"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        },
        "tags": [
          "default"
        ]
      }
    },
    "/{api_id}/keys": {
      "get": {
        "summary": "Get column headers",
        "description": "Returns all column headers from the first row",
        "operationId": "getKeys",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Column headers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "keys"
        ]
      }
    },
    "/{api_id}/name": {
      "get": {
        "summary": "Get spreadsheet name",
        "description": "Returns the spreadsheet title",
        "operationId": "getName",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Spreadsheet name",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "name"
        ]
      }
    },
    "/{api_id}/count": {
      "get": {
        "summary": "Get row count",
        "description": "Returns the total number of rows",
        "operationId": "getCount",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Row count",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rows": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "count"
        ]
      }
    },
    "/{api_id}/search": {
      "get": {
        "summary": "Search rows (AND)",
        "description": "Returns rows matching ALL specified conditions",
        "operationId": "searchRows",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "casesensitive",
            "in": "query",
            "description": "Enable case-sensitive matching",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "search"
        ]
      }
    },
    "/{api_id}/search_or": {
      "get": {
        "summary": "Search rows (OR)",
        "description": "Returns rows matching ANY specified condition",
        "operationId": "searchRowsOr",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "casesensitive",
            "in": "query",
            "description": "Enable case-sensitive matching",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "search_or"
        ]
      }
    },
    "/{api_id}/{column_name}/{value}": {
      "patch": {
        "summary": "Update rows",
        "description": "Updates rows matching the specified column and value",
        "operationId": "updateRows",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "column_name",
            "in": "path",
            "required": true,
            "description": "Column name to match",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "value",
            "in": "path",
            "required": true,
            "description": "Value to match in the column",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sheet",
            "in": "query",
            "description": "Specific sheet/tab name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "description": "Value Input Option setting",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "type": "object",
                    "description": "Fields to update",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rows updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "updated": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "default"
        ]
      },
      "delete": {
        "summary": "Delete rows",
        "description": "Deletes rows matching the specified column and value",
        "operationId": "deleteRows",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "column_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "value",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sheet",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Rows deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deleted": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "default"
        ]
      }
    },
    "/{api_id}/batch_update": {
      "patch": {
        "summary": "Batch update rows",
        "description": "Updates multiple rows in a single request (paid accounts only)",
        "operationId": "batchUpdateRows",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sheet",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "type": "array",
                    "description": "Array of update objects with query and update fields",
                    "items": {
                      "type": "object",
                      "properties": {
                        "query": {
                          "type": "string"
                        }
                      },
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rows updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "updated": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "batch_update"
        ]
      }
    },
    "/{api_id}/duplicates": {
      "delete": {
        "summary": "Delete duplicates",
        "description": "Removes all duplicate rows",
        "operationId": "deleteDuplicates",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sheet",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Duplicates deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "duplicates": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "duplicates"
        ]
      }
    },
    "/{api_id}/all": {
      "delete": {
        "summary": "Clear all content",
        "description": "Removes all data rows (preserves headers by default)",
        "operationId": "clearAll",
        "parameters": [
          {
            "name": "api_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "with_first_row",
            "in": "query",
            "description": "Also delete column headers",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "sheet",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Content cleared",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deleted": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "all"
        ]
      }
    }
  },
  "tags": [
    {
      "name": "all"
    },
    {
      "name": "batch_update"
    },
    {
      "name": "count"
    },
    {
      "name": "default"
    },
    {
      "name": "duplicates"
    },
    {
      "name": "keys"
    },
    {
      "name": "name"
    },
    {
      "name": "search"
    },
    {
      "name": "search_or"
    }
  ]
}
