{
  "openapi": "3.0.3",
  "info": {
    "title": "Upstash Developer API",
    "description": "The Upstash Developer API allows you to create and manage Upstash products and resources programmatically. You can automate everything you can do in the console. Authentication uses HTTP Basic Auth with your email and API key.",
    "version": "1.0.0",
    "contact": {
      "name": "Support Team",
      "email": "support@upstash.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://developer.upstash.com/"
  },
  "servers": [
    {
      "url": "https://api.upstash.com/v2"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "redis",
      "description": "Manage Redis databases"
    },
    {
      "name": "teams",
      "description": "Manage teams and team members"
    },
    {
      "name": "vector",
      "description": "Manage vector indices"
    },
    {
      "name": "search",
      "description": "Manage search indices"
    },
    {
      "name": "qstash",
      "description": "Manage QStash"
    }
  ],
  "paths": {
    "/redis/databases": {
      "get": {
        "operationId": "listDatabases",
        "tags": [
          "redis"
        ],
        "summary": "List Databases",
        "description": "This endpoint lists all Redis databases of the user.",
        "responses": {
          "200": {
            "description": "List of databases",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Database"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials"
          }
        }
      },
      "post": {
        "operationId": "createDatabase",
        "tags": [
          "redis"
        ],
        "summary": "Create Database",
        "description": "This endpoint creates a new Redis database.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDatabaseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created database",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Database"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/redis/database/{id}": {
      "get": {
        "operationId": "getDatabase",
        "tags": [
          "redis"
        ],
        "summary": "Get Database",
        "description": "This endpoint gets details of a specific Redis database.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Database ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Database details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Database"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Database not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteDatabase",
        "tags": [
          "redis"
        ],
        "summary": "Delete Database",
        "description": "This endpoint deletes a Redis database.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the database to be deleted"
          }
        ],
        "responses": {
          "200": {
            "description": "Database deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Database not found"
          }
        }
      }
    },
    "/redis/database/{id}/reset-password": {
      "post": {
        "operationId": "resetDatabasePassword",
        "tags": [
          "redis"
        ],
        "summary": "Reset Database Password",
        "description": "This endpoint resets the password for a Redis database.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Password reset"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/vector/namespaces": {
      "get": {
        "operationId": "listVectorNamespaces",
        "tags": [
          "vector"
        ],
        "summary": "List Vector Namespaces",
        "description": "Lists all vector indices/namespaces for the user.",
        "responses": {
          "200": {
            "description": "List of vector namespaces",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/VectorNamespace"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createVectorNamespace",
        "tags": [
          "vector"
        ],
        "summary": "Create Vector Namespace",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateVectorNamespaceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Namespace created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VectorNamespace"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create Vector Namespace"
      }
    },
    "/teams": {
      "get": {
        "operationId": "listTeams",
        "tags": [
          "teams"
        ],
        "summary": "List Teams",
        "description": "Lists all teams for the user.",
        "responses": {
          "200": {
            "description": "List of teams",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Team"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createTeam",
        "tags": [
          "teams"
        ],
        "summary": "Create Team",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTeamRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Team created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Team"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create Team"
      }
    },
    "/teams/{teamId}/member": {
      "post": {
        "operationId": "addTeamMember",
        "tags": [
          "teams"
        ],
        "summary": "Add Team Member",
        "parameters": [
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddTeamMemberRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Member added"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Add Team Member"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use your Upstash email and API key as credentials (email:api_key)"
      }
    },
    "schemas": {
      "Database": {
        "type": "object",
        "properties": {
          "database_id": {
            "type": "string",
            "description": "ID of the database"
          },
          "database_name": {
            "type": "string",
            "description": "Name of the database"
          },
          "region": {
            "type": "string",
            "description": "Region where database is hosted"
          },
          "port": {
            "type": "integer",
            "format": "int64",
            "description": "Database port for clients to connect"
          },
          "creation_time": {
            "type": "integer",
            "format": "int64",
            "description": "Creation time as Unix timestamp"
          },
          "state": {
            "type": "string",
            "enum": [
              "active",
              "suspended",
              "passive"
            ],
            "description": "State of the database"
          },
          "endpoint": {
            "type": "string",
            "description": "Endpoint hostname of the database"
          },
          "tls": {
            "type": "boolean",
            "description": "TLS/SSL enabled"
          },
          "type": {
            "type": "string",
            "enum": [
              "free",
              "payg",
              "pro",
              "paid"
            ],
            "description": "Payment plan of the database"
          },
          "primary_region": {
            "type": "string",
            "description": "Primary region of the database cluster"
          },
          "read_regions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of read regions"
          },
          "eviction": {
            "type": "boolean",
            "description": "Entry eviction is enabled"
          },
          "consistent": {
            "type": "boolean",
            "description": "Strong consistency mode is enabled"
          },
          "customer_id": {
            "type": "string",
            "description": "Owner identifier"
          },
          "daily_backup_enabled": {
            "type": "boolean"
          },
          "replicas": {
            "type": "integer",
            "description": "Replica factor"
          },
          "db_max_clients": {
            "type": "integer",
            "format": "int64"
          },
          "db_memory_threshold": {
            "type": "integer",
            "format": "int64"
          },
          "db_max_commands_per_second": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "CreateDatabaseRequest": {
        "type": "object",
        "required": [
          "name",
          "region"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name for the database"
          },
          "region": {
            "type": "string",
            "description": "Region to create the database in"
          },
          "tls": {
            "type": "boolean",
            "description": "Enable TLS/SSL"
          },
          "eviction": {
            "type": "boolean"
          },
          "consistent": {
            "type": "boolean"
          }
        }
      },
      "VectorNamespace": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "dimensions": {
            "type": "integer"
          },
          "similarity_function": {
            "type": "string"
          }
        }
      },
      "CreateVectorNamespaceRequest": {
        "type": "object",
        "required": [
          "name",
          "region",
          "dimensions"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "dimensions": {
            "type": "integer"
          },
          "similarity_function": {
            "type": "string",
            "enum": [
              "COSINE",
              "EUCLIDEAN",
              "DOT_PRODUCT"
            ]
          }
        }
      },
      "Team": {
        "type": "object",
        "properties": {
          "team_id": {
            "type": "string"
          },
          "team_name": {
            "type": "string"
          },
          "copy_cc": {
            "type": "boolean"
          }
        }
      },
      "CreateTeamRequest": {
        "type": "object",
        "required": [
          "team_name"
        ],
        "properties": {
          "team_name": {
            "type": "string"
          },
          "copy_cc": {
            "type": "boolean"
          }
        }
      },
      "AddTeamMemberRequest": {
        "type": "object",
        "required": [
          "member_email",
          "member_role"
        ],
        "properties": {
          "member_email": {
            "type": "string",
            "format": "email"
          },
          "member_role": {
            "type": "string",
            "enum": [
              "owner",
              "member"
            ]
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
