{
  "openapi": "3.0.3",
  "info": {
    "title": "Buzzsprout API",
    "version": "1.0.0",
    "description": "The Buzzsprout API allows you to manage podcasts and episodes on the Buzzsprout podcast hosting platform. Authentication uses an API token passed as a query parameter.",
    "x-jentic-source-url": "https://github.com/Buzzsprout/buzzsprout-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.buzzsprout.com/api",
      "description": "Buzzsprout API"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    {
      "name": "Podcasts",
      "description": "Manage podcasts"
    },
    {
      "name": "Episodes",
      "description": "Manage podcast episodes"
    }
  ],
  "paths": {
    "/{podcast_id}.json": {
      "get": {
        "operationId": "getPodcast",
        "tags": [
          "Podcasts"
        ],
        "summary": "Retrieve podcast details",
        "parameters": [
          {
            "name": "podcast_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Podcast ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Podcast details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Podcast"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Retrieve podcast details"
      }
    },
    "/{podcast_id}/episodes.json": {
      "get": {
        "operationId": "listEpisodes",
        "tags": [
          "Episodes"
        ],
        "summary": "List all episodes for a podcast",
        "parameters": [
          {
            "name": "podcast_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of episodes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Episode"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List all episodes for a podcast"
      },
      "post": {
        "operationId": "createEpisode",
        "tags": [
          "Episodes"
        ],
        "summary": "Create a new episode",
        "parameters": [
          {
            "name": "podcast_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEpisodeRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Episode created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Episode"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create a new episode"
      }
    },
    "/{podcast_id}/episodes/{id}.json": {
      "get": {
        "operationId": "getEpisode",
        "tags": [
          "Episodes"
        ],
        "summary": "Get a specific episode",
        "parameters": [
          {
            "name": "podcast_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Episode ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Episode details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Episode"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get a specific episode"
      },
      "put": {
        "operationId": "updateEpisode",
        "tags": [
          "Episodes"
        ],
        "summary": "Update an episode",
        "parameters": [
          {
            "name": "podcast_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateEpisodeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Episode updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Episode"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Update an episode"
      },
      "delete": {
        "operationId": "deleteEpisode",
        "tags": [
          "Episodes"
        ],
        "summary": "Delete an episode",
        "parameters": [
          {
            "name": "podcast_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Episode deleted"
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete an episode"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_token",
        "description": "Buzzsprout API token"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "Podcast": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "background_image": {
            "type": "string"
          },
          "artwork_url": {
            "type": "string"
          },
          "main_category": {
            "type": "string"
          },
          "explicit": {
            "type": "boolean"
          },
          "language": {
            "type": "string"
          },
          "website": {
            "type": "string"
          },
          "contact_email": {
            "type": "string"
          },
          "itunes_url": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Episode": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "audio_url": {
            "type": "string"
          },
          "artwork_url": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string"
          },
          "summary": {
            "type": "string",
            "nullable": true
          },
          "artist": {
            "type": "string"
          },
          "tags": {
            "type": "string",
            "nullable": true
          },
          "published_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "duration": {
            "type": "integer",
            "description": "Duration in seconds"
          },
          "hq": {
            "type": "boolean",
            "description": "High quality audio"
          },
          "magic_mastering": {
            "type": "boolean"
          },
          "guid": {
            "type": "string"
          },
          "inactive_at": {
            "type": "string",
            "nullable": true
          },
          "episode_number": {
            "type": "integer",
            "nullable": true
          },
          "season_number": {
            "type": "integer",
            "nullable": true
          },
          "episode_type": {
            "type": "string",
            "description": "full, trailer, or bonus"
          },
          "explicit": {
            "type": "boolean"
          },
          "private": {
            "type": "boolean"
          },
          "total_plays": {
            "type": "integer"
          }
        }
      },
      "CreateEpisodeRequest": {
        "type": "object",
        "required": [
          "title",
          "audio_url"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "artist": {
            "type": "string"
          },
          "tags": {
            "type": "string"
          },
          "published_at": {
            "type": "string",
            "format": "date-time"
          },
          "duration": {
            "type": "integer"
          },
          "hq": {
            "type": "boolean"
          },
          "magic_mastering": {
            "type": "boolean"
          },
          "episode_number": {
            "type": "integer"
          },
          "season_number": {
            "type": "integer"
          },
          "episode_type": {
            "type": "string",
            "enum": [
              "full",
              "trailer",
              "bonus"
            ]
          },
          "explicit": {
            "type": "boolean"
          },
          "private": {
            "type": "boolean"
          },
          "audio_url": {
            "type": "string",
            "description": "URL to the audio file"
          },
          "artwork_url": {
            "type": "string"
          }
        }
      },
      "UpdateEpisodeRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "artist": {
            "type": "string"
          },
          "tags": {
            "type": "string"
          },
          "published_at": {
            "type": "string",
            "format": "date-time"
          },
          "episode_number": {
            "type": "integer"
          },
          "season_number": {
            "type": "integer"
          },
          "episode_type": {
            "type": "string",
            "enum": [
              "full",
              "trailer",
              "bonus"
            ]
          },
          "explicit": {
            "type": "boolean"
          },
          "private": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
