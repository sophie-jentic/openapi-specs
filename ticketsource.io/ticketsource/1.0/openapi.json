{
  "openapi": "3.0.3",
  "info": {
    "title": "TicketSource Zapier API",
    "version": "1.0",
    "description": "The TicketSource Zapier integration API for managing customers, events, and bookings",
    "contact": {
      "name": "TicketSource",
      "url": "https://www.ticketsource.co.uk/help",
      "email": "support@ticketsource.co.uk"
    },
    "x-jentic-source-url": "https://zapier-openapi.ticketsource.io/"
  },
  "servers": [
    {
      "url": "https://www.ticketsource.co.uk/services/zapier",
      "description": "Zapier Service"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/customers": {
      "post": {
        "summary": "Get Customers",
        "operationId": "customers",
        "description": "Retrieve a paginated list of Customers",
        "parameters": [
          {
            "name": "Page",
            "in": "header",
            "required": true,
            "description": "The page of results requested",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "Service-Endpoint",
            "in": "header",
            "required": true,
            "description": "Must be 'Customers'",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Customer"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "customers"
        ]
      }
    },
    "/events": {
      "post": {
        "summary": "Get Events",
        "operationId": "events",
        "description": "Retrieve a paginated list of Events",
        "parameters": [
          {
            "name": "Page",
            "in": "header",
            "required": true,
            "description": "The page of results requested",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "Service-Endpoint",
            "in": "header",
            "required": true,
            "description": "Must be 'Events'",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Event"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "events"
        ]
      }
    },
    "/bookings": {
      "post": {
        "summary": "Get Bookings",
        "operationId": "bookings",
        "description": "Retrieve a paginated list of Bookings",
        "parameters": [
          {
            "name": "Page",
            "in": "header",
            "required": true,
            "description": "The page of results requested",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "Service-Endpoint",
            "in": "header",
            "required": true,
            "description": "Must be 'Bookings'",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Booking"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "bookings"
        ]
      }
    },
    "/find-customer": {
      "post": {
        "summary": "Find Customer",
        "operationId": "find-customers",
        "description": "Search for customer records matching input parameters",
        "parameters": [
          {
            "name": "Service-Endpoint",
            "in": "header",
            "required": true,
            "description": "Must be 'Find-Customer'",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerName": {
                    "type": "string"
                  },
                  "customerPostcode": {
                    "type": "string"
                  },
                  "customerEmailAddress": {
                    "type": "string",
                    "format": "email"
                  },
                  "customerPhoneNumber": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Customer"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "find-customer"
        ]
      }
    },
    "/find-event": {
      "post": {
        "summary": "Find Event",
        "operationId": "find-events",
        "description": "Search for events matching input parameters",
        "parameters": [
          {
            "name": "Service-Endpoint",
            "in": "header",
            "description": "Must be 'Find-Event'",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "event_name": {
                    "type": "string"
                  },
                  "venue_name": {
                    "type": "string"
                  },
                  "event_dateTime": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Event"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "find-event"
        ]
      }
    },
    "/new-customer": {
      "post": {
        "summary": "Create Customer",
        "operationId": "new-customer",
        "description": "Add a new Customer",
        "parameters": [
          {
            "name": "Service-Endpoint",
            "in": "header",
            "required": true,
            "description": "Must be 'New-Customer'",
            "schema": {
              "type": "string",
              "enum": [
                "New-Customer"
              ]
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "contactSurname": {
                    "type": "string"
                  },
                  "contactFirstName": {
                    "type": "string"
                  },
                  "contactTitle": {
                    "type": "string"
                  },
                  "contactAdd1": {
                    "type": "string"
                  },
                  "contactAdd2": {
                    "type": "string"
                  },
                  "contactAdd3": {
                    "type": "string"
                  },
                  "contactAdd4": {
                    "type": "string"
                  },
                  "contactTellNo": {
                    "type": "string"
                  },
                  "contactPostcode": {
                    "type": "string"
                  },
                  "contactEmail": {
                    "type": "string"
                  },
                  "contactMembershipNo": {
                    "type": "string"
                  },
                  "contactMembershipNoStartDate": {
                    "type": "string"
                  },
                  "contactMembershipNoEndDate": {
                    "type": "string"
                  },
                  "promoterConsentEmail": {
                    "type": "string"
                  },
                  "promoterConsentPost": {
                    "type": "string"
                  },
                  "promoterConsentSMS": {
                    "type": "string"
                  },
                  "patronNoteDesc": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "Customer added successfully"
                      ]
                    },
                    "customer": {
                      "type": "object",
                      "properties": {
                        "customer_id": {
                          "type": "string"
                        },
                        "created_at": {
                          "type": "string",
                          "format": "date-time"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "new-customer"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://www.ticketsource.co.uk/oauth/authorize",
            "tokenUrl": "https://www.ticketsource.co.uk/oauth/token",
            "scopes": {}
          }
        }
      }
    },
