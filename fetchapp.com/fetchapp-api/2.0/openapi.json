    "/orders/{order_id}/send_email": {
      "post": {
        "operationId": "sendOrderEmail",
        "tags": [
          "Orders"
        ],
        "summary": "Send download email for an order",
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Email sent"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Send download email for an order"
