          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List downloads for an order"
      }
    },
    "/orders/{order_id}/expire": {
      "post": {
        "operationId": "expireOrder",
        "tags": [
          "Orders"
        ],
        "summary": "Expire an order immediately",
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order expired"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Expire an order immediately"
