        "responses": {
          "200": {
            "description": "Downloads list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Download"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all downloads"
      }
    }
  },
  "tags": [
    {
      "name": "Account"
    },
    {
      "name": "Downloads"
    },
    {
      "name": "Orders"
    },
    {
      "name": "Products"
    }
  ]
}
