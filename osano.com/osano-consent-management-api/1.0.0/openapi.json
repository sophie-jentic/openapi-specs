    "/analytics/consent": {
      "get": {
        "operationId": "getConsentAnalytics",
        "summary": "Get consent analytics",
        "tags": [
          "Analytics"
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
