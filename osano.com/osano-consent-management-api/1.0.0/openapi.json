{
  "openapi": "3.0.3",
  "info": {
    "title": "Osano Consent Management API",
    "version": "1.0.0",
    "description": "Osano consent management platform API for managing user consent, privacy policies, data subject requests, and cookie consent across web properties.",
    "x-jentic-source-url": "https://developers.osano.com/uc/core-api/openapi",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.osano.com/v1"
    }
  ],
  "paths": {
