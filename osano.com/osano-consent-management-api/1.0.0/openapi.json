  "components": {
    "schemas": {
      "ConsentRecord": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "subjectId": {
            "type": "string"
          },
          "purposes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "purposeId": {
                  "type": "string"
                },
                "allowed": {
                  "type": "boolean"
                }
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "source": {
            "type": "string"
          }
        }
      },
      "DSRRequest": {
        "type": "object",
        "required": [
          "email",
          "type"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "type": {
            "type": "string",
            "enum": [
              "access",
              "deletion",
              "portability",
              "rectification"
            ]
          },
          "description": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Osano API key"
      }
    }
  },
