{
  "openapi": "3.0.3",
  "info": {
    "title": "GoFile API",
    "description": "GoFile is a free file sharing and storage platform. The GoFile API allows programmatic access to upload files, manage content (folders, files), create direct links, search content, and manage accounts.",
    "version": "1.0.0",
    "contact": {
      "name": "GoFile",
      "url": "https://gofile.io"
    }
  },
  "servers": [
    {
      "url": "https://api.gofile.io",
      "description": "GoFile API server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/accounts": {
      "post": {
        "summary": "Create account",
        "description": "Create a new guest account or send a login link to an existing account email.",
        "operationId": "createAccount",
        "security": [],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email address. If provided, sends a login link. If omitted, creates a guest account."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account created or login link sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountCreateResponse"
                }
              }
            }
          }
        },
        "tags": [
          "accounts"
        ]
      }
    },
    "/accounts/website": {
      "get": {
        "summary": "Get account info",
        "description": "Retrieve the account information for the authenticated user.",
        "operationId": "getAccount",
        "responses": {
          "200": {
            "description": "Account information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid token"
          }
        },
        "tags": [
          "accounts"
        ]
      }
    },
    "/servers": {
      "get": {
        "summary": "Get available servers",
        "description": "Retrieve a list of available servers for uploading files.",
        "operationId": "getServers",
        "security": [],
        "responses": {
          "200": {
            "description": "List of available upload servers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServersResponse"
                }
              }
            }
          }
        },
        "tags": [
          "servers"
        ]
      }
    },
    "/contents/{contentId}": {
      "get": {
        "summary": "Get content details",
        "description": "Retrieve details of a content item (file or folder) including its children.",
        "operationId": "getContent",
        "parameters": [
          {
            "name": "contentId",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the content",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "contentFilter",
            "in": "query",
            "description": "Filter content by type",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of items per page",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "sortField",
            "in": "query",
            "description": "Field to sort by (e.g., name, createTime)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortDirection",
            "in": "query",
            "description": "Sort direction (1 for ascending, -1 for descending)",
            "schema": {
              "type": "integer",
              "enum": [
                1,
                -1
              ]
            }
          },
          {
            "name": "password",
            "in": "query",
            "description": "Password for password-protected content",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Content details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentResponse"
                }
              }
            }
          },
          "404": {
            "description": "Content not found"
          }
        },
        "tags": [
          "contents"
        ]
      }
    },
    "/contents/{contentId}/update": {
      "put": {
        "summary": "Update content",
        "description": "Update content attributes such as name, description, public status, password, expiry, or tags.",
        "operationId": "updateContent",
        "parameters": [
          {
            "name": "contentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "attribute",
                  "attributeValue"
                ],
                "properties": {
                  "attribute": {
                    "type": "string",
                    "description": "The attribute to update (e.g., name, description, public, password, expiry, tags)"
                  },
                  "attributeValue": {
                    "type": "string",
                    "description": "The new value for the attribute"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Content updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        },
        "tags": [
          "contents"
        ]
      }
    },
    "/contents": {
      "delete": {
        "summary": "Delete contents",
        "description": "Delete one or more content items (files or folders).",
        "operationId": "deleteContents",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "contentsId"
                ],
                "properties": {
                  "contentsId": {
                    "type": "string",
                    "description": "Comma-separated list of content IDs to delete"
                  },
                  "proof": {
                    "type": "string",
                    "description": "Proof token for deletion verification"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contents deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        },
        "tags": [
          "contents"
        ]
      }
    },
    "/contents/createfolder": {
      "post": {
        "summary": "Create folder",
        "description": "Create a new folder within a parent folder.",
        "operationId": "createFolder",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "parentFolderId"
                ],
                "properties": {
                  "parentFolderId": {
                    "type": "string",
                    "description": "ID of the parent folder"
                  },
                  "folderName": {
                    "type": "string",
                    "description": "Name of the new folder"
                  },
                  "public": {
                    "type": "boolean",
                    "description": "Whether the folder should be publicly accessible"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Folder created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateFolderResponse"
                }
              }
            }
          }
        },
        "tags": [
          "contents"
        ]
      }
    },
    "/contents/search": {
      "get": {
        "summary": "Search contents",
        "description": "Search for files and folders by name within a specified content scope.",
        "operationId": "searchContents",
        "parameters": [
          {
            "name": "contentId",
            "in": "query",
            "required": true,
            "description": "ID of the content scope to search within",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchedString",
            "in": "query",
            "required": true,
            "description": "The search string",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "createTimeFrom",
            "in": "query",
            "description": "Filter by creation time (from timestamp)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "createTimeTo",
            "in": "query",
            "description": "Filter by creation time (to timestamp)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentResponse"
                }
              }
            }
          }
        },
        "tags": [
          "contents"
        ]
      }
    },
    "/contents/{contentId}/directlinks": {
      "get": {
        "summary": "List direct links",
        "description": "Retrieve direct links for a content item.",
        "operationId": "getDirectLinks",
        "parameters": [
          {
            "name": "contentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of direct links",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DirectLinksResponse"
                }
              }
            }
          }
        },
        "tags": [
          "contents"
        ]
      },
      "post": {
        "summary": "Create direct link",
        "description": "Create a new direct link for a content item, optionally with zip support for bulk downloads.",
        "operationId": "createDirectLink",
        "parameters": [
          {
            "name": "contentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "contentIdsToZip": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Content IDs to include in a zip download"
                  },
                  "expireTime": {
                    "type": "integer",
                    "description": "Expiration time as Unix timestamp"
                  },
                  "isReqLink": {
                    "type": "boolean"
                  },
                  "password": {
                    "type": "string",
                    "description": "Optional password protection for the link"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Direct link created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DirectLinkResponse"
                }
              }
            }
          }
        },
        "tags": [
          "contents"
        ]
      }
    },
    "/contents/{contentId}/directlinks/{directLinkId}": {
      "put": {
        "summary": "Update direct link",
        "description": "Update settings for an existing direct link.",
        "operationId": "updateDirectLink",
        "parameters": [
          {
            "name": "contentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "directLinkId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "expireTime": {
                    "type": "integer",
                    "description": "Expiration time as Unix timestamp"
                  },
                  "sourceIpsAllowed": {
                    "type": "string",
                    "description": "Comma-separated list of allowed source IPs"
                  },
                  "domainsAllowed": {
                    "type": "string",
                    "description": "Comma-separated list of allowed domains"
                  },
                  "domainsBlocked": {
                    "type": "string",
                    "description": "Comma-separated list of blocked domains"
                  },
                  "auth": {
                    "type": "string",
                    "description": "Authentication requirement for the link"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Direct link updated"
          }
        },
        "tags": [
          "contents"
        ]
      },
      "delete": {
        "summary": "Delete direct link",
        "description": "Delete an existing direct link.",
        "operationId": "deleteDirectLink",
        "parameters": [
          {
            "name": "contentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "directLinkId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Direct link deleted"
          }
        },
        "tags": [
          "contents"
        ]
      }
    },
    "/uploadfile": {
      "post": {
        "summary": "Upload a file",
        "description": "Upload a file to GoFile. Use the /servers endpoint first to get an available upload server, then upload to https://{server}.gofile.io/uploadfile.",
        "operationId": "uploadFile",
        "servers": [
          {
            "url": "https://{server}.gofile.io",
            "description": "Upload server (get server name from /servers endpoint)",
            "variables": {
              "server": {
                "default": "upload",
                "description": "Server name returned from the /servers endpoint"
              }
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The file to upload"
                  },
                  "token": {
                    "type": "string",
                    "description": "Account token for authenticated uploads"
                  },
                  "folderId": {
                    "type": "string",
                    "description": "Destination folder ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          }
        },
        "tags": [
          "uploadfile"
        ]
      }
    },
    "/getCountries": {
      "get": {
        "summary": "Get countries list",
        "description": "Retrieve a list of all supported countries.",
        "operationId": "getCountries",
        "security": [],
        "responses": {
          "200": {
            "description": "List of countries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountriesResponse"
                }
              }
            }
          }
        },
        "tags": [
          "getCountries"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Account token obtained from creating an account"
      }
    },
    "schemas": {
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Response status (ok or error)"
          }
        }
      },
      "AccountCreateResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "token": {
                "type": "string",
                "description": "Account token for authentication"
              }
            }
          }
        }
      },
      "AccountResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "tier": {
                "type": "string"
              },
              "token": {
                "type": "string"
              },
              "rootFolder": {
                "type": "string"
              },
              "totalSize": {
                "type": "integer"
              },
              "totalDownloadCount": {
                "type": "integer"
              }
            }
          }
        }
      },
      "ServersResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "servers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Server hostname"
                    },
                    "zone": {
                      "type": "string",
                      "description": "Server geographic zone"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ContentResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "description": "Content type (folder or file)"
              },
              "name": {
                "type": "string"
              },
              "parentFolder": {
                "type": "string"
              },
              "createTime": {
                "type": "integer"
              },
              "public": {
                "type": "boolean"
              },
              "totalSize": {
                "type": "integer"
              },
              "totalDownloadCount": {
                "type": "integer"
              },
              "children": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "size": {
                      "type": "integer"
                    },
                    "createTime": {
                      "type": "integer"
                    },
                    "link": {
                      "type": "string"
                    },
                    "mimetype": {
                      "type": "string"
                    },
                    "md5": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "CreateFolderResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "parentFolder": {
                "type": "string"
              },
              "createTime": {
                "type": "integer"
              },
              "type": {
                "type": "string"
              }
            }
          }
        }
      },
      "UploadResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "downloadPage": {
                "type": "string",
                "description": "URL to the download page"
              },
              "code": {
                "type": "string",
                "description": "File code"
              },
              "parentFolder": {
                "type": "string"
              },
              "fileId": {
                "type": "string"
              },
              "fileName": {
                "type": "string"
              },
              "md5": {
                "type": "string"
              }
            }
          }
        }
      },
      "DirectLinksResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DirectLink"
            }
          }
        }
      },
      "DirectLinkResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/DirectLink"
          }
        }
      },
      "DirectLink": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "expireTime": {
            "type": "integer"
          },
          "sourceIpsAllowed": {
            "type": "string"
          },
          "domainsAllowed": {
            "type": "string"
          },
          "domainsBlocked": {
            "type": "string"
          },
          "auth": {
            "type": "string"
          }
        }
      },
      "CountriesResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "accounts"
    },
    {
      "name": "contents"
    },
    {
      "name": "getCountries"
    },
    {
      "name": "servers"
    },
    {
      "name": "uploadfile"
    }
  ]
}
