                }
              }
            }
          }
        },
        "tags": [
          "Account Information"
        ]
      }
    },
    "/meta/lists": {
      "get": {
        "operationId": "listListFields",
        "summary": "List list fields",
        "description": "Returns all list field options.",
        "responses": {
          "200": {
            "description": "List field options",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "fieldId": {
                        "type": "integer"
                      },
                      "alias": {
                        "type": "string"
                      },
                      "options": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "integer"
                            },
                            "name": {
                              "type": "string"
                            },
                            "archived": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Account Information"
        ]
      }
    },
    "/meta/tables": {
      "get": {
        "operationId": "listTabularFields",
        "summary": "List tabular fields",
        "description": "Returns all available tabular data fields.",
        "responses": {
          "200": {
            "description": "List of tabular fields",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "alias": {
                        "type": "string"
                      },
                      "fields": {
                        "type": "array",
                        "items": {
                          "type": "object"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Account Information"
        ]
      }
    },
    "/meta/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List users",
        "description": "Returns list of BambooHR user accounts.",
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer"
                      },
                      "employeeId": {
                        "type": "integer"
                      },
                      "firstName": {
                        "type": "string"
                      },
                      "lastName": {
                        "type": "string"
                      },
                      "email": {
                        "type": "string",
                        "format": "email"
                      },
                      "status": {
                        "type": "string"
                      },
                      "lastLogin": {
                        "type": "string",
                        "format": "date-time"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Account Information"
        ]
      }
    },
    "/employees/{id}/tables/{table}": {
      "get": {
        "operationId": "getEmployeeTableData",
        "summary": "Get employee table data",
        "description": "Returns tabular data for the employee (e.g., jobInfo, compensation).",
        "parameters": [
          {
            "$ref": "#/components/parameters/EmployeeId"
          },
          {
            "name": "table",
            "in": "path",
            "required": true,
            "description": "Table alias (e.g., jobInfo, compensation, emergencyContacts)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Table rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Tabular Data"
        ]
      },
      "post": {
        "operationId": "createTableRow",
        "summary": "Create table row",
        "description": "Adds a new row to the employee's tabular data.",
        "parameters": [
          {
            "$ref": "#/components/parameters/EmployeeId"
          },
          {
            "name": "table",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Row created"
          }
        },
        "tags": [
          "Tabular Data"
        ]
      }
    },
    "/employees/{id}/tables/{table}/{rowId}": {
      "post": {
        "operationId": "updateTableRow",
        "summary": "Update table row",
        "description": "Updates an existing row in employee tabular data.",
        "parameters": [
          {
            "$ref": "#/components/parameters/EmployeeId"
          },
          {
            "name": "table",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rowId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Row updated"
          }
        },
        "tags": [
          "Tabular Data"
        ]
      },
      "delete": {
        "operationId": "deleteTableRow",
        "summary": "Delete table row",
        "description": "Deletes a row from employee tabular data.",
        "parameters": [
          {
            "$ref": "#/components/parameters/EmployeeId"
          },
          {
            "name": "table",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rowId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Row deleted"
          }
        },
        "tags": [
          "Tabular Data"
        ]
      }
    },
    "/employees/{id}/time_off/request": {
      "put": {
        "operationId": "createTimeOffRequest",
        "summary": "Create time off request",
        "description": "Creates a time off request for the employee.",
        "parameters": [
          {
            "$ref": "#/components/parameters/EmployeeId"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status",
                  "start",
                  "end",
                  "timeOffTypeId"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "requested",
                      "approved",
                      "denied",
                      "canceled"
                    ]
                  },
                  "start": {
                    "type": "string",
                    "format": "date"
                  },
                  "end": {
                    "type": "string",
                    "format": "date"
                  },
                  "timeOffTypeId": {
                    "type": "integer"
                  },
                  "amount": {
                    "type": "number"
                  },
                  "notes": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "dates": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "number"
                    }
                  },
                  "previousRequest": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Time off request created"
          }
        },
        "tags": [
          "Time Off"
        ]
      }
    },
    "/time_off/requests": {
      "get": {
        "operationId": "listTimeOffRequests",
        "summary": "List time off requests",
        "description": "Returns time off requests within a date range.",
        "parameters": [
          {
            "name": "start",
            "in": "query",
            "required": true,
            "description": "Start date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "description": "End date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Time off type filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Status filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "employeeId",
            "in": "query",
            "description": "Filter by employee ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "action",
            "in": "query",
            "description": "Filter by action type",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of time off requests",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TimeOffRequest"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Time Off"
        ]
      }
    },
