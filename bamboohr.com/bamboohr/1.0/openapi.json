    "/reports/{reportId}": {
      "get": {
        "operationId": "getCompanyReport",
        "summary": "Get company report",
        "description": "Returns a company report by ID.",
        "parameters": [
          {
            "name": "reportId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Output format",
            "schema": {
              "type": "string",
              "enum": [
                "JSON",
                "CSV",
                "XML",
                "PDF"
              ],
              "default": "JSON"
            }
          },
          {
            "name": "fd",
            "in": "query",
            "description": "Set to yes to use field display names as keys",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Report data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "title": {
                      "type": "string"
                    },
                    "fields": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "employees": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Reports"
        ]
      }
    },
    "/reports/custom": {
      "post": {
        "operationId": "requestCustomReport",
        "summary": "Request custom report",
        "description": "Generates a custom report with specified fields and filters.",
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "description": "Output format",
            "schema": {
              "type": "string",
              "enum": [
                "JSON",
                "CSV",
                "XML",
                "PDF"
              ],
              "default": "JSON"
            }
          }
        ],
        "requestBody": {
          "required": true,
