{
  "openapi": "3.0.3",
  "info": {
    "title": "BambooHR API",
    "description": "BambooHR is a cloud-based HR software solution. The BambooHR API provides access to employee data, time off management, applicant tracking, reports, company files, goals, training, webhooks, and more. Uses HTTP Basic authentication with an API key as username and 'x' as password.",
    "version": "1.0",
    "contact": {
      "name": "BambooHR API Support",
      "url": "https://documentation.bamboohr.com/docs"
    },
    "x-categories": [
      "Human Resources"
    ],
    "x-logo": {
      "url": "https://www.bamboohr.com/favicon.ico"
    }
  },
  "servers": [
    {
      "url": "https://api.bamboohr.com/api/gateway.php/{companyDomain}/v1",
      "description": "BambooHR API endpoint",
      "variables": {
        "companyDomain": {
          "default": "mycompany",
          "description": "Your BambooHR company subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "BasicAuth": []
    }
  ],
  "paths": {
    "/employees/{id}": {
      "get": {
        "operationId": "getEmployee",
        "summary": "Get employee",
        "description": "Returns employee data for the specified employee ID. Specify which fields to return using the fields query parameter. Max 400 fields per request.",
        "parameters": [
          {
            "$ref": "#/components/parameters/EmployeeId"
          },
          {
            "name": "fields",
            "in": "query",
            "description": "Comma-separated list of field names to return",
            "schema": {
              "type": "string"
            },
            "example": "firstName,lastName,department,jobTitle"
          },
          {
            "name": "onlyCurrent",
            "in": "query",
            "description": "Set to false to include future-dated values",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Employee data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Employee"
                }
              }
            }
          },
          "404": {
            "description": "Employee not found"
          }
        },
        "tags": [
          "Employees"
        ]
      },
      "post": {
        "operationId": "updateEmployee",
        "summary": "Update employee",
        "description": "Updates employee data for the specified ID.",
        "parameters": [
          {
            "$ref": "#/components/parameters/EmployeeId"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "description": "Key-value pairs of field names and new values"
              },
              "example": {
                "firstName": "John",
                "lastName": "Doe",
                "department": "Engineering"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Employee updated"
          },
          "400": {
            "description": "Invalid data"
          }
        },
        "tags": [
          "Employees"
        ]
      }
    },
    "/employees": {
      "post": {
        "operationId": "createEmployee",
        "summary": "Create employee",
        "description": "Creates a new employee. firstName and lastName are required.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "firstName",
                  "lastName"
                ],
                "properties": {
                  "firstName": {
                    "type": "string"
                  },
                  "lastName": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Employee created",
            "headers": {
              "Location": {
                "description": "URL of the new employee resource",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid data"
          }
        },
        "tags": [
          "Employees"
        ]
      },
      "get": {
        "operationId": "listEmployees",
        "summary": "List employees",
        "description": "Returns a list of employees.",
        "parameters": [
          {
            "name": "fields",
            "in": "query",
            "description": "Comma-separated list of field names to return",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of employees",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "employees": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Employee"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Employees"
        ]
      }
    },
    "/employees/directory": {
      "get": {
        "operationId": "getEmployeeDirectory",
        "summary": "Get employee directory",
        "description": "Returns the company employee directory.",
        "responses": {
          "200": {
            "description": "Employee directory",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fields": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "employees": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Employee"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Employees"
        ]
      }
    },
    "/company/information": {
      "get": {
        "operationId": "getCompanyInformation",
        "summary": "Get company information",
        "description": "Returns basic company information.",
        "responses": {
          "200": {
            "description": "Company information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Employees"
        ]
      }
    },
    "/meta/fields": {
      "get": {
        "operationId": "listFields",
        "summary": "List fields",
        "description": "Returns a list of all available employee fields.",
        "responses": {
          "200": {
            "description": "List of field definitions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FieldDefinition"
