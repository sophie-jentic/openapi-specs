  "components": {
    "schemas": {
      "Part": {
        "type": "object",
        "properties": {
          "@id": {
            "type": "string"
          },
          "@type": {
            "type": "string"
          },
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "comment": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "description": "Category IRI"
          },
          "footprint": {
            "type": "string",
            "nullable": true
          },
          "manufacturer": {
            "type": "string",
            "nullable": true
          },
          "manufacturer_product_number": {
            "type": "string"
          },
          "tags": {
            "type": "string"
          },
          "mass": {
            "type": "number",
            "nullable": true
          },
          "ipn": {
            "type": "string",
            "nullable": true
          },
          "minamount": {
            "type": "number"
          },
          "partLots": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PartLot"
            }
          },
          "orderdetails": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "attachments": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "PartInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "comment": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "footprint": {
            "type": "string"
          },
          "manufacturer": {
            "type": "string"
          },
          "manufacturer_product_number": {
            "type": "string"
          },
          "tags": {
            "type": "string"
          },
          "minamount": {
            "type": "number"
          }
        },
        "required": [
          "name"
        ]
      },
      "PartLot": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "amount": {
            "type": "number"
          },
          "storage_location": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "comment": {
            "type": "string"
          },
          "needs_refill": {
            "type": "boolean"
          }
        }
      },
      "CategoryInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "parent": {
            "type": "string",
            "nullable": true
          },
          "comment": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "FootprintInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
