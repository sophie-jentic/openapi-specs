{
  "openapi": "3.0.3",
  "info": {
    "title": "Part-DB API",
    "version": "1.0.0",
    "description": "Part-DB is an electronic part inventory management system. The API provides CRUD access to parts, categories, footprints, manufacturers, storage locations, suppliers, and attachments.",
    "x-jentic-source-url": "https://part-db.de/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080/api"
    }
  ],
  "paths": {
    "/parts": {
      "get": {
        "operationId": "listParts",
        "summary": "List parts",
        "tags": [
          "Parts"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "itemsPerPage",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 30
            }
          },
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Category IRI filter"
          },
          {
            "name": "order[name]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Part list",
            "content": {
              "application/ld+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "hydra:member": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Part"
                      }
                    },
                    "hydra:totalItems": {
                      "type": "integer"
                    },
                    "hydra:view": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List parts"
      },
      "post": {
        "operationId": "createPart",
        "summary": "Create a part",
        "tags": [
          "Parts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/ld+json": {
              "schema": {
                "$ref": "#/components/schemas/PartInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Part created",
            "content": {
              "application/ld+json": {
                "schema": {
                  "$ref": "#/components/schemas/Part"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a part"
      }
    },
    "/parts/{id}": {
      "get": {
        "operationId": "getPart",
        "summary": "Get a part",
        "tags": [
          "Parts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Part details",
            "content": {
              "application/ld+json": {
                "schema": {
                  "$ref": "#/components/schemas/Part"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a part"
      },
      "put": {
        "operationId": "updatePart",
        "summary": "Update a part",
        "tags": [
          "Parts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/ld+json": {
              "schema": {
                "$ref": "#/components/schemas/PartInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Part updated"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update a part"
      },
      "delete": {
        "operationId": "deletePart",
        "summary": "Delete a part",
        "tags": [
          "Parts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Part deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete a part"
      }
    },
