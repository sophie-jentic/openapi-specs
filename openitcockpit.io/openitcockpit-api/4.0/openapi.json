{
  "openapi": "3.0.3",
  "info": {
    "title": "openITCOCKPIT API",
    "version": "4.0",
    "description": "openITCOCKPIT is an open-source IT monitoring platform based on Nagios/Naemon. It provides a comprehensive REST API for managing hosts, services, contacts, commands, time periods, host groups, service groups, and accessing monitoring data.",
    "x-jentic-source-url": "https://openitcockpit.io/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{oitc-host}/api"
    }
  ],
  "paths": {
    "/hosts.json": {
      "get": {
        "operationId": "listHosts",
        "summary": "List all hosts",
        "tags": [
          "Hosts"
        ],
        "parameters": [
          {
            "name": "angular",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 25
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          },
          {
            "name": "filter[Hosts.name]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[Hosts.address]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Host list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HostListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all hosts"
      },
      "post": {
        "operationId": "createHost",
        "summary": "Create a host",
        "tags": [
          "Hosts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HostCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Host created"
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a host"
      }
