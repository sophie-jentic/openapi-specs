                "type": "string"
              },
              "address": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "container_id": {
                "type": "integer"
              },
              "hosttemplate_id": {
                "type": "integer"
              },
              "check_interval": {
                "type": "integer"
              },
              "retry_interval": {
                "type": "integer"
              },
              "max_check_attempts": {
                "type": "integer"
              },
              "notification_interval": {
                "type": "integer"
              },
              "tags": {
                "type": "string"
              },
              "priority": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "satellite_id": {
                "type": "integer"
              },
              "active_checks_enabled": {
                "type": "boolean"
              }
            }
          }
        }
      },
      "ServiceCreate": {
        "type": "object",
        "required": [
          "Service"
        ],
        "properties": {
          "Service": {
            "type": "object",
            "required": [
              "name",
              "host_id",
              "servicetemplate_id"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "host_id": {
                "type": "integer"
              },
              "servicetemplate_id": {
                "type": "integer"
              },
              "check_interval": {
                "type": "integer"
              },
              "retry_interval": {
                "type": "integer"
              },
              "max_check_attempts": {
                "type": "integer"
              },
              "active_checks_enabled": {
                "type": "boolean"
              }
            }
          }
        }
      },
      "HostListResponse": {
        "type": "object",
        "properties": {
          "all_hosts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Host"
            }
          },
          "paging": {
            "type": "object",
