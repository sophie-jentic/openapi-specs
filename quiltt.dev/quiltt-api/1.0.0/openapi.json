{
  "openapi": "3.0.3",
  "info": {
    "title": "Quiltt API",
    "version": "1.0.0",
    "description": "Financial data platform API for managing profiles, connections, accounts, transactions, and integrations with financial data providers.",
    "x-jentic-source-url": "https://www.quiltt.dev/api-reference/rest",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.quiltt.io"
    }
  ],
  "paths": {
    "/v1/users/sessions": {
      "post": {
        "operationId": "createSession",
        "summary": "Issue session token",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserSession"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Issue session token"
      }
    },
    "/v1/users/session": {
      "delete": {
        "operationId": "revokeSession",
        "summary": "Revoke current session",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "204": {
            "description": "Session revoked"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Revoke current session"
      }
    },
    "/v1/introspect/api_key": {
      "post": {
        "operationId": "introspectApiKey",
        "summary": "Validate API key",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "API key details"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Validate API key"
      }
    },
    "/v1/introspect/session_token": {
      "post": {
        "operationId": "introspectSessionToken",
        "summary": "Validate session token",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Session details"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Validate session token"
      }
    },
    "/v1/introspect/processor_token": {
      "post": {
        "operationId": "introspectProcessorToken",
        "summary": "Validate processor token",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Processor token details"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Validate processor token"
      }
    },
    "/v1/profiles": {
      "post": {
        "operationId": "createProfile",
        "summary": "Create profile",
        "tags": [
          "Profiles"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Profile created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Profile"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create profile"
      },
      "get": {
        "operationId": "listProfiles",
        "summary": "List all profiles",
        "tags": [
          "Profiles"
        ],
        "responses": {
          "200": {
            "description": "Profiles list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Profile"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all profiles"
      }
    },
    "/v1/profiles/{id}": {
      "get": {
        "operationId": "getProfile",
        "summary": "Get profile",
        "tags": [
          "Profiles"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Profile"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get profile"
      },
      "patch": {
        "operationId": "updateProfile",
        "summary": "Update profile",
        "tags": [
          "Profiles"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update profile"
      },
      "delete": {
        "operationId": "deleteProfile",
        "summary": "Delete profile",
        "tags": [
          "Profiles"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Profile deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete profile"
      }
