        },
        "responses": {
          "201": {
            "description": "Connection imported"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Import from Plaid"
      }
    },
    "/v1/institutions": {
      "get": {
        "operationId": "searchInstitutions",
        "summary": "Search institutions",
        "tags": [
          "Institutions"
        ],
        "parameters": [
          {
            "name": "routing_number",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Institutions list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Search institutions"
