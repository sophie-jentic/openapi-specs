{
  "openapi": "3.0.3",
  "info": {
    "title": "Lemonway API",
    "description": "Lemonway Payment Platform API for account management, money-in/money-out operations, P2P transfers, and payment processing. Supports multiple payment methods including cards, bank transfers, PayPal, SEPA direct debits, and includes KYC/AML compliance automation.",
    "version": "8.2",
    "x-jentic-source-url": "https://documentation.lemonway.com/reference",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.lemonway.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "OAuth2": []
    }
  ],
  "components": {
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://api.lemonway.com/oauth/token",
            "scopes": {}
          }
        }
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error code"
          },
          "error_description": {
            "type": "string",
            "description": "Human-readable error description"
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "accountId": {
            "type": "string",
            "description": "Unique account identifier"
          },
          "type": {
            "type": "string",
            "enum": [
              "individual",
              "legal_entity"
            ],
            "description": "Account type"
          },
          "status": {
            "type": "string",
            "description": "Account status"
          },
          "balances": {
            "type": "object",
            "description": "Account balance information"
          }
        }
      },
      "MoneyIn": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Transaction identifier"
          },
          "amount": {
            "type": "number",
            "format": "double",
            "description": "Transaction amount"
          },
          "currency": {
            "type": "string",
            "description": "Currency code"
          },
          "status": {
            "type": "string",
            "description": "Transaction status"
          }
        }
      },
      "MoneyOut": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Transaction identifier"
          },
          "amount": {
            "type": "number",
            "format": "double",
            "description": "Withdrawal amount"
          },
          "currency": {
            "type": "string",
            "description": "Currency code"
          },
          "iban": {
            "type": "string",
            "description": "Destination IBAN"
          }
        }
      }
    }
  },
  "paths": {
    "/v2/accounts": {
      "post": {
        "operationId": "createAccount",
        "summary": "Create account",
        "description": "Create individual or legal entity accounts for onboarding",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Account"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ]
      },
      "get": {
        "operationId": "listAccounts",
        "summary": "List accounts",
        "description": "List all payment accounts",
        "responses": {
          "200": {
            "description": "List of accounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Account"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ]
      }
    },
