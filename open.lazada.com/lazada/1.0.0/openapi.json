    "/orders/get": {
      "get": {
        "operationId": "getOrders",
        "summary": "Get order list",
        "description": "Retrieve a paginated list of orders for the authenticated seller.",
        "tags": [
          "Orders"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter orders by status.",
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "packed",
                "ready_to_ship",
                "shipped",
                "delivered",
                "returned",
                "failed",
                "canceled"
              ]
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Filter orders created before this date (ISO 8601).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Filter orders created after this date (ISO 8601).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset.",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of orders to return per page.",
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 100
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "description": "Sort field for results.",
            "schema": {
              "type": "string",
              "enum": [
                "created_at",
                "updated_at"
              ]
            }
          },
          {
            "name": "sort_direction",
            "in": "query",
            "description": "Sort direction.",
            "schema": {
              "type": "string",
              "enum": [
                "ASC",
                "DESC"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order list retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderListResponse"
