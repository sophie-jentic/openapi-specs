  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "access_token",
        "in": "query",
        "description": "Lazada Open Platform API key (access token) obtained through the app authorization flow."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code."
          },
          "type": {
            "type": "string",
            "description": "Error type (e.g., ISV, ISP, SYSTEM)."
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message."
          },
          "request_id": {
            "type": "string",
            "description": "Unique request identifier for debugging."
          }
        },
        "required": [
          "code",
          "type",
          "message"
        ]
      },
      "Product": {
        "type": "object",
        "properties": {
          "item_id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique product item identifier."
          },
          "primary_category": {
            "type": "integer",
            "format": "int64",
            "description": "Primary category ID."
          },
          "attributes": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Product name."
              },
              "short_description": {
                "type": "string",
                "description": "Short product description."
              },
              "description": {
                "type": "string",
                "description": "Full product description (HTML)."
              },
              "brand": {
                "type": "string",
                "description": "Product brand."
              }
            }
          },
          "skus": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sku"
            },
            "description": "List of SKU variants."
          },
          "status": {
            "type": "string",
            "description": "Product status.",
            "enum": [
              "active",
              "inactive",
              "deleted"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Product creation timestamp."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Product last update timestamp."
          }
        }
      },
      "Sku": {
        "type": "object",
        "properties": {
          "sku_id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique SKU identifier."
          },
          "seller_sku": {
            "type": "string",
            "description": "Seller-defined SKU code."
          },
          "price": {
            "type": "number",
            "format": "float",
            "description": "Selling price."
          },
          "special_price": {
            "type": "number",
            "format": "float",
            "description": "Special/sale price."
          },
          "quantity": {
            "type": "integer",
            "description": "Available stock quantity."
          },
          "status": {
            "type": "string",
            "description": "SKU status."
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of image URLs."
          }
        }
      },
      "ProductListResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Response code (0 for success)."
          },
          "data": {
            "type": "object",
            "properties": {
              "total_products": {
                "type": "integer",
                "description": "Total number of products."
              },
              "products": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "request_id": {
            "type": "string"
          }
        }
      },
      "ProductDetailResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/Product"
          },
          "request_id": {
            "type": "string"
          }
        }
      },
      "SellerReview": {
        "type": "object",
        "properties": {
          "review_id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique review identifier."
          },
          "order_id": {
            "type": "integer",
            "format": "int64",
            "description": "Associated order ID."
          },
          "rating": {
            "type": "integer",
            "description": "Rating score (1-5).",
            "minimum": 1,
            "maximum": 5
          },
          "comment": {
            "type": "string",
            "description": "Review text."
          },
          "buyer_name": {
            "type": "string",
            "description": "Buyer display name."
          },
          "created_at": {
            "type": "string",
