{
  "openapi": "3.0.3",
  "info": {
    "title": "Lazada Open Platform API",
    "description": "Retrieve product ratings and seller performance metrics from the Lazada Open Platform. Provides access to product information, seller data, order management, ratings, reviews, and performance analytics.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://open.lazada.com/doc/doc.htm",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.lazada.com/rest",
      "description": "Lazada Open Platform API (Production)"
    },
    {
      "url": "https://api.lazada.sg/rest",
      "description": "Lazada Open Platform API (Singapore)"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Products",
      "description": "Product listing and management operations"
    },
    {
      "name": "Ratings",
      "description": "Product ratings and reviews"
    },
    {
      "name": "Seller",
      "description": "Seller information and performance metrics"
    },
    {
      "name": "Orders",
      "description": "Order management and retrieval"
    },
    {
      "name": "Categories",
      "description": "Category tree and attributes"
    }
  ],
  "paths": {
    "/products/get": {
      "get": {
        "operationId": "getProducts",
        "summary": "Get product list",
        "description": "Retrieve a paginated list of products for the authenticated seller.",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "description": "Filter type for products (all, live, inactive, deleted, image-missing, pending, rejected, sold-out).",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "live",
                "inactive",
                "deleted",
                "image-missing",
                "pending",
                "rejected",
                "sold-out"
              ]
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search keyword for product name or seller SKU.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of products to skip (pagination offset).",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of products to return per page.",
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 500
            }
          },
          {
            "name": "create_before",
            "in": "query",
            "description": "Filter products created before this date (ISO 8601).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "create_after",
            "in": "query",
            "description": "Filter products created after this date (ISO 8601).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "update_before",
            "in": "query",
            "description": "Filter products updated before this date (ISO 8601).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "update_after",
            "in": "query",
            "description": "Filter products updated after this date (ISO 8601).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product list retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
