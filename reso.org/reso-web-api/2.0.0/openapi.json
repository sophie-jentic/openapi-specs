            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "OpenHouseKey": {
                  "type": "string"
                },
                "ListingKey": {
                  "type": "string"
                },
                "OpenHouseDate": {
                  "type": "string",
                  "format": "date"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
