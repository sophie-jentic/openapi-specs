          },
          "ListOfficeKey": {
            "type": "string"
          }
        }
      },
      "PropertyListResponse": {
        "type": "object",
        "properties": {
          "value": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Property"
            }
          },
          "@odata.count": {
            "type": "integer"
          },
          "@odata.nextLink": {
            "type": "string"
          }
        }
      },
      "MemberListResponse": {
        "type": "object",
        "properties": {
          "value": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "MemberKey": {
                  "type": "string"
                },
                "MemberFirstName": {
                  "type": "string"
                },
                "MemberLastName": {
                  "type": "string"
                },
                "MemberEmail": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "OfficeListResponse": {
        "type": "object",
        "properties": {
          "value": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
