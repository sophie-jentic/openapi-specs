            "type": "string"
          },
          "ListingId": {
            "type": "string"
          },
          "ListPrice": {
            "type": "number"
          },
          "StandardStatus": {
            "type": "string"
          },
          "PropertyType": {
            "type": "string"
          },
          "StreetNumber": {
            "type": "string"
          },
          "StreetName": {
            "type": "string"
          },
          "City": {
            "type": "string"
          },
          "StateOrProvince": {
            "type": "string"
          },
          "PostalCode": {
            "type": "string"
          },
          "BedroomsTotal": {
            "type": "integer"
          },
          "BathroomsTotalInteger": {
            "type": "integer"
          },
          "LivingArea": {
            "type": "number"
          },
          "ListAgentKey": {
