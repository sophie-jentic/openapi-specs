{
  "openapi": "3.0.3",
  "info": {
    "title": "Palaccio Zapier Webhook API",
    "description": "API for managing webhooks and retrieving leads through Zapier integration",
    "version": "1.0.0",
    "contact": {
      "url": "https://www.palaccio.com"
    }
  },
  "servers": [
    {
      "url": "https://zapierwebhook-haghklbvya-uc.a.run.app",
      "description": "Production server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Execute Zapier action",
        "description": "Execute various Zapier actions including retrieving recent leads, subscribing to webhooks, or unsubscribing from webhooks",
        "operationId": "executeAction",
        "parameters": [
          {
            "name": "zapierKey",
            "in": "query",
            "description": "The unique key used to identify the user in the database",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "action",
            "in": "query",
            "description": "The action to perform",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "getRecentLeads",
                "subscribeHook",
                "unsubscribeHook"
              ]
            }
          },
          {
            "name": "hookUrl",
            "in": "query",
            "description": "The webhook URL (required for subscribeHook and unsubscribeHook actions)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/DefaultResponse"
                    },
                    {
                      "$ref": "#/components/schemas/LeadsResponse"
                    },
                    {
                      "$ref": "#/components/schemas/HookResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Zapier key not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "default"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "DefaultResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Zapier Request Received"
          },
          "user": {
            "type": "string",
            "example": "user_uid"
          },
          "displayName": {
            "type": "string",
            "example": "User"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          }
        }
      },
      "LeadsResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Lead"
        }
      },
      "Lead": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Lead Name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "lead@example.com"
          },
          "phone": {
            "type": "string",
            "example": "123-456-7890"
          },
          "status": {
            "type": "string",
            "example": "Status"
          },
          "type": {
            "type": "string",
            "example": "Type"
          }
        }
      },
      "HookResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Hook Url Saved"
          },
          "hookUrl": {
            "type": "string",
            "format": "uri",
            "example": "https://example.com/webhook"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Zapier Key Not Found"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "default"
    }
  ]
}
