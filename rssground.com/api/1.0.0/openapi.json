{
  "openapi": "3.0.3",
  "info": {
    "title": "RSS Ground API",
    "description": "RSS Ground API enables management of personal feeds, posting campaigns, and webhook notifications. All interactions require OAuth 2.0 authentication.",
    "version": "1.0.0",
    "contact": {
      "name": "RSS Ground Support",
      "url": "https://help.rssground.com"
    }
  },
  "servers": [
    {
      "url": "https://www.rssground.com/api",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/me": {
      "get": {
        "summary": "Get User Info",
        "description": "Retrieves authenticated user's ID and name",
        "operationId": "getMe",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "User ID"
                    },
                    "name": {
                      "type": "string",
                      "description": "User name"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "me"
        ]
      }
    },
    "/me/feeds/personal": {
      "get": {
        "summary": "List Personal Feeds",
        "description": "Lists all personal feeds associated with the account",
        "operationId": "listPersonalFeeds",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Feed"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "me"
        ]
      }
    },
    "/me/campaigns": {
      "get": {
        "summary": "List Campaigns",
        "description": "Returns posting campaigns configured for integrations",
        "operationId": "listCampaigns",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Campaign"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "me"
        ]
      }
    },
    "/campaign/sampleresponse": {
      "get": {
        "summary": "Get Sample Webhook Response",
        "description": "Provides sample webhook trigger data",
        "operationId": "getSampleWebhookResponse",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Sample webhook trigger data"
                }
              }
            }
          }
        },
        "tags": [
          "campaign"
        ]
      }
    },
    "/feed/personal/item": {
      "post": {
        "summary": "Create Feed Item",
        "description": "Creates new posts in personal feeds",
        "operationId": "createFeedItem",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "feed_id",
                  "title",
                  "description"
                ],
                "properties": {
                  "feed_id": {
                    "type": "string",
                    "description": "Personal feed identifier"
                  },
                  "title": {
                    "type": "string",
                    "description": "Post title"
                  },
                  "description": {
                    "type": "string",
                    "description": "HTML-formatted content"
                  },
                  "link": {
                    "type": "string",
                    "format": "uri",
                    "description": "Optional related URL"
                  },
                  "image_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Optional image URL for visual content"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Item created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedItem"
                }
              }
            }
          }
        },
        "tags": [
          "feed"
        ]
      }
    },
    "/campaign/webhook": {
      "post": {
        "summary": "Subscribe to Webhook",
        "description": "Subscribes to webhook notifications",
        "operationId": "subscribeWebhook",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "campaign_id",
                  "url"
                ],
                "properties": {
                  "campaign_id": {
                    "type": "string",
                    "description": "Campaign identifier"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Webhook callback URL"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook subscription created successfully"
          }
        },
        "tags": [
          "campaign"
        ]
      },
      "delete": {
        "summary": "Unsubscribe from Webhook",
        "description": "Unsubscribes from webhook notifications",
        "operationId": "unsubscribeWebhook",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "campaign_id"
                ],
                "properties": {
                  "campaign_id": {
                    "type": "string",
                    "description": "Campaign identifier"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook subscription removed successfully"
          }
        },
        "tags": [
          "campaign"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Feed": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Feed identifier"
          },
          "name": {
            "type": "string",
            "description": "Feed name"
          }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Campaign identifier"
          },
          "name": {
            "type": "string",
            "description": "Campaign name"
          }
        }
      },
      "FeedItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Item identifier"
          },
          "feed_id": {
            "type": "string",
            "description": "Personal feed identifier"
          },
          "title": {
            "type": "string",
            "description": "Post title"
          },
          "description": {
            "type": "string",
            "description": "HTML-formatted content"
          },
          "link": {
            "type": "string",
            "format": "uri",
            "description": "Related URL",
            "nullable": true
          },
          "image_url": {
            "type": "string",
            "format": "uri",
            "description": "Image URL for visual content",
            "nullable": true
          }
        }
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://www.rssground.com/oauth/authorize",
            "tokenUrl": "https://www.rssground.com/oauth/token",
            "scopes": {}
          }
        },
        "description": "OAuth 2.0 authentication required for all API interactions"
      }
    }
  },
  "tags": [
    {
      "name": "campaign"
    },
    {
      "name": "feed"
    },
    {
      "name": "me"
    }
  ]
}
