{
  "openapi": "3.0.3",
  "info": {
    "title": "APITable API",
    "version": "1.0.0",
    "description": "APITable (formerly Vika, also known as AITable.ai) is an API-oriented smart spreadsheet with features for managing data, creating custom views, setting row permissions, and generating one-click API panels. The API allows you to manage datasheets, records, fields, and spaces programmatically.",
    "x-jentic-source-url": "https://developers.apitable.com",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.apitable.com/fusion/v1",
      "description": "APITable API server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/spaces": {
      "get": {
        "summary": "List Spaces",
        "description": "Get a list of all accessible spaces.",
        "operationId": "listSpaces",
        "responses": {
          "200": {
            "description": "List of spaces",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "spaces": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "name": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "spaces"
        ]
      }
    },
    "/spaces/{spaceId}/nodes": {
      "get": {
        "summary": "List Nodes in Space",
        "description": "Get a list of all nodes (datasheets, folders, etc.) in a space.",
        "operationId": "listNodes",
        "parameters": [
          {
            "name": "spaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Space identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "List of nodes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "nodes": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "name": {
                                "type": "string"
                              },
                              "type": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Space not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "spaces"
        ]
      }
    },
    "/datasheets/{datasheetId}/records": {
      "get": {
        "summary": "List Records",
        "description": "Get records from a datasheet with optional filtering, sorting, and pagination.",
        "operationId": "listRecords",
        "parameters": [
          {
            "name": "datasheetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Datasheet identifier"
          },
          {
            "name": "viewId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "View identifier for filtering"
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 1000
            },
            "description": "Number of records per page"
          },
          {
            "name": "pageNum",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sort specification in JSON format"
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Field IDs to include in response"
          }
        ],
        "responses": {
          "200": {
            "description": "List of records",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "records": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "recordId": {
                                "type": "string"
                              },
                              "fields": {
                                "type": "object"
                              },
                              "createdAt": {
                                "type": "integer"
                              }
                            }
                          }
                        },
                        "pageNum": {
                          "type": "integer"
                        },
                        "pageSize": {
                          "type": "integer"
                        },
                        "total": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Datasheet not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "datasheets"
        ]
      },
      "post": {
        "summary": "Create Records",
        "description": "Add one or more records to a datasheet.",
        "operationId": "createRecords",
        "parameters": [
          {
            "name": "datasheetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "records"
                ],
                "properties": {
                  "records": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "fields"
                      ],
                      "properties": {
                        "fields": {
                          "type": "object",
                          "description": "Field values for the record"
                        }
                      }
                    }
                  },
                  "fieldKey": {
                    "type": "string",
                    "enum": [
                      "name",
                      "id"
                    ],
                    "default": "name",
                    "description": "Whether to use field names or IDs"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Records created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "records": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "recordId": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "datasheets"
        ]
      }
    },
    "/datasheets/{datasheetId}/records/{recordId}": {
      "patch": {
        "summary": "Update Record",
        "description": "Update a specific record in a datasheet.",
        "operationId": "updateRecord",
        "parameters": [
          {
            "name": "datasheetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "recordId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "fields"
                ],
                "properties": {
                  "fields": {
                    "type": "object",
                    "description": "Field values to update"
                  },
                  "fieldKey": {
                    "type": "string",
                    "enum": [
                      "name",
                      "id"
                    ],
                    "default": "name"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record updated successfully"
          },
          "404": {
            "description": "Record not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "datasheets"
        ]
      },
      "delete": {
        "summary": "Delete Record",
        "description": "Delete a specific record from a datasheet.",
        "operationId": "deleteRecord",
        "parameters": [
          {
            "name": "datasheetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "recordId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Record deleted successfully"
          },
          "404": {
            "description": "Record not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "datasheets"
        ]
      }
    },
    "/datasheets/{datasheetId}/fields": {
      "get": {
        "summary": "List Fields",
        "description": "Get all fields in a datasheet.",
        "operationId": "listFields",
        "parameters": [
          {
            "name": "datasheetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of fields",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "fields": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "name": {
                                "type": "string"
                              },
                              "type": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "datasheets"
        ]
      },
      "post": {
        "summary": "Create Field",
        "description": "Add a new field to a datasheet.",
        "operationId": "createField",
        "parameters": [
          {
            "name": "datasheetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "type"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "description": "Field type (Text, Number, SingleSelect, etc.)"
                  },
                  "property": {
                    "type": "object",
                    "description": "Additional field properties"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Field created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "datasheets"
        ]
      }
    },
    "/datasheets/{datasheetId}/views": {
      "get": {
        "summary": "List Views",
        "description": "Get all views in a datasheet.",
        "operationId": "listViews",
        "parameters": [
          {
            "name": "datasheetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of views",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "views": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "name": {
                                "type": "string"
                              },
                              "type": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "datasheets"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API token obtained from your APITable account. Include as Bearer token in Authorization header."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "datasheets"
    },
    {
      "name": "spaces"
    }
  ]
}
