{
  "openapi": "3.0.3",
  "info": {
    "title": "Willo API",
    "version": "1.0.0",
    "description": "Willo is a video interviewing platform. The API provides access to interviews, candidates, questions, and video management.",
    "x-jentic-source-url": "https://willo-developer.carrd.co/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.willo.video/v1"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/interviews": {
      "get": {
        "summary": "List Interviews",
        "description": "Retrieve a list of interviews",
        "operationId": "listInterviews",
        "tags": [
          "Interviews"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Interview"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      },
      "post": {
        "summary": "Create Interview",
        "description": "Create a new interview",
        "operationId": "createInterview",
        "tags": [
          "Interviews"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InterviewRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Interview created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Interview"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/interviews/{interview_id}": {
      "get": {
        "summary": "Get Interview",
        "description": "Retrieve a specific interview",
        "operationId": "getInterview",
        "tags": [
          "Interviews"
        ],
        "parameters": [
          {
            "name": "interview_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Interview"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      },
      "put": {
        "summary": "Update Interview",
        "description": "Update an interview",
        "operationId": "updateInterview",
        "tags": [
          "Interviews"
        ],
        "parameters": [
          {
            "name": "interview_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InterviewRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Interview updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Interview"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete Interview",
        "description": "Delete an interview",
        "operationId": "deleteInterview",
        "tags": [
          "Interviews"
        ],
        "parameters": [
          {
            "name": "interview_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Interview deleted"
          }
        }
      }
    },
    "/candidates": {
      "get": {
        "summary": "List Candidates",
        "description": "Retrieve a list of candidates",
        "operationId": "listCandidates",
        "tags": [
          "Candidates"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Candidate"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Candidate",
        "description": "Create a new candidate",
        "operationId": "createCandidate",
        "tags": [
          "Candidates"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CandidateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Candidate created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Candidate"
                }
              }
            }
          }
        }
      }
    },
    "/candidates/{candidate_id}": {
      "get": {
        "summary": "Get Candidate",
        "description": "Retrieve a specific candidate",
        "operationId": "getCandidate",
        "tags": [
          "Candidates"
        ],
        "parameters": [
          {
            "name": "candidate_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Candidate"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete Candidate",
        "description": "Delete a candidate",
        "operationId": "deleteCandidate",
        "tags": [
          "Candidates"
        ],
        "parameters": [
          {
            "name": "candidate_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Candidate deleted"
          }
        }
      }
    },
    "/questions": {
      "get": {
        "summary": "List Questions",
        "description": "Retrieve a list of interview questions",
        "operationId": "listQuestions",
        "tags": [
          "Questions"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Question"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Question",
        "description": "Create a new question",
        "operationId": "createQuestion",
        "tags": [
          "Questions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuestionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Question created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Question"
                }
              }
            }
          }
        }
      }
    },
    "/questions/{question_id}": {
      "get": {
        "summary": "Get Question",
        "description": "Retrieve a specific question",
        "operationId": "getQuestion",
        "tags": [
          "Questions"
        ],
        "parameters": [
          {
            "name": "question_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Question"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete Question",
        "description": "Delete a question",
        "operationId": "deleteQuestion",
        "tags": [
          "Questions"
        ],
        "parameters": [
          {
            "name": "question_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Question deleted"
          }
        }
      }
    },
    "/videos": {
      "get": {
        "summary": "List Videos",
        "description": "Retrieve a list of interview videos",
        "operationId": "listVideos",
        "tags": [
          "Videos"
        ],
        "parameters": [
          {
            "name": "interview_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "candidate_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Video"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/videos/{video_id}": {
      "get": {
        "summary": "Get Video",
        "description": "Retrieve a specific video",
        "operationId": "getVideo",
        "tags": [
          "Videos"
        ],
        "parameters": [
          {
            "name": "video_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Video"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key authentication"
      }
    },
    "schemas": {
      "Interview": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "active",
              "completed",
              "archived"
            ]
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Question"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "InterviewRequest": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "question_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Candidate": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "CandidateRequest": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "email"
        ],
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "Question": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "duration_seconds": {
            "type": "integer"
          },
          "required": {
            "type": "boolean"
          }
        }
      },
      "QuestionRequest": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "duration_seconds": {
            "type": "integer"
          },
          "required": {
            "type": "boolean"
          }
        }
      },
      "Video": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "interview_id": {
            "type": "string"
          },
          "candidate_id": {
            "type": "string"
          },
          "question_id": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "duration": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "ErrorResponse": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "UnauthorizedError": {
        "description": "Authentication required",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Interviews",
      "description": "Interview management"
    },
    {
      "name": "Candidates",
      "description": "Candidate management"
    },
    {
      "name": "Questions",
      "description": "Question management"
    },
    {
      "name": "Videos",
      "description": "Video operations"
    }
  ]
}
