          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/messaging/qmgr/{qmgrName}/queue/{queueName}/message": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send a message to a queue",
        "description": "Puts a message on the specified queue",
        "tags": [
          "Messaging"
        ],
        "parameters": [
          {
            "name": "qmgrName",
            "in": "path",
            "description": "Name of the queue manager",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "queueName",
            "in": "path",
            "description": "Name of the queue",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ibm-mq-md-correlationId",
            "in": "header",
            "description": "Correlation ID for the message",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ibm-mq-md-expiry",
            "in": "header",
            "description": "Message expiry in tenths of a second",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "ibm-mq-md-persistence",
            "in": "header",
            "description": "Message persistence",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "persistent",
                "nonPersistent"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "text/plain": {
              "schema": {
                "type": "string"
              }
            },
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Message sent successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "browseMessages",
        "summary": "Browse messages on a queue",
        "description": "Browses messages on the specified queue without removing them",
        "tags": [
          "Messaging"
        ],
        "parameters": [
          {
            "name": "qmgrName",
            "in": "path",
            "description": "Name of the queue manager",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "queueName",
            "in": "path",
            "description": "Name of the queue",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of messages to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "consumeMessage",
        "summary": "Consume a message from a queue",
        "description": "Destructively gets (consumes) a message from the specified queue",
        "tags": [
          "Messaging"
        ],
        "parameters": [
          {
            "name": "qmgrName",
            "in": "path",
            "description": "Name of the queue manager",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "queueName",
            "in": "path",
            "description": "Name of the queue",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ibm-mq-md-correlationId",
            "in": "header",
            "description": "Correlation ID to match",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Message consumed successfully",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "No messages available",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/login": {
      "post": {
        "operationId": "login",
        "summary": "Authenticate user",
        "description": "Authenticates a user and returns a LTPA token for subsequent API calls",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful, LTPA token returned in cookie"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/v1/logout": {
      "post": {
        "operationId": "logout",
        "summary": "Log out user",
        "description": "Invalidates the current LTPA token",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Logout successful"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QueueManager": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Queue manager name"
          },
          "state": {
            "type": "string",
            "description": "Queue manager state",
            "enum": [
              "running",
              "ended"
            ]
          },
          "isDefaultQueueManager": {
            "type": "boolean"
          },
          "platformType": {
            "type": "string"
          },
          "commandLevel": {
            "type": "integer"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "QueueManagerListResponse": {
        "type": "object",
        "properties": {
          "qmgr": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QueueManager"
            }
          }
        }
      },
      "Queue": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Queue name"
          },
          "type": {
            "type": "string",
            "enum": [
              "local",
              "alias",
              "remote",
              "model",
              "cluster"
            ]
          },
          "general": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string"
              },
              "isGet": {
                "type": "boolean"
              },
              "isPut": {
                "type": "boolean"
              },
              "inhibitGet": {
                "type": "boolean"
              },
              "inhibitPut": {
                "type": "boolean"
              }
            }
          },
          "status": {
            "type": "object",
            "properties": {
              "currentDepth": {
                "type": "integer"
              },
              "openInputCount": {
                "type": "integer"
              },
              "openOutputCount": {
                "type": "integer"
              },
              "lastGetDateTime": {
                "type": "string",
