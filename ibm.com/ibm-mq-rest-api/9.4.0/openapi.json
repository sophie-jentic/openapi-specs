{
  "openapi": "3.0.3",
  "info": {
    "title": "IBM MQ REST API",
    "version": "9.4.0",
    "description": "IBM MQ Administration REST API for managing queue managers, queues, channels, subscriptions, and messaging. Provides RESTful access to IBM MQ resources for administration, messaging, and monitoring.",
    "x-jentic-source-url": "https://www.ibm.com/products/mq",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{hostname}:{port}/ibmmq/rest",
      "description": "IBM MQ REST API server",
      "variables": {
        "hostname": {
          "default": "localhost",
          "description": "MQ server hostname"
        },
        "port": {
          "default": "9443",
          "description": "MQ REST API port"
        }
      }
    }
  ],
  "paths": {
    "/v2/admin/qmgr": {
      "get": {
        "operationId": "listQueueManagers",
        "summary": "List queue managers",
        "description": "Returns a list of queue managers that are available on the MQ installation",
        "tags": [
          "Queue Managers"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Filter by queue manager name, supports wildcards",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attributes",
            "in": "query",
            "description": "Comma-separated list of attributes to return",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueManagerListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/admin/qmgr/{qmgrName}": {
      "get": {
        "operationId": "getQueueManager",
        "summary": "Get queue manager details",
        "description": "Returns detailed information about a specific queue manager",
        "tags": [
          "Queue Managers"
        ],
        "parameters": [
          {
            "name": "qmgrName",
            "in": "path",
            "description": "Name of the queue manager",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attributes",
            "in": "query",
            "description": "Comma-separated list of attributes to return",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueManager"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Queue manager not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/admin/qmgr/{qmgrName}/queue": {
      "get": {
        "operationId": "listQueues",
        "summary": "List queues",
        "description": "Returns a list of queues for a specific queue manager",
        "tags": [
          "Queues"
        ],
        "parameters": [
          {
            "name": "qmgrName",
            "in": "path",
            "description": "Name of the queue manager",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "Filter by queue name, supports wildcards",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by queue type",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "local",
                "alias",
                "remote",
                "model",
                "cluster"
              ]
            }
          },
          {
            "name": "attributes",
            "in": "query",
            "description": "Comma-separated list of attributes to return",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createQueue",
        "summary": "Create a queue",
        "description": "Creates a new queue on the specified queue manager",
        "tags": [
          "Queues"
        ],
        "parameters": [
          {
            "name": "qmgrName",
            "in": "path",
            "description": "Name of the queue manager",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueueCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Queue created successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Queue already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/admin/qmgr/{qmgrName}/queue/{queueName}": {
      "get": {
        "operationId": "getQueue",
        "summary": "Get queue details",
        "description": "Returns detailed information about a specific queue",
