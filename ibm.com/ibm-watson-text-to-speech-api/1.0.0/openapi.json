  "components": {
    "schemas": {
      "Voices": {
        "type": "object",
        "properties": {
          "voices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Voice"
            }
          }
        }
      },
      "Voice": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "gender": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "customizable": {
            "type": "boolean"
          },
          "supported_features": {
            "type": "object",
            "properties": {
              "custom_pronunciation": {
                "type": "boolean"
              },
              "voice_transformation": {
                "type": "boolean"
              }
            }
          }
        }
      },
      "SynthesizeRequest": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "description": "Text to synthesize (plain text or SSML)"
          }
        }
      },
      "Pronunciation": {
        "type": "object",
        "properties": {
          "pronunciation": {
            "type": "string"
          }
        }
      },
      "CustomModels": {
        "type": "object",
        "properties": {
          "customizations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CustomModel"
            }
          }
        }
      },
      "CustomModel": {
        "type": "object",
        "properties": {
          "customization_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "last_modified": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          },
          "words": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Word"
            }
          }
        }
      },
      "CreateCustomModel": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "language": {
            "type": "string",
