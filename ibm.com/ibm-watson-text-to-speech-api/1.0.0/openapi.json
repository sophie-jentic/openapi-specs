{
  "openapi": "3.0.3",
  "info": {
    "title": "IBM Watson Text to Speech API",
    "version": "1.0.0",
    "description": "IBM Watson Text to Speech converts written text to natural-sounding speech. The service supports multiple languages and voices, SSML input, word timings, custom voice models, and various audio formats.",
    "x-jentic-source-url": "https://cloud.ibm.com/apidocs/text-to-speech",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.us-south.text-to-speech.watson.cloud.ibm.com",
      "description": "US South instance (replace with your region)"
    }
  ],
  "paths": {
    "/v1/voices": {
      "get": {
        "operationId": "listVoices",
        "summary": "List available voices",
        "description": "Lists all voices available for use with the service. The information includes the name, language, gender, and other details about each voice.",
        "tags": [
          "Voices"
        ],
        "responses": {
          "200": {
            "description": "List of available voices",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Voices"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/voices/{voice}": {
      "get": {
        "operationId": "getVoice",
        "summary": "Get a voice",
        "description": "Gets information about the specified voice.",
        "tags": [
          "Voices"
        ],
        "parameters": [
          {
            "name": "voice",
            "in": "path",
            "description": "Voice identifier (e.g., en-US_AllisonV3Voice)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "customization_id",
            "in": "query",
            "description": "GUID of a custom model to include with the voice",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Voice details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Voice"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Voice not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/synthesize": {
      "get": {
        "operationId": "synthesizeGet",
        "summary": "Synthesize audio (GET)",
        "description": "Synthesizes text to audio via query parameter. Limited to 8KB of text.",
        "tags": [
          "Synthesis"
        ],
        "parameters": [
          {
            "name": "accept",
            "in": "query",
            "description": "Audio format (e.g., audio/wav, audio/mp3, audio/ogg;codecs=opus, audio/flac)",
            "required": false,
            "schema": {
              "type": "string",
              "default": "audio/ogg;codecs=opus"
            }
          },
          {
            "name": "text",
            "in": "query",
            "description": "Text to synthesize (plain text or SSML)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "voice",
            "in": "query",
            "description": "Voice to use for synthesis",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en-US_MichaelV3Voice"
            }
          },
          {
            "name": "customization_id",
            "in": "query",
            "description": "GUID of custom model",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Audio stream",
            "content": {
              "audio/wav": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "audio/mp3": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "audio/ogg;codecs=opus": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "audio/flac": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "406": {
            "description": "Not acceptable - unsupported audio format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "synthesize",
        "summary": "Synthesize audio (POST)",
        "description": "Synthesizes text to audio. Accepts plain text or SSML input in the request body.",
        "tags": [
          "Synthesis"
        ],
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "description": "Audio format",
            "required": false,
            "schema": {
              "type": "string",
              "default": "audio/ogg;codecs=opus"
            }
          },
          {
            "name": "voice",
            "in": "query",
            "description": "Voice to use",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en-US_MichaelV3Voice"
            }
          },
          {
            "name": "customization_id",
            "in": "query",
            "description": "GUID of custom model",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SynthesizeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audio stream",
            "content": {
              "audio/wav": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "audio/mp3": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "audio/ogg;codecs=opus": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "audio/flac": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "406": {
            "description": "Not acceptable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/pronunciation": {
      "get": {
        "operationId": "getPronunciation",
        "summary": "Get pronunciation",
        "description": "Gets the phonetic pronunciation of the specified text.",
        "tags": [
          "Pronunciation"
        ],
        "parameters": [
          {
            "name": "text",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "voice",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Phoneme format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "ipa",
                "ibm"
              ],
              "default": "ipa"
            }
          },
          {
            "name": "customization_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pronunciation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pronunciation"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/customizations": {
      "get": {
