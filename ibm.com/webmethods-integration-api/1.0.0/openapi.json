{
  "openapi": "3.0.3",
  "info": {
    "title": "IBM webMethods Integration API",
    "version": "1.0.0",
    "description": "IBM webMethods Integration (formerly Software AG webMethods.io Integration) REST API for managing integration workflows, flow services, connectors, and execution. Provides cloud-native iPaaS capabilities for building and managing integrations.",
    "x-jentic-source-url": "https://www.ibm.com/products/webmethods",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{tenant}.int-aws-{region}.webmethods.io",
      "variables": {
        "tenant": {
          "default": "tenant"
        },
        "region": {
          "default": "region"
        }
      }
    }
  ],
  "paths": {
    "/integration/rest/external/v1/workflows": {
      "get": {
        "operationId": "listWorkflows",
        "summary": "List workflows",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "inactive"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List workflows"
      },
      "post": {
        "operationId": "createWorkflow",
        "summary": "Create a workflow",
        "tags": [
          "Workflows"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a workflow"
      }
    },
    "/integration/rest/external/v1/workflows/{workflowUid}": {
      "get": {
        "operationId": "getWorkflow",
        "summary": "Get a workflow",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflowUid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a workflow"
      },
      "put": {
        "operationId": "updateWorkflow",
        "summary": "Update a workflow",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflowUid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update a workflow"
      },
      "delete": {
        "operationId": "deleteWorkflow",
        "summary": "Delete a workflow",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflowUid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete a workflow"
      }
    },
    "/integration/rest/external/v1/workflows/{workflowUid}/run": {
      "post": {
        "operationId": "runWorkflow",
        "summary": "Execute a workflow",
        "tags": [
          "Workflow Execution"
        ],
        "parameters": [
          {
            "name": "workflowUid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Execution result"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Execute a workflow"
      }
    },
    "/integration/rest/external/v1/workflows/{workflowUid}/executions": {
      "get": {
        "operationId": "listWorkflowExecutions",
        "summary": "List workflow executions",
        "tags": [
          "Workflow Execution"
        ],
        "parameters": [
          {
            "name": "workflowUid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "successful",
                "failed",
                "running"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List workflow executions"
      }
    },
    "/integration/rest/external/v1/flowservices": {
      "get": {
        "operationId": "listFlowServices",
        "summary": "List flow services",
        "tags": [
          "Flow Services"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List flow services"
      },
      "post": {
        "operationId": "createFlowService",
        "summary": "Create a flow service",
        "tags": [
          "Flow Services"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a flow service"
      }
    },
    "/integration/rest/external/v1/flowservices/{flowServiceUid}/run": {
      "post": {
        "operationId": "runFlowService",
        "summary": "Execute a flow service",
        "tags": [
          "Flow Services"
        ],
        "parameters": [
          {
            "name": "flowServiceUid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Execution result"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Execute a flow service"
      }
    },
    "/integration/rest/external/v1/connectors": {
      "get": {
        "operationId": "listConnectors",
        "summary": "List available connectors",
        "tags": [
          "Connectors"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List available connectors"
      }
    },
    "/integration/rest/external/v1/connectors/accounts": {
      "get": {
        "operationId": "listConnectorAccounts",
        "summary": "List connector accounts",
        "tags": [
          "Connectors"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List connector accounts"
      }
    },
    "/integration/rest/external/v1/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "List projects",
        "tags": [
          "Projects"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List projects"
      },
      "post": {
        "operationId": "createProject",
        "summary": "Create a project",
        "tags": [
          "Projects"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a project"
      }
    },
    "/integration/rest/external/v1/monitor/executions": {
      "get": {
        "operationId": "monitorExecutions",
        "summary": "Monitor executions",
        "tags": [
          "Monitoring"
        ],
        "parameters": [
          {
            "name": "startDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Execution data"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Monitor executions"
      }
    }
  },
  "components": {
    "schemas": {
      "WorkflowList": {
        "type": "object",
        "properties": {
          "output": {
            "type": "object",
            "properties": {
              "workflows": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "uid": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "created_date": {
                      "type": "string"
                    },
                    "last_modified_date": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "WorkflowInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "output": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string"
              },
              "error_details": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Connectors"
    },
    {
      "name": "Flow Services"
    },
    {
      "name": "Monitoring"
    },
    {
      "name": "Projects"
    },
    {
      "name": "Workflow Execution"
    },
    {
      "name": "Workflows"
    }
  ]
}
