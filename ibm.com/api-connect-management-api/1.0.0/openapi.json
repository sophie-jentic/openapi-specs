{
  "openapi": "3.0.3",
  "info": {
    "title": "IBM API Connect Management API",
    "version": "1.0.0",
    "description": "IBM API Connect Management REST API for managing APIs, products, catalogs, consumer organizations, applications, and subscriptions. Provides full lifecycle API management capabilities including design, secure, socialize, analyze, and monetize.",
    "x-jentic-source-url": "https://www.ibm.com/products/api-connect",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{management-server}/api",
      "variables": {
        "management-server": {
          "default": "api-manager.example.com"
        }
      }
    }
  ],
