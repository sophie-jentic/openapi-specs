      "delete": {
        "operationId": "deleteCloudQueueManager",
        "summary": "Delete a cloud queue manager",
        "description": "Deprovisions and deletes a cloud queue manager",
        "tags": [
          "Queue Managers"
        ],
        "parameters": [
          {
            "name": "serviceInstanceGuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "queueManagerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Deletion accepted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{serviceInstanceGuid}/queue_managers/{queueManagerId}/status": {
      "get": {
        "operationId": "getCloudQueueManagerStatus",
