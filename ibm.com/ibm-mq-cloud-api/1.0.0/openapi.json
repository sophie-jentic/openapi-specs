{
  "openapi": "3.0.3",
  "info": {
    "title": "IBM MQ Cloud API",
    "version": "1.0.0",
    "description": "IBM MQ on Cloud service API for provisioning and managing cloud-hosted queue managers. Provides endpoints for creating, configuring, and monitoring MQ queue managers deployed on IBM Cloud.",
    "x-jentic-source-url": "https://www.ibm.com/cloud/mq",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.{region}.mq2.cloud.ibm.com/v1",
      "description": "IBM MQ on Cloud API",
      "variables": {
        "region": {
          "default": "us-south",
          "description": "IBM Cloud region",
          "enum": [
            "us-south",
            "us-east",
            "eu-gb",
            "eu-de",
            "au-syd"
          ]
        }
      }
    }
  ],
  "paths": {
    "/{serviceInstanceGuid}/queue_managers": {
      "get": {
        "operationId": "listCloudQueueManagers",
        "summary": "List cloud queue managers",
        "description": "Returns a list of queue managers in the MQ on Cloud service instance",
        "tags": [
          "Queue Managers"
        ],
        "parameters": [
          {
            "name": "serviceInstanceGuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Service instance GUID"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Pagination offset"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 25,
              "maximum": 100
            },
            "description": "Number of results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CloudQueueManagerList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCloudQueueManager",
        "summary": "Create a cloud queue manager",
        "description": "Provisions a new queue manager in the MQ on Cloud service",
        "tags": [
          "Queue Managers"
        ],
        "parameters": [
          {
            "name": "serviceInstanceGuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CloudQueueManagerCreate"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Queue manager creation accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CloudQueueManager"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
