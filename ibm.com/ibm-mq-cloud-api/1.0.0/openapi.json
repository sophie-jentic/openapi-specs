  "components": {
    "schemas": {
      "CloudQueueManager": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "size": {
            "type": "string",
            "enum": [
              "xsmall",
              "small",
              "medium",
              "large"
            ]
          },
          "version": {
            "type": "string"
          },
          "statusUri": {
            "type": "string"
          },
          "webConsoleUrl": {
            "type": "string"
          },
          "restApiUrl": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CloudQueueManagerList": {
        "type": "object",
        "properties": {
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "first": {
            "type": "object",
            "properties": {
              "href": {
                "type": "string"
              }
            }
          },
          "next": {
            "type": "object",
            "properties": {
              "href": {
                "type": "string"
              }
            }
          },
          "queue_managers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CloudQueueManager"
            }
          }
        }
      },
      "CloudQueueManagerCreate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Queue manager name (max 48 chars)"
          },
          "displayName": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "size": {
            "type": "string",
            "enum": [
              "xsmall",
              "small",
              "medium",
              "large"
            ]
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "location",
          "size"
        ]
      },
      "QueueManagerStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "initializing",
              "running",
              "deleting",
              "error",
              "stopped"
            ]
          }
        }
      },
      "CloudUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "href": {
            "type": "string"
          }
        }
      },
      "UserList": {
        "type": "object",
        "properties": {
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CloudUser"
            }
          }
        }
      },
      "UserCreate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "email"
        ]
      },
      "Application": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time"
          }
