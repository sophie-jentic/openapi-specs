            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "toUser": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reassigned"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Reassign a task"
      }
    },
