{
  "openapi": "3.0.3",
  "info": {
    "title": "IBM Business Automation Workflow API",
    "version": "1.0.0",
    "description": "IBM Business Automation Workflow (BAW) REST API for managing business processes, cases, tasks, and workflow operations. Part of IBM Cloud Pak for Business Automation. Provides process instance management, task operations, case management, and process analytics.",
    "x-jentic-source-url": "https://www.ibm.com/products/business-automation-workflow",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}:{port}/rest/bpm/wle/v1",
      "variables": {
        "host": {
          "default": "localhost"
        },
        "port": {
          "default": "9443"
        }
      }
    }
  ],
  "paths": {
    "/processes": {
      "get": {
        "operationId": "listProcessApps",
        "summary": "List process applications",
        "tags": [
          "Processes"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List process applications"
      },
      "post": {
        "operationId": "startProcess",
        "summary": "Start a process",
        "tags": [
          "Processes"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartProcessInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Process started"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Start a process"
      }
    },
