{
  "openapi": "3.0.3",
  "info": {
    "title": "IBM Operational Decision Manager API",
    "version": "1.0.0",
    "description": "IBM Operational Decision Manager (ODM) REST API for executing decision services, managing rule applications, and governing business rules. Includes Rule Execution Server (RES) REST API for ruleset execution and management, and Decision Center REST API for rule governance.",
    "x-jentic-source-url": "https://www.ibm.com/products/operational-decision-manager",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}:{port}/DecisionService/rest",
      "variables": {
        "host": {
          "default": "localhost"
        },
        "port": {
          "default": "9443"
        }
      }
    }
  ],
  "paths": {
    "/v2/ruleapps": {
      "get": {
        "operationId": "listRuleApps",
        "summary": "List rule applications",
        "tags": [
          "Rule Applications"
        ],
        "parameters": [
          {
            "name": "baseStatus",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "enabled",
                "disabled"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuleAppList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List rule applications"
      },
      "post": {
        "operationId": "deployRuleApp",
        "summary": "Deploy a rule application",
        "tags": [
          "Rule Applications"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Deployed"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Deploy a rule application"
      }
    },
    "/v2/ruleapps/{ruleAppName}": {
      "get": {
        "operationId": "getRuleApp",
        "summary": "Get a rule application",
        "tags": [
          "Rule Applications"
        ],
        "parameters": [
          {
            "name": "ruleAppName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a rule application"
      },
      "delete": {
        "operationId": "deleteRuleApp",
        "summary": "Delete a rule application",
        "tags": [
          "Rule Applications"
        ],
        "parameters": [
          {
            "name": "ruleAppName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete a rule application"
      }
    },
    "/v2/ruleapps/{ruleAppName}/{rulesetName}": {
      "get": {
        "operationId": "getRuleset",
        "summary": "Get a ruleset",
        "tags": [
          "Rulesets"
        ],
        "parameters": [
          {
            "name": "ruleAppName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rulesetName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a ruleset"
      }
    },
    "/v2/ruleapps/{ruleAppName}/{rulesetVersion}/{rulesetName}/execute": {
      "post": {
        "operationId": "executeRuleset",
        "summary": "Execute a ruleset",
        "description": "Executes the specified version of a ruleset within a rule application.",
        "tags": [
          "Execution"
        ],
        "parameters": [
          {
            "name": "ruleAppName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rulesetVersion",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rulesetName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecutionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Execution result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecutionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Ruleset not found"
          }
        }
      }
    },
    "/v2/ruleapps/{ruleAppName}/{rulesetName}/execute": {
      "post": {
        "operationId": "executeLatestRuleset",
        "summary": "Execute latest version of a ruleset",
        "tags": [
          "Execution"
        ],
        "parameters": [
          {
            "name": "ruleAppName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rulesetName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecutionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Execution result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecutionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Execute latest version of a ruleset"
      }
    },
    "/v1/decisionservices": {
      "get": {
        "operationId": "listDecisionServices",
        "summary": "List decision services",
        "tags": [
          "Decision Services"
        ],
        "responses": {
          "200": {
            "description": "List of decision services"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List decision services"
      }
    },
    "/v1/decisionservices/{dsId}": {
      "get": {
        "operationId": "getDecisionService",
        "summary": "Get a decision service",
        "tags": [
          "Decision Services"
        ],
        "parameters": [
          {
            "name": "dsId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a decision service"
      }
    },
    "/v1/decisionservices/{dsId}/execute": {
      "post": {
        "operationId": "executeDecisionService",
        "summary": "Execute a decision service",
        "tags": [
          "Decision Services"
        ],
        "parameters": [
          {
            "name": "dsId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecutionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Execution result"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Execute a decision service"
      }
    },
    "/v2/status": {
      "get": {
        "operationId": "getServerStatus",
        "summary": "Get server status",
        "tags": [
          "Server"
        ],
        "responses": {
          "200": {
            "description": "Server status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerStatus"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get server status"
      }
    },
    "/v2/diagnostics": {
      "get": {
        "operationId": "getDiagnostics",
        "summary": "Get server diagnostics",
        "tags": [
          "Server"
        ],
        "responses": {
          "200": {
            "description": "Diagnostics information"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get server diagnostics"
      }
    }
  },
  "components": {
    "schemas": {
      "RuleAppList": {
        "type": "object",
        "properties": {
          "ruleApps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "version": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ExecutionRequest": {
        "type": "object",
        "properties": {
          "__DecisionID__": {
            "type": "string"
          },
          "input": {
            "type": "object",
            "description": "Input parameters matching the ruleset signature"
          }
        }
      },
      "ExecutionResponse": {
        "type": "object",
        "properties": {
          "__DecisionID__": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "__executionInfo__": {
            "type": "object",
            "properties": {
              "executionDuration": {
                "type": "integer"
              },
              "rulesFired": {
                "type": "integer"
              }
            }
          }
        }
      },
      "ServerStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "nbRuleApps": {
            "type": "integer"
          },
          "nbRulesets": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Decision Services"
    },
    {
      "name": "Execution"
    },
    {
      "name": "Rule Applications"
    },
    {
      "name": "Rulesets"
    },
    {
      "name": "Server"
    }
  ]
}
