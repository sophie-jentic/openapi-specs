{
  "openapi": "3.0.3",
  "info": {
    "title": "TeamBuildr Strength API",
    "version": "1.0.0",
    "description": "TeamBuildr is a strength and conditioning platform. The API provides access to athletes, workouts, exercises, and performance tracking.",
    "x-jentic-source-url": "https://app.teambuildr.com/api/docs/gymaware",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.teambuildr.com/v1"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/athletes": {
      "get": {
        "summary": "List Athletes",
        "description": "Retrieve a list of athletes",
        "operationId": "listAthletes",
        "tags": [
          "Athletes"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "team_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Athlete"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      },
      "post": {
        "summary": "Create Athlete",
        "description": "Create a new athlete",
        "operationId": "createAthlete",
        "tags": [
          "Athletes"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AthleteRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Athlete created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Athlete"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/athletes/{athlete_id}": {
      "get": {
        "summary": "Get Athlete",
        "description": "Retrieve a specific athlete",
        "operationId": "getAthlete",
        "tags": [
          "Athletes"
        ],
        "parameters": [
          {
            "name": "athlete_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Athlete"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      },
      "put": {
        "summary": "Update Athlete",
        "description": "Update an athlete",
        "operationId": "updateAthlete",
        "tags": [
          "Athletes"
        ],
        "parameters": [
          {
            "name": "athlete_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AthleteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Athlete updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Athlete"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete Athlete",
        "description": "Delete an athlete",
        "operationId": "deleteAthlete",
        "tags": [
          "Athletes"
        ],
        "parameters": [
          {
            "name": "athlete_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Athlete deleted"
          }
        }
      }
    },
    "/workouts": {
      "get": {
        "summary": "List Workouts",
        "description": "Retrieve a list of workouts",
        "operationId": "listWorkouts",
        "tags": [
          "Workouts"
        ],
        "parameters": [
          {
            "name": "athlete_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Workout"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Workout",
        "description": "Create a new workout",
        "operationId": "createWorkout",
        "tags": [
          "Workouts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkoutRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workout created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Workout"
                }
              }
            }
          }
        }
      }
    },
    "/workouts/{workout_id}": {
      "get": {
        "summary": "Get Workout",
        "description": "Retrieve a specific workout",
        "operationId": "getWorkout",
        "tags": [
          "Workouts"
        ],
        "parameters": [
          {
            "name": "workout_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Workout"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete Workout",
        "description": "Delete a workout",
        "operationId": "deleteWorkout",
        "tags": [
          "Workouts"
        ],
        "parameters": [
          {
            "name": "workout_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Workout deleted"
          }
        }
      }
    },
    "/exercises": {
      "get": {
        "summary": "List Exercises",
        "description": "Retrieve a list of exercises",
        "operationId": "listExercises",
        "tags": [
          "Exercises"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Exercise"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Exercise",
        "description": "Create a new exercise",
        "operationId": "createExercise",
        "tags": [
          "Exercises"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExerciseRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Exercise created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Exercise"
                }
              }
            }
          }
        }
      }
    },
    "/exercises/{exercise_id}": {
      "get": {
        "summary": "Get Exercise",
        "description": "Retrieve a specific exercise",
        "operationId": "getExercise",
        "tags": [
          "Exercises"
        ],
        "parameters": [
          {
            "name": "exercise_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Exercise"
                }
              }
            }
          }
        }
      }
    },
    "/performance": {
      "get": {
        "summary": "Get Performance Data",
        "description": "Retrieve performance metrics and statistics",
        "operationId": "getPerformanceData",
        "tags": [
          "Performance"
        ],
        "parameters": [
          {
            "name": "athlete_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PerformanceData"
                }
              }
            }
          }
        }
      }
    },
    "/teams": {
      "get": {
        "summary": "List Teams",
        "description": "Retrieve a list of teams",
        "operationId": "listTeams",
        "tags": [
          "Teams"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Team"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key authentication"
      }
    },
    "schemas": {
      "Athlete": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "team_id": {
            "type": "string"
          },
          "height": {
            "type": "number"
          },
          "weight": {
            "type": "number"
          },
          "position": {
            "type": "string"
          }
        }
      },
      "AthleteRequest": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "email"
        ],
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "team_id": {
            "type": "string"
          },
          "height": {
            "type": "number"
          },
          "weight": {
            "type": "number"
          }
        }
      },
      "Workout": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "athlete_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "exercises": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkoutExercise"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "WorkoutRequest": {
        "type": "object",
        "required": [
          "athlete_id",
          "name"
        ],
        "properties": {
          "athlete_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "exercises": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Exercise": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "muscle_groups": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "equipment": {
            "type": "string"
          }
        }
      },
      "ExerciseRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "equipment": {
            "type": "string"
          }
        }
      },
      "WorkoutExercise": {
        "type": "object",
        "properties": {
          "exercise_id": {
            "type": "string"
          },
          "sets": {
            "type": "integer"
          },
          "reps": {
            "type": "integer"
          },
          "weight": {
            "type": "number"
          }
        }
      },
      "PerformanceData": {
        "type": "object",
        "properties": {
          "athlete_id": {
            "type": "string"
          },
          "metrics": {
            "type": "object",
            "additionalProperties": true
          },
          "workouts_completed": {
            "type": "integer"
          },
          "total_volume": {
            "type": "number"
          }
        }
      },
      "Team": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "sport": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "ErrorResponse": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "UnauthorizedError": {
        "description": "Authentication required",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Athletes",
      "description": "Athlete management"
    },
    {
      "name": "Workouts",
      "description": "Workout management"
    },
    {
      "name": "Exercises",
      "description": "Exercise catalog"
    },
    {
      "name": "Performance",
      "description": "Performance tracking"
    },
    {
      "name": "Teams",
      "description": "Team management"
    }
  ]
}
