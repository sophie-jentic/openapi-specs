  "components": {
    "schemas": {
      "EventSearchResponse": {
        "type": "object",
        "properties": {
          "min_id": {
            "type": "string"
          },
          "max_id": {
            "type": "string"
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          },
          "reached_beginning": {
            "type": "boolean"
          },
          "reached_end": {
            "type": "boolean"
          },
          "min_time_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "received_at": {
            "type": "string",
            "format": "date-time"
          },
          "display_received_at": {
            "type": "string"
          },
          "source_id": {
            "type": "integer"
          },
          "source_name": {
            "type": "string"
          },
          "source_ip": {
            "type": "string"
          },
          "facility": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "hostname": {
            "type": "string"
          },
          "program": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "System": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "last_event_at": {
            "type": "string",
            "format": "date-time"
          },
          "auto_delete": {
            "type": "boolean"
          },
          "ip_address": {
            "type": "string"
          },
          "hostname": {
            "type": "string"
          },
          "syslog": {
            "type": "object",
            "properties": {
              "hostname": {
                "type": "string"
              },
              "port": {
                "type": "integer"
              }
            }
          }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
