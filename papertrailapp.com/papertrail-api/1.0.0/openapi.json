{
  "openapi": "3.0.3",
  "info": {
    "title": "Papertrail API",
    "version": "1.0.0",
    "description": "Papertrail is a cloud-hosted log management service. The HTTP API provides access to log events, systems, groups, saved searches, users, and log archives.",
    "x-jentic-source-url": "https://www.papertrail.com/help/http-api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://papertrailapp.com/api/v1"
    }
  ],
  "paths": {
    "/events/search.json": {
      "get": {
        "operationId": "searchEvents",
        "summary": "Search log events",
        "tags": [
          "Events"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "system_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by system ID"
          },
          {
            "name": "group_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by group ID"
          },
          {
            "name": "min_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Minimum event ID for pagination"
          },
          {
            "name": "max_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Maximum event ID for pagination"
          },
          {
            "name": "min_time",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Minimum time (Unix epoch seconds)"
          },
          {
            "name": "max_time",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Maximum time (Unix epoch seconds)"
          },
          {
            "name": "tail",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Tail mode - return latest events"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Search log events"
      }
    },
