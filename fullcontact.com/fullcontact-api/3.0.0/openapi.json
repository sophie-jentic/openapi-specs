{
  "openapi": "3.0.3",
  "info": {
    "title": "FullContact Enrich API",
    "description": "FullContact's Enrich API resolves person and company data from fragmented identifiers. Provide emails, phones, names, addresses, social profiles, or MAIDs to get enriched contact information including demographics, social profiles, and employment data.",
    "version": "3.0.0",
    "contact": {
      "name": "FullContact Support",
      "url": "https://docs.fullcontact.com/"
    }
  },
  "servers": [
    {
      "url": "https://api.fullcontact.com/v3",
      "description": "FullContact API v3"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/person.enrich": {
      "post": {
        "operationId": "enrichPerson",
        "summary": "Enrich a person",
        "description": "Enrich person data using multi-field identifiers. Provide one or more identifiers (email, phone, name+address, social profiles, MAIDs) to receive enriched person data including demographics, employment, and social profiles.",
        "tags": [
          "Enrich"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PersonEnrichRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Person found and enriched",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersonEnrichResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request (e.g., more than 25 identifiers per type)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Person not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/company.enrich": {
      "post": {
        "operationId": "enrichCompany",
        "summary": "Enrich a company",
        "description": "Enrich company data by providing a domain name. Returns company details including name, location, industry, employee count, and social profiles.",
        "tags": [
          "Enrich"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompanyEnrichRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Company found and enriched",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanyEnrichResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Company not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/identity.map": {
      "post": {
        "operationId": "identityMap",
        "summary": "Map a customer record",
        "description": "Map fragmented customer identifiers to a unified PersonID in the FullContact Identity Graph. Use this to create or update identity mappings.",
        "tags": [
          "Resolve"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IdentityMapRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record mapped successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IdentityMapResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/identity.resolve": {
      "post": {
        "operationId": "identityResolve",
        "summary": "Resolve a customer record",
        "description": "Resolve fragmented identifiers to a PersonID and return all associated identifiers. Maps and resolves in a single call.",
        "tags": [
          "Resolve"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IdentityResolveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record resolved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IdentityResolveResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/identity.mapResolve": {
      "post": {
        "operationId": "identityMapResolve",
        "summary": "Map and resolve a customer record",
        "description": "Combines map and resolve operations into a single call. Maps provided identifiers and returns the resolved PersonID with all associated identifiers.",
        "tags": [
          "Resolve"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IdentityResolveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record mapped and resolved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IdentityResolveResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/identity.delete": {
      "post": {
        "operationId": "identityDelete",
        "summary": "Delete a customer record",
        "description": "Delete a mapped customer record from the FullContact Identity Graph by recordId.",
        "tags": [
          "Resolve"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "recordId"
                ],
                "properties": {
                  "recordId": {
                    "type": "string",
                    "description": "The client-driven record identifier to delete."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Record not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/tags.create": {
      "post": {
        "operationId": "createTag",
        "summary": "Create customer tags",
        "description": "Create tags for a customer record identified by recordId.",
        "tags": [
          "Tags"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "recordId",
                  "tags"
                ],
                "properties": {
                  "recordId": {
                    "type": "string",
                    "description": "The client-driven record identifier."
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "key": {
                          "type": "string"
                        },
                        "value": {
                          "type": "string"
                        }
                      }
                    },
                    "description": "List of key-value tag pairs."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tags created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/tags.get": {
      "post": {
        "operationId": "getTags",
        "summary": "Get customer tags",
        "description": "Retrieve tags for a customer record identified by recordId.",
        "tags": [
          "Tags"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
