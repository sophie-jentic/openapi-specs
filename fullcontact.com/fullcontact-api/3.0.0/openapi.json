                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "FullContact API key passed as a Bearer token in the Authorization header."
      }
    },
    "schemas": {
      "PersonEnrichRequest": {
        "type": "object",
        "description": "Multi-field request for person enrichment. Provide at least one identifier.",
        "properties": {
          "email": {
            "type": "string",
            "description": "A single email address (cleartext, MD5, or SHA-256 hash; must be lowercase and trimmed)."
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Multiple email addresses (max 25)."
          },
          "phone": {
            "type": "string",
            "description": "A single phone number (international numbers require country codes)."
          },
          "phones": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Multiple phone numbers (max 25)."
          },
          "name": {
            "type": "object",
            "description": "Person name (queryable only with location).",
            "properties": {
              "full": {
                "type": "string",
                "description": "Full name."
              },
              "given": {
                "type": "string",
                "description": "First name."
              },
              "family": {
                "type": "string",
                "description": "Last name."
              }
            }
          },
          "location": {
            "type": "object",
            "description": "Location (queryable only with name).",
            "properties": {
              "addressLine1": {
                "type": "string"
              },
              "addressLine2": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "region": {
                "type": "string"
              },
              "regionCode": {
                "type": "string"
              },
              "postalCode": {
                "type": "string"
              }
            }
          },
          "profiles": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "service": {
                  "type": "string",
                  "description": "Social platform name (e.g., twitter, linkedin)."
                },
                "url": {
                  "type": "string",
                  "description": "Profile URL."
                },
                "id": {
                  "type": "string",
                  "description": "Profile ID."
                },
                "username": {
                  "type": "string",
                  "description": "Profile username."
                }
              }
            },
            "description": "Social platform profiles."
          },
          "maids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Mobile Advertising IDs."
          },
          "recordId": {
            "type": "string",
            "description": "Client-driven record identifier."
          },
          "personId": {
            "type": "string",
            "description": "FullContact PersonID."
          },
          "li_nonid": {
            "type": "string",
            "description": "LiveIntent pre-authenticated digital nonID."
          }
        }
      },
      "PersonEnrichResponse": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string"
          },
          "ageRange": {
            "type": "string"
          },
          "gender": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "organization": {
            "type": "string"
          },
          "twitter": {
            "type": "string"
          },
          "linkedin": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          },
          "avatar": {
            "type": "string",
            "format": "uri"
          },
          "details": {
            "type": "object",
            "description": "Additional data from enabled Insights Bundles.",
            "properties": {
              "demographics": {
                "type": "object",
                "properties": {
                  "age": {
                    "type": "integer"
                  },
                  "ageRange": {
                    "type": "string"
                  },
                  "gender": {
                    "type": "string"
                  },
                  "locationGeneral": {
                    "type": "string"
                  }
                }
              },
              "employment": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    },
                    "domain": {
                      "type": "string"
                    },
                    "current": {
                      "type": "boolean"
                    }
                  }
                }
              },
              "education": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
