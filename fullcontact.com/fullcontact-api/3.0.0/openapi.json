              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "recordId": {
                      "type": "string"
                    },
                    "tags": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "key": {
                            "type": "string"
                          },
                          "value": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tags.delete": {
      "post": {
        "operationId": "deleteTags",
        "summary": "Delete customer tags",
        "description": "Delete tags from a customer record identified by recordId.",
        "tags": [
          "Tags"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "recordId",
                  "tags"
                ],
                "properties": {
                  "recordId": {
                    "type": "string",
                    "description": "The client-driven record identifier."
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "key": {
                          "type": "string"
                        },
                        "value": {
                          "type": "string"
                        }
                      }
                    },
                    "description": "List of tag key-value pairs to delete."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
