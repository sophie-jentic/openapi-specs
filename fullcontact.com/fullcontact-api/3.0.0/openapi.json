                    }
                  }
                }
              },
              "urls": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string",
                      "format": "uri"
                    },
                    "type": {
                      "type": "string"
                    }
                  }
                }
              },
              "interests": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
