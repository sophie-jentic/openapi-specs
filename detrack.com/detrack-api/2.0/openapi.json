{
  "openapi": "3.0.3",
  "info": {
    "title": "Detrack API",
    "description": "Detrack is a delivery management and electronic proof of delivery (ePOD) platform. The Detrack API enables programmatic management of deliveries, collections, vehicles, and real-time tracking for last-mile logistics operations.",
    "version": "2.0",
    "contact": {
      "name": "Detrack",
      "url": "https://www.detrack.com"
    },
    "x-jentic-source-url": "https://www.detrack.com/api-documentation/"
  },
  "servers": [
    {
      "url": "https://app.detrack.com/api/v2",
      "description": "Detrack API v2"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "paths": {
    "/dn/deliveries": {
      "get": {
        "summary": "List deliveries",
        "description": "Retrieve a list of delivery jobs.",
        "operationId": "listDeliveries",
        "tags": ["Deliveries"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination.",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results per page.",
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "date",
            "in": "query",
            "description": "Filter by delivery date (YYYY-MM-DD).",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by delivery status.",
            "schema": { "type": "string", "enum": ["info_recv", "dispatched", "completed", "completed_partial", "failed"] }
          },
          {
            "name": "do_number",
            "in": "query",
            "description": "Filter by delivery order number.",
            "schema": { "type": "string" }
          },
          {
            "name": "assign_to",
            "in": "query",
            "description": "Filter by assigned driver.",
            "schema": { "type": "string" }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort field.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of deliveries.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Delivery" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "summary": "Create deliveries",
        "description": "Create one or more delivery jobs.",
        "operationId": "createDeliveries",
        "tags": ["Deliveries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["data"],
                "properties": {
                  "data": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/DeliveryCreate" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deliveries created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Delivery" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/dn/deliveries/{do_number}": {
      "get": {
        "summary": "Get a delivery",
        "description": "Retrieve a specific delivery by delivery order number.",
        "operationId": "getDelivery",
        "tags": ["Deliveries"],
        "parameters": [
          {
            "name": "do_number",
            "in": "path",
            "required": true,
            "description": "Delivery order number.",
            "schema": { "type": "string" }
          },
          {
            "name": "date",
            "in": "query",
            "description": "Delivery date (YYYY-MM-DD). Required if duplicate DO numbers exist.",
            "schema": { "type": "string", "format": "date" }
          }
        ],
        "responses": {
          "200": {
            "description": "Delivery details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/Delivery" }
                  }
                }
              }
            }
          },
          "404": { "description": "Delivery not found" }
        }
      },
      "put": {
        "summary": "Update a delivery",
        "description": "Update an existing delivery.",
        "operationId": "updateDelivery",
        "tags": ["Deliveries"],
        "parameters": [
          {
            "name": "do_number",
            "in": "path",
            "required": true,
            "description": "Delivery order number.",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": { "$ref": "#/components/schemas/DeliveryUpdate" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Delivery updated.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/Delivery" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "404": { "description": "Delivery not found" }
        }
      },
      "delete": {
        "summary": "Delete a delivery",
        "description": "Delete a delivery by order number.",
        "operationId": "deleteDelivery",
        "tags": ["Deliveries"],
        "parameters": [
          {
            "name": "do_number",
            "in": "path",
            "required": true,
            "description": "Delivery order number.",
            "schema": { "type": "string" }
          },
          {
            "name": "date",
            "in": "query",
            "description": "Delivery date (YYYY-MM-DD).",
            "schema": { "type": "string", "format": "date" }
          }
        ],
        "responses": {
          "200": { "description": "Delivery deleted." },
          "404": { "description": "Delivery not found" }
        }
      }
    },
    "/dn/deliveries/bulk": {
      "post": {
        "summary": "Bulk create deliveries",
        "description": "Create multiple delivery jobs in bulk.",
        "operationId": "bulkCreateDeliveries",
        "tags": ["Deliveries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["data"],
                "properties": {
                  "data": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/DeliveryCreate" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Bulk deliveries created." },
          "400": { "description": "Bad request" }
        }
      },
      "delete": {
        "summary": "Bulk delete deliveries",
        "description": "Delete multiple deliveries in bulk.",
        "operationId": "bulkDeleteDeliveries",
        "tags": ["Deliveries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["data"],
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["do_number", "date"],
                      "properties": {
                        "do_number": { "type": "string" },
                        "date": { "type": "string", "format": "date" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Deliveries deleted." },
          "400": { "description": "Bad request" }
        }
      }
    },
    "/dn/deliveries/reattempt": {
      "post": {
        "summary": "Reattempt deliveries",
        "description": "Reattempt failed delivery jobs.",
        "operationId": "reattemptDeliveries",
        "tags": ["Deliveries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["data"],
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["do_number", "date"],
                      "properties": {
                        "do_number": { "type": "string" },
                        "date": { "type": "string", "format": "date" },
                        "new_date": { "type": "string", "format": "date" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Reattempt created." },
          "400": { "description": "Bad request" }
        }
      }
    },
