  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "API key for authenticating requests. Obtain from the Detrack dashboard."
      }
    },
    "schemas": {
      "Delivery": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "do_number": { "type": "string", "description": "Delivery order number." },
          "date": { "type": "string", "format": "date" },
          "status": { "type": "string", "description": "Delivery status." },
          "address": { "type": "string" },
          "postal_code": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "country": { "type": "string" },
          "deliver_to": { "type": "string", "description": "Recipient name." },
          "phone": { "type": "string" },
          "notify_email": { "type": "string", "format": "email" },
          "assign_to": { "type": "string", "description": "Assigned driver name." },
          "instructions": { "type": "string" },
          "zone": { "type": "string" },
          "lat": { "type": "number" },
          "lng": { "type": "number" },
          "start_date": { "type": "string", "format": "date-time" },
          "eta": { "type": "string", "format": "date-time" },
          "time_window": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DeliveryItem" }
          },
          "pod_time": { "type": "string", "format": "date-time" },
          "pod_signature_url": { "type": "string", "format": "uri" },
          "pod_photo_url": { "type": "string", "format": "uri" },
          "reason": { "type": "string", "description": "Failure reason if applicable." },
          "tracking_url": { "type": "string", "format": "uri" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "DeliveryCreate": {
        "type": "object",
        "required": ["do_number", "date", "address"],
        "properties": {
          "do_number": { "type": "string", "description": "Unique delivery order number." },
          "date": { "type": "string", "format": "date", "description": "Delivery date." },
          "address": { "type": "string" },
          "postal_code": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "country": { "type": "string" },
          "deliver_to": { "type": "string" },
          "phone": { "type": "string" },
          "notify_email": { "type": "string", "format": "email" },
          "assign_to": { "type": "string", "description": "Driver name to assign." },
          "instructions": { "type": "string" },
          "zone": { "type": "string" },
          "time_window": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DeliveryItem" }
          }
        }
      },
      "DeliveryUpdate": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "address": { "type": "string" },
          "postal_code": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "country": { "type": "string" },
          "deliver_to": { "type": "string" },
          "phone": { "type": "string" },
          "notify_email": { "type": "string", "format": "email" },
          "assign_to": { "type": "string" },
