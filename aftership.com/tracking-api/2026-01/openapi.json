  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "as-api-key",
        "in": "header",
        "description": "AfterShip API key"
      }
    },
    "schemas": {
      "Tracking": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique ID of the tracking"
          },
          "tracking_number": {
            "type": "string"
          },
          "slug": {
            "type": "string",
            "description": "Courier slug"
          },
          "tag": {
            "type": "string",
            "enum": [
              "Pending",
              "InfoReceived",
              "InTransit",
              "OutForDelivery",
              "AttemptFail",
              "Delivered",
              "AvailableForPickup",
              "Exception",
              "Expired"
            ]
          },
          "subtag": {
            "type": "string"
          },
          "subtag_message": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "order_id": {
            "type": "string"
          },
          "order_number": {
            "type": "string"
          },
          "customer_name": {
            "type": "string"
          },
          "origin_country_iso3": {
            "type": "string"
          },
          "destination_country_iso3": {
            "type": "string"
          },
          "shipment_type": {
            "type": "string"
          },
          "signed_by": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "expected_delivery": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "checkpoints": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Checkpoint"
            }
          },
          "custom_fields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "Checkpoint": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string"
          },
          "checkpoint_time": {
            "type": "string",
            "format": "date-time"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country_iso3": {
            "type": "string"
          },
          "country_name": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          },
          "subtag": {
            "type": "string"
          },
          "subtag_message": {
            "type": "string"
          },
          "zip": {
            "type": "string"
          },
          "location": {
            "type": "string"
          }
        }
      },
      "TrackingListResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "type": "object",
            "properties": {
              "count": {
                "type": "integer"
              },
              "trackings": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Tracking"
                }
              }
            }
          }
        }
      },
      "TrackingResponse": {
        "type": "object",
