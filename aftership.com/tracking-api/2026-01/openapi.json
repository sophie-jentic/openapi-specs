        "operationId": "predictEstimatedDelivery",
        "tags": [
          "Estimated Delivery"
        ],
        "summary": "Predict estimated delivery date",
        "description": "Batch predict estimated delivery dates based on origin, destination, courier, and pickup date.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
