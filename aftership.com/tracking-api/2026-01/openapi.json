              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Predicted delivery dates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "estimated_delivery_dates": {
                          "type": "array",
