    "/trackings/{id}/mark-as-completed": {
      "post": {
        "operationId": "markTrackingCompleted",
        "tags": [
          "Trackings"
        ],
        "summary": "Mark a tracking as completed",
        "description": "Mark a tracking as completed with a given reason (DELIVERED, LOST, RETURNED_TO_SENDER).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Tracking ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "reason"
                ],
                "properties": {
                  "reason": {
                    "type": "string",
                    "enum": [
                      "DELIVERED",
                      "LOST",
                      "RETURNED_TO_SENDER"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tracking marked as completed",
