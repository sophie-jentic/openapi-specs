{
  "openapi": "3.0.3",
  "info": {
    "title": "AfterShip Tracking API",
    "version": "2026-01",
    "description": "AfterShip Tracking API enables e-commerce businesses to track shipments across 1,100+ carriers worldwide. Create, update, and manage trackings with real-time checkpoint data and webhook notifications.",
    "x-jentic-source-url": "https://www.aftership.com/docs/tracking",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.aftership.com/tracking/2026-01",
      "description": "AfterShip Tracking API"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Trackings",
      "description": "Create, manage and retrieve shipment trackings"
    },
    {
      "name": "Couriers",
      "description": "Courier detection and information"
    },
    {
      "name": "Estimated Delivery",
      "description": "Estimated delivery date predictions"
    },
    {
      "name": "Notifications",
      "description": "Notification management for trackings"
    }
  ],
  "paths": {
    "/trackings": {
      "get": {
        "operationId": "getTrackings",
        "tags": [
          "Trackings"
        ],
        "summary": "Get trackings",
        "description": "Get tracking results of multiple trackings. Supports pagination, filtering by keyword, tag, courier slug, delivery status, and date range.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page to display"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 200
            },
            "description": "Number of trackings per page (max 200)"
          },
          {
            "name": "keyword",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search keyword for tracking number, order ID, etc."
          },
          {
            "name": "slug",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Courier slug to filter by"
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "Pending",
                "InfoReceived",
                "InTransit",
                "OutForDelivery",
                "AttemptFail",
                "Delivered",
                "AvailableForPickup",
                "Exception",
                "Expired"
              ]
            },
            "description": "Tracking status tag"
          },
          {
            "name": "created_at_min",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start date for creation filter (ISO 8601)"
          },
          {
            "name": "created_at_max",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End date for creation filter (ISO 8601)"
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of fields to return"
          },
          {
            "name": "origin",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Origin country ISO3 code"
          },
          {
            "name": "destination",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Destination country ISO3 code"
          }
        ],
        "responses": {
          "200": {
            "description": "List of trackings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackingListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createTracking",
        "tags": [
          "Trackings"
        ],
        "summary": "Create a tracking",
        "description": "Create a tracking with tracking number and optionally specify slug. Auto-detects courier if slug is not provided.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTrackingRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tracking created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Tracking already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/trackings/{id}": {
      "get": {
        "operationId": "getTrackingById",
