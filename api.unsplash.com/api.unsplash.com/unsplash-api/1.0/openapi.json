    "/photos/random": {
      "get": {
        "operationId": "getRandomPhoto",
        "summary": "Get a random photo",
        "parameters": [
          {
            "name": "collections",
            "in": "query",
            "description": "Comma-separated collection IDs to narrow selection",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "topics",
            "in": "query",
            "description": "Comma-separated topic IDs",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orientation",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "landscape",
                "portrait",
                "squarish"
              ]
            }
          },
          {
            "name": "content_filter",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "low",
                "high"
              ],
              "default": "low"
            }
          },
          {
            "name": "count",
            "in": "query",
            "description": "Number of photos to return (1-30)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30,
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Random photo(s)",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/Photo"
                    },
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Photo"
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "photos"
        ],
        "description": "Get a random photo"
      }
    },
