    "/users/{username}/photos": {
      "get": {
        "operationId": "getUserPhotos",
        "summary": "List a user's photos",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 30
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "latest",
                "oldest",
                "popular",
                "views",
                "downloads"
              ],
              "default": "latest"
            }
          },
          {
            "name": "stats",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "orientation",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "landscape",
                "portrait",
                "squarish"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of photos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Photo"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "users"
        ],
        "description": "List a user's photos"
      }
    },
