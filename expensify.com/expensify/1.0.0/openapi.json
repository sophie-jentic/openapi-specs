{
  "openapi": "3.0.3",
  "info": {
    "title": "Expensify API",
    "version": "1.0.0",
    "description": "The Expensify Integration Server API allows you to programmatically export expense reports, create reports and expenses, manage employees, and update policy configurations. All requests use a single endpoint with a requestJobDescription JSON payload.",
    "x-jentic-source-url": "https://integrations.expensify.com/Integration-Server/doc/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://integrations.expensify.com/Integration-Server",
      "description": "Expensify Integration Server"
    }
  ],
  "security": [
    {
      "partnerCredentials": []
    }
  ],
  "paths": {
    "/ExpensifyIntegrations": {
      "post": {
        "operationId": "expensifyIntegrations",
        "tags": [
          "Integrations"
        ],
        "summary": "Execute an Expensify integration job",
        "description": "All Expensify API operations are performed via this single endpoint. The job type is specified in the requestJobDescription JSON parameter. Supported job types: file (export), reconciliation, download, create, update, get.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/IntegrationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Job executed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IntegrationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "partnerCredentials": {
        "type": "apiKey",
        "in": "query",
        "name": "partnerUserID",
        "description": "Partner credentials are passed within the requestJobDescription JSON payload as partnerUserID and partnerUserSecret"
      }
    },
    "schemas": {
      "IntegrationRequest": {
        "type": "object",
        "required": [
          "requestJobDescription"
        ],
        "properties": {
          "requestJobDescription": {
            "type": "string",
            "description": "JSON string describing the job. Must include type, credentials, and inputSettings."
          },
          "template": {
            "type": "string",
            "description": "Freemarker template for export jobs (file extension .ftl)"
          }
        }
      },
      "JobDescription": {
        "type": "object",
        "required": [
          "type",
          "credentials"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "file",
              "reconciliation",
              "download",
              "create",
              "update",
              "get"
            ],
            "description": "Job type to execute"
          },
          "credentials": {
            "$ref": "#/components/schemas/Credentials"
          },
          "inputSettings": {
            "$ref": "#/components/schemas/InputSettings"
          },
          "outputSettings": {
            "$ref": "#/components/schemas/OutputSettings"
          },
          "onReceive": {
            "type": "object",
            "properties": {
              "immediateResponse": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "onFinish": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OnFinishAction"
            }
          },
          "test": {
            "type": "boolean",
            "description": "If true, onFinish actions will not be executed"
          }
        }
      },
      "Credentials": {
        "type": "object",
        "required": [
          "partnerUserID",
          "partnerUserSecret"
        ],
        "properties": {
          "partnerUserID": {
            "type": "string",
            "description": "Your Expensify partner user ID"
          },
          "partnerUserSecret": {
            "type": "string",
            "description": "Your Expensify partner user secret"
          }
        }
      },
      "InputSettings": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "combinedReportData",
              "reconciliation",
              "report",
              "expenses",
              "policy",
              "policyList",
              "employees",
              "expenseRules",
              "domainCardList",
              "reportStatus",
              "tagApprovers"
            ],
            "description": "Type of input settings"
          },
          "reportState": {
            "type": "string",
            "description": "Filter by report state: OPEN, SUBMITTED, APPROVED, REIMBURSED, ARCHIVED"
          },
          "limit": {
            "type": "string",
            "description": "Max number of reports to export"
          },
          "employeeEmail": {
            "type": "string",
            "format": "email"
          },
          "filters": {
            "$ref": "#/components/schemas/InputFilters"
          },
          "policyID": {
            "type": "string"
          },
          "policyIDList": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "adminOnly": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "REIMBURSED"
            ]
          },
          "paymentSource": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          },
          "feed": {
            "type": "string"
          },
          "async": {
            "type": "boolean"
          },
          "report": {
            "$ref": "#/components/schemas/ReportInput"
          },
          "expenses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExpenseInput"
            }
          },
          "transactionList": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExpenseInput"
            }
          },
          "fileType": {
            "type": "string"
          },
          "policyName": {
            "type": "string"
          },
          "plan": {
            "type": "string",
            "enum": [
              "team",
              "corporate"
            ]
          }
        }
      },
      "InputFilters": {
        "type": "object",
        "properties": {
          "reportIDList": {
            "type": "string"
          },
          "policyIDList": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          },
          "approvedAfter": {
            "type": "string",
            "format": "date"
          },
          "markedAsExported": {
            "type": "string"
          }
        }
      },
      "OutputSettings": {
        "type": "object",
        "properties": {
          "fileExtension": {
            "type": "string",
            "description": "Output format: csv, xls, xlsx, txt, pdf, json, xml"
          },
          "fileBasename": {
            "type": "string"
          },
          "includeFullPageReceiptsPdf": {
            "type": "boolean"
          }
        }
      },
      "OnFinishAction": {
        "type": "object",
        "properties": {
          "actionName": {
            "type": "string",
            "enum": [
              "email",
              "markAsExported",
              "sftpUpload"
            ]
          },
          "recipients": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      },
      "ReportInput": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "fields": {
            "type": "object"
          }
        }
      },
      "ExpenseInput": {
        "type": "object",
        "required": [
          "merchant",
          "currency",
          "amount"
        ],
        "properties": {
          "merchant": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "created": {
            "type": "string",
            "format": "date"
          },
          "amount": {
            "type": "integer",
            "description": "Amount in cents"
          },
          "category": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          },
          "billable": {
            "type": "boolean"
          },
          "reimbursable": {
            "type": "boolean"
          },
          "comment": {
            "type": "string"
          },
          "reportID": {
            "type": "string"
          },
          "policyID": {
            "type": "string"
          },
          "externalID": {
            "type": "string"
          },
          "tax": {
            "$ref": "#/components/schemas/TaxInput"
          }
        }
      },
      "TaxInput": {
        "type": "object",
        "properties": {
          "rateID": {
            "type": "string"
          },
          "amount": {
            "type": "integer"
          }
        }
      },
      "IntegrationResponse": {
        "type": "object",
        "properties": {
          "responseCode": {
            "type": "integer"
          },
          "responseMessage": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "reportName": {
            "type": "string"
          },
          "reportID": {
            "type": "string"
          },
          "policyID": {
            "type": "string"
          },
          "policyName": {
            "type": "string"
          },
          "nbEmployees": {
            "type": "integer"
          },
          "policyInfo": {
            "type": "object"
          },
          "policyList": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "domainCardList": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "transactionList": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExpenseInput"
            }
          },
          "reportIDs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "skippedReports": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "failedReports": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "responseCode": {
            "type": "integer"
          },
          "responseMessage": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Integrations"
    }
  ]
}
