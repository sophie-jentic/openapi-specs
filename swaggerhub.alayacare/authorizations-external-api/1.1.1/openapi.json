{
  "openapi": "3.0.1",
  "info": {
    "title": "Authorizations External API",
    "description": "The external API for the authorizations feature in api.scheduler.",
    "version": "1.1.1",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/AlayaCare/authorizations-external_api/1.1.1/swagger.json",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://virtserver.swaggerhub.com/api.scheduler"
    }
  ],
  "paths": {
    "/authorizations": {
      "get": {
        "tags": [
          "Authorizations"
        ],
        "summary": "Fetches a list of authorizations",
        "description": "Fetches a list of authorizations\n",
        "parameters": [
          {
            "name": "start_at_from",
            "in": "query",
            "description": "The minumum start at of the authorization.",
            "required": true,
            "schema": {
              "type": "string",
              "example": "2022-01-13"
            }
          },
          {
            "name": "start_at_to",
            "in": "query",
            "description": "The maximum start at of the authorization",
            "required": true,
            "schema": {
              "type": "string",
              "example": "2022-01-13"
            }
          },
          {
            "name": "end_at_from",
            "in": "query",
            "description": "The minumum end at of the authorization",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2022-01-13"
            }
          },
          {
            "name": "end_at_to",
            "in": "query",
            "description": "The maximum end at of the authorization.",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2022-01-13"
            }
          },
          {
            "name": "client_id",
            "in": "query",
            "description": "The ID of the client which the authorization belongs to.",
            "required": false,
            "schema": {
              "type": "integer",
              "example": 2020
            }
          },
          {
            "name": "authorization_number",
            "in": "query",
            "description": "Substring of the authorization number.",
            "required": false,
            "schema": {
              "type": "string",
              "example": "ABC"
            }
          },
          {
            "name": "service_id",
            "in": "query",
            "description": "IDs of the service linked to the authorization.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer",
                "example": 12
              }
            }
          },
          {
            "name": "bill_code_id",
            "in": "query",
            "description": "IDs of the Bill Codes linked to the authorization.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer",
                "example": 21
              }
            }
          },
          {
            "name": "methodology",
            "in": "query",
            "description": "Methodology of the authorization number.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "payor",
                "payor_bill_code",
                "payor_service"
              ],
              "example": "payor"
            }
          },
          {
            "name": "authorization_status",
            "in": "query",
            "description": "The status of the authorizaton.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "NEW",
                  "PENDING",
                  "PROCESSED"
                ],
                "example": "PROCESSED"
              }
            }
          },
          {
            "name": "payor_id_type",
            "in": "query",
            "description": "Type of the payor ID.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "FUNDER",
                "CONTACT"
              ],
              "example": "FUNDER"
            }
          },
          {
            "name": "payor_id",
            "in": "query",
            "description": "The IDs of the payer.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer",
                "example": 12
              }
            }
          },
          {
            "name": "first_day_of_week",
            "in": "query",
            "description": "The authorization's first day of the week.",
            "required": false,
            "schema": {
              "type": "integer",
              "example": 12
            }
          },
          {
            "name": "exclude_authorizations_with_items",
            "in": "query",
            "description": "If True, it will exclude from the result all authorizations with usage items linked to it.",
            "required": false,
            "schema": {
              "type": "boolean",
              "example": true
            }
          },
          {
            "$ref": "#/components/parameters/pageParam"
          },
          {
            "$ref": "#/components/parameters/countParam"
          }
        ],
        "responses": {
          "200": {
            "description": "List of authorizations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorizationList"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/InvalidEnumExceptionSchema"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserNotAuthenticatedExceptionSchema"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden request error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForbiddenExceptionSchema"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected Error",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "code": "500",
                    "message": "An unexpected error has occurred. Please, try again."
                  }
                }
              }
            }
          }
        },
        "operationId": "get-authorizations"
      },
      "post": {
        "tags": [
          "Authorizations"
        ],
        "summary": "Creates a new authorization",
        "requestBody": {
          "description": "It creates a new authorization.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAuthorization"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Authorization created.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseAuthorization"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/BadRequestExceptionSchema"
                    }
                  ]
                },
                "examples": {
                  "InvalidStartDate": {
                    "summary": "Invalid Start Date",
                    "value": {
                      "code": "400",
                      "message": "`start_at` cannot be more than 1 year in the past."
                    }
                  },
                  "InvalidEndDate": {
                    "summary": "Invalid End Date",
                    "value": {
                      "code": "400",
                      "message": "`end_at` should be the same or after `start_at`"
                    }
                  },
                  "InvalidPayorId": {
                    "summary": "Invalid Payor ID",
                    "value": {
                      "code": "400",
                      "message": "`payor_id` and `payor_id_type` is required when `methodology` is `payor`, payor_bill_code, payor_service."
                    }
                  },
                  "InvalidClientID": {
                    "summary": "Invalid Client ID",
                    "value": {
                      "code": "400",
                      "message": "Client ID not found."
                    }
                  },
                  "InvalidBillCodeID": {
                    "summary": "Invalid Billcode(s) ID",
                    "value": {
                      "code": "400",
                      "message": "Bill Code(s) ID not found."
                    }
                  },
                  "InvalidServiceID": {
                    "summary": "Invalid Service(s) ID",
                    "value": {
                      "code": "400",
                      "message": "Service(s) IDs are not funded by the Payor ID 12"
                    }
                  },
                  "InvalidRuleType": {
                    "summary": "Invalid Rule Type",
                    "value": {
                      "code": "400",
                      "message": "Rule Type HOURS is not possible for Payor 12."
                    }
                  },
                  "InvalidRuleDaily": {
                    "summary": "Invalid Rule Daily",
                    "value": {
                      "code": "400",
                      "message": "`rule_daily` must be lower than or equal `rule_monthly`."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserNotAuthenticatedExceptionSchema"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden request error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForbiddenExceptionSchema"
                },
                "examples": {
                  "AuthorizationsFeatureFlagDisabled": {
                    "summary": "Authorizations Feature is Disabled",
                    "value": {
                      "code": "403",
                      "message": "Authorizations feature flag is not enabled for client_id: 2020."
                    }
                  },
                  "UserDoesNotHavePermission": {
                    "summary": "User Does Not Have Permission",
                    "value": {
                      "code": "403",
                      "message": "You do not have permission to perform this action."
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Creates a new authorization",
        "operationId": "post-authorizations"
      }
    },
    "/authorizations/{authorization_id}": {
      "put": {
        "tags": [
          "Authorizations"
        ],
        "summary": "Updates an existing authorization",
        "parameters": [
          {
            "$ref": "#/components/parameters/authorizationIdParam"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAuthorization"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authorization updated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseAuthorization"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequestExceptionSchema"
                },
                "examples": {
                  "EndDateBeforeStartDate": {
                    "summary": "End at before Start at",
                    "value": {
                      "code": "400",
                      "message": "`end_at` should be the same or after `start_at`."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserNotAuthenticatedExceptionSchema"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden request error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForbiddenExceptionSchema"
                },
                "examples": {
                  "AuthorizationsFeatureFlagDisabled": {
                    "summary": "Authoroziations Feature is Disabled",
                    "value": {
                      "code": "403",
                      "message": "Authorizations feature flag is not enabled for client_id: 2020."
                    }
                  },
                  "UserDoesNotHavePermission": {
                    "summary": "User Does Not Have Permission",
                    "value": {
                      "code": "403",
                      "message": "You do not have permission to perform this action."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Authorization Not Found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorizationNotFound"
                }
              }
            }
          }
        },
        "description": "Updates an existing authorization",
        "operationId": "put-authorizations-by-authorization-id"
      },
      "delete": {
        "tags": [
          "Authorizations"
        ],
        "summary": "Deactivates an Authorization",
        "description": "Deletes an Authorization\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/authorizationIdParam"
          }
        ],
        "responses": {
          "204": {
            "description": "Authorization deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "example": ""
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserNotAuthenticatedExceptionSchema"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden request error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForbiddenExceptionSchema"
                },
                "examples": {
                  "AuthorizationsFeatureFlagDisabled": {
                    "summary": "Authoroziations Feature is Disabled",
                    "value": {
                      "code": "403",
                      "message": "Authorizations feature flag is not enabled for authorization_id: 1"
                    }
                  },
                  "UserDoesNotHavePermission": {
                    "summary": "User Does Not Have Permission",
                    "value": {
                      "code": "403",
                      "message": "You do not have permission to perform this action."
                    }
                  },
                  "AuthorizationCanNotBeDeleted": {
                    "summary": "Authorization can not be deleted",
                    "value": {
                      "code": "403",
                      "message": "Authorization can not be deleted."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Authorization Not Found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorizationNotFound"
                }
              }
            }
          }
        },
        "operationId": "delete-authorizations-by-authorization-id"
      }
    },
    "/authorizations/medicaid_ids": {
      "post": {
        "tags": [
          "Authorizations"
        ],
        "summary": "Retrieves medicaid IDs for specific client",
        "description": "Retrieves medicaid IDs for a list of specific client ID and a date",
        "requestBody": {
          "description": "Medicaid IDs Request",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MedicaidIdsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of medicaid IDs by client ID and date",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MedicaidIdsResponse"
                }
              }
            }
          }
        },
        "operationId": "post-authorizations-medicaid-ids"
      }
    },
    "/authorizations/{authorization_id}/usages": {
      "get": {
        "tags": [
          "Authorizations Usages"
        ],
        "summary": "Fetches a list of authorizations Usage",
        "description": "Fetches a list of authorizations usage.\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/authorizationIdParam"
          },
          {
            "name": "start_date_from",
            "in": "query",
            "description": "The minumum start at of the authorization.",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2022-01-01"
            }
          },
          {
            "name": "start_date_to",
            "in": "query",
            "description": "The maximum start at of the authorization",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2022-01-01"
            }
          },
          {
            "name": "end_date_from",
            "in": "query",
            "description": "The minumum end at of the authorization",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2022-01-01"
            }
          },
          {
            "name": "end_date_to",
            "in": "query",
            "description": "The maximum end at of the authorization.",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2022-01-01"
            }
          },
          {
            "name": "frequency_type",
            "in": "query",
            "description": "The frequency type of the Authorization Usage.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "DAILY",
                "FRIDAY",
                "MONDAY",
                "MONTHLY",
                "PERIOD",
                "SATURDAY",
                "SUNDAY",
                "THURSDAY",
                "TUESDAY",
                "WEDNESDAY",
                "WEEKLY"
              ],
              "example": "TUESDAY"
            }
          },
          {
            "name": "is_over_utilized",
            "in": "query",
            "description": "Whether the usage is over utilized or not",
            "required": false,
            "schema": {
              "type": "boolean",
              "example": false
            }
          },
          {
            "$ref": "#/components/parameters/pageParam"
          },
          {
            "$ref": "#/components/parameters/countParam"
          }
        ],
        "responses": {
          "200": {
            "description": "List of Authorizations Usage Items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorizationUsageList"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserNotAuthenticatedExceptionSchema"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden request error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForbiddenExceptionSchema"
                }
              }
            }
          }
        },
        "operationId": "get-authorizations-by-authorization-id-usages"
      }
    },
    "/authorizations/items/utilization_status": {
      "post": {
        "tags": [
          "Item Utilization Status"
        ],
        "summary": "It returns the utilization status of an item.",
        "description": "It calculates the utilization status of an item for all authorizations the item is utilizing. It will return 'OVER_UTILIZED' if the item exceeds the authorized quantity or value of at least one authorization, 'UNDER_UTILIZED' if the item does not over utilize any authorization. If no authorizations are calculated for the item, it will return 'UNKNOWN'.",
        "parameters": [
          {
            "name": "items",
            "in": "query",
            "description": "The IDs and types of each item",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthorizationItemList"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of Authorizations Usage Items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorizationItemUtilizationStatusList"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/MissingRequiredParameterExceptionSchema"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserNotAuthenticatedExceptionSchema"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden request error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForbiddenExceptionSchema"
                }
              }
            }
          }
        },
        "operationId": "post-authorizations-items-utilization-status"
      }
    }
  },
  "components": {
    "parameters": {
      "authorizationIdParam": {
        "name": "authorization_id",
        "in": "path",
        "description": "The ID of the authorization",
        "required": true,
        "schema": {
          "type": "integer",
          "example": 1
        }
      },
      "pageParam": {
        "name": "page",
        "description": "Filter by page number.",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 1,
          "example": 2
        }
      },
      "countParam": {
        "name": "count",
        "description": "Number of items per page.",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 100,
          "example": 200
        }
      }
    },
    "schemas": {
      "AuthorizationList": {
        "description": "Paginated list of Authorizations",
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "description": "Number of items in the response",
            "example": 1
          },
          "page": {
            "type": "integer",
            "description": "Current page number",
            "example": 1
          },
          "total_pages": {
            "type": "integer",
            "description": "Total number of pages available",
            "example": 1
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Authorization"
            }
          }
        },
        "required": [
          "items"
        ]
      },
      "Authorization": {
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseAuthorization"
          },
          {
            "type": "object",
            "properties": {
              "service_ids": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "example": 12
                }
              },
              "billcode_ids": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "example": 15
                }
              }
            }
          }
        ]
      },
      "BaseAuthorization": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "client_id": {
            "type": "number",
            "example": 2001
          },
          "authorization_number": {
            "type": "string",
            "example": "ABC123"
          },
          "start_at": {
            "type": "string",
            "example": "2023-03-13"
          },
          "end_at": {
            "type": "string",
            "example": "2023-03-20"
          },
          "member_number": {
            "type": "string",
            "example": "AAAABBBB"
          },
          "program_id": {
            "type": "string",
            "example": "AAAABBBB"
          },
          "case_manager_name": {
            "type": "string",
            "example": "AAAABBBB"
          },
          "case_manager_email": {
            "type": "string",
            "example": "AAAABBBB"
          },
          "case_manager_fax": {
            "type": "string",
            "example": "AAAABBBB"
          },
          "case_manager_phone": {
            "type": "string",
            "example": "AAAABBBB"
          },
          "rule_type": {
            "type": "string",
            "enum": [
              "HOURS",
              "VISITS",
              "RATE"
            ],
            "example": "HOURS"
          },
          "rule_daily": {
            "type": "number",
            "example": 5
          },
          "rule_weekly": {
            "type": "number",
            "example": 70
          },
          "rule_monthly": {
            "type": "number",
            "example": 160
          },
          "rule_period": {
            "type": "number",
            "example": 160
          },
          "rule_monday": {
            "type": "number",
            "example": 1
          },
          "rule_tuesday": {
            "type": "number",
            "example": 2
          },
          "rule_wednesday": {
            "type": "number",
            "example": 2
          },
          "rule_thursday": {
            "type": "number",
            "example": 3
          },
          "rule_friday": {
            "type": "number",
            "example": 2
          },
          "rule_saturday": {
            "type": "number",
            "example": 2
          },
          "rule_sunday": {
            "type": "number",
            "example": 2
          },
          "rule_custom": {
            "type": "number",
            "example": 2
          },
