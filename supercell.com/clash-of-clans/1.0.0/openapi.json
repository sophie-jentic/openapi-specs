    "/clans": {
      "get": {
        "summary": "Search clans",
        "description": "Search all clans by name and/or filtering the results using various criteria",
        "operationId": "searchClans",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search clans by name"
          },
          {
            "name": "warFrequency",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by war frequency"
          },
          {
            "name": "locationId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by location identifier"
          },
          {
            "name": "minMembers",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by minimum number of clan members"
          },
          {
            "name": "maxMembers",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by maximum number of clan members"
          },
          {
            "name": "minClanPoints",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by minimum amount of clan points"
          },
          {
            "name": "minClanLevel",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by minimum clan level"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Limit the number of returned results"
          },
          {
            "name": "after",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Return only items that occur after this marker"
          },
          {
            "name": "before",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Return only items that occur before this marker"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "paging": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "clans"
        ]
      }
    },
