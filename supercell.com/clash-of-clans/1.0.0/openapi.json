  "paths": {
    "/clans/{clanTag}": {
      "get": {
        "summary": "Get clan information",
        "description": "Get information about a single clan by clan tag",
        "operationId": "getClan",
        "parameters": [
          {
            "name": "clanTag",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Tag of the clan (URL encode the # character)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tag": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "location": {
                      "type": "object"
                    },
                    "clanLevel": {
                      "type": "integer"
                    },
                    "clanPoints": {
                      "type": "integer"
                    },
                    "clanVersusPoints": {
                      "type": "integer"
                    },
                    "requiredTrophies": {
                      "type": "integer"
                    },
                    "warFrequency": {
                      "type": "string"
                    },
                    "warWinStreak": {
                      "type": "integer"
                    },
                    "warWins": {
                      "type": "integer"
                    },
                    "warTies": {
                      "type": "integer"
                    },
                    "warLosses": {
                      "type": "integer"
                    },
                    "isWarLogPublic": {
                      "type": "boolean"
                    },
                    "members": {
                      "type": "integer"
                    },
                    "memberList": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Access denied - invalid API key"
          },
          "404": {
            "description": "Clan not found"
          }
        },
        "tags": [
          "clans"
        ]
      }
    },
