{
  "openapi": "3.0.3",
  "info": {
    "title": "ecobee API",
    "version": "1.0.0",
    "description": "The ecobee API provides an HTTP-based interface for control and access to ecobee smart thermostats, including thermostat data retrieval, updates, reports, group management, and demand response operations.",
    "x-jentic-source-url": "https://developer.ecobee.com/home/developer/api/introduction/index.shtml",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.ecobee.com/1"
    }
  ],
  "paths": {
    "/thermostatSummary": {
      "get": {
        "operationId": "getThermostatSummary",
        "summary": "Get thermostat summary (polling)",
        "tags": [
          "Thermostats"
        ],
        "description": "Retrieves a lightweight summary of thermostat data for polling changes",
        "parameters": [
          {
            "name": "json",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "JSON-encoded selection object"
          }
        ],
        "responses": {
          "200": {
            "description": "Summary response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThermostatSummaryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
