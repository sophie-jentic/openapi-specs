{
  "openapi": "3.0.3",
  "info": {
    "title": "Blackfire API",
    "version": "1.0.0",
    "description": "Blackfire is a continuous observability and performance testing platform for PHP, Python, Go, and Node.js applications. The API provides access to profiling data, build management, environment configuration, and organization settings.",
    "x-jentic-source-url": "https://blackfire.io/docs/reference",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://blackfire.io/api/v2",
      "description": "Blackfire API v2"
    }
  ],
  "paths": {
    "/profiles/{uuid}": {
      "get": {
        "operationId": "getProfile",
        "summary": "Get a profile",
        "description": "Retrieves details of a specific profiling result.",
        "tags": [
          "Profiles"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Profile details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Profile"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteProfile",
        "summary": "Delete a profile",
        "tags": [
          "Profiles"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Profile deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Delete a profile"
      }
    },
    "/builds": {
      "get": {
        "operationId": "listBuilds",
        "summary": "List builds",
        "description": "Returns a list of builds for the authenticated environment.",
        "tags": [
          "Builds"
        ],
        "parameters": [
          {
            "name": "environment",
            "in": "query",
            "description": "Environment UUID filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Build list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BuildList"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createBuild",
        "summary": "Create a build",
        "description": "Creates a new build for running performance tests.",
        "tags": [
          "Builds"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBuildRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Build created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Build"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/builds/{uuid}": {
      "get": {
        "operationId": "getBuild",
        "summary": "Get a build",
        "tags": [
          "Builds"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Build details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Build"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a build"
      }
    },
    "/builds/{uuid}/report": {
      "get": {
        "operationId": "getBuildReport",
        "summary": "Get build report",
        "description": "Retrieves the performance test report for a completed build.",
        "tags": [
          "Builds"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Build report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BuildReport"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/environments": {
      "get": {
        "operationId": "listEnvironments",
        "summary": "List environments",
        "tags": [
          "Environments"
        ],
        "responses": {
          "200": {
            "description": "Environment list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnvironmentList"
                }
              }
            }
          }
        },
        "description": "List environments"
      }
    },
    "/environments/{uuid}": {
      "get": {
        "operationId": "getEnvironment",
        "summary": "Get an environment",
        "tags": [
          "Environments"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Environment details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Environment"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get an environment"
      },
      "put": {
        "operationId": "updateEnvironment",
        "summary": "Update an environment",
        "tags": [
          "Environments"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateEnvironmentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Environment updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Environment"
                }
              }
            }
          }
        },
        "description": "Update an environment"
      }
    },
    "/organizations/{uuid}": {
      "get": {
        "operationId": "getOrganization",
        "summary": "Get organization details",
        "tags": [
          "Organizations"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Organization details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Organization"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get organization details"
      }
    },
    "/organizations/{uuid}/members": {
      "get": {
        "operationId": "listOrganizationMembers",
        "summary": "List organization members",
        "tags": [
          "Organizations"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Member list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "members": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Member"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List organization members"
      }
    }
  },
  "components": {
    "schemas": {
      "Profile": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "envelope": {
            "type": "object",
            "description": "Profile envelope containing metadata"
          }
        }
      },
      "Build": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "todo",
              "in-progress",
              "done",
              "errored"
            ]
          },
          "environment": {
            "$ref": "#/components/schemas/EnvironmentRef"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "finished_at": {
            "type": "string",
            "format": "date-time"
          },
          "report_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "BuildList": {
        "type": "object",
        "properties": {
          "builds": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Build"
            }
          },
          "page": {
            "type": "integer"
          },
          "pages": {
            "type": "integer"
          }
        }
      },
      "CreateBuildRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "environment": {
            "type": "string",
            "description": "Environment UUID"
          },
          "trigger_name": {
            "type": "string"
          },
          "external_id": {
            "type": "string"
          },
          "external_parent_id": {
            "type": "string"
          }
        },
        "required": [
          "title"
        ]
      },
      "BuildReport": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "state": {
            "type": "string"
          },
          "nb_successful_scenarios": {
            "type": "integer"
          },
          "nb_failed_scenarios": {
            "type": "integer"
          },
          "scenarios": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Environment": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "organization": {
            "$ref": "#/components/schemas/OrganizationRef"
          }
        }
      },
      "EnvironmentRef": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "EnvironmentList": {
        "type": "object",
        "properties": {
          "environments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Environment"
            }
          }
        }
      },
      "UpdateEnvironmentRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      },
      "Organization": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OrganizationRef": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Member": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "admin",
              "member"
            ]
          }
        }
      }
    },
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication using Blackfire server credentials (Server ID as username, Server Token as password)"
      }
    }
  },
  "security": [
    {
      "BasicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Builds"
    },
    {
      "name": "Environments"
    },
    {
      "name": "Organizations"
    },
    {
      "name": "Profiles"
    }
  ]
}
