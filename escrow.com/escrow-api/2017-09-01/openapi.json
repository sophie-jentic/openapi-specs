  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication with email and API key"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "TransactionInput": {
        "type": "object",
        "required": [
          "parties",
          "items",
          "currency",
          "description"
        ],
        "properties": {
          "parties": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string",
                  "enum": [
                    "buyer",
                    "seller",
                    "broker"
                  ]
                },
                "customer": {
                  "type": "string",
                  "format": "email"
                }
              }
            }
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "general_merchandise",
                    "domain_name",
                    "motor_vehicle"
                  ]
                },
                "inspection_period": {
                  "type": "integer"
                },
                "quantity": {
                  "type": "integer"
                },
                "schedule": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "amount": {
                        "type": "number"
                      },
                      "payer_customer": {
                        "type": "string"
                      },
                      "beneficiary_customer": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "currency": {
            "type": "string",
            "default": "usd"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
