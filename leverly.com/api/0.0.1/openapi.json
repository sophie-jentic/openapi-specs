{
  "openapi": "3.0.3",
  "info": {
    "title": "Leverly API",
    "version": "0.0.1",
    "description": "API for managing leads and call tracking with Leverly",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://app.leverly.com/main/api/v1",
      "description": "Production server"
    }
  ],
  "x-jentic-source-url": "https://app.leverly.com/admin-panel/swagger",
  "paths": {
    "/inquiries/create.json": {
      "post": {
        "tags": [
          "Call"
        ],
        "summary": "Post lead",
        "description": "Create a new inquiry/lead for call tracking",
        "operationId": "createInquiry",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/token"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phone1"
                ],
                "properties": {
                  "firstName": {
                    "type": "string",
                    "example": "John"
                  },
                  "lastName": {
                    "type": "string",
                    "example": "Smith"
                  },
                  "phone1": {
                    "type": "string",
                    "example": "+16193041710"
                  },
                  "phone2": {
                    "type": "string",
                    "example": "+16193041710"
                  },
                  "phone3": {
                    "type": "string",
                    "example": "+16193041710"
                  },
                  "phone4": {
                    "type": "string",
                    "example": "+16193041710"
                  },
                  "email": {
                    "type": "string",
                    "example": "abc@gmail.com"
                  },
                  "address1": {
                    "type": "string",
                    "example": "great company street"
                  },
                  "city": {
                    "type": "string",
                    "example": "LA"
                  },
                  "state": {
                    "type": "string",
                    "example": "CA"
                  },
                  "zip": {
                    "type": "string",
                    "example": "94111"
                  },
                  "country": {
                    "type": "string",
                    "example": "USA"
                  },
                  "parameter1": {
                    "type": "string",
                    "example": "RoutingRuleGroup1",
                    "description": "Routing rule name (parameter1)"
                  },
                  "leadSource": {
                    "type": "string",
                    "example": "Chat2Phone"
                  },
                  "programOfInterest": {
                    "type": "string",
                    "example": "Art History"
                  },
                  "companyName": {
                    "type": "string",
                    "example": "just company"
                  },
                  "keyword": {
                    "type": "string",
                    "example": "abc"
                  },
                  "comments": {
                    "type": "string",
                    "example": "Comment for this inquiry"
                  },
                  "vendorLeadId": {
                    "type": "string",
                    "example": "00Q8000001S7rWu"
                  },
                  "callDelay": {
                    "type": "string",
                    "example": ""
                  },
                  "group_id": {
                    "type": "integer",
                    "example": 344,
                    "description": "Assign this inquiry for the group"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "id",
                        "message"
                      ],
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 1322
                        },
                        "message": {
                          "type": "string",
                          "example": "inquiry received"
                        }
                      }
                    },
                    {
                      "$ref": "#/components/schemas/ErrorResponse"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/401"
          }
        }
      }
    },
    "/inquiries/stop_reattempts": {
      "post": {
        "tags": [
          "Call"
        ],
        "summary": "Stop reattempts for lead number",
        "description": "Stop call reattempts for a specific phone number",
        "operationId": "stopReattempts",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/token"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phone_number"
                ],
                "properties": {
                  "phone_number": {
                    "type": "string",
                    "example": "+16193041710"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "status",
                        "code",
                        "message"
                      ],
                      "properties": {
                        "status": {
                          "type": "string",
                          "example": "success"
                        },
                        "code": {
                          "type": "string",
                          "example": "200"
                        },
                        "message": {
                          "type": "string",
                          "example": "Success: Call removed from queue"
                        }
                      }
                    },
                    {
                      "$ref": "#/components/schemas/ErrorResponse"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/401"
          }
        }
      }
    },
    "/users": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get User",
        "description": "Retrieve user information",
        "operationId": "getUser",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/token"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/User"
                    },
                    {
                      "$ref": "#/components/schemas/ErrorResponse"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/401"
          }
        }
      }
    },
    "/callhistory": {
      "get": {
        "tags": [
          "Call"
        ],
        "summary": "Get call history",
        "description": "Retrieve call history records",
        "operationId": "getCallHistory",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/token"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/CallHistory"
                      }
                    },
                    {
                      "$ref": "#/components/schemas/ErrorResponse"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/401"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "username": {
        "name": "username",
        "in": "query",
        "description": "Access username",
        "required": true,
        "schema": {
          "type": "string",
          "example": "test_user@test.com"
        }
      },
      "token": {
        "name": "token",
        "in": "query",
        "description": "Access token",
        "required": true,
        "schema": {
          "type": "string",
          "example": "uhwe8ef89w8fh98wehdhqwj2d90d3"
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "status",
          "code",
          "message"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "error"
          },
          "code": {
            "type": "string",
            "enum": [
              "1004",
              "1001",
              "1002",
              "4001",
              "4101"
            ],
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Error message",
            "example": "Invalid username or token"
          }
        }
      },
      "User": {
        "type": "object",
        "required": [
          "id",
          "login_url",
          "username",
          "name",
          "customer_id",
          "customer_name",
          "customer_code",
          "sub_accounts",
          "openid",
          "appdirect_baseurl"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 123
          },
          "customer_id": {
            "type": "integer",
            "example": 4342
          },
          "username": {
            "type": "string",
            "example": "test@test.com"
          },
          "name": {
            "type": "string",
            "example": "John"
          },
          "customer_name": {
            "type": "string",
            "example": "Awesome company"
          },
          "customer_code": {
            "type": "string",
            "example": "GEN_4342"
          },
          "sub_accounts": {
            "type": "string",
            "example": "1,34,222"
          },
          "openid": {
            "type": "string",
            "example": ""
          },
          "appdirect_baseurl": {
            "type": "string",
            "example": ""
          },
          "login_url": {
            "type": "string",
            "example": ""
          },
          "token": {
            "type": "string",
            "nullable": true,
            "example": "78y84f873h28rh783y4"
          }
        }
      },
      "CallHistory": {
        "type": "object",
        "required": [
          "id",
          "inquiryId"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "64621"
          },
          "callRecordingName": {
            "type": "string",
            "nullable": true,
            "example": "873ey7832y92u98uu"
          },
          "inquiryToConnectionTime": {
            "type": "string",
            "nullable": true,
            "example": "160"
          },
          "repPhone": {
            "type": "string",
            "nullable": true,
            "example": "+1321398298"
          },
          "repResponse": {
            "type": "string",
            "nullable": true,
            "example": "No Answer"
          },
          "zip": {
            "type": "string",
            "nullable": true,
            "example": "12797"
          },
          "inquiryId": {
            "type": "string",
            "example": "81386"
          },
          "inquiryTime": {
            "type": "string",
            "nullable": true,
            "example": "13:08:59"
          },
          "callTime": {
            "type": "string",
            "nullable": true,
            "example": "13:08:59"
          },
          "firstName": {
            "type": "string",
            "nullable": true,
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "nullable": true,
            "example": "Smith"
          },
          "email": {
            "type": "string",
            "nullable": true,
            "example": "test@test.com"
          },
          "phone1": {
            "type": "string",
            "nullable": true,
            "example": "+14238429238"
          },
          "leadSource": {
            "type": "string",
            "nullable": true,
            "example": "Web form 1"
          },
          "companyName": {
            "type": "string",
            "nullable": true,
            "example": "Company test"
          },
          "inquiryStatus": {
            "type": "string",
            "nullable": true,
            "example": "Call"
          },
          "callState": {
            "type": "string",
            "nullable": true,
            "example": "In process"
          },
          "inquiryDateTime": {
            "type": "string",
            "nullable": true,
            "example": "2023-05-05T13:08:59+0000"
          }
        }
      }
    },
    "responses": {
      "401": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "QueryAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "username",
        "description": "Username and token must be provided as query parameters"
      }
    }
  },
  "security": [
    {
      "QueryAuth": []
    }
  ],
  "tags": [
    {
      "name": "Call"
    },
    {
      "name": "Users"
    }
  ]
}
