            "type": "string"
          },
          "Title": {
            "type": "string"
          },
          "Artist": {
            "type": "string"
          },
          "Album": {
            "type": "string"
          },
          "Track": {
            "type": "string"
          },
          "Date": {
            "type": "string"
          },
          "Genre": {
            "type": "string"
          },
          "Composer": {
            "type": "string"
          },
          "Time": {
            "type": "string"
          },
          "duration": {
            "type": "number"
          },
          "bitrate": {
            "type": "string"
          },
          "audio": {
            "type": "string"
          }
        }
      },
      "PlaybackStatus": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "enum": [
              "play",
              "pause",
              "stop"
            ]
          },
          "volume": {
            "type": "integer"
          },
          "repeat": {
            "type": "integer"
          },
          "random": {
            "type": "integer"
          },
          "single": {
            "type": "integer"
          },
          "consume": {
            "type": "integer"
          },
          "elapsed": {
            "type": "string"
          },
          "duration": {
            "type": "string"
          },
          "bitrate": {
            "type": "string"
          },
          "audio": {
            "type": "string"
          },
          "song": {
            "type": "integer"
          },
          "playlistlength": {
            "type": "integer"
          }
        }
      },
      "LibraryItem": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string"
          },
          "Title": {
            "type": "string"
          },
          "Artist": {
            "type": "string"
          },
          "Album": {
            "type": "string"
          },
          "Genre": {
            "type": "string"
          },
          "Date": {
            "type": "string"
          }
        }
