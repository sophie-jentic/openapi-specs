{
  "openapi": "3.0.3",
  "info": {
    "title": "Moode Audio API",
    "version": "1.0.0",
    "description": "Moode is an audiophile-quality music player for Raspberry Pi. The API provides control over playback, library management, radio stations, and system configuration via JSON commands.",
    "x-jentic-source-url": "https://moodeaudio.org/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://moode.local"
    }
  ],
  "paths": {
    "/command/": {
      "get": {
        "operationId": "executeCommand",
        "summary": "Execute a moode command",
        "tags": [
          "Commands"
        ],
        "parameters": [
          {
            "name": "cmd",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "get_currentsong",
                "get_playback_status",
                "get_library",
                "get_playlist",
                "get_radio_stations",
                "get_audio_info",
                "get_system_info",
                "set_volume",
                "play",
                "pause",
                "stop",
                "next",
                "previous",
                "toggle",
                "seek",
                "random",
                "repeat",
                "clear_queue",
                "update_library"
              ]
            },
            "description": "Command name"
          },
          {
            "name": "level",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "description": "Volume level (for set_volume)"
          },
          {
            "name": "position",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Seek position in seconds"
          }
        ],
        "responses": {
          "200": {
            "description": "Command result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "description": "Execute a moode command"
      }
    },
    "/command/?cmd=get_currentsong": {
      "get": {
        "operationId": "getCurrentSong",
        "summary": "Get currently playing song",
        "tags": [
          "Playback"
        ],
        "responses": {
          "200": {
            "description": "Current song info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Song"
                }
              }
            }
          }
        },
        "description": "Get currently playing song"
      }
    },
    "/command/?cmd=get_playback_status": {
      "get": {
        "operationId": "getPlaybackStatus",
        "summary": "Get playback status",
        "tags": [
          "Playback"
        ],
        "responses": {
          "200": {
            "description": "Playback status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlaybackStatus"
                }
              }
            }
          }
        },
        "description": "Get playback status"
      }
    },
    "/command/?cmd=get_library": {
      "get": {
        "operationId": "getLibrary",
        "summary": "Get music library",
        "tags": [
          "Library"
        ],
        "responses": {
          "200": {
            "description": "Library contents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LibraryItem"
                  }
                }
              }
            }
          }
        },
        "description": "Get music library"
      }
    },
    "/command/?cmd=get_playlist": {
      "get": {
        "operationId": "getPlaylist",
        "summary": "Get current playlist/queue",
        "tags": [
          "Playback"
        ],
        "responses": {
          "200": {
            "description": "Queue contents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Song"
                  }
                }
              }
            }
          }
        },
        "description": "Get current playlist/queue"
      }
    },
    "/command/?cmd=get_radio_stations": {
      "get": {
        "operationId": "getRadioStations",
        "summary": "List radio stations",
        "tags": [
          "Radio"
        ],
        "responses": {
          "200": {
            "description": "Radio station list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RadioStation"
                  }
                }
              }
            }
          }
        },
        "description": "List radio stations"
      }
    },
    "/command/?cmd=get_audio_info": {
      "get": {
        "operationId": "getAudioInfo",
        "summary": "Get audio output information",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Audio info"
          }
        },
        "description": "Get audio output information"
      }
    },
    "/command/?cmd=get_system_info": {
      "get": {
        "operationId": "getSystemInfo",
        "summary": "Get system information",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "System info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SystemInfo"
                }
              }
            }
          }
        },
        "description": "Get system information"
      }
    },
    "/command/?cmd=play": {
      "get": {
        "operationId": "play",
        "summary": "Start playback",
        "tags": [
          "Playback"
        ],
        "responses": {
          "200": {
            "description": "Playback started"
          }
        },
        "description": "Start playback"
      }
    },
    "/command/?cmd=pause": {
      "get": {
        "operationId": "pause",
        "summary": "Pause playback",
        "tags": [
          "Playback"
        ],
        "responses": {
          "200": {
            "description": "Playback paused"
          }
        },
        "description": "Pause playback"
      }
    },
    "/command/?cmd=stop": {
      "get": {
        "operationId": "stop",
        "summary": "Stop playback",
        "tags": [
          "Playback"
        ],
        "responses": {
          "200": {
            "description": "Playback stopped"
          }
        },
        "description": "Stop playback"
      }
    },
    "/command/?cmd=next": {
      "get": {
        "operationId": "next",
        "summary": "Skip to next track",
        "tags": [
          "Playback"
        ],
        "responses": {
          "200": {
            "description": "Skipped to next"
          }
        },
        "description": "Skip to next track"
      }
    },
    "/command/?cmd=previous": {
      "get": {
        "operationId": "previous",
        "summary": "Go to previous track",
        "tags": [
          "Playback"
        ],
        "responses": {
          "200": {
            "description": "Went to previous"
          }
        },
        "description": "Go to previous track"
      }
    },
    "/command/?cmd=set_volume": {
      "get": {
        "operationId": "setVolume",
        "summary": "Set volume level",
        "tags": [
          "Playback"
        ],
        "parameters": [
          {
            "name": "level",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Volume set"
          }
        },
        "description": "Set volume level"
      }
    },
    "/command/?cmd=update_library": {
      "get": {
        "operationId": "updateLibrary",
        "summary": "Trigger library rescan",
        "tags": [
          "Library"
        ],
        "responses": {
          "200": {
            "description": "Library update started"
          }
        },
        "description": "Trigger library rescan"
      }
    },
    "/command/?cmd=clear_queue": {
      "get": {
        "operationId": "clearQueue",
        "summary": "Clear the playback queue",
        "tags": [
          "Playback"
        ],
        "responses": {
          "200": {
            "description": "Queue cleared"
          }
        },
        "description": "Clear the playback queue"
      }
    }
  },
  "components": {
