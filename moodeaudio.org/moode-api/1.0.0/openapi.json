      "SystemInfo": {
        "type": "object",
        "properties": {
          "hostname": {
            "type": "string"
          },
          "kernel": {
            "type": "string"
          },
          "architecture": {
            "type": "string"
          },
          "memused": {
            "type": "string"
          },
          "memfree": {
            "type": "string"
          },
          "cpuload": {
            "type": "string"
          },
          "cputemp": {
            "type": "string"
          },
          "uptime": {
            "type": "string"
          },
