{
  "openapi": "3.1.0",
  "info": {
    "title": "DistanceMatrix.ai API",
    "description": "Distance Matrix and Geocoding API by distancematrix.ai. Calculate distances, travel times (with real-time traffic), and geocode addresses worldwide. Supports driving, walking, bicycling, and transit modes with global coverage.",
    "version": "1.0.0",
    "contact": {
      "name": "DistanceMatrix.ai",
      "url": "https://distancematrix.ai"
    }
  },
  "servers": [
    {
      "url": "https://api.distancematrix.ai",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/maps/api/distancematrix/json": {
      "get": {
        "operationId": "getDistanceMatrix",
        "summary": "Calculate distance and travel time",
        "description": "Calculates distance and duration between one or more origins and destinations. Supports real-time traffic data for driving mode when departure_time is specified.",
        "parameters": [
          {
            "name": "origins",
            "in": "query",
            "required": true,
            "description": "Starting point(s) for the distance calculation. Accepts addresses or latitude/longitude coordinates (format: lat,lng). Separate multiple origins with a pipe character (|).",
            "schema": {
              "type": "string"
            },
            "example": "51.4822656,-0.1933769"
          },
          {
            "name": "destinations",
            "in": "query",
            "required": true,
            "description": "Destination(s) for the distance calculation. Accepts addresses or latitude/longitude coordinates (format: lat,lng). Separate multiple destinations with a pipe character (|).",
            "schema": {
              "type": "string"
            },
            "example": "51.4994794,-0.1269979"
          },
          {
            "name": "mode",
            "in": "query",
            "required": false,
            "description": "Transportation mode for the distance calculation.",
            "schema": {
              "type": "string",
              "enum": [
                "driving",
                "walking",
                "bicycling",
                "transit"
              ],
              "default": "driving"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "description": "Language code for the response (e.g., en, de, fr, es, pt).",
            "schema": {
              "type": "string"
            },
            "example": "en"
          },
          {
            "name": "avoid",
            "in": "query",
            "required": false,
            "description": "Route restriction. Biases results to avoid the specified feature. Only one restriction per request.",
            "schema": {
              "type": "string",
              "enum": [
                "tolls",
                "highways",
                "ferries",
                "indoor"
              ]
            }
          },
          {
            "name": "units",
            "in": "query",
            "required": false,
            "description": "Unit system for displaying distance values.",
            "schema": {
              "type": "string",
              "enum": [
                "metric",
                "imperial"
              ],
              "default": "metric"
            }
          },
          {
            "name": "departure_time",
            "in": "query",
            "required": false,
            "description": "Desired departure time. Use 'now' for current time or a UTC timestamp in seconds. Required for traffic data (driving mode only). Cannot be combined with arrival_time.",
            "schema": {
              "type": "string"
            },
            "example": "now"
          },
          {
            "name": "arrival_time",
            "in": "query",
            "required": false,
            "description": "Desired arrival time as a UTC timestamp in seconds. Cannot be combined with departure_time. Used with transit mode.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "traffic_model",
            "in": "query",
            "required": false,
            "description": "Traffic prediction model. Only applicable when departure_time is set and mode is driving.",
            "schema": {
              "type": "string",
              "enum": [
                "best_guess",
                "pessimistic",
                "optimistic"
              ],
              "default": "best_guess"
            }
          },
          {
            "name": "transit_mode",
            "in": "query",
            "required": false,
            "description": "Preferred transit type(s). Only applicable when mode is transit.",
            "schema": {
              "type": "string",
              "enum": [
                "bus",
                "subway",
                "train",
                "tram",
                "rail"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful distance matrix response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DistanceMatrixResponse"
                },
                "example": {
                  "status": "OK",
                  "origin_addresses": [
                    "Chapel, London SW6 1BA, UK"
                  ],
                  "destination_addresses": [
                    "Westminster Abbey, London SW1P 3PA, UK"
                  ],
                  "rows": [
                    {
                      "elements": [
                        {
                          "status": "OK",
                          "distance": {
                            "text": "7.6 km",
                            "value": 7567
                          },
                          "duration": {
                            "text": "22 mins",
                            "value": 1359
                          },
                          "duration_in_traffic": {
                            "text": "23 mins",
                            "value": 1395
                          }
                        }
                      ]
                    }
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "maps"
        ]
      }
    },
    "/maps/api/geocode/json": {
      "get": {
        "operationId": "geocodeAddress",
        "summary": "Geocode an address to coordinates",
        "description": "Converts a street address into geographic coordinates (latitude and longitude). Returns detailed address components, formatted address, geometry, and place identifiers.",
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "required": true,
            "description": "Street address to geocode, formatted per national postal standards. Spaces should be URL-encoded as %20.",
            "schema": {
              "type": "string"
            },
            "example": "Westermarkt 20, 1016 GV Amsterdam, Netherlands"
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "description": "Language code for the response. Supports 60+ languages.",
            "schema": {
              "type": "string"
            },
            "example": "en"
          },
          {
            "name": "region",
            "in": "query",
            "required": false,
            "description": "Two-character ccTLD region code to bias geocoding results.",
            "schema": {
              "type": "string"
            },
            "example": "nl"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful geocoding response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeocodeResponse"
                }
              }
            }
          }
        },
        "tags": [
          "maps"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API access token obtained from the distancematrix.ai admin panel."
      }
    },
    "schemas": {
      "DistanceMatrixResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Top-level status of the request.",
            "enum": [
              "OK",
              "INVALID_REQUEST",
              "MAX_ELEMENTS_EXCEEDED",
              "OVER_DAILY_LIMIT",
              "OVER_QUERY_LIMIT",
              "REQUEST_DENIED",
              "UNKNOWN_ERROR"
            ]
          },
          "origin_addresses": {
            "type": "array",
            "description": "Array of geocoded origin addresses.",
            "items": {
              "type": "string"
            }
          },
          "destination_addresses": {
            "type": "array",
            "description": "Array of geocoded destination addresses.",
            "items": {
              "type": "string"
            }
          },
          "rows": {
            "type": "array",
            "description": "Array of result rows, one per origin.",
            "items": {
              "$ref": "#/components/schemas/DistanceMatrixRow"
            }
          },
          "error_message": {
            "type": "string",
            "description": "Detailed error information when status is not OK."
          }
        },
        "required": [
          "status"
        ]
      },
      "DistanceMatrixRow": {
        "type": "object",
        "properties": {
          "elements": {
            "type": "array",
            "description": "Array of results for each origin-destination pair.",
            "items": {
              "$ref": "#/components/schemas/DistanceMatrixElement"
            }
          }
        },
        "required": [
          "elements"
        ]
      },
      "DistanceMatrixElement": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Status of this element.",
            "enum": [
              "OK",
              "NOT_FOUND",
              "ZERO_RESULTS",
              "MAX_ROUTE_LENGTH_EXCEEDED",
              "UNKNOWN_ERROR"
            ]
          },
          "distance": {
            "$ref": "#/components/schemas/TextValuePair",
            "description": "Distance between origin and destination."
          },
          "duration": {
            "$ref": "#/components/schemas/TextValuePair",
            "description": "Travel duration between origin and destination."
          },
          "duration_in_traffic": {
            "$ref": "#/components/schemas/TextValuePair",
            "description": "Traffic-adjusted travel duration. Only present when departure_time is specified with driving mode."
          }
        },
        "required": [
          "status"
        ]
      },
      "TextValuePair": {
        "type": "object",
        "description": "A value expressed as both human-readable text and a numeric value.",
        "properties": {
          "text": {
            "type": "string",
            "description": "Human-readable representation (e.g., '7.6 km', '22 mins')."
          },
          "value": {
            "type": "integer",
            "description": "Numeric value in base units (meters for distance, seconds for duration)."
          }
        },
        "required": [
          "text",
          "value"
        ]
      },
      "GeocodeResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Status of the geocoding request.",
            "enum": [
              "OK",
              "ZERO_RESULTS",
              "OVER_DAILY_LIMIT",
              "OVER_QUERY_LIMIT",
              "REQUEST_DENIED",
              "INVALID_REQUEST",
              "UNKNOWN_ERROR"
            ]
          },
          "results": {
            "type": "array",
            "description": "Array of geocoded address results.",
            "items": {
              "$ref": "#/components/schemas/GeocodeResult"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "GeocodeResult": {
        "type": "object",
        "properties": {
          "address_components": {
            "type": "array",
            "description": "Array of address component objects.",
            "items": {
              "$ref": "#/components/schemas/AddressComponent"
            }
          },
          "formatted_address": {
            "type": "string",
            "description": "Human-readable full address string."
          },
          "geometry": {
            "$ref": "#/components/schemas/Geometry"
          },
          "types": {
            "type": "array",
            "description": "Array of type tags for this result.",
            "items": {
              "type": "string"
            }
          },
          "place_id": {
            "type": "string",
            "description": "Unique identifier for this place."
          },
          "plus_code": {
            "type": "object",
            "description": "Plus code identifier for the location.",
            "properties": {
              "compound_code": {
                "type": "string"
              },
              "global_code": {
                "type": "string"
              }
            }
          }
        }
      },
      "AddressComponent": {
        "type": "object",
        "properties": {
          "long_name": {
            "type": "string",
            "description": "Full text description of the address component."
          },
          "short_name": {
            "type": "string",
            "description": "Abbreviated text for the address component."
          },
          "types": {
            "type": "array",
            "description": "Type tags for this component (e.g., street_address, locality, country, postal_code).",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "long_name",
          "short_name",
          "types"
        ]
      },
      "Geometry": {
        "type": "object",
        "properties": {
          "location": {
            "type": "object",
            "description": "Geographic coordinates.",
            "properties": {
              "lat": {
                "type": "number",
                "description": "Latitude."
              },
              "lng": {
                "type": "number",
                "description": "Longitude."
              }
            },
            "required": [
              "lat",
              "lng"
            ]
          },
          "location_type": {
            "type": "string",
            "description": "Precision level of the geocoding result.",
            "enum": [
              "ROOFTOP",
              "RANGE_INTERPOLATED",
              "GEOMETRIC_CENTER",
              "APPROXIMATE"
            ]
          }
        },
        "required": [
          "location",
          "location_type"
        ]
      }
    }
  },
  "tags": [
    {
      "name": "maps"
    }
  ]
}
