            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "user",
            "in": "query",
            "description": "A name to associate this acknowledgement action with. Does not have to match an existing username in Netreo to be accepted (so an automated value like \"Ticketing System\" is acceptable).\n",
