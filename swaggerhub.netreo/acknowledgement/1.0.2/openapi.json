            "schema": {
              "type": "string"
            }
          },
          {
            "name": "comment",
            "in": "query",
            "description": "A comment that will be added to the record of the acknowledgement in Netreo and sent out in any acknowledgement alerts.<br>\n<br>Limit of 255 characters.\n",
