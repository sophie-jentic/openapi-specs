    "/customers/{customer_uuid}/merge/{into_customer_uuid}": {
      "post": {
        "operationId": "mergeCustomers",
        "summary": "Merge customers",
        "description": "Merges one customer into another. All data from the source customer is moved to the target.",
        "tags": [
          "Customers"
        ],
        "parameters": [
          {
            "name": "customer_uuid",
            "in": "path",
