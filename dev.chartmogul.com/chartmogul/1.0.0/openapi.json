    "/metrics/mrr": {
      "get": {
        "operationId": "retrieveMrr",
        "summary": "Retrieve MRR",
        "description": "Retrieves Monthly Recurring Revenue (MRR) metrics over a specified date range. All amounts are in cents.",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "name": "start-date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date (YYYY-MM-DD)"
          },
          {
            "name": "end-date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date (YYYY-MM-DD)"
          },
          {
            "name": "interval",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "day",
                "week",
                "month",
                "quarter"
              ]
            },
            "description": "Time interval for grouping"
          },
          {
            "name": "geo",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by geography (ISO country code)"
          },
          {
            "name": "plans",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by plan name"
          }
        ],
        "responses": {
          "200": {
            "description": "MRR metrics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/MrrEntry"
                      }
                    },
                    "summary": {
                      "$ref": "#/components/schemas/MetricsSummary"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
