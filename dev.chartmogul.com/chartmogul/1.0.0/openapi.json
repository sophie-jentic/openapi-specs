                  },
                  "zip": {
                    "type": "string"
                  },
                  "lead_created_at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "free_trial_started_at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "owner": {
                    "type": "string"
                  },
                  "website_url": {
                    "type": "string"
                  }
