      "delete": {
        "operationId": "deleteCustomer",
        "summary": "Delete a customer",
        "description": "Deletes a customer and all associated data.",
        "tags": [
          "Customers"
        ],
        "parameters": [
          {
            "name": "customer_uuid",
            "in": "path",
            "required": true,
