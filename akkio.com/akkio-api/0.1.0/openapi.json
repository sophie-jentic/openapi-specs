{
  "openapi": "3.0.3",
  "info": {
    "title": "Akkio API",
    "version": "0.1.0",
    "description": "Akkio is a no-code AI/ML platform. The API provides endpoints for managing datasets, training predictive models, making predictions, managing projects, and using Chat Explore for conversational data analysis.",
    "x-jentic-source-url": "https://docs.akkio.com",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.akkio.com"
    }
  ],
  "tags": [
    {
      "name": "Datasets",
      "description": "Dataset management - create, list, add rows, delete"
    },
    {
      "name": "Models",
      "description": "Model listing, predictions, and deletion (legacy v1)"
    },
    {
      "name": "Training",
      "description": "Async model training (v2)"
    },
    {
      "name": "Projects",
      "description": "Project management"
    },
    {
      "name": "Chat Explore",
      "description": "Conversational data analysis"
    }
  ],
  "security": [
    {
      "ApiKeyHeader": []
    },
    {
      "ApiKeyQuery": []
    }
  ],
  "paths": {
    "/v1/datasets": {
      "get": {
        "operationId": "listDatasets",
        "summary": "Get all datasets",
        "description": "Get all datasets in your organization, or get a specific dataset by ID.",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your API key"
          },
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Optional dataset ID for specific dataset details"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "datasets": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DatasetSummary"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Missing or invalid API key"
          }
        }
      },
      "post": {
        "operationId": "createOrAddToDataset",
        "summary": "Create dataset or add rows",
        "description": "Create a new empty dataset (with name param) or add rows to an existing dataset (with id and rows in body).",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Name for new dataset (mutually exclusive with id/rows)"
          },
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Existing dataset ID to add rows to"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "rows": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "description": "Array of row objects with field name to value mappings"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dataset created or rows added",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "dataset_id": {
                      "type": "string"
                    },
                    "dataset_name": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteDataset",
        "summary": "Delete a dataset",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Dataset ID to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Dataset deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        },
        "description": "Delete a dataset"
      }
    },
    "/v1/models": {
      "get": {
        "operationId": "listModels",
        "summary": "Get all models",
        "tags": [
          "Models"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of models",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "models": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ModelSummary"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get all models"
      },
      "post": {
        "operationId": "makePrediction",
        "summary": "Make a prediction",
        "description": "Submit data to a trained model for predictions.",
        "tags": [
          "Models"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "api_key": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string",
                    "description": "Model ID"
                  },
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "description": "Data rows for prediction"
                  }
                },
                "required": [
                  "api_key",
                  "id",
                  "data"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prediction results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "predictions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteModel",
        "summary": "Delete a model",
        "tags": [
          "Models"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Model deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        },
        "description": "Delete a model"
      }
    },
    "/api/v1/models/train/new": {
      "post": {
        "operationId": "submitTrainingTask",
        "summary": "Submit model training task",
        "description": "Start an asynchronous model training job. Returns a task_id to poll for status.",
        "tags": [
          "Training"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrainRequestPayload"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Task started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskStartedResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/models/train/{task_id}/status": {
      "get": {
        "operationId": "getTrainingStatus",
        "summary": "Get training task status",
        "tags": [
          "Training"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskStatusResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        },
        "description": "Get training task status"
      }
    },
    "/api/v1/models/train/{task_id}/result": {
      "get": {
        "operationId": "getTrainingResult",
        "summary": "Get training task result",
        "description": "Retrieve the result of a completed model training task.",
        "tags": [
          "Training"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Training result with model ID and stats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/v1/projects": {
      "post": {
        "operationId": "createProject",
        "summary": "Create a new project",
        "tags": [
          "Projects"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProjectPayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        },
        "description": "Create a new project"
      }
    },
    "/api/v1/projects/{project_id}": {
      "get": {
        "operationId": "getProject",
        "summary": "Get a project",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        },
        "description": "Get a project"
      },
      "put": {
        "operationId": "updateProject",
        "summary": "Update a project",
        "description": "Update custom instructions for Chat Explore on a project.",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProjectPayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        }
      },
      "delete": {
        "operationId": "deleteProject",
        "summary": "Delete a project",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project deleted"
          },
          "422": {
            "description": "Validation error"
          }
        },
        "description": "Delete a project"
      }
    },
    "/api/v1/chat-explore/new": {
      "post": {
        "operationId": "submitChatExploreQuery",
        "summary": "Submit Chat Explore query",
        "description": "Submit a conversational data analysis query. Returns a task_id for async polling.",
        "tags": [
          "Chat Explore"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatExplorePayload"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Task started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskStartedResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/v1/chat-explore/status/{task_id}": {
      "get": {
        "operationId": "getChatExploreStatus",
        "summary": "Get Chat Explore task status",
        "tags": [
          "Chat Explore"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskStatusResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        },
        "description": "Get Chat Explore task status"
      }
    },
    "/api/v1/chat-explore/result/{task_id}": {
      "get": {
        "operationId": "getChatExploreResult",
        "summary": "Get Chat Explore result",
        "tags": [
          "Chat Explore"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chat result with message, images, and table data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatExploreResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        },
        "description": "Get Chat Explore result"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key passed via X-API-Key header (for /api/v1 endpoints)"
      },
      "ApiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key passed as query parameter (for /v1 endpoints)"
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          }
        }
      },
      "DatasetSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ModelSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "TrainRequestPayload": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "description": "The ID of the dataset to train on"
          },
          "predict_fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Field names to predict (case sensitive)"
          },
          "duration": {
            "type": "integer",
            "description": "Training time: 10 (Fastest), 60 (High Quality), 300 (Higher Quality), 1800 (Production)"
          },
          "ignore_fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Field names to ignore"
          },
          "extra_attention": {
            "type": "boolean",
            "default": false,
            "description": "Helps with predicting rare cases"
          },
          "force": {
            "type": "boolean",
            "default": false,
            "description": "Force creation even if another model exists"
          }
        },
        "required": [
          "dataset_id",
          "predict_fields",
          "duration"
        ]
      },
      "TaskStartedResponse": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "Task ID for polling status"
          }
        },
        "required": [
          "task_id"
        ]
      },
      "TaskStatusResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "IN_PROGRESS",
              "SUCCEEDED",
              "FAILED",
              "UNKNOWN_TIMEOUT"
            ]
          },
          "metadata": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "location": {
                "type": "string",
                "description": "Result path (when SUCCEEDED)"
              },
              "estimate_seconds": {
                "type": "number",
                "description": "Time estimate (when IN_PROGRESS)"
              },
              "error": {
                "type": "string",
                "description": "Error message (when FAILED)"
              }
            }
          }
        },
        "required": [
          "status",
          "metadata"
        ]
      },
      "CreateProjectPayload": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Project name"
          },
          "_owner": {
            "type": "string",
            "description": "Owner user ID"
          },
          "_org": {
            "type": "string",
            "description": "Organization ID"
          },
          "chatContext": {
            "type": "string",
            "description": "Context for Chat Explore"
          },
          "chatInstructions": {
            "type": "string",
            "description": "Response instructions for Chat Explore"
          },
          "chatSuggestions": {
            "type": "string",
            "description": "Newline-separated suggestion prompts"
          }
        },
        "required": [
          "_owner",
          "_org",
          "name"
        ]
      },
      "UpdateProjectPayload": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "chatContext": {
            "type": "string"
          },
          "chatInstructions": {
            "type": "string"
          },
          "chatSuggestions": {
            "type": "string"
          }
        }
      },
      "ProjectResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "chatContext": {
            "type": "string"
          },
          "chatInstructions": {
            "type": "string"
          },
          "chatSuggestions": {
            "type": "string"
          }
        }
      },
      "ChatExplorePayload": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "description": "Conversation messages"
          },
          "dataset_id": {
            "type": "string",
            "description": "Dataset ID (either this or project_id required)"
          },
          "project_id": {
            "type": "string",
            "description": "Project ID (either this or dataset_id required)"
          },
          "chatContext": {
            "type": "string"
          },
          "chatInstructions": {
            "type": "string"
          }
        },
        "required": [
          "messages"
        ]
      },
      "ChatMessage": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "string"
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Base64-encoded images"
          },
          "table": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "description": "Table data as array of row objects"
          }
        },
        "required": [
          "role",
          "content"
        ]
      },
      "ChatExploreResult": {
        "type": "object",
        "properties": {
          "message": {
            "$ref": "#/components/schemas/ChatMessage"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "HTTPValidationError": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "loc": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "msg": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
