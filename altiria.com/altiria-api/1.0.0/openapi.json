            "items": {
              "type": "string"
            }
          },
          "from": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "encoding": {
            "type": "string"
          },
          "scheduleDate": {
            "type": "string",
            "format": "date-time"
          },
          "campaignName": {
            "type": "string"
          },
          "tags": {
            "type": "array",
