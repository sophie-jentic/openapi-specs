{
  "openapi": "3.0.3",
  "info": {
    "title": "Altiria API",
    "version": "1.0.0",
    "description": "Altiria is a communications platform providing SMS, email, voice, WhatsApp, and landing page APIs for business messaging.",
    "x-jentic-source-url": "https://apidocs.altiria.com/es/",
    "contact": {}
  },
  "servers": [
