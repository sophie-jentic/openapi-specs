        "type": "object",
        "required": [
          "templateId",
          "from",
          "messages"
        ],
        "properties": {
          "templateId": {
            "type": "integer"
          },
          "from": {
            "type": "string"
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
