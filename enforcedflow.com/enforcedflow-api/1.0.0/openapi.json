{
  "openapi": "3.0.3",
  "x-jentic-source-url": "https://enforcedflow.com/api/",
  "info": {
    "title": "EnforcedFlow API",
    "description": "EnforcedFlow provides no-code AI automation with human-in-the-loop workflows and round-robin agent management. This API enables creating review tasks, managing agents, and implementing round-robin distribution.",
    "version": "1.0.0",
    "contact": {
      "name": "EnforcedFlow Support",
      "url": "https://enforcedflow.com"
    }
  },
  "servers": [
    {
      "url": "https://api.enforcedflow.com/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/tasks": {
      "post": {
        "summary": "Create human-in-the-loop task",
        "description": "Creates a task for human review and approval/rejection",
        "operationId": "createTask",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "content"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Task title"
                  },
                  "content": {
                    "type": "string",
                    "description": "Content to review"
                  },
                  "review_guidelines": {
                    "type": "string",
                    "description": "Guidelines for reviewing the task"
                  },
                  "source_content": {
                    "type": "string",
                    "description": "Source content reference"
                  },
                  "metadata": {
                    "type": "object",
                    "description": "Additional metadata",
                    "additionalProperties": true
                  },
                  "allow_metadata_editing": {
                    "type": "boolean",
                    "description": "Allow metadata editing during review"
                  },
                  "group_name": {
                    "type": "string",
                    "description": "Group name for task assignment"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Task created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/agents": {
      "post": {
        "summary": "Add or update agent",
        "description": "Creates or updates an agent in a round-robin group",
        "operationId": "addOrUpdateAgent",
        "tags": [
          "Agents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "group_id",
                  "agent_id"
                ],
                "properties": {
                  "group_id": {
                    "type": "string",
                    "description": "Round-robin group identifier"
                  },
                  "agent_id": {
                    "type": "string",
                    "description": "Agent identifier"
                  },
                  "agent_name": {
                    "type": "string",
                    "description": "Agent name"
                  },
                  "metadata": {
                    "type": "object",
                    "description": "Additional agent metadata",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            }
          },
          "201": {
            "description": "Agent created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Find agents in group",
        "description": "Lists all agents within a specified round-robin group",
        "operationId": "findAgents",
        "tags": [
          "Agents"
        ],
        "parameters": [
          {
            "name": "group_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Round-robin group identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "List of agents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "agents": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Agent"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Group not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/agents/next": {
      "get": {
        "summary": "Get next agent",
        "description": "Selects the next available agent from a round-robin group",
        "operationId": "getNextAgent",
        "tags": [
          "Agents"
        ],
        "parameters": [
          {
            "name": "group_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Round-robin group identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Next agent selected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "No available agents",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/round-robin/next": {
      "get": {
        "summary": "Get next item (simple round-robin)",
        "description": "Returns the next item from a simple round-robin group",
        "operationId": "getNextItem",
        "tags": [
          "Round Robin"
        ],
        "parameters": [
          {
            "name": "group",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Group identifier"
          },
          {
            "name": "options",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of options"
          }
        ],
        "responses": {
          "200": {
            "description": "Next item selected",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "item": {
                      "type": "string",
                      "description": "Selected item"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Task identifier"
          },
          "title": {
            "type": "string",
            "description": "Task title"
          },
          "content": {
            "type": "string",
            "description": "Content to review"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "approved",
              "rejected"
            ],
            "description": "Task status"
          },
          "group_name": {
            "type": "string",
            "description": "Group name"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Task creation timestamp"
          },
          "reviewed_at": {
            "type": "string",
            "format": "date-time",
            "description": "Task review timestamp"
          }
        }
      },
      "Agent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Agent identifier"
          },
          "agent_id": {
            "type": "string",
            "description": "Agent ID"
          },
          "agent_name": {
            "type": "string",
            "description": "Agent name"
          },
          "group_id": {
            "type": "string",
            "description": "Group identifier"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive"
            ],
            "description": "Agent status"
          },
          "last_assigned": {
            "type": "string",
            "format": "date-time",
            "description": "Last assignment timestamp"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "message": {
            "type": "string",
            "description": "Detailed error description"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Agents"
    },
    {
      "name": "Round Robin"
    },
    {
      "name": "Tasks"
    }
  ]
}
