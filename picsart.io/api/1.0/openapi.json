{
  "openapi": "3.0.3",
  "info": {
    "title": "Picsart Enterprise API",
    "description": "Picsart Enterprise API provides powerful image and video manipulation tools including background removal, upscaling, effects, and more.",
    "version": "1.0",
    "contact": {
      "url": "https://docs.picsart.io/"
    }
  },
  "servers": [
    {
      "url": "https://api.picsart.io/tools/1.0",
      "description": "Image Tools API"
    },
    {
      "url": "https://video-api.picsart.io/v1",
      "description": "Video API"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/removebg": {
      "post": {
        "summary": "Remove & Change Background",
        "description": "Effortlessly identifies and isolates the foreground, ensuring every detail from jewelry to hair is captured. Supports background replacement with images or colors.",
        "operationId": "removeBackground",
        "servers": [
          {
            "url": "https://api.picsart.io/tools/1.0"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "description": "Binary image file, URL, or image ID",
                    "oneOf": [
                      {
                        "type": "string",
                        "format": "binary"
                      },
                      {
                        "type": "string",
                        "format": "uri"
                      }
                    ]
                  },
                  "output_type": {
                    "type": "string",
                    "enum": [
                      "mask",
                      "cutout"
                    ],
                    "description": "Output type: mask or cutout"
                  },
                  "bg_image": {
                    "type": "string",
                    "description": "Background image URL or binary"
                  },
                  "bg_color": {
                    "type": "string",
                    "description": "Background color (hex code or color name)"
                  },
                  "bg_blur": {
                    "type": "integer",
                    "description": "Background blur amount"
                  },
                  "stroke_size": {
                    "type": "integer",
                    "description": "Size of stroke/border"
                  },
                  "stroke_color": {
                    "type": "string",
                    "description": "Stroke color (hex code)"
                  },
                  "stroke_opacity": {
                    "type": "integer",
                    "description": "Stroke opacity (0-100)"
                  },
                  "shadow": {
                    "type": "string",
                    "description": "Shadow configuration"
                  },
                  "model": {
                    "type": "string",
                    "description": "Model selection for background removal"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "JPG",
                      "PNG",
                      "WEBP"
                    ],
                    "description": "Output format"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "headers": {
              "X-Picsart-Correlation-Id": {
                "schema": {
                  "type": "string"
                }
              },
              "X-Picsart-Ratelimit-Available": {
                "schema": {
                  "type": "integer"
                }
              },
              "X-Picsart-Ratelimit-Limit": {
                "schema": {
                  "type": "integer"
                }
              },
              "X-Picsart-Ratelimit-Reset-Time": {
                "schema": {
                  "type": "string"
                }
              },
              "X-Picsart-Credit-Available": {
                "schema": {
                  "type": "integer"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "url": {
                          "type": "string",
                          "format": "uri"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "402": {
            "description": "Payment Required"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          },
          "405": {
            "description": "Method Not Allowed"
          },
          "413": {
            "description": "Payload Too Large"
          },
          "415": {
            "description": "Unsupported Media Type"
          },
          "422": {
            "description": "Unprocessable Entity"
          },
          "429": {
            "description": "Too Many Requests"
          },
          "431": {
            "description": "Request Header Fields Too Large"
          },
          "500": {
            "description": "Internal Server Error"
          },
          "503": {
            "description": "Service Unavailable"
          }
        },
        "tags": [
          "removebg"
        ]
      }
    },
    "/upscale": {
      "post": {
        "summary": "Upscale Image",
        "description": "Upscale images by a factor of 2, 4, 6, or 8",
        "operationId": "upscaleImage",
        "servers": [
          {
            "url": "https://api.picsart.io/tools/1.0"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "image",
                  "upscale_factor"
                ],
                "properties": {
                  "image": {
                    "description": "Binary image file or URL",
                    "oneOf": [
                      {
                        "type": "string",
                        "format": "binary"
                      },
                      {
                        "type": "string",
                        "format": "uri"
                      }
                    ]
                  },
                  "upscale_factor": {
                    "type": "integer",
                    "enum": [
                      2,
                      4,
                      6,
                      8
                    ],
                    "description": "Upscale factor"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "JPG",
                      "PNG",
                      "WEBP"
                    ],
                    "description": "Output format"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          }
        },
        "tags": [
          "upscale"
        ]
      }
    },
    "/upscale/ultra": {
      "post": {
        "summary": "Ultra Upscale Image",
        "description": "Upscale images by a factor of 2-16 with sync, async, or auto modes",
        "operationId": "ultraUpscaleImage",
        "servers": [
          {
            "url": "https://api.picsart.io/tools/1.0"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "image",
                  "upscale_factor"
                ],
                "properties": {
                  "image": {
                    "description": "Binary image file or URL",
                    "oneOf": [
                      {
                        "type": "string",
                        "format": "binary"
                      },
                      {
                        "type": "string",
                        "format": "uri"
                      }
                    ]
                  },
                  "upscale_factor": {
                    "type": "integer",
                    "minimum": 2,
                    "maximum": 16,
                    "description": "Upscale factor (2-16)"
                  },
                  "mode": {
                    "type": "string",
                    "enum": [
                      "sync",
                      "async",
                      "auto"
                    ],
                    "description": "Processing mode"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "JPG",
                      "PNG",
                      "WEBP"
                    ],
                    "description": "Output format"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Synchronous response with result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          },
          "202": {
            "description": "Asynchronous response with transaction ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "transaction_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "upscale"
        ]
      }
    },
    "/upscale/ultra/{transaction_id}": {
      "get": {
        "summary": "Get Ultra Upscale Result",
        "description": "Retrieve the result of an asynchronous ultra upscale operation",
        "operationId": "getUltraUpscaleResult",
        "servers": [
          {
            "url": "https://api.picsart.io/tools/1.0"
          }
        ],
        "parameters": [
          {
            "name": "transaction_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Transaction ID from async upscale request"
          }
        ],
        "responses": {
          "200": {
            "description": "Result available",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          }
        },
        "tags": [
          "upscale"
        ]
      }
    },
    "/remove-background": {
      "post": {
        "summary": "Remove & Change Video Background",
        "description": "Remove video backgrounds or replace them with custom colors or images. Processes asynchronously.",
        "operationId": "removeVideoBackground",
        "servers": [
          {
            "url": "https://video-api.picsart.io/v1"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "video_url"
                ],
                "properties": {
                  "video_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Source video URL"
                  },
                  "bg_color": {
                    "type": "string",
                    "description": "Background color (hex code or color name). Use 'transparent' or '#00000000' for transparency. Default: #008800",
                    "default": "#008800"
                  },
                  "bg_image_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Background image URL (alternative to bg_color)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Processing started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "transaction_id": {
                      "type": "string",
                      "description": "Use this ID to check processing status"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "remove-background"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "ImageResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "remove-background"
    },
    {
      "name": "removebg"
    },
    {
      "name": "upscale"
    }
  ]
}
