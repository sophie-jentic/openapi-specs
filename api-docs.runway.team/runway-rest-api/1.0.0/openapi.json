{
  "openapi": "3.1.0",
  "info": {
    "title": "Runway REST API",
    "description": "Runway (runway.team) is a release management platform for mobile app teams. The REST API allows you to access information about your releases in Runway. Authentication via X-API-Key header.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api-docs.runway.team/openapi.json",
    "contact": {
      "name": "API Support"
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "servers": [
    {
      "url": "https://api.runway.team/v1",
      "description": "The production Runway server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "API root",
        "description": "Returns a welcome message with a link to the API documentation. No authentication required.",
        "operationId": "getApiRoot",
        "tags": [
          "app"
        ],
        "responses": {
          "200": {
            "description": "Welcome message",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/status": {
      "get": {
        "summary": "Health check",
        "description": "Returns a simple health check response. No authentication required.",
        "operationId": "getStatus",
        "tags": [
          "app"
        ],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/app/{appId}": {
      "get": {
        "summary": "Get app details",
        "description": "Returns the details of an app.",
        "operationId": "getAppById",
        "tags": [
          "app"
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "parameters": [
          {
            "name": "appId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique identifier for the app"
          }
        ],
        "responses": {
          "200": {
            "description": "App details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/App"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/app/{appId}/release": {
      "get": {
