{
  "openapi": "3.0.0",
  "info": {
    "title": "Systembolaget API",
    "description": "API for accessing Systembolaget's product catalog and store information. Systembolaget is the government-owned chain of liquor stores in Sweden.",
    "version": "1.0.0",
    "contact": {
      "url": "https://api-portal.systembolaget.se"
    }
  },
  "servers": [
    {
      "url": "https://api-systembolaget.azure-api.net"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/products/v1/product": {
      "get": {
        "summary": "Search products",
        "operationId": "searchProducts",
        "parameters": [
          {
            "name": "productNameSearchQuery",
            "in": "query",
            "description": "Search by product name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "categoryLevel1",
            "in": "query",
            "description": "Filter by primary category",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "categoryLevel2",
            "in": "query",
            "description": "Filter by secondary category",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "categoryLevel3",
            "in": "query",
            "description": "Filter by tertiary category",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "default": 30,
              "maximum": 100
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "Sort field",
            "schema": {
              "type": "string",
              "enum": ["Name", "Price", "Volume"]
            }
          },
          {
            "name": "sortDirection",
            "in": "query",
            "description": "Sort direction",
            "schema": {
              "type": "string",
              "enum": ["Ascending", "Descending"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Product"
                      }
                    },
                    "metadata": {
                      "$ref": "#/components/schemas/Metadata"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/products/v1/product/{productNumber}": {
      "get": {
        "summary": "Get product details",
        "operationId": "getProduct",
        "parameters": [
          {
            "name": "productNumber",
            "in": "path",
            "required": true,
            "description": "Product number",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          }
        }
      }
    },
    "/stores/v1/store": {
      "get": {
        "summary": "Search stores",
        "operationId": "searchStores",
        "parameters": [
          {
            "name": "storeName",
            "in": "query",
            "description": "Search by store name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "city",
            "in": "query",
            "description": "Filter by city",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "county",
            "in": "query",
            "description": "Filter by county",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "latitude",
            "in": "query",
            "description": "Latitude for geographic search",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "longitude",
            "in": "query",
            "description": "Longitude for geographic search",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "radiusInKm",
            "in": "query",
            "description": "Search radius in kilometers",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Store"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stores/v1/store/{siteId}": {
      "get": {
        "summary": "Get store details",
        "operationId": "getStore",
        "parameters": [
          {
            "name": "siteId",
            "in": "path",
            "required": true,
            "description": "Store site ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Store"
                }
              }
            }
          }
        }
      }
    },
    "/inventory/v1/store/{siteId}/product/{productNumber}": {
      "get": {
        "summary": "Get product inventory at specific store",
        "operationId": "getInventory",
        "parameters": [
          {
            "name": "siteId",
            "in": "path",
            "required": true,
            "description": "Store site ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "productNumber",
            "in": "path",
            "required": true,
            "description": "Product number",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Inventory"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Ocp-Apim-Subscription-Key",
        "description": "API subscription key"
      }
    },
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "productNumber": {
            "type": "string"
          },
          "productName": {
            "type": "string"
          },
          "productNameBold": {
            "type": "string"
          },
          "productNameThin": {
            "type": "string"
          },
          "categoryLevel1": {
            "type": "string"
          },
          "categoryLevel2": {
            "type": "string"
          },
          "categoryLevel3": {
            "type": "string"
          },
          "categoryLevel4": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "volume": {
            "type": "number",
            "format": "double"
          },
          "pricePerLiter": {
            "type": "number",
            "format": "double"
          },
          "alcoholPercentage": {
            "type": "number",
            "format": "double"
          },
          "assortment": {
            "type": "string"
          },
          "assortmentText": {
            "type": "string"
          },
          "beverageDescription": {
            "type": "string"
          },
          "usage": {
            "type": "string"
          },
          "taste": {
            "type": "string"
          },
          "tasteSymbols": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tasteClockGroupBitter": {
            "type": "integer"
          },
          "tasteClockGroupSmokiness": {
            "type": "integer"
          },
          "tasteClockBitter": {
            "type": "integer"
          },
          "tasteClockFruitacid": {
            "type": "integer"
          },
          "tasteClockBody": {
            "type": "integer"
          },
          "tasteClockRoughness": {
            "type": "integer"
          },
          "tasteClockSweetness": {
            "type": "integer"
          },
          "tasteClockSmokiness": {
            "type": "integer"
          },
          "tasteClockCasque": {
            "type": "integer"
          },
          "country": {
            "type": "string"
          },
          "originLevel1": {
            "type": "string"
          },
          "originLevel2": {
            "type": "string"
          },
          "producer": {
            "type": "string"
          },
          "supplier": {
            "type": "string"
          },
          "vintage": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "sugar": {
            "type": "number",
            "format": "double"
          },
          "sugarContent": {
            "type": "string"
          },
          "acid": {
            "type": "number",
            "format": "double"
          },
          "grapes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "packaging": {
            "type": "string"
          },
          "seal": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isNews": {
            "type": "boolean"
          },
          "isTemporaryOutOfStock": {
            "type": "boolean"
          },
          "isCompletelyOutOfStock": {
            "type": "boolean"
          },
          "isManufacturingCountry": {
            "type": "boolean"
          },
          "isRegionalRestricted": {
            "type": "boolean"
          },
          "isInStoreSearchAssortment": {
            "type": "boolean"
          },
          "isWebLaunch": {
            "type": "boolean"
          },
          "productLaunchDate": {
            "type": "string",
            "format": "date-time"
          },
          "imageUrl": {
            "type": "string"
          },
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "imageUrl": {
                  "type": "string"
                },
                "size": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Store": {
        "type": "object",
        "properties": {
          "siteId": {
            "type": "string"
          },
          "alias": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "postalCode": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "county": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "services": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "depot": {
            "type": "string"
          },
          "posNumber": {
            "type": "string"
          },
          "position": {
            "type": "object",
            "properties": {
              "latitude": {
                "type": "number",
                "format": "double"
              },
              "longitude": {
                "type": "number",
                "format": "double"
              }
            }
          },
          "openingHours": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string",
                  "format": "date"
                },
                "openFrom": {
                  "type": "string"
                },
                "openTo": {
                  "type": "string"
                },
                "reason": {
                  "type": "string"
                }
              }
            }
          },
          "isAgent": {
            "type": "boolean"
          },
          "distanceInMeters": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "Inventory": {
        "type": "object",
        "properties": {
          "siteId": {
            "type": "string"
          },
          "productNumber": {
            "type": "string"
          },
          "stockLevel": {
            "type": "integer"
          },
          "isSellableInStore": {
            "type": "boolean"
          },
          "nextDeliveryDate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "Metadata": {
        "type": "object",
        "properties": {
          "docCount": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          }
        }
      }
    }
  }
}
