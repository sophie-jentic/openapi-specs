{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenWISP Controller API",
    "version": "1.0.0",
    "description": "OpenWISP is a modular network management system. The Controller API provides REST endpoints for managing devices, configurations, templates, VPN servers, organizations, and network topology. It uses Django REST Framework with token authentication.",
    "x-jentic-source-url": "https://openwisp.io/docs/stable/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{openwisp-host}/api/v1"
    }
  ],
  "paths": {
    "/controller/device/": {
      "get": {
        "operationId": "listDevices",
        "summary": "List devices",
        "tags": [
          "Devices"
        ],
        "parameters": [
          {
            "name": "organization",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by organization slug"
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by device name"
          },
          {
            "name": "mac_address",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by MAC address"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Device list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedDeviceList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List devices"
      },
      "post": {
        "operationId": "createDevice",
        "summary": "Create a device",
        "tags": [
          "Devices"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Device created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Device"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a device"
      }
    },
