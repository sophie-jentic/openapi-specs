  "components": {
    "schemas": {
      "Device": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "organization": {
            "type": "string",
            "format": "uuid"
          },
          "mac_address": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "os": {
            "type": "string"
          },
          "system": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "config": {
            "type": "object"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "modified": {
            "type": "string",
            "format": "date-time"
          },
          "last_ip": {
            "type": "string"
          },
          "management_ip": {
            "type": "string"
          },
          "group": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "DeviceCreate": {
        "type": "object",
        "required": [
          "name",
          "organization",
          "mac_address"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "organization": {
            "type": "string",
            "format": "uuid"
          },
          "mac_address": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "os": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "config": {
            "type": "object"
          }
        }
      },
      "TemplateCreate": {
        "type": "object",
        "required": [
          "name",
          "organization",
          "backend",
          "config"
