{
  "openapi": "3.0.3",
  "info": {
    "title": "Navitia API",
    "version": "2.0.0",
    "description": "Navitia is the open API for building cool stuff with transport data. Journey planning, isochrones, schedules, and more.",
    "x-jentic-source-url": "https://doc.navitia.io/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.navitia.io/v1"
    }
  ],
  "paths": {
    "/coverage": {
      "get": {
        "operationId": "getCoverage",
        "summary": "List coverage areas",
        "tags": [
          "Coverage"
        ],
        "responses": {
          "200": {
            "description": "Coverage areas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "regions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Region"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List coverage areas"
      }
    },
    "/coverage/{region}/journeys": {
      "get": {
        "operationId": "getJourneys",
        "summary": "Plan a journey",
        "tags": [
          "Journeys"
        ],
        "parameters": [
          {
            "name": "region",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Origin (coord or stop_area)"
          },
          {
            "name": "to",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Destination"
          },
          {
            "name": "datetime",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "datetime_represents",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "departure",
                "arrival"
              ]
            }
          },
          {
            "name": "max_nb_journeys",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Journeys",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JourneyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Plan a journey"
      }
    },
    "/coverage/{region}/isochrones": {
      "get": {
        "operationId": "getIsochrones",
        "summary": "Get isochrone map",
        "tags": [
          "Journeys"
        ],
        "parameters": [
          {
            "name": "region",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "datetime",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "max_duration",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Isochrone",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get isochrone map"
      }
    },
    "/coverage/{region}/stop_areas": {
      "get": {
        "operationId": "getStopAreas",
        "summary": "List stop areas",
        "tags": [
          "Public Transport"
        ],
        "parameters": [
          {
            "name": "region",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25
            }
          },
          {
            "name": "start_page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stop areas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stop_areas": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/StopArea"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List stop areas"
      }
    },
    "/coverage/{region}/lines": {
      "get": {
        "operationId": "getLines",
        "summary": "List transit lines",
        "tags": [
          "Public Transport"
        ],
        "parameters": [
          {
            "name": "region",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lines",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "lines": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Line"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List transit lines"
      }
    },
    "/coverage/{region}/stop_areas/{stopAreaId}/departures": {
      "get": {
        "operationId": "getDepartures",
        "summary": "Get departures from stop",
        "tags": [
          "Schedules"
        ],
        "parameters": [
          {
            "name": "region",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "stopAreaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from_datetime",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Departures",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepartureResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get departures from stop"
      }
    },
    "/coverage/{region}/stop_areas/{stopAreaId}/arrivals": {
      "get": {
        "operationId": "getArrivals",
        "summary": "Get arrivals at stop",
        "tags": [
          "Schedules"
        ],
        "parameters": [
          {
            "name": "region",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "stopAreaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from_datetime",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Arrivals",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepartureResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get arrivals at stop"
      }
    },
    "/coverage/{region}/places": {
      "get": {
        "operationId": "searchPlaces",
        "summary": "Search places",
        "tags": [
          "Places"
        ],
        "parameters": [
          {
            "name": "region",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "stop_area",
                  "address",
                  "poi",
                  "administrative_region"
                ]
              }
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Places",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "places": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Place"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Search places"
      }
    },
    "/coverage/{region}/disruptions": {
      "get": {
        "operationId": "getDisruptions",
        "summary": "Get disruptions",
        "tags": [
          "Disruptions"
        ],
        "parameters": [
          {
            "name": "region",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "since",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "until",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Disruptions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "disruptions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Disruption"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get disruptions"
      }
    }
  },
  "components": {
    "schemas": {
      "Region": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "JourneyResponse": {
        "type": "object",
        "properties": {
          "journeys": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Journey"
            }
          }
        }
      },
      "Journey": {
        "type": "object",
        "properties": {
          "duration": {
            "type": "integer"
          },
          "nb_transfers": {
            "type": "integer"
          },
          "departure_date_time": {
            "type": "string"
          },
          "arrival_date_time": {
            "type": "string"
          },
          "sections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Section"
            }
          }
        }
      },
      "Section": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "duration": {
            "type": "integer"
          },
          "from": {
            "$ref": "#/components/schemas/Place"
          },
          "to": {
            "$ref": "#/components/schemas/Place"
          },
          "display_informations": {
            "type": "object",
            "properties": {
              "network": {
                "type": "string"
              },
              "direction": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "color": {
                "type": "string"
              }
            }
          }
        }
      },
      "StopArea": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "coord": {
            "type": "object",
            "properties": {
              "lat": {
                "type": "string"
              },
              "lon": {
                "type": "string"
              }
            }
          }
        }
      },
      "Line": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "network": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            }
          }
        }
      },
      "Place": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "embedded_type": {
            "type": "string"
          }
        }
      },
      "DepartureResponse": {
        "type": "object",
        "properties": {
          "departures": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "stop_date_time": {
                  "type": "object",
                  "properties": {
                    "departure_date_time": {
                      "type": "string"
                    },
                    "arrival_date_time": {
                      "type": "string"
                    }
                  }
                },
                "route": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "direction": {
                      "$ref": "#/components/schemas/Place"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Disruption": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "severity": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "effect": {
                "type": "string"
              }
            }
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "API key as username, no password"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Coverage",
      "description": "Coverage areas"
    },
    {
      "name": "Journeys",
      "description": "Journey planning and isochrones"
    },
    {
      "name": "Public Transport",
      "description": "Stops, lines, routes"
    },
    {
      "name": "Schedules",
      "description": "Departures and arrivals"
    },
    {
      "name": "Places",
      "description": "Place search"
    },
    {
      "name": "Disruptions",
      "description": "Service disruptions"
    }
  ]
}
