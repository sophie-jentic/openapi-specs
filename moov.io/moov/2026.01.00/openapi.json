{
  "openapi": "3.0.3",
  "info": {
    "title": "Moov API",
    "version": "2026.01.00",
    "description": "The Moov API provides a comprehensive platform for payment processing, money movement, and financial account management. This API enables businesses to manage transfers, process refunds, handle disputes, issue cards, and integrate various payment methods including bank accounts, cards, Apple Pay, and wallets.",
    "contact": {
      "name": "Moov Support",
      "url": "https://docs.moov.io"
    }
  },
  "servers": [
    {
      "url": "https://api.moov.io",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Access token and authentication management"
    },
    {
      "name": "Accounts",
      "description": "Moov account management operations"
    },
    {
      "name": "Sources",
      "description": "Payment method management (bank accounts, cards, wallets)"
    },
    {
      "name": "Transfers",
      "description": "Money movement and transfer operations"
    },
    {
      "name": "Refunds",
      "description": "Refund processing and management"
    },
    {
      "name": "Disputes",
      "description": "Dispute handling and resolution"
    },
    {
      "name": "Cards",
      "description": "Card issuing and management"
    },
    {
      "name": "Payment Links",
      "description": "Payment link creation and management"
    },
    {
      "name": "Enrichment",
      "description": "Branding, forms, and institution data"
    }
  ],
  "paths": {
    "/accounts": {
      "post": {
        "summary": "Create an account",
        "description": "Create a new Moov account",
        "tags": ["Accounts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "get": {
        "summary": "List accounts",
        "description": "Retrieve a list of accounts",
        "tags": ["Accounts"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of accounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Account"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{accountID}": {
      "get": {
        "summary": "Get account details",
        "description": "Retrieve details of a specific account",
        "tags": ["Accounts"],
        "parameters": [
          {
            "name": "accountID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Account details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "404": {
            "description": "Account not found"
          }
        }
      },
      "patch": {
        "summary": "Update account",
        "description": "Update an existing account",
        "tags": ["Accounts"],
        "parameters": [
          {
            "name": "accountID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{accountID}/bank-accounts": {
      "post": {
        "summary": "Add bank account",
        "description": "Add a bank account as a payment source",
        "tags": ["Sources"],
        "parameters": [
          {
            "name": "accountID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BankAccountCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bank account added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BankAccount"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List bank accounts",
        "description": "List all bank accounts for an account",
        "tags": ["Sources"],
        "parameters": [
          {
            "name": "accountID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of bank accounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BankAccount"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{accountID}/transfers": {
      "post": {
        "summary": "Create transfer",
        "description": "Create a new money transfer",
        "tags": ["Transfers"],
        "parameters": [
          {
            "name": "accountID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Transfer created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transfer"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List transfers",
        "description": "List all transfers for an account",
        "tags": ["Transfers"],
        "parameters": [
          {
            "name": "accountID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of transfers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Transfer"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{accountID}/transfers/{transferID}": {
      "get": {
        "summary": "Get transfer details",
        "description": "Retrieve details of a specific transfer",
        "tags": ["Transfers"],
        "parameters": [
          {
            "name": "accountID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "transferID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transfer details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transfer"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{accountID}/refunds": {
      "post": {
        "summary": "Create refund",
        "description": "Create a new refund",
        "tags": ["Refunds"],
        "parameters": [
          {
            "name": "accountID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefundCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Refund created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Refund"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{accountID}/cards": {
      "post": {
        "summary": "Issue card",
        "description": "Issue a new card",
        "tags": ["Cards"],
        "parameters": [
          {
            "name": "accountID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CardCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Card issued successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Card"
                }
              }
            }
          }
        }
      }
    },
    "/payment-links": {
      "post": {
        "summary": "Create payment link",
        "description": "Create a new payment link",
        "tags": ["Payment Links"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentLinkCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Payment link created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentLink"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Account": {
        "type": "object",
        "properties": {
          "accountID": {
            "type": "string",
            "description": "Unique identifier for the account"
          },
          "accountType": {
            "type": "string",
            "enum": ["individual", "business"]
          },
          "displayName": {
            "type": "string"
          },
          "profile": {
            "type": "object"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdOn": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AccountCreate": {
        "type": "object",
        "required": ["accountType"],
        "properties": {
          "accountType": {
            "type": "string",
            "enum": ["individual", "business"]
          },
          "profile": {
            "type": "object"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AccountUpdate": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string"
          },
          "profile": {
            "type": "object"
          }
        }
      },
      "BankAccount": {
        "type": "object",
        "properties": {
          "bankAccountID": {
            "type": "string"
          },
          "accountNumber": {
            "type": "string"
          },
          "routingNumber": {
            "type": "string"
          },
          "accountType": {
            "type": "string",
            "enum": ["checking", "savings"]
          },
          "holderName": {
            "type": "string"
          }
        }
      },
      "BankAccountCreate": {
        "type": "object",
        "required": ["accountNumber", "routingNumber", "accountType"],
        "properties": {
          "accountNumber": {
            "type": "string"
          },
          "routingNumber": {
            "type": "string"
          },
          "accountType": {
            "type": "string",
            "enum": ["checking", "savings"]
          },
          "holderName": {
            "type": "string"
          }
        }
      },
      "Transfer": {
        "type": "object",
        "properties": {
          "transferID": {
            "type": "string"
          },
          "amount": {
            "type": "object",
            "properties": {
              "value": {
                "type": "integer"
              },
              "currency": {
                "type": "string"
              }
            }
          },
          "source": {
            "type": "object"
          },
          "destination": {
            "type": "object"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "completed", "failed", "canceled"]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TransferCreate": {
        "type": "object",
        "required": ["amount", "source", "destination"],
        "properties": {
          "amount": {
            "type": "object",
            "required": ["value", "currency"],
            "properties": {
              "value": {
                "type": "integer"
              },
              "currency": {
                "type": "string"
              }
            }
          },
          "source": {
            "type": "object"
          },
          "destination": {
            "type": "object"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "Refund": {
        "type": "object",
        "properties": {
          "refundID": {
            "type": "string"
          },
          "amount": {
            "type": "object",
            "properties": {
              "value": {
                "type": "integer"
              },
              "currency": {
                "type": "string"
              }
            }
          },
          "status": {
            "type": "string"
          }
        }
      },
      "RefundCreate": {
        "type": "object",
        "required": ["transferID", "amount"],
        "properties": {
          "transferID": {
            "type": "string"
          },
          "amount": {
            "type": "object",
            "required": ["value", "currency"],
            "properties": {
              "value": {
                "type": "integer"
              },
              "currency": {
                "type": "string"
              }
            }
          }
        }
      },
      "Card": {
        "type": "object",
        "properties": {
          "cardID": {
            "type": "string"
          },
          "cardType": {
            "type": "string"
          },
          "lastFour": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "CardCreate": {
        "type": "object",
        "required": ["cardType"],
        "properties": {
          "cardType": {
            "type": "string"
          },
          "shippingAddress": {
            "type": "object"
          }
        }
      },
      "PaymentLink": {
        "type": "object",
        "properties": {
          "paymentLinkID": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "amount": {
            "type": "object",
            "properties": {
              "value": {
                "type": "integer"
              },
              "currency": {
                "type": "string"
              }
            }
          },
          "status": {
            "type": "string"
          }
        }
      },
      "PaymentLinkCreate": {
        "type": "object",
        "required": ["amount"],
        "properties": {
          "amount": {
            "type": "object",
            "required": ["value", "currency"],
            "properties": {
              "value": {
                "type": "integer"
              },
              "currency": {
                "type": "string"
              }
            }
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
