{
  "openapi": "3.0.3",
  "info": {
    "title": "Fintel API",
    "version": "1.0.0",
    "description": "Fintel provides financial intelligence data including institutional ownership, short interest, insider trading, and options flow data.",
    "x-jentic-source-url": "https://fintel.io/api-developers",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.fintel.io/web/v1"
    }
  ],
  "paths": {
    "/ownership/{ticker}": {
      "get": {
        "operationId": "getInstitutionalOwnership",
        "summary": "Get institutional ownership",
        "tags": [
          "Ownership"
        ],
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Stock ticker symbol"
          }
        ],
        "responses": {
          "200": {
            "description": "Ownership data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OwnershipResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get institutional ownership"
      }
    },
    "/short-interest/{ticker}": {
      "get": {
        "operationId": "getShortInterest",
        "summary": "Get short interest data",
        "tags": [
          "Short Interest"
        ],
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Short interest data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShortInterestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get short interest data"
      }
    },
    "/insider-trading/{ticker}": {
      "get": {
        "operationId": "getInsiderTrading",
        "summary": "Get insider trading data",
        "tags": [
          "Insider Trading"
        ],
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Insider trading data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InsiderTradingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get insider trading data"
      }
    },
    "/options-flow/{ticker}": {
      "get": {
        "operationId": "getOptionsFlow",
        "summary": "Get options flow data",
        "tags": [
          "Options"
        ],
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Options flow data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OptionsFlowResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get options flow data"
      }
    }
  },
  "components": {
    "schemas": {
      "OwnershipResponse": {
        "type": "object",
        "properties": {
          "ticker": {
            "type": "string"
          },
          "institutions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "shares": {
                  "type": "integer"
                },
                "value": {
                  "type": "number"
                },
                "change": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "ShortInterestResponse": {
        "type": "object",
        "properties": {
          "ticker": {
            "type": "string"
          },
          "shortInterest": {
            "type": "number"
          },
          "shortInterestRatio": {
            "type": "number"
          },
          "sharesShort": {
            "type": "integer"
          }
        }
      },
      "InsiderTradingResponse": {
        "type": "object",
        "properties": {
          "ticker": {
            "type": "string"
          },
          "transactions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "insiderName": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "transactionType": {
                  "type": "string"
                },
                "shares": {
                  "type": "integer"
                },
                "price": {
                  "type": "number"
                },
                "date": {
                  "type": "string",
                  "format": "date"
                }
              }
            }
          }
        }
      },
      "OptionsFlowResponse": {
        "type": "object",
        "properties": {
          "ticker": {
            "type": "string"
          },
          "flows": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "call",
                    "put"
                  ]
                },
                "strike": {
                  "type": "number"
                },
                "expiration": {
                  "type": "string",
                  "format": "date"
                },
                "premium": {
                  "type": "number"
                },
                "volume": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Fintel API key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Insider Trading"
    },
    {
      "name": "Options"
    },
    {
      "name": "Ownership"
    },
    {
      "name": "Short Interest"
    }
  ]
}
