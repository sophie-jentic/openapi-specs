{
  "openapi": "3.0.3",
  "info": {
    "title": "EasyCSV API",
    "version": "1.0.0",
    "description": "EasyCSV provides a webhook-based API for importing CSV files and processing data. Import CSVs via HTTP POST requests to an EasyCSV endpoint, then receive parsed row data via webhooks to your application. Also supports email-based imports and scheduled imports from Google Sheets, Airtable, and file servers.",
    "x-jentic-source-url": "https://easycsv.io/docs/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.easycsv.io",
      "description": "EasyCSV"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/{company_slug}/{sheet_slug}": {
      "post": {
        "operationId": "importFile",
        "tags": [
          "Import"
        ],
        "summary": "Import a CSV/XLSX file",
        "description": "POST a CSV file URL to the EasyCSV import endpoint. EasyCSV will fetch the file and process each row, then POST each row to your webhook URL.",
        "parameters": [
          {
            "name": "company_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your EasyCSV company slug"
          },
          {
            "name": "sheet_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your EasyCSV sheet/import slug"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import started successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ImportRequest": {
        "type": "object",
        "required": [
          "api_key",
          "public_file_url"
        ],
        "properties": {
          "api_key": {
            "type": "string",
            "description": "Your EasyCSV API key"
          },
          "public_file_url": {
            "type": "string",
            "description": "Publicly accessible URL to the CSV, XLSX, or ZIP file"
          },
          "importer_email": {
            "type": "string",
            "description": "Email address where import results will be sent"
          },
          "import_name": {
            "type": "string",
            "description": "Name for this import (defaults to filename)"
          },
          "import_code": {
            "type": "string",
            "description": "Optional unique code for identifying and validating the import"
          },
          "extra_columns": {
            "type": "object",
            "description": "JSON hash of extra column key-value pairs added to every row/record",
            "additionalProperties": true
          }
        }
      },
      "ImportResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "import_id": {
            "type": "integer",
            "description": "Unique ID for this import"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "tags": [
    {
      "name": "Import"
    }
  ]
}
