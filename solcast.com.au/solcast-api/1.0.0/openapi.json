{
  "openapi": "3.0.3",
  "info": {
    "title": "Solcast API",
    "version": "1.0.0",
    "description": "Solcast provides forecast, live, and historical solar irradiance, PV power, and weather data.",
    "x-jentic-source-url": "https://solcast.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.solcast.com.au"
    }
  ],
  "paths": {
    "/world_radiation/forecasts": {
      "get": {
        "operationId": "getRadiationForecasts",
        "summary": "Get radiation forecasts",
        "tags": [
          "Radiation"
        ],
        "parameters": [
          {
            "name": "latitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "hours",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RadiationForecastResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get radiation forecasts"
      }
    },
