    }
  },
  "components": {
    "schemas": {
      "RadiationForecastResponse": {
        "type": "object",
        "properties": {
          "forecasts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RadiationDataPoint"
            }
          }
        }
      },
      "RadiationEstimatedResponse": {
        "type": "object",
        "properties": {
          "estimated_actuals": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RadiationDataPoint"
            }
          }
        }
      },
      "RadiationDataPoint": {
        "type": "object",
        "properties": {
          "ghi": {
            "type": "number"
          },
          "dni": {
            "type": "number"
          },
          "dhi": {
            "type": "number"
          },
          "air_temp": {
            "type": "number"
          },
          "period_end": {
            "type": "string",
            "format": "date-time"
          },
          "period": {
            "type": "string"
          }
        }
      },
      "PvPowerForecastResponse": {
        "type": "object",
        "properties": {
          "forecasts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PvPowerDataPoint"
            }
          }
        }
      },
      "PvPowerEstimatedResponse": {
        "type": "object",
        "properties": {
          "estimated_actuals": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PvPowerDataPoint"
            }
          }
        }
      },
      "PvPowerDataPoint": {
        "type": "object",
        "properties": {
          "pv_estimate": {
            "type": "number"
          },
          "period_end": {
            "type": "string",
            "format": "date-time"
          },
          "period": {
            "type": "string"
          }
        }
      },
      "TmyResponse": {
        "type": "object",
        "properties": {
          "tmy_hourly": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
