  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "BotDetectionEvent": {
        "type": "object",
        "properties": {
          "ip": {
            "type": "string"
          },
          "uas": {
            "type": "string"
          },
          "event_id": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "recipient_id": {
            "type": "string"
          },
          "message_id": {
            "type": "string"
          },
          "ts": {
            "type": "string"
          },
          "message_ts": {
            "type": "string"
          }
        },
        "required": [
          "ip",
          "uas",
          "event_id"
        ]
      },
      "EmailValidationResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string",
            "enum": [
              "deliverable",
              "undeliverable",
              "risky",
              "unknown"
            ]
          },
          "reason": {
            "type": "string"
          },
          "role": {
            "type": "boolean"
          },
          "free": {
            "type": "boolean"
          },
          "disposable": {
            "type": "boolean"
          },
          "did_you_mean": {
            "type": "string"
          },
          "sendex": {
            "type": "number"
          },
          "email": {
            "type": "string"
          },
          "user": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          }
        }
      },
      "Domain": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "data_location": {
            "type": "string"
          },
          "wildcard": {
            "type": "boolean"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "ov-token"
      }
    }
  },
  "security": [
