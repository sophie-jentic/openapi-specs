{
  "openapi": "3.1.0",
  "info": {
    "title": "SoChain Dogecoin Blockchain API",
    "description": "SoChain (chain.so) provides a fast blockchain API for querying Dogecoin (DOGE) network data including addresses, transactions, blocks, balances, and price information. Response times average 5ms. Supports mainnet (DOGE) and testnet (DOGETEST).",
    "version": "3.0.0",
    "contact": {
      "name": "SoChain",
      "url": "https://chain.so"
    }
  },
  "servers": [
    {
      "url": "https://chain.so/api/v3",
      "description": "SoChain API v3 production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/balance/DOGE/{address}": {
      "get": {
        "operationId": "getDogeBalance",
        "summary": "Get address balance",
        "description": "Returns the confirmed and unconfirmed Dogecoin balance for a given address.",
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "The Dogecoin address to query.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful balance response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BalanceResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "balance"
        ]
      }
    },
    "/address_summary/DOGE/{address}": {
      "get": {
        "operationId": "getDogeAddressSummary",
        "summary": "Get address summary",
        "description": "Returns basic statistics for a Dogecoin address including transaction counts and value totals.",
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "The Dogecoin address to query.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful address summary response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddressSummaryResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "address_summary"
        ]
      }
    },
    "/transactions/DOGE/{address}/{page}": {
      "get": {
        "operationId": "getDogeAddressTransactions",
        "summary": "Get address transactions",
        "description": "Returns paginated transactions for a Dogecoin address, 10 per page.",
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "The Dogecoin address to query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "path",
            "required": true,
            "description": "Page number for pagination (starts at 1).",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful transactions response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "transactions"
        ]
      }
    },
    "/transaction_counts/DOGE/{address}": {
      "get": {
        "operationId": "getDogeTransactionCounts",
        "summary": "Get transaction counts for address",
        "description": "Returns the sent, received, and total transaction counts for a Dogecoin address.",
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "The Dogecoin address to query.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful transaction counts response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionCountsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "transaction_counts"
        ]
      }
    },
    "/unspent_outputs/DOGE/{address}/{page}": {
      "get": {
        "operationId": "getDogeUnspentOutputs",
        "summary": "Get unspent transaction outputs",
        "description": "Returns paginated unspent outputs (UTXOs) for a Dogecoin address, 10 per page.",
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "The Dogecoin address to query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "path",
            "required": true,
            "description": "Page number for pagination (starts at 1).",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful unspent outputs response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnspentOutputsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "unspent_outputs"
        ]
      }
    },
    "/is_valid_address/DOGE/{address}": {
      "get": {
        "operationId": "isValidDogeAddress",
        "summary": "Validate Dogecoin address",
        "description": "Checks if a given address is a valid Dogecoin address format.",
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "The address to validate.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful validation response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidAddressResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "is_valid_address"
        ]
      }
    },
    "/transaction/DOGE/{hash}": {
      "get": {
        "operationId": "getDogeTransaction",
        "summary": "Get transaction details",
        "description": "Returns complete transaction data for a given Dogecoin transaction hash.",
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "description": "The transaction hash to look up.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful transaction response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionDetailResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "transaction"
        ]
      }
    },
    "/latest_blocks_summary/DOGE": {
      "get": {
        "operationId": "getDogeLatestBlocksSummary",
        "summary": "Get latest blocks summary",
        "description": "Returns a summary of the last 10 blocks on the Dogecoin network.",
        "responses": {
          "200": {
            "description": "Successful blocks summary response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LatestBlocksSummaryResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "latest_blocks_summary"
        ]
      }
    },
    "/block/DOGE/{block_hash_or_height}": {
      "get": {
        "operationId": "getDogeBlock",
        "summary": "Get block data",
        "description": "Returns block data by block hash or block height.",
        "parameters": [
          {
            "name": "block_hash_or_height",
            "in": "path",
            "required": true,
            "description": "The block hash or block height to query.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful block response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlockResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "block"
        ]
      }
    },
    "/best_block_hash/DOGE": {
      "get": {
        "operationId": "getDogeBestBlockHash",
        "summary": "Get latest block hash",
        "description": "Returns the hash of the latest indexed block on the Dogecoin network.",
        "responses": {
          "200": {
            "description": "Successful best block hash response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BestBlockHashResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "best_block_hash"
        ]
      }
    },
    "/price/DOGE/{unix_timestamp}": {
      "get": {
        "operationId": "getDogePrice",
        "summary": "Get Dogecoin price at timestamp",
        "description": "Returns the Dogecoin price at a specific Unix timestamp.",
        "parameters": [
          {
            "name": "unix_timestamp",
            "in": "path",
            "required": true,
            "description": "Unix timestamp for the price query.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful price response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "price"
        ]
      }
    },
    "/network_info/DOGE": {
      "get": {
        "operationId": "getDogeNetworkInfo",
        "summary": "Get network information",
        "description": "Returns Dogecoin network statistics including mempool data, fee rates, and expected block composition for the next 6 blocks.",
        "responses": {
          "200": {
            "description": "Successful network info response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NetworkInfoResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "tags": [
          "network_info"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "API-KEY",
        "in": "header",
        "description": "API key obtained from the SoChain dashboard. Must not be published client-side."
      }
    },
    "schemas": {
      "SuccessEnvelope": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status",
          "data"
        ]
      },
      "ErrorEnvelope": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "fail"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "error_message": {
                "type": "string"
              }
            },
            "required": [
              "error_message"
            ]
          }
        },
        "required": [
          "status",
          "data"
        ]
      },
      "BalanceResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "confirmed": {
                "type": "string",
                "description": "Confirmed balance in DOGE."
              },
              "unconfirmed": {
                "type": "string",
                "description": "Unconfirmed balance in DOGE."
              }
            }
          }
        }
      },
      "AddressSummaryResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "confirmed": {
                "type": "string"
              },
              "unconfirmed": {
                "type": "string"
              },
              "txs_sent": {
                "type": "integer",
                "description": "Number of transactions sent."
              },
              "txs_received": {
                "type": "integer",
                "description": "Number of transactions received."
              },
              "balance_change": {
                "type": "string",
                "description": "Net balance change."
              },
              "value_sent": {
                "type": "string",
                "description": "Total value sent."
              },
              "value_received": {
                "type": "string",
                "description": "Total value received."
              }
            }
          }
        }
      },
      "TransactionsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "transactions": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/TransactionSummary"
                }
              }
            }
          }
        }
      },
      "TransactionCountsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "txs_sent": {
                "type": "integer"
              },
              "txs_received": {
                "type": "integer"
              },
              "txs_total": {
                "type": "integer"
              }
            }
          }
        }
      },
      "UnspentOutputsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "outputs": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/UnspentOutput"
                }
              }
            }
          }
        }
      },
      "ValidAddressResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "is_valid": {
                "type": "boolean",
                "description": "Whether the address is valid on the DOGE network."
              }
            }
          }
        }
      },
      "TransactionDetailResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "hash": {
                "type": "string"
              },
              "confirmations": {
                "type": "integer"
              },
              "size": {
                "type": "integer",
                "description": "Transaction size in bytes."
              },
              "vsize": {
                "type": "integer",
                "description": "Virtual transaction size."
              },
              "weight": {
                "type": "integer",
                "description": "Transaction weight."
              },
              "fee": {
                "type": "string",
                "description": "Transaction fee in DOGE."
              },
              "block_height": {
                "type": "integer",
                "description": "Block height where the transaction was confirmed."
              },
              "time": {
                "type": "integer",
                "description": "Unix timestamp of the transaction."
              },
              "price": {
                "type": "string",
                "description": "DOGE price at the time of the transaction."
              },
              "inputs": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/TransactionInput"
                }
              },
              "outputs": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/TransactionOutput"
                }
              }
            }
          }
        }
      },
      "LatestBlocksSummaryResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BlockSummary"
            },
            "description": "Summary of the last 10 blocks."
          }
        }
      },
      "BlockResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "height": {
                "type": "integer"
              },
              "hash": {
                "type": "string"
              },
              "difficulty": {
                "type": "string"
              },
              "merkleroot": {
                "type": "string"
              },
              "nonce": {
                "type": "integer"
              },
              "reward": {
                "type": "string",
                "description": "Block reward in DOGE."
              },
              "fees": {
                "type": "string",
                "description": "Total fees in the block."
              },
              "num_txs": {
                "type": "integer",
                "description": "Number of transactions in the block."
              },
              "weight": {
                "type": "integer"
              },
              "time": {
                "type": "integer",
                "description": "Unix timestamp of the block."
              }
            }
          }
        }
      },
      "BestBlockHashResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "hash": {
                "type": "string",
                "description": "Hash of the latest indexed block."
              }
            }
          }
        }
      },
      "PriceResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "price": {
                "type": "string",
                "description": "Price of DOGE in USD at the given timestamp."
              },
              "timestamp": {
                "type": "integer"
              }
            }
          }
        }
      },
      "NetworkInfoResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "mempool_txs": {
                "type": "integer",
                "description": "Number of transactions in the mempool."
              },
              "mempool_size": {
                "type": "integer",
                "description": "Mempool size in bytes."
              },
              "min_fee_rate": {
                "type": "string",
                "description": "Minimum fee rate in the mempool."
              },
              "median_fee_rate": {
                "type": "string",
                "description": "Median fee rate in the mempool."
              }
            }
          }
        }
      },
      "TransactionSummary": {
        "type": "object",
        "properties": {
          "hash": {
            "type": "string"
          },
          "time": {
            "type": "integer"
          },
          "block_height": {
            "type": "integer"
          },
          "confirmations": {
            "type": "integer"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "UnspentOutput": {
        "type": "object",
        "properties": {
          "txid": {
            "type": "string"
          },
          "output_no": {
            "type": "integer"
          },
          "value": {
            "type": "string"
          },
          "confirmations": {
            "type": "integer"
          }
        }
      },
      "TransactionInput": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "txid": {
            "type": "string"
          },
          "output_no": {
            "type": "integer"
          }
        }
      },
      "TransactionOutput": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "output_no": {
            "type": "integer"
          }
        }
      },
      "BlockSummary": {
        "type": "object",
        "properties": {
          "height": {
            "type": "integer"
          },
          "hash": {
            "type": "string"
          },
          "time": {
            "type": "integer"
          },
          "num_txs": {
            "type": "integer"
          },
          "reward": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Invalid or missing API key.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        }
      },
      "NotFound": {
        "description": "The requested resource was not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Rate limit exceeded.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "address_summary"
    },
    {
      "name": "balance"
    },
    {
      "name": "best_block_hash"
    },
