{
  "openapi": "3.0.3",
  "info": {
    "title": "StealthSeminar API",
    "version": "1.0.0",
    "description": "StealthSeminar API for webinar registration and management.",
    "x-jentic-source-url": "https://docs.stealthseminarapp.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.joinnow.live"
    }
  ],
  "paths": {
    "/webinars/{shortId}/registration-information": {
      "get": {
        "operationId": "getRegistrationInfo",
        "summary": "Get registration information",
        "description": "Retrieves webinar details including title, timezone, upcoming times, and registration configuration settings.",
        "tags": [
          "Webinars"
        ],
        "parameters": [
          {
            "name": "shortId",
            "in": "path",
            "required": true,
            "description": "The 6-character webinar identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistrationInfo"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Webinar not found"
          }
        }
      }
    },
    "/webinars/{shortId}/registration": {
      "post": {
        "operationId": "registerForWebinar",
        "summary": "Register for a webinar",
        "description": "Registers an attendee for a specific webinar instance with their contact and custom information.",
        "tags": [
          "Webinars"
        ],
        "parameters": [
          {
            "name": "shortId",
            "in": "path",
            "required": true,
            "description": "The 6-character webinar identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistrationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registration successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistrationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RegistrationInfo": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "upcoming_times": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "date-time"
            }
          },
          "registration_config": {
            "type": "object"
          }
        }
      },
      "RegistrationRequest": {
        "type": "object",
        "properties": {
          "start_time": {
            "type": "string",
            "format": "date-time",
            "description": "Event start time in ISO 8601 format"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Registrant email address"
          },
          "name": {
            "type": "string",
            "description": "Registrant name"
          },
          "sms_number": {
            "type": "string",
            "description": "Phone number for SMS reminders"
          },
          "timezone": {
            "type": "string",
            "description": "Registrant timezone"
          },
          "gdprConsentReceived": {
            "type": "boolean",
            "description": "GDPR consent status"
          },
          "customFields": {
            "type": "object",
            "description": "Additional registration information"
          },
          "linkParams": {
            "type": "object",
            "description": "Marketing or UTM parameters"
          },
          "registration_page_id": {
            "type": "string",
            "description": "Source registration page ID"
          },
          "yesterdays_now": {
            "type": "boolean",
            "description": "Indicates replay registration"
          }
        },
        "required": [
          "start_time",
          "email"
        ]
      },
      "RegistrationResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "registration_id": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Webinars"
    }
  ]
}
