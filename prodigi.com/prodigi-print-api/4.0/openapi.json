{
  "openapi": "3.0.3",
  "info": {
    "title": "Prodigi Print API",
    "version": "4.0",
    "description": "Prodigi print-on-demand API. Create and manage orders for printed products including photos, wall art, phone cases, apparel, and more. Products are produced and shipped globally.",
    "x-jentic-source-url": "https://www.prodigi.com/print-api/docs/reference/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.prodigi.com/v4.0",
      "description": "Production"
    },
    {
      "url": "https://api.sandbox.prodigi.com/v4.0",
      "description": "Sandbox"
    }
  ],
  "paths": {
    "/Orders": {
      "post": {
        "operationId": "createOrder",
        "summary": "Create order",
        "description": "Create a new print order with recipient, items, and assets",
        "tags": [
          "Orders"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderOutcome"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listOrders",
        "summary": "Get orders",
        "description": "List orders with optional filtering",
        "tags": [
          "Orders"
        ],
        "parameters": [
          {
            "name": "top",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            }
          },
          {
            "name": "skip",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "createdFrom",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "createdTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "draft",
                "awaitingPayment",
                "inProgress",
                "complete",
                "cancelled"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Orders list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrdersListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/Orders/{orderId}": {
      "get": {
        "operationId": "getOrder",
        "summary": "Get order by ID",
        "tags": [
          "Orders"
        ],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderOutcome"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get order by ID"
      }
    },
    "/Orders/{orderId}/actions/cancel": {
      "post": {
        "operationId": "cancelOrder",
        "summary": "Cancel an order",
        "tags": [
          "Order Actions"
        ],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cancelled order"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Cancel an order"
      }
    },
    "/Orders/{orderId}/actions/updateShipping": {
      "post": {
        "operationId": "updateOrderShipping",
        "summary": "Update order shipping method",
        "tags": [
          "Order Actions"
        ],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "shippingMethod": {
                    "type": "string",
                    "enum": [
                      "Budget",
                      "Standard",
                      "StandardPlus",
                      "Express",
                      "Overnight"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shipping updated"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Update order shipping method"
      }
    },
    "/Orders/{orderId}/actions/updateRecipient": {
      "post": {
        "operationId": "updateOrderRecipient",
        "summary": "Update order recipient",
        "tags": [
          "Order Actions"
        ],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Recipient"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recipient updated"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Update order recipient"
      }
    },
    "/Orders/{orderId}/actions/updateMetaData": {
      "post": {
        "operationId": "updateOrderMetadata",
        "summary": "Update order metadata",
        "tags": [
          "Order Actions"
        ],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "metadata": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Metadata updated"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Update order metadata"
      }
    },
    "/Quotes": {
      "post": {
        "operationId": "createQuote",
        "summary": "Get a price quote",
        "description": "Get pricing before placing an order",
        "tags": [
          "Quotes"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuoteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quote result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/Products": {
      "get": {
        "operationId": "listProducts",
        "summary": "List products",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "sku",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "top",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Products list"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List products"
      }
    },
    "/Products/{sku}": {
      "get": {
        "operationId": "getProduct",
        "summary": "Get product by SKU",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "sku",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product details"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get product by SKU"
      }
    },
    "/Shipping/info": {
      "post": {
        "operationId": "getShippingInfo",
        "summary": "Get shipping information",
        "tags": [
          "Shipping"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "destinationCountryCode": {
                    "type": "string"
                  },
                  "skus": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shipping options"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get shipping information"
      }
    }
  },
  "components": {
    "schemas": {
      "CreateOrderRequest": {
        "type": "object",
        "required": [
          "shippingMethod",
          "recipient",
          "items"
        ],
        "properties": {
          "merchantReference": {
            "type": "string"
          },
          "shippingMethod": {
            "type": "string",
            "enum": [
              "Budget",
              "Standard",
              "StandardPlus",
              "Express",
              "Overnight"
            ]
          },
          "callbackUrl": {
            "type": "string"
          },
          "idempotencyKey": {
            "type": "string"
          },
          "recipient": {
            "$ref": "#/components/schemas/Recipient"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          },
          "branding": {
            "$ref": "#/components/schemas/Branding"
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "Recipient": {
        "type": "object",
        "required": [
          "name",
          "address"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          }
        }
      },
      "Address": {
        "type": "object",
        "required": [
          "line1",
          "postalOrZipCode",
          "countryCode",
          "townOrCity"
        ],
        "properties": {
          "line1": {
            "type": "string"
          },
          "line2": {
            "type": "string"
          },
          "postalOrZipCode": {
            "type": "string"
          },
          "countryCode": {
            "type": "string"
          },
          "townOrCity": {
            "type": "string"
          },
          "stateOrCounty": {
            "type": "string"
          }
        }
      },
      "OrderItem": {
        "type": "object",
        "required": [
          "sku",
          "copies",
          "sizing",
          "assets"
        ],
        "properties": {
          "merchantReference": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "copies": {
            "type": "integer"
          },
          "sizing": {
            "type": "string",
            "enum": [
              "fillPrintArea",
              "fitPrintArea",
              "stretchToPrintArea"
            ]
          },
          "attributes": {
            "type": "object"
          },
          "recipientCost": {
            "$ref": "#/components/schemas/Cost"
          },
          "assets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemAsset"
            }
          }
        }
      },
      "ItemAsset": {
        "type": "object",
        "required": [
          "printArea",
          "url"
        ],
        "properties": {
          "printArea": {
            "type": "string",
            "default": "default"
          },
          "url": {
            "type": "string"
          },
          "md5Hash": {
            "type": "string"
          },
          "pageCount": {
            "type": "integer"
          }
        }
      },
      "Cost": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "Branding": {
        "type": "object",
        "properties": {
          "postcard": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              }
            }
          },
          "flyer": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              }
            }
          },
          "packing_slip_bw": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              }
            }
          },
          "packing_slip_color": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              }
            }
          }
        }
      },
      "OrderOutcome": {
        "type": "object",
        "properties": {
          "outcome": {
            "type": "string"
          },
          "order": {
            "$ref": "#/components/schemas/Order"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "lastUpdated": {
            "type": "string",
            "format": "date-time"
          },
          "merchantReference": {
            "type": "string"
          },
          "shippingMethod": {
            "type": "string"
          },
          "status": {
            "type": "object",
            "properties": {
              "stage": {
                "type": "string",
                "enum": [
                  "InProgress",
                  "Complete",
                  "Cancelled"
                ]
              },
              "issues": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "details": {
                "type": "object"
              }
            }
          },
          "charges": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "shipments": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "recipient": {
            "$ref": "#/components/schemas/Recipient"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          }
        }
      },
      "OrdersListResponse": {
        "type": "object",
        "properties": {
          "outcome": {
            "type": "string"
          },
          "orders": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Order"
            }
          },
          "hasMore": {
            "type": "boolean"
          },
          "nextUrl": {
            "type": "string"
          }
        }
      },
      "QuoteRequest": {
        "type": "object",
        "properties": {
          "shippingMethod": {
            "type": "string"
          },
          "destinationCountryCode": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "sku": {
                  "type": "string"
                },
                "copies": {
                  "type": "integer"
                },
                "assets": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "printArea": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "QuoteResponse": {
        "type": "object",
        "properties": {
          "outcome": {
            "type": "string"
          },
          "quotes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "shipmentMethod": {
                  "type": "string"
                },
                "costSummary": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Prodigi API key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Order Actions"
    },
    {
      "name": "Orders"
    },
    {
      "name": "Products"
    },
    {
      "name": "Quotes"
    },
    {
      "name": "Shipping"
    }
  ]
}
