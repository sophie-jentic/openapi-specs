  "info": {
    "title": "airSlate WorkFlow API",
    "version": "1.0.0",
    "description": "airSlate is a workflow automation platform. The API provides endpoints for managing organizations, flows (slate), templates, documents, and users. Authentication uses OAuth 2.0 Bearer tokens.",
