      "url": "https://api.airslate.com/v1",
      "description": "airSlate API v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "OAuth2 authentication"
    },
    {
      "name": "Organizations",
      "description": "Manage organizations"
    },
    {
      "name": "Flows",
      "description": "Manage workflow flows"
    },
    {
      "name": "Templates",
      "description": "Manage flow templates"
    },
    {
      "name": "Documents",
      "description": "Manage documents in flows"
