          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Total number of referrers to return",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "path",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "by_type",
            "in": "query",
            "required": false,
            "description": "Show breakdown by traffic source (1=yes)",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          },
          {
            "name": "jsonp",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Referrer data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReferrersResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/live/top_geo/v1/": {
      "get": {
        "operationId": "getTopGeo",
        "summary": "Get geographic data",
        "description": "Returns real-time geographic information by location segment including regions, countries, cities, and metro codes.",
        "tags": [
          "Real-Time"
        ],
        "parameters": [
          {
            "name": "host",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of segments to return",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "jsonp",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Geographic data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeoResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/live/quickstats/v4/": {
      "get": {
        "operationId": "getQuickstats",
        "summary": "Get quickstats",
