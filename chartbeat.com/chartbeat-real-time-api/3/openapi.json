  "components": {
    "schemas": {
      "TopPagesResponse": {
        "type": "object",
        "properties": {
          "pages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PageData"
            }
          }
        }
      },
      "PageData": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "host": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "stats": {
            "$ref": "#/components/schemas/PageStats"
          }
        }
      },
      "PageStats": {
        "type": "object",
        "properties": {
          "people": {
            "type": "integer",
            "description": "Concurrent visitors"
          },
          "read": {
            "type": "integer"
          },
          "visits": {
            "type": "integer"
          },
          "direct": {
            "type": "integer"
          },
          "links": {
            "type": "integer"
          },
          "search": {
            "type": "integer"
          },
          "internal": {
            "type": "integer"
          },
          "social": {
            "type": "integer"
          },
          "new": {
            "type": "integer"
          },
          "idle": {
            "type": "integer"
          },
          "write": {
            "type": "integer"
          },
          "article": {
            "type": "integer"
          },
          "recirc": {
            "type": "integer"
          }
        }
      },
      "SummaryResponse": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "additionalProperties": true
            },
            "type": {
              "type": "string"
            }
          }
        }
      },
      "ReferrersResponse": {
        "type": "object",
        "properties": {
          "referrers": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            }
          }
        }
      },
      "GeoResponse": {
        "type": "object",
        "properties": {
          "geo": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer"
              },
              "countries": {
                "type": "object",
                "additionalProperties": {
                  "type": "integer"
                }
              },
              "regions": {
                "type": "object",
                "additionalProperties": {
                  "type": "integer"
                }
              },
              "cities": {
                "type": "object",
                "additionalProperties": {
                  "type": "integer"
                }
              },
              "metro_codes": {
                "type": "object",
                "additionalProperties": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "QuickstatsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "stats": {
                "$ref": "#/components/schemas/PageStats"
              },
              "toppages": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "visitors": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "RecentVisitorsResponse": {
        "type": "object",
        "properties": {
          "visitors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "referrer": {
                  "type": "string"
                },
                "platform": {
                  "type": "string"
                },
                "city": {
                  "type": "string"
                },
                "country": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "HistoricalSeriesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
