{
  "openapi": "3.0.3",
  "info": {
    "title": "Chartbeat Real-Time API",
    "version": "3",
    "description": "Chartbeat provides real-time and historical analytics for editorial teams. This API provides real-time traffic data including top pages, summaries, referrers, geographic data, and quickstats.",
    "x-jentic-source-url": "https://docs.chartbeat.com/cbp/api/real-time-apis/traffic-data",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.chartbeat.com"
    }
  ],
  "tags": [
    {
      "name": "Real-Time",
      "description": "Real-time traffic data endpoints"
    },
    {
      "name": "Historical",
      "description": "Historical data endpoints"
    }
  ],
  "paths": {
    "/live/toppages/v3/": {
      "get": {
        "operationId": "getTopPages",
        "summary": "Get top pages",
        "description": "Returns a list of top pages on your site ordered by default based on the number of concurrents.",
        "tags": [
          "Real-Time"
        ],
        "parameters": [
          {
            "name": "host",
            "in": "query",
            "required": true,
            "description": "The site ID of the site you are querying",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of pages to return (default 10)",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "section",
            "in": "query",
            "required": false,
            "description": "Filter by section(s), comma-separated",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "author",
            "in": "query",
            "required": false,
            "description": "Filter by author(s), comma-separated",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "required": false,
            "description": "Sort parameter",
            "schema": {
              "type": "string",
              "enum": [
                "engaged_time",
                "new",
                "returning",
                "social",
                "links",
                "internal",
                "direct",
                "search"
              ]
            }
          },
          {
            "name": "exclude_people",
            "in": "query",
            "required": false,
            "description": "Min concurrents threshold",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "now_on",
            "in": "query",
            "required": false,
            "description": "Show recirculation list (1=yes)",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          },
          {
            "name": "all_platforms",
            "in": "query",
            "required": false,
            "description": "Show platform breakdown (1=yes)",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          },
          {
            "name": "loyalty",
            "in": "query",
            "required": false,
            "description": "Show loyalty breakdown (1=yes)",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          },
          {
            "name": "types",
            "in": "query",
            "required": false,
            "description": "Show page types (1=yes)",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          },
          {
            "name": "metrics",
            "in": "query",
            "required": false,
            "description": "Custom metrics set. Video customers: video_state",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "jsonp",
            "in": "query",
            "required": false,
            "description": "JSONP callback function name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Top pages data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TopPagesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/live/summary/v3/": {
      "get": {
        "operationId": "getSummary",
        "summary": "Get summary data",
        "description": "Returns numeric or categorical summaries of event fields for a host. Supports keys like pagetimer, time_spent, domain, title, new, path, referrer, read, write, idle.",
        "tags": [
          "Real-Time"
        ],
        "parameters": [
          {
            "name": "host",
            "in": "query",
            "required": true,
            "description": "The site ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keys",
            "in": "query",
            "required": true,
            "description": "Comma-separated data keys",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "path",
            "in": "query",
            "required": false,
            "description": "Filter by specific path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "jsonp",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Summary data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SummaryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/live/referrers/v3/": {
      "get": {
        "operationId": "getReferrers",
        "summary": "Get top referrers",
        "description": "Returns the list of top referrers for a specific domain.",
