          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Add priority fee"
      }
    },
    "/cities": {
      "get": {
        "operationId": "getCityInfo",
        "summary": "Get city info",
        "description": "Retrieve supported cities and vehicle types.",
        "tags": [
