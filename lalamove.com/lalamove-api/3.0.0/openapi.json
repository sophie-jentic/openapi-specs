  },
  "components": {
    "schemas": {
      "QuotationRequest": {
        "type": "object",
        "required": [
          "serviceType",
          "stops",
          "language"
        ],
        "properties": {
          "serviceType": {
            "type": "string"
          },
          "stops": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "coordinates": {
                  "type": "object",
                  "properties": {
                    "lat": {
                      "type": "string"
                    },
                    "lng": {
                      "type": "string"
                    }
                  }
                },
                "address": {
                  "type": "string"
                }
              }
            }
          },
          "language": {
            "type": "string"
          },
          "scheduleAt": {
            "type": "string",
            "format": "date-time"
          },
          "specialRequests": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isRouteOptimized": {
            "type": "boolean"
          }
        }
      },
      "QuotationResponse": {
        "type": "object",
        "properties": {
          "quotationId": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "priceBreakdown": {
            "type": "object"
          },
          "stops": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "distance": {
            "type": "object"
          }
        }
      },
      "OrderRequest": {
        "type": "object",
        "required": [
          "quotationId",
          "sender"
        ],
        "properties": {
          "quotationId": {
            "type": "string"
          },
          "sender": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "phone": {
                "type": "string"
              }
            }
          },
          "recipients": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "isPODEnabled": {
            "type": "boolean"
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string"
          },
          "quotationId": {
            "type": "string"
          },
          "priceBreakdown": {
            "type": "object"
          },
          "driverId": {
            "type": "string"
          },
          "shareLink": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "stops": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "DriverResponse": {
        "type": "object",
        "properties": {
          "driverId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "plateNumber": {
            "type": "string"
          },
          "coordinates": {
            "type": "object",
            "properties": {
              "lat": {
                "type": "string"
              },
              "lng": {
                "type": "string"
              }
            }
          }
        }
      },
      "CityListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "WebhookResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "hmacAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "HMAC SHA256 signature: hmac KEY:TIMESTAMP:SIGNATURE"
      }
    }
  },
  "security": [
    {
      "hmacAuth": []
    }
  ],
  "tags": [
    {
      "name": "Cities"
    },
    {
      "name": "Drivers"
    },
    {
      "name": "Orders"
    },
    {
      "name": "Quotations"
    },
    {
      "name": "Webhooks"
    }
  ]
}
