{
  "openapi": "3.0.3",
  "info": {
    "title": "Lalamove API",
    "version": "3.0.0",
    "description": "Lalamove delivery API for creating quotations, placing orders, tracking deliveries, managing drivers, and configuring webhooks.",
    "x-jentic-source-url": "https://developers.lalamove.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://rest.lalamove.com/v3"
    }
  ],
  "paths": {
    "/quotations": {
      "post": {
        "operationId": "createQuotation",
        "summary": "Get quotation",
        "description": "Request a delivery quotation with pricing.",
        "tags": [
          "Quotations"
        ],
        "parameters": [
          {
            "name": "Market",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "UN/LOCODE market code"
          },
          {
            "name": "Request-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuotationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuotationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/quotations/{quotationId}": {
      "get": {
        "operationId": "getQuotation",
        "summary": "Get quotation details",
        "tags": [
          "Quotations"
        ],
        "parameters": [
          {
            "name": "quotationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Market",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuotationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get quotation details"
      }
    },
    "/orders": {
