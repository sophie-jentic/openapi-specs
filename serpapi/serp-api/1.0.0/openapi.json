{
  "openapi": "3.0.3",
  "info": {
    "title": "SerpApi - Search Engine Results Page API",
    "description": "SerpApi provides a real-time API to access search engine results. It parses Google (and other engine) results and returns structured JSON data including organic results, knowledge graphs, local packs, ads, and more. Commonly used for SEO research, SERP tracking, and competitive analysis.",
    "version": "1.0.0",
    "contact": {
      "name": "SerpApi",
      "url": "https://serpapi.com"
    },
    "termsOfService": "https://serpapi.com/terms-of-service"
  },
  "servers": [
    {
      "url": "https://serpapi.com",
      "description": "SerpApi Production Server"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "search",
        "summary": "Perform a search engine query",
        "description": "Execute a search query against the specified engine (default: Google) and return structured results including organic listings, knowledge graph, local results, ads, and more.",
        "parameters": [
          {
            "name": "engine",
            "in": "query",
            "description": "The search engine to use. Defaults to 'google'.",
            "schema": {
              "type": "string",
              "default": "google",
              "enum": [
                "google",
                "google_images",
                "google_videos",
                "google_news",
                "google_shopping",
                "google_patents",
                "google_local",
                "google_maps",
                "google_about_this_result",
                "bing",
                "yahoo",
                "youtube",
                "baidu",
                "yandex",
                "duckduckgo"
              ]
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "The search query. Supports advanced operators such as site:, inurl:, intitle:.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Geographic location for the search. Use the Locations API to find valid values.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uule",
            "in": "query",
            "description": "Google-encoded location string. Alternative to the location parameter.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "google_domain",
            "in": "query",
            "description": "Google domain to use (e.g., google.com, google.co.uk). Defaults to google.com.",
            "schema": {
              "type": "string",
              "default": "google.com"
            }
          },
          {
            "name": "gl",
            "in": "query",
            "description": "Country code for the search (2-letter ISO 3166-1 code, e.g., 'us', 'uk').",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hl",
            "in": "query",
            "description": "Language code for the search (2-letter code, e.g., 'en', 'fr').",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cr",
            "in": "query",
            "description": "Restrict results to documents originating in a particular country.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lr",
            "in": "query",
            "description": "Restrict results to documents written in a particular language.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "num",
            "in": "query",
            "description": "Number of results to return per page.",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Result offset for pagination (e.g., 10 for page 2 with num=10).",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "safe",
            "in": "query",
            "description": "Safe search filtering level.",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "off"
              ]
            }
          },
          {
            "name": "nfpr",
            "in": "query",
            "description": "Exclude auto-corrected results. Set to 1 to disable auto-correction.",
            "schema": {
              "type": "string",
              "enum": [
                "0",
                "1"
              ]
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Control omitted results filtering. Set to 0 to include omitted results.",
            "schema": {
              "type": "string",
              "enum": [
                "0",
                "1"
              ]
            }
          },
          {
            "name": "tbm",
            "in": "query",
            "description": "Search type. Controls which type of results to return.",
            "schema": {
              "type": "string",
              "enum": [
                "isch",
                "lcl",
                "vid",
                "nws",
                "shop",
                "pts"
              ]
            }
          },
          {
            "name": "tbs",
            "in": "query",
            "description": "Advanced search parameters (e.g., time-based filters like qdr:d for past day).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "device",
            "in": "query",
            "description": "Device type to emulate for the search.",
            "schema": {
              "type": "string",
              "enum": [
                "desktop",
                "tablet",
                "mobile"
              ],
              "default": "desktop"
            }
          },
          {
            "name": "no_cache",
            "in": "query",
            "description": "Force fresh results by bypassing the SerpApi cache.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "async",
            "in": "query",
            "description": "Submit search asynchronously. Retrieve results later via the Searches Archive API.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "output",
            "in": "query",
            "description": "Output format for the response.",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "html"
              ],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "tags": [
          "search"
        ]
      }
    },
    "/account.json": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get account information",
        "description": "Retrieve account details including plan information, usage statistics, and rate limits. This endpoint is free of charge and does not count toward the monthly quota.",
        "responses": {
          "200": {
            "description": "Account information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        },
        "tags": [
          "account.json"
        ]
      }
    },
    "/locations.json": {
      "get": {
        "operationId": "getLocations",
        "summary": "Search for supported locations",
        "description": "Find supported geographic locations that can be used with the search API's location parameter. Results are ordered by reach (population) from highest to lowest.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Location search query string (e.g., 'Austin', 'London').",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of locations to return.",
            "schema": {
              "type": "integer",
              "maximum": 10
            }
          }
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Array of matching locations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Location"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "locations.json"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "SerpApi private API key, available from your account dashboard."
      }
    },
    "schemas": {
      "SearchResponse": {
        "type": "object",
        "properties": {
          "search_metadata": {
            "type": "object",
            "description": "Metadata about the search request.",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique search identifier."
              },
              "status": {
                "type": "string",
                "description": "Search status (e.g., 'Success')."
              },
              "json_endpoint": {
                "type": "string",
                "description": "URL to retrieve cached JSON results."
              },
              "created_at": {
                "type": "string",
                "description": "Timestamp when the search was created."
              },
              "processed_at": {
                "type": "string",
                "description": "Timestamp when the search was processed."
              },
              "total_time_taken": {
                "type": "number",
                "description": "Total processing time in seconds."
              }
            }
          },
          "search_parameters": {
            "type": "object",
            "description": "Normalized search parameters used for the request.",
            "properties": {
              "engine": {
                "type": "string"
              },
              "q": {
                "type": "string"
              },
              "google_domain": {
                "type": "string"
              },
              "hl": {
                "type": "string"
              },
              "gl": {
                "type": "string"
              },
              "device": {
                "type": "string"
              }
            }
          },
          "search_information": {
            "type": "object",
            "description": "Information about the search results.",
            "properties": {
              "total_results": {
                "type": "integer",
                "description": "Total number of results found."
              },
              "time_taken_displayed": {
                "type": "number",
                "description": "Time taken as displayed by the search engine."
              },
              "query_displayed": {
                "type": "string",
                "description": "The query as displayed in search results."
              }
            }
          },
          "organic_results": {
            "type": "array",
            "description": "Main organic search results.",
            "items": {
              "$ref": "#/components/schemas/OrganicResult"
            }
          },
          "knowledge_graph": {
            "type": "object",
            "description": "Knowledge graph panel data, if present.",
            "properties": {
              "title": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "source": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "link": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "local_results": {
            "type": "object",
            "description": "Local pack results, if present.",
            "properties": {
              "places": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "position": {
                      "type": "integer"
                    },
                    "title": {
                      "type": "string"
                    },
                    "rating": {
                      "type": "number"
                    },
                    "reviews": {
                      "type": "integer"
                    },
                    "address": {
                      "type": "string"
                    },
                    "phone": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "pagination": {
            "type": "object",
            "description": "Pagination information.",
            "properties": {
              "current": {
                "type": "integer"
              },
              "next": {
                "type": "string"
              },
              "other_pages": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "OrganicResult": {
        "type": "object",
        "properties": {
          "position": {
            "type": "integer",
            "description": "Position in the results list."
          },
          "title": {
            "type": "string",
            "description": "Title of the result."
          },
          "link": {
            "type": "string",
            "description": "URL of the result."
          },
          "displayed_link": {
            "type": "string",
            "description": "Display URL shown in results."
          },
          "snippet": {
            "type": "string",
            "description": "Text snippet from the result."
          },
          "snippet_highlighted_words": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Words highlighted in the snippet."
          },
          "cached_page_link": {
            "type": "string",
            "description": "Link to Google's cached version."
          },
          "source": {
            "type": "string",
            "description": "Source of the result."
          },
          "date": {
            "type": "string",
            "description": "Date associated with the result, if any."
          },
          "rich_snippet": {
            "type": "object",
            "description": "Rich snippet data (ratings, reviews, etc.).",
            "properties": {
              "top": {
                "type": "object",
                "properties": {
                  "detected_extensions": {
                    "type": "object"
                  },
                  "extensions": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "sitelinks": {
            "type": "object",
            "description": "Sitelinks associated with this result.",
            "properties": {
              "inline": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "title": {
                      "type": "string"
                    },
                    "link": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "AccountResponse": {
        "type": "object",
        "properties": {
          "account_id": {
            "type": "string",
            "description": "Unique account identifier."
          },
          "api_key": {
            "type": "string",
            "description": "The API key associated with the account."
          },
          "account_email": {
            "type": "string",
            "description": "Email address on the account."
          },
          "plan_id": {
            "type": "string",
            "description": "Current plan identifier."
          },
          "plan_name": {
            "type": "string",
            "description": "Name of the current plan."
          },
          "plan_monthly_price": {
            "type": "number",
            "description": "Monthly price of the plan."
          },
          "searches_per_month": {
            "type": "integer",
            "description": "Total searches allowed per month."
          },
          "plan_searches_left": {
            "type": "integer",
            "description": "Remaining searches for the current month."
          },
          "this_month_usage": {
            "type": "integer",
            "description": "Number of searches used this month."
          },
          "last_hour_searches": {
            "type": "integer",
            "description": "Number of searches in the last hour."
          },
          "account_rate_limit_per_hour": {
            "type": "integer",
            "description": "Maximum searches allowed per hour."
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique location identifier."
          },
          "google_id": {
            "type": "integer",
            "description": "Google's location ID."
          },
          "google_parent_id": {
            "type": "integer",
            "description": "Parent location's Google ID."
          },
          "name": {
            "type": "string",
            "description": "Location display name."
          },
          "canonical_name": {
            "type": "string",
            "description": "Full hierarchical location name."
          },
          "country_code": {
            "type": "string",
            "description": "ISO country code."
          },
          "target_type": {
            "type": "string",
            "description": "Location category (e.g., 'City', 'DMA Region', 'County')."
          },
          "reach": {
            "type": "integer",
            "description": "Population/reach estimate."
          },
          "gps": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 2,
            "maxItems": 2,
            "description": "GPS coordinates as [longitude, latitude]."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "account.json"
    },
    {
      "name": "locations.json"
    },
    {
      "name": "search"
    }
  ]
}
