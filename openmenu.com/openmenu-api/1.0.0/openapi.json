{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenMenu API",
    "version": "1.0.0",
    "description": "OpenMenu API provides access to restaurant menus, menu items, nutrition data, search, deals, and analytics powered by DishDNA machine learning technology.",
    "x-jentic-source-url": "https://openmenu.com/api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.openmenu.com/api"
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "searchRestaurants",
        "summary": "Search restaurants, menus and menu items",
        "description": "Provides results for locating restaurants, menus and menu items using proprietary algorithms.",
        "tags": [
          "Standard"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "latitude",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Latitude for location-based search"
          },
          {
            "name": "longitude",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Longitude for location-based search"
          },
          {
            "name": "radius",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Search radius"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
