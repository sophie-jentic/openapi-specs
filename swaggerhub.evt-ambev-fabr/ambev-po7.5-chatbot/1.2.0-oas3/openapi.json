{
  "openapi": "3.0.0",
  "info": {
    "description": "Chatbot app calls SAP PO 7.5 Integration\nMethods:\n  <br>\u00bb Data Forn Ext\n  <br>\u00bb Data Forn Int\n\n  1.2.0-oas3 (07/10/2019):\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;\u2022 Added Production URL Server\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;\u2022 Structure T_NF\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; added AUGDT\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; added NF\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;\u2022 Structure T_PEDIDO\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; added XBLNR_NF\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; added EINDT_NF\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; added XBLNR_MIGO\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;\u2022 Structure T_REQUISICAO\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; added FRGKZ\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; added FRGDT      \n  \n  1.1.0-oas3 (19/09/2019):\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;\u2022 Structure T_FORNECEDOR\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; added NAME1\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; added BANKL\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;\u2022 Structure T_PEDIDO\n  <br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; added FRGKE\n  \n  1.0.0-oas3 (04/09/2019): Creation\n",
    "version": "1.2.0-oas3",
