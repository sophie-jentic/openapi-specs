        "type": "apiKey",
        "name": "api_key",
        "in": "header"
      }
    },
    "schemas": {
      "postDataFornExt_req": {
        "type": "object",
        "properties": {
          "I_CNPJ": {
            "type": "string",
            "description": "N\u00ba ID fiscal 1",
            "maxLength": 16
          },
          "I_CPF": {
            "type": "string",
            "description": "N\u00ba ID fiscal 2",
            "maxLength": 11
          },
          "I_NF": {
            "type": "string",
            "description": "N\u00ba da NF-e de nove posi\u00e7\u00f5es",
            "maxLength": 9
          }
        },
        "title": "postDataFornExt_req",
        "xml": {
          "name": "postDataFornExt_req"
        },
        "description": ""
      },
      "postDataFornExt_res": {
        "type": "object",
        "properties": {
          "T_FORNECEDOR": {
            "$ref": "#/components/schemas/T_FORNECEDOR"
          },
          "T_NF": {
            "$ref": "#/components/schemas/T_NF"
          },
          "T_PEDIDO": {
            "$ref": "#/components/schemas/T_PEDIDO"
          },
          "T_RETURN": {
            "$ref": "#/components/schemas/T_RETURN"
          }
        },
        "title": "postDataFornExt_res",
        "xml": {
          "name": "postDataFornExt_res"
        },
        "description": ""
      },
      "postDataFornExt_exc": {
        "type": "object",
        "properties": {
          "standard": {
            "$ref": "#/components/schemas/exc_standard"
          }
        },
        "xml": {
          "name": "postApontamentoMip_exc"
        }
      },
      "postDataFornInt_req": {
        "type": "object",
        "properties": {
          "I_BANFN": {
            "type": "string",
            "description": "N\u00ba requisi\u00e7\u00e3o de compra",
            "maxLength": 10
          },
          "I_BNFPO": {
            "type": "string",
            "description": "N\u00ba do item da requisi\u00e7\u00e3o de compra",
            "maxLength": 5,
            "pattern": "\\\\d+"
          },
          "I_EBELN": {
            "type": "string",
            "description": "N\u00ba do documento de compras",
            "maxLength": 10
          },
          "I_EBELP": {
            "type": "string",
            "description": "N\u00ba item do documento de compra",
            "maxLength": 5,
            "pattern": "\\\\d+"
          },
          "I_NFENUM": {
            "type": "string",
            "description": "N\u00ba da NF-e de nove posi\u00e7\u00f5es",
            "maxLength": 9
          }
        },
        "title": "postDataFornInt_req",
        "xml": {
          "name": "postDataFornInt_req"
        },
        "description": ""
      },
      "postDataFornInt_res": {
        "type": "object",
        "properties": {
          "T_FORNECEDOR": {
            "$ref": "#/components/schemas/T_FORNECEDOR"
          },
          "T_NF": {
            "$ref": "#/components/schemas/T_NF"
          },
          "T_PEDIDO": {
            "$ref": "#/components/schemas/T_PEDIDO"
          },
          "T_REQUISICAO": {
            "$ref": "#/components/schemas/T_REQUISICAO"
          },
          "T_RETURN": {
            "$ref": "#/components/schemas/T_RETURN"
          }
        },
        "title": "postDataFornInt_res",
        "xml": {
          "name": "postDataFornInt_res"
        },
        "description": ""
      },
      "postDataFornInt_exc": {
        "type": "object",
        "properties": {
          "standard": {
            "$ref": "#/components/schemas/exc_standard"
          }
        },
        "xml": {
          "name": "postDataFornInt_exc"
        }
      },
      "exc_standard": {
        "properties": {
          "faultText": {
            "type": "string"
          },
          "faultUrl": {
            "type": "string"
          },
          "faultDetail": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/faultDetail_list"
            }
          }
        }
      },
      "faultDetail_list": {
        "type": "object",
        "properties": {
          "severity": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        },
        "xml": {
          "name": "faultDetail_list"
        }
      },
      "T_FORNECEDOR": {
        "type": "object",
        "properties": {
          "item": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ZCHATBOT_FORNECEDOR"
            }
          }
        }
      },
      "T_NF": {
        "type": "object",
        "properties": {
          "item": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ZCHATBOT_NF"
            }
          }
        }
      },
      "T_PEDIDO": {
        "type": "object",
        "properties": {
          "item": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ZCHATBOT_PEDIDO"
            }
          }
        }
      },
      "T_REQUISICAO": {
        "type": "object",
        "properties": {
          "item": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ZCHATBOT_REQUISICAO"
            }
          }
        }
      },
      "T_RETURN": {
        "type": "object",
        "properties": {
          "item": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ZCHATBOT_RETORNO"
            }
          }
        }
      },
      "ZCHATBOT_FORNECEDOR": {
        "type": "object",
        "properties": {
          "LIFNR": {
            "type": "string",
            "description": "N\u00ba conta do fornecedor",
            "maxLength": 10
          },
          "STCD1": {
            "type": "string",
            "description": "N\u00ba ID fiscal 1",
            "maxLength": 16
          },
          "SMTP_ADDR": {
            "type": "string",
            "description": "Endere\u00e7o de e-mail",
            "maxLength": 241
          },
          "STRAS": {
            "type": "string",
            "description": "Rua e n\u00ba",
            "maxLength": 30
          },
          "ERDAT": {
            "type": "string",
            "format": "date",
            "description": "Data de cria\u00e7\u00e3o do registro"
          },
          "BANKN": {
            "type": "string",
            "description": "N\u00ba conta banc\u00e1ria",
            "maxLength": 18
          },
          "LOEVM": {
            "type": "string",
            "description": "C\u00f3digo de elimina\u00e7\u00e3o",
            "maxLength": 1
          },
          "NAME1": {
            "type": "string",
            "description": "Name 1"
          },
          "BANKL": {
            "type": "string",
            "description": "Bank Number"
          }
        }
      },
      "ZCHATBOT_NF": {
        "type": "object",
        "properties": {
          "DOCNUM": {
            "type": "string",
            "description": "N\u00ba documento",
            "maxLength": 10,
            "pattern": "\\\\d+"
          },
          "STATU": {
            "type": "string",
            "description": "Status",
            "maxLength": 1
          },
          "AUGCP": {
            "type": "string",
            "format": "date",
            "description": "Data de entrada da compensa\u00e7\u00e3o"
          },
          "ZLSPR": {
            "type": "string",
            "description": "Chave para o bloqueio de pagamento",
            "maxLength": 1
          },
          "DOCDAT": {
            "type": "string",
            "format": "date",
            "description": "Data do documento"
          },
          "AUGDT": {
            "type": "string",
            "format": "date",
            "description": "Clearing Date"
          },
          "NF": {
            "type": "string",
            "description": "Reference Document Number"
          }
        }
      },
      "ZCHATBOT_PEDIDO": {
        "type": "object",
        "properties": {
          "EBELN": {
            "type": "string",
            "description": "N\u00ba do documento de compras",
            "maxLength": 10
          },
          "EBELP": {
            "type": "string",
            "description": "N\u00ba item do documento de compra",
            "maxLength": 5,
            "pattern": "\\\\d+"
          },
          "LOEKZ": {
            "type": "string",
            "description": "Marca\u00e7\u00e3o de elimina\u00e7\u00e3o",
            "maxLength": 1
          },
          "STATU": {
            "type": "string",
            "description": "Status da solicita\u00e7\u00e3o de cota\u00e7\u00e3o",
            "maxLength": 1
          },
          "BEDAT": {
            "type": "string",
            "format": "date",
            "description": "Data do pedido"
          },
          "EINDT": {
            "type": "string",
            "format": "date",
            "description": "Data de remessa do item"
          },
          "XBLNR": {
            "type": "string",
            "description": "N\u00ba documento de refer\u00eancia",
            "maxLength": 16
          },
          "BLDAT": {
            "type": "string",
            "format": "date",
            "description": "Data no documento"
          },
          "WADAT_IST": {
            "type": "string",
            "format": "date",
            "description": "Data real do movimento de mercadorias"
          },
          "NETDT": {
            "type": "string",
            "format": "date",
            "description": "Vencimento l\u00edquido"
          },
          "FRGKE": {
            "type": "string",
            "description": "Release Indicator. Purchasing Document"
          },
          "XBLNR_NF": {
            "type": "string",
            "description": "Reference Document Number"
          },
          "EINDT_NF": {
            "type": "string",
            "format": "date",
            "description": "item Delivery Date"
          },
          "XBLNR_MIGO": {
            "type": "string",
            "description": "Reference Document Number"
          }
        }
      },
      "ZCHATBOT_REQUISICAO": {
        "type": "object",
        "properties": {
          "BANFN": {
            "type": "string",
            "description": "N\u00ba requisi\u00e7\u00e3o de compra",
            "maxLength": 10
          },
          "BNFPO": {
            "type": "string",
            "description": "N\u00ba do item da requisi\u00e7\u00e3o de compra",
            "maxLength": 5,
            "pattern": "\\\\d+"
          },
          "STATU": {
            "type": "string",
            "description": "Status de processamento da requisi\u00e7\u00e3o de compra",
            "maxLength": 1
          },
          "BANPR": {
            "type": "string",
            "description": "Estado do processamento da requisi\u00e7\u00e3o de compra",
            "maxLength": 2
          },
          "BLCKD": {
            "type": "string",
            "description": "Requisi\u00e7\u00e3o de compra bloqueada",
            "maxLength": 1
          },
          "EBAKZ": {
            "type": "string",
            "description": "Requisi\u00e7\u00e3o de compra conclu\u00edda",
            "maxLength": 1
          },
          "LOEKZ": {
            "type": "string",
            "description": "Marca\u00e7\u00e3o de elimina\u00e7\u00e3o",
            "maxLength": 1
          },
          "BADAT": {
            "type": "string",
            "format": "date",
            "description": "Data da solicita\u00e7\u00e3o"
          },
          "FRGKZ": {
            "type": "string",
            "description": "Release Indicator"
          },
          "FRGDT": {
            "type": "string",
            "format": "date",
            "description": "Purchase Requisition Release Date"
          }
        }
      },
      "ZCHATBOT_RETORNO": {
        "type": "object",
        "properties": {
          "MESSAGE": {
            "type": "string",
            "description": "Message Text",
            "maxLength": 220
          }
        }
      }
    }
  }
}
