{
  "openapi": "3.0.0",
  "servers": [
    {
      "url": "https://{customerId}.api.vonixcc.com.br/billing",
      "variables": {
        "customerId": {
          "description": "api-billing-calls",
          "default": "blackbox"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "info": {
    "title": "Api de calculo de tarifas",
    "description": "Esta \u00e9 a API que calcula a tarifa\u00e7\u00e3o das chamadas ativas dos clientes",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/vonix-tecnologia/api-billing-calls/1.0.0/swagger.json",
    "contact": {}
  },
  "paths": {
    "/plans": {
      "get": {
        "summary": "Lista todos os planos",
        "description": "Traz a lista de todos os planos e suas respectivas tarifas cadastradas.",
        "parameters": [
          {
            "in": "query",
            "name": "description",
            "description": "passa uma string opcional para a busca dos planos pela descri\u00e7\u00e3o",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "name",
            "description": "busca os planos pelo nome",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "id",
            "description": "busca um plano na lista pelo id",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "retorna a lista de planos que correspondem \u00e0 busca",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Plans"
                }
              }
            }
          },
          "500": {
            "description": "internal error"
          }
        },
        "tags": [
          "plans"
        ],
        "operationId": "get-plans"
      },
      "post": {
        "summary": "adiciona um plano",
        "responses": {
          "201": {
            "description": "plano criado"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "$errors": {
                      "type": "string",
                      "example": "missing request params"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "name",
                  "description"
                ],
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "plans"
        ],
        "description": "adiciona um plano",
        "operationId": "post-plans"
      }
    },
    "/plans/{id}": {
      "put": {
        "summary": "Atualiza um plano",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "id do plano a ser atualizado",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "atualiza\u00e7\u00e3o realizada com sucesso"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "plans"
        ],
        "description": "Atualiza um plano",
        "operationId": "put-plans-by-id"
      }
    },
    "/tariffs": {
      "post": {
        "summary": "adiciona uma nova tarifa em um plano existente",
        "responses": {
          "201": {
            "description": "tarifa criada"
          },
          "500": {
            "description": "internal error"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "$errors": {
                      "type": "string",
                      "example": "missing request params"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Tariffs"
              }
            }
          }
        },
        "tags": [
          "tariffs"
        ],
        "description": "adiciona uma nova tarifa em um plano existente",
        "operationId": "post-tariffs"
      }
    },
    "/tariffs/{id}": {
      "put": {
        "summary": "Atualiza uma Tarifa",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "id da Tarifa a ser atualizada",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "atualiza\u00e7\u00e3o realizada com sucesso"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Tariffs"
              }
            }
          }
        },
        "tags": [
          "tariffs"
        ],
        "description": "Atualiza uma Tarifa",
        "operationId": "put-tariffs-by-id"
      }
    },
    "/trunkings": {
      "get": {
        "summary": "Lista todos os troncos cadastrados",
        "description": "Traz a lista de todos os troncos previamente cadastrados. Eles devem existir na tabela trunkings",
        "parameters": [
          {
            "in": "query",
            "name": "name",
            "description": "busca o tronco pelo nome",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "id",
            "description": "busca o tronco pelo id",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "retorna a lista de troncos que correspondem \u00e0 busca",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "description": "Cont\u00e9m a lista dos troncos",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "Id do Tronco"
                          },
                          "name": {
                            "type": "string",
                            "description": "Nome do Tronco"
                          },
                          "trunkingId": {
                            "type": "integer",
                            "description": "Id do tronco na tabela trunkings do cliente."
                          },
                          "planId": {
                            "type": "integer",
                            "description": "Id do plano ao qual esse tronco est\u00e1 vinculado."
                          }
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "internal error"
          }
        },
        "tags": [
          "trunkings"
        ],
        "operationId": "get-trunkings"
      },
      "post": {
        "summary": "vincunla um tronco da tabela trunkings a um plano cadastrado",
        "responses": {
          "201": {
            "description": "tronco criado"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "$errors": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "planId",
                  "trunkingId"
                ],
                "type": "object",
                "properties": {
                  "planId": {
                    "type": "integer"
                  },
                  "trunkingId": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "trunkings"
        ],
        "description": "vincunla um tronco da tabela trunkings a um plano cadastrado",
        "operationId": "post-trunkings"
      }
    },
    "/trunkings/{id}": {
      "put": {
        "summary": "Atualiza um tronco",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "id do tronco a ser atualizado",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "atualiza\u00e7\u00e3o realizada com sucesso"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "planId": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "trunkings"
        ],
        "description": "Atualiza um tronco",
        "operationId": "put-trunkings-by-id"
      }
    },
    "/calls": {
      "get": {
        "summary": "Lista as chamadas tarifadas",
        "description": "Retorna os primeiros 50 registros das chamadas tarifadas.",
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "description": "especifica o numero da pagina das chamadas a serem retornadas",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "callId",
            "description": "busca uma chamada pelo id",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "retorna a lista de chamadas tarifadas",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Calls"
                }
              }
            }
          },
          "500": {
            "description": "internal error"
          }
        },
        "tags": [
          "calls"
        ],
        "operationId": "get-calls"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Plans": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "description": "Cont\u00e9m a lista dos planos",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "description": "Id do Plano"
                },
                "name": {
                  "type": "string",
                  "description": "Nome do Plano"
                },
                "description": {
                  "type": "string",
                  "description": "Descri\u00e7\u00e3o do Plano"
                },
                "tariffs": {
                  "type": "array",
                  "description": "Cont\u00e9m a lista de tarifas desse plano",
                  "items": {
                    "type": "object",
                    "properties": {
                      "callTypeId": {
                        "type": "integer"
                      },
                      "valueByMin": {
                        "type": "number",
                        "description": "valor a ser cobrado por minuto"
                      },
                      "initialTime": {
                        "type": "integer",
                        "description": "tempo inicial a ser cobrado"
                      },
                      "incrementSecs": {
                        "type": "integer",
                        "description": "o calculo proporcional deve ser feito a cada quantos segundos"
                      },
                      "minToTax": {
                        "type": "number",
                        "description": "minimo de segundos atingidos para que seja feita a cobran\u00e7a"
                      },
                      "completeTax": {
                        "type": "number",
                        "description": "taxa de completamento"
                      },
                      "createdAt": {
                        "type": "number",
                        "format": "timestamp",
                        "description": "data de cria\u00e7\u00e3o da tarifa"
                      }
                    }
                  }
                }
              }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer"
              }
            }
          }
        }
      },
      "Tariffs": {
        "required": [
          "planId",
          "callTypeId"
        ],
        "type": "object",
        "properties": {
          "planId": {
            "type": "integer"
          },
          "callTypeId": {
            "type": "integer"
          },
          "valueByMin": {
            "type": "number",
            "example": 2.0,
            "default": 0
          },
          "initialTime": {
            "type": "integer",
            "default": 30
          },
          "incrementSecs": {
            "type": "integer",
            "default": 6
          },
          "completeTax": {
            "type": "integer",
            "default": 0
          },
          "minToTax": {
            "type": "integer",
            "default": 3
          }
        }
      },
      "Calls": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "description": "Cont\u00e9m a lista dos planos",
            "items": {
              "type": "object",
              "properties": {
                "callId": {
                  "type": "integer",
                  "description": "Id da chamada"
                },
                "billingValue": {
                  "type": "number",
                  "description": "Valor tarifado da chamada"
                },
                "billingTime": {
                  "type": "integer",
                  "format": "seconds",
                  "description": "quantos segundos foram tarifados"
                }
              }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "calls"
    },
    {
      "name": "plans"
    },
    {
      "name": "tariffs"
    },
    {
      "name": "trunkings"
    }
  ]
}
