{
  "openapi": "3.0.3",
  "info": {
    "title": "OCR.space API",
    "description": "OCR.space is a free OCR (Optical Character Recognition) API that converts images and PDFs to text. It supports 30+ languages, multiple OCR engines, and can return word-level coordinates. Input can be provided as a file upload, a URL, or a base64-encoded image.",
    "version": "1.0.0",
    "contact": {
      "name": "OCR.space",
      "url": "https://ocr.space"
    },
    "termsOfService": "https://ocr.space/terms"
  },
  "servers": [
    {
      "url": "https://api.ocr.space",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "paths": {
    "/parse/image": {
      "post": {
        "operationId": "parseImage",
        "summary": "Parse image or PDF to extract text via OCR",
        "description": "Full-featured OCR endpoint that accepts image or PDF input via file upload, URL, or base64 encoding. Returns extracted text and optional word coordinates.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image or PDF file to process. One of file, url, or base64Image is required."
                  },
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of the image or PDF to process. One of file, url, or base64Image is required."
                  },
                  "base64Image": {
                    "type": "string",
                    "description": "Base64-encoded image or PDF. Must include the data URI prefix, e.g. 'data:image/png;base64,...'. One of file, url, or base64Image is required."
                  },
                  "language": {
                    "type": "string",
                    "default": "eng",
                    "description": "Language for OCR recognition. Use 3-letter language code.",
                    "enum": [
                      "ara",
                      "bul",
                      "chs",
                      "cht",
                      "hrv",
                      "cze",
                      "dan",
                      "dut",
                      "eng",
                      "fin",
                      "fre",
                      "ger",
                      "gre",
                      "hun",
                      "kor",
                      "ita",
                      "jpn",
                      "pol",
                      "por",
                      "rus",
                      "slv",
                      "spa",
                      "swe",
                      "tur"
                    ]
                  },
                  "isOverlayRequired": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, returns word-level coordinates (bounding boxes) in the response."
                  },
                  "filetype": {
                    "type": "string",
                    "description": "Override automatic file type detection.",
                    "enum": [
                      "PDF",
                      "GIF",
                      "PNG",
                      "JPG",
                      "TIF",
                      "BMP"
                    ]
                  },
                  "detectOrientation": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, auto-rotates the image and detects text orientation."
                  },
                  "isCreateSearchablePdf": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, generates a searchable PDF and returns a download URL."
                  },
                  "isSearchablePdfHideTextLayer": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, hides the text layer in the generated searchable PDF."
                  },
                  "scale": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, enables internal upscaling for low-resolution images/documents."
                  },
                  "isTable": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, enables line-by-line parsing optimized for tables and structured data."
                  },
                  "OCREngine": {
                    "type": "integer",
                    "default": 1,
                    "description": "OCR engine to use. Engine 1: fast, general purpose. Engine 2: more accurate, slower. Engine 3: advanced features.",
                    "enum": [
                      1,
                      2,
                      3
                    ]
                  }
                }
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of the image or PDF to process."
                  },
                  "base64Image": {
                    "type": "string",
                    "description": "Base64-encoded image or PDF with data URI prefix."
                  },
                  "language": {
                    "type": "string",
                    "default": "eng",
                    "description": "Language for OCR recognition (3-letter code)."
                  },
                  "isOverlayRequired": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, returns word-level coordinates."
                  },
                  "filetype": {
                    "type": "string",
                    "description": "Override automatic file type detection.",
                    "enum": [
                      "PDF",
                      "GIF",
                      "PNG",
                      "JPG",
                      "TIF",
                      "BMP"
                    ]
                  },
                  "detectOrientation": {
                    "type": "boolean",
                    "default": false
                  },
                  "isCreateSearchablePdf": {
                    "type": "boolean",
                    "default": false
                  },
                  "isSearchablePdfHideTextLayer": {
                    "type": "boolean",
                    "default": false
                  },
                  "scale": {
                    "type": "boolean",
                    "default": false
                  },
                  "isTable": {
                    "type": "boolean",
                    "default": false
                  },
                  "OCREngine": {
                    "type": "integer",
                    "default": 1,
                    "enum": [
                      1,
                      2,
                      3
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OCR processing result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OCRResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "403": {
            "description": "Forbidden - API key does not have access"
          },
          "429": {
            "description": "Too Many Requests - Rate limit exceeded (free tier: 500 requests/day)"
          }
        },
        "tags": [
          "parse"
        ]
      }
    },
    "/parse/imageurl": {
      "get": {
        "operationId": "parseImageUrl",
        "summary": "Parse image via URL (simplified GET endpoint)",
        "description": "Simplified OCR endpoint that only accepts image/PDF input via URL parameter. Useful for simple integrations where POST is not convenient.",
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API authentication key."
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "description": "URL of the image or PDF to process."
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "eng"
            },
            "description": "Language for OCR recognition (3-letter code)."
          },
          {
            "name": "isOverlayRequired",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "If true, returns word-level coordinates."
          },
          {
            "name": "filetype",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "PDF",
                "GIF",
                "PNG",
                "JPG",
                "TIF",
                "BMP"
              ]
            },
            "description": "Override automatic file type detection."
          },
          {
            "name": "detectOrientation",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Auto-rotate and detect text orientation."
          },
          {
            "name": "isCreateSearchablePdf",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Generate searchable PDF."
          },
          {
            "name": "scale",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Enable internal upscaling for low-resolution images."
          },
          {
            "name": "isTable",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Enable table/structured data parsing."
          },
          {
            "name": "OCREngine",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "enum": [
                1,
                2,
                3
              ]
            },
            "description": "OCR engine selection (1, 2, or 3)."
          }
        ],
        "responses": {
          "200": {
            "description": "OCR processing result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OCRResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "429": {
            "description": "Too Many Requests - Rate limit exceeded"
          }
        },
        "tags": [
          "parse"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "apikey",
        "description": "API key for authentication. Obtain a free key at https://ocr.space/ocrapi/freekey"
      }
    },
    "schemas": {
      "OCRResponse": {
        "type": "object",
        "properties": {
          "ParsedResults": {
            "type": "array",
            "description": "Array of parsed results, one per page/image.",
            "items": {
              "$ref": "#/components/schemas/ParsedResult"
            }
          },
          "OCRExitCode": {
            "type": "integer",
            "description": "Overall exit code. 1=Success (all pages), 2=Partial success, 3=All pages failed, 4=Fatal error.",
            "enum": [
              1,
              2,
              3,
              4
            ]
          },
          "IsErroredOnProcessing": {
            "type": "boolean",
            "description": "Whether an error occurred during processing."
          },
          "ErrorMessage": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true,
            "description": "Error messages, if any."
          },
          "ErrorDetails": {
            "type": "string",
            "nullable": true,
            "description": "Detailed error information."
          },
          "SearchablePDFURL": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "URL to download the searchable PDF, if isCreateSearchablePdf was true."
          },
          "ProcessingTimeInMilliseconds": {
            "type": "string",
            "description": "Time taken to process the request, in milliseconds."
          }
        }
      },
      "ParsedResult": {
        "type": "object",
        "properties": {
          "TextOverlay": {
            "$ref": "#/components/schemas/TextOverlay"
          },
          "TextOrientation": {
            "type": "string",
            "nullable": true,
            "description": "Detected text orientation in degrees."
          },
          "FileParseExitCode": {
            "type": "integer",
            "description": "Per-page exit code. 0=File not found, 1=Success, -10=Parse error, -20=Timeout, -30=Validation error, -99=Unknown error."
          },
          "ParsedText": {
            "type": "string",
            "description": "The extracted text content from this page/image."
          },
          "ErrorMessage": {
            "type": "string",
            "nullable": true,
            "description": "Error message for this specific page, if any."
          },
          "ErrorDetails": {
            "type": "string",
            "nullable": true,
            "description": "Detailed error for this page."
          }
        }
      },
      "TextOverlay": {
        "type": "object",
        "description": "Word-level coordinate data. Only populated when isOverlayRequired is true.",
        "properties": {
          "Lines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TextLine"
            }
          },
          "HasOverlay": {
            "type": "boolean",
            "description": "Whether overlay data is present."
          },
          "Message": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "TextLine": {
        "type": "object",
        "properties": {
          "Words": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Word"
            }
          },
          "MaxHeight": {
            "type": "number",
            "description": "Maximum height of words in this line."
          },
          "MinTop": {
            "type": "number",
            "description": "Minimum top position of words in this line."
          }
        }
      },
      "Word": {
        "type": "object",
        "properties": {
          "WordText": {
            "type": "string",
            "description": "The recognized word text."
          },
          "Left": {
            "type": "number",
            "description": "Left coordinate of the bounding box."
          },
          "Top": {
            "type": "number",
            "description": "Top coordinate of the bounding box."
          },
          "Height": {
            "type": "number",
            "description": "Height of the bounding box."
          },
          "Width": {
            "type": "number",
            "description": "Width of the bounding box."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "parse"
    }
  ]
}
