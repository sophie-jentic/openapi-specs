{
  "openapi": "3.0.3",
  "info": {
    "title": "Last.fm API",
    "description": "The Last.fm API allows access to music data including artist info, album info, track info, user listening history (scrobbles), charts, tags, and more. All requests use the method parameter to specify the API method.",
    "version": "2.0",
    "contact": {
      "name": "Last.fm",
      "url": "https://www.last.fm/api",
      "email": "partners@last.fm"
    },
    "termsOfService": "https://www.last.fm/api/tos",
    "x-jentic-source-url": "https://www.last.fm/api"
  },
  "servers": [
    {
      "url": "https://ws.audioscrobbler.com/2.0",
      "description": "Last.fm API server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Album",
      "description": "Album-related methods"
    },
    {
      "name": "Artist",
      "description": "Artist-related methods"
    },
    {
      "name": "Auth",
      "description": "Authentication methods"
    },
    {
      "name": "Chart",
      "description": "Chart methods"
    },
    {
      "name": "Geo",
      "description": "Geographic methods"
    },
    {
      "name": "Library",
      "description": "Library methods"
    },
    {
      "name": "Tag",
      "description": "Tag methods"
    },
    {
      "name": "Track",
      "description": "Track-related methods"
    },
    {
      "name": "User",
      "description": "User-related methods"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "albumGetInfo",
        "summary": "Get album info",
        "description": "Get the metadata and tracklist for an album on Last.fm using the album name or a MusicBrainz ID.",
        "tags": [
          "Album"
        ],
        "parameters": [
          {
            "name": "method",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "album.getinfo"
              ]
            }
          },
          {
            "name": "artist",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The artist name"
          },
          {
            "name": "album",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The album name"
          },
          {
            "name": "mbid",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The MusicBrainz ID for the album"
          },
          {
            "name": "autocorrect",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "description": "Transform misspelled artist names into correct artist names"
          },
          {
            "name": "username",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Username to include user playcount"
          },
          {
            "name": "lang",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "ISO 639 alpha-2 language code for wiki content"
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your Last.fm API key"
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml"
              ],
              "default": "json"
            },
            "description": "Response format"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlbumInfoResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      },
      "post": {
        "operationId": "trackScrobble",
        "summary": "Scrobble a track",
        "description": "Add a track scrobble to a user's profile. Authentication required.",
        "tags": [
          "Track"
        ],
        "security": [
          {
            "apiKey": [],
            "sessionKey": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "method",
                  "artist",
                  "track",
                  "timestamp",
                  "api_key",
                  "api_sig",
                  "sk"
                ],
                "properties": {
                  "method": {
                    "type": "string",
                    "enum": [
                      "track.scrobble"
                    ]
                  },
                  "artist": {
                    "type": "string",
                    "description": "The artist name"
                  },
                  "track": {
                    "type": "string",
                    "description": "The track name"
                  },
                  "timestamp": {
                    "type": "integer",
                    "description": "Unix timestamp of when the track was listened to"
                  },
                  "album": {
                    "type": "string",
                    "description": "The album name"
                  },
                  "albumArtist": {
                    "type": "string",
                    "description": "The album artist"
                  },
                  "trackNumber": {
                    "type": "integer",
                    "description": "The track number on the album"
                  },
                  "duration": {
                    "type": "integer",
                    "description": "Track length in seconds"
                  },
                  "api_key": {
                    "type": "string"
                  },
                  "api_sig": {
                    "type": "string",
                    "description": "API method signature"
                  },
                  "sk": {
                    "type": "string",
                    "description": "Session key from authentication"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scrobble accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrobbleResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AlbumInfoResponse": {
        "type": "object",
        "properties": {
          "album": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "artist": {
                "type": "string"
              },
              "mbid": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "image": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "#text": {
                      "type": "string",
                      "format": "uri"
                    },
                    "size": {
                      "type": "string",
                      "enum": [
                        "small",
                        "medium",
                        "large",
                        "extralarge",
                        "mega"
                      ]
                    }
                  }
                }
              },
              "listeners": {
                "type": "string"
              },
              "playcount": {
                "type": "string"
              },
              "tracks": {
                "type": "object",
                "properties": {
                  "track": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/TrackSummary"
                    }
                  }
                }
              },
              "tags": {
                "type": "object",
                "properties": {
                  "tag": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Tag"
                    }
                  }
                }
              },
              "wiki": {
                "$ref": "#/components/schemas/Wiki"
              }
            }
          }
        }
      },
      "ScrobbleResponse": {
        "type": "object",
        "properties": {
          "scrobbles": {
            "type": "object",
            "properties": {
              "@attr": {
                "type": "object",
                "properties": {
                  "accepted": {
                    "type": "integer"
                  },
                  "ignored": {
                    "type": "integer"
                  }
                }
              },
              "scrobble": {
                "type": "object",
                "properties": {
                  "artist": {
                    "type": "object",
                    "properties": {
                      "corrected": {
                        "type": "string"
                      },
                      "#text": {
                        "type": "string"
                      }
                    }
                  },
                  "album": {
                    "type": "object",
                    "properties": {
                      "corrected": {
                        "type": "string"
                      },
                      "#text": {
                        "type": "string"
                      }
                    }
                  },
                  "track": {
                    "type": "object",
                    "properties": {
                      "corrected": {
                        "type": "string"
                      },
                      "#text": {
                        "type": "string"
                      }
                    }
                  },
                  "timestamp": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "TrackSummary": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "duration": {
            "type": "integer"
          },
          "@attr": {
            "type": "object",
            "properties": {
              "rank": {
                "type": "integer"
              }
            }
          },
          "artist": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "mbid": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Image": {
        "type": "object",
        "properties": {
          "#text": {
            "type": "string",
            "format": "uri"
          },
          "size": {
            "type": "string",
            "enum": [
              "small",
              "medium",
              "large",
              "extralarge",
              "mega"
            ]
          }
        }
      },
      "Wiki": {
        "type": "object",
        "properties": {
          "published": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "integer",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid parameters or missing required parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Invalid API key or authentication failure",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Rate limit exceeded. Reduce request frequency.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      },
      "sessionKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}
