{
  "openapi": "3.0.3",
  "info": {
    "title": "Charity Search API",
    "description": "Comprehensive charity and nonprofit lookup API providing access to 2.5 million US charities and 87,000 Canadian charities with detailed information including financial data, geolocation, and IRS classification.",
    "version": "1.0.0",
    "x-jentic-source-url": "http://charityapi.orghunter.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://data.orghunter.com/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "search",
      "description": "Search operations for charities"
    },
    {
      "name": "charity",
      "description": "Operations for retrieving charity details"
    },
    {
      "name": "classification",
      "description": "NTEE classification operations"
    },
    {
      "name": "financial",
      "description": "Financial data operations"
    }
  ],
  "paths": {
    "/charitysearch": {
      "get": {
        "operationId": "searchCharities",
        "summary": "Search charities",
        "description": "Search the entire database of IRS-registered nonprofits using filters like EIN, name, category, location, and ZIP code with pagination support",
        "tags": [
          "search"
        ],
        "parameters": [
          {
            "name": "searchTerm",
            "in": "query",
            "description": "Search term for charity name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "eligible",
            "in": "query",
            "description": "Filter by eligibility status",
            "schema": {
              "type": "string",
              "enum": [
                "1",
                "0"
              ]
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "Two-letter state code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "city",
            "in": "query",
            "description": "City name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "zipCode",
            "in": "query",
            "description": "ZIP code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "description": "NTEE category code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Starting record for pagination (default: 0)",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "rows",
            "in": "query",
            "description": "Number of records to return (default: 20, max: 100)",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CharitySearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/charitybasic": {
      "get": {
        "operationId": "getCharityBasic",
        "summary": "Get basic charity information",
        "description": "Retrieve detailed information on a charity, including its current status with the IRS",
        "tags": [
          "charity"
        ],
        "parameters": [
          {
            "name": "ein",
            "in": "query",
            "required": true,
            "description": "Employer Identification Number (EIN)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CharityBasicResponse"
                }
              }
            }
          },
          "404": {
            "description": "Charity not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/charitygeo": {
      "get": {
        "operationId": "getCharityGeo",
        "summary": "Get charity with geolocation",
        "description": "Retrieve charity details with geolocation data for Google Maps integration",
        "tags": [
          "charity"
        ],
        "parameters": [
          {
            "name": "ein",
            "in": "query",
            "required": true,
            "description": "Employer Identification Number (EIN)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CharityGeoResponse"
                }
              }
            }
          },
          "404": {
            "description": "Charity not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/charityfinancial": {
      "get": {
        "operationId": "getCharityFinancial",
        "summary": "Get charity financial data",
        "description": "Retrieve detailed financial information from the charity's latest Form 990",
        "tags": [
          "financial"
        ],
        "parameters": [
          {
            "name": "ein",
            "in": "query",
            "required": true,
            "description": "Employer Identification Number (EIN)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CharityFinancialResponse"
                }
              }
            }
          },
          "404": {
            "description": "Financial data not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/charitypremium": {
      "get": {
        "operationId": "getCharityPremium",
        "summary": "Get comprehensive charity data",
        "description": "Retrieve the most comprehensive charity information combining financial data, charts, and mapping",
        "tags": [
          "charity"
        ],
        "parameters": [
          {
            "name": "ein",
            "in": "query",
            "required": true,
            "description": "Employer Identification Number (EIN)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CharityPremiumResponse"
                }
              }
            }
          },
          "404": {
            "description": "Charity not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/categories": {
      "get": {
        "operationId": "getCategories",
        "summary": "Get NTEE categories",
        "description": "Retrieve a list of all NTEE (National Taxonomy of Exempt Entities) classification categories",
        "tags": [
          "classification"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CategoriesResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "user_key"
      }
    },
    "schemas": {
      "CharitySearchResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CharitySummary"
            }
          },
          "total": {
            "type": "integer"
          },
          "start": {
            "type": "integer"
          },
          "rows": {
            "type": "integer"
          }
        }
      },
      "CharitySummary": {
        "type": "object",
        "properties": {
          "ein": {
            "type": "string"
          },
          "charityName": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "zipCode": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "eligible": {
            "type": "boolean"
          },
          "score": {
            "type": "number",
            "description": "Search relevance score"
          }
        }
      },
      "CharityBasicResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/CharityBasic"
          }
        }
      },
      "CharityBasic": {
        "type": "object",
        "properties": {
          "ein": {
            "type": "string"
          },
          "charityName": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "zipCode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "website": {
            "type": "string"
          },
          "mission": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "nteeCode": {
            "type": "string"
          },
          "eligible": {
            "type": "boolean"
          },
          "irsStatus": {
            "type": "string"
          },
          "taxDeductibleStatus": {
            "type": "string"
          },
          "filingRequirement": {
            "type": "string"
          },
          "assetAmount": {
            "type": "number"
          },
          "incomeAmount": {
            "type": "number"
          },
          "revenueAmount": {
            "type": "number"
          }
        }
      },
      "CharityGeoResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/CharityGeo"
          }
        }
      },
      "CharityGeo": {
        "allOf": [
          {
            "$ref": "#/components/schemas/CharityBasic"
          },
          {
            "type": "object",
            "properties": {
              "latitude": {
                "type": "number"
              },
              "longitude": {
                "type": "number"
              },
              "accuracy": {
                "type": "string"
              }
            }
          }
        ]
      },
      "CharityFinancialResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/CharityFinancial"
          }
        }
      },
      "CharityFinancial": {
        "type": "object",
        "properties": {
          "ein": {
            "type": "string"
          },
          "charityName": {
            "type": "string"
          },
          "taxYear": {
            "type": "integer"
          },
          "totalRevenue": {
            "type": "number"
          },
          "totalExpenses": {
            "type": "number"
          },
          "totalAssets": {
            "type": "number"
          },
          "totalLiabilities": {
            "type": "number"
          },
          "netAssets": {
            "type": "number"
          },
          "programServiceRevenue": {
            "type": "number"
          },
          "contributions": {
            "type": "number"
          },
          "investmentIncome": {
            "type": "number"
          },
          "programServiceExpenses": {
            "type": "number"
          },
          "administrativeExpenses": {
            "type": "number"
          },
          "fundraisingExpenses": {
            "type": "number"
          }
        }
      },
      "CharityPremiumResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/CharityPremium"
          }
        }
      },
      "CharityPremium": {
        "allOf": [
          {
            "$ref": "#/components/schemas/CharityGeo"
          },
          {
            "$ref": "#/components/schemas/CharityFinancial"
          },
          {
            "type": "object",
            "properties": {
              "officers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    },
                    "compensation": {
                      "type": "number"
                    }
                  }
                }
              },
              "programs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "description": {
                      "type": "string"
                    },
                    "expenses": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "CategoriesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Category"
            }
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "statusCode": {
            "type": "integer",
            "description": "HTTP status code"
          }
        }
      }
    }
  }
}
