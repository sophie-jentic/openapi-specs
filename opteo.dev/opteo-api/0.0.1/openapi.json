{
  "openapi": "3.0.3",
  "info": {
    "title": "Opteo API",
    "version": "0.0.1",
    "description": "Opteo API for managing Google Ads accounts, budgets, performance goals, and improvements.",
    "x-jentic-source-url": "https://github.com/Opteo/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.opteo.dev/v0"
    }
  ],
  "paths": {
    "/customers": {
      "get": {
        "operationId": "listCustomers",
        "summary": "List customers",
        "description": "Retrieve accessible ad accounts.",
        "tags": [
          "Customers"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter by status",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "linked",
                "unlinked",
                "all"
              ],
              "default": "linked"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomerListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
