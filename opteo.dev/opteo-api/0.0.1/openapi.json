  "components": {
    "schemas": {
      "CustomerListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Customer"
            }
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "linked": {
            "type": "boolean"
          }
        }
      },
      "LinkingResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "type": "object",
            "properties": {
              "linked": {
                "type": "boolean"
              },
              "teamMembers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "type": "string"
                    },
                    "connected": {
                      "type": "boolean"
                    }
                  }
                }
              },
              "changelogEmails": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "BudgetResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "type": "object",
            "properties": {
              "lastUpdated": {
                "type": "string",
                "format": "date-time"
              },
              "budget": {
                "type": "number"
              },
              "currencyCode": {
                "type": "string"
              }
            }
          }
        }
      },
      "PerformanceModeResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "type": "object",
            "properties": {
              "performanceMode": {
                "type": "string",
                "enum": [
                  "CPA",
                  "ROAS"
                ]
              }
            }
          }
        }
      },
      "PerformanceGoalsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "type": "object",
            "properties": {
              "primaryGoal": {
                "type": "string"
              },
              "secondaryGoal": {
                "type": "string"
              },
              "goalCycle": {
                "type": "string"
              },
              "goalAmount": {
                "type": "number"
              },
              "cycleStartDay": {
                "type": "string"
              },
              "cycleStartDate": {
                "type": "string"
              }
            }
          }
        }
      },
      "PerformanceGoalsUpdate": {
        "type": "object",
        "properties": {
          "goalAmount": {
            "type": "number",
            "minimum": 0
          },
          "goalCycle": {
            "type": "string"
          },
          "primaryGoal": {
            "type": "string"
          },
          "secondaryGoal": {
            "type": "string"
          },
          "cycleStartDay": {
            "type": "string"
          },
          "cycleStartDate": {
            "type": "string"
          }
        }
      },
      "ImprovementListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Improvement"
            }
          }
        }
      },
      "Improvement": {
        "type": "object",
        "properties": {
          "improvement_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "location": {
            "type": "object"
          },
          "text_description": {
            "type": "string"
          }
        }
      },
      "CompletedImprovementListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "improvement_id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "completed_ts": {
                  "type": "string",
                  "format": "date-time"
                },
                "completed_by_email": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token provided by Opteo team."
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Budget"
    },
    {
      "name": "Customers"
    },
    {
      "name": "Improvements"
    },
    {
      "name": "Performance"
