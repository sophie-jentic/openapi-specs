{
  "openapi": "3.0.3",
  "info": {
    "title": "Defastra API",
    "description": "Fraud detection and risk assessment API for email addresses and phone numbers",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.defastra.com/reference/authentication",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.defastra.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Email Verification",
      "description": "Deep email check and fraud detection"
    },
    {
      "name": "Phone Verification",
      "description": "Phone number analysis and fraud risk assessment"
    }
  ],
  "paths": {
    "/deep_email_check": {
      "post": {
        "tags": [
          "Email Verification"
        ],
        "summary": "Perform deep email check",
        "description": "Performs fraud detection on email addresses",
        "operationId": "deepEmailCheck",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email address to check"
                  },
                  "timeout": {
                    "type": "integer",
                    "description": "Request timeout in seconds"
                  },
                  "label": {
                    "type": "string",
                    "description": "Optional label for tracking"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "description": "Request status"
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique request identifier"
                    },
                    "wallet": {
                      "type": "number",
                      "description": "Remaining wallet balance"
                    },
                    "deep_email_check": {
                      "type": "object",
                      "description": "Email check results"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/deep_phone_check": {
      "post": {
        "tags": [
          "Phone Verification"
        ],
        "summary": "Perform deep phone check",
        "description": "Analyzes phone numbers for fraud risk",
        "operationId": "deepPhoneCheck",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "phone"
                ],
                "properties": {
                  "phone": {
                    "type": "string",
                    "description": "Phone number to check"
                  },
                  "timeout": {
                    "type": "integer",
                    "description": "Request timeout in seconds"
                  },
                  "label": {
                    "type": "string",
                    "description": "Optional label for tracking"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "description": "Request status"
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique request identifier"
                    },
                    "wallet": {
                      "type": "number",
                      "description": "Remaining wallet balance"
                    },
                    "risk_level": {
                      "type": "string",
                      "description": "Risk level assessment"
                    },
                    "risk_score": {
                      "type": "number",
                      "description": "Numerical risk score"
                    },
                    "checks": {
                      "type": "object",
                      "description": "Detailed check results"
                    },
                    "phone": {
                      "type": "object",
                      "description": "Phone data"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "API key from dashboard"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "boolean",
            "example": false
          },
          "error_type": {
            "type": "string",
            "description": "Error type identifier"
          },
          "error_message": {
            "type": "string",
            "description": "Human-readable error message"
          }
        }
      }
    }
  }
}
