{
  "openapi": "3.0.3",
  "info": {
    "title": "Castmagic API",
    "description": "Castmagic API for managing media objects, spaces, and webhooks. Castmagic is a content processing platform that allows you to create media objects from audio/video files and manage workspaces.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://castmagic.gitbook.io/castmagic-internal-api/zapier",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://app.castmagic.io/api/zapier",
      "description": "Castmagic Zapier API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/validate": {
      "get": {
        "operationId": "validateApiKey",
        "summary": "Validate API Key",
        "description": "Validates the provided API key to ensure it is active and authorized.",
        "responses": {
          "200": {
            "description": "API key is valid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "valid": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Invalid API key."
          }
        },
        "tags": [
          "validate"
        ]
      }
    },
    "/spaces": {
      "get": {
        "operationId": "listSpaces",
        "summary": "List Spaces",
        "description": "Lists all spaces available to the authenticated user.",
        "responses": {
          "200": {
            "description": "A list of spaces.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Space"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Invalid API key."
          }
        },
        "tags": [
          "spaces"
        ]
      }
    },
    "/objects": {
      "post": {
        "operationId": "createObject",
        "summary": "Create Media Object",
        "description": "Creates a new media object from a downloadable file URL in the specified space.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "filename",
                  "download_url",
                  "space_id"
                ],
                "properties": {
                  "filename": {
                    "type": "string",
                    "description": "The name of the media file."
                  },
                  "download_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "The URL from which the media file can be downloaded."
                  },
                  "space_id": {
                    "type": "string",
                    "description": "The identifier of the target space where the object will be created."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Media object created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaObject"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Invalid API key."
          }
        },
        "tags": [
          "objects"
        ]
      }
    },
    "/hooks/subscribe": {
      "post": {
        "operationId": "subscribeWebhook",
        "summary": "Subscribe Webhook",
        "description": "Subscribes a new webhook URL to receive event notifications.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "hookUrl",
                  "type"
                ],
                "properties": {
                  "hookUrl": {
                    "type": "string",
                    "format": "uri",
                    "description": "The webhook endpoint URL to receive notifications."
                  },
                  "type": {
                    "type": "string",
                    "description": "The category or type of webhook events to subscribe to."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook subscription created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "hook_id": {
                      "type": "string",
                      "description": "The unique identifier of the created webhook subscription."
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Invalid API key."
          }
        },
        "tags": [
          "hooks"
        ]
      }
    },
    "/hooks/unsubscribe": {
      "delete": {
        "operationId": "unsubscribeWebhook",
        "summary": "Unsubscribe Webhook",
        "description": "Unsubscribes an existing webhook by its identifier.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "hook_id"
                ],
                "properties": {
                  "hook_id": {
                    "type": "string",
                    "description": "The unique identifier of the webhook subscription to remove."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook unsubscribed successfully."
          },
          "403": {
            "description": "Forbidden - Invalid API key."
          }
        },
        "tags": [
          "hooks"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key passed as a Bearer token in the Authorization header."
      }
    },
    "schemas": {
      "Space": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the space."
          },
          "name": {
            "type": "string",
            "description": "Name of the space."
          }
        }
      },
      "MediaObject": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the media object."
          },
          "filename": {
            "type": "string",
            "description": "Name of the media file."
          },
          "space_id": {
            "type": "string",
            "description": "The space this object belongs to."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "hooks"
    },
    {
      "name": "objects"
    },
    {
      "name": "spaces"
    },
    {
      "name": "validate"
    }
  ]
}
