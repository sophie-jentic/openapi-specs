          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "novoIntervalo": {
                    "type": "integer",
                    "format": "int64",
                    "description": "ID do novo intervalo (opcional)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Intervalo finalizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          }
        },
        "operationId": "post-finalizar-intervalo"
      }
    },
    "/solicitar-intervalo": {
      "post": {
        "tags": [
          "Atendente"
        ],
        "summary": "Solicitar intervalo",
        "description": "Solicita um intervalo para o atendente logado",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "idIntervalo"
                ],
                "properties": {
                  "idIntervalo": {
                    "type": "integer",
                    "format": "int64",
                    "description": "ID do tipo de intervalo",
                    "example": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Intervalo solicitado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          },
          "400": {
            "description": "Erro ao solicitar intervalo"
          }
        },
        "operationId": "post-solicitar-intervalo"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtido atrav\u00e9s do endpoint POST /v1/token."
      },
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Autentica\u00e7\u00e3o com username, password, client_id e secret_id"
      }
    },
    "schemas": {
      "LoginPassword": {
        "type": "object",
        "required": [
          "grant_type",
          "username",
          "password"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "password"
            ],
            "example": "password"
          },
          "username": {
            "type": "string",
            "description": "Login do usu\u00e1rio",
            "example": "SEU_USERNAME"
          },
          "password": {
            "type": "string",
            "description": "Senha do usu\u00e1rio",
            "example": "SUA_PASSWORD"
          }
        }
      },
      "LoginPanelCode": {
        "type": "object",
        "required": [
          "grant_type",
          "code"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "panel_code"
            ]
          },
          "code": {
            "type": "string",
            "description": "C\u00f3digo do painel",
            "example": "PAINEL001"
          }
        }
      },
      "LoginTotemCode": {
        "type": "object",
        "required": [
          "grant_type",
          "code"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "totem_code"
            ]
          },
          "code": {
            "type": "string",
            "description": "C\u00f3digo do totem",
            "example": "TOTEM001"
          }
        }
      },
      "LoginSchedulingCode": {
        "type": "object",
        "required": [
          "grant_type",
          "client_id"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "scheduling_code"
            ]
          },
          "client_id": {
            "type": "string",
            "description": "ID do cliente para agendamento",
            "example": "agendamento_client"
          }
        }
      },
      "RefreshToken": {
        "type": "object",
        "required": [
          "grant_type",
          "refresh_token"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "refresh_token"
            ]
          },
          "refresh_token": {
            "type": "string",
            "description": "Token de refresh",
            "example": "eyJhbGciOiJIUzI1NiJ9..."
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "Token de acesso JWT",
            "example": "eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c"
          },
          "refresh_token": {
            "type": "string",
            "description": "Token para renova\u00e7\u00e3o",
            "example": "eyJhbGciOiJIUzI1NiJ9.refresh_content.signature"
          },
          "token_type": {
            "type": "string",
            "example": "Bearer"
          },
          "expires_in": {
            "type": "integer",
            "description": "Tempo de expira\u00e7\u00e3o em segundos",
            "example": 3600
          }
        }
      },
      "UsuarioInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
