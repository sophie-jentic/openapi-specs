            "description": "ID do usu\u00e1rio"
          },
          "nome": {
            "type": "string",
            "description": "Nome do atendente",
            "example": "Jo\u00e3o Silva"
          },
          "login": {
            "type": "string",
            "description": "Login do usu\u00e1rio",
            "example": "joao.silva"
          },
          "mesa": {
            "$ref": "#/components/schemas/Mesa"
          },
          "unidade": {
            "$ref": "#/components/schemas/Unidade"
          }
        }
      },
      "PainelInfo": {
