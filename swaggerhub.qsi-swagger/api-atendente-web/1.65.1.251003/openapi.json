            "description": "Informa\u00e7\u00f5es da entidade logada",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/UsuarioInfo"
                    },
                    {
                      "$ref": "#/components/schemas/PainelInfo"
                    },
                    {
                      "$ref": "#/components/schemas/TotemInfo"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Token inv\u00e1lido ou expirado"
          }
        },
        "operationId": "get-me"
      }
    },
    "/associar-mesa": {
      "post": {
        "tags": [
          "Autentica\u00e7\u00e3o"
        ],
        "summary": "Associar mesa ao atendente",
        "description": "Associa uma mesa espec\u00edfica ao atendente logado",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "branch",
                  "codigoMesa"
                ],
                "properties": {
                  "branch": {
                    "type": "string",
                    "description": "ID da unidade",
                    "example": "17"
                  },
                  "codigoMesa": {
                    "type": "string",
                    "description": "C\u00f3digo da mesa",
                    "example": "001"
                  },
                  "atendenteTablet": {
                    "type": "boolean",
                    "description": "Indica se \u00e9 acesso via tablet",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mesa associada com sucesso"
          },
          "400": {
            "description": "Dados inv\u00e1lidos para associa\u00e7\u00e3o"
          },
          "409": {
            "description": "Mesa j\u00e1 est\u00e1 em uso"
          }
        },
        "operationId": "post-associar-mesa"
      }
    },
    "/logout": {
