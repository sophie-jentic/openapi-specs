  "paths": {
    "/token": {
      "post": {
        "tags": [
          "Autentica\u00e7\u00e3o"
        ],
        "summary": "Gerar token de acesso",
        "security": [
          {
            "BasicAuth": []
          }
        ],
        "description": "Gera token JWT para autentica\u00e7\u00e3o nos demais endpoints",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/LoginPassword"
                  },
                  {
                    "$ref": "#/components/schemas/LoginPanelCode"
                  },
                  {
                    "$ref": "#/components/schemas/LoginTotemCode"
                  },
                  {
                    "$ref": "#/components/schemas/LoginSchedulingCode"
                  },
                  {
                    "$ref": "#/components/schemas/RefreshToken"
                  }
                ]
              },
              "examples": {
                "password": {
                  "summary": "Login com usu\u00e1rio e senha",
                  "value": {
                    "grant_type": "password",
                    "username": "SEU_USERNAME",
                    "password": "SUA_PASSWORD"
                  }
                },
                "panel_code": {
                  "summary": "Login com c\u00f3digo do painel",
                  "value": {
                    "grant_type": "panel_code",
                    "code": "PAINEL001"
                  }
                },
                "refresh_token": {
                  "summary": "Renovar token",
                  "value": {
                    "grant_type": "refresh_token",
                    "refresh_token": "eyJhbGciOiJIUzI1NiJ9..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token gerado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inv\u00e1lidas",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "operationId": "post-token"
      }
    },
    "/me": {
      "get": {
        "tags": [
          "Autentica\u00e7\u00e3o"
        ],
        "summary": "Informa\u00e7\u00f5es do usu\u00e1rio logado",
        "description": "Retorna as informa\u00e7\u00f5es da entidade logada (atendente, painel ou totem)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
