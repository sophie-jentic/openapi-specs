{
  "openapi": "3.0.3",
  "info": {
    "title": "EndorseFlow API",
    "version": "1.0.0",
    "description": "Testimonial management API for sending email requests and managing webhooks for testimonial events.",
    "x-jentic-source-url": "https://endorseflow.featurebase.app/help/articles/1344032",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.endorseflow.com"
    }
  ],
  "paths": {
    "/zapier/testimonials/send-email-request": {
      "post": {
        "operationId": "sendTestimonialRequest",
        "summary": "Send testimonial request email",
        "description": "Sends a testimonial request email to a recipient",
        "tags": [
          "Testimonials"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "to_email",
                  "message"
                ],
                "properties": {
                  "to_email": {
                    "type": "string",
                    "format": "email"
                  },
                  "message": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email sent"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/zapier/webhooks/register": {
      "post": {
        "operationId": "registerWebhook",
        "summary": "Register a webhook",
        "description": "Register a webhook URL to receive event notifications",
        "tags": [
          "Webhooks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "hookUrl",
                  "event"
                ],
                "properties": {
                  "hookUrl": {
                    "type": "string",
                    "format": "uri"
                  },
                  "event": {
                    "type": "string",
                    "enum": [
                      "testimonial.created",
                      "testimonial.completed"
                    ],
                    "default": "testimonial.created"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook registered"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/zapier/webhooks/unregister": {
      "delete": {
        "operationId": "unregisterWebhook",
        "summary": "Unregister a webhook",
        "description": "Remove a previously registered webhook",
        "tags": [
          "Webhooks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "hookUrl",
                  "event"
                ],
                "properties": {
                  "hookUrl": {
                    "type": "string",
                    "format": "uri"
                  },
                  "event": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook unregistered"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Testimonials"
    },
    {
      "name": "Webhooks"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}
