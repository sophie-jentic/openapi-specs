{
  "openapi": "3.0.3",
  "info": {
    "title": "Alpha Vantage API",
    "version": "1.0.0",
    "description": "Alpha Vantage provides free and premium APIs for realtime and historical financial data. Covers stocks, forex, crypto, commodities, economic indicators, and 50+ technical indicators.",
    "x-jentic-source-url": "https://www.alphavantage.co/documentation/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://www.alphavantage.co",
      "description": "Alpha Vantage Production"
    }
  ],
  "security": [
    {
      "ApiKeyQuery": []
    }
  ],
  "tags": [
    {
      "name": "Core Stock APIs",
      "description": "Time series stock data (intraday, daily, weekly, monthly)"
    },
    {
      "name": "Options",
      "description": "US options data APIs"
    },
    {
      "name": "Alpha Intelligence",
      "description": "News, sentiments, earnings, insider transactions"
    },
    {
      "name": "Fundamental Data",
      "description": "Company financials, earnings, dividends, splits"
    },
    {
      "name": "Forex",
      "description": "Foreign exchange rates and time series"
    },
    {
      "name": "Cryptocurrencies",
      "description": "Crypto exchange rates and time series"
    },
    {
      "name": "Commodities",
      "description": "Commodity prices (gold, silver, oil, etc.)"
    },
    {
      "name": "Economic Indicators",
      "description": "GDP, CPI, unemployment, treasury yields, etc."
    },
    {
      "name": "Technical Indicators",
      "description": "50+ technical indicators (SMA, EMA, RSI, MACD, etc.)"
    }
  ],
  "paths": {
    "/query": {
      "get": {
        "operationId": "query",
        "summary": "Query the Alpha Vantage API",
        "description": "Single endpoint for all Alpha Vantage API functions. The 'function' parameter determines which data is returned. See documentation for all supported functions and their parameters.",
        "tags": [
          "Core Stock APIs"
        ],
        "parameters": [
          {
            "name": "function",
            "in": "query",
            "required": true,
            "description": "The API function to call. Determines the type of data returned.",
            "schema": {
              "type": "string",
              "enum": [
                "TIME_SERIES_INTRADAY",
                "TIME_SERIES_DAILY",
                "TIME_SERIES_DAILY_ADJUSTED",
                "TIME_SERIES_WEEKLY",
                "TIME_SERIES_WEEKLY_ADJUSTED",
                "TIME_SERIES_MONTHLY",
                "TIME_SERIES_MONTHLY_ADJUSTED",
                "GLOBAL_QUOTE",
                "REALTIME_BULK_QUOTES",
                "SYMBOL_SEARCH",
                "MARKET_STATUS",
                "REALTIME_OPTIONS",
                "HISTORICAL_OPTIONS",
                "NEWS_SENTIMENT",
                "EARNINGS_CALL_TRANSCRIPT",
                "TOP_GAINERS_LOSERS",
                "INSIDER_TRANSACTIONS",
                "INSTITUTIONAL_HOLDINGS",
                "ANALYTICS_FIXED_WINDOW",
                "ANALYTICS_SLIDING_WINDOW",
                "OVERVIEW",
                "ETF_PROFILE",
                "DIVIDENDS",
                "SPLITS",
                "INCOME_STATEMENT",
                "BALANCE_SHEET",
                "CASH_FLOW",
                "SHARES_OUTSTANDING",
                "EARNINGS",
                "EARNINGS_ESTIMATE",
                "LISTING_STATUS",
                "EARNINGS_CALENDAR",
                "IPO_CALENDAR",
                "CURRENCY_EXCHANGE_RATE",
                "FX_INTRADAY",
                "FX_DAILY",
                "FX_WEEKLY",
                "FX_MONTHLY",
                "CRYPTO_EXCHANGE_RATE",
                "CRYPTO_INTRADAY",
                "DIGITAL_CURRENCY_DAILY",
                "DIGITAL_CURRENCY_WEEKLY",
                "DIGITAL_CURRENCY_MONTHLY",
                "GOLD_ETF_SPOT",
                "GOLD_SILVER_HISTORY",
                "WTI",
                "BRENT",
                "NATURAL_GAS",
                "COPPER",
                "ALUMINUM",
                "WHEAT",
                "CORN",
                "COTTON",
                "SUGAR",
                "COFFEE",
                "ALL_COMMODITIES",
                "REAL_GDP",
                "REAL_GDP_PER_CAPITA",
                "TREASURY_YIELD",
                "FEDERAL_FUNDS_RATE",
                "CPI",
                "INFLATION",
                "RETAIL_SALES",
                "DURABLES",
                "UNEMPLOYMENT",
                "NONFARM_PAYROLL",
                "SMA",
                "EMA",
                "WMA",
                "DEMA",
                "TEMA",
                "TRIMA",
                "KAMA",
                "MAMA",
                "VWAP",
                "T3",
                "MACD",
                "MACDEXT",
                "STOCH",
                "STOCHF",
                "RSI",
                "STOCHRSI",
                "WILLR",
                "ADX",
                "ADXR",
                "APO",
                "PPO",
                "MOM",
                "BOP",
                "CCI",
                "CMO",
                "ROC",
                "ROCR",
                "AROON",
                "AROONOSC",
                "MFI",
                "TRIX",
                "ULTOSC",
                "DX",
                "MINUS_DI",
                "PLUS_DI",
                "MINUS_DM",
                "PLUS_DM",
                "BBANDS",
                "MIDPOINT",
                "MIDPRICE",
                "SAR",
                "TRANGE",
                "ATR",
                "NATR",
                "AD",
                "ADOSC",
                "OBV",
                "HT_TRENDLINE",
                "HT_SINE",
                "HT_TRENDMODE",
                "HT_DCPERIOD",
                "HT_DCPHASE",
                "HT_PHASOR"
              ]
            }
          },
          {
            "name": "symbol",
            "in": "query",
            "description": "Ticker symbol (e.g., IBM, MSFT). Required for most stock/forex/crypto functions.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "interval",
            "in": "query",
            "description": "Time interval for intraday data: 1min, 5min, 15min, 30min, 60min. Also used by some technical indicators.",
            "schema": {
              "type": "string",
              "enum": [
                "1min",
                "5min",
                "15min",
                "30min",
                "60min"
              ]
            }
          },
          {
            "name": "adjusted",
            "in": "query",
            "description": "If true (default), output is adjusted by historical split and dividend events.",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "extended_hours",
            "in": "query",
            "description": "If true (default), includes pre-market and post-market data.",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "month",
            "in": "query",
            "description": "Query a specific month (YYYY-MM format) for intraday data.",
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}$"
            }
          },
          {
            "name": "outputsize",
            "in": "query",
            "description": "compact (default, latest 100 points) or full (full history).",
            "schema": {
              "type": "string",
              "enum": [
                "compact",
                "full"
              ],
              "default": "compact"
            }
          },
          {
            "name": "datatype",
            "in": "query",
            "description": "json (default) or csv.",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv"
              ],
              "default": "json"
            }
          },
          {
            "name": "entitlement",
            "in": "query",
            "description": "Data freshness: realtime or delayed (15-min). Premium feature.",
            "schema": {
              "type": "string",
              "enum": [
                "realtime",
                "delayed"
              ]
            }
          },
          {
            "name": "keywords",
            "in": "query",
            "description": "Search keywords for SYMBOL_SEARCH function.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from_currency",
            "in": "query",
            "description": "Source currency for forex/crypto exchange rates (e.g., USD, BTC).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "to_currency",
            "in": "query",
            "description": "Target currency for forex/crypto exchange rates (e.g., EUR, USD).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from_symbol",
            "in": "query",
            "description": "Source currency for FX time series.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "to_symbol",
            "in": "query",
            "description": "Target currency for FX time series.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "market",
            "in": "query",
            "description": "Market for crypto (e.g., USD). Used in DIGITAL_CURRENCY functions.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tickers",
            "in": "query",
            "description": "Comma-separated list of tickers for NEWS_SENTIMENT.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "topics",
            "in": "query",
            "description": "News topics filter for NEWS_SENTIMENT.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "time_from",
            "in": "query",
            "description": "Start time for news sentiment (YYYYMMDDTHHMM format).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "time_to",
            "in": "query",
            "description": "End time for news sentiment.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order for news: LATEST, EARLIEST, RELEVANCE.",
            "schema": {
              "type": "string",
              "enum": [
                "LATEST",
                "EARLIEST",
                "RELEVANCE"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results to return (e.g., for news).",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "date",
            "in": "query",
            "description": "Date for IPO/earnings calendar or listing status (YYYY-MM-DD).",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "For LISTING_STATUS: active or delisted.",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "delisted"
              ]
            }
          },
          {
            "name": "horizon",
            "in": "query",
            "description": "Time horizon for earnings calendar: 3month, 6month, 12month.",
            "schema": {
              "type": "string",
              "enum": [
                "3month",
                "6month",
                "12month"
              ]
            }
          },
          {
            "name": "time_period",
            "in": "query",
            "description": "Number of data points for technical indicators (e.g., 10, 20, 50).",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "series_type",
            "in": "query",
            "description": "Price type for technical indicators: close, open, high, low.",
            "schema": {
              "type": "string",
              "enum": [
                "close",
                "open",
                "high",
                "low"
              ]
            }
          },
          {
            "name": "fastperiod",
            "in": "query",
            "description": "Fast period for MACD, APO, PPO, STOCH, etc.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "slowperiod",
            "in": "query",
            "description": "Slow period for MACD, APO, PPO, etc.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "signalperiod",
            "in": "query",
            "description": "Signal period for MACD.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "fastmatype",
            "in": "query",
            "description": "Moving average type for fast period (0=SMA, 1=EMA, 2=WMA, 3=DEMA, 4=TEMA, 5=TRIMA, 6=T3, 7=KAMA, 8=MAMA).",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 8
            }
          },
          {
            "name": "slowmatype",
            "in": "query",
            "description": "Moving average type for slow period.",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 8
            }
          },
          {
            "name": "signalmatype",
            "in": "query",
            "description": "Moving average type for signal period.",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 8
            }
          },
          {
            "name": "fastkperiod",
            "in": "query",
            "description": "Fast K period for STOCH/STOCHF/STOCHRSI.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "slowkperiod",
            "in": "query",
            "description": "Slow K period for STOCH.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "slowdperiod",
            "in": "query",
            "description": "Slow D period for STOCH.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "slowkmatype",
            "in": "query",
            "description": "MA type for slow K.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "slowdmatype",
            "in": "query",
            "description": "MA type for slow D.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "fastdperiod",
            "in": "query",
            "description": "Fast D period for STOCHF.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "fastdmatype",
            "in": "query",
            "description": "MA type for fast D.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "nbdevup",
            "in": "query",
            "description": "Standard deviation multiplier for upper band (BBANDS).",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "nbdevdn",
            "in": "query",
            "description": "Standard deviation multiplier for lower band (BBANDS).",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "matype",
            "in": "query",
            "description": "Moving average type.",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 8
            }
          },
          {
            "name": "timeperiod1",
            "in": "query",
            "description": "First time period for ULTOSC.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "timeperiod2",
            "in": "query",
            "description": "Second time period for ULTOSC.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "timeperiod3",
            "in": "query",
            "description": "Third time period for ULTOSC.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "acceleration",
            "in": "query",
            "description": "Acceleration factor for SAR.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "maximum",
            "in": "query",
            "description": "Maximum acceleration for SAR.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "fastlimit",
            "in": "query",
            "description": "Fast limit for MAMA indicator.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "slowlimit",
            "in": "query",
            "description": "Slow limit for MAMA indicator.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "maturity",
            "in": "query",
            "description": "Treasury yield maturity: 3month, 2year, 5year, 7year, 10year, 30year.",
            "schema": {
              "type": "string",
              "enum": [
                "3month",
                "2year",
                "5year",
                "7year",
                "10year",
                "30year"
              ]
            }
          },
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "description": "Your Alpha Vantage API key.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Structure varies based on function parameter.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Response object. Structure depends on the function called."
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string",
                  "description": "CSV data when datatype=csv"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded (5 calls/min for free tier, 75 calls/min for premium)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "apikey",
        "description": "Alpha Vantage API key passed as query parameter"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "Error Message": {
            "type": "string"
          },
          "Information": {
            "type": "string"
          },
          "Note": {
            "type": "string",
            "description": "Rate limit or usage note"
          }
        }
      }
    }
  }
}
