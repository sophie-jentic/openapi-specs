{
  "openapi": "3.0.3",
  "info": {
    "title": "Relevance AI API",
    "version": "1.0.0",
    "description": "Relevance AI is the home of the AI workforce. The API allows you to manage agents, tools, tasks, and knowledge. Build autonomous AI agents that follow your processes.",
    "x-jentic-source-url": "https://relevanceai.com/docs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api-{region}.stack.tryrelevance.com/latest",
      "description": "Relevance AI API",
      "variables": {
        "region": {
          "default": "d7b62b",
          "description": "Your region ID (e.g. d7b62b)"
        }
      }
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/agents/list": {
      "post": {
        "operationId": "listAgents",
        "tags": [
          "Agents"
        ],
        "summary": "List Agents",
        "description": "Lists all agents in your project.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListAgentsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agents list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/agents/{agent_id}": {
      "get": {
        "operationId": "getAgent",
        "tags": [
          "Agents"
        ],
        "summary": "Get Agent",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Agent details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get Agent"
      },
      "delete": {
        "operationId": "deleteAgent",
        "tags": [
          "Agents"
        ],
        "summary": "Delete Agent",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Agent deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete Agent"
      }
    },
    "/agents/upsert": {
      "post": {
        "operationId": "upsertAgent",
        "tags": [
          "Agents"
        ],
        "summary": "Create or Update Agent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertAgentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent upserted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create or Update Agent"
      }
    },
    "/agents/{agent_id}/tasks/trigger": {
      "post": {
        "operationId": "triggerAgentTask",
        "tags": [
          "Tasks"
        ],
        "summary": "Trigger an Agent Task",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TriggerTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task triggered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TriggeredTask"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Trigger an Agent Task"
      }
    },
    "/agents/{agent_id}/tasks/{conversation_id}/view_steps": {
      "get": {
        "operationId": "viewTaskSteps",
        "tags": [
          "Tasks"
        ],
        "summary": "View Task Steps",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "conversation_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task steps",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskStepsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "View Task Steps"
      }
    },
    "/tools/list": {
      "post": {
        "operationId": "listTools",
        "tags": [
          "Tools"
        ],
        "summary": "List Tools",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListToolsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tools list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToolListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List Tools"
      }
    },
    "/tools/studios/{tool_id}/run": {
      "post": {
        "operationId": "runTool",
        "tags": [
          "Tools"
        ],
        "summary": "Run a Tool",
        "parameters": [
          {
            "name": "tool_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunToolRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tool output",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToolOutput"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Run a Tool"
      }
    },
    "/knowledge/list": {
      "post": {
        "operationId": "listKnowledge",
        "tags": [
          "Knowledge"
        ],
        "summary": "List Knowledge Sets",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListKnowledgeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Knowledge sets list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List Knowledge Sets"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Your Relevance AI API key in format: {project_id}:{api_key}"
      }
    },
    "schemas": {
      "ListAgentsRequest": {
        "type": "object",
        "properties": {
          "page_size": {
            "type": "integer"
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "AgentListResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Agent"
            }
          },
          "cursor": {
            "type": "string"
          },
          "has_more": {
            "type": "boolean"
          }
        }
      },
      "Agent": {
        "type": "object",
        "properties": {
          "agent_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "system_prompt": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "temperature": {
            "type": "number"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UpsertAgentRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "agent_id": {
            "type": "string",
            "description": "Provide to update existing agent"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "system_prompt": {
            "type": "string"
          },
          "model": {
            "type": "string",
            "enum": [
              "gpt-3.5",
              "gpt-4",
              "claude-3-opus",
              "claude-3-sonnet"
            ]
          },
          "temperature": {
            "type": "number"
          }
        }
      },
      "TriggerTaskRequest": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string",
            "description": "The task message/prompt"
          },
          "filters": {
            "type": "object",
            "description": "Optional filters"
          }
        }
      },
      "TriggeredTask": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string"
          },
          "conversation_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "triggered",
              "running",
              "completed",
              "failed"
            ]
          }
        }
      },
      "TaskStepsResponse": {
        "type": "object",
        "properties": {
          "conversation_id": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "Task step"
            }
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ListToolsRequest": {
        "type": "object",
        "properties": {
          "max_results": {
            "type": "integer"
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "ToolListResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tool"
            }
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "Tool": {
        "type": "object",
        "properties": {
          "tool_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "public": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RunToolRequest": {
        "type": "object",
        "required": [
          "params"
        ],
        "properties": {
          "params": {
            "type": "object",
            "description": "Tool parameters as key-value pairs"
          }
        }
      },
      "ToolOutput": {
        "type": "object",
        "properties": {
          "output": {
            "type": "object",
            "description": "Tool output fields"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ListKnowledgeRequest": {
        "type": "object",
        "properties": {
          "page_size": {
            "type": "integer"
          }
        }
      },
      "KnowledgeListResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KnowledgeSet"
            }
          }
        }
      },
      "KnowledgeSet": {
        "type": "object",
        "properties": {
          "knowledge_set": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "num_rows": {
            "type": "integer"
          }
        }
      },
      "DeleteResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Agents"
    },
    {
      "name": "Knowledge"
    },
    {
      "name": "Tasks"
    },
    {
      "name": "Tools"
    }
  ]
}
