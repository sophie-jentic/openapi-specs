{
  "openapi": "3.0.3",
  "info": {
    "title": "Paige by Merchynt API",
    "version": "1.0.0",
    "description": "Paige by Merchynt provides listing and review management. The API includes a single sign-on endpoint for authenticating users.",
    "x-jentic-source-url": "https://merchynt.stoplight.io/docs/merchynt-listings-reviews/ZG9jOjM4MDMyNzU5-merchynt-s-single-sign-on-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.merchynt.com"
    }
  ],
  "paths": {
    "/sso/token": {
      "post": {
        "operationId": "createSsoToken",
        "summary": "Create SSO token",
        "description": "Generate a single sign-on token for user authentication",
        "tags": [
          "SSO"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSO token generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SsoTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SsoTokenResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "SSO"
    }
  ]
}
