        "operationId": "createList",
        "summary": "Create a new mailing list (SOAP)",
        "description": "Creates a new mailing list (requires appropriate privileges).",
        "tags": [
          "Lists"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "listname",
                  "subject",
                  "template",
                  "description",
                  "topic"
                ],
                "properties": {
                  "listname": {
                    "type": "string"
                  },
                  "subject": {
                    "type": "string"
                  },
                  "template": {
                    "type": "string",
                    "description": "List template (e.g. discussion_list, hotline, newsletter)"
                  },
                  "description": {
                    "type": "string"
                  },
                  "topic": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "boolean"
                    }
                  }
                }
              }
