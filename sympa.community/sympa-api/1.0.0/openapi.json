{
  "openapi": "3.0.3",
  "info": {
    "title": "Sympa API",
    "version": "1.0.0",
    "description": "Sympa is an open-source mailing list management (MLM) software. The primary API interface is SOAP/HTTP (WSDL-based). This spec models the SOAP operations as REST-like endpoints for discoverability. In practice, these are SOAP actions sent via POST to the SOAP endpoint URL. Sympa 6.2+ also has a limited REST API for some operations.",
    "x-jentic-source-url": "https://www.sympa.community/manual/customize/soap-api.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "{server_url}",
      "variables": {
        "server_url": {
          "default": "https://web.example.org",
          "description": "Sympa web server URL"
        }
      }
    }
  ],
  "paths": {
    "/sympasoap": {
      "post": {
        "operationId": "soapRequest",
        "summary": "SOAP endpoint",
        "description": "All Sympa API operations are SOAP-based. Send SOAP XML envelopes to this endpoint. Supported operations include: login, casLogin, authenticateAndRun, authenticateRemoteAppAndRun, lists, complexLists, info, which, complexWhich, amI, review, fullReview, subscribe, signoff, add, del, createList, closeList.",
        "tags": [
          "SOAP"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "text/xml": {
              "schema": {
                "type": "string",
                "description": "SOAP XML envelope"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SOAP response",
            "content": {
              "text/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "SOAP fault",
            "content": {
              "text/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/sympa/wsdl": {
      "get": {
        "operationId": "getWsdl",
        "summary": "Get WSDL service description",
        "description": "Returns the WSDL document describing all available SOAP operations.",
        "tags": [
          "Discovery"
        ],
        "responses": {
          "200": {
            "description": "WSDL document",
            "content": {
              "text/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/sympasoap/login": {
      "post": {
        "operationId": "login",
        "summary": "Authenticate user (SOAP)",
        "description": "SOAP login operation. Authenticates user email and password against Sympa user DB.",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "session_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sympasoap/lists": {
      "post": {
        "operationId": "getLists",
        "summary": "List available mailing lists (SOAP)",
        "description": "Returns a list of available mailing lists for the authenticated user. Authorization scenarios are applied.",
        "tags": [
          "Lists"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "topic": {
                    "type": "string"
                  },
                  "subtopic": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MailingList"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sympasoap/info": {
      "post": {
        "operationId": "getListInfo",
        "summary": "Get list information (SOAP)",
        "description": "Returns description information about a given mailing list.",
