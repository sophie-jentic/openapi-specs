  "components": {
    "schemas": {
      "MailingList": {
        "type": "object",
        "properties": {
          "listAddress": {
            "type": "string"
          },
          "homepage": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          }
        }
      },
      "MailingListInfo": {
        "type": "object",
        "properties": {
          "listAddress": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "homepage": {
            "type": "string"
          },
          "isSubscriber": {
            "type": "boolean"
          },
          "isOwner": {
            "type": "boolean"
          },
          "isEditor": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "faultcode": {
            "type": "string"
          },
          "faultstring": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
