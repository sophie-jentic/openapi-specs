{
  "openapi": "3.0.3",
  "info": {
    "title": "Logo.dev Image CDN API",
    "version": "1.0.0",
    "description": "Logo.dev is a comprehensive logo API that fetches company logos by domain, stock ticker, crypto symbol, ISIN, or brand name. Simple image CDN with publishable API key authentication.",
    "x-jentic-source-url": "https://logo.dev/docs",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://img.logo.dev"
    }
  ],
  "paths": {
    "/{domain}": {
      "get": {
        "operationId": "get_logo_by_domain",
        "summary": "Get company logo by domain",
        "description": "Fetch a company's logo image by providing their domain name.",
        "tags": [
          "Image CDN"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Company domain (e.g. nike.com)"
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Publishable API key"
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                32,
                64,
                128,
                256
              ]
            },
            "description": "Logo size in pixels"
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "png",
                "jpg",
                "webp"
              ]
            },
            "description": "Image format"
          },
          {
            "name": "retina",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Return 2x resolution for retina displays"
          },
          {
            "name": "greyscale",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Return greyscale version"
          },
          {
            "name": "fallback",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Return a fallback placeholder if no logo found"
          }
        ],
        "responses": {
          "200": {
            "description": "Logo image",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/webp": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          },
          "404": {
            "description": "Logo not found"
          }
        }
      }
    },
    "/ticker/{symbol}": {
      "get": {
        "operationId": "get_logo_by_ticker",
        "summary": "Get company logo by stock ticker",
