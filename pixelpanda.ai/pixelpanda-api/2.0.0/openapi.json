{
  "openapi": "3.0.3",
  "info": {
    "title": "PixelPanda API",
    "version": "2.0.0",
    "description": "AI-powered image processing API for background removal, upscaling, text removal, image-to-image transformation, product marketing, UGC video generation, and batch processing.",
    "x-jentic-source-url": "https://pixelpanda.ai/developers",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.pixelpanda.ai"
    }
  ],
  "paths": {
    "/api/process": {
      "post": {
        "operationId": "processImage",
        "summary": "Process an image",
        "description": "Process an image with various operations: background_removal, upscale, text_removal, image_to_image.",
        "tags": [
          "Image Processing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "processing_type": {
                    "type": "string",
                    "enum": [
                      "background_removal",
                      "upscale",
                      "text_removal",
                      "image_to_image"
                    ]
                  },
                  "output_format": {
                    "type": "string"
                  },
                  "quality": {
                    "type": "string"
                  },
                  "scale": {
                    "type": "integer",
                    "enum": [
                      2,
                      4
                    ]
                  },
                  "face_enhance": {
                    "type": "boolean"
                  },
                  "parameters": {
                    "type": "string",
                    "description": "JSON string with prompt and strength for image_to_image"
                  }
                },
                "required": [
                  "processing_type"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessingResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/tryon/generate": {
      "post": {
        "operationId": "generateProductMarketing",
        "summary": "Generate product marketing images",
        "description": "Creates marketing photos with AI models holding or wearing products.",
        "tags": [
          "Product Marketing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "product_image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "model_id": {
                    "type": "string"
                  },
                  "prompt": {
                    "type": "string"
                  }
                },
                "required": [
                  "product_image",
                  "model_id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessingResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/tryon/quick-video": {
      "post": {
        "operationId": "generateUgcVideo",
        "summary": "Generate UGC video",
        "description": "Converts avatar images into talking-head videos with voiceover and lip-sync.",
        "tags": [
          "Product Marketing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "image_url": {
                    "type": "string"
                  },
                  "script": {
                    "type": "string"
                  },
                  "prompt": {
                    "type": "string"
                  },
                  "enable_subtitles": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "image_url",
                  "script"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/batches": {
      "post": {
        "operationId": "submitBatchJob",
        "summary": "Submit batch processing job",
        "description": "Processes up to 100 product images in one request.",
        "tags": [
          "Batch Processing"
