  },
  "components": {
    "schemas": {
      "ProcessingResult": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "processing_id": {
            "type": "string"
          },
          "result_url": {
            "type": "string"
          },
          "credits_used": {
            "type": "integer"
          },
          "processing_time": {
            "type": "number"
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "VideoResult": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "video_url": {
            "type": "string"
          },
          "duration_seconds": {
            "type": "number"
          },
          "credits_used": {
            "type": "integer"
          }
        }
      },
      "BatchRequest": {
        "type": "object",
        "properties": {
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "image": {
                  "type": "string"
                },
                "category": {
                  "type": "string"
                }
              }
            }
          },
          "images_per_product": {
            "type": "integer"
          },
          "webhook_url": {
            "type": "string"
          }
        }
      },
      "BatchResponse": {
        "type": "object",
        "properties": {
          "batch_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "total_images": {
            "type": "integer"
          },
          "credits_reserved": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "JobRequest": {
        "type": "object",
        "properties": {
          "product_image": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "images_to_generate": {
            "type": "integer"
          },
          "webhook_url": {
            "type": "string"
          }
        }
      },
      "JobResponse": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string"
                }
              }
            }
          },
          "credits_used": {
            "type": "integer"
          }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
