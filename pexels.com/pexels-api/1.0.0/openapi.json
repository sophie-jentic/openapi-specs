{
  "openapi": "3.0.3",
  "info": {
    "title": "Pexels API",
    "description": "The Pexels API enables programmatic access to the full Pexels content library, including photos and videos. You can search, curate, and retrieve free stock media for use in your applications.",
    "version": "1.0.0",
    "contact": {
      "name": "Pexels",
      "url": "https://www.pexels.com/api/"
    },
    "termsOfService": "https://www.pexels.com/api/documentation/#guidelines"
  },
  "servers": [
    {
      "url": "https://api.pexels.com",
      "description": "Pexels API production server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/v1/search": {
      "get": {
        "operationId": "searchPhotos",
        "summary": "Search Photos",
        "description": "Search for photos matching a query string. Returns paginated results.",
        "tags": [
          "Photos"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "The search query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orientation",
            "in": "query",
            "description": "Filter by photo orientation.",
            "schema": {
              "type": "string",
              "enum": [
                "landscape",
                "portrait",
                "square"
              ]
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Minimum photo size.",
            "schema": {
              "type": "string",
              "enum": [
                "large",
                "medium",
                "small"
              ]
            }
          },
          {
            "name": "color",
            "in": "query",
            "description": "Filter by color. Can be a hex code (without #) or a color name.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "locale",
            "in": "query",
            "description": "The locale of the search query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "The page number to retrieve.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of results per page (max 80).",
            "schema": {
              "type": "integer",
              "default": 15,
              "maximum": 80
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhotoSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/v1/curated": {
      "get": {
        "operationId": "getCuratedPhotos",
        "summary": "Curated Photos",
        "description": "Returns real-time curated photos selected by the Pexels team.",
        "tags": [
          "Photos"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 15,
              "maximum": 80
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhotoSearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/photos/{id}": {
      "get": {
        "operationId": "getPhoto",
        "summary": "Get Photo",
        "description": "Retrieve a specific photo by its ID.",
        "tags": [
          "Photos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The photo ID.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Photo"
                }
              }
            }
          },
          "404": {
            "description": "Photo not found"
          }
        }
      }
    },
    "/videos/search": {
      "get": {
        "operationId": "searchVideos",
        "summary": "Search Videos",
        "description": "Search for videos matching a query string.",
        "tags": [
          "Videos"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "The search query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orientation",
            "in": "query",
            "description": "Filter by video orientation.",
            "schema": {
              "type": "string",
              "enum": [
                "landscape",
                "portrait",
                "square"
              ]
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Minimum video size.",
            "schema": {
              "type": "string",
              "enum": [
                "large",
                "medium",
                "small"
              ]
            }
          },
          {
            "name": "locale",
            "in": "query",
            "description": "The locale of the search query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 15,
              "maximum": 80
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoSearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/videos/popular": {
      "get": {
        "operationId": "getPopularVideos",
        "summary": "Popular Videos",
        "description": "Returns popular Pexels videos.",
        "tags": [
          "Videos"
        ],
        "parameters": [
          {
            "name": "min_width",
            "in": "query",
            "description": "Minimum width in pixels.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "min_height",
            "in": "query",
            "description": "Minimum height in pixels.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "min_duration",
            "in": "query",
            "description": "Minimum duration in seconds.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "max_duration",
            "in": "query",
            "description": "Maximum duration in seconds.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 15,
              "maximum": 80
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoSearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/videos/videos/{id}": {
      "get": {
        "operationId": "getVideo",
        "summary": "Get Video",
        "description": "Retrieve a specific video by its ID.",
        "tags": [
          "Videos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The video ID.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Video"
                }
              }
            }
          },
          "404": {
            "description": "Video not found"
          }
        }
      }
    },
    "/v1/collections": {
      "get": {
        "operationId": "listCollections",
        "summary": "List My Collections",
        "description": "Returns all collections belonging to the API user.",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 15,
              "maximum": 80
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectionListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/collections/featured": {
      "get": {
        "operationId": "listFeaturedCollections",
        "summary": "Featured Collections",
        "description": "Returns all featured collections on Pexels.",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 15,
              "maximum": 80
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectionListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/collections/{id}": {
      "get": {
        "operationId": "getCollectionMedia",
        "summary": "Get Collection Media",
        "description": "Returns all media (photos and videos) within a single collection.",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The collection ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by media type.",
            "schema": {
              "type": "string",
              "enum": [
                "photos",
                "videos"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 15,
              "maximum": 80
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectionMediaResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key provided by Pexels. Use as: Authorization: YOUR_API_KEY"
      }
    },
    "schemas": {
      "Photo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The photo ID."
          },
          "width": {
            "type": "integer",
            "description": "Original width in pixels."
          },
          "height": {
            "type": "integer",
            "description": "Original height in pixels."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "The Pexels URL of the photo."
          },
          "photographer": {
            "type": "string",
            "description": "The photographer's name."
          },
          "photographer_url": {
            "type": "string",
            "format": "uri",
            "description": "The photographer's Pexels profile URL."
          },
          "photographer_id": {
            "type": "integer",
            "description": "The photographer's ID."
          },
          "avg_color": {
            "type": "string",
            "description": "Average color as hex."
          },
          "src": {
            "$ref": "#/components/schemas/PhotoSrc"
          },
          "liked": {
            "type": "boolean",
            "description": "Whether the user liked the photo."
          },
          "alt": {
            "type": "string",
            "description": "Alt text for the photo."
          }
        }
      },
      "PhotoSrc": {
        "type": "object",
        "description": "Photo source URLs in various sizes.",
        "properties": {
          "original": {
            "type": "string",
            "format": "uri"
          },
          "large2x": {
            "type": "string",
            "format": "uri"
          },
          "large": {
            "type": "string",
            "format": "uri"
          },
          "medium": {
            "type": "string",
            "format": "uri"
          },
          "small": {
            "type": "string",
            "format": "uri"
          },
          "portrait": {
            "type": "string",
            "format": "uri"
          },
          "landscape": {
            "type": "string",
            "format": "uri"
          },
          "tiny": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "PhotoSearchResponse": {
        "type": "object",
        "properties": {
          "total_results": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "photos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Photo"
            }
          },
          "next_page": {
            "type": "string",
            "format": "uri"
          },
          "prev_page": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Video": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "image": {
            "type": "string",
            "format": "uri",
            "description": "Screenshot/thumbnail URL."
          },
          "full_res": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "duration": {
            "type": "integer",
            "description": "Duration in seconds."
          },
          "user": {
            "$ref": "#/components/schemas/VideoUser"
          },
          "video_files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VideoFile"
            }
          },
          "video_pictures": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VideoPicture"
            }
          }
        }
      },
      "VideoUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "VideoFile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "quality": {
            "type": "string",
            "enum": [
              "hd",
              "sd",
              "uhd"
            ]
          },
          "file_type": {
            "type": "string"
          },
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          },
          "fps": {
            "type": "number"
          },
          "link": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "VideoPicture": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "picture": {
            "type": "string",
            "format": "uri"
          },
          "nr": {
            "type": "integer"
          }
        }
      },
      "VideoSearchResponse": {
        "type": "object",
        "properties": {
          "total_results": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "videos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Video"
            }
          },
          "next_page": {
            "type": "string",
            "format": "uri"
          },
          "prev_page": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Collection": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "private": {
            "type": "boolean"
          },
          "media_count": {
            "type": "integer"
          },
          "photos_count": {
            "type": "integer"
          },
          "videos_count": {
            "type": "integer"
          }
        }
      },
      "CollectionListResponse": {
        "type": "object",
        "properties": {
          "total_results": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "collections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Collection"
            }
          },
          "next_page": {
            "type": "string",
            "format": "uri"
          },
          "prev_page": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "CollectionMediaResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "total_results": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "media": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/Photo"
                },
                {
                  "$ref": "#/components/schemas/Video"
                }
              ]
            }
          },
          "next_page": {
            "type": "string",
            "format": "uri"
          },
          "prev_page": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Collections"
    },
    {
      "name": "Photos"
    },
    {
      "name": "Videos"
    }
  ]
}
