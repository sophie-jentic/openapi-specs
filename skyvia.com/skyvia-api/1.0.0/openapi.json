  "components": {
    "schemas": {
      "Connection": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "connector": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdDate": {
            "type": "string",
            "format": "date-time"
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ConnectionCreate": {
        "type": "object",
        "required": [
          "name",
          "connector"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "connector": {
            "type": "string"
          },
          "settings": {
            "type": "object"
          }
        }
      },
      "Package": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "Import",
              "Export",
              "Replication",
              "Synchronization",
              "DataFlow",
              "Query"
            ]
          },
          "status": {
            "type": "string"
          },
          "schedule": {
            "type": "object"
          },
          "createdDate": {
            "type": "string",
            "format": "date-time"
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RunInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "packageId": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "InProgress",
              "Success",
              "Error",
              "Cancelled",
              "Warning"
            ]
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "recordsProcessed": {
            "type": "integer"
          },
          "recordsSucceeded": {
            "type": "integer"
          },
          "recordsFailed": {
            "type": "integer"
          },
          "errorMessage": {
            "type": "string"
          }
        }
      },
      "Endpoint": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "connectionId": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "Agent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "Online",
              "Offline"
            ]
          },
