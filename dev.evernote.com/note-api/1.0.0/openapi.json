{
  "openapi": "3.0.3",
  "info": {
    "title": "Evernote API",
    "version": "1.0.0",
    "description": "Evernote uses a Thrift-based EDAM (Evernote Data Access and Management) protocol accessed over HTTPS. The NoteStore service provides note, notebook, tag, and search operations. The UserStore service provides user and authentication operations. All calls are POST requests with Thrift-encoded bodies to the respective service endpoint.",
    "x-jentic-source-url": "https://dev.evernote.com/doc/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.evernote.com",
      "description": "Evernote production"
    },
    {
      "url": "https://sandbox.evernote.com",
      "description": "Evernote sandbox"
    }
  ],
  "security": [
    {
      "oauth": []
    }
  ],
  "tags": [
    {
      "name": "Notes",
      "description": "Note CRUD operations"
    },
    {
      "name": "Notebooks",
      "description": "Notebook operations"
    },
    {
      "name": "Tags",
      "description": "Tag operations"
    },
    {
      "name": "Search",
      "description": "Search operations"
    },
    {
      "name": "User",
      "description": "User operations"
    }
  ],
  "paths": {
    "/edam/notestore": {
      "post": {
        "operationId": "noteStoreCall",
        "summary": "NoteStore Thrift RPC endpoint",
        "description": "All NoteStore operations are invoked via Thrift binary protocol POST to this endpoint. Key operations: createNote, getNote, updateNote, deleteNote, findNotesMetadata, listNotebooks, createNotebook, updateNotebook, listTags, createTag, updateTag. The auth token is passed in the Thrift call parameters.",
        "tags": [
          "Notes"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-thrift": {
              "schema": {
                "type": "string",
                "format": "binary",
                "description": "Thrift binary-encoded NoteStore method call"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Thrift binary-encoded response"
          },
          "401": {
            "description": "Authentication failed"
          },
          "403": {
            "description": "Permission denied"
          }
        }
      }
    },
    "/edam/user": {
      "post": {
        "operationId": "userStoreCall",
        "summary": "UserStore Thrift RPC endpoint",
        "description": "All UserStore operations are invoked via Thrift binary protocol POST. Key operations: getUser, getPremiumInfo, checkVersion, getBootstrapInfo.",
        "tags": [
          "User"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-thrift": {
              "schema": {
                "type": "string",
                "format": "binary",
                "description": "Thrift binary-encoded UserStore method call"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Thrift binary-encoded response"
          },
          "401": {
            "description": "Authentication failed"
          }
        }
      }
    },
    "/oauth": {
      "get": {
        "operationId": "oauthRequestToken",
        "summary": "OAuth request token",
        "description": "Initiates the OAuth 1.0a flow to obtain a request token for user authorization.",
        "tags": [
          "User"
        ],
        "parameters": [
          {
            "name": "oauth_consumer_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "oauth_signature",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "oauth_signature_method",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "oauth_timestamp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "oauth_nonce",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "oauth_callback",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OAuth request token response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth": {
        "type": "oauth2",
        "flows": {
          "implicit": {
            "authorizationUrl": "https://example.com/oauth/authorize",
            "scopes": {}
          }
        }
      }
    }
  }
}
