  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API Key passed in the Authorization header"
      }
    },
    "schemas": {
      "HabitListResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Habit"
            }
          },
          "version": {
            "type": "string"
          },
          "status": {
            "type": "boolean"
          }
        }
      },
      "HabitSingleResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/Habit"
          },
          "version": {
            "type": "string"
          },
          "status": {
            "type": "boolean"
          }
        }
      },
      "Habit": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "is_archived": {
            "type": "boolean"
          },
          "start_date": {
            "type": "string",
            "format": "date-time"
          },
          "remind": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "time_of_day": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recurrence": {
            "type": "string",
            "description": "RRule string"
          },
          "created_date": {
            "type": "string",
            "format": "date-time"
          },
          "goal": {
            "$ref": "#/components/schemas/HabitGoal"
          },
          "goal_history_items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HabitGoal"
            }
          },
          "log_method": {
            "type": "string"
          },
          "priority": {
            "type": "number"
          },
          "area": {
            "$ref": "#/components/schemas/Area"
          }
        }
      },
      "HabitGoal": {
        "type": "object",
        "properties": {
          "unit_type": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "periodicity": {
            "type": "string"
          }
        }
      },
      "Area": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          }
        }
      },
      "LogListResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Log"
            }
          },
          "version": {
            "type": "string"
          },
          "status": {
            "type": "boolean"
          }
        }
      },
      "Log": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "created_date": {
            "type": "string",
            "format": "date-time"
          },
          "unit_type": {
            "type": "string"
          },
          "habit_id": {
            "type": "string"
          }
        }
      },
      "AddLogRequest": {
        "type": "object",
        "properties": {
          "unit_type": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "target_date": {
            "type": "string",
            "description": "Date format"
          }
        }
      },
      "NoteListResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Note"
            }
          },
          "version": {
            "type": "string"
          },
          "status": {
            "type": "boolean"
          }
        }
      },
      "Note": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "created_date": {
            "type": "string",
            "format": "date-time"
          },
          "image_url": {
            "type": "string",
            "nullable": true
          },
          "note_type": {
            "type": "integer"
          },
          "habit_id": {
            "type": "string"
          }
        }
      },
      "AddNoteRequest": {
        "type": "object",
        "properties": {
          "created": {
            "type": "string",
            "description": "Date format"
          },
          "content": {
            "type": "string"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "nullable": true
          },
          "version": {
            "type": "string"
          },
          "status": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "nullable": true
          },
          "version": {
            "type": "string"
          },
          "status": {
            "type": "boolean",
            "example": false
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Habits"
    },
    {
      "name": "Logs"
    },
    {
      "name": "Notes"
    }
  ]
}
