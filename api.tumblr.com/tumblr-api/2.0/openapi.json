            }
          }
        ],
        "responses": {
          "200": {
            "description": "Blog info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/Meta"
                    },
                    "response": {
                      "type": "object",
                      "properties": {
                        "blog": {
                          "$ref": "#/components/schemas/Blog"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get blog info",
        "tags": [
          "blog"
        ]
      }
    },
    "/blog/{blog-identifier}/posts": {
      "get": {
        "operationId": "getBlogPosts",
        "summary": "Get published posts",
        "parameters": [
          {
            "name": "blog-identifier",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "text",
                "quote",
                "link",
                "answer",
                "video",
                "audio",
                "photo",
                "chat"
              ]
            }
          },
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "reblog_info",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "notes_info",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Response format filter",
            "schema": {
              "type": "string",
              "enum": [
                "text",
                "raw"
              ]
            }
          },
          {
            "name": "before",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Blog posts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/Meta"
                    },
                    "response": {
                      "type": "object",
                      "properties": {
                        "blog": {
                          "$ref": "#/components/schemas/Blog"
                        },
                        "posts": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Post"
                          }
                        },
                        "total_posts": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
