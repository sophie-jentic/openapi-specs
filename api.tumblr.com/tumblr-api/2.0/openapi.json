                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get blogs the user is following",
        "tags": [
          "user"
        ]
      }
    },
    "/user/follow": {
      "post": {
        "operationId": "followBlog",
        "summary": "Follow a blog",
        "security": [
          {
            "oauth2": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "URL of the blog to follow"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Blog followed"
          },
          "404": {
            "description": "Blog not found"
          }
        },
        "description": "Follow a blog",
        "tags": [
          "user"
        ]
      }
    },
    "/user/unfollow": {
