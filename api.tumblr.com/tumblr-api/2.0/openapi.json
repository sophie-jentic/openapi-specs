    "/blog/{blog-identifier}/post": {
      "post": {
        "operationId": "createPost",
        "summary": "Create a new blog post",
        "security": [
          {
            "oauth2": []
          }
        ],
        "parameters": [
          {
            "name": "blog-identifier",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "text",
                      "photo",
                      "quote",
                      "link",
                      "chat",
                      "audio",
                      "video"
                    ]
                  },
                  "state": {
                    "type": "string",
                    "enum": [
                      "published",
                      "draft",
                      "queue",
                      "private"
                    ]
                  },
                  "tags": {
                    "type": "string",
                    "description": "Comma-separated tags"
                  },
                  "tweet": {
                    "type": "string"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "html",
                      "markdown"
                    ]
                  },
                  "slug": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string"
                  },
                  "caption": {
                    "type": "string"
                  },
                  "source": {
                    "type": "string"
                  },
                  "quote": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Post created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/Meta"
                    },
                    "response": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Create a new blog post",
        "tags": [
          "blog"
        ]
      }
    },
