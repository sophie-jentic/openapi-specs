{
  "openapi": "3.0.3",
  "info": {
    "title": "Tumblr API",
    "description": "The Tumblr API v2 provides access to blog content, posts, followers, likes, and user information. Supports creating, editing, and deleting posts, as well as following and unfollowing blogs.",
    "version": "2.0",
    "contact": {
      "name": "Tumblr API",
      "url": "https://www.tumblr.com/docs/en/api/v2"
    },
    "license": {
      "name": "Tumblr Terms of Service",
      "url": "https://www.tumblr.com/policy/en/terms-of-service"
    }
  },
  "externalDocs": {
    "description": "Tumblr API v2 Documentation",
    "url": "https://www.tumblr.com/docs/en/api/v2"
  },
  "servers": [
    {
      "url": "https://api.tumblr.com/v2",
      "description": "Tumblr API v2"
    }
  ],
  "security": [
    {
      "oauth2": []
    },
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/user/info": {
      "get": {
        "operationId": "getUserInfo",
        "summary": "Get the authenticated user's info",
        "security": [
          {
            "oauth2": []
          }
        ],
        "responses": {
          "200": {
            "description": "User info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/Meta"
                    },
                    "response": {
                      "type": "object",
                      "properties": {
                        "user": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get the authenticated user's info",
        "tags": [
          "user"
        ]
      }
    },
    "/user/dashboard": {
      "get": {
        "operationId": "getUserDashboard",
        "summary": "Get the user's dashboard",
        "security": [
          {
            "oauth2": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results (1-20, default 20)",
            "schema": {
              "type": "integer",
              "maximum": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Post number to start at",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Post type to filter",
            "schema": {
              "type": "string",
              "enum": [
                "text",
                "photo",
                "quote",
                "link",
                "chat",
                "audio",
                "video",
                "answer"
              ]
            }
          },
          {
            "name": "since_id",
            "in": "query",
            "description": "Return posts after this ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "reblog_info",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "notes_info",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Dashboard posts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/Meta"
                    },
                    "response": {
                      "type": "object",
                      "properties": {
                        "posts": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Post"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get the user's dashboard",
        "tags": [
          "user"
        ]
      }
    },
    "/user/likes": {
      "get": {
        "operationId": "getUserLikes",
        "summary": "Get the user's liked posts",
        "security": [
          {
            "oauth2": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "before",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "after",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Liked posts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/Meta"
                    },
                    "response": {
                      "type": "object",
                      "properties": {
                        "liked_posts": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Post"
                          }
                        },
                        "liked_count": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get the user's liked posts",
        "tags": [
          "user"
        ]
      }
    },
