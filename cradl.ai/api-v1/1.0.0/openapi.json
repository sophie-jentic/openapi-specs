{
  "openapi": "3.0.3",
  "info": {
    "title": "Cradl AI API",
    "description": "Build AI agents to automate document workflows. The Cradl AI API provides endpoints for managing agents, documents, runs, models, and predictions with human-in-the-loop capabilities.",
    "version": "1.0.0",
    "contact": {
      "name": "Cradl AI Support",
      "url": "https://docs.cradl.ai"
    }
  },
  "servers": [
    {
      "url": "https://api.cradl.ai/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "oauth2ClientCredentials": []
    }
  ],
  "paths": {
    "/agents": {
      "get": {
        "summary": "List Agents",
        "description": "Retrieve all available agents for your organization",
        "operationId": "listAgents",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "agents": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Agent"
                      }
                    },
                    "nextToken": {
                      "type": "string",
                      "nullable": true,
                      "description": "Pagination token for retrieving next page"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "agents"
        ]
      }
    },
    "/agents/{agentId}/runs": {
      "post": {
        "summary": "Create Run",
        "description": "Initialize a new processing run for an agent",
        "operationId": "createRun",
        "parameters": [
          {
            "name": "agentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the agent"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "variables": {
                    "type": "object",
                    "description": "Optional metadata variables for the run",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Run created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Run"
                }
              }
            }
          }
        },
        "tags": [
          "agents"
        ]
      }
    },
    "/documents": {
      "post": {
        "summary": "Create Document",
        "description": "Create and associate a document with an agent run",
        "operationId": "createDocument",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "agentRunId"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Name of the document"
                  },
                  "agentRunId": {
                    "type": "string",
                    "description": "ID of the agent run to associate with this document"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Document"
                }
              }
            }
          }
        },
        "tags": [
          "documents"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Agent": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "description": "Unique identifier for the agent"
          },
          "name": {
            "type": "string",
            "description": "Name of the agent"
          }
        }
      },
      "Run": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Run ID formatted as {orgId}/{agentId}/{runId}"
          },
          "agentId": {
            "type": "string",
            "description": "ID of the associated agent"
          },
          "variables": {
            "type": "object",
            "description": "Metadata variables for the run",
            "additionalProperties": true
          }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the document"
          },
          "name": {
            "type": "string",
            "description": "Name of the document"
          },
          "agentRunId": {
            "type": "string",
            "description": "ID of the associated agent run"
          },
          "fileUrl": {
            "type": "string",
            "format": "uri",
            "description": "Presigned URL for uploading the document file"
          }
        }
      }
    },
    "securitySchemes": {
      "oauth2ClientCredentials": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://auth.cradl.ai/oauth2/token",
            "scopes": {},
            "x-audience": "https://api.cradl.ai/v1"
          }
        },
        "description": "OAuth2 client credentials flow. Use grant_type=client_credentials with audience=https://api.cradl.ai/v1"
      }
    }
  },
  "tags": [
    {
      "name": "agents"
    },
    {
      "name": "documents"
    }
  ]
}
