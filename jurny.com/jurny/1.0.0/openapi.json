{
  "openapi": "3.0.3",
  "info": {
    "title": "Jurny API",
    "version": "1.0.0",
    "description": "Jurny API for vacation rental and property management. Manage properties, bookings, guests, and automation workflows.",
    "x-jentic-source-url": "https://devmos.jurny.com/api/doc/host#/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.jurny.com/v1"
    }
  ],
  "security": [
    {
      "ApiKey": []
    }
  ],
  "components": {
    "schemas": {
      "PropertyRequest": {
        "type": "object",
        "required": [
          "name",
          "address"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "bedrooms": {
            "type": "integer"
          },
          "bathrooms": {
            "type": "number"
          },
          "max_guests": {
            "type": "integer"
          },
          "amenities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "PropertyResponse": {
        "type": "object",
        "properties": {
          "property_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ReservationRequest": {
        "type": "object",
        "required": [
          "property_id",
          "check_in",
          "check_out",
          "guest_name"
        ],
        "properties": {
          "property_id": {
            "type": "string"
          },
          "check_in": {
            "type": "string",
            "format": "date"
          },
          "check_out": {
            "type": "string",
            "format": "date"
          },
          "guest_name": {
            "type": "string"
          },
          "guest_email": {
            "type": "string",
            "format": "email"
          },
          "guest_phone": {
            "type": "string"
          },
          "guests": {
            "type": "integer"
          }
        }
      },
      "ReservationResponse": {
        "type": "object",
        "properties": {
          "reservation_id": {
            "type": "string"
          },
          "property_id": {
            "type": "string"
          },
          "check_in": {
            "type": "string",
            "format": "date"
          },
          "check_out": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "GuestResponse": {
        "type": "object",
        "properties": {
          "guest_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "paths": {
    "/properties": {
      "post": {
        "summary": "Create property",
        "description": "Add a new property to the system",
        "operationId": "createProperty",
        "tags": [
          "Properties"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PropertyRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Property created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PropertyResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List properties",
        "description": "Get a list of all properties",
        "operationId": "listProperties",
        "tags": [
          "Properties"
        ],
        "responses": {
          "200": {
            "description": "List of properties",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PropertyResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/properties/{property_id}": {
      "get": {
        "summary": "Get property",
        "description": "Retrieve details of a specific property",
        "operationId": "getProperty",
        "tags": [
          "Properties"
        ],
        "parameters": [
          {
            "name": "property_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Property details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PropertyResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reservations": {
      "post": {
        "summary": "Create reservation",
        "description": "Create a new reservation for a property",
        "operationId": "createReservation",
        "tags": [
          "Reservations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReservationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reservation created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReservationResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List reservations",
        "description": "Get a list of reservations",
        "operationId": "listReservations",
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "name": "property_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of reservations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReservationResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/guests/{guest_id}": {
      "get": {
        "summary": "Get guest",
        "description": "Retrieve guest information",
        "operationId": "getGuest",
        "tags": [
          "Guests"
        ],
        "parameters": [
          {
            "name": "guest_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Guest details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GuestResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Properties",
      "description": "Property management"
    },
    {
      "name": "Reservations",
      "description": "Reservation management"
    },
    {
      "name": "Guests",
      "description": "Guest management"
    }
  ]
}
