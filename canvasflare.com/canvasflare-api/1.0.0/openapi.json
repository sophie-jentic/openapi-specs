{
  "openapi": "3.0.3",
  "info": {
    "title": "Canvasflare API",
    "version": "1.0.0",
    "description": "Canvasflare API for rendering HTML to images, taking webpage screenshots, and managing generated images.",
    "x-jentic-source-url": "https://docs.canvasflare.com",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.canvasflare.com"
    }
  ],
  "paths": {
    "/render": {
      "post": {
        "operationId": "renderImage",
        "summary": "Render image from HTML",
        "description": "Generate an image from HTML content with customizable rendering options.",
        "tags": [
          "Rendering"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RenderInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image rendered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded"
          },
          "500": {
            "description": "Server error"
          },
          "503": {
            "description": "Service unavailable"
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/screenshot": {
      "get": {
        "operationId": "screenshotUrl",
        "summary": "Screenshot a URL",
        "description": "Generate a screenshot of a public webpage.",
        "tags": [
          "Rendering"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "Complete webpage URL",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "css",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "png",
                "jpeg",
                "jpg",
                "webp",
                "gif",
                "jp2",
                "tiff",
                "avif",
                "heif"
              ],
              "default": "png"
            }
          },
          {
            "name": "viewport_width",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1920
            }
          },
          {
            "name": "viewport_height",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1080
            }
          },
          {
            "name": "device_scale",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3,
              "default": 2
            }
          },
          {
            "name": "viewport_device",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "full_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "selector",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ms_delay",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "user_agent",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "image_quality",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 80
            }
          },
          {
            "name": "image_width",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "image_height",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "viewport_mobile",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "viewport_landscape",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "viewport_has_touch",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Screenshot taken",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded"
          },
          "500": {
            "description": "Server error"
          },
          "503": {
            "description": "Service unavailable"
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/image/{id}": {
      "get": {
        "operationId": "getImage",
        "summary": "Get image by ID",
        "description": "Returns the URL of an image by its ID.",
        "tags": [
          "Images"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dl",
            "in": "query",
            "required": false,
            "description": "Make image URL downloadable by browser",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Image URL",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "image_url": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Image not found"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteImage",
        "summary": "Delete image",
        "description": "Remove an image from the system.",
        "tags": [
          "Images"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Image deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "image": {
                      "type": "string"
                    },
                    "status": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Image not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "RenderInput": {
        "type": "object",
        "required": [
          "html"
        ],
        "properties": {
          "html": {
            "type": "string",
            "description": "HTML content to render"
          },
          "css": {
            "type": "string"
          },
          "format": {
            "type": "string",
            "enum": [
              "png",
              "jpeg",
              "jpg",
              "webp",
              "gif",
              "jp2",
              "tiff",
              "avif",
              "heif"
            ]
          },
          "viewport_width": {
            "type": "integer",
            "default": 1920
          },
          "viewport_height": {
            "type": "integer",
            "default": 1080
          },
          "device_scale": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3,
            "default": 1
          },
          "viewport_device": {
            "type": "string"
          },
          "full_page": {
            "type": "boolean",
            "default": false
          },
          "selector": {
            "type": "string"
          },
          "ms_delay": {
            "type": "integer",
            "default": 100
          },
          "image_quality": {
            "type": "integer",
            "default": 80
          },
          "image_width": {
            "type": "integer"
          },
          "image_height": {
            "type": "integer"
          },
          "user_agent": {
            "type": "string"
          },
          "viewport_mobile": {
            "type": "boolean"
          },
          "viewport_landscape": {
            "type": "boolean"
          },
          "viewport_has_touch": {
            "type": "boolean"
          }
        }
      },
      "ImageResponse": {
        "type": "object",
        "properties": {
          "imageUrl": {
            "type": "string",
            "description": "URL of the generated image"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "statusCode": {
            "type": "integer"
          },
          "code": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Images"
    },
    {
      "name": "Rendering"
    }
  ]
}
