  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token API key"
      }
    },
    "schemas": {
      "Offer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "auto_process": {
            "type": "boolean"
          },
          "currency": {
            "type": "string"
          },
          "down_payment": {
            "type": "number"
          },
          "down_payment_type": {
            "type": "string",
            "enum": [
              "percent",
              "fixed"
            ]
          },
          "down_payment_flexible": {
            "type": "boolean"
          },
          "down_payment_min": {
            "type": "number",
            "nullable": true
          },
          "down_payment_max": {
            "type": "number",
            "nullable": true
          },
          "term": {
            "type": "integer"
          },
          "term_units": {
            "type": "string"
          },
          "term_flexible": {
            "type": "boolean"
          },
          "term_min": {
            "type": "integer"
          },
          "term_max": {
            "type": "integer"
          },
          "term_date": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "frequency": {
            "type": "integer"
          },
          "frequency_units": {
            "type": "string"
          },
          "frequency_flexible": {
            "type": "boolean"
          },
          "frequency_min": {
            "type": "integer",
            "nullable": true
          },
          "frequency_max": {
            "type": "integer",
            "nullable": true
          },
          "frequency_days": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "payment_schedule_description": {
            "type": "string",
            "nullable": true
          },
          "merchant_id": {
            "type": "string",
            "format": "uuid"
          },
          "integration_options": {
            "nullable": true
          },
          "require_ship_to": {
            "nullable": true
          },
          "inserted_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OfferCreateRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "auto_process": {
            "type": "boolean"
          },
          "payment_schedule_description": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "down_payment": {
            "type": "number"
          },
