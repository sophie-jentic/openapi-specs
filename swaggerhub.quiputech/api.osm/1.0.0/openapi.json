{
  "swagger": "2.0",
  "info": {
    "description": "Order and Service Management",
    "version": "1.0.0",
    "title": "OSM API",
    "contact": {
      "email": "info@quiputech.com"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/quiputech/api.osm/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "operation",
      "description": "Operations related calls"
    }
  ],
  "paths": {
    "/v1/order/{orderId}": {
      "get": {
        "tags": [
          "operation"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "description": "Order Id to retrieve",
            "required": true,
            "type": "string"
          }
        ],
        "summary": "request order execution",
        "responses": {
          "200": {
            "description": "Order retrieved",
            "schema": {
              "$ref": "#/definitions/OrderResponse"
            }
          },
          "404": {
            "description": "Order not found"
          }
        },
        "description": "request order execution",
        "operationId": "get-v1-order-by-orderid"
      }
    },
    "/v1/order": {
      "post": {
        "tags": [
          "operation"
        ],
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "orderRequest",
            "description": "Order request to execute",
            "schema": {
              "$ref": "#/definitions/OrderRequest"
            }
          },
          {
            "in": "header",
            "type": "string",
            "name": "Security-Token",
            "required": true
          }
        ],
        "summary": "request order execution",
        "responses": {
          "200": {
            "description": "Successful operation",
            "schema": {
              "$ref": "#/definitions/OrderResponse"
            }
          },
          "400": {
            "description": "Unsuccessful operation",
            "schema": {
              "$ref": "#/definitions/OrderResponse"
            }
          }
        },
        "description": "request order execution",
        "operationId": "post-v1-order"
      }
    }
  },
  "definitions": {
    "Header": {
      "type": "object",
      "properties": {
        "errorCode": {
          "type": "integer",
          "example": 0,
          "description": "Transaction error code. 0 means OK, anything different is an error code.\n"
        },
        "errorMessage": {
          "type": "string",
          "example": "Order executed successfully",
          "description": "Transaction execution message.\n"
        },
        "transactionUUID": {
          "type": "string",
          "example": "212f34c6-cf79-4906-943e-659e965d3f2b"
        },
        "millis": {
          "type": "integer",
          "example": 250
        }
      }
    },
    "Order": {
      "type": "object",
      "required": [
        "orderId",
        "status"
      ],
      "properties": {
        "orderId": {
          "type": "string",
          "example": "XA-213431231"
        },
        "status": {
          "type": "string",
          "example": "FULFILLED",
          "enum": [
            "FULFILLED",
            "SCHEDULED",
            "RUNNING",
            "ABORTED",
            "CANCELED"
          ]
        },
        "scheduledExecutionDate": {
          "type": "string",
          "format": "date-time"
        },
        "executionDate": {
          "type": "string",
          "format": "date-time"
        },
        "dataMap": {
          "$ref": "#/definitions/DataMap"
        }
      }
    },
    "DataMap": {
      "type": "object",
      "description": "Map<String, Object> of different parameters to exchange between parties. Every transaction expects and defines different set of parameters.\n",
      "properties": {
        "toNumber": {
          "type": "string",
          "example": "+51994336911",
          "description": "For recharge request"
        },
        "currency": {
          "type": "string",
          "example": "PEN",
          "description": "For recharge request"
        },
        "amount": {
          "type": "string",
          "example": "10.0",
          "description": "For recharge request"
        },
        "rechargeId": {
          "type": "string",
          "example": "UV1232-1212-AF-212",
          "description": "For recharge response"
        },
        "remainingBalance": {
          "type": "string",
          "example": "145.00",
          "description": "For recharge response"
        }
      },
      "additionalProperties": {
        "type": "object",
        "description": "Any parameter defined that needs to be exchanged in transaction\n"
      }
    },
    "OrderRequest": {
      "type": "object",
      "properties": {
        "merchantId": {
          "type": "string",
          "example": "123456789"
        },
        "channel": {
          "type": "string",
          "example": "ONLINE",
          "enum": [
            "ONLINE"
          ]
        },
        "externalTransactionId": {
          "type": "string",
          "example": "f6489f0c-0ef8-4f5a-a5c9-a832fbb07c69"
        },
        "target": {
          "type": "string",
          "example": "telefonica"
        },
        "action": {
          "type": "string",
          "example": "recharge"
        },
        "dataMap": {
          "$ref": "#/definitions/DataMap"
        }
      }
    },
    "OrderResponse": {
      "type": "object",
      "properties": {
        "header": {
          "$ref": "#/definitions/Header"
        },
        "order": {
          "$ref": "#/definitions/Order"
        }
      }
    }
  },
  "host": "virtserver.swaggerhub.com",
  "basePath": "/quiputech/api.osm/1.0.0",
  "schemes": [
    "https"
  ]
}
