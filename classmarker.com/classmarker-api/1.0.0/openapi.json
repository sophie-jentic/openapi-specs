              "type": "string"
            },
            "description": "The unique identifier of the question."
          },
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/signature"
          },
          {
            "$ref": "#/components/parameters/timestamp"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with question details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v1"
        ]
      },
      "put": {
        "operationId": "updateQuestion",
        "summary": "Update Question",
        "description": "Updates an existing question. Supported types: multiple choice, multiple response, true/false, essay.",
        "parameters": [
          {
            "name": "question_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique identifier of the question."
          },
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/signature"
          },
          {
            "$ref": "#/components/parameters/timestamp"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuestionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Question updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v1"
        ]
      }
    }
  },
  "components": {
    "parameters": {
      "apiKey": {
        "name": "api_key",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Your unique API key."
      },
      "signature": {
        "name": "signature",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "SHA256 hash of (api_key + api_secret + timestamp), lowercase."
      },
      "timestamp": {
        "name": "timestamp",
        "in": "query",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "Current UNIX timestamp in seconds. Must be within a 5-minute variance window."
      },
      "finishedAfterTimestamp": {
        "name": "finishedAfterTimestamp",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer"
        },
        "description": "UNIX timestamp to retrieve results finished after this time. Default is 2 weeks ago; minimum is 3 months ago."
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 200
        },
        "description": "Maximum number of results to return per request."
      }
    },
    "schemas": {
      "StandardResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "no_results",
              "error"
            ],
            "description": "Response status."
          },
          "request_path": {
            "type": "string",
            "description": "Echo of the requested path."
          },
          "server_timestamp": {
            "type": "integer",
            "description": "ClassMarker server timestamp."
          }
        }
      },
      "GroupsLinksExamsResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/StandardResponse"
          },
          {
            "type": "object",
            "properties": {
              "groups": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "links": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          }
        ]
      },
      "GroupResultsResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/StandardResponse"
          },
          {
            "type": "object",
            "properties": {
              "finished_after_timestamp_used": {
                "type": "integer",
                "description": "Echo of the finishedAfterTimestamp used."
              },
              "next_finished_after_timestamp": {
                "type": "integer",
                "description": "Use this value as finishedAfterTimestamp in the next request to get subsequent results."
              },
              "results": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/GroupResult"
                }
              }
            }
          }
        ]
      },
      "LinkResultsResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/StandardResponse"
          },
          {
            "type": "object",
            "properties": {
              "finished_after_timestamp_used": {
                "type": "integer"
              },
              "next_finished_after_timestamp": {
                "type": "integer"
              },
              "results": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/LinkResult"
                }
              }
            }
          }
        ]
      },
      "GroupResult": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string"
          },
          "first": {
            "type": "string",
            "description": "First name."
          },
          "last": {
            "type": "string",
            "description": "Last name."
          },
          "email": {
            "type": "string"
          },
          "test_id": {
            "type": "string"
          },
          "group_id": {
            "type": "string"
          },
          "percentage": {
            "type": "number"
          },
          "points_scored": {
            "type": "number"
          },
          "points_available": {
            "type": "number"
          },
          "time_started": {
            "type": "integer",
            "description": "UNIX timestamp when the test was started."
          },
          "time_finished": {
            "type": "integer",
            "description": "UNIX timestamp when the test was finished."
          },
          "status": {
            "type": "string"
          },
          "duration": {
            "type": "integer",
            "description": "Duration in seconds."
          },
          "percentage_passmark": {
            "type": "number"
          },
          "passed": {
            "type": "boolean"
          },
          "requires_grading": {
            "type": "boolean"
          },
          "certificate_url": {
            "type": "string"
          },
          "certificate_serial": {
            "type": "string"
          },
          "view_results_url": {
            "type": "string"
          },
          "test_type": {
            "type": "string"
          },
          "monitor_events": {
            "$ref": "#/components/schemas/MonitorEvents"
          }
        }
      },
      "LinkResult": {
        "allOf": [
          {
            "$ref": "#/components/schemas/GroupResult"
          },
          {
            "type": "object",
            "properties": {
              "link_id": {
