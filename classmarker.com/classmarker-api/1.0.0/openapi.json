                }
              }
            }
          }
        },
        "tags": [
          "v1"
        ]
      }
    },
    "/v1/accesslists/{access_list_id}.json": {
      "post": {
        "operationId": "addAccessListCodes",
        "summary": "Add Access List Codes",
        "description": "Adds access codes to an access list. Maximum 100 codes per request, up to 20,000 total codes per list, each up to 255 characters.",
        "parameters": [
          {
            "name": "access_list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique identifier of the access list."
          },
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/signature"
          },
          {
            "$ref": "#/components/parameters/timestamp"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "maxItems": 100,
                "description": "Array of access codes to add."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access codes added successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v1"
        ]
      },
      "delete": {
        "operationId": "deleteAccessListCodes",
        "summary": "Delete Access List Codes",
        "description": "Deletes access codes from an access list. Maximum 100 codes per request.",
        "parameters": [
          {
            "name": "access_list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique identifier of the access list."
          },
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/signature"
          },
          {
            "$ref": "#/components/parameters/timestamp"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "maxItems": 100,
                "description": "Array of access codes to delete."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access codes deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v1"
        ]
      }
    },
    "/v1/categories.json": {
      "get": {
        "operationId": "getCategories",
        "summary": "Get All Categories",
