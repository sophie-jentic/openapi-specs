    },
    "/v1/questions.json": {
      "get": {
        "operationId": "getQuestions",
        "summary": "Get All Questions",
        "description": "Retrieves all questions, paginated at 200 per page.",
        "parameters": [
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/signature"
          },
          {
            "$ref": "#/components/parameters/timestamp"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with questions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v1"
        ]
      },
      "post": {
        "operationId": "createQuestion",
        "summary": "Create Question",
        "description": "Creates a new question. Supported types: multiple choice, multiple response, true/false, essay.",
        "parameters": [
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/signature"
          },
          {
            "$ref": "#/components/parameters/timestamp"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuestionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Question created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v1"
        ]
      }
    },
    "/v1/questions/{question_id}.json": {
      "get": {
        "operationId": "getQuestion",
        "summary": "Get Question",
        "description": "Retrieves a specific question by its identifier.",
