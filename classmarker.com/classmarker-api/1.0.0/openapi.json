          {
            "$ref": "#/components/parameters/signature"
          },
          {
            "$ref": "#/components/parameters/timestamp"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "New name for the parent category."
                  },
                  "verify_only": {
                    "type": "boolean",
                    "description": "If true, validates the request without updating."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Parent category updated or validated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v1"
        ]
      }
    },
    "/v1/categories/category.json": {
      "post": {
        "operationId": "createSubCategory",
        "summary": "Create Sub-Category",
        "description": "Creates a new sub-category under a parent category.",
        "parameters": [
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/signature"
          },
          {
            "$ref": "#/components/parameters/timestamp"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Name of the sub-category."
                  },
                  "parent_category_id": {
                    "type": "string",
                    "description": "ID of the parent category."
                  },
                  "verify_only": {
                    "type": "boolean",
                    "description": "If true, validates the request without creating."
                  }
                },
                "required": [
                  "name",
                  "parent_category_id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sub-category created or validated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v1"
        ]
      }
    },
    "/v1/category/{id}.json": {
      "put": {
        "operationId": "updateSubCategory",
