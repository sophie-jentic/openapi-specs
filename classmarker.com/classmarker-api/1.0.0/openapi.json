{
  "openapi": "3.0.3",
  "info": {
    "title": "ClassMarker API",
    "description": "ClassMarker API for managing online tests, quizzes, groups, links, results, access lists, categories, and question banks. ClassMarker is an online testing platform that provides quiz and exam creation with detailed result reporting.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.classmarker.com/online-testing/docs/api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.classmarker.com",
      "description": "ClassMarker API Server"
    }
  ],
  "paths": {
    "/v1.json": {
      "get": {
        "operationId": "getGroupsLinksExams",
        "summary": "Get Groups, Links and Exams",
        "description": "Retrieves details of all groups, links and exams your API key has permissions to access.",
        "parameters": [
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/signature"
          },
          {
            "$ref": "#/components/parameters/timestamp"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with groups, links and exams.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GroupsLinksExamsResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v1.json"
        ]
      }
    },
    "/v1/groups/recent_results.json": {
      "get": {
        "operationId": "getGroupsRecentResults",
        "summary": "Get Recent Results for All Groups",
        "description": "Retrieves recent test results across all groups. Default timestamp is 2 weeks ago; minimum is 3 months old.",
        "parameters": [
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/signature"
          },
          {
            "$ref": "#/components/parameters/timestamp"
          },
          {
            "$ref": "#/components/parameters/finishedAfterTimestamp"
          },
          {
            "$ref": "#/components/parameters/limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with group results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GroupResultsResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v1"
        ]
      }
    },
    "/v1/groups/{group_id}/tests/{test_id}/recent_results.json": {
      "get": {
        "operationId": "getGroupTestRecentResults",
        "summary": "Get Recent Results for a Group Test",
        "description": "Retrieves recent test results for a specific test within a specific group.",
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique identifier of the group."
          },
          {
            "name": "test_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique identifier of the test."
          },
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "$ref": "#/components/parameters/signature"
          },
          {
            "$ref": "#/components/parameters/timestamp"
          },
          {
            "$ref": "#/components/parameters/finishedAfterTimestamp"
          },
          {
            "$ref": "#/components/parameters/limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with group test results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GroupResultsResponse"
                }
              }
            }
          }
        },
        "tags": [
          "v1"
        ]
      }
    },
    "/v1/links/recent_results.json": {
