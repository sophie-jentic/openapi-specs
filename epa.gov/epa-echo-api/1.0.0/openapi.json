  "components": {
    "schemas": {
      "FacilitySearchResponse": {
        "type": "object",
        "properties": {
          "Results": {
            "type": "object",
            "properties": {
              "Message": {
                "type": "string"
              },
              "TotalCount": {
                "type": "string"
              },
              "PageNo": {
                "type": "string"
              },
              "Facilities": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Facility"
                }
              }
            }
          }
        }
      },
      "Facility": {
        "type": "object",
        "properties": {
          "FacilityName": {
            "type": "string"
          },
          "RegistryId": {
            "type": "string"
