{
  "openapi": "3.0.3",
  "info": {
    "title": "EPA ECHO API",
    "version": "1.0.0",
    "description": "EPA's Enforcement and Compliance History Online (ECHO) provides REST web services for searching and retrieving environmental compliance and enforcement data for facilities regulated under the Clean Air Act, Clean Water Act, Safe Drinking Water Act, and Resource Conservation and Recovery Act. Services are query-only and require no authentication.",
    "x-jentic-source-url": "https://echo.epa.gov/tools/web-services",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://ofmpub.epa.gov/echo"
    }
  ],
  "paths": {
    "/echo_rest_services.get_facilities": {
      "get": {
        "operationId": "searchAllFacilities",
        "summary": "All Media Programs Facility Search",
        "description": "Search across all environmental program records for facilities. The most general facility search type.",
        "tags": [
          "Facility Search"
        ],
        "parameters": [
          {
            "name": "output",
            "in": "query",
            "required": false,
            "description": "Output format",
            "schema": {
              "type": "string",
              "enum": [
                "JSON",
                "XML",
                "JSONP"
              ],
              "default": "JSON"
            }
          },
          {
            "name": "p_fn",
            "in": "query",
            "required": false,
            "description": "Facility name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "p_sa",
            "in": "query",
            "required": false,
            "description": "Street address",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "p_ct",
            "in": "query",
            "required": false,
            "description": "City name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "p_st",
            "in": "query",
            "required": false,
            "description": "Two-letter state code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "p_zip",
            "in": "query",
            "required": false,
            "description": "Five-digit ZIP code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "p_fips",
            "in": "query",
            "required": false,
            "description": "FIPS county code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "p_tribal",
            "in": "query",
            "required": false,
            "description": "Tribal area flag",
            "schema": {
              "type": "string",
              "enum": [
                "Y",
                "N"
              ]
            }
          },
          {
            "name": "p_sic",
            "in": "query",
            "required": false,
            "description": "Standard Industrial Classification code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "p_naics",
            "in": "query",
            "required": false,
            "description": "NAICS code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "p_med",
            "in": "query",
            "required": false,
            "description": "Environmental media filter",
            "schema": {
              "type": "string",
              "enum": [
                "A",
                "C",
                "R",
                "W",
                "ALL"
              ]
            }
          },
          {
            "name": "p_qiv",
            "in": "query",
            "required": false,
            "description": "Quarter in violation filter",
            "schema": {
              "type": "string",
              "enum": [
                "0",
                "GT1",
                "GT2",
                "GT4",
                "GT8",
                "12"
              ]
            }
          },
          {
            "name": "p_pn",
            "in": "query",
            "required": false,
            "description": "Permit number",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "responseset",
            "in": "query",
            "required": false,
            "description": "Maximum number of records to return",
            "schema": {
              "type": "integer",
              "default": 1000
            }
          },
          {
            "name": "pageno",
            "in": "query",
            "required": false,
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "callback",
            "in": "query",
            "required": false,
            "description": "JSONP callback function name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Facility search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FacilitySearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
