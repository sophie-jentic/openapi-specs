  "components": {
    "schemas": {
      "ChatRequest": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "user_id": {
            "type": "string"
          },
          "channel": {
            "type": "string"
          }
        }
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "string"
          },
          "answer_type": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "blocks": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "AsyncChatResponse": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "RatingRequest": {
        "type": "object",
        "required": [
          "session_id",
          "message_id",
          "rating"
        ],
        "properties": {
          "session_id": {
            "type": "string"
          },
          "message_id": {
            "type": "string"
          },
          "rating": {
            "type": "string",
            "enum": [
              "thumbs_up",
              "thumbs_down"
            ]
          },
          "feedback": {
            "type": "string"
          }
        }
      },
      "ChatHistoryRequest": {
        "type": "object",
        "required": [
          "session_id"
        ],
        "properties": {
          "session_id": {
            "type": "string"
          }
        }
      },
      "ChatHistoryResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      },
      "ChatSessionsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "session_id": {
                  "type": "string"
                },
                "created_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key for Alltius platform."
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Chat"
    },
    {
      "name": "Reports"
    },
    {
      "name": "Webhooks"
    }
  ]
}
