    "/custom-fields": {
      "get": {
        "tags": ["Custom Fields"],
        "summary": "List custom fields",
        "description": "Retrieve all custom fields",
        "operationId": "listCustomFields",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
