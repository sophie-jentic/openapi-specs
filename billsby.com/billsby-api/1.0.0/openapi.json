  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key authentication. Add your API key from Settings > Configuration > API keys and webhooks"
      }
    },
    "schemas": {
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique customer identifier"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Customer email address"
          },
          "firstName": {
            "type": "string",
            "description": "Customer first name"
          },
          "lastName": {
            "type": "string",
            "description": "Customer last name"
          },
          "company": {
            "type": "string",
            "description": "Company name",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Customer creation timestamp"
          }
        }
      },
      "CustomerCreate": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Customer email address"
          },
          "firstName": {
            "type": "string",
            "description": "Customer first name"
          },
          "lastName": {
            "type": "string",
            "description": "Customer last name"
          },
          "company": {
            "type": "string",
            "description": "Company name",
            "nullable": true
          }
        }
      },
      "CustomerUpdate": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Customer email address"
          },
          "firstName": {
            "type": "string",
            "description": "Customer first name"
          },
          "lastName": {
            "type": "string",
            "description": "Customer last name"
          },
          "company": {
            "type": "string",
            "description": "Company name",
            "nullable": true
          }
        }
      },
      "Subscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique subscription identifier"
          },
          "customerId": {
            "type": "string",
            "description": "Associated customer ID"
          },
          "planId": {
            "type": "string",
            "description": "Current plan ID"
          },
          "status": {
            "type": "string",
            "enum": ["active", "cancelled", "expired", "paused"],
            "description": "Subscription status"
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "description": "Subscription start date"
          },
          "nextRenewalDate": {
            "type": "string",
            "format": "date",
            "description": "Next renewal date",
            "nullable": true
          }
        }
      },
      "SubscriptionCreate": {
        "type": "object",
        "required": ["planId", "customer"],
        "properties": {
          "planId": {
            "type": "string",
            "description": "Plan ID"
          },
          "customer": {
            "$ref": "#/components/schemas/CustomerCreate"
          }
        }
      },
      "Invoice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique invoice identifier"
          },
          "customerId": {
            "type": "string",
            "description": "Associated customer ID"
          },
          "amount": {
            "type": "number",
            "description": "Invoice amount"
          },
          "status": {
            "type": "string",
            "enum": ["paid", "unpaid", "refunded", "written_off"],
            "description": "Invoice status"
          },
          "dueDate": {
            "type": "string",
            "format": "date",
            "description": "Invoice due date"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Invoice creation timestamp"
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique product identifier"
          },
          "name": {
            "type": "string",
            "description": "Product name"
          },
          "description": {
            "type": "string",
            "description": "Product description",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Product creation timestamp"
          }
        }
      },
      "ProductCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Product name"
          },
          "description": {
            "type": "string",
            "description": "Product description",
            "nullable": true
          }
        }
      },
      "ProductUpdate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Product name"
          },
          "description": {
            "type": "string",
            "description": "Product description",
            "nullable": true
          }
        }
      },
      "Plan": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique plan identifier"
          },
          "productId": {
            "type": "string",
            "description": "Associated product ID"
          },
          "name": {
            "type": "string",
            "description": "Plan name"
          },
          "price": {
            "type": "number",
            "description": "Plan price"
          },
          "currency": {
            "type": "string",
            "description": "Currency code"
          }
        }
      },
      "PlanCreate": {
        "type": "object",
        "required": ["productId", "name", "price"],
        "properties": {
          "productId": {
            "type": "string",
            "description": "Associated product ID"
          },
          "name": {
            "type": "string",
            "description": "Plan name"
          },
          "price": {
            "type": "number",
            "description": "Plan price"
          },
          "currency": {
            "type": "string",
            "description": "Currency code",
            "default": "USD"
          }
        }
      },
      "CustomField": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique custom field identifier"
