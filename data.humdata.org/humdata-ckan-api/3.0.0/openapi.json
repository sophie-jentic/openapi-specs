                  "$ref": "#/components/schemas/CkanErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/action/package_search": {
      "get": {
        "operationId": "packageSearch",
        "summary": "Search Datasets",
        "description": "Search for datasets matching a query. Supports Solr query syntax for advanced filtering.",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Search query (Solr query syntax)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fq",
            "in": "query",
            "required": false,
            "description": "Filter query (e.g. tags:economy)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "Sort order (e.g. score desc, metadata_modified desc)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rows",
            "in": "query",
            "required": false,
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "Offset for pagination",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "facet.field",
            "in": "query",
            "required": false,
            "description": "JSON array of field names to facet on",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "facet.limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of facet values",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "include_private",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CkanSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CkanErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CkanErrorResponse"
                }
              }
            }
          }
        }
      }
    },
