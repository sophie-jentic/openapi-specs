{
  "openapi": "3.0.3",
  "info": {
    "title": "Humdata CKAN API",
    "version": "3.0.0",
    "description": "The Humanitarian Data Exchange (HDX) uses the CKAN Action API v3 to provide programmatic access to humanitarian datasets. CKAN's API exposes all core functionality including listing, searching, creating, updating, and deleting datasets (packages), resources, organizations, and groups. It follows an RPC-style pattern where all actions are called via POST or GET to /api/3/action/{action_name}.",
    "x-jentic-source-url": "https://data.humdata.org/api/3/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://data.humdata.org/api/3"
    }
  ],
  "paths": {
    "/action/package_list": {
      "get": {
        "operationId": "packageList",
        "summary": "List All Datasets",
        "description": "Returns a list of the names of all datasets (packages) on the site.",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of results to return",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Offset for pagination",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of dataset names",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CkanListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CkanErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CkanErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/action/package_show": {
      "get": {
        "operationId": "packageShow",
        "summary": "Get Dataset Details",
        "description": "Returns the full metadata and resource list for a single dataset.",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "Dataset name or ID",
            "schema": {
              "type": "string"
            }
