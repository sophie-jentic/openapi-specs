{
  "openapi": "3.0.3",
  "info": {
    "title": "Mindee OCR API",
    "description": "Mindee is a document processing and OCR API platform for parsing invoices, receipts, passports, and custom documents.",
    "version": "0.1.0",
    "contact": {
      "name": "Mindee",
      "url": "https://mindee.com"
    },
    "x-jentic-source-url": "https://api.mindee.net/openapi.json"
  },
  "servers": [
    {
      "url": "https://api.mindee.net",
      "description": "Mindee API"
    }
  ],
  "security": [
    {
      "HTTPBearer": []
    }
  ],
  "paths": {
    "/v1/products/{account}/{product}/{version}/predict": {
      "post": {
        "summary": "Predict (synchronous)",
        "description": "Submit a document for synchronous parsing and prediction.",
        "operationId": "predict",
        "tags": [
          "Prediction"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "path",
            "required": true,
            "description": "Account name or 'mindee'.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "product",
            "in": "path",
            "required": true,
            "description": "Product name.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "document": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            },
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "document": {
                    "type": "string",
                    "description": "Base64 or URL."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prediction result.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
