        "responses": {
          "204": {
            "description": "Cache cleared."
          }
        },
        "description": "Clear cache"
      }
    },
    "/internal/cache/tokens": {
      "put": {
        "summary": "Clear tokens cache",
        "operationId": "clearTokensCache",
        "tags": [
