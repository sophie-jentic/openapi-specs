          },
          "description": {
            "type": "string"
          },
          "connectionString": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "Policy": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "state": {
            "type": "string"
          }
        }
      },
      "PolicyListResponse": {
        "type": "object",
        "properties": {
          "hits": {
            "type": "array",
            "items": {
