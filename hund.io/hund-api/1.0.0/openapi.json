              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/issues/{issue_id}": {
      "get": {
        "operationId": "getIssue",
        "summary": "Retrieve issue",
        "tags": [
          "Issues"
        ],
        "parameters": [
          {
            "name": "issue_id",
