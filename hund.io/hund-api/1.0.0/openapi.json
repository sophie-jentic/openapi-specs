{
  "openapi": "3.0.3",
  "info": {
    "title": "Hund API",
    "version": "1.0.0",
    "description": "Status page monitoring and incident management API. Manage components, groups, issues, events, metric providers, watchdogs, and statuses.",
    "x-jentic-source-url": "https://hund.io/help/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.hund.io/v1"
    }
  ],
  "paths": {
    "/context": {
      "get": {
        "operationId": "getContext",
        "summary": "Retrieve context",
        "description": "Retrieve the current Context",
        "tags": [
          "Context"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Context"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateContext",
        "summary": "Update context",
        "description": "Update the current Context",
        "tags": [
          "Context"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Context"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/context/domain/retry_secure": {
      "put": {
        "operationId": "retryDomainSecure",
        "summary": "Retry domain certificate",
        "description": "Retry certificate issuance for custom domain",
        "tags": [
          "Context"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomDomain"
