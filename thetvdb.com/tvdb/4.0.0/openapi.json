{
  "openapi": "3.0.3",
  "info": {
    "title": "TheTVDB API",
    "version": "4.0.0",
    "description": "TheTVDB API v4 for accessing television, movie, and people data.",
    "x-jentic-source-url": "https://thetvdb.com/api-information",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api4.thetvdb.com/v4"
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "operationId": "login",
        "summary": "Login",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "apikey": {
                    "type": "string"
                  }
                },
                "required": [
                  "apikey"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Login"
      }
    },
    "/search": {
      "get": {
        "operationId": "search",
        "summary": "Search",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "movie",
                "series",
                "person",
                "company"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/SearchResult"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Search"
      }
    },
    "/series/{id}": {
      "get": {
        "operationId": "getSeries",
        "summary": "Get series",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Series",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Series"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get series"
      }
    },
    "/series/{id}/episodes/default": {
      "get": {
        "operationId": "getSeriesEpisodes",
        "summary": "Get episodes",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "season",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Episodes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "episodes": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Episode"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get episodes"
      }
    },
    "/movies/{id}": {
      "get": {
        "operationId": "getMovie",
        "summary": "Get movie",
        "tags": [
          "Movies"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Movie",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/MovieDetail"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get movie"
      }
    },
    "/people/{id}": {
      "get": {
        "operationId": "getPerson",
        "summary": "Get person",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Person"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get person"
      }
    },
    "/episodes/{id}": {
      "get": {
        "operationId": "getEpisode",
        "summary": "Get episode",
        "tags": [
          "Episodes"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Episode",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Episode"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get episode"
      }
    },
    "/seasons/{id}": {
      "get": {
        "operationId": "getSeason",
        "summary": "Get season",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Season"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get season"
      }
    }
  },
  "components": {
    "schemas": {
      "Series": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "image": {
            "type": "string"
          },
          "firstAired": {
            "type": "string"
          },
          "lastAired": {
            "type": "string"
          },
          "status": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          },
          "overview": {
            "type": "string"
          },
          "year": {
            "type": "string"
          },
          "averageRuntime": {
            "type": "integer"
          }
        }
      },
      "Episode": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "seriesId": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "aired": {
            "type": "string"
          },
          "runtime": {
            "type": "integer"
          },
          "overview": {
            "type": "string"
          },
          "seasonNumber": {
            "type": "integer"
          },
          "number": {
            "type": "integer"
          },
          "image": {
            "type": "string"
          }
        }
      },
      "MovieDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "image": {
            "type": "string"
          },
          "year": {
            "type": "string"
          },
          "runtime": {
            "type": "integer"
          },
          "overview": {
            "type": "string"
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "objectID": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "year": {
            "type": "string"
          },
          "overview": {
            "type": "string"
          },
          "tvdb_id": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Search"
    },
    {
      "name": "Series"
    },
    {
      "name": "Movies"
    },
    {
      "name": "Episodes"
    },
    {
      "name": "People"
    }
  ]
}
