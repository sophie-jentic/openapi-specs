{
  "openapi": "3.0.3",
  "info": {
    "title": "Clockwork Recruiting API",
    "description": "Clockwork Recruiting is an executive search and recruiting platform. The API provides access to people, companies, positions, tags, regions, and webhook management. Authentication uses API key/secret pair with firm service key.",
    "version": "3.0",
    "x-jentic-source-url": "https://www.clockworkrecruiting.com/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.clockworkrecruiting.com/v3.0/{firmName}",
      "description": "Clockwork Recruiting API v3.0",
      "variables": {
        "firmName": {
          "default": "your-firm",
          "description": "Your firm name as registered with Clockwork Recruiting"
        }
      }
    }
  ],
  "security": [
    {
      "tokenAuth": [],
      "apiKeyHeader": []
    }
  ],
  "paths": {
    "/people": {
      "get": {
        "operationId": "listPeople",
        "summary": "List people",
        "description": "Retrieve a paginated list of people (candidates).",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25
            },
            "description": "Number of results per page"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of people",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "people": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Person"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPerson",
        "summary": "Create a person",
        "description": "Create a new person (candidate) record.",
        "tags": [
          "People"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PersonCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Person created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Person"
                }
              }
            }
          }
        }
      }
    },
    "/people/{personId}": {
      "get": {
        "operationId": "getPerson",
        "summary": "Get a person",
        "description": "Retrieve a specific person by ID.",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "personId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Person ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Person details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Person"
                }
              }
            }
          }
        }
      }
    },
    "/people/{personId}/tags": {
      "post": {
        "operationId": "addPersonTag",
        "summary": "Add tag to a person",
        "description": "Add one or more tags to a person.",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "personId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Person ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tag_names": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Tag names to add"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tags added successfully"
          }
        }
      }
    },
    "/people/{personId}/addresses": {
      "post": {
        "operationId": "createPersonAddress",
        "summary": "Add address to a person",
        "description": "Add a new address to a person.",
