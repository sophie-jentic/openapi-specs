        "parameters": [
          {
            "name": "personId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Person ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddressCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Address created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Address"
                }
              }
            }
          }
        }
      }
    },
    "/people/{personId}/email_addresses": {
      "post": {
        "operationId": "createPersonEmail",
        "summary": "Add email to a person",
        "description": "Add a new email address to a person.",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "personId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Person ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email_address"
                ],
                "properties": {
                  "email_address": {
                    "type": "string",
                    "format": "email"
                  },
                  "label": {
                    "type": "string",
                    "description": "Label for the email (e.g., work, personal)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Email address added successfully"
          }
        }
      }
    },
    "/people/{personId}/phone_numbers": {
      "post": {
        "operationId": "createPersonPhoneNumber",
