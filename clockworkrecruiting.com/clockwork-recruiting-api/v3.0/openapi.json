            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "LinkedIn profile URL"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "LinkedIn URL added successfully"
          }
        }
      }
    },
    "/people/{personId}/positions": {
      "post": {
        "operationId": "createPersonPosition",
        "summary": "Add position to a person",
