        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "personId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Person ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phone_number"
                ],
                "properties": {
                  "phone_number": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string",
                    "description": "Label for the phone number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Phone number added successfully"
          }
        }
      }
    },
    "/people/{personId}/linkedin_urls": {
      "post": {
        "operationId": "createPersonLinkedIn",
        "summary": "Add LinkedIn URL to a person",
