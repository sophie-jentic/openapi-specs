  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ContactInput": {
        "type": "object",
        "required": [
          "primaryEmail"
        ],
        "properties": {
          "primaryEmail": {
            "type": "string",
            "format": "email"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "isSolicitation": {
            "type": "boolean"
          },
          "subscriptionStatus": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "birthDate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "TransactionInput": {
        "type": "object",
        "required": [
          "amount",
          "paidAt",
          "paymentMethod"
        ],
        "properties": {
          "amount": {
            "type": "number"
          },
          "paidAt": {
            "type": "string",
            "format": "date-time"
          },
          "paymentMethod": {
            "type": "string"
          },
          "campaignId": {
            "type": "string"
          },
          "impactAreaId": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://usa.keela.co/oauth/authorize",
            "tokenUrl": "https://usa.keela.co/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "Campaigns"
    },
    {
