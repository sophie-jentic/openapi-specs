{
  "openapi": "3.0.3",
  "info": {
    "title": "CurrencyAPI",
    "version": "3.0.0",
    "description": "CurrencyAPI provides reliable exchange rates and currency conversion. Delivers JSON data for latest and historical exchange rates, currency conversion, and a list of supported currencies.",
    "x-jentic-source-url": "https://currencyapi.com/docs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.currencyapi.com/v3",
      "description": "CurrencyAPI v3 Production"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Exchange Rates",
      "description": "Latest and historical exchange rate data"
    },
    {
      "name": "Currencies",
      "description": "Supported currencies information"
    },
    {
      "name": "Status",
      "description": "API account status"
    }
  ],
  "paths": {
    "/latest": {
      "get": {
        "operationId": "getLatestRates",
        "summary": "Get latest exchange rates",
        "description": "Returns the latest exchange rates. Updated every 60 seconds for paid plans.",
        "tags": [
          "Exchange Rates"
        ],
        "parameters": [
          {
            "name": "base_currency",
            "in": "query",
            "required": false,
            "description": "Base currency code (default: USD)",
            "schema": {
              "type": "string",
              "default": "USD"
            }
          },
          {
            "name": "currencies",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of currency codes to filter results",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with latest rates",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LatestRatesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable entity - validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/historical": {
      "get": {
        "operationId": "getHistoricalRates",
        "summary": "Get historical exchange rates",
        "description": "Returns historical exchange rates for a specific date.",
        "tags": [
          "Exchange Rates"
        ],
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "description": "The date for historical rates in YYYY-MM-DD format",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "base_currency",
            "in": "query",
            "required": false,
            "description": "Base currency code (default: USD)",
            "schema": {
              "type": "string",
              "default": "USD"
            }
          },
          {
            "name": "currencies",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of currency codes to filter results",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with historical rates",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HistoricalRatesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/range": {
      "get": {
        "operationId": "getRangeRates",
        "summary": "Get exchange rates for a date range",
        "description": "Returns daily exchange rates between two dates for time-series analysis.",
        "tags": [
          "Exchange Rates"
        ],
        "parameters": [
          {
            "name": "datetime_start",
            "in": "query",
            "required": true,
            "description": "Start of the date range in YYYY-MM-DDTHH:MM:SS format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "datetime_end",
            "in": "query",
            "required": true,
            "description": "End of the date range in YYYY-MM-DDTHH:MM:SS format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "accuracy",
            "in": "query",
            "required": false,
            "description": "Accuracy of the returned data (day, hour, quarter_hour, minute)",
            "schema": {
              "type": "string",
              "enum": [
                "day",
                "hour",
                "quarter_hour",
                "minute"
              ]
            }
          },
          {
            "name": "base_currency",
            "in": "query",
            "required": false,
            "description": "Base currency code",
            "schema": {
              "type": "string",
              "default": "USD"
            }
          },
          {
            "name": "currencies",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of currency codes to filter results",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with range rates",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RangeRatesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/currencies": {
      "get": {
        "operationId": "listCurrencies",
        "summary": "List supported currencies",
        "description": "Returns a list of all supported currencies with their details.",
        "tags": [
          "Currencies"
        ],
        "parameters": [
          {
            "name": "currencies",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of currency codes to filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "Filter by currency type",
            "schema": {
              "type": "string",
              "enum": [
                "fiat",
                "crypto",
                "metal"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with currencies list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrenciesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/status": {
      "get": {
        "operationId": "getAccountStatus",
        "summary": "Get API account status",
        "description": "Returns the current status of your API account including quotas and usage.",
        "tags": [
          "Status"
        ],
        "responses": {
          "200": {
            "description": "Successful response with account status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "apikey",
        "description": "API key passed as query parameter"
      }
    },
    "schemas": {
      "LatestRatesResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/MetaInfo"
          },
          "data": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/CurrencyRate"
            }
          }
        }
      },
      "HistoricalRatesResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/MetaInfo"
          },
          "data": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/CurrencyRate"
            }
          }
        }
      },
      "RangeRatesResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/MetaInfo"
          },
          "data": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/CurrencyRate"
              }
            }
          }
        }
      },
      "CurrenciesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/CurrencyInfo"
            }
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "account_id": {
            "type": "integer"
          },
          "quotas": {
            "type": "object",
            "properties": {
              "month": {
                "type": "object",
                "properties": {
                  "total": {
                    "type": "integer"
                  },
                  "used": {
                    "type": "integer"
                  },
                  "remaining": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      },
      "MetaInfo": {
        "type": "object",
        "properties": {
          "last_updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CurrencyRate": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "value": {
            "type": "number"
          }
        }
      },
      "CurrencyInfo": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "symbol_native": {
            "type": "string"
          },
          "decimal_digits": {
            "type": "integer"
          },
          "rounding": {
            "type": "number"
          },
          "code": {
            "type": "string"
          },
          "name_plural": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "fiat",
              "crypto",
              "metal"
            ]
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "object"
          }
        }
      }
    }
  }
}
