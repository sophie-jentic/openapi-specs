{
  "openapi": "3.0.3",
  "info": {
    "title": "Dexcom CGM API",
    "version": "3.0.0",
    "description": "Dexcom Continuous Glucose Monitoring (CGM) API provides access to glucose data, device information, alerts, calibrations, and user events from Dexcom CGM systems. The API enables developers to build applications that retrieve real-time and historical glucose readings.",
    "x-jentic-source-url": "https://developer.dexcom.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.dexcom.com",
      "description": "Production"
    },
    {
      "url": "https://sandbox-api.dexcom.com",
      "description": "Sandbox"
    }
  ],
  "paths": {
    "/v3/users/self/egvs": {
      "get": {
        "operationId": "getEstimatedGlucoseValues",
        "summary": "Get estimated glucose values",
        "description": "Returns estimated glucose values (EGVs) for the authenticated user within a specified date range. EGVs represent continuous glucose readings from the CGM sensor.",
        "tags": [
          "Glucose Data"
        ],
        "parameters": [
          {
            "name": "startDate",
            "in": "query",
            "required": true,
            "description": "Start of the query range in ISO 8601 format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": true,
            "description": "End of the query range in ISO 8601 format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with EGV records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EGVsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid date range",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or expired token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - insufficient scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v3/users/self/events": {
      "get": {
        "operationId": "getUserEvents",
        "summary": "Get user events",
        "description": "Returns user-entered events including carbohydrate intake, insulin doses, exercise, and health events within a specified date range.",
        "tags": [
          "Events"
        ],
        "parameters": [
          {
            "name": "startDate",
            "in": "query",
            "required": true,
            "description": "Start of the query range in ISO 8601 format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": true,
            "description": "End of the query range in ISO 8601 format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with event records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v3/users/self/devices": {
      "get": {
        "operationId": "getDevices",
        "summary": "Get devices",
        "description": "Returns information about the user's Dexcom CGM devices including transmitter and display device details.",
