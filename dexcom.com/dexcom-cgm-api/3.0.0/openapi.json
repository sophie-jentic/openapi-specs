    "/v2/oauth2/login": {
      "get": {
        "operationId": "oauthLogin",
        "summary": "OAuth2 authorization",
        "description": "Redirects the user to the Dexcom login page for OAuth2 authorization. After successful authorization, the user is redirected back to the specified redirect URI with an authorization code.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "OAuth2 client ID"
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "description": "Redirect URI after authorization"
          },
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "code"
              ]
            },
            "description": "OAuth2 response type"
          },
          {
            "name": "scope",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Requested OAuth2 scopes (e.g., offline_access)"
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "CSRF state parameter"
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to Dexcom login page"
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid client",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/oauth2/token": {
      "post": {
        "operationId": "oauthToken",
        "summary": "Exchange authorization code for token",
        "description": "Exchanges an authorization code for an access token and refresh token, or refreshes an existing token.",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "OAuth2 client ID"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "OAuth2 client secret"
                  },
                  "code": {
                    "type": "string",
                    "description": "Authorization code from login redirect"
                  },
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "authorization_code",
                      "refresh_token"
                    ],
                    "description": "OAuth2 grant type"
                  },
                  "redirect_uri": {
                    "type": "string",
                    "format": "uri",
                    "description": "Redirect URI used during authorization"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Refresh token for token renewal"
                  }
                },
                "required": [
                  "client_id",
                  "client_secret",
                  "grant_type"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful token response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid grant",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid client credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EGV": {
        "type": "object",
        "properties": {
          "recordId": {
            "type": "string",
            "description": "Unique record identifier"
          },
          "systemTime": {
            "type": "string",
            "format": "date-time",
            "description": "System time of the reading"
          },
          "displayTime": {
            "type": "string",
            "format": "date-time",
            "description": "Display time of the reading"
          },
          "transmitterId": {
            "type": "string",
            "description": "Transmitter ID"
          },
          "transmitterTicks": {
            "type": "integer",
            "description": "Transmitter tick count"
          },
          "value": {
            "type": "number",
            "description": "Glucose value in mg/dL"
          },
          "status": {
            "type": "string",
            "description": "Reading status"
          },
          "trend": {
            "type": "string",
            "enum": [
              "doubleUp",
              "singleUp",
              "fortyFiveUp",
              "flat",
              "fortyFiveDown",
              "singleDown",
              "doubleDown",
              "none",
              "notComputable",
              "rateOutOfRange"
            ],
            "description": "Glucose trend direction"
          },
          "trendRate": {
            "type": "number",
            "description": "Rate of glucose change in mg/dL/min"
          },
          "unit": {
            "type": "string",
            "enum": [
              "mg/dL",
              "mmol/L"
            ],
            "description": "Glucose unit of measure"
          }
        }
      },
      "EGVsResponse": {
        "type": "object",
        "properties": {
          "recordType": {
            "type": "string"
          },
          "recordVersion": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EGV"
            }
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "recordId": {
            "type": "string"
          },
          "systemTime": {
            "type": "string",
            "format": "date-time"
          },
          "displayTime": {
            "type": "string",
            "format": "date-time"
          },
          "eventType": {
            "type": "string",
            "enum": [
              "carbs",
              "insulin",
              "exercise",
              "health"
            ],
            "description": "Type of user event"
          },
          "eventSubType": {
            "type": "string",
            "description": "Subtype of event (e.g., light, medium, heavy for exercise)"
          },
          "value": {
            "type": "string",
            "description": "Event value (e.g., grams of carbs, units of insulin)"
          },
          "unit": {
            "type": "string",
            "description": "Unit for the event value"
          }
        }
      },
      "EventsResponse": {
        "type": "object",
        "properties": {
          "recordType": {
            "type": "string"
          },
          "recordVersion": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          }
        }
      },
      "Device": {
        "type": "object",
        "properties": {
          "lastUploadDate": {
            "type": "string",
            "format": "date-time"
          },
          "alertScheduleList": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "transmitterGeneration": {
            "type": "string",
            "enum": [
              "g4",
              "g5",
              "g6",
              "g7"
            ],
            "description": "Transmitter generation"
          },
          "displayDevice": {
            "type": "string",
            "description": "Type of display device"
          },
          "transmitterId": {
            "type": "string",
            "description": "Transmitter serial number"
          },
          "displayApp": {
            "type": "string",
            "description": "Display application name"
          }
        }
      },
      "DevicesResponse": {
        "type": "object",
        "properties": {
          "recordType": {
            "type": "string"
          },
          "recordVersion": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Device"
            }
          }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "recordId": {
            "type": "string"
          },
          "systemTime": {
            "type": "string",
            "format": "date-time"
          },
          "displayTime": {
            "type": "string",
            "format": "date-time"
          },
          "alertName": {
            "type": "string",
            "enum": [
              "high",
              "low",
              "rise",
              "fall",
              "outOfRange",
              "urgentLow",
              "urgentLowSoon",
              "noReadings",
              "fixedLow"
            ],
            "description": "Name of the alert"
          },
          "alertState": {
            "type": "string",
            "enum": [
              "unknown",
              "inactive",
              "activeSnoozed",
              "activeAlarming"
            ],
            "description": "State of the alert"
          }
        }
      },
      "AlertsResponse": {
        "type": "object",
        "properties": {
          "recordType": {
            "type": "string"
          },
          "recordVersion": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Alert"
            }
          }
        }
      },
      "Calibration": {
        "type": "object",
        "properties": {
          "recordId": {
            "type": "string"
          },
          "systemTime": {
            "type": "string",
            "format": "date-time"
          },
          "displayTime": {
            "type": "string",
            "format": "date-time"
          },
          "value": {
            "type": "number",
            "description": "Calibration value in mg/dL"
          },
          "unit": {
            "type": "string",
            "enum": [
              "mg/dL",
              "mmol/L"
            ]
          }
        }
      },
      "CalibrationsResponse": {
        "type": "object",
        "properties": {
          "recordType": {
            "type": "string"
          },
          "recordVersion": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Calibration"
            }
          }
        }
      },
      "DataRangeResponse": {
        "type": "object",
        "properties": {
          "recordType": {
            "type": "string"
          },
          "recordVersion": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "calibrations": {
            "type": "object",
            "properties": {
              "start": {
                "type": "object",
                "properties": {
                  "systemTime": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "displayTime": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              },
              "end": {
                "type": "object",
                "properties": {
                  "systemTime": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "displayTime": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          },
          "egvs": {
            "type": "object",
            "properties": {
              "start": {
                "type": "object",
                "properties": {
                  "systemTime": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "displayTime": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              },
              "end": {
                "type": "object",
                "properties": {
                  "systemTime": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "displayTime": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          },
          "events": {
            "type": "object",
            "properties": {
              "start": {
                "type": "object",
                "properties": {
                  "systemTime": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "displayTime": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              },
              "end": {
                "type": "object",
                "properties": {
                  "systemTime": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "displayTime": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        }
      },
      "StatisticsResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "hypoglycemiaRisk": {
            "type": "string",
