                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v3/users/self/statistics": {
      "get": {
        "operationId": "getStatistics",
        "summary": "Get glucose statistics",
        "description": "Returns summary glucose statistics including time in range, average glucose, GMI, and coefficient of variation for a specified date range.",
        "tags": [
