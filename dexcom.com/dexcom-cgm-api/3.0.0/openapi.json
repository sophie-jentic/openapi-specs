    "/v3/users/self/alerts": {
      "get": {
        "operationId": "getAlertScheduleSettings",
        "summary": "Get alert schedule settings",
        "description": "Returns the user's alert and alert schedule settings for high/low glucose thresholds, signal loss, and other CGM alerts.",
