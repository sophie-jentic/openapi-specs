    "/v3/users/self/dataRange": {
      "get": {
        "operationId": "getDataRange",
        "summary": "Get data range",
        "description": "Returns the date range of data available for the authenticated user, optionally filtered by last sync time. Useful for determining what data can be queried.",
        "tags": [
          "Glucose Data"
        ],
        "parameters": [
          {
            "name": "lastSyncTime",
            "in": "query",
            "required": false,
            "description": "Last sync time to check for new data",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with data range info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataRangeResponse"
