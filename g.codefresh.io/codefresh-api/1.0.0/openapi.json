{
  "openapi": "3.0.3",
  "info": {
    "title": "Codefresh API",
    "version": "1.0.0",
    "description": "Codefresh provides a comprehensive API for CI/CD pipeline management. You can trigger builds, get build status, create/manage pipelines, manage projects, and more. Authentication uses API keys generated from User Settings.",
    "x-jentic-source-url": "https://codefresh.io/docs/docs/integrations/codefresh-api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://g.codefresh.io/api",
      "description": "Codefresh API"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Builds",
      "description": "Trigger and manage pipeline builds"
    },
    {
      "name": "Pipelines",
      "description": "Create and manage pipelines"
    },
    {
      "name": "Projects",
      "description": "Manage projects"
    },
    {
      "name": "Contexts",
      "description": "Shared configuration contexts"
    }
  ],
  "paths": {
    "/builds/{buildId}": {
      "get": {
        "operationId": "getBuild",
        "summary": "Get build status",
        "description": "Get the status and details of a specific build by its ID.",
        "tags": [
          "Builds"
        ],
        "parameters": [
          {
            "name": "buildId",
            "in": "path",
            "required": true,
            "description": "The build ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Build details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Build"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "post": {
        "operationId": "triggerBuild",
        "summary": "Trigger a pipeline build",
        "description": "Trigger a new build for a pipeline. You can pass extra environment variables and specify the branch.",
        "tags": [
          "Builds"
        ],
        "parameters": [
          {
            "name": "buildId",
            "in": "path",
            "required": true,
            "description": "The service/pipeline ID to trigger",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TriggerBuildRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Build triggered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Build"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/builds": {
      "get": {
        "operationId": "listBuilds",
        "summary": "List builds",
        "description": "List builds with optional filtering.",
        "tags": [
          "Builds"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of builds to return",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by build status",
            "schema": {
              "type": "string",
              "enum": [
                "running",
                "success",
                "error",
                "pending",
                "terminated"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of builds",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Build"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/pipelines": {
      "get": {
        "operationId": "listPipelines",
        "summary": "List pipelines",
        "description": "List all pipelines accessible to the authenticated user.",
        "tags": [
          "Pipelines"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of pipelines to return",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of pipelines",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PipelineListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createPipeline",
        "summary": "Create a pipeline",
        "description": "Create a new pipeline programmatically. The pipeline spec follows the Codefresh YAML pipeline specification format.",
        "tags": [
          "Pipelines"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PipelineCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pipeline created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pipeline"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/pipelines/{name}": {
      "get": {
        "operationId": "getPipeline",
        "summary": "Get a pipeline",
        "description": "Get details of a specific pipeline by its name (project_name/pipeline_name).",
        "tags": [
          "Pipelines"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "Pipeline name in format project_name/pipeline_name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pipeline details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pipeline"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "operationId": "updatePipeline",
        "summary": "Update a pipeline",
        "description": "Update an existing pipeline definition.",
        "tags": [
          "Pipelines"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "Pipeline name in format project_name/pipeline_name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PipelineCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pipeline updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pipeline"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "operationId": "deletePipeline",
        "summary": "Delete a pipeline",
        "description": "Delete a pipeline by its name.",
        "tags": [
          "Pipelines"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "Pipeline name in format project_name/pipeline_name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pipeline deleted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/pipelines/{name}/runs": {
      "post": {
        "operationId": "runPipeline",
        "summary": "Run a pipeline",
        "description": "Trigger a new run (build) for a specific pipeline, with optional branch and variable overrides.",
        "tags": [
          "Pipelines"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "Pipeline name in format project_name/pipeline_name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunPipelineRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pipeline run triggered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Build"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "List projects",
        "description": "List all projects.",
        "tags": [
          "Projects"
        ],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Project"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createProject",
        "summary": "Create a project",
        "description": "Create a new project.",
        "tags": [
          "Projects"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/projects/{projectName}": {
      "get": {
        "operationId": "getProject",
        "summary": "Get a project",
        "description": "Get details of a specific project.",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "name": "projectName",
            "in": "path",
            "required": true,
            "description": "Project name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "operationId": "deleteProject",
        "summary": "Delete a project",
        "description": "Delete a project by name.",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "name": "projectName",
            "in": "path",
            "required": true,
            "description": "Project name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project deleted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/contexts": {
      "get": {
        "operationId": "listContexts",
        "summary": "List shared configuration contexts",
        "description": "List shared configuration contexts available in the account.",
        "tags": [
          "Contexts"
        ],
        "responses": {
          "200": {
            "description": "List of contexts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Context"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key generated from Codefresh User Settings. Pass as-is (no Bearer prefix)."
      }
    },
    "schemas": {
      "Build": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "description": "Build ID"
          },
          "serviceId": {
            "type": "string",
            "description": "Pipeline/service ID"
          },
          "status": {
            "type": "string",
            "enum": [
              "running",
              "success",
              "error",
              "pending",
              "terminated"
            ],
            "description": "Build status"
          },
          "type": {
            "type": "string",
            "description": "Build type"
          },
          "repoOwner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repoName": {
            "type": "string",
            "description": "Repository name"
          },
          "branch": {
            "type": "string",
            "description": "Git branch"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "started": {
            "type": "string",
            "format": "date-time"
          },
          "finished": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TriggerBuildRequest": {
        "type": "object",
        "required": [
          "serviceId",
          "type"
        ],
        "properties": {
          "serviceId": {
            "type": "string",
            "description": "Pipeline/service ID to trigger"
          },
          "type": {
            "type": "string",
            "default": "build",
            "description": "Build type"
          },
          "repoOwner": {
            "type": "string",
            "description": "Repository owner"
          },
          "branch": {
            "type": "string",
            "description": "Git branch to build"
          },
          "repoName": {
            "type": "string",
            "description": "Repository name"
          },
          "variables": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Extra environment variables to pass to the build"
          }
        }
      },
      "Pipeline": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "pipeline"
            ]
          },
          "metadata": {
            "$ref": "#/components/schemas/PipelineMetadata"
          },
          "spec": {
            "$ref": "#/components/schemas/PipelineSpec"
          }
        }
      },
      "PipelineMetadata": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Full pipeline name (project_name/pipeline_name)"
          },
          "project": {
            "type": "string",
            "description": "Project name"
          },
          "description": {
            "type": "string"
          },
          "isPublic": {
            "type": "boolean",
            "description": "If true, pipeline logs are public"
          },
          "labels": {
            "type": "object",
            "properties": {
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "PipelineSpec": {
        "type": "object",
        "properties": {
          "steps": {
            "type": "object",
            "description": "Pipeline steps definition"
          },
          "stages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "variables": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PipelineVariable"
            }
          },
          "contexts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Shared configuration context names"
          },
          "triggers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PipelineTrigger"
            }
          },
          "concurrency": {
            "type": "integer",
            "description": "Max concurrent instances"
          },
          "triggerConcurrency": {
            "type": "integer"
          },
          "branchConcurrency": {
            "type": "integer"
          }
        }
      },
      "PipelineVariable": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "encrypted": {
            "type": "boolean"
          }
        }
      },
      "PipelineTrigger": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Trigger type (e.g., git)"
          },
          "provider": {
            "type": "string",
            "description": "Git provider (e.g., github)"
          },
          "name": {
            "type": "string"
          },
          "repo": {
            "type": "string",
            "description": "Repository in owner/name format"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "branchRegex": {
            "type": "string"
          }
        }
      },
      "PipelineCreateRequest": {
        "type": "object",
        "required": [
          "version",
          "kind",
          "metadata",
          "spec"
        ],
        "properties": {
          "version": {
            "type": "string",
            "default": "1.0"
          },
          "kind": {
            "type": "string",
            "default": "pipeline"
          },
          "metadata": {
            "$ref": "#/components/schemas/PipelineMetadata"
          },
          "spec": {
            "$ref": "#/components/schemas/PipelineSpec"
          }
        }
      },
      "RunPipelineRequest": {
        "type": "object",
        "properties": {
          "branch": {
            "type": "string",
            "description": "Git branch to use"
          },
          "trigger": {
            "type": "string",
            "description": "Trigger name"
          },
          "variables": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Extra environment variables"
          }
        }
      },
      "PipelineListResponse": {
        "type": "object",
        "properties": {
          "docs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Pipeline"
            }
          },
          "count": {
            "type": "integer"
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "projectName": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ProjectCreateRequest": {
        "type": "object",
        "required": [
          "projectName"
        ],
        "properties": {
          "projectName": {
            "type": "string",
            "description": "Name of the project to create"
          }
        }
      },
      "Context": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authorization required",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}
