{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenSearch API",
    "version": "2.0.0",
    "description": "OpenSearch is a community-driven, open-source search and analytics engine derived from Elasticsearch 7.10.2. This spec covers the core REST API for document indexing, searching, cluster management, and index lifecycle operations.",
    "x-jentic-source-url": "https://opensearch.org/docs/latest/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://localhost:9200",
      "description": "Default OpenSearch endpoint"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getClusterInfo",
        "summary": "Get cluster information",
        "description": "Returns basic cluster information including version, cluster name, and UUID.",
        "tags": [
          "Cluster"
        ],
        "responses": {
          "200": {
            "description": "Cluster info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClusterInfo"
                }
              }
            }
          }
        }
      }
    },
    "/_cluster/health": {
      "get": {
        "operationId": "getClusterHealth",
        "summary": "Get cluster health",
        "description": "Returns the health status of the cluster.",
        "tags": [
          "Cluster"
        ],
        "parameters": [
          {
            "name": "timeout",
            "in": "query",
            "description": "Timeout for the request (e.g., 30s)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "wait_for_status",
            "in": "query",
            "description": "Wait until cluster reaches this status",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "green",
                "yellow",
                "red"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cluster health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClusterHealth"
                }
              }
            }
          }
        }
      }
    },
    "/_cat/indices": {
      "get": {
        "operationId": "catIndices",
        "summary": "List indices (cat API)",
        "description": "Returns information about indices in a compact, human-readable format.",
        "tags": [
          "Cat"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "text"
              ]
            }
          },
          {
            "name": "v",
            "in": "query",
            "description": "Include column headers",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "h",
            "in": "query",
            "description": "Comma-separated list of column names to display",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Index listing",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/{index}": {
      "put": {
        "operationId": "createIndex",
        "summary": "Create an index",
        "description": "Creates a new index with optional settings and mappings.",
        "tags": [
          "Indices"
        ],
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IndexSettings"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Index created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AcknowledgedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid settings/mappings"
          }
        }
      },
      "delete": {
        "operationId": "deleteIndex",
        "summary": "Delete an index",
        "description": "Deletes an existing index.",
        "tags": [
          "Indices"
        ],
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Index deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AcknowledgedResponse"
                }
              }
            }
          },
          "404": {
            "description": "Index not found"
          }
        }
      },
      "get": {
        "operationId": "getIndex",
        "summary": "Get index details",
        "description": "Returns settings, mappings, and aliases for an index.",
        "tags": [
          "Indices"
        ],
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Index details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Index not found"
          }
        }
      }
    },
    "/{index}/_doc/{id}": {
      "put": {
        "operationId": "indexDocument",
        "summary": "Index a document",
        "description": "Indexes a document with a specific ID.",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "refresh",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false",
                "wait_for"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Document body"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document indexed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndexResponse"
                }
              }
            }
          },
          "201": {
            "description": "Document created"
          }
        }
      },
      "get": {
        "operationId": "getDocument",
        "summary": "Get a document",
        "description": "Retrieves a specific document by ID.",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_source",
            "in": "query",
            "description": "Comma-separated list of source fields to include",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetResponse"
                }
              }
            }
          },
          "404": {
            "description": "Document not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteDocument",
        "summary": "Delete a document",
        "description": "Deletes a document by ID.",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document deleted"
          },
          "404": {
            "description": "Document not found"
          }
        }
      }
    },
    "/{index}/_doc": {
      "post": {
        "operationId": "indexDocumentAutoId",
        "summary": "Index a document with auto-generated ID",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndexResponse"
                }
              }
            }
          }
        },
        "description": "Index a document with auto-generated ID"
      }
    },
    "/{index}/_search": {
      "get": {
        "operationId": "searchDocumentsGet",
        "summary": "Search documents (GET)",
        "description": "Search for documents matching a query string.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Lucene query string",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      },
      "post": {
        "operationId": "searchDocumentsPost",
        "summary": "Search documents (POST)",
        "description": "Search for documents using Query DSL in the request body.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/_bulk": {
      "post": {
        "operationId": "bulkOperations",
        "summary": "Bulk operations",
        "description": "Perform multiple index/create/delete/update operations in a single request using newline-delimited JSON.",
        "tags": [
          "Documents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-ndjson": {
              "schema": {
                "type": "string",
                "description": "Newline-delimited JSON bulk actions"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "took": {
                      "type": "integer"
                    },
                    "errors": {
                      "type": "boolean"
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ClusterInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "cluster_name": {
            "type": "string"
          },
          "cluster_uuid": {
            "type": "string"
          },
          "version": {
            "type": "object",
            "properties": {
              "distribution": {
                "type": "string"
              },
              "number": {
                "type": "string"
              },
              "build_type": {
                "type": "string"
              },
              "build_hash": {
                "type": "string"
              },
              "build_date": {
                "type": "string"
              },
              "build_snapshot": {
                "type": "boolean"
              },
              "lucene_version": {
                "type": "string"
              },
              "minimum_wire_compatibility_version": {
                "type": "string"
              },
              "minimum_index_compatibility_version": {
                "type": "string"
              }
            }
          },
          "tagline": {
            "type": "string"
          }
        }
      },
      "ClusterHealth": {
        "type": "object",
        "properties": {
          "cluster_name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "green",
              "yellow",
              "red"
            ]
          },
          "timed_out": {
            "type": "boolean"
          },
          "number_of_nodes": {
            "type": "integer"
          },
          "number_of_data_nodes": {
            "type": "integer"
          },
          "active_primary_shards": {
            "type": "integer"
          },
          "active_shards": {
            "type": "integer"
          },
          "relocating_shards": {
            "type": "integer"
          },
          "initializing_shards": {
            "type": "integer"
          },
          "unassigned_shards": {
            "type": "integer"
          },
          "active_shards_percent_as_number": {
            "type": "number"
          }
        }
      },
      "IndexSettings": {
        "type": "object",
        "properties": {
          "settings": {
            "type": "object",
            "properties": {
              "index": {
                "type": "object",
                "properties": {
                  "number_of_shards": {
                    "type": "integer"
                  },
                  "number_of_replicas": {
                    "type": "integer"
                  }
                }
              }
            }
          },
          "mappings": {
            "type": "object",
            "properties": {
              "properties": {
                "type": "object"
              }
            }
          }
        }
      },
      "IndexResponse": {
        "type": "object",
        "properties": {
          "_index": {
            "type": "string"
          },
          "_id": {
            "type": "string"
          },
          "_version": {
            "type": "integer"
          },
          "result": {
            "type": "string",
            "enum": [
              "created",
              "updated"
            ]
          },
          "_shards": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer"
              },
              "successful": {
                "type": "integer"
              },
              "failed": {
                "type": "integer"
              }
            }
          },
          "_seq_no": {
            "type": "integer"
          },
          "_primary_term": {
            "type": "integer"
          }
        }
      },
      "GetResponse": {
        "type": "object",
        "properties": {
          "_index": {
            "type": "string"
          },
          "_id": {
            "type": "string"
          },
          "_version": {
            "type": "integer"
          },
          "_seq_no": {
            "type": "integer"
          },
          "_primary_term": {
            "type": "integer"
          },
          "found": {
            "type": "boolean"
          },
          "_source": {
            "type": "object"
          }
        }
      },
      "SearchRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "object",
            "description": "OpenSearch Query DSL"
          },
          "size": {
            "type": "integer"
          },
          "from": {
            "type": "integer"
          },
          "sort": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "_source": {
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "aggs": {
            "type": "object",
            "description": "Aggregations"
          },
          "highlight": {
            "type": "object"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "took": {
            "type": "integer",
            "description": "Time in milliseconds"
          },
          "timed_out": {
            "type": "boolean"
          },
          "_shards": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer"
              },
              "successful": {
                "type": "integer"
              },
              "skipped": {
                "type": "integer"
              },
              "failed": {
                "type": "integer"
              }
            }
          },
          "hits": {
            "type": "object",
            "properties": {
              "total": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "integer"
                  },
                  "relation": {
                    "type": "string"
                  }
                }
              },
              "max_score": {
                "type": "number"
              },
              "hits": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "_index": {
                      "type": "string"
                    },
                    "_id": {
                      "type": "string"
                    },
                    "_score": {
                      "type": "number"
                    },
                    "_source": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "aggregations": {
            "type": "object"
          }
        }
      },
      "AcknowledgedResponse": {
        "type": "object",
        "properties": {
          "acknowledged": {
            "type": "boolean"
          },
          "shards_acknowledged": {
            "type": "boolean"
          },
          "index": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Cat"
    },
    {
      "name": "Cluster"
    },
    {
      "name": "Documents"
    },
    {
      "name": "Indices"
    },
    {
      "name": "Search"
    }
  ]
}
