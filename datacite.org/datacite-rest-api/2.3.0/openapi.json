{
  "openapi": "3.0.3",
  "info": {
    "title": "DataCite REST API",
    "version": "2.3.0",
    "description": "The DataCite REST API is used for all API interactions with DataCite services including DOI management, metadata retrieval, and repository management. Official OpenAPI spec available at https://github.com/datacite/lupo/blob/master/openapi.yaml",
    "x-jentic-source-url": "https://support.datacite.org/docs/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.datacite.org"
    }
  ],
  "paths": {
    "/dois": {
      "get": {
        "operationId": "listDois",
        "summary": "List DOIs",
        "tags": [
          "DOIs"
        ],
        "description": "Query DOI records with comprehensive search and filtering",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page[size]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 25
            }
          },
          {
            "name": "page[number]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "DOI list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DoiListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      },
      "post": {
        "operationId": "createDoi",
        "summary": "Create DOI",
        "tags": [
          "DOIs"
        ],
        "description": "Create a new DOI",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "DOI created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/dois/{id}": {
      "get": {
        "operationId": "getDoi",
        "summary": "Get DOI",
        "tags": [
          "DOIs"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "DOI details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DoiResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get DOI"
      },
      "put": {
        "operationId": "updateDoi",
        "summary": "Update DOI",
        "tags": [
          "DOIs"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update DOI"
      },
      "delete": {
        "operationId": "deleteDoi",
        "summary": "Delete DOI",
        "tags": [
          "DOIs"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete DOI"
      }
    },
    "/clients": {
      "get": {
        "operationId": "listClients",
        "summary": "List clients",
        "tags": [
          "Clients"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Client list"
          }
        },
        "description": "List clients"
      }
    },
    "/clients/{id}": {
      "get": {
        "operationId": "getClient",
        "summary": "Get client",
        "tags": [
          "Clients"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Client details"
          }
        },
        "description": "Get client"
      }
    },
    "/providers": {
      "get": {
        "operationId": "listProviders",
        "summary": "List providers",
        "tags": [
          "Providers"
        ],
        "responses": {
          "200": {
            "description": "Provider list"
          }
        },
        "description": "List providers"
      }
    },
    "/providers/{id}": {
      "get": {
        "operationId": "getProvider",
        "summary": "Get provider",
        "tags": [
          "Providers"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Provider details"
          }
        },
        "description": "Get provider"
      }
    },
    "/activities": {
      "get": {
        "operationId": "listActivities",
        "summary": "List activities",
        "tags": [
          "Activities"
        ],
        "responses": {
          "200": {
            "description": "Activity list"
          }
        },
        "description": "List activities"
      }
    },
    "/activities/{id}": {
      "get": {
        "operationId": "getActivity",
        "summary": "Get activity",
        "tags": [
          "Activities"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Activity details"
          }
        },
        "description": "Get activity"
      }
    },
    "/events": {
      "get": {
        "operationId": "listEvents",
        "summary": "List events",
        "tags": [
          "Events"
        ],
        "responses": {
          "200": {
            "description": "Event list"
          }
        },
        "description": "List events"
      }
    },
    "/heartbeat": {
      "get": {
        "operationId": "getHeartbeat",
        "summary": "Get heartbeat",
        "tags": [
          "Status"
        ],
        "responses": {
          "200": {
            "description": "Heartbeat response"
          }
        },
        "description": "Get heartbeat"
      }
    }
  },
  "components": {
    "schemas": {
      "DoiListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DoiResource"
            }
          },
          "meta": {
            "type": "object"
          }
        }
      },
      "DoiResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/DoiResource"
          }
        }
      },
      "DoiResource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "attributes": {
            "type": "object",
            "properties": {
              "doi": {
                "type": "string"
              },
              "titles": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "creators": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "publisher": {
                "type": "string"
              },
              "publicationYear": {
                "type": "integer"
              },
              "types": {
                "type": "object"
              },
              "url": {
                "type": "string"
              },
              "state": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Activities"
    },
    {
      "name": "Clients"
    },
    {
      "name": "DOIs"
    },
    {
      "name": "Events"
    },
    {
      "name": "Providers"
    },
    {
      "name": "Status"
    }
  ]
}
