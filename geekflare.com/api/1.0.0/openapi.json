{
  "openapi": "3.0.0",
  "info": {
    "title": "Geekflare API",
    "description": "Geekflare API is a suite of REST-based tools for web scraping, screenshots, metadata extraction, PDF generation, and DNS lookups. Transform web data into clean, structured formats with support for Markdown, JSON, and HTML outputs.",
    "version": "1.0.0",
    "contact": {
      "name": "Geekflare",
      "url": "https://geekflare.com",
      "email": "support@geekflare.com"
    }
  },
  "servers": [
    {
      "url": "https://api.geekflare.com",
      "description": "Geekflare Production API Server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/scrape": {
      "post": {
        "summary": "Web Scraping",
        "description": "Scrape web content and receive output in Markdown, JSON, or HTML format",
        "operationId": "scrapeWebContent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Target URL to scrape"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "markdown",
                      "json",
                      "html"
                    ],
                    "description": "Output format for scraped content",
                    "default": "json"
                  },
                  "proxyCountry": {
                    "type": "string",
                    "description": "Country code for proxy routing (premium plans only)",
                    "pattern": "^[A-Z]{2}$"
                  },
                  "renderJs": {
                    "type": "boolean",
                    "description": "Enable JavaScript rendering for dynamic content",
                    "default": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully scraped content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        },
        "tags": [
          "scrape"
        ]
      }
    },
    "/screenshot": {
      "post": {
        "summary": "Capture Screenshot",
        "description": "Capture full-page screenshots with lazy-loading and dynamic content support",
        "operationId": "captureScreenshot",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Target URL to screenshot"
                  },
                  "fullPage": {
                    "type": "boolean",
                    "description": "Capture full page or viewport only",
                    "default": true
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "png",
                      "jpg",
                      "webp"
                    ],
                    "description": "Image output format",
                    "default": "png"
                  },
                  "quality": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "description": "Image quality (1-100)",
                    "default": 90
                  },
                  "width": {
                    "type": "integer",
                    "description": "Viewport width in pixels",
                    "default": 1920
                  },
                  "height": {
                    "type": "integer",
                    "description": "Viewport height in pixels",
                    "default": 1080
                  },
                  "proxyCountry": {
                    "type": "string",
                    "description": "Country code for proxy routing (premium plans only)",
                    "pattern": "^[A-Z]{2}$"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully captured screenshot",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        },
        "tags": [
          "screenshot"
        ]
      }
    },
    "/metadata": {
      "post": {
        "summary": "Extract Metadata",
        "description": "Extract OpenGraph, Twitter Cards, and Schema.org metadata from web pages",
        "operationId": "extractMetadata",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Target URL to extract metadata from"
                  },
                  "proxyCountry": {
                    "type": "string",
                    "description": "Country code for proxy routing (premium plans only)",
                    "pattern": "^[A-Z]{2}$"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully extracted metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        },
        "tags": [
          "metadata"
        ]
      }
    },
    "/pdf": {
      "post": {
        "summary": "Generate PDF",
        "description": "Generate PDF documents from URLs",
        "operationId": "generatePdf",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Target URL to convert to PDF"
                  },
                  "landscape": {
                    "type": "boolean",
                    "description": "Use landscape orientation",
                    "default": false
                  },
                  "printBackground": {
                    "type": "boolean",
                    "description": "Include background graphics",
                    "default": true
                  },
                  "proxyCountry": {
                    "type": "string",
                    "description": "Country code for proxy routing (premium plans only)",
                    "pattern": "^[A-Z]{2}$"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully generated PDF",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        },
        "tags": [
          "pdf"
        ]
      }
    },
    "/dns": {
      "post": {
        "summary": "DNS Lookup",
        "description": "Perform DNS record lookups and validation",
        "operationId": "dnsLookup",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "domain"
                ],
                "properties": {
                  "domain": {
                    "type": "string",
                    "description": "Domain name to query"
                  },
                  "recordType": {
                    "type": "string",
                    "enum": [
                      "A",
                      "AAAA",
                      "CNAME",
                      "MX",
                      "NS",
                      "TXT",
                      "SOA",
                      "PTR"
                    ],
                    "description": "DNS record type to query",
                    "default": "A"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully retrieved DNS records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        },
        "tags": [
          "dns"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for authentication. Get your key from the Geekflare dashboard."
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Response timestamp"
          },
          "apiStatus": {
            "type": "string",
            "description": "API operation status"
          },
          "apiCode": {
            "type": "integer",
            "description": "Internal API code"
          },
          "message": {
            "type": "string",
            "description": "Response message"
          },
          "meta": {
            "type": "object",
            "description": "Metadata about the request",
            "properties": {
              "creditsUsed": {
                "type": "integer",
                "description": "Number of credits consumed"
              }
            }
          },
          "data": {
            "type": "object",
            "description": "Response data payload"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "apiStatus": {
            "type": "string"
          },
          "apiCode": {
            "type": "integer"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "meta": {
            "type": "object"
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "Invalid or missing API key"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Insufficient permissions - free plan accessing premium feature",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "This feature requires a premium subscription"
            }
          }
        }
      },
      "TooManyRequests": {
        "description": "Rate limit exceeded (1-50 requests per second based on plan)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "Rate limit exceeded. Please try again later."
            }
          }
        }
      }
    }
  },
  "x-rate-limits": {
    "range": "1-50 requests per second",
    "note": "Rate limits depend on subscription tier"
  },
  "x-credit-system": {
    "basic-requests": "1 credit (DNS, lite scraping)",
    "advanced-requests": "5 credits (screenshots, PDF generation)"
  },
  "tags": [
    {
      "name": "dns"
    },
    {
      "name": "metadata"
    },
    {
      "name": "pdf"
    },
    {
      "name": "scrape"
    },
    {
      "name": "screenshot"
    }
  ]
}
