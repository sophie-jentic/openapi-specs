  "components": {
    "parameters": {
      "format": {
        "name": "format",
        "in": "query",
        "description": "Response format: json, xml, jsonP, jsonstat",
        "schema": {
          "type": "string",
          "enum": [
            "json",
            "xml",
            "jsonP",
            "jsonstat"
          ],
          "default": "xml"
        }
      },
      "page": {
        "name": "page",
        "in": "query",
        "description": "Page number for pagination",
        "schema": {
          "type": "integer",
          "default": 1
        }
      },
      "per_page": {
        "name": "per_page",
        "in": "query",
        "description": "Results per page (default 50)",
        "schema": {
          "type": "integer",
          "default": 50
        }
      }
    },
    "schemas": {
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "pages": {
            "type": "integer"
          },
          "per_page": {
            "type": "string"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "Country": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "iso2Code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "region": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "iso2code": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          },
          "adminregion": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "iso2code": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          },
          "incomeLevel": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "iso2code": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          },
          "lendingType": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "iso2code": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          },
          "capitalCity": {
            "type": "string"
          },
          "longitude": {
            "type": "string"
          },
          "latitude": {
            "type": "string"
          }
        }
      },
      "CountryListResponse": {
        "type": "array",
        "items": {
          "oneOf": [
            {
              "$ref": "#/components/schemas/PaginationMeta"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Country"
              }
            }
          ]
        }
      },
      "IndicatorDataEntry": {
        "type": "object",
        "properties": {
          "indicator": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          },
          "country": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          },
          "countryiso3code": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "value": {
            "type": "number",
            "nullable": true
          },
          "unit": {
            "type": "string"
          },
          "obs_status": {
            "type": "string"
          },
          "decimal": {
            "type": "integer"
          }
        }
      },
      "IndicatorDataResponse": {
        "type": "array",
        "items": {
          "oneOf": [
            {
              "$ref": "#/components/schemas/PaginationMeta"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/IndicatorDataEntry"
              }
            }
          ]
        }
      }
    }
  },
  "tags": [
