{
  "openapi": "3.0.3",
  "info": {
    "title": "World Bank Indicators API",
    "description": "Provides programmatic access to nearly 16,000 time series indicators across over 45 databases from the World Bank. Includes World Development Indicators, International Debt Statistics, Doing Business, Human Capital Index, and more. No authentication required.",
    "version": "2.0",
    "contact": {
      "name": "World Bank Data Help Desk",
      "url": "https://datahelpdesk.worldbank.org/"
    },
    "license": {
      "name": "Creative Commons Attribution 4.0",
      "url": "https://creativecommons.org/licenses/by/4.0/"
    }
  },
  "externalDocs": {
    "description": "World Bank Indicators API Documentation",
    "url": "https://datahelpdesk.worldbank.org/knowledgebase/articles/889392"
  },
  "servers": [
    {
      "url": "https://api.worldbank.org/v2",
      "description": "World Bank API v2"
    }
  ],
  "paths": {
    "/country": {
      "get": {
        "operationId": "listCountries",
        "summary": "List all countries",
        "parameters": [
          {
            "$ref": "#/components/parameters/format"
          },
          {
            "$ref": "#/components/parameters/page"
          },
          {
            "$ref": "#/components/parameters/per_page"
          },
          {
            "name": "incomeLevel",
            "in": "query",
            "description": "Filter by income level code (e.g. LIC, MIC, HIC)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lendingType",
            "in": "query",
            "description": "Filter by lending type",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "region",
            "in": "query",
            "description": "Filter by region code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of countries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountryListResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "description": "List all countries",
        "tags": [
          "country"
        ]
      }
    },
    "/country/{country_codes}": {
      "get": {
        "operationId": "getCountries",
        "summary": "Get one or more countries by ISO code",
        "parameters": [
          {
            "name": "country_codes",
            "in": "path",
            "required": true,
            "description": "One or more ISO 2-letter or 3-letter country codes separated by semicolons (e.g. us;br;cn)",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "Country details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountryListResponse"
                }
              }
            }
          }
        },
        "description": "Get one or more countries by ISO code",
        "tags": [
          "country"
        ]
      }
    },
    "/country/{country_codes}/indicator/{indicator_code}": {
      "get": {
        "operationId": "getIndicatorData",
        "summary": "Get indicator data for specific countries",
        "parameters": [
          {
            "name": "country_codes",
            "in": "path",
            "required": true,
            "description": "Country codes separated by semicolons (e.g. br;cn), or \"all\"",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "indicator_code",
            "in": "path",
            "required": true,
            "description": "Indicator code (e.g. SP.POP.TOTL, NY.GDP.MKTP.CD)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "description": "Date or date range (e.g. 2000, 2000:2010, 2012M01:2012M08, 2013Q1:2013Q4)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mrv",
            "in": "query",
            "description": "Fetch most recent values (number)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "mrnev",
            "in": "query",
            "description": "Fetch most recent non-empty values (number)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "gapfill",
            "in": "query",
            "description": "Fill gaps when using MRV (Y/N)",
            "schema": {
              "type": "string",
              "enum": [
                "Y",
                "N"
              ]
            }
          },
          {
            "name": "frequency",
            "in": "query",
            "description": "Data frequency: Y (yearly), M (monthly), Q (quarterly)",
            "schema": {
              "type": "string",
              "enum": [
                "Y",
                "M",
                "Q"
              ]
            }
          },
          {
            "name": "footnote",
            "in": "query",
            "description": "Include footnotes (y/n)",
            "schema": {
              "type": "string",
              "enum": [
                "y",
                "n"
              ]
            }
          },
          {
            "name": "source",
            "in": "query",
            "description": "Data source ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "#/components/parameters/format"
          },
          {
            "$ref": "#/components/parameters/page"
          },
          {
            "$ref": "#/components/parameters/per_page"
          },
          {
            "name": "downloadformat",
            "in": "query",
            "description": "Download format for bulk export",
            "schema": {
              "type": "string",
              "enum": [
                "csv",
                "xml",
                "excel"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Indicator data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndicatorDataResponse"
                }
              }
            }
          }
        },
        "description": "Get indicator data for specific countries",
        "tags": [
          "country"
        ]
      }
    },
    "/indicator": {
      "get": {
        "operationId": "listIndicators",
        "summary": "List all available indicators",
        "parameters": [
          {
            "$ref": "#/components/parameters/format"
          },
          {
            "$ref": "#/components/parameters/page"
          },
          {
            "$ref": "#/components/parameters/per_page"
          }
        ],
        "responses": {
          "200": {
            "description": "List of indicators",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array"
                }
              }
            }
          }
        },
        "description": "List all available indicators",
        "tags": [
          "indicator"
        ]
      }
    },
    "/indicator/{indicator_code}": {
      "get": {
        "operationId": "getIndicator",
        "summary": "Get metadata for a specific indicator",
        "parameters": [
          {
            "name": "indicator_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "Indicator metadata",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array"
                }
              }
            }
          }
        },
        "description": "Get metadata for a specific indicator",
        "tags": [
          "indicator"
        ]
      }
    },
    "/sources": {
      "get": {
        "operationId": "listSources",
