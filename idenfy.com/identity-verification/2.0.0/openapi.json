{
  "openapi": "3.0.3",
  "info": {
    "title": "iDenfy Identity Verification API",
    "version": "2.0.0",
    "description": "iDenfy API for identity verification services",
    "contact": {
      "url": "https://documentation.idenfy.com/"
    }
  },
  "servers": [
    {
      "url": "https://ivs.idenfy.com/api/v2"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/token": {
      "post": {
        "summary": "Generate identification token",
        "description": "Create a new verification session and generate an identification token",
        "operationId": "generateToken",
        "tags": [
          "Identity Verification"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateTokenResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key pair for authentication"
      }
    },
    "schemas": {
      "GenerateTokenRequest": {
        "type": "object",
        "required": [
          "clientId"
        ],
        "properties": {
          "clientId": {
            "type": "string",
            "description": "A unique string identifying a client"
          },
          "externalRef": {
            "type": "string",
            "description": "Internal system tracking reference"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "sex": {
            "type": "string",
            "enum": [
              "M",
              "F"
            ]
          },
          "nationality": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "documentNumber": {
            "type": "string"
          },
          "personalNumber": {
            "type": "string"
          },
          "successUrl": {
            "type": "string",
            "format": "uri"
          },
          "errorUrl": {
            "type": "string",
            "format": "uri"
          },
          "unverifiedUrl": {
            "type": "string",
            "format": "uri"
          },
          "callbackUrl": {
            "type": "string",
            "format": "uri"
          },
          "locale": {
            "type": "string"
          },
          "expiryTime": {
            "type": "integer"
          },
          "sessionLength": {
            "type": "integer"
          },
          "tokenType": {
            "type": "string"
          },
          "showInstructions": {
            "type": "boolean"
          },
          "generateDigitString": {
            "type": "boolean"
          },
          "nfcRequired": {
            "type": "boolean"
          },
          "nfcOptional": {
            "type": "boolean"
          },
          "checkLiveness": {
            "type": "boolean"
          },
          "checkAml": {
            "type": "boolean"
          }
        }
      },
      "GenerateTokenResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "authToken": {
            "type": "string"
          },
          "scanRef": {
            "type": "string"
          },
          "clientId": {
            "type": "string"
          },
          "digitString": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Identity Verification"
    }
  ]
}
