    "/convert/{symbol1}/{symbol2}": {
      "post": {
        "operationId": "convert",
        "summary": "Convert currency",
        "description": "Converts an amount from one currency to another.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "symbol1",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The first currency code (e.g. BTC)"
          },
          {
            "name": "symbol2",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The second currency code (e.g. USD)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConvertRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "amnt": {
                      "type": "string",
                      "description": "Converted amount"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
