          {
            "name": "symbol2",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The second currency code (e.g. USD)"
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Return trades with tid >= since"
