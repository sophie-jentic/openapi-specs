    "/order_book/{symbol1}/{symbol2}/": {
      "get": {
        "operationId": "getOrderBook",
        "summary": "Get order book",
        "description": "Returns the order book for a trading pair.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "symbol1",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The first currency code (e.g. BTC)"
          },
          {
            "name": "symbol2",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The second currency code (e.g. USD)"
          },
          {
            "name": "depth",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Limit the number of bid/ask records returned"
