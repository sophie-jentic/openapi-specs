    },
    "/trade_history/{symbol1}/{symbol2}/": {
      "get": {
        "operationId": "getTradeHistory",
        "summary": "Get trade history",
        "description": "Returns recent trades for a trading pair.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "symbol1",
            "in": "path",
            "required": true,
            "schema": {
