{
  "openapi": "3.0.3",
  "info": {
    "title": "CEX.IO API",
    "version": "1.0.0",
    "description": "CEX.IO cryptocurrency exchange REST API for market data, trading, and account management.",
    "x-jentic-source-url": "https://cex.io/rest-api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://cex.io/api"
    }
  ],
  "tags": [
    {
      "name": "Public",
      "description": "Public market data endpoints"
    },
    {
      "name": "Private",
      "description": "Authenticated account and trading endpoints"
    }
  ],
  "paths": {
    "/currency_limits": {
      "get": {
        "operationId": "getCurrencyLimits",
        "summary": "Get currency limits",
        "description": "Returns data on limits for all trading pairs.",
        "tags": [
          "Public"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrencyLimitsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ticker/{symbol1}/{symbol2}": {
      "get": {
        "operationId": "getTicker",
        "summary": "Get ticker",
        "description": "Returns the ticker for a given trading pair with bid, ask, last price, volume.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "symbol1",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The first currency code (e.g. BTC)"
          },
          {
            "name": "symbol2",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The second currency code (e.g. USD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ticker"
                }
              }
            }
          }
        }
      }
    },
    "/tickers/{marketSymbol1}/{marketSymbol2}": {
      "get": {
        "operationId": "getTickersByMarket",
        "summary": "Get tickers for all pairs by markets",
        "description": "Returns tickers for all pairs filtered by market symbols.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "marketSymbol1",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "First currency code (mandatory)"
          },
          {
            "name": "marketSymbol2",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Second currency code (optional)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TickersResponse"
                }
              }
            }
          }
        }
      }
    },
    "/last_price/{symbol1}/{symbol2}": {
      "get": {
        "operationId": "getLastPrice",
        "summary": "Get last price",
        "description": "Returns the last traded price for a given pair.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "symbol1",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
