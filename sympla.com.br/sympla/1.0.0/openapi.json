            "type": "string"
          },
          "address_state": {
            "type": "string"
          },
          "address_city": {
            "type": "string"
          },
          "address_zip_code": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lon": {
            "type": "number"
