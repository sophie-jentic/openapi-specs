{
  "openapi": "3.0.1",
  "info": {
    "title": "BEYABLE Ranking API",
    "description": "Get product rankings in CSV format (comma separated, quoted strings) with 3 columns \"ProductId\", \"abTestGroup\" and \"Position\"",
    "version": "1.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/DEVELOP_BEYABLE/beyable-product-ranking/1.0/swagger.json",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://apibeyableprod.azure-api.net"
    }
  ],
  "paths": {
    "/persoproductranking/{accountId}/{rankingGroupId}/{segmentId}/{tenant}": {
      "get": {
        "summary": "GetProductRankingWithPerso",
        "description": "Get product ranking (no perso)",
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "description": "Account identifier (uuid without hyphens)",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/hyphenLessUuid"
            }
          },
          {
            "name": "rankingGroupId",
            "in": "path",
            "description": "Ranking group identifier (uuid without hyphens)",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/hyphenLessUuid"
            }
          },
          {
            "name": "segmentId",
            "in": "path",
            "description": "Ranking segment identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tenant",
            "in": "path",
            "description": "Account tenant",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CSV file (comma separated, quoted strings) with 3 columns \"ProductId\", \"abTestGroup\" and \"Position\"",
            "content": {
              "text/csv": {
                "example": "\"ProductId\",\"abTestGroup\",\"Position\"\r\n\"5505\",\"abTest1\",1\r\n\"5506\",\"abTest1\",2\r\n\"5507\",\"abTest1\",3"
              }
            }
          }
        },
        "tags": [
          "persoproductranking"
        ],
        "operationId": "get-persoproductranking-by-accountid-by-rankinggroupid-by-segmentid-by-tenant"
      }
    },
