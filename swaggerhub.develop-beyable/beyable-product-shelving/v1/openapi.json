{
  "openapi": "3.0.1",
  "info": {
    "title": "BEYABLE Product Shelving API",
    "description": "This API provides collection of products built from BEYABLE Shelving Rules",
    "version": "v1",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/DEVELOP_BEYABLE/beyable-product-shelving/v1/swagger.json",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://apibeyableprod.azure-api.net/productshelving"
    }
  ],
  "paths": {
    "/{account}/{rule}/{dimension}/{pointofinterest}": {
      "get": {
        "summary": "Products for the requested Shelving Rule",
        "description": "Products for the requested Shelving Rule",
        "operationId": "products-for-shelving-rule",
        "parameters": [
          {
            "name": "account",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rule",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dimension",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pointofinterest",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Api-Version",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product collection with cardinal (score)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssociatedProductsForPointOfInterest"
                },
                "example": {
                  "PointOfInterest": {
                    "Id": "Sousrayon=Eau du Soir"
                  },
                  "AssociatedPoints": [
                    {
                      "Point": {
                        "Id": "995700",
                        "Name": "Cr\u00e8me Parfum\u00e9e Hydratante Eau du Soir",
                        "Description": "",
                        "Url": "https://www.mysite.com/fr-FR/creme-parfumee-hydratante-eau-du-soir-195700.html",
                        "ImagePath": "",
                        "Feature1": "91.00",
                        "Feature2": "91.00",
                        "Categories": [
                          "Univers=Parfums",
                          "Rayon=Parfum femme",
                          "Sousrayon=Eau du Soir"
                        ],
                        "CustomTags": [],
                        "Tags": []
                      },
                      "Cardinal": 4
                    }
                  ]
                }
              }
            }
          },
          "204": {
            "description": "No product collection"
          },
          "401": {
            "description": "Check Subscription-Key"
          },
          "404": {
            "description": "Not found, check Api-Version header"
          }
        },
        "tags": [
          "default"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "AssociatedProductsForPointOfInterest": {
        "type": "object",
        "properties": {
          "PointOfInterest": {
            "type": "object",
            "properties": {
              "Id": {
                "type": "string"
              }
            }
          },
          "AssociatedPoints": {
            "type": "array",
            "items": {
              "required": [
                "Point",
                "Cardinal"
              ],
              "type": "object",
              "properties": {
                "Point": {
                  "type": "object",
                  "properties": {
                    "Id": {
                      "type": "string"
                    },
                    "Name": {
                      "type": "string"
                    },
                    "Description": {
                      "type": "string"
                    },
                    "Url": {
                      "type": "string"
                    },
                    "ImagePath": {
                      "type": "string"
                    },
                    "Feature1": {
                      "type": "string"
                    },
                    "Feature2": {
                      "type": "string"
                    },
                    "Categories": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "CustomTags": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "Tags": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "Cardinal": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "example": {
          "PointOfInterest": {
            "Id": "string"
          },
          "AssociatedPoints": [
            {
              "Point": {
                "Id": "string",
                "Name": "string",
                "Description": "string",
                "Url": "string",
                "ImagePath": "string",
                "Feature1": "string",
                "Feature2": "string",
                "Categories": [
                  "string"
                ],
                "CustomTags": [
                  "Generic array"
                ],
                "Tags": [
                  "Generic array"
                ]
              },
              "Cardinal": 0
            }
          ]
        }
      }
    },
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "name": "Subscription-Key",
        "in": "header"
      },
      "apiKeyQuery": {
        "type": "apiKey",
        "name": "subscription-key",
        "in": "query"
      }
    }
  },
  "security": [
    {
      "apiKeyHeader": []
    },
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
