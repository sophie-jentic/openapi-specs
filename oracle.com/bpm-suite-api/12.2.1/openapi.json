{
  "openapi": "3.0.3",
  "info": {
    "title": "Oracle BPM Suite REST API",
    "version": "12.2.1",
    "description": "Oracle BPM Suite 12c REST API for managing business processes, human tasks, and workflow operations. Provides process instance management, task operations, and process analytics.",
    "x-jentic-source-url": "https://www.oracle.com/middleware/technologies/bpm.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}:{port}/bpm/api",
      "variables": {
        "host": {
          "default": "localhost"
        },
        "port": {
          "default": "7001"
        }
      }
    }
  ],
  "paths": {
    "/4.0/processes": {
      "get": {
        "operationId": "listProcessDefinitions",
        "summary": "List process definitions",
        "tags": [
          "Processes"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessDefinitionList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List process definitions"
      }
    },
    "/4.0/processes/{processDefId}": {
      "get": {
        "operationId": "getProcessDefinition",
        "summary": "Get a process definition",
        "tags": [
          "Processes"
        ],
        "parameters": [
          {
            "name": "processDefId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a process definition"
      }
    },
    "/4.0/processes/{processDefId}/instances": {
      "get": {
        "operationId": "listProcessInstances",
        "summary": "List process instances",
        "tags": [
          "Process Instances"
        ],
        "parameters": [
          {
            "name": "processDefId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "OPEN",
                "COMPLETED",
                "ABORTED",
                "ERRORED",
                "SUSPENDED"
              ]
            }
          },
          {
            "name": "beginDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List process instances"
      },
      "post": {
        "operationId": "createProcessInstance",
        "summary": "Create a process instance",
        "tags": [
          "Process Instances"
        ],
        "parameters": [
          {
            "name": "processDefId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProcessInstanceInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a process instance"
      }
    },
    "/4.0/processes/instances/{instanceId}": {
      "get": {
        "operationId": "getProcessInstance",
        "summary": "Get a process instance",
        "tags": [
          "Process Instances"
        ],
        "parameters": [
          {
            "name": "instanceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a process instance"
      },
      "delete": {
        "operationId": "deleteProcessInstance",
        "summary": "Abort a process instance",
        "tags": [
          "Process Instances"
        ],
        "parameters": [
          {
            "name": "instanceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aborted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Abort a process instance"
      }
    },
    "/4.0/processes/instances/{instanceId}/suspend": {
      "put": {
        "operationId": "suspendProcessInstance",
        "summary": "Suspend a process instance",
        "tags": [
          "Process Instances"
        ],
        "parameters": [
          {
            "name": "instanceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Suspended"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Suspend a process instance"
      }
    },
    "/4.0/processes/instances/{instanceId}/resume": {
      "put": {
        "operationId": "resumeProcessInstance",
        "summary": "Resume a process instance",
        "tags": [
          "Process Instances"
        ],
        "parameters": [
          {
            "name": "instanceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resumed"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Resume a process instance"
      }
    },
    "/4.0/tasks": {
      "get": {
        "operationId": "listTasks",
        "summary": "List human tasks",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "ASSIGNED",
                "COMPLETED",
                "SUSPENDED",
                "WITHDRAWN",
                "EXPIRED",
                "INFO_REQUESTED",
                "ERRORED"
              ]
            }
          },
          {
            "name": "assignee",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startRow",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List human tasks"
      }
    },
    "/4.0/tasks/{taskId}": {
      "get": {
        "operationId": "getTask",
        "summary": "Get a task",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a task"
      }
    },
    "/4.0/tasks/{taskId}/actions/complete": {
      "put": {
        "operationId": "completeTask",
        "summary": "Complete a task",
        "tags": [
          "Task Actions"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskActionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Completed"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Complete a task"
      }
    },
    "/4.0/tasks/{taskId}/actions/approve": {
      "put": {
        "operationId": "approveTask",
        "summary": "Approve a task",
        "tags": [
          "Task Actions"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Approved"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Approve a task"
      }
    },
    "/4.0/tasks/{taskId}/actions/reject": {
      "put": {
        "operationId": "rejectTask",
        "summary": "Reject a task",
        "tags": [
          "Task Actions"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Rejected"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Reject a task"
      }
    },
    "/4.0/tasks/{taskId}/actions/claim": {
      "put": {
        "operationId": "claimTask",
        "summary": "Claim a task",
        "tags": [
          "Task Actions"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Claimed"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Claim a task"
      }
    },
    "/4.0/tasks/{taskId}/actions/release": {
      "put": {
        "operationId": "releaseTask",
        "summary": "Release a task",
        "tags": [
          "Task Actions"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Released"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Release a task"
      }
    },
    "/4.0/tasks/{taskId}/actions/reassign": {
      "put": {
        "operationId": "reassignTask",
        "summary": "Reassign a task",
        "tags": [
          "Task Actions"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "assignee": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reassigned"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Reassign a task"
      }
    },
    "/4.0/tasks/{taskId}/comments": {
      "get": {
        "operationId": "listTaskComments",
        "summary": "List task comments",
        "tags": [
          "Task Comments"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List task comments"
      },
      "post": {
        "operationId": "addTaskComment",
        "summary": "Add a comment to a task",
        "tags": [
          "Task Comments"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "comment": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Comment added"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Add a comment to a task"
      }
    },
    "/4.0/tasks/{taskId}/attachments": {
      "get": {
        "operationId": "listTaskAttachments",
        "summary": "List task attachments",
        "tags": [
          "Task Attachments"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List task attachments"
      },
      "post": {
        "operationId": "addTaskAttachment",
        "summary": "Upload a task attachment",
        "tags": [
          "Task Attachments"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Attachment added"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Upload a task attachment"
      }
    }
  },
  "components": {
    "schemas": {
      "ProcessDefinitionList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "processDefId": {
                  "type": "string"
                },
                "processName": {
                  "type": "string"
                },
                "revision": {
                  "type": "string"
                },
                "compositedn": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ProcessInstanceInput": {
        "type": "object",
        "properties": {
          "processDefId": {
            "type": "string"
          },
          "serviceName": {
            "type": "string"
          },
          "operationName": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          }
        }
      },
      "TaskList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "taskId": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "priority": {
                  "type": "integer"
                },
                "assignees": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "createdDate": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          },
          "totalCount": {
            "type": "integer"
          }
        }
      },
      "TaskActionInput": {
        "type": "object",
        "properties": {
          "outcome": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Process Instances"
    },
    {
      "name": "Processes"
    },
    {
      "name": "Task Actions"
    },
    {
      "name": "Task Attachments"
    },
    {
      "name": "Task Comments"
    },
    {
      "name": "Tasks"
    }
  ]
}
