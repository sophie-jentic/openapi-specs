{
  "openapi": "3.0.3",
  "info": {
    "title": "Planet Data API",
    "version": "1.0.0",
    "description": "Planet provides satellite imagery and geospatial data. The Data API allows searching, filtering, and downloading satellite imagery.",
    "x-jentic-source-url": "https://docs.planet.com/develop/apis/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.planet.com/data/v1"
    }
  ],
  "paths": {
    "/quick-search": {
      "post": {
        "operationId": "quickSearch",
        "summary": "Quick search for imagery",
        "description": "Search for satellite imagery matching specified filters",
        "tags": [
          "Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/searches": {
      "post": {
        "operationId": "createSavedSearch",
        "summary": "Create a saved search",
        "tags": [
          "Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Saved search created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SavedSearch"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create a saved search"
      },
      "get": {
        "operationId": "listSavedSearches",
        "summary": "List saved searches",
        "tags": [
          "Search"
        ],
        "responses": {
          "200": {
            "description": "Saved searches",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SavedSearch"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List saved searches"
      }
    },
    "/item-types": {
      "get": {
        "operationId": "listItemTypes",
        "summary": "List available item types",
        "description": "Returns available satellite imagery item types (e.g., PSScene, SkySatCollect)",
        "tags": [
          "Item Types"
        ],
        "responses": {
          "200": {
            "description": "Item types",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ItemType"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/item-types/{itemTypeId}/items/{itemId}": {
      "get": {
        "operationId": "getItem",
        "summary": "Get item details",
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "name": "itemTypeId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get item details"
      }
    },
    "/item-types/{itemTypeId}/items/{itemId}/assets": {
      "get": {
        "operationId": "listItemAssets",
        "summary": "List item assets",
        "description": "Returns downloadable assets for a satellite image item",
        "tags": [
          "Assets"
        ],
        "parameters": [
          {
            "name": "itemTypeId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Assets list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/item-types/{itemTypeId}/items/{itemId}/assets/{assetTypeId}/activate": {
      "post": {
        "operationId": "activateAsset",
        "summary": "Activate an asset for download",
        "tags": [
          "Assets"
        ],
        "parameters": [
          {
            "name": "itemTypeId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "assetTypeId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Asset activation started"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Activate an asset for download"
      }
    }
  },
  "components": {
    "schemas": {
      "SearchRequest": {
        "type": "object",
        "required": [
          "item_types",
          "filter"
        ],
        "properties": {
          "item_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "filter": {
            "type": "object"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "features": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            }
          },
          "_links": {
            "type": "object"
          }
        }
      },
      "SavedSearch": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "filter": {
            "type": "object"
          },
          "item_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Item": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "geometry": {
            "type": "object"
          },
          "properties": {
            "type": "object",
            "properties": {
              "acquired": {
                "type": "string",
                "format": "date-time"
              },
              "cloud_cover": {
                "type": "number"
              },
              "pixel_resolution": {
                "type": "number"
              }
            }
          },
          "_links": {
            "type": "object"
          }
        }
      },
      "ItemType": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "display_description": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Planet API key as username with empty password"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Assets"
    },
    {
      "name": "Item Types"
    },
    {
      "name": "Items"
    },
    {
      "name": "Search"
    }
  ]
}
