{
  "openapi": "3.0.3",
  "info": {
    "title": "StarCraft 2 API",
    "description": "Blizzard's StarCraft 2 API provides access to game data, player profiles, ladders, and league information. The API is divided into Community APIs (player profiles, ladders, match history, etc.) and Game Data APIs (league data, season information). Authentication is done via OAuth 2.0 client credentials flow using a Battle.net developer application.",
    "version": "1.0.0",
    "contact": {
      "name": "Blizzard Developer Portal",
      "url": "https://develop.battle.net"
    },
    "termsOfService": "https://www.blizzard.com/en-us/legal/a2989b50-5f16-43b1-abec-2ae17cc09dd6/blizzard-developer-api-terms-of-use"
  },
  "servers": [
    {
      "url": "https://{region}.api.blizzard.com",
      "description": "Blizzard API regional server",
      "variables": {
        "region": {
          "default": "us",
          "description": "API region",
          "enum": [
            "us",
            "eu",
            "kr",
            "tw"
          ]
        }
      }
    },
    {
      "url": "https://gateway.battlenet.com.cn",
      "description": "Blizzard API China region server"
    }
  ],
  "security": [
    {
      "oauth2ClientCredentials": []
    }
  ],
