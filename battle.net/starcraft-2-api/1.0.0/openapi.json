    "/data/sc2/league/{seasonId}/{queueId}/{teamType}/{leagueId}": {
      "get": {
        "operationId": "getLeagueData",
        "summary": "Get league data",
        "description": "Returns data for the specified season, queue, team type, and league. The queueId values are: 1 (Wings of Liberty 1v1), 2 (Wings of Liberty 2v2), 3 (Wings of Liberty 3v3), 4 (Wings of Liberty 4v4), 101 (Heart of the Swarm 1v1), 102 (Heart of the Swarm 2v2), 103 (Heart of the Swarm 3v3), 104 (Heart of the Swarm 4v4), 201 (Legacy of the Void 1v1), 202 (Legacy of the Void 2v2), 203 (Legacy of the Void 3v3), 204 (Legacy of the Void 4v4), 206 (Legacy of the Void Archon). The teamType values are: 0 (Arranged), 1 (Random). The leagueId values are: 0 (Bronze), 1 (Silver), 2 (Gold), 3 (Platinum), 4 (Diamond), 5 (Master), 6 (Grandmaster).",
        "tags": [
          "Game Data APIs"
        ],
        "parameters": [
          {
            "name": "seasonId",
            "in": "path",
            "required": true,
            "description": "The season ID.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "queueId",
            "in": "path",
            "required": true,
            "description": "The queue ID (e.g., 201 for LotV 1v1, 202 for LotV 2v2).",
            "schema": {
              "type": "integer",
              "enum": [
                1,
                2,
                3,
                4,
                101,
                102,
                103,
                104,
                201,
                202,
                203,
                204,
                206
              ]
            }
          },
          {
            "name": "teamType",
            "in": "path",
            "required": true,
            "description": "The team type (0 = arranged, 1 = random).",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          },
          {
            "name": "leagueId",
            "in": "path",
            "required": true,
            "description": "The league ID (0=Bronze, 1=Silver, 2=Gold, 3=Platinum, 4=Diamond, 5=Master, 6=Grandmaster).",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1,
                2,
                3,
                4,
                5,
                6
              ]
            }
          },
          {
            "$ref": "#/components/parameters/locale"
          }
        ],
        "responses": {
          "200": {
            "description": "League data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeagueData"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
