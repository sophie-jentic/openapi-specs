                "properties": {
                  "side": {
                    "type": "string",
                    "enum": [
                      "buy",
                      "sell"
                    ]
                  },
                  "order_type": {
                    "type": "string",
                    "enum": [
                      "limit_order",
                      "market_order"
                    ]
                  },
                  "market": {
                    "type": "string"
                  },
                  "price_per_unit": {
                    "type": "number",
                    "description": "Required for limit orders"
                  },
                  "total_quantity": {
                    "type": "number"
                  },
                  "client_order_id": {
                    "type": "string"
                  },
                  "timestamp": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
