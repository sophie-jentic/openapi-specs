  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-AUTH-APIKEY",
        "description": "API key"
      },
      "apiSignature": {
        "type": "apiKey",
        "in": "header",
        "name": "X-AUTH-SIGNATURE",
        "description": "HMAC-SHA256 signature of the JSON payload using API secret"
      }
    },
    "schemas": {
      "Ticker": {
        "type": "object",
        "properties": {
          "market": {
            "type": "string"
          },
          "last_price": {
            "type": "string"
          },
          "bid": {
            "type": "string"
          },
          "ask": {
            "type": "string"
          },
          "high": {
            "type": "string"
          },
