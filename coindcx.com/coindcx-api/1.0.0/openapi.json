        ],
        "summary": "Create Order",
        "description": "Place a new spot order.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "side",
                  "order_type",
                  "market",
                  "total_quantity",
                  "timestamp"
