          },
          "min_quantity": {
            "type": "number"
          },
          "max_quantity": {
            "type": "number"
          },
          "min_price": {
            "type": "number"
          },
          "max_price": {
            "type": "number"
          },
          "base_currency_precision": {
            "type": "integer"
          },
          "target_currency_precision": {
            "type": "integer"
          }
        }
      },
      "OrderBook": {
        "type": "object",
        "properties": {
          "bids": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "price": {
                  "type": "string"
                },
                "quantity": {
                  "type": "string"
                }
              }
            }
          },
          "asks": {
