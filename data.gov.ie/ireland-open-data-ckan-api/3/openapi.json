{
  "openapi": "3.0.3",
  "info": {
    "title": "Ireland Open Data Portal API (CKAN)",
    "version": "3",
    "description": "Ireland's open data portal API powered by CKAN. Provides access to government datasets, resources, organizations, and groups.",
    "x-jentic-source-url": "https://data.gov.ie/api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://data.gov.ie/api"
    }
  ],
  "paths": {
    "/3/action/package_list": {
      "get": {
        "operationId": "package_list",
        "summary": "List all datasets",
        "description": "Return a list of the names of the site's datasets (packages).",
        "tags": [
          "Packages"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Max number of datasets to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Offset for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CkanListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/3/action/current_package_list_with_resources": {
      "get": {
        "operationId": "current_package_list_with_resources",
        "summary": "List datasets with resources",
        "description": "Return a list of the site's datasets and their resources, sorted most-recently-modified first.",
        "tags": [
          "Packages"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
