          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Dataset not found"
          }
        }
      }
    },
    "/3/action/package_search": {
      "get": {
        "operationId": "package_search",
        "summary": "Search datasets",
        "description": "Search for packages satisfying a given search criteria.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Solr search query"
          },
          {
            "name": "fq",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter query"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sorting of results, e.g. 'relevance asc, metadata_modified desc'"
          },
          {
            "name": "rows",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of matching rows to return"
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset in the complete result"
          },
          {
            "name": "facet",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Enable faceted results"
          },
          {
            "name": "facet.field",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Fields to facet upon"
          },
          {
            "name": "facet.limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            },
            "description": "Facet limit"
          },
          {
            "name": "include_private",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include private datasets"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PackageSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
