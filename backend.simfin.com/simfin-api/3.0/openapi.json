    "/api/v3/companies/prices/compact": {
      "get": {
        "description": "Get price data, compact format (more efficient data transfer)",
        "operationId": "prices",
        "parameters": [
          {
            "description": "SimFin Id(s), comma separated",
            "explode": false,
            "in": "query",
            "name": "id",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "number",
                "example": 470
              }
            }
          },
          {
            "description": "Tickers, comma separated (Comma Separated)",
            "explode": false,
            "in": "query",
            "name": "ticker",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "example": "AAPL"
              }
            }
          },
          {
            "description": "Whether to include ratios and derived metrics also",
            "in": "query",
            "name": "ratios",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "description": "For derived metrics, if the as-reported figures should be used or the eventually restated values",
            "in": "query",
            "name": "asreported",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "description": "Filter for date range, starting date. E.g. setting starting date as 2012-01-01 would only retrieve prices AFTER that date.",
            "in": "query",
            "name": "start",
            "required": false,
            "schema": {
              "type": "string",
              "example": "1999-12-31"
            }
          },
          {
            "description": "Filter for date range, ending date. E.g. setting ending date as 2012-01-01 would only retrieve prices BEFORE that date.",
            "in": "query",
            "name": "end",
            "required": false,
            "schema": {
              "type": "string",
              "example": "1999-12-31"
            }
          },
          {
            "description": "Example: \"api-key ovBimDZTPrKdG9Yx58GjQf2A\"",
            "example": "api-key ovBimDZTPrKdG9Yx58GjQf2A",
            "in": "header",
            "name": "Authorization",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {}
            },
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "API Not Found"
          },
          "429": {
            "description": "Rate limits exceeded, see section Rate Limits"
          }
        },
        "summary": "Price Data (Compact)",
        "tags": [
          "Price Data"
        ]
      }
    },
