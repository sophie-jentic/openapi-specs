    "/api/v3/filings/get-report/{filingType}/{filingIdentifier}": {
      "get": {
        "description": "Retrieves the filing document which is either a HTML document or a PDF, rate limited based on your account type. For free accounts 8 requests per DAY, for START subscriptions 40 requests per day, for BASIC subscriptions 400 requests per day and for PRO subscriptions 5 requests per SECOND.",
        "operationId": "3",
        "parameters": [
          {
            "description": "Type of the filing, either HTML or PDF. You get this for a specific document from the /list or /by-company endpoints, i.e. you can't 'choose' what type you want to have returned.",
            "in": "path",
            "name": "filingType",
            "required": true,
            "schema": {
              "type": "string",
              "example": "HTML"
            }
          },
          {
            "description": "The filing identifier, you get this for a specific document from the /list or /by-company endpoints. For SEC documents, this is the accession number without trailing zeros and dashes.",
            "in": "path",
            "name": "filingIdentifier",
            "required": true,
            "schema": {
              "type": "number",
              "example": 95017023005530
            }
          },
          {
            "description": "Whether to use base64 encoding for the file output",
            "in": "query",
            "name": "base64",
            "required": false,
            "schema": {
              "type": "boolean",
              "example": false,
              "default": false
            }
          },
          {
            "description": "Example: \"api-key ovBimDZTPrKdG9Yx58GjQf2A\"",
            "example": "api-key ovBimDZTPrKdG9Yx58GjQf2A",
            "in": "header",
            "name": "Authorization",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "API Not Found"
          },
          "429": {
            "description": "Rate limits exceeded, see section Rate Limits"
          }
        },
        "summary": "Get Filing",
        "tags": [
          "Filings"
        ]
      }
    },
