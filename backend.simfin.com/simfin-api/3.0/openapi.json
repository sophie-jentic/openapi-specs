    "/api/v3/companies/statements/compact": {
      "get": {
        "description": "Get financial statements, compact format (more efficient data transfer)",
        "operationId": "statements",
        "parameters": [
          {
            "description": "SimFin Id(s), comma separated",
            "explode": false,
            "in": "query",
            "name": "id",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "number",
                "example": 470
              }
            }
          },
          {
            "description": "Tickers, comma separated",
            "explode": false,
            "in": "query",
            "name": "ticker",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "example": "AAPL"
              }
            }
          },
          {
            "description": "List of statements (comma separated), available values: pl (Profit & Loss), bs (Balance Sheet), cf (Cash Flow), derived (Derived Ratios and Indicators)",
            "explode": false,
            "in": "query",
            "name": "statements",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "PL",
                  "BS",
                  "CF",
                  "DERIVED"
                ]
              }
            }
          },
          {
            "description": "List of time periods (comma separated), available values: q1, q2, q3, q4, fy, h1, h2, nine_month. If you want to retrieve all quarterly periods for example, you would use period=q1,q2,q3,q4",
            "explode": false,
            "in": "query",
            "name": "period",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "Q1",
                  "Q2",
                  "Q3",
                  "Q4",
                  "FY",
                  "H1",
                  "H2",
                  "NINE_MONTH"
                ]
              }
            }
          },
          {
            "description": "List of financial years (comma separated). This the fiscal year of the company, not the calendar year.",
            "in": "query",
            "name": "fyear",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2021,2023"
            }
          },
          {
            "description": "Filter for date range, starting date. E.g. setting starting date as 2012-01-01 would only retrieve statements with a reporting period ending AFTER 1st of January 2012 (so statements ending in December 31st 2011 would be excluded)",
            "in": "query",
            "name": "start",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2012-01-01"
            }
          },
          {
            "description": "Filter for date range, ending date. E.g. setting ending date as 2012-01-01 would only retrieve statements with a reporting period ending BEFORE 1st of January 2012 (so statements ending in December 31st 2011 would be excluded)",
            "in": "query",
            "name": "end",
            "required": false,
            "schema": {
              "type": "string",
              "example": "1999-12-31"
            }
          },
          {
            "description": "Retrieves trailing twelve month periods",
            "in": "query",
            "name": "ttm",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "description": "Retrieves the statements as-reported (not restated).",
            "in": "query",
            "name": "asreported",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "description": "Retrieves details for all columns",
            "in": "query",
            "name": "details",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "description": "Example: \"api-key ovBimDZTPrKdG9Yx58GjQf2A\"",
            "example": "api-key ovBimDZTPrKdG9Yx58GjQf2A",
            "in": "header",
            "name": "Authorization",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {}
            },
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "API Not Found"
          },
          "429": {
            "description": "Rate limits exceeded, see section Rate Limits"
          }
        },
        "summary": "Financial Statements (Compact)",
        "tags": [
          "Financial Statements"
        ]
      }
    },
