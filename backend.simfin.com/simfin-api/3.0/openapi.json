  "paths": {
    "/api/v3/companies/changed-companies": {
      "get": {
        "description": "Returns the companies modified since a certain start date.",
        "operationId": "12",
        "parameters": [
          {
            "description": "Minimum date of change (optional)",
            "in": "query",
            "name": "start",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2020-12-31"
            }
          },
          {
            "description": "Example: \"api-key ovBimDZTPrKdG9Yx58GjQf2A\"",
            "example": "api-key ovBimDZTPrKdG9Yx58GjQf2A",
            "in": "header",
            "name": "Authorization",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {}
            },
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "API Not Found"
          }
        },
        "summary": "Changed Companies",
        "tags": [
          "Utils"
        ]
      }
    },
    "/api/v3/companies/common-shares-outstanding": {
      "get": {
        "description": "Retrieves the common shares outstanding (point in time) and applying a date filter if specified.",
        "operationId": "shares",
        "parameters": [
          {
            "description": "SimFin Id(s), comma separated",
            "explode": false,
            "in": "query",
            "name": "id",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "number",
                "example": 470
              }
            }
          },
          {
            "description": "Tickers, comma separated (Comma Separated)",
            "explode": false,
            "in": "query",
            "name": "ticker",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "example": "AAPL"
              }
            }
          },
          {
            "description": "Filter for minimum date",
            "in": "query",
            "name": "start",
            "required": false,
            "schema": {
              "type": "string",
              "example": "1999-12-31"
            }
          },
          {
            "description": "Filter for maximum date",
            "in": "query",
            "name": "end",
            "required": false,
            "schema": {
              "type": "string",
              "example": "1999-12-31"
            }
          },
          {
            "description": "Example: \"api-key ovBimDZTPrKdG9Yx58GjQf2A\"",
            "example": "api-key ovBimDZTPrKdG9Yx58GjQf2A",
            "in": "header",
            "name": "Authorization",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {}
            },
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "API Not Found"
          }
        },
        "summary": "Common Shares Outstanding",
        "tags": [
          "Shares Outstanding"
        ]
      }
    },
    "/api/v3/companies/data-change-log": {
      "get": {
        "description": "Returns all the changes that occurred in the database, paginated.",
        "operationId": "11",
        "parameters": [
          {
            "description": "Pagination index to be returned, starts at 0",
            "in": "query",
            "name": "pageNumber",
            "required": true,
            "schema": {
              "type": "number",
              "example": 0
            }
          },
          {
            "description": "Number of entries per page to be returned (maximum 1000)",
            "in": "query",
            "name": "itemsPerPage",
            "required": true,
            "schema": {
              "maximum": 1000,
              "minimum": 1,
              "type": "number",
              "example": 10
            }
          },
          {
            "description": "Example: \"api-key ovBimDZTPrKdG9Yx58GjQf2A\"",
            "example": "api-key ovBimDZTPrKdG9Yx58GjQf2A",
            "in": "header",
            "name": "Authorization",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {}
            },
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "API Not Found"
          }
        },
        "summary": "Changes in Database",
        "tags": [
          "Utils"
        ]
      }
    },
    "/api/v3/companies/general/compact": {
      "get": {
        "description": "Get Information for one or several companies by SimFin ID or ticker. Compact format (more efficient data transfer)",
        "operationId": "general",
        "parameters": [
          {
            "description": "SimFin Id(s), comma separated",
            "explode": false,
            "in": "query",
            "name": "id",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "number",
                "example": 470
              }
            }
          },
          {
            "description": "Tickers, comma separated",
            "explode": false,
            "in": "query",
            "name": "ticker",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "example": "AAPL"
              }
            }
          },
          {
            "description": "Example: \"api-key ovBimDZTPrKdG9Yx58GjQf2A\"",
            "example": "api-key ovBimDZTPrKdG9Yx58GjQf2A",
            "in": "header",
            "name": "Authorization",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CompanyArrayFormat"
                  }
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "API Not Found"
          },
          "429": {
            "description": "Rate limits exceeded, see section Rate Limits"
          }
        },
        "summary": "General Company Info (Compact)",
        "tags": [
          "General Data"
        ]
      }
    },
