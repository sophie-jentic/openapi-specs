    "/profiles/{id}/updates/reorder.json": {
      "post": {
        "operationId": "reorderUpdates",
        "summary": "Reorder updates in queue",
        "description": "Edit the order at which statuses for the specified social media profile will be sent out of the buffer.",
        "tags": [
          "Updates"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Profile ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "order": {
                    "type": "array",
                    "items": {
