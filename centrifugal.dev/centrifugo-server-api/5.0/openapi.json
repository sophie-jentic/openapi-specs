              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresenceStatsResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/history": {
      "post": {
        "operationId": "history",
        "summary": "Get channel history",
        "description": "Returns publication history for a channel.",
        "tags": [
          "History"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "channel"
                ],
                "properties": {
                  "channel": {
                    "type": "string",
                    "description": "Channel name"
                  },
                  "limit": {
                    "type": "integer",
                    "description": "Max number of publications to return"
                  },
                  "since": {
                    "type": "object",
                    "properties": {
                      "offset": {
                        "type": "integer"
                      },
                      "epoch": {
                        "type": "string"
                      }
                    }
                  },
                  "reverse": {
                    "type": "boolean",
                    "description": "Return in reverse order"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "History result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HistoryResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/history_remove": {
      "post": {
        "operationId": "historyRemove",
        "summary": "Remove channel history",
        "description": "Removes publication history for a channel.",
        "tags": [
          "History"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "channel"
                ],
                "properties": {
                  "channel": {
                    "type": "string",
                    "description": "Channel name"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "History removed"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/channels": {
      "post": {
        "operationId": "channels",
        "summary": "List active channels",
        "description": "Returns list of active channels (with at least one active subscriber).",
        "tags": [
          "Channels"
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pattern": {
                    "type": "string",
                    "description": "Channel pattern to filter"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Channel list",
            "content": {
              "application/json": {
                "schema": {
