{
  "openapi": "3.0.3",
  "info": {
    "title": "Centrifugo Server API",
    "version": "5.0",
    "description": "Centrifugo real-time messaging server HTTP API. Provides server-side operations for publishing messages, managing channels, subscriptions, presence information, history, and user connections. All commands are sent as POST requests to the /api endpoint.",
    "x-jentic-source-url": "https://centrifugal.dev/docs/server/server_api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Default local Centrifugo instance"
    }
  ],
  "tags": [
    {
      "name": "Publishing"
    },
    {
      "name": "Channels"
    },
    {
      "name": "Presence"
    },
    {
      "name": "History"
    },
    {
      "name": "Connections"
    },
    {
      "name": "User"
    },
    {
      "name": "Stats"
    },
    {
      "name": "Admin"
    },
    {
      "name": "Batch"
    }
  ],
  "paths": {
    "/api/publish": {
      "post": {
        "operationId": "publish",
        "summary": "Publish message to a channel",
        "description": "Publishes data to a channel. The data field can be any valid JSON.",
        "tags": [
          "Publishing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "channel",
                  "data"
                ],
                "properties": {
                  "channel": {
                    "type": "string",
                    "description": "Channel name to publish to"
                  },
                  "data": {
                    "type": "object",
                    "description": "JSON data to publish"
                  },
                  "skip_history": {
                    "type": "boolean",
                    "description": "Skip adding to history"
                  },
                  "tags": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    },
                    "description": "Publication tags"
                  },
                  "b64data": {
                    "type": "string",
                    "description": "Base64-encoded binary data (alternative to data)"
                  },
                  "idempotency_key": {
                    "type": "string",
                    "description": "Idempotency key for exactly-once publishing"
                  },
                  "delta": {
                    "type": "boolean",
                    "description": "Whether to use delta compression"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message published",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublishResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/broadcast": {
      "post": {
        "operationId": "broadcast",
        "summary": "Broadcast message to multiple channels",
        "description": "Publishes the same data to multiple channels at once.",
        "tags": [
          "Publishing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "channels",
                  "data"
                ],
                "properties": {
                  "channels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of channel names"
                  },
                  "data": {
                    "type": "object",
                    "description": "JSON data to publish"
                  },
                  "skip_history": {
                    "type": "boolean"
                  },
                  "tags": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "b64data": {
                    "type": "string"
                  },
                  "idempotency_key": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Broadcast result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BroadcastResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/subscribe": {
      "post": {
        "operationId": "subscribe",
        "summary": "Subscribe user to a channel",
        "description": "Subscribes a user to a channel using their connection.",
        "tags": [
          "Channels"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user",
                  "channel"
                ],
                "properties": {
                  "user": {
                    "type": "string",
                    "description": "User ID"
                  },
                  "channel": {
                    "type": "string",
                    "description": "Channel name"
                  },
                  "info": {
                    "type": "object",
                    "description": "Custom channel info"
                  },
                  "b64info": {
                    "type": "string",
                    "description": "Base64-encoded channel info"
                  },
                  "client": {
                    "type": "string",
                    "description": "Client ID (to subscribe specific connection)"
                  },
                  "session": {
                    "type": "string",
                    "description": "Session ID"
                  },
                  "data": {
                    "type": "object",
                    "description": "Custom data for subscription"
                  },
                  "recover_since": {
                    "type": "object",
                    "properties": {
                      "offset": {
                        "type": "integer"
                      },
                      "epoch": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User subscribed"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/unsubscribe": {
      "post": {
        "operationId": "unsubscribe",
        "summary": "Unsubscribe user from a channel",
        "description": "Unsubscribes a user from a channel.",
        "tags": [
          "Channels"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user",
                  "channel"
                ],
                "properties": {
                  "user": {
                    "type": "string",
                    "description": "User ID"
                  },
                  "channel": {
                    "type": "string",
                    "description": "Channel name"
                  },
                  "client": {
                    "type": "string",
                    "description": "Client ID"
                  },
                  "session": {
                    "type": "string",
                    "description": "Session ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User unsubscribed"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/disconnect": {
      "post": {
        "operationId": "disconnect",
        "summary": "Disconnect a user",
        "description": "Disconnects all connections of a user.",
        "tags": [
          "Connections"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user"
                ],
                "properties": {
                  "user": {
                    "type": "string",
                    "description": "User ID to disconnect"
                  },
                  "client": {
                    "type": "string",
                    "description": "Specific client to disconnect"
                  },
                  "session": {
                    "type": "string",
                    "description": "Session ID"
                  },
                  "whitelist": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Client IDs to keep connected"
                  },
                  "disconnect": {
                    "type": "object",
                    "properties": {
                      "code": {
                        "type": "integer"
                      },
                      "reason": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User disconnected"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/refresh": {
      "post": {
        "operationId": "refresh",
        "summary": "Refresh connection credentials",
        "description": "Refreshes connection credentials for a user.",
        "tags": [
          "Connections"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user"
                ],
                "properties": {
                  "user": {
                    "type": "string"
                  },
                  "client": {
                    "type": "string"
                  },
                  "session": {
                    "type": "string"
                  },
                  "expired": {
                    "type": "boolean"
                  },
                  "expire_at": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Credentials refreshed"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/presence": {
      "post": {
        "operationId": "presence",
        "summary": "Get channel presence",
        "description": "Returns presence information for a channel (currently active subscribers).",
        "tags": [
          "Presence"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "channel"
                ],
                "properties": {
                  "channel": {
                    "type": "string",
                    "description": "Channel name"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Presence data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresenceResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/presence_stats": {
      "post": {
        "operationId": "presenceStats",
        "summary": "Get channel presence stats",
        "description": "Returns short channel presence statistics (number of clients and unique users).",
        "tags": [
          "Presence"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
