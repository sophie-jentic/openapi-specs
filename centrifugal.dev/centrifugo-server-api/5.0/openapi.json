    "/api/invalidate_user_tokens": {
      "post": {
        "operationId": "invalidateUserTokens",
        "summary": "Invalidate user tokens",
        "description": "Invalidates all tokens for a specific user, causing reconnection.",
        "tags": [
          "User"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user"
                ],
                "properties": {
                  "user": {
                    "type": "string"
                  },
                  "issued_before": {
                    "type": "integer",
                    "description": "Unix timestamp; tokens issued before this will be invalidated"
                  },
                  "channel": {
                    "type": "string",
                    "description": "Invalidate tokens for a specific channel only"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tokens invalidated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/device_register": {
      "post": {
        "operationId": "deviceRegister",
        "summary": "Register push notification device",
        "description": "Registers a device for push notifications.",
        "tags": [
          "Admin"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id",
                  "provider",
                  "token"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "provider": {
                    "type": "string",
                    "enum": [
                      "fcm",
                      "hms",
                      "apns"
                    ]
                  },
                  "token": {
