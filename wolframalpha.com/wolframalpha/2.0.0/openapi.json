{
  "openapi": "3.0.3",
  "info": {
    "title": "Wolfram|Alpha API",
    "description": "Computational knowledge engine API providing full programmatic access to Wolfram|Alpha capabilities. Includes Full Results API for structured query results, Short Answers API for plain text answers, Simple API for image-based results, Spoken Results API for text-to-speech optimized responses, and Fast Query Recognizer for query classification.",
    "version": "2.0.0",
    "contact": {
      "name": "Wolfram Alpha LLC",
      "url": "https://products.wolframalpha.com/api/"
    },
    "x-jentic-source-url": "https://products.wolframalpha.com/api/"
  },
  "servers": [
    {
      "url": "https://api.wolframalpha.com",
      "description": "Production API server"
    }
  ],
  "security": [
    {
      "appId": []
    }
  ],
  "tags": [
    {
      "name": "Full Results",
      "description": "Full programmatic access to all Wolfram|Alpha capabilities with structured results"
    },
    {
      "name": "Short Answers",
      "description": "Plain text single-line answers"
    },
    {
      "name": "Simple",
      "description": "Image-based result delivery"
    },
    {
      "name": "Spoken Results",
      "description": "Text-to-speech optimized conversational answers"
    }
  ],
  "paths": {
    "/v2/query": {
      "get": {
        "operationId": "getFullResults",
        "summary": "Get full computational results",
        "description": "Full programmatic access to all Wolfram|Alpha capabilities including disambiguation, drilldown, and asynchronous results delivery. Returns structured results organized into pods.",
        "tags": [
          "Full Results"
        ],
        "parameters": [
          {
            "name": "appid",
            "in": "query",
            "required": true,
            "description": "Application ID obtained from the Wolfram|Alpha Developer Portal.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "input",
            "in": "query",
            "required": true,
            "description": "URL-encoded query string. Maximum 200 characters.",
            "schema": {
              "type": "string",
              "maxLength": 200
            }
          },
          {
            "name": "output",
            "in": "query",
            "required": false,
            "description": "Output format.",
            "schema": {
              "type": "string",
              "enum": [
                "xml",
                "json"
              ],
              "default": "xml"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of desired result formats for pod content.",
            "schema": {
              "type": "string",
              "example": "image,plaintext"
            }
          },
          {
            "name": "includepodid",
            "in": "query",
            "required": false,
            "description": "Include only specific pods by ID. Can be repeated.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "excludepodid",
            "in": "query",
            "required": false,
            "description": "Exclude specific pods by ID. Can be repeated.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "podtitle",
            "in": "query",
            "required": false,
            "description": "Filter pods by title. Supports wildcard (*).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "podindex",
            "in": "query",
            "required": false,
            "description": "Select pods by 1-based position index.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scanner",
            "in": "query",
            "required": false,
            "description": "Filter by the scanner type that produced the pod.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ip",
            "in": "query",
            "required": false,
            "description": "IPv4 or IPv6 address for location context. Mutually exclusive with latlong and location.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "latlong",
            "in": "query",
            "required": false,
            "description": "Latitude,longitude for location context. Mutually exclusive with ip and location.",
            "schema": {
              "type": "string",
              "example": "40.7128,-74.0060"
            }
          },
          {
            "name": "location",
            "in": "query",
            "required": false,
            "description": "Semantic location string. Mutually exclusive with ip and latlong.",
            "schema": {
              "type": "string",
              "example": "Boston, MA"
            }
          },
          {
            "name": "units",
            "in": "query",
            "required": false,
            "description": "Measurement system preference.",
            "schema": {
              "type": "string",
              "enum": [
                "metric",
                "nonmetric"
              ]
            }
          },
          {
            "name": "width",
            "in": "query",
            "required": false,
            "description": "Text/table width limit in pixels.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "maxwidth",
            "in": "query",
            "required": false,
            "description": "Extended maximum width in pixels.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "plotwidth",
            "in": "query",
            "required": false,
            "description": "Plot/graphic width limit in pixels.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "mag",
            "in": "query",
            "required": false,
            "description": "Magnification factor.",
            "schema": {
              "type": "number",
              "minimum": 0.5,
              "maximum": 2.0
            }
          },
          {
            "name": "scantimeout",
            "in": "query",
            "required": false,
            "description": "Scan stage timeout in seconds.",
            "schema": {
              "type": "number",
              "default": 3.0
            }
          },
          {
            "name": "podtimeout",
            "in": "query",
            "required": false,
            "description": "Individual pod format timeout in seconds.",
            "schema": {
              "type": "number",
              "default": 4.0
            }
          },
          {
            "name": "formattimeout",
            "in": "query",
            "required": false,
            "description": "Total format stage timeout in seconds.",
            "schema": {
              "type": "number",
              "default": 8.0
            }
          },
          {
            "name": "parsetimeout",
            "in": "query",
            "required": false,
            "description": "Query parsing timeout in seconds.",
            "schema": {
              "type": "number",
              "default": 5.0
            }
          },
          {
            "name": "totaltimeout",
            "in": "query",
            "required": false,
            "description": "Overall query timeout in seconds.",
            "schema": {
              "type": "number",
              "default": 20.0
            }
          },
          {
            "name": "async",
            "in": "query",
            "required": false,
            "description": "Enable asynchronous mode to return partial results.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "reinterpret",
            "in": "query",
            "required": false,
            "description": "Allow query reinterpretation if initial interpretation fails.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "translation",
            "in": "query",
            "required": false,
            "description": "Enable translation attempts for non-English queries.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "ignorecase",
            "in": "query",
            "required": false,
            "description": "Ignore case sensitivity in input.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "assumption",
            "in": "query",
            "required": false,
            "description": "Specify assumptions about query meaning.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "podstate",
            "in": "query",
            "required": false,
            "description": "Modify pod display state.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful query result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResult"
                }
              },
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing required parameters",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing AppID",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1/result": {
      "get": {
        "operationId": "getShortAnswer",
        "summary": "Get a short text answer",
        "description": "Returns a single plain text answer extracted from the Wolfram|Alpha Result pod. Ideal for quick factual lookups.",
        "tags": [
          "Short Answers"
        ],
        "parameters": [
          {
            "name": "appid",
            "in": "query",
            "required": true,
            "description": "Application ID obtained from the Wolfram|Alpha Developer Portal.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "i",
            "in": "query",
            "required": true,
            "description": "URL-encoded input query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "units",
            "in": "query",
            "required": false,
            "description": "Measurement system preference.",
            "schema": {
              "type": "string",
              "enum": [
                "metric",
                "imperial"
              ]
            }
          },
          {
            "name": "timeout",
            "in": "query",
            "required": false,
            "description": "Maximum processing time in seconds.",
            "schema": {
              "type": "number",
              "default": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Plain text answer",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                },
                "example": "186.2 miles"
              }
            }
          },
          "400": {
            "description": "Missing input parameter or incorrect syntax"
          },
          "501": {
            "description": "Query cannot be interpreted - misspelled, poorly formatted, or restricted topic"
          }
        }
      }
    },
    "/v1/simple": {
      "get": {
        "operationId": "getSimpleImage",
        "summary": "Get result as an image",
        "description": "Returns a single static image containing formatted Wolfram|Alpha results. Does not support disambiguation, drilldown, or asynchronous delivery.",
        "tags": [
          "Simple"
        ],
        "parameters": [
          {
            "name": "appid",
            "in": "query",
            "required": true,
            "description": "Application ID obtained from the Wolfram|Alpha Developer Portal.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "i",
            "in": "query",
            "required": true,
            "description": "URL-encoded input query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "layout",
            "in": "query",
            "required": false,
            "description": "Controls content presentation format.",
            "schema": {
              "type": "string",
              "enum": [
                "divider",
                "labelbar"
              ],
              "default": "divider"
            }
          },
          {
            "name": "background",
            "in": "query",
            "required": false,
            "description": "Background color as HTML color name, hex RGB, or decimal RGB.",
            "schema": {
              "type": "string",
              "default": "white"
            }
          },
          {
            "name": "foreground",
            "in": "query",
            "required": false,
            "description": "Text color for readability.",
            "schema": {
              "type": "string",
              "enum": [
                "black",
                "white"
              ],
              "default": "black"
            }
          },
          {
            "name": "fontsize",
            "in": "query",
            "required": false,
            "description": "Font size in points.",
            "schema": {
              "type": "integer",
              "default": 14
            }
          },
          {
            "name": "width",
            "in": "query",
            "required": false,
            "description": "Output image width in pixels.",
            "schema": {
              "type": "integer",
              "default": 500
            }
          },
          {
            "name": "units",
            "in": "query",
            "required": false,
            "description": "Measurement system preference.",
            "schema": {
              "type": "string",
              "enum": [
                "metric",
                "imperial"
              ]
            }
          },
          {
            "name": "timeout",
            "in": "query",
            "required": false,
            "description": "Maximum processing time in seconds.",
            "schema": {
              "type": "number",
              "default": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Image containing formatted results",
            "content": {
              "image/gif": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Missing input parameter or incorrect syntax"
          },
          "501": {
            "description": "Query cannot be interpreted"
          }
        }
      }
    },
    "/v1/spoken": {
      "get": {
        "operationId": "getSpokenResult",
        "summary": "Get spoken text result",
        "description": "Returns a plain text conversational sentence optimized for text-to-speech delivery.",
        "tags": [
          "Spoken Results"
        ],
        "parameters": [
          {
            "name": "appid",
            "in": "query",
            "required": true,
            "description": "Application ID obtained from the Wolfram|Alpha Developer Portal.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "i",
            "in": "query",
            "required": true,
            "description": "URL-encoded input query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "units",
            "in": "query",
            "required": false,
            "description": "Measurement system preference.",
            "schema": {
              "type": "string",
              "enum": [
                "metric",
                "imperial"
              ]
            }
          },
          {
            "name": "timeout",
            "in": "query",
            "required": false,
            "description": "Maximum processing time in seconds.",
            "schema": {
              "type": "number",
              "default": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversational plain text answer optimized for speech",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                },
                "example": "The distance from the center of New York City, New York to the center of Los Angeles, California is about 2464 miles."
              }
            }
          },
          "400": {
            "description": "Missing input parameter or incorrect syntax"
          },
          "501": {
            "description": "Query cannot be interpreted"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QueryResult": {
        "type": "object",
        "description": "Full results response from the Wolfram|Alpha computational engine.",
        "properties": {
          "queryresult": {
            "type": "object",
            "properties": {
              "success": {
                "type": "boolean",
                "description": "Whether the query was successfully interpreted."
              },
              "error": {
                "type": "boolean",
                "description": "Whether a processing error occurred."
              },
              "numpods": {
                "type": "integer",
                "description": "Number of pods returned."
              },
              "timing": {
                "type": "number",
                "description": "Wall-clock execution time in seconds."
              },
              "parsetiming": {
                "type": "number",
                "description": "Query parsing duration in seconds."
              },
              "pods": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Pod"
                }
              }
            }
          }
        }
      },
      "Pod": {
        "type": "object",
        "description": "A result category containing related data.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the pod."
          },
          "title": {
            "type": "string",
            "description": "Descriptive heading for the pod."
          },
          "scanner": {
            "type": "string",
            "description": "Component type that generated the pod."
          },
          "position": {
            "type": "integer",
            "description": "Display order (multiples of 100)."
          },
          "primary": {
            "type": "boolean",
            "description": "Whether this is marked as the primary result."
          },
          "error": {
            "type": "boolean",
            "description": "Whether this pod encountered an error."
          },
          "subpods": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Subpod"
            }
          }
        }
      },
      "Subpod": {
        "type": "object",
        "description": "Individual data unit within a pod.",
        "properties": {
          "title": {
            "type": "string"
          },
          "img": {
            "type": "object",
            "properties": {
              "src": {
                "type": "string",
                "format": "uri"
              },
              "alt": {
                "type": "string"
              },
              "width": {
                "type": "integer"
              },
              "height": {
                "type": "integer"
              }
            }
          },
          "plaintext": {
            "type": "string",
            "description": "Plain text representation of the result."
          }
        }
      }
    },
    "securitySchemes": {
      "appId": {
        "type": "apiKey",
        "in": "header",
        "name": "appId"
      }
    }
  }
}
