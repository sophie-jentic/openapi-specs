    "title": "Xignite Global Quotes API",
    "version": "1.0.0",
    "description": "Xignite provides cloud-based financial market data APIs. The Global Quotes API delivers delayed and real-time stock quotes for global equities, currency exchange rates, historical prices, fund NAVs, commodities, indices, bonds, and more across multiple specialized sub-APIs.",
    "x-jentic-source-url": "https://www.xignite.com/products/",
    "contact": {
      "name": "API Support"
    }
  },
