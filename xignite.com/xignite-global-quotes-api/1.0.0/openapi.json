    {
      "url": "https://globalquotes.xignite.com"
    }
  ],
  "paths": {
    "/xGlobalQuotes.json/GetGlobalDelayedQuote": {
      "get": {
        "operationId": "getGlobalDelayedQuote",
        "summary": "Get global delayed quote",
        "description": "Returns a delayed quote for a global equity.",
        "tags": [
          "Global Quotes"
        ],
        "parameters": [
          {
            "name": "IdentifierType",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "Symbol",
                "ISIN",
                "SEDOL",
                "CUSIP",
                "CIK"
              ]
            }
          },
          {
            "name": "Identifier",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_Token",
            "in": "query",
            "required": true,
            "description": "API authentication token",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GlobalQuote"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
