{
  "openapi": "3.0.3",
  "info": {
    "title": "3D Bin Packing API",
    "description": "Optimize packing of items into bins, pallets, and containers. Supports multiple optimization modes (minimize bins, maximize utilization, minimize cost), 3D coordinate placement, weight constraints, item grouping, and visual output generation (SVG/PNG). Maximum 4,999 total items per request.",
    "version": "1.0.0",
    "contact": {
      "name": "3D Bin Packing",
      "url": "https://www.3dbinpacking.com"
    }
  },
  "servers": [
    {
      "url": "https://global-api.3dbinpacking.com",
      "description": "Global (load-balanced)"
    },
    {
      "url": "https://us-east.api.3dbinpacking.com",
      "description": "US East (Virginia)"
    },
    {
      "url": "https://eu.api.3dbinpacking.com",
      "description": "Europe (Ireland)"
    },
    {
      "url": "https://asia1.api.3dbinpacking.com",
      "description": "Asia Pacific (Singapore)"
    }
  ],
  "security": [
    {
      "UsernameApiKey": []
    }
  ],
  "paths": {
    "/packer/packIntoMany": {
      "post": {
        "operationId": "packIntoMany",
        "summary": "Pack items into multiple bins",
        "description": "Optimize packing of items into multiple bins by quantity, space utilization, or cost. Returns packed bin layouts with 3D coordinates and optional visualization images.",
        "tags": [
          "Packing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PackIntoManyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Packing result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PackResponse"
                }
              }
            }
          }
        }
      }
    },
    "/packer/palletPack": {
      "post": {
        "operationId": "palletPack",
        "summary": "Stack items on pallets",
        "description": "Optimize pallet stacking for transport and storage. Similar to packIntoMany but designed for pallet-based workflows.",
        "tags": [
          "Packing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PalletPackRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pallet packing result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PalletPackResponse"
                }
              }
            }
          }
        }
      }
    },
    "/packer/findSmallestBin": {
      "post": {
        "operationId": "findSmallestBin",
        "summary": "Find missing container dimension",
        "description": "Calculate an unknown container dimension (width, height, or depth) given the items to pack and the other known dimensions.",
        "tags": [
          "Dimension Calculation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindSmallestBinRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Smallest bin result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindBinResponse"
                }
              }
            }
          }
        }
      }
    },
    "/packer/findBinSize": {
      "post": {
        "operationId": "findBinSize",
        "summary": "Find optimal box size",
        "description": "Calculate optimal container dimensions from items alone, without providing any container specification.",
        "tags": [
          "Dimension Calculation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindBinSizeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Optimal bin size result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindBinResponse"
                }
              }
            }
          }
        }
      }
    },
    "/packer/tryOutBoxSizes": {
      "post": {
        "operationId": "tryOutBoxSizes",
        "summary": "Try various box configurations",
        "description": "Test multiple box size configurations to find optimal packing arrangements.",
        "tags": [
          "Packing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TryOutBoxSizesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Box size trial results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PackResponse"
                }
              }
            }
          }
        }
      }
    },
    "/packer/checkMaxLoad": {
      "post": {
        "operationId": "checkMaxLoad",
        "summary": "Validate weight constraints",
        "description": "Check and validate maximum weight constraints for packing configurations.",
        "tags": [
          "Validation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckMaxLoadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Weight validation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PackResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "UsernameApiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "username",
        "description": "Username and API key obtained from Profile Settings / API Access after registration. Both 'username' and 'api_key' query parameters are required."
      }
    },
    "schemas": {
      "Item": {
        "type": "object",
        "required": [
          "id",
          "w",
          "h",
          "d",
          "q",
          "wg"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique item identifier"
          },
          "w": {
            "type": "number",
            "description": "Width of the item"
          },
          "h": {
            "type": "number",
            "description": "Height of the item"
          },
          "d": {
            "type": "number",
            "description": "Depth of the item"
          },
          "wg": {
            "type": "number",
            "description": "Weight of the item"
          },
          "q": {
            "type": "integer",
            "description": "Quantity of this item",
            "minimum": 1
          },
          "vr": {
            "type": "boolean",
            "description": "Whether vertical rotation is allowed",
            "default": true
          },
          "group": {
            "type": "string",
            "description": "Grouping identifier for item separation"
          },
          "separate": {
            "type": "integer",
            "description": "Prevent mixed packing with other items (0 or 1)",
            "enum": [
              0,
              1
            ],
            "default": 0
          },
          "limit_per_bin": {
            "type": "integer",
            "description": "Maximum number of this item per container"
          },
          "acceptable_bins": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of bin IDs that can hold this item"
          }
        }
      },
      "Bin": {
        "type": "object",
        "required": [
          "id",
          "w",
          "h",
          "d",
          "max_wg"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique bin identifier"
          },
          "w": {
            "type": "number",
            "description": "Width of the bin"
          },
          "h": {
            "type": "number",
            "description": "Height of the bin"
          },
          "d": {
            "type": "number",
            "description": "Depth of the bin"
          },
          "max_wg": {
            "type": "number",
            "description": "Maximum weight limit (0 = unlimited)",
            "default": 0
          },
          "cost": {
            "type": "number",
            "description": "Cost of this bin (used with cost optimization mode)"
          },
          "quantity": {
            "type": "integer",
            "description": "Available quantity of this bin type"
          }
        }
      },
      "ImageParams": {
        "type": "object",
        "properties": {
          "images_format": {
            "type": "string",
            "enum": [
              "svg",
              "png"
            ],
            "description": "Image output format"
          },
          "images_width": {
            "type": "integer",
            "description": "Image width in pixels (1-250)",
            "minimum": 1,
            "maximum": 250
          },
          "images_height": {
            "type": "integer",
            "description": "Image height in pixels (1-250)",
            "minimum": 1,
            "maximum": 250
          },
          "images_version": {
            "type": "integer",
            "enum": [
              1,
              2
            ],
            "description": "Image rendering version"
          },
          "images_sbs": {
            "type": "integer",
            "enum": [
              0,
              1
            ],
            "description": "Generate step-by-step images (0 = no, 1 = yes)"
          },
          "images_complete": {
            "type": "integer",
            "enum": [
              0,
              1
            ],
            "description": "Generate final result visualization (0 = no, 1 = yes)"
          },
          "images_separated": {
            "type": "integer",
            "enum": [
              0,
              1
            ],
            "description": "Generate individual item placement images (0 = no, 1 = yes)"
          }
        }
      },
      "PackIntoManyRequest": {
        "type": "object",
        "required": [
          "username",
          "api_key",
          "items",
          "bins"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "API username from Profile Settings"
          },
          "api_key": {
            "type": "string",
            "description": "API key from Profile Settings"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            },
            "description": "Array of items to pack"
          },
          "bins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Bin"
            },
            "description": "Array of available bins"
          },
          "optimization_mode": {
            "type": "string",
            "enum": [
              "bins_number",
              "bins_utilization",
              "cost"
            ],
            "default": "bins_number",
            "description": "Optimization strategy: minimize bin count, maximize utilization, or minimize cost"
          },
          "images_format": {
            "type": "string",
            "enum": [
              "svg",
              "png"
            ]
          },
          "images_width": {
            "type": "integer",
            "minimum": 1,
            "maximum": 250
          },
          "images_height": {
            "type": "integer",
            "minimum": 1,
            "maximum": 250
          },
          "images_version": {
            "type": "integer",
            "enum": [
              1,
              2
            ]
          },
          "images_sbs": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          },
          "images_complete": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          },
          "images_separated": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          }
        }
      },
      "PalletPackRequest": {
        "type": "object",
        "required": [
          "username",
          "api_key",
          "items",
          "bins"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "API username from Profile Settings"
          },
          "api_key": {
            "type": "string",
            "description": "API key from Profile Settings"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            },
            "description": "Array of items to stack on pallets"
          },
          "bins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Bin"
            },
            "description": "Pallet definitions"
          },
          "images_format": {
            "type": "string",
            "enum": [
              "svg",
              "png"
            ]
          },
          "images_width": {
            "type": "integer",
            "minimum": 1,
            "maximum": 250
          },
          "images_height": {
            "type": "integer",
            "minimum": 1,
            "maximum": 250
          },
          "images_version": {
            "type": "integer",
            "enum": [
              1,
              2
            ]
          },
          "images_sbs": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          },
          "images_complete": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          },
          "images_separated": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          }
        }
      },
      "FindSmallestBinRequest": {
        "type": "object",
        "required": [
          "username",
          "api_key",
          "items",
          "bins",
          "find"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "API username from Profile Settings"
          },
          "api_key": {
            "type": "string",
            "description": "API key from Profile Settings"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            },
            "description": "Array of items to pack"
          },
          "bins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Bin"
            },
            "description": "Bin definitions with partial dimensions"
          },
          "find": {
            "type": "string",
            "enum": [
              "w",
              "h",
              "d"
            ],
            "description": "Which dimension to calculate (w = width, h = height, d = depth)"
          }
        }
      },
      "FindBinSizeRequest": {
        "type": "object",
        "required": [
          "username",
          "api_key",
          "items"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "API username from Profile Settings"
          },
          "api_key": {
            "type": "string",
            "description": "API key from Profile Settings"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            },
            "description": "Array of items to pack"
          }
        }
      },
      "TryOutBoxSizesRequest": {
        "type": "object",
        "required": [
          "username",
          "api_key",
          "items",
          "bins"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "API username from Profile Settings"
          },
          "api_key": {
            "type": "string",
            "description": "API key from Profile Settings"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            },
            "description": "Array of items to pack"
          },
          "bins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Bin"
            },
            "description": "Array of box sizes to try"
          }
        }
      },
      "CheckMaxLoadRequest": {
        "type": "object",
        "required": [
          "username",
          "api_key",
          "items",
          "bins"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "API username from Profile Settings"
          },
          "api_key": {
            "type": "string",
            "description": "API key from Profile Settings"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            },
            "description": "Array of items to validate"
          },
          "bins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Bin"
            },
            "description": "Bin definitions with weight constraints"
          }
        }
      },
      "Coordinates": {
        "type": "object",
        "properties": {
          "x1": {
            "type": "number"
          },
          "y1": {
            "type": "number"
          },
          "z1": {
            "type": "number"
          },
          "x2": {
            "type": "number"
          },
          "y2": {
            "type": "number"
          },
          "z2": {
            "type": "number"
          }
        }
      },
      "PackedItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Item identifier"
          },
          "w": {
            "type": "number",
            "description": "Width as packed"
          },
          "h": {
            "type": "number",
            "description": "Height as packed"
          },
          "d": {
            "type": "number",
            "description": "Depth as packed"
          },
          "wg": {
            "type": "number",
            "description": "Weight"
          },
          "coordinates": {
            "$ref": "#/components/schemas/Coordinates"
          },
          "image_sbs": {
            "type": "string",
            "description": "URL of step-by-step image"
          },
          "image_separated": {
            "type": "string",
            "description": "URL of separated item image"
          },
          "image_complete": {
            "type": "string",
            "description": "URL of complete packing image"
          }
        }
      },
      "PackedBin": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Bin identifier"
          },
          "w": {
            "type": "number",
            "description": "Bin width"
          },
          "h": {
            "type": "number",
            "description": "Bin height"
          },
          "d": {
            "type": "number",
            "description": "Bin depth"
          },
          "used_space": {
            "type": "number",
            "description": "Percentage of space utilized"
          },
          "weight": {
            "type": "number",
            "description": "Total item weight in this bin"
          },
          "gross_weight": {
            "type": "number",
            "description": "Total weight including container"
          },
          "used_weight": {
            "type": "number",
            "description": "Percentage of max weight limit used"
          },
          "stack_height": {
            "type": "number",
            "description": "Height of stacked contents"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PackedItem"
            },
            "description": "Items packed in this bin with placement coordinates"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "level": {
            "type": "string",
            "enum": [
              "critical",
              "warning"
            ],
            "description": "Error severity level"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      },
      "PackResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "enum": [
              0,
              1
            ],
            "description": "1 = success (no critical errors), 0 = critical errors present"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Error"
            }
          },
          "bins_packed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PackedBin"
            },
            "description": "Bins with packed items and placement data"
          },
          "not_packed_items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PackedItem"
            },
            "description": "Items that could not be packed"
          }
        }
      },
      "PalletPackResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "enum": [
              0,
              1
            ],
            "description": "1 = success (no critical errors), 0 = critical errors present"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Error"
            }
          },
          "pallets_packed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PackedBin"
            },
            "description": "Pallets with packed items and placement data"
          },
          "not_packed_items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PackedItem"
            },
            "description": "Items that could not be packed"
          }
        }
      },
      "FindBinResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "enum": [
              0,
              1
            ],
            "description": "1 = success, 0 = critical errors"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Error"
            }
          },
          "bins_packed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PackedBin"
            },
            "description": "Calculated bin dimensions with packed items"
          },
          "not_packed_items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PackedItem"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Dimension Calculation"
    },
    {
      "name": "Packing"
    },
    {
      "name": "Validation"
    }
  ]
}
