{
  "openapi": "3.0.3",
  "info": {
    "title": "Maxio (Chargify) API",
    "version": "1.0.0",
    "description": "Maxio (formerly Chargify) is a subscription management and recurring billing platform. The API provides endpoints for managing subscriptions, customers, products, components, payments, invoices, and more. All API requests use JSON format.",
    "x-jentic-source-url": "https://developer.maxio.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{subdomain}.chargify.com",
      "description": "Maxio Chargify API",
      "variables": {
        "subdomain": {
          "default": "yoursite",
          "description": "Your Chargify subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Subscriptions",
      "description": "Subscription management"
    },
    {
      "name": "Customers",
      "description": "Customer management"
    },
    {
      "name": "Products",
      "description": "Product catalog"
    },
    {
      "name": "Product Families",
      "description": "Product family management"
    },
    {
      "name": "Components",
      "description": "Metered and quantity-based components"
    },
    {
      "name": "Invoices",
      "description": "Invoice management"
    },
    {
      "name": "Payments",
      "description": "Payment management"
    }
  ],
  "paths": {
    "/subscriptions.json": {
      "get": {
        "operationId": "listSubscriptions",
        "summary": "List subscriptions",
        "description": "Returns a paginated list of all subscriptions.",
        "tags": [
          "Subscriptions"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 200
            },
            "description": "Results per page"
          },
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "canceled",
                "expired",
                "on_hold",
                "past_due",
                "soft_failure",
                "trialing",
                "trial_ended",
                "unpaid"
              ]
            },
            "description": "Filter by subscription state"
          },
          {
            "name": "product",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by product ID"
          },
          {
            "name": "date_field",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "current_period_ends_at",
                "current_period_starts_at",
                "created_at",
                "activated_at",
                "canceled_at",
                "expires_at",
                "trial_started_at",
                "trial_ended_at",
                "updated_at"
              ]
            },
            "description": "Date field to filter on"
          },
          {
            "name": "start_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Filter start date"
          },
          {
            "name": "end_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Filter end date"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "signup_date",
                "period_start",
                "period_end",
                "next_assessment",
                "state",
                "created_at",
                "updated_at"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of subscriptions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "subscription": {
                        "$ref": "#/components/schemas/Subscription"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createSubscription",
        "summary": "Create a subscription",
        "description": "Creates a new subscription for a customer.",
        "tags": [
          "Subscriptions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "subscription": {
                    "$ref": "#/components/schemas/CreateSubscriptionRequest"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Subscription created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subscription": {
                      "$ref": "#/components/schemas/Subscription"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable entity",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
