        },
        "type": {
          "description": "Customer type.",
          "type": "string"
        }
      }
    },
    "Account": {
      "properties": {
        "number": {
          "description": "Customer's account number.",
          "type": "string"
        },
        "currency": {
          "description": "Account currency.",
          "type": "string"
        },
        "status": {
          "description": "Account Status",
          "type": "string"
        }
      }
    },
    "Balance": {
      "properties": {
        "amount": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      }
    },
    "FullStatementResponse": {
      "properties": {
        "accountNumber": {
          "description": "The account number.",
          "type": "string"
        },
        "currency": {
          "description": "The account currency.",
          "type": "string"
        },
        "balance": {
          "description": "The account balance.",
          "type": "string"
        },
        "transactions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/FullStatementTransaction"
          }
        }
      }
    },
    "GetMiniStatementResponse": {
      "properties": {
        "accountNumber": {
          "description": "Account number",
          "type": "string"
        },
        "currency": {
          "description": "Account currency.",
          "type": "string"
        },
        "balance": {
          "description": "Account balance.",
          "type": "string"
        },
        "transactions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/MiniStatementTransaction"
          }
        }
      }
    },
    "AccountEnquiryResponse": {
      "properties": {
        "account": {
