            "description": "File details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileViewResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid lookup term"
          },
          "404": {
            "description": "File not found"
          }
        },
        "description": "View file details by SHA256"
      }
    },
    "/files/view/id/{id}/": {
      "get": {
        "operationId": "viewFileById",
        "summary": "View file details by ID",
        "tags": [
          "Files"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileViewResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid lookup term"
          },
          "404": {
            "description": "File not found"
          }
        },
        "description": "View file details by ID"
      }
    },
    "/files/get/{sha256}/": {
      "get": {
        "operationId": "downloadFile",
        "summary": "Download file by SHA256",
        "description": "Returns the binary content of the file matching the specified SHA256 hash.",
        "tags": [
          "Files"
        ],
        "parameters": [
          {
            "name": "sha256",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File binary content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "File not found"
          }
        }
      }
    },
    "/pcap/get/{task}/": {
      "get": {
        "operationId": "downloadPcap",
        "summary": "Download PCAP file",
        "description": "Returns the network capture (PCAP) associated with the given task.",
        "tags": [
          "Files"
        ],
        "parameters": [
          {
            "name": "task",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PCAP file content",
            "content": {
              "application/vnd.tcpdump.pcap": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "File not found"
          }
        }
      }
    },
    "/machines/list/": {
      "get": {
        "operationId": "listMachines",
        "summary": "List analysis machines",
        "description": "Returns a list with details on the analysis machines available.",
        "tags": [
          "Machines"
        ],
        "responses": {
          "200": {
            "description": "List of machines",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MachineListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/machines/view/{name}/": {
      "get": {
        "operationId": "viewMachine",
        "summary": "View machine details",
        "description": "Returns details on the analysis machine associated with the given name.",
        "tags": [
          "Machines"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Machine details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MachineViewResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Machine not found"
          }
        }
      }
    },
    "/cuckoo/status/": {
      "get": {
        "operationId": "getStatus",
        "summary": "Get sandbox status",
        "description": "Returns the basic status of the sandbox, including version and tasks overview.",
        "tags": [
          "Status"
        ],
        "responses": {
          "200": {
            "description": "Sandbox status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api-token-auth/": {
      "post": {
        "operationId": "getToken",
        "summary": "Get authentication token",
        "description": "Authenticate and retrieve an API token using username and password.",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string",
                    "format": "password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid credentials"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TaskCreateResponse": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "integer",
            "description": "ID of the newly created task"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "category": {
            "type": "string",
            "description": "Task category (file, url)"
          },
          "target": {
            "type": "string",
            "description": "Analysis target (file path or URL)"
          },
          "machine": {
            "type": "string"
          },
          "package": {
            "type": "string"
          },
          "sample_id": {
            "type": "integer"
          },
          "guest": {
            "type": "object"
          },
          "custom": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "platform": {
            "type": "string"
          },
          "options": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "description": "Task status (pending, running, completed, reported)"
          },
          "enforce_timeout": {
            "type": "boolean"
          },
          "timeout": {
            "type": "integer"
          },
          "memory": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "added_on": {
            "type": "string",
            "format": "date-time"
          },
          "completed_on": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TaskListResponse": {
        "type": "object",
        "properties": {
          "tasks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Task"
            }
          }
        }
      },
      "TaskViewResponse": {
        "type": "object",
        "properties": {
          "task": {
            "$ref": "#/components/schemas/Task"
          }
        }
      },
      "FileViewResponse": {
        "type": "object",
        "properties": {
          "sample": {
            "$ref": "#/components/schemas/Sample"
          }
        }
      },
      "Sample": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "md5": {
            "type": "string"
          },
          "sha1": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "sha512": {
            "type": "string"
          },
          "crc32": {
            "type": "string"
          },
          "ssdeep": {
            "type": "string"
          },
          "file_size": {
            "type": "integer"
          },
          "file_type": {
            "type": "string"
          }
        }
      },
      "Machine": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "ip": {
            "type": "string"
          },
          "platform": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "locked": {
            "type": "boolean"
          },
          "locked_changed_on": {
            "type": "string"
          },
          "status_changed_on": {
            "type": "string"
          },
          "resultserver_ip": {
            "type": "string"
          },
          "resultserver_port": {
            "type": "string"
          },
          "interface": {
            "type": "string"
          },
          "snapshot": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "MachineListResponse": {
        "type": "object",
        "properties": {
          "machines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Machine"
            }
          }
        }
      },
      "MachineViewResponse": {
        "type": "object",
        "properties": {
          "machine": {
            "$ref": "#/components/schemas/Machine"
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string"
          },
          "protocol_version": {
            "type": "integer"
          },
          "hostname": {
            "type": "string"
          },
          "tasks": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer"
              },
              "pending": {
                "type": "integer"
              },
              "running": {
                "type": "integer"
              },
              "completed": {
                "type": "integer"
              },
              "reported": {
                "type": "integer"
              }
            }
          },
          "machines": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer"
              },
              "available": {
                "type": "integer"
              }
            }
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    },
