{
  "openapi": "3.0.3",
  "info": {
    "title": "CAPE Sandbox API",
    "version": "2.0.0",
    "description": "CAPE (Config And Payload Extraction) Sandbox REST API for automated malware analysis. Supports submitting samples (files and URLs), retrieving analysis reports, screenshots, PCAP files, and managing analysis machines.",
    "x-jentic-source-url": "https://capev2.readthedocs.io/en/latest/usage/api.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://capesandbox.com/apiv2"
    }
  ],
  "paths": {
    "/tasks/create/file/": {
      "post": {
        "operationId": "createFileTask",
        "summary": "Submit a file for analysis",
        "description": "Adds a file to the list of pending tasks to be processed and analyzed. Returns the ID of the newly created task.",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Sample file to analyze"
                  },
                  "package": {
                    "type": "string",
                    "description": "Analysis package to use"
                  },
                  "timeout": {
                    "type": "integer",
                    "description": "Analysis timeout in seconds"
                  },
                  "priority": {
                    "type": "integer",
                    "description": "Task priority (1-3)",
                    "minimum": 1,
                    "maximum": 3
                  },
                  "options": {
                    "type": "string",
                    "description": "Options to pass to the analysis package"
                  },
                  "machine": {
                    "type": "string",
                    "description": "ID of the analysis machine to use"
                  },
                  "platform": {
                    "type": "string",
                    "description": "Platform name (e.g., windows)"
                  },
                  "tags": {
                    "type": "string",
                    "description": "Comma-separated machine tags"
                  },
                  "custom": {
                    "type": "string",
                    "description": "Custom string to pass to processing modules"
                  },
                  "memory": {
                    "type": "boolean",
                    "description": "Enable full memory dump"
                  },
                  "enforce_timeout": {
                    "type": "boolean",
                    "description": "Enforce full timeout execution"
                  },
                  "clock": {
                    "type": "string",
                    "description": "Virtual machine clock (format: %m-%d-%Y %H:%M:%S)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskCreateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/create/url/": {
      "post": {
        "operationId": "createUrlTask",
        "summary": "Submit a URL for analysis",
        "description": "Adds a URL to the list of pending tasks to be processed and analyzed.",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to analyze"
                  },
                  "package": {
                    "type": "string"
                  },
                  "timeout": {
                    "type": "integer"
                  },
                  "priority": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 3
                  },
                  "options": {
                    "type": "string"
                  },
                  "machine": {
                    "type": "string"
                  },
                  "platform": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "string"
                  },
                  "custom": {
                    "type": "string"
                  },
                  "memory": {
                    "type": "boolean"
                  },
                  "enforce_timeout": {
                    "type": "boolean"
                  },
                  "clock": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskCreateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tasks/list/": {
      "get": {
        "operationId": "listTasks",
        "summary": "List analysis tasks",
        "description": "Returns a list of tasks stored in the database.",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of returned tasks",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Data offset",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of tasks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tasks/view/{id}/": {
      "get": {
        "operationId": "viewTask",
        "summary": "View task details",
        "description": "Returns details on the task associated with the specified ID.",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskViewResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Task not found"
          }
        }
      }
    },
    "/tasks/delete/{id}/": {
      "get": {
        "operationId": "deleteTask",
        "summary": "Delete a task",
        "description": "Removes the given task from the database and deletes the results.",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Task not found"
          },
          "500": {
            "description": "Unable to delete the task"
          }
        }
      }
    },
    "/tasks/report/{id}/": {
      "get": {
        "operationId": "getTaskReport",
        "summary": "Get analysis report",
        "description": "Returns the report generated from the analysis. Defaults to JSON format.",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Analysis report",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Invalid report format"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Report not found"
          }
        }
      }
    },
    "/tasks/report/{id}/{format}/": {
      "get": {
        "operationId": "getTaskReportFormatted",
        "summary": "Get analysis report in specific format",
        "description": "Returns the report in the specified format (json, html, maec, metadata, all, dropped).",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "format",
            "in": "path",
            "required": true,
            "description": "Report format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "html",
                "maec",
                "metadata",
                "all",
                "dropped"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Analysis report in requested format"
          },
          "400": {
            "description": "Invalid report format"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Report not found"
          }
        }
      }
    },
    "/tasks/screenshots/{id}/": {
      "get": {
        "operationId": "getTaskScreenshots",
        "summary": "Get task screenshots",
        "description": "Retrieves all screenshots associated with a given analysis task ID.",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Screenshots archive",
            "content": {
              "application/zip": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "File or folder not found"
          }
        }
      }
    },
    "/tasks/screenshots/{id}/{screenshot}/": {
      "get": {
        "operationId": "getTaskScreenshot",
        "summary": "Get a specific screenshot",
        "description": "Retrieves a specific screenshot by its numerical identifier.",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "screenshot",
            "in": "path",
            "required": true,
            "description": "Screenshot number (e.g., 0001)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Screenshot image",
            "content": {
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "File not found"
          }
        }
      }
    },
    "/files/view/md5/{md5}/": {
      "get": {
        "operationId": "viewFileByMd5",
        "summary": "View file details by MD5",
        "tags": [
          "Files"
        ],
        "parameters": [
          {
            "name": "md5",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File details",
