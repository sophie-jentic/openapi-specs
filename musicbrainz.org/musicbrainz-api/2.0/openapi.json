{
  "openapi": "3.1.0",
  "info": {
    "title": "MusicBrainz API",
    "version": "2.0",
    "description": "The MusicBrainz API provides access to the MusicBrainz Database of music metadata. It supports lookup, browse, and search operations for areas, artists, events, genres, instruments, labels, places, recordings, releases, release-groups, series, works, and URLs. Responses are available in XML (default) and JSON formats.",
    "contact": {
      "name": "MusicBrainz",
      "url": "https://musicbrainz.org/doc/MusicBrainz_API"
    },
    "x-apisguru-categories": [
      "media"
    ],
    "x-logo": {
      "url": "https://musicbrainz.org/static/images/entity/artist.svg"
    }
  },
  "servers": [
    {
      "url": "https://musicbrainz.org/ws/2"
    }
  ],
  "security": [],
  "components": {
    "securitySchemes": {
      "digestAuth": {
        "type": "http",
        "scheme": "digest",
        "description": "Required for data submission and user-specific requests."
      }
    },
    "schemas": {
      "ArtistResult": {
        "type": "object",
        "properties": {
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "count": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "artists": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Artist"
            }
          }
        }
      },
      "Artist": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "type": {
            "type": "string"
          },
          "type-id": {
            "type": "string"
          },
          "score": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "sort-name": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "area": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "begin-area": {
            "type": "object"
          },
          "disambiguation": {
            "type": "string"
          },
          "life-span": {
            "type": "object",
            "properties": {
              "begin": {
                "type": "string"
              },
              "end": {
                "type": "string"
              },
              "ended": {
                "type": "boolean"
              }
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "count": {
                  "type": "integer"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "count": {
                  "type": "integer"
                },
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Release": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "barcode": {
            "type": "string"
          },
          "artist-credit": {
            "type": "array",
            "items": {
