          },
          "title": {
            "type": "string"
          },
          "primary-type": {
            "type": "string"
          },
          "secondary-types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "first-release-date": {
            "type": "string"
          },
          "artist-credit": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
