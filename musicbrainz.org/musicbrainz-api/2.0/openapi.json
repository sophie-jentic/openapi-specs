      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "created": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          }
        }
      }
    },
    "parameters": {
      "fmt": {
        "name": "fmt",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": [
            "json",
            "xml"
          ]
        },
        "description": "Response format."
      },
      "inc": {
        "name": "inc",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Subquery includes, separated by +."
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 25,
          "maximum": 100
        }
      },
      "offset": {
        "name": "offset",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 0
        }
      }
    }
  },
  "paths": {
    "/artist/{mbid}": {
      "get": {
        "operationId": "lookupArtist",
        "summary": "Lookup an artist by MBID",
        "tags": [
          "Lookup"
        ],
        "parameters": [
          {
            "name": "mbid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "$ref": "#/components/parameters/inc"
          },
          {
            "$ref": "#/components/parameters/fmt"
          }
        ],
        "responses": {
          "200": {
            "description": "Artist details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Artist"
                }
              }
            }
          }
        },
        "description": "Lookup an artist by MBID"
      }
    },
    "/artist": {
      "get": {
        "operationId": "searchArtists",
        "summary": "Search for artists",
