          "disambiguation": {
            "type": "string"
          },
          "video": {
            "type": "boolean"
          },
          "artist-credit": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "isrcs": {
            "type": "array",
            "items": {
