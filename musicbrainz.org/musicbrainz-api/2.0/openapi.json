          },
          "language": {
            "type": "string"
          },
          "iswcs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "disambiguation": {
            "type": "string"
          },
          "relations": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Genre": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "disambiguation": {
            "type": "string"
          }
