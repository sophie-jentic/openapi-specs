  "components": {
    "schemas": {
      "CallInput": {
        "type": "object",
        "required": [
          "recording_s3_key",
          "external_id",
          "direction",
          "performed_at",
          "user_uuid"
        ],
        "properties": {
          "recording_s3_key": {
            "type": "string"
          },
          "external_id": {
            "type": "string"
          },
          "direction": {
            "type": "string"
          },
          "performed_at": {
            "type": "string",
            "format": "date-time"
          },
          "user_uuid": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          }
        }
      },
      "MeetingEventInput": {
        "type": "object",
        "required": [
          "meeting_url",
          "user_uuid",
          "start_time",
          "end_time",
          "organizer",
          "to_record"
        ],
        "properties": {
          "meeting_url": {
            "type": "string"
          },
          "user_uuid": {
            "type": "string"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "organizer": {
            "type": "string"
          },
          "to_record": {
            "type": "boolean"
          },
          "title": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
