    "schemas": {
      "automated_replenishment_task_base": {
        "type": "object",
        "required": [
          "method",
          "pack_size_rounding",
          "created_by"
        ],
        "properties": {
          "site_codes": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "Identifier of the site that the purchase orders will be generated for"
          },
          "supplier_code": {
            "type": "string",
            "description": "Identifier of the supplier that the purchase order will be generated for. If no value is specified then purchase orders will be generated for all suppliers."
          },
          "method": {
            "type": "string",
            "enum": [
              "min_max"
            ],
            "description": "The method used to calculate the requirements for purchase orders."
          },
          "pack_size_rounding": {
            "type": "string",
            "enum": [
              "round_to_nearest",
              "round_up",
              "round_down"
            ]
          },
          "created_by": {
            "type": "string",
            "maxLength": 30,
            "example": "greg",
            "description": "The user that created the task"
          }
        }
      },
      "automated_replenishment_task_create": {
        "$ref": "#/components/schemas/automated_replenishment_task_base"
      },
      "automated_replenishment_task": {
        "allOf": [
          {
            "$ref": "#/components/schemas/automated_replenishment_task_base"
          },
          {
            "type": "object",
            "properties": {
              "task_code": {
                "type": "number",
                "description": "Unique identifier of the automated purchase orders task. Used to retrieve progress of the automated purchase orders job.",
                "example": 45244
              },
              "task_status": {
                "type": "string",
                "enum": [
                  "in_progress",
                  "failed",
                  "complete"
                ],
                "example": "complete"
              },
              "total_number_of_suppliers": {
                "type": "number",
                "example": 163,
                "description": "Total number of suppliers covered by the jobs parameters."
              },
              "count_of_purchase_orders_created": {
                "type": "number",
                "example": 4,
                "description": "Number of purchase orders that have been generated."
              },
              "count_of_purchase_orders_not_created": {
                "type": "number",
                "example": 1,
                "description": "Number of purchase orders that have not been generated."
              },
              "purchase_order_codes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 13,
                  "maxLength": 13
                },
                "example": [
                  "0249990012345",
                  "0249990012346",
                  "0249990012347",
                  "0249990012348"
                ]
              },
              "created": {
                "type": "string",
                "format": "date-time",
                "example": "2024-02-20T12:39:35.734Z",
                "description": "The date and time that the task was created"
              },
              "updated": {
                "type": "string",
                "format": "date-time",
                "example": "2024-02-20T12:41:13.265Z",
                "description": "The date and time that task was last updated"
              }
            }
          }
        ]
      },
      "error_response": {
        "type": "object",
        "required": [
          "error_code",
          "error_message"
        ],
        "properties": {
          "error_code": {
            "type": "string",
            "example": "INVALID_NUMBER_RANGE"
          },
          "error_message": {
            "type": "string",
            "example": "Field sitecode must not be less than 0"
          },
          "error_field": {
            "type": "string",
            "example": "site_code"
          }
        }
      },
      "error_responses": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/error_response"
        }
      }
    },
    "securitySchemes": {
      "application": {
        "type": "apiKey",
        "in": "header",
        "name": "application"
      }
    }
  },
  "tags": [
    {
      "name": "Health Check"
    },
    {
      "name": "automated_replenishment"
    },
    {
      "name": "purchase_order"
    }
  ]
}
