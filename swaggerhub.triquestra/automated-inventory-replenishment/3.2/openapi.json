    "/automated_replenishment/task": {
      "parameters": [
        {
          "$ref": "https://api.swaggerhub.com/domains/Triquestra/infinityapi_common_parameters/3.0.0#/components/parameters/x_logging_id"
        },
        {
          "$ref": "https://api.swaggerhub.com/domains/Triquestra/infinityapi_common_parameters/3.0.0#/components/parameters/x_request_id"
        },
        {
          "$ref": "https://api.swaggerhub.com/domains/Triquestra/infinityapi_common_parameters/3.0.0#/components/parameters/user_agent"
        }
      ],
      "post": {
        "tags": [
          "automated_replenishment"
        ],
        "summary": "Starts a new automated purchase orders task",
        "description": "An automated purchase orders task will asynchronously generate purchase orders. Once a task has been created, the GET endpoint can be used to monitor progress.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/automated_replenishment_task_create"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/automated_replenishment_task"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "409": {
            "$ref": "#/components/responses/409"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          },
          "501": {
            "$ref": "#/components/responses/501"
          }
        },
        "operationId": "post-automated-replenishment-task"
      }
    },
    "/automated_replenishment/task/{task_code}": {
      "parameters": [
        {
          "$ref": "https://api.swaggerhub.com/domains/Triquestra/infinityapi_common_parameters/3.0.0#/components/parameters/x_logging_id"
        },
        {
          "$ref": "https://api.swaggerhub.com/domains/Triquestra/infinityapi_common_parameters/3.0.0#/components/parameters/user_agent"
        },
        {
          "name": "task_code",
          "in": "path",
          "required": true,
          "description": "The unique identifier of Inventory Replenishment task",
          "schema": {
            "type": "number",
            "format": "integer"
          }
        }
      ],
      "get": {
        "tags": [
          "purchase_order"
        ],
        "summary": "Gets an existing purchase_order",
        "responses": {
          "200": {
            "description": "Status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/automated_replenishment_task"
                }
              }
            }
