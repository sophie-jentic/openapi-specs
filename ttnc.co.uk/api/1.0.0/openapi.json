{
  "openapi": "3.0.3",
  "info": {
    "title": "TTNC (Novero) API",
    "version": "1.0.0",
    "description": "XML-based telephony API for managing numbers, calls, voicemail, and telecommunications services",
    "x-jentic-source-url": "https://help.ttnc.co.uk/docs/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://xml.ttnc.co.uk",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "vkeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication operations"
    },
    {
      "name": "Numbers",
      "description": "Number management operations"
    },
    {
      "name": "Calls",
      "description": "Call configuration and management"
    },
    {
      "name": "Cards",
      "description": "Card management operations"
    },
    {
      "name": "CDR",
      "description": "Call detail records"
    },
    {
      "name": "Voicemail",
      "description": "Voicemail configuration"
    }
  ],
  "paths": {
    "/auth": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Authenticate user",
        "description": "Verify API credentials and authenticate user",
        "operationId": "authenticate",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/AuthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/get-numbers": {
      "post": {
        "tags": [
          "Numbers"
        ],
        "summary": "Get numbers",
        "description": "Retrieve list of numbers in account",
        "operationId": "getNumbers",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/GetNumbersRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Numbers retrieved",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/GetNumbersResponse"
                }
              }
            }
          }
        }
      }
    },
    "/delete-number": {
      "post": {
        "tags": [
          "Numbers"
        ],
        "summary": "Delete number",
        "description": "Remove a number from account",
        "operationId": "deleteNumber",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/DeleteNumberRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Number deleted",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/suspend": {
      "post": {
        "tags": [
          "Numbers"
        ],
        "summary": "Suspend number",
        "description": "Suspend a number temporarily",
        "operationId": "suspendNumber",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/NumberActionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Number suspended",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/unsuspend": {
      "post": {
        "tags": [
          "Numbers"
        ],
        "summary": "Unsuspend number",
        "description": "Reactivate a suspended number",
        "operationId": "unsuspendNumber",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/NumberActionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Number unsuspended",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/set-destination": {
      "post": {
        "tags": [
          "Calls"
        ],
        "summary": "Set call destination",
        "description": "Configure where calls to a number should be routed",
        "operationId": "setDestination",
