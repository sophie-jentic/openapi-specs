    "/get-cdrs": {
      "post": {
        "tags": [
          "CDR"
        ],
        "summary": "Get multiple CDRs",
        "description": "Retrieve multiple call detail records with filtering",
        "operationId": "getCDRs",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/GetCDRsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "CDRs retrieved",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/GetCDRsResponse"
                }
              }
            }
