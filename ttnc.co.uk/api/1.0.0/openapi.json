  },
  "components": {
    "securitySchemes": {
      "vkeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-VKey",
        "description": "Application VKey for API access (requires IP whitelisting)"
      }
    },
    "schemas": {
      "AuthRequest": {
        "type": "object",
        "xml": {
          "name": "NoveroRequest"
        },
        "properties": {
          "Request": {
            "type": "object",
            "properties": {
              "target": {
                "type": "string",
                "xml": {
                  "attribute": true
                }
              },
              "name": {
                "type": "string",
                "xml": {
                  "attribute": true
                },
                "example": "Auth"
              },
              "id": {
                "type": "string",
                "xml": {
                  "attribute": true
                }
              }
            }
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "xml": {
          "name": "NoveroResponse"
        },
        "properties": {
          "Response": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "integer",
                "xml": {
                  "attribute": true
                }
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      },
      "GetNumbersRequest": {
        "type": "object",
        "xml": {
          "name": "NoveroRequest"
        },
        "properties": {
          "Request": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "xml": {
                  "attribute": true
                },
                "example": "GetNumbers"
              }
            }
          }
        }
      },
      "GetNumbersResponse": {
        "type": "object",
        "xml": {
          "name": "NoveroResponse"
        },
        "properties": {
          "Response": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "integer",
                "xml": {
                  "attribute": true
                }
              },
              "numbers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "number": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "DeleteNumberRequest": {
        "type": "object",
        "xml": {
          "name": "NoveroRequest"
        },
        "properties": {
          "Request": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "xml": {
                  "attribute": true
                },
                "example": "DeleteNumber"
              },
              "number": {
                "type": "string"
              }
            }
          }
        }
      },
      "NumberActionRequest": {
        "type": "object",
        "xml": {
          "name": "NoveroRequest"
        },
        "properties": {
          "Request": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "xml": {
                  "attribute": true
                }
              },
              "number": {
                "type": "string"
              }
            }
          }
        }
      },
      "SetDestinationRequest": {
        "type": "object",
        "xml": {
          "name": "NoveroRequest"
        },
        "properties": {
          "Request": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "xml": {
                  "attribute": true
                },
                "example": "SetDestination"
              },
              "number": {
                "type": "string"
              },
              "destination": {
                "type": "string"
              }
            }
          }
        }
      },
      "GetCallRatesRequest": {
        "type": "object",
        "xml": {
          "name": "NoveroRequest"
        },
        "properties": {
          "Request": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "xml": {
                  "attribute": true
                },
                "example": "GetCallRates"
              }
            }
          }
        }
      },
      "GetCallRatesResponse": {
        "type": "object",
        "xml": {
          "name": "NoveroResponse"
        },
        "properties": {
          "Response": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "integer",
                "xml": {
                  "attribute": true
                }
              },
              "rates": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "GetCardsRequest": {
        "type": "object",
        "xml": {
          "name": "NoveroRequest"
        },
        "properties": {
          "Request": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "xml": {
                  "attribute": true
                },
                "example": "GetCards"
              }
            }
          }
        }
      },
      "GetCardsResponse": {
        "type": "object",
        "xml": {
          "name": "NoveroResponse"
        },
        "properties": {
          "Response": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "integer",
                "xml": {
                  "attribute": true
                }
              },
              "cards": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "GetCDRRequest": {
        "type": "object",
        "xml": {
          "name": "NoveroRequest"
        },
        "properties": {
          "Request": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "xml": {
                  "attribute": true
                },
                "example": "GetCDR"
              },
              "cdr_id": {
                "type": "string"
              }
            }
          }
        }
      },
      "GetCDRResponse": {
        "type": "object",
        "xml": {
          "name": "NoveroResponse"
        },
        "properties": {
          "Response": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "integer",
                "xml": {
                  "attribute": true
                }
              },
              "cdr": {
                "type": "object"
              }
            }
          }
        }
      },
      "GetCDRsRequest": {
        "type": "object",
        "xml": {
          "name": "NoveroRequest"
        },
        "properties": {
          "Request": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "xml": {
                  "attribute": true
                },
                "example": "GetCDRs"
              },
              "start_date": {
                "type": "string",
                "format": "date-time"
              },
              "end_date": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "GetCDRsResponse": {
        "type": "object",
        "xml": {
          "name": "NoveroResponse"
        },
        "properties": {
          "Response": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "integer",
                "xml": {
                  "attribute": true
                }
              },
              "cdrs": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "SetVoicemailDestinationRequest": {
        "type": "object",
        "xml": {
          "name": "NoveroRequest"
        },
        "properties": {
          "Request": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "xml": {
                  "attribute": true
                },
                "example": "SetVoicemailDestination"
              },
              "number": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              }
            }
          }
        }
      },
      "StandardResponse": {
        "type": "object",
        "xml": {
          "name": "NoveroResponse"
        },
        "properties": {
          "Response": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "integer",
                "xml": {
                  "attribute": true
                },
                "description": "HTTP status code"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "xml": {
          "name": "NoveroResponse"
        },
        "properties": {
          "Response": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "integer",
                "xml": {
                  "attribute": true
                }
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Invalid or missing VKey, or IP not whitelisted",
        "content": {
          "application/xml": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}
