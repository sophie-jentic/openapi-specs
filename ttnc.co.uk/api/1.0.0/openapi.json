    "/set-voicemail-destination": {
      "post": {
        "tags": [
          "Voicemail"
        ],
        "summary": "Set voicemail destination",
        "description": "Configure voicemail destination email",
        "operationId": "setVoicemailDestination",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/SetVoicemailDestinationRequest"
              }
