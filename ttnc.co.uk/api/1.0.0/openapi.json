    "/get-cdr": {
      "post": {
        "tags": [
          "CDR"
        ],
        "summary": "Get single CDR",
        "description": "Retrieve a single call detail record",
        "operationId": "getCDR",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
