            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/SetDestinationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Destination set",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/get-call-rates": {
      "post": {
        "tags": [
          "Calls"
        ],
        "summary": "Get call rates",
        "description": "Retrieve call rates for destinations",
        "operationId": "getCallRates",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/GetCallRatesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Call rates retrieved",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/GetCallRatesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/enable-recording": {
      "post": {
        "tags": [
          "Calls"
        ],
        "summary": "Enable call recording",
        "description": "Enable recording for calls on a number",
        "operationId": "enableRecording",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/NumberActionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recording enabled",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/disable-recording": {
      "post": {
        "tags": [
          "Calls"
        ],
        "summary": "Disable call recording",
        "description": "Disable recording for calls on a number",
        "operationId": "disableRecording",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/NumberActionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recording disabled",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/get-cards": {
      "post": {
        "tags": [
          "Cards"
        ],
        "summary": "Get cards",
        "description": "Retrieve payment cards on account",
        "operationId": "getCards",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/GetCardsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cards retrieved",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/GetCardsResponse"
                }
              }
            }
          }
        }
      }
