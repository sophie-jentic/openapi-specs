    "/enable-voicemail": {
      "post": {
        "tags": [
          "Voicemail"
        ],
        "summary": "Enable voicemail",
        "description": "Enable voicemail for a number",
        "operationId": "enableVoicemail",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/NumberActionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Voicemail enabled",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/disable-voicemail": {
      "post": {
        "tags": [
          "Voicemail"
        ],
        "summary": "Disable voicemail",
        "description": "Disable voicemail for a number",
        "operationId": "disableVoicemail",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/NumberActionRequest"
