{
  "openapi": "3.0.3",
  "info": {
    "title": "CFEngine Enterprise API",
    "version": "1.0.0",
    "description": "CFEngine Enterprise REST API for managing infrastructure automation. Provides access to host management, inventory reports, SQL queries, user/RBAC management, status/settings, and various operational endpoints for the CFEngine Mission Portal.",
    "x-jentic-source-url": "https://docs.cfengine.com/docs/lts/api/enterprise-api-ref/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://hub.cfengine.com",
      "description": "CFEngine Hub (replace with your hub URL)"
    }
  ],
  "paths": {
    "/api": {
      "get": {
        "operationId": "getServerStatus",
        "summary": "Get server status",
        "description": "Returns API status, version information, and license details.",
        "tags": [
          "Status & Settings"
        ],
        "responses": {
          "200": {
            "description": "Server status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/settings": {
      "get": {
        "operationId": "getSettings",
        "summary": "Get settings",
        "description": "Returns all Mission Portal and REST API settings. Admin only.",
        "tags": [
          "Status & Settings"
        ],
        "responses": {
          "200": {
            "description": "Settings response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SettingsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "updateSettings",
        "summary": "Update settings",
        "description": "Updates Mission Portal and API settings. Admin only.",
        "tags": [
          "Status & Settings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SettingsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings updated"
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/user": {
      "get": {
        "operationId": "listUsers",
        "summary": "List users",
        "description": "List all users. Admin only.",
        "tags": [
          "Users & RBAC"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "Regex filter for usernames",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "external",
            "in": "query",
            "description": "Filter by internal/external users",
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/user/{username}": {
      "get": {
        "operationId": "getUser",
        "summary": "Get user data",
        "tags": [
          "Users & RBAC"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "404": {
            "description": "User not found"
          }
        },
        "description": "Get user data"
      },
      "put": {
        "operationId": "createUser",
        "summary": "Create new user",
        "tags": [
          "Users & RBAC"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Create new user"
      },
      "post": {
        "operationId": "updateUser",
        "summary": "Update user",
        "tags": [
          "Users & RBAC"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Update user"
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete user",
        "tags": [
          "Users & RBAC"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          },
          "404": {
            "description": "User not found"
          }
        },
        "description": "Delete user"
      }
    },
    "/api/user/{username}/unlock": {
      "post": {
        "operationId": "unlockUser",
        "summary": "Unlock user",
        "description": "Unlocks a user locked out due to 2FA setup timeout. Grants additional 48 hours.",
        "tags": [
          "Users & RBAC"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "User unlocked"
          }
        }
      }
    },
    "/api/role": {
      "get": {
        "operationId": "listRoles",
        "summary": "List RBAC roles",
        "tags": [
          "Users & RBAC"
        ],
        "responses": {
          "200": {
            "description": "Role list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoleListResponse"
                }
              }
            }
          }
        },
        "description": "List RBAC roles"
      }
    },
    "/api/role/{roleId}": {
      "get": {
        "operationId": "getRole",
        "summary": "Get RBAC role",
        "tags": [
          "Users & RBAC"
        ],
        "parameters": [
          {
            "name": "roleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Role details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoleResponse"
                }
              }
            }
          }
        },
        "description": "Get RBAC role"
      },
      "put": {
        "operationId": "createRole",
        "summary": "Create RBAC role",
        "tags": [
          "Users & RBAC"
        ],
        "parameters": [
          {
            "name": "roleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RoleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Role created"
          }
        },
        "description": "Create RBAC role"
      },
      "post": {
        "operationId": "updateRole",
        "summary": "Update RBAC role",
        "tags": [
          "Users & RBAC"
        ],
        "parameters": [
          {
            "name": "roleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RoleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Role updated"
          }
        },
        "description": "Update RBAC role"
      },
      "delete": {
        "operationId": "deleteRole",
        "summary": "Delete RBAC role",
        "tags": [
          "Users & RBAC"
        ],
        "parameters": [
          {
            "name": "roleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Role deleted"
          }
        },
        "description": "Delete RBAC role"
      }
    },
    "/api/host": {
      "get": {
        "operationId": "listHosts",
        "summary": "List hosts",
        "tags": [
          "Hosts"
        ],
        "parameters": [
          {
            "name": "context-include",
            "in": "query",
            "description": "Comma-delimited regex to include hosts by context",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "context-exclude",
            "in": "query",
            "description": "Comma-delimited regex to exclude hosts by context",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Host list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HostListResponse"
                }
              }
            }
          }
        },
        "description": "List hosts"
      }
    },
    "/api/host/{hostId}": {
      "get": {
        "operationId": "getHost",
        "summary": "Get host details",
        "tags": [
          "Hosts"
        ],
        "parameters": [
          {
            "name": "hostId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Host details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HostResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get host details"
      },
      "delete": {
        "operationId": "deleteHost",
        "summary": "Remove host from hub",
        "description": "Removes host data from reporting database and stops collecting reports.",
        "tags": [
          "Hosts"
        ],
        "parameters": [
          {
            "name": "hostId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Host scheduled for deletion"
          },
          "404": {
            "description": "Host not found"
          }
        }
      }
    },
    "/api/hosts/by-class": {
      "get": {
        "operationId": "listHostsByClass",
        "summary": "List hosts grouped by hard classes",
        "description": "Returns hosts grouped by their CFEngine classes (Ansible inventory compatible).",
        "tags": [
          "Hosts"
        ],
        "parameters": [
          {
            "name": "context-include",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "yaml"
              ],
              "default": "json"
            }
          },
          {
            "name": "withInventory",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "inventoryFile",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hosts by class",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/hosts/deleted": {
      "get": {
        "operationId": "listDeletedHosts",
        "summary": "Get deleted hosts list",
        "tags": [
          "Hosts"
        ],
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted hosts list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeletedHostListResponse"
                }
              }
            }
          }
        },
        "description": "Get deleted hosts list"
      }
    },
    "/api/hosts/restore-deleted/{hostId}": {
      "post": {
        "operationId": "restoreDeletedHost",
        "summary": "Restore deleted host",
        "tags": [
          "Hosts"
        ],
        "parameters": [
          {
            "name": "hostId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Host restored"
          },
          "404": {
            "description": "Host not found"
          }
        },
        "description": "Restore deleted host"
      }
    },
    "/api/hosts/delete-permanently/{hostId}": {
      "delete": {
        "operationId": "permanentlyDeleteHost",
        "summary": "Permanently delete host entry",
        "tags": [
          "Hosts"
        ],
        "parameters": [
          {
            "name": "hostId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Host permanently deleted"
          },
          "404": {
            "description": "Host not found"
          }
        },
        "description": "Permanently delete host entry"
      }
    },
    "/api/query": {
      "post": {
        "operationId": "executeQuery",
        "summary": "Execute SQL query",
        "description": "Executes a read-only SQL query against the CFEngine database. Subject to RBAC.",
        "tags": [
          "Query"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query"
          }
        }
      }
    },
    "/api/query/async": {
      "post": {
        "operationId": "scheduleAsyncQuery",
        "summary": "Schedule SQL query as long-running job",
        "tags": [
          "Query"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AsyncQueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Job scheduled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsyncQueryJobResponse"
                }
              }
            }
          }
        },
        "description": "Schedule SQL query as long-running job"
      }
    },
    "/api/query/async/{jobId}": {
      "get": {
        "operationId": "getAsyncQueryStatus",
        "summary": "Check async query status",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsyncQueryStatusResponse"
                }
              }
            }
          }
        },
        "description": "Check async query status"
      },
      "delete": {
        "operationId": "cancelAsyncQuery",
        "summary": "Cancel async query",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job cancelled"
          }
        },
        "description": "Cancel async query"
      }
    },
    "/api/inventory": {
      "post": {
        "operationId": "queryInventory",
        "summary": "Query inventory reports",
        "description": "Query inventory data with filtering, sorting, and pagination.",
        "tags": [
          "Inventory"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InventoryQueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inventory results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/inventory/attributes-dictionary": {
      "get": {
        "operationId": "listInventoryAttributes",
        "summary": "List inventory attributes",
        "tags": [
          "Inventory"
        ],
        "responses": {
          "200": {
            "description": "Attributes dictionary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/InventoryAttribute"
                  }
                }
              }
            }
          }
        },
        "description": "List inventory attributes"
      }
    },
    "/api/inventory/attributes-dictionary/{id}": {
      "patch": {
        "operationId": "editInventoryAttribute",
        "summary": "Edit inventory attribute",
        "tags": [
          "Inventory"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EditInventoryAttributeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Attribute updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InventoryAttribute"
                }
              }
            }
          }
        },
        "description": "Edit inventory attribute"
      }
    }
  },
  "components": {
    "schemas": {
      "ApiMetaResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "page": {
                "type": "integer"
              },
              "count": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              },
              "timestamp": {
                "type": "integer",
                "description": "Unix timestamp"
              }
            }
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "apiName": {
                  "type": "string"
                },
                "apiVersion": {
                  "type": "string"
                },
                "enterpriseVersion": {
                  "type": "string"
                },
                "coreVersion": {
                  "type": "string"
                },
                "authenticated": {
                  "type": "string",
                  "enum": [
                    "internal",
                    "external"
                  ]
                },
                "userId": {
                  "type": "string"
                },
                "license": {
                  "type": "object",
                  "properties": {
                    "expires": {
                      "type": "string"
                    },
                    "owner": {
                      "type": "string"
                    },
                    "licenseType": {
                      "type": "string"
                    },
                    "granted": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "SettingsResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SettingsRequest"
            }
          }
        }
      },
      "SettingsRequest": {
        "type": "object",
        "properties": {
          "rbacEnabled": {
            "type": "boolean"
          },
          "hostIdentifier": {
            "type": "string"
          },
          "ldapEnabled": {
            "type": "boolean"
          },
          "logLevel": {
            "type": "string",
            "enum": [
              "emergency",
              "alert",
              "critical",
              "error",
              "warning",
              "notice",
              "info",
              "debug"
            ]
          },
          "blueHostHorizon": {
            "type": "integer",
            "description": "Threshold in minutes for unreachable hosts"
          },
          "sameHostsNumberOfRuns": {
            "type": "integer"
          },
          "enforce2FA": {
            "type": "boolean"
          },
          "minPasswordLength": {
            "type": "integer"
          },
          "passwordComplexity": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4
          },
          "passwordExpirationAfterResetHours": {
            "type": "integer"
          }
        }
      },
      "UserListResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserObject"
            }
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserObject"
            }
          }
        }
      },
      "UserObject": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
