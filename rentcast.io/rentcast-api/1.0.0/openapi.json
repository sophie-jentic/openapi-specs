{
  "openapi": "3.0.3",
  "info": {
    "title": "RentCast API",
    "version": "1.0.0",
    "description": "RentCast provides real estate and property data APIs including property records, property valuations (AVM), sale and rental listings, and market statistics across all 50 US states.",
    "x-jentic-source-url": "https://www.rentcast.io/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.rentcast.io/v1"
    }
  ],
  "paths": {
    "/properties": {
      "get": {
        "operationId": "getPropertyRecords",
        "summary": "Search property records",
        "description": "Search residential and commercial property records by address or specific criteria.",
        "tags": [
          "Property Data"
        ],
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "description": "Property street address",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "city",
            "in": "query",
            "description": "City name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "State abbreviation",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "zipCode",
            "in": "query",
            "description": "ZIP code",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "latitude",
            "in": "query",
            "description": "Latitude for location search",
            "required": false,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "longitude",
            "in": "query",
            "description": "Longitude for location search",
            "required": false,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "description": "Search radius in miles",
            "required": false,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "propertyType",
            "in": "query",
            "description": "Property type filter",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Single Family",
                "Condo",
                "Townhouse",
                "Multi-Family",
                "Apartment",
                "Mobile",
                "Land"
              ]
            }
          },
          {
            "name": "bedrooms",
            "in": "query",
            "description": "Number of bedrooms",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "bathrooms",
            "in": "query",
            "description": "Number of bathrooms",
            "required": false,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 500
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Property"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
