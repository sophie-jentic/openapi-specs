{
  "openapi": "3.0.3",
  "info": {
    "title": "Telenor APIs",
    "description": "Telenor telecommunications and business services APIs including mobile and fixed network ordering, IoT management, SMS messaging, positioning services, CDN, and service ticket management for Norwegian telecommunications infrastructure.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developer.telenor.no/api/index.html",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.telenor.no",
      "description": "Telenor API server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/mobile-order/v1/subscriptions": {
      "post": {
        "summary": "Create mobile subscription",
        "description": "Create a new mobile subscription order",
        "operationId": "createMobileSubscription",
        "tags": [
          "Mobile Order"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MobileSubscriptionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Subscription created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MobileSubscriptionResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "get": {
        "summary": "List mobile subscriptions",
        "description": "Retrieve list of mobile subscriptions",
        "operationId": "listMobileSubscriptions",
        "tags": [
          "Mobile Order"
        ],
        "responses": {
          "200": {
            "description": "List of subscriptions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subscriptions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/MobileSubscription"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/mobile-order/v1/subscriptions/{subscriptionId}": {
      "get": {
        "summary": "Get mobile subscription",
        "description": "Retrieve details of a specific subscription",
        "operationId": "getMobileSubscription",
        "tags": [
          "Mobile Order"
        ],
        "parameters": [
          {
            "name": "subscriptionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Subscription details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MobileSubscription"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "summary": "Update mobile subscription",
        "description": "Update an existing mobile subscription",
        "operationId": "updateMobileSubscription",
        "tags": [
          "Mobile Order"
        ],
        "parameters": [
          {
            "name": "subscriptionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MobileSubscriptionUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MobileSubscription"
                }
              }
            }
          }
        }
      }
    },
    "/fixed-order/v1/orders": {
      "post": {
        "summary": "Create fixed network order",
        "description": "Send order to Telenor for fixed network services with delivery tracking",
        "operationId": "createFixedOrder",
        "tags": [
          "Fixed Order"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FixedOrderRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FixedOrderResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List fixed network orders",
        "description": "Retrieve list of fixed network orders",
        "operationId": "listFixedOrders",
        "tags": [
          "Fixed Order"
        ],
        "responses": {
          "200": {
            "description": "List of orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orders": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/FixedOrder"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/iot-order/v1/subscriptions": {
      "get": {
        "summary": "List IoT subscriptions",
        "description": "Retrieve IoT/M2M subscription information",
        "operationId": "listIoTSubscriptions",
        "tags": [
          "IoT Order"
        ],
        "responses": {
          "200": {
            "description": "List of IoT subscriptions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subscriptions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/IoTSubscription"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update IoT subscription",
        "description": "Update IoT subscription information",
        "operationId": "updateIoTSubscription",
        "tags": [
          "IoT Order"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IoTSubscriptionUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IoTSubscription"
                }
              }
            }
          }
        }
      }
    },
    "/iot-positioning/v1/positions": {
      "get": {
        "summary": "Get IoT device positions",
        "description": "Retrieve last known positions for active IoT subscriptions",
        "operationId": "getIoTPositions",
        "tags": [
          "IoT Positioning"
        ],
        "parameters": [
          {
            "name": "subscription_ids",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "List of subscription IDs"
          }
        ],
        "responses": {
          "200": {
            "description": "Device positions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "positions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/IoTPosition"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/positioning/v1/locate": {
      "post": {
        "summary": "Locate device",
        "description": "Localize devices for security solutions and fleet management",
        "operationId": "locateDevice",
        "tags": [
          "Positioning"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "msisdn"
                ],
                "properties": {
                  "msisdn": {
                    "type": "string",
                    "description": "Phone number to locate"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Device location",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceLocation"
                }
              }
            }
          }
        }
      }
    },
    "/sms/v1/messages": {
      "post": {
        "summary": "Send SMS",
        "description": "Send SMS to mobile users",
        "operationId": "sendSMS",
        "tags": [
          "SMS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SMSRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "SMS sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SMSResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sms-alert/v1/alerts": {
      "post": {
        "summary": "Send SMS alert",
        "description": "Send SMS geographically within Telenor network or internationally",
        "operationId": "sendSMSAlert",
        "tags": [
          "SMS Alert"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SMSAlertRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Alert sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SMSAlertResponse"
                }
              }
            }
          }
        }
      }
    },
    "/service-ticket/v1/tickets": {
      "post": {
        "summary": "Create service ticket",
        "description": "Enable corporate customers to create service tickets",
        "operationId": "createServiceTicket",
        "tags": [
          "Service Ticket"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ServiceTicketRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Ticket created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceTicketResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List service tickets",
        "description": "Retrieve list of service tickets",
        "operationId": "listServiceTickets",
        "tags": [
          "Service Ticket"
        ],
        "responses": {
          "200": {
            "description": "List of tickets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tickets": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ServiceTicket"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/service-ticket/v1/tickets/{ticketId}": {
      "get": {
        "summary": "Get service ticket",
        "description": "Retrieve details of a specific service ticket",
        "operationId": "getServiceTicket",
        "tags": [
          "Service Ticket"
        ],
        "parameters": [
          {
            "name": "ticketId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ticket details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceTicket"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/broadband-offer/v1/offers": {
      "get": {
        "summary": "Get broadband offers",
        "description": "Retrieve available broadband offers for service platforms",
        "operationId": "getBroadbandOffers",
        "tags": [
          "Broadband Offer"
        ],
        "parameters": [
          {
            "name": "location",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Location to check availability"
          }
        ],
        "responses": {
          "200": {
            "description": "List of offers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "offers": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/BroadbandOffer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stores/v1/locations": {
      "get": {
        "summary": "Get Telenor stores",
        "description": "Retrieve Telenor Store locations for integration into applications",
        "operationId": "getStoreLocations",
        "tags": [
          "Stores"
        ],
        "parameters": [
          {
            "name": "city",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "latitude",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "longitude",
            "in": "query",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of store locations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stores": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/StoreLocation"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/mport/v1/devices": {
      "get": {
        "summary": "Get device information",
        "description": "Access device information and company policies",
        "operationId": "getDevices",
        "tags": [
          "mPort"
        ],
        "responses": {
          "200": {
            "description": "Device information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "devices": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Device"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication"
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Unauthorized - Invalid or missing API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "MobileSubscriptionRequest": {
        "type": "object",
        "required": [
          "customerId",
          "productId"
        ],
        "properties": {
          "customerId": {
            "type": "string"
          },
          "productId": {
            "type": "string"
          },
          "msisdn": {
            "type": "string"
          }
        }
      },
      "MobileSubscriptionResponse": {
        "type": "object",
        "properties": {
          "subscriptionId": {
            "type": "string"
          },
          "orderId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "MobileSubscription": {
        "type": "object",
        "properties": {
          "subscriptionId": {
            "type": "string"
          },
          "msisdn": {
            "type": "string"
          },
          "productName": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "activationDate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "MobileSubscriptionUpdate": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string"
          },
          "addons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "FixedOrderRequest": {
        "type": "object",
        "required": [
          "customerId",
          "serviceType",
          "address"
        ],
        "properties": {
          "customerId": {
            "type": "string"
          },
          "serviceType": {
            "type": "string"
          },
          "address": {
            "type": "object",
            "properties": {
              "street": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "postalCode": {
                "type": "string"
              }
            }
          }
        }
      },
      "FixedOrderResponse": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string"
          },
          "trackingUrl": {
            "type": "string"
          },
          "estimatedDelivery": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "FixedOrder": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "serviceType": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "IoTSubscription": {
        "type": "object",
        "properties": {
          "subscriptionId": {
            "type": "string"
          },
          "iccid": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "dataUsage": {
            "type": "object",
            "properties": {
              "used": {
                "type": "number"
              },
              "limit": {
                "type": "number"
              }
            }
          }
        }
      },
      "IoTSubscriptionUpdate": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "dataLimit": {
            "type": "number"
          }
        }
      },
      "IoTPosition": {
        "type": "object",
        "properties": {
          "subscriptionId": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "accuracy": {
            "type": "number"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DeviceLocation": {
        "type": "object",
        "properties": {
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "accuracy": {
            "type": "number"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SMSRequest": {
        "type": "object",
        "required": [
          "to",
          "message"
        ],
        "properties": {
          "to": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Phone numbers"
          },
          "message": {
            "type": "string"
          },
          "from": {
            "type": "string"
          }
        }
      },
      "SMSResponse": {
        "type": "object",
        "properties": {
          "messageId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "SMSAlertRequest": {
        "type": "object",
        "required": [
          "recipients",
          "message"
        ],
        "properties": {
          "recipients": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "message": {
            "type": "string"
          },
          "region": {
            "type": "string"
          }
        }
      },
      "SMSAlertResponse": {
        "type": "object",
        "properties": {
          "alertId": {
            "type": "string"
          },
          "sent": {
            "type": "integer"
          },
          "failed": {
            "type": "integer"
          }
        }
      },
      "ServiceTicketRequest": {
        "type": "object",
        "required": [
          "category",
          "description"
        ],
        "properties": {
          "category": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "description": {
            "type": "string"
          },
          "contactPerson": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "phone": {
                "type": "string"
              },
              "email": {
                "type": "string"
              }
            }
          }
        }
      },
      "ServiceTicketResponse": {
        "type": "object",
        "properties": {
          "ticketId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ServiceTicket": {
        "type": "object",
        "properties": {
          "ticketId": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BroadbandOffer": {
        "type": "object",
        "properties": {
          "offerId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "speed": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "available": {
            "type": "boolean"
          }
        }
      },
      "StoreLocation": {
        "type": "object",
        "properties": {
          "storeId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "openingHours": {
            "type": "object"
          }
        }
      },
      "Device": {
        "type": "object",
        "properties": {
          "deviceId": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "imei": {
            "type": "string"
          },
          "policies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Broadband Offer"
    },
    {
      "name": "Fixed Order"
    },
    {
      "name": "IoT Order"
    },
    {
      "name": "IoT Positioning"
    },
    {
      "name": "Mobile Order"
