{
  "openapi": "3.0.3",
  "info": {
    "title": "Ramp Network REST API",
    "version": "1.0.0",
    "description": "Ramp Network crypto on-ramp/off-ramp REST API for managing purchases, assets, and quotes.",
    "x-jentic-source-url": "https://docs.rampnetwork.com/rest-api-reference",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.ramp.network/api"
    }
  ],
  "paths": {
    "/host-api/assets": {
      "get": {
        "operationId": "listAssets",
        "summary": "List assets",
        "description": "List available crypto assets.",
        "tags": [
          "Assets"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "currencyCode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Fiat currency code"
          },
          {
            "name": "useIp",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Use IP for locale"
          }
        ]
      }
    },
    "/host-api/purchase/{purchaseId}": {
      "get": {
        "operationId": "getPurchase",
        "summary": "Get purchase",
        "description": "Get purchase details.",
        "tags": [
          "Purchases"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Purchase"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "purchaseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": ""
          }
        ]
      }
    },
    "/host-api/purchase": {
      "post": {
        "operationId": "createPurchase",
        "summary": "Create purchase",
        "description": "Initiate a new purchase.",
        "tags": [
          "Purchases"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Purchase"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Purchase"
              }
            }
          }
        }
      }
    },
    "/host-api/quote": {
      "post": {
        "operationId": "getQuote",
        "summary": "Get quote",
        "description": "Get a price quote for a crypto purchase.",
        "tags": [
          "Quotes"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quote"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/host-api/offramp/assets": {
      "get": {
        "operationId": "listOfframpAssets",
        "summary": "List off-ramp assets",
        "description": "List available off-ramp assets.",
        "tags": [
          "Off-Ramp"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/host-api/offramp/quote": {
      "post": {
        "operationId": "getOfframpQuote",
        "summary": "Get off-ramp quote",
        "description": "Get a price quote for selling crypto.",
        "tags": [
          "Off-Ramp"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "code": {
            "type": "integer"
          }
        }
      },
      "Purchase": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "fiatValue": {
            "type": "number"
          },
          "fiatCurrency": {
            "type": "string"
          },
          "cryptoAmount": {
            "type": "string"
          },
          "asset": {
            "type": "object"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Quote": {
        "type": "object",
        "properties": {
          "fiatValue": {
            "type": "number"
          },
          "fiatCurrency": {
            "type": "string"
          },
          "cryptoAmount": {
            "type": "string"
          },
          "asset": {
            "type": "string"
          },
          "appliedFee": {
            "type": "number"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Assets"
    },
    {
      "name": "Off-Ramp"
    },
    {
      "name": "Purchases"
    },
    {
      "name": "Quotes"
    }
  ]
}
