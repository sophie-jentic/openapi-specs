    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "variables": {
        "host": {
          "default": "localhost/teampass"
        }
      }
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Items",
      "description": "Password/item management"
    },
    {
      "name": "Folders",
      "description": "Folder management"
    },
    {
