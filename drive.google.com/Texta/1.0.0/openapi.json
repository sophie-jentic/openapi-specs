{
  "openapi": "3.0.3",
  "info": {
    "title": "Texta API",
    "description": "API for AI content generation and writing",
    "version": "1.0.0",
    "x-jentic-source-url": "https://drive.google.com/file/d/1ZQBCloSrKAveziACfywqDtkpyClP2H3U/view?usp=sharing",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.texta.ai"
    }
  ],
  "paths": {
    "/content/generate": {
      "post": {
        "operationId": "generateContent",
        "summary": "Generate content",
        "description": "Generate content",
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": {
                    "type": "string"
                  },
                  "length": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "content"
        ]
      }
    },
    "/content/rewrite": {
      "post": {
        "operationId": "rewriteContent",
        "summary": "Rewrite existing content",
        "description": "Rewrite existing content",
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string"
                  },
                  "style": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "content"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        },
        "required": [
          "error"
        ]
      }
    }
  },
  "tags": [
    {
      "name": "content"
    }
  ]
}
