{
  "openapi": "3.0.3",
  "info": {
    "title": "Watchmode API",
    "version": "1.0.0",
    "description": "Watchmode API for finding streaming availability of movies and TV shows across platforms.",
    "x-jentic-source-url": "https://api.watchmode.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.watchmode.com/v1"
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "searchTitles",
        "summary": "Search titles",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search_field",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "name",
                "imdb_id",
                "tmdb_id"
              ]
            }
          },
          {
            "name": "search_value",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "types",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Search titles"
      }
    },
    "/title/{id}/details": {
      "get": {
        "operationId": "getTitleDetails",
        "summary": "Get title details",
        "tags": [
          "Titles"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "append_to_response",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated: sources,genres"
          }
        ],
        "responses": {
          "200": {
            "description": "Title details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TitleDetail"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get title details"
      }
    },
    "/title/{id}/sources": {
      "get": {
        "operationId": "getTitleSources",
        "summary": "Get streaming sources",
        "tags": [
          "Titles"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "regions",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Source"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get streaming sources"
      }
    },
    "/list-titles": {
      "get": {
        "operationId": "listTitles",
        "summary": "List all titles",
        "tags": [
          "Titles"
        ],
        "parameters": [
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "types",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "source_ids",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "genres",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 250
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Titles",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TitleListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all titles"
      }
    },
    "/sources": {
      "get": {
        "operationId": "listSources",
        "summary": "List streaming sources",
        "tags": [
          "Sources"
        ],
        "parameters": [
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "regions",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StreamingService"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List streaming sources"
      }
    },
    "/networks": {
      "get": {
        "operationId": "listNetworks",
        "summary": "List TV networks",
        "tags": [
          "Sources"
        ],
        "parameters": [
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Networks"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List TV networks"
      }
    },
    "/title/{id}/cast-crew": {
      "get": {
        "operationId": "getCastCrew",
        "summary": "Get cast and crew",
        "tags": [
          "Titles"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cast and crew"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get cast and crew"
      }
    },
    "/releases": {
      "get": {
        "operationId": "getReleases",
        "summary": "Get new releases",
        "tags": [
          "Releases"
        ],
        "parameters": [
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "source_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "types",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Releases"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get new releases"
      }
    }
  },
  "components": {
    "schemas": {
      "SearchResponse": {
        "type": "object",
        "properties": {
          "title_results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TitleSummary"
            }
          }
        }
      },
      "TitleSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          },
          "imdb_id": {
            "type": "string"
          },
          "tmdb_id": {
            "type": "integer"
          }
        }
      },
      "TitleDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          },
          "imdb_id": {
            "type": "string"
          },
          "tmdb_id": {
            "type": "integer"
          },
          "plot_overview": {
            "type": "string"
          },
          "user_rating": {
            "type": "number"
          },
          "runtime_minutes": {
            "type": "integer"
          },
          "genre_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Source"
            }
          }
        }
      },
      "Source": {
        "type": "object",
        "properties": {
          "source_id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "sub",
              "rent",
              "buy",
              "free",
              "addon"
            ]
          },
          "region": {
            "type": "string"
          },
          "web_url": {
            "type": "string",
            "format": "uri"
          },
          "price": {
            "type": "number"
          }
        }
      },
      "StreamingService": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "logo_100px": {
            "type": "string"
          },
          "regions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "TitleListResponse": {
        "type": "object",
        "properties": {
          "titles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TitleSummary"
            }
          },
          "page": {
            "type": "integer"
          },
          "total_pages": {
            "type": "integer"
          },
          "total_results": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "statusCode": {
            "type": "integer"
          },
          "statusMessage": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "apiKey",
        "in": "query"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Search"
    },
    {
      "name": "Titles"
    },
    {
      "name": "Sources"
    },
    {
      "name": "Releases"
    }
  ]
}
