{
  "openapi": "3.0.3",
  "info": {
    "title": "Akeneo PIM API",
    "version": "7.0.0",
    "description": "Akeneo is a Product Information Management (PIM) system. The REST API provides endpoints for managing products, product models, families, attributes, categories, channels, locales, media files, reference entities, asset management, and catalogs.",
    "x-jentic-source-url": "https://api.akeneo.com",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{instance}.cloud.akeneo.com/api/rest/v1",
      "variables": {
        "instance": {
          "default": "your-instance",
          "description": "Your Akeneo cloud instance"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Products",
      "description": "Product management (UUID-based)"
    },
    {
      "name": "Product Models",
      "description": "Product model management"
    },
    {
      "name": "Families",
      "description": "Family and family variant management"
    },
    {
      "name": "Attributes",
      "description": "Attribute management"
    },
    {
      "name": "Categories",
      "description": "Category management"
    },
    {
      "name": "Channels",
      "description": "Channel management"
    },
    {
      "name": "Locales",
      "description": "Locale management"
    },
    {
      "name": "Media Files",
      "description": "Product media file management"
    },
    {
      "name": "Authentication",
      "description": "OAuth2 authentication"
    },
    {
      "name": "Jobs",
      "description": "Import/export job management"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/oauth/v1/token": {
      "post": {
        "operationId": "getToken",
        "summary": "Get authentication token",
        "description": "Obtain an OAuth2 access token using client credentials.",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "password"
                    ],
                    "description": "Grant type"
                  },
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": [
                  "grant_type",
                  "username",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string"
                    },
                    "expires_in": {
                      "type": "integer"
                    },
                    "token_type": {
                      "type": "string"
                    },
                    "scope": {
                      "type": "string"
                    },
                    "refresh_token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/products-uuid": {
      "get": {
        "operationId": "listProductsUuid",
        "summary": "Get list of products",
        "description": "Get a paginated list of products with optional filtering.",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "JSON-encoded search filters"
          },
          {
            "name": "scope",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Channel code for completeness filter"
          },
          {
            "name": "locales",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated locale codes"
          },
          {
            "name": "attributes",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated attribute codes to return"
          },
          {
            "name": "pagination_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "page",
                "search_after"
              ]
            },
            "description": "Pagination type"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            }
          },
          {
            "name": "with_count",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of products",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      },
      "post": {
        "operationId": "createProductUuid",
        "summary": "Create a new product",
        "tags": [
          "Products"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductWrite"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created"
          },
          "400": {
            "description": "Invalid product data"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Unprocessable entity"
          }
        },
        "description": "Create a new product"
      },
      "patch": {
        "operationId": "upsertProductsUuid",
        "summary": "Update/create several products",
        "description": "Submit a collection of products for batch upsert (JSONL format).",
        "tags": [
          "Products"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-ndjson": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch operation results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BatchResult"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/products-uuid/{uuid}": {
      "get": {
        "operationId": "getProductUuid",
