          "404": {
            "description": "Product not found"
          }
        },
        "description": "Get a product"
      },
      "patch": {
        "operationId": "upsertProductUuid",
        "summary": "Update/create a product",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductWrite"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created"
          },
          "204": {
            "description": "Product updated"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Unprocessable entity"
          }
        },
        "description": "Update/create a product"
      },
      "delete": {
        "operationId": "deleteProductUuid",
        "summary": "Delete a product",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Product deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Product not found"
          }
        },
        "description": "Delete a product"
      }
    },
