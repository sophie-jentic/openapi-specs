{
  "openapi": "3.0.3",
  "info": {
    "title": "Multi-Scrobbler API",
    "version": "1.0.0",
    "description": "Multi-scrobbler is a self-hosted scrobble manager that detects music plays from various sources and scrobbles to multiple clients (Last.fm, Listenbrainz, Maloja, etc.). The API provides status and control endpoints.",
    "x-jentic-source-url": "https://foxxmd.github.io/multi-scrobbler/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:9078/api"
    }
  ],
  "paths": {
    "/status": {
      "get": {
        "operationId": "getStatus",
        "summary": "Get overall application status",
        "tags": [
          "Status"
        ],
        "responses": {
          "200": {
            "description": "Application status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        },
        "description": "Get overall application status"
      }
    },
    "/sources": {
      "get": {
        "operationId": "listSources",
        "summary": "List configured sources",
        "tags": [
          "Sources"
        ],
        "responses": {
          "200": {
            "description": "Source list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Source"
                  }
                }
              }
            }
          }
        },
        "description": "List configured sources"
      }
    },
    "/sources/{name}/recent": {
      "get": {
        "operationId": "getSourceRecent",
        "summary": "Get recent scrobbles from a source",
        "tags": [
          "Sources"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent plays",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Play"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Source not found"
          }
        },
        "description": "Get recent scrobbles from a source"
      }
    },
    "/clients": {
      "get": {
        "operationId": "listClients",
        "summary": "List configured scrobble clients",
        "tags": [
          "Clients"
        ],
        "responses": {
          "200": {
            "description": "Client list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Client"
                  }
                }
              }
            }
          }
        },
        "description": "List configured scrobble clients"
      }
    },
    "/clients/{name}/recent": {
      "get": {
        "operationId": "getClientRecent",
        "summary": "Get recent scrobbles sent to a client",
        "tags": [
          "Clients"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent scrobbles"
          },
          "404": {
            "description": "Client not found"
          }
        },
        "description": "Get recent scrobbles sent to a client"
      }
    },
    "/recent": {
      "get": {
        "operationId": "getRecentPlays",
        "summary": "Get recent plays across all sources",
        "tags": [
          "Plays"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent plays",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Play"
                  }
                }
              }
            }
          }
        },
        "description": "Get recent plays across all sources"
      }
    },
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "Health check",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Healthy"
          },
          "503": {
            "description": "Unhealthy"
          }
        },
        "description": "Health check"
      }
    },
    "/logs": {
      "get": {
        "operationId": "getLogs",
        "summary": "Get application logs",
        "tags": [
          "System"
        ],
        "parameters": [
          {
            "name": "level",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "debug",
                "info",
                "warn",
                "error"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Log entries"
          }
        },
        "description": "Get application logs"
      }
    }
  },
  "components": {
    "schemas": {
      "Status": {
        "type": "object",
        "properties": {
          "sources": {
            "type": "integer"
          },
          "clients": {
            "type": "integer"
          },
          "version": {
            "type": "string"
          },
          "uptime": {
            "type": "string"
          }
        }
      },
      "Source": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "spotify",
              "plex",
              "tautulli",
              "subsonic",
              "jellyfin",
              "lastfm",
              "listenbrainz",
              "mpris",
              "mopidy",
              "webscrobbler",
              "chromecast",
              "musikcube",
              "mpd",
              "jriver",
              "kodi",
              "ytmusic"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "running",
              "idle",
              "error"
            ]
          },
          "tracksDiscovered": {
            "type": "integer"
          },
          "plays": {
            "type": "integer"
          }
        }
      },
      "Client": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "lastfm",
              "listenbrainz",
              "maloja"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "running",
              "idle",
              "error"
            ]
          },
          "scrobbled": {
            "type": "integer"
          }
        }
      },
      "Play": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "track": {
                "type": "string"
              },
              "artists": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "album": {
                "type": "string"
              },
              "duration": {
                "type": "integer"
              }
            }
          },
          "source": {
            "type": "string"
          },
          "listenedAt": {
            "type": "string",
            "format": "date-time"
          },
          "scrobbled": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": [],
  "tags": [
    {
      "name": "Clients"
    },
    {
      "name": "Plays"
    },
    {
      "name": "Sources"
    },
    {
      "name": "Status"
    },
    {
      "name": "System"
    }
  ]
}
