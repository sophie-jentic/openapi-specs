{
  "openapi": "3.0.3",
  "info": {
    "title": "ButterCMS API",
    "version": "2.0.0",
    "description": "ButterCMS is a headless CMS that lets you manage content via API. Access blog posts, pages, collections, authors, categories, tags, feeds, and content fields.",
    "x-jentic-source-url": "https://buttercms.com/docs/api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.buttercms.com/v2"
    }
  ],
  "tags": [
    {
      "name": "Posts",
      "description": "Blog posts"
    },
    {
      "name": "Authors",
      "description": "Blog authors"
    },
    {
      "name": "Categories",
      "description": "Blog categories"
    },
    {
      "name": "Tags",
      "description": "Blog tags"
    },
    {
      "name": "Pages",
      "description": "Pages and page types"
    },
    {
      "name": "Collections",
      "description": "Content collections"
    },
    {
      "name": "Feeds",
      "description": "RSS/Atom/Sitemap feeds"
    },
    {
      "name": "Content Fields",
      "description": "Global content fields"
    }
  ],
  "paths": {
    "/posts/": {
      "get": {
        "operationId": "listPosts",
        "summary": "List blog posts",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "auth_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "exclude_body",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Exclude post body from response"
          },
          {
            "name": "author_slug",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category_slug",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag_slug",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "preview",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "description": "Include draft posts"
          }
        ],
        "responses": {
          "200": {
            "description": "Post list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List blog posts"
      }
    },
    "/posts/{slug}/": {
      "get": {
        "operationId": "getPost",
        "summary": "Get a blog post by slug",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "auth_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Post slug"
          },
          {
            "name": "preview",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Post details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Post"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get a blog post by slug"
      }
    },
