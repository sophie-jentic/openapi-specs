              "type": "string"
            }
          },
          {
            "name": "page_type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Page type slug (e.g. 'landing-page')"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
