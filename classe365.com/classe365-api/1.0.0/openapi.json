    "x-jentic-source-url": "https://speca.io/classe365/academics",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{tenant_name}.classe365.com",
      "description": "Classe365 tenant-specific server",
      "variables": {
        "tenant_name": {
          "default": "demo",
          "description": "Your Classe365 tenant name"
        }
      }
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
