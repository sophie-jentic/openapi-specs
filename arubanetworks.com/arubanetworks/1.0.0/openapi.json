  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth 2.0 authentication with access tokens",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "/oauth2/authorize/central/api",
            "tokenUrl": "/oauth2/token",
            "scopes": {
