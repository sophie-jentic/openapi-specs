              "maximum": 14,
              "default": 7
            },
            "description": "Number of days"
          },
          {
            "name": "offset_hours",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": -48
            },
            "description": "Include past data offset in hours (min -48)"
          },
          {
            "name": "alt",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "tempunit",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "C",
                "F"
              ]
            }
          },
          {
            "name": "windunit",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "MS",
                "KTS",
                "KMH",
                "MPH"
              ]
            }
          },
          {
            "name": "tz",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dataset",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "en"
            }
          },
          {
            "name": "rounding",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
