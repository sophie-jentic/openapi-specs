{
  "openapi": "3.0.3",
  "info": {
    "title": "Foreca Weather API",
    "description": "Foreca Weather API provides current weather observations, forecasts (minutely, 15-minutely, hourly, 3-hourly, daily), location search, and weather map tiles.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developer.foreca.com",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://fnw6.foreca.com",
      "description": "Foreca Weather API server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authorization",
      "description": "Token management endpoints"
    },
    {
      "name": "Location",
      "description": "Location search and info"
    },
    {
      "name": "Observation",
      "description": "Current weather observations"
    },
    {
      "name": "Forecast",
      "description": "Weather forecast endpoints"
    },
    {
      "name": "Maps",
      "description": "Weather map tile endpoints"
    }
  ],
  "paths": {
    "/authorize/token": {
      "post": {
        "operationId": "createToken",
        "summary": "Create access token",
        "description": "Authenticate with application credentials and receive a JWT bearer token.",
        "tags": [
          "Authorization"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "user",
                  "password"
                ],
                "properties": {
                  "user": {
                    "type": "string",
                    "description": "Application key username"
                  },
                  "password": {
                    "type": "string",
                    "description": "Application key password"
                  },
                  "expire_hours": {
                    "type": "integer",
                    "description": "Token expiry in hours. Default 1, max 168, -1 for non-expiring.",
                    "default": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/authorize/key": {
      "post": {
        "operationId": "listKeys",
        "summary": "List API keys",
        "description": "List all active API keys for the account.",
        "tags": [
          "Authorization"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "user",
                  "password"
                ],
                "properties": {
                  "user": {
                    "type": "string",
                    "description": "Application key username"
                  },
                  "password": {
                    "type": "string",
                    "description": "Application key password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of API keys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ApiKey"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/authorize/key/{key}": {
      "delete": {
        "operationId": "deleteKey",
        "summary": "Delete an API key",
        "description": "Delete a specific API key.",
        "tags": [
          "Authorization"
        ],
        "security": [],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The API key to delete"
          },
          {
            "name": "user",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Application key username"
          },
          {
            "name": "password",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Application key password"
          }
        ],
        "responses": {
          "200": {
            "description": "Key deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/location/search/{query}": {
      "get": {
        "operationId": "searchLocations",
        "summary": "Search for locations",
        "description": "Search for locations by name or keyword.",
        "tags": [
          "Location"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query string"
          },
          {
            "name": "lang",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "en"
            },
            "description": "ISO 639-1 language code"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "ISO 3166-1 alpha-2 country code filter"
          }
        ],
        "responses": {
          "200": {
            "description": "Location search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LocationSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
