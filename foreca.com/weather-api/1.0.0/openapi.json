    "/api/v1/observation/latest/{location}": {
      "get": {
        "operationId": "getLatestObservation",
        "summary": "Get latest weather observations",
        "description": "Get the latest weather observations from nearby stations.",
        "tags": [
          "Observation"
        ],
        "parameters": [
          {
            "name": "location",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Longitude,latitude coordinates or location ID"
          },
          {
            "name": "tz",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "IANA timezone"
          },
          {
            "name": "stations",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 6,
              "default": 3
            },
            "description": "Number of observation stations to return"
          },
          {
            "name": "prec",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "description": "Include precipitation data (0 or 1)"
          },
          {
            "name": "tempunit",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "C",
                "F"
              ]
            },
            "description": "Temperature unit"
          },
          {
            "name": "windunit",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "MS",
                "KTS",
                "KMH",
                "MPH"
              ]
            },
            "description": "Wind speed unit"
          },
          {
            "name": "rounding",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "description": "Round values (0 or 1)"
          }
        ],
        "responses": {
          "200": {
            "description": "Latest observations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObservationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
