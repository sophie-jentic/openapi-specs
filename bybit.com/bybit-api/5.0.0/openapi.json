          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InstrumentsResponse"
                }
              }
            }
          }
        },
        "operationId": "get-v5-market-instruments-info"
      }
    },
    "/v5/order/create": {
      "post": {
        "tags": [
          "Order"
        ],
        "summary": "Place Order",
        "description": "Create an order. Supports spot, linear, inverse, and option trading.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "category",
                  "symbol",
                  "side",
                  "orderType",
                  "qty"
                ],
                "properties": {
                  "category": {
                    "type": "string",
                    "enum": [
                      "spot",
                      "linear",
                      "inverse",
                      "option"
                    ],
                    "description": "Product type"
                  },
                  "symbol": {
                    "type": "string",
                    "description": "Symbol name, e.g. BTCUSDT"
                  },
                  "side": {
                    "type": "string",
                    "enum": [
                      "Buy",
                      "Sell"
                    ],
                    "description": "Order side"
                  },
                  "orderType": {
                    "type": "string",
                    "enum": [
                      "Market",
                      "Limit"
                    ],
                    "description": "Order type"
                  },
                  "qty": {
                    "type": "string",
                    "description": "Order quantity"
                  },
                  "price": {
                    "type": "string",
                    "description": "Order price. Required for limit orders"
                  },
                  "triggerPrice": {
                    "type": "string",
                    "description": "Conditional order trigger price"
                  },
                  "timeInForce": {
                    "type": "string",
                    "enum": [
                      "GTC",
                      "IOC",
                      "FOK",
                      "PostOnly"
                    ],
                    "description": "Time in force"
                  },
                  "takeProfit": {
                    "type": "string",
                    "description": "Take profit price"
                  },
                  "stopLoss": {
                    "type": "string",
                    "description": "Stop loss price"
                  },
                  "orderLinkId": {
                    "type": "string",
                    "description": "User customised order ID, max 36 characters"
                  },
                  "isLeverage": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Whether to borrow. 0: default, 1: borrow"
                  },
                  "positionIdx": {
                    "type": "integer",
                    "enum": [
                      0,
                      1,
                      2
                    ],
                    "description": "Position index. 0: one-way, 1: buy hedge, 2: sell hedge"
                  },
                  "reduceOnly": {
                    "type": "boolean",
                    "description": "Reduce only order flag"
                  },
                  "tpslMode": {
                    "type": "string",
                    "enum": [
                      "Full",
                      "Partial"
                    ],
                    "description": "TP/SL mode"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          }
        },
        "operationId": "post-v5-order-create"
      }
    },
    "/v5/order/amend": {
      "post": {
        "tags": [
          "Order"
        ],
        "summary": "Amend Order",
        "description": "Amend an open unfilled or partially filled order.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "category",
                  "symbol"
                ],
                "properties": {
                  "category": {
                    "type": "string",
                    "enum": [
                      "spot",
                      "linear",
                      "inverse",
                      "option"
                    ]
                  },
                  "symbol": {
                    "type": "string"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "Order ID. Either orderId or orderLinkId required"
                  },
                  "orderLinkId": {
                    "type": "string",
                    "description": "User customised order ID"
                  },
                  "qty": {
                    "type": "string",
                    "description": "New order quantity"
                  },
                  "price": {
                    "type": "string",
                    "description": "New order price"
                  },
                  "triggerPrice": {
                    "type": "string"
                  },
                  "takeProfit": {
                    "type": "string"
                  },
                  "stopLoss": {
                    "type": "string"
                  },
                  "tpslMode": {
                    "type": "string",
                    "enum": [
                      "Full",
                      "Partial"
                    ]
                  },
                  "tpLimitPrice": {
                    "type": "string"
                  },
                  "slLimitPrice": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          }
        },
        "operationId": "post-v5-order-amend"
      }
    },
    "/v5/order/cancel": {
      "post": {
        "tags": [
          "Order"
        ],
        "summary": "Cancel Order",
        "description": "Cancel an unfilled or partially filled order.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "category",
                  "symbol"
                ],
                "properties": {
                  "category": {
                    "type": "string",
                    "enum": [
                      "spot",
                      "linear",
                      "inverse",
                      "option"
                    ]
                  },
                  "symbol": {
                    "type": "string"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "Order ID. Either orderId or orderLinkId required"
                  },
                  "orderLinkId": {
                    "type": "string",
                    "description": "User customised order ID"
                  },
                  "orderFilter": {
                    "type": "string",
                    "enum": [
                      "Order",
                      "tpslOrder",
                      "StopOrder"
                    ],
                    "description": "Spot only filter"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          }
        },
        "operationId": "post-v5-order-cancel"
      }
    },
    "/v5/order/realtime": {
      "get": {
        "tags": [
          "Order"
        ],
        "summary": "Get Open Orders",
        "description": "Query unfilled or partially filled orders in real-time.",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "spot",
                "linear",
                "inverse",
                "option"
              ]
            }
          },
          {
            "name": "symbol",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "baseCoin",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "settleCoin",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orderId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orderLinkId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "openOnly",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "description": "0: open orders, 1: recent 500 closed"
          },
          {
            "name": "orderFilter",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 50
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenOrdersResponse"
                }
              }
            }
          }
        },
        "operationId": "get-v5-order-realtime"
      }
    },
