            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "settleCoin",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
