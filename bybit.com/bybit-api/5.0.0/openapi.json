    "/v5/account/wallet-balance": {
      "get": {
        "tags": [
          "Account"
        ],
        "summary": "Get Wallet Balance",
        "description": "Obtain wallet balance, query asset information of each currency.",
        "parameters": [
          {
            "name": "accountType",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "UNIFIED"
              ]
            },
            "description": "Account type"
          },
          {
            "name": "coin",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Coin name, multiple coins separated by comma"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WalletBalanceResponse"
                }
              }
            }
          }
        },
        "operationId": "get-v5-account-wallet-balance"
      }
    },
    "/v5/asset/withdraw/create": {
      "post": {
        "tags": [
          "Asset"
        ],
        "summary": "Withdraw",
        "description": "Withdraw assets from the Bybit account.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "coin",
                  "address",
                  "amount",
                  "timestamp",
                  "accountType"
                ],
                "properties": {
                  "coin": {
                    "type": "string",
                    "description": "Coin name"
                  },
                  "chain": {
                    "type": "string",
                    "description": "Chain name"
                  },
                  "address": {
                    "type": "string",
                    "description": "Wallet address or Bybit UID"
                  },
                  "tag": {
                    "type": "string",
                    "description": "Tag/memo if required"
                  },
                  "amount": {
                    "type": "string",
                    "description": "Withdraw amount"
                  },
                  "timestamp": {
                    "type": "integer",
                    "description": "Current timestamp in ms"
                  },
                  "forceChain": {
                    "type": "integer",
                    "enum": [
                      0,
                      1,
                      2
                    ],
                    "description": "0: default, 1: force on-chain, 2: UID transfer"
                  },
                  "accountType": {
                    "type": "string",
                    "enum": [
                      "FUND",
                      "UTA"
                    ],
                    "description": "Wallet type"
                  },
                  "feeType": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Fee handling: 0: manual, 1: auto"
                  },
                  "requestId": {
                    "type": "string",
                    "description": "Idempotency key"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "retCode": {
                      "type": "integer"
                    },
                    "retMsg": {
                      "type": "string"
                    },
                    "result": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "operationId": "post-v5-asset-withdraw-create"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-BAPI-API-KEY",
        "description": "API key"
      },
      "apiSignature": {
        "type": "apiKey",
        "in": "header",
        "name": "X-BAPI-SIGN",
        "description": "Request signature"
      },
      "timestamp": {
        "type": "apiKey",
        "in": "header",
        "name": "X-BAPI-TIMESTAMP",
        "description": "UTC timestamp in milliseconds"
      }
    },
    "schemas": {
      "BaseResponse": {
        "type": "object",
        "properties": {
          "retCode": {
            "type": "integer",
            "description": "Success/error code. 0 means success"
          },
          "retMsg": {
            "type": "string",
            "description": "Success/error message"
          },
          "retExtInfo": {
            "type": "object"
          },
          "time": {
            "type": "integer",
            "description": "Current timestamp in milliseconds"
          }
        }
      },
      "KlineResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseResponse"
          },
          {
            "type": "object",
            "properties": {
              "result": {
                "type": "object",
                "properties": {
                  "symbol": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string"
                  },
                  "list": {
                    "type": "array",
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "[startTime, open, high, low, close, volume, turnover]"
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "OrderbookResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseResponse"
          },
          {
            "type": "object",
            "properties": {
              "result": {
                "type": "object",
                "properties": {
                  "s": {
                    "type": "string",
                    "description": "Symbol name"
                  },
                  "b": {
                    "type": "array",
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "description": "Bid side [price, size]"
                  },
                  "a": {
                    "type": "array",
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "description": "Ask side [price, size]"
                  },
                  "ts": {
                    "type": "integer",
                    "description": "Timestamp"
                  },
                  "u": {
                    "type": "integer",
                    "description": "Update ID"
                  }
                }
              }
            }
          }
        ]
      },
      "TickerResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseResponse"
          },
          {
            "type": "object",
            "properties": {
              "result": {
                "type": "object",
                "properties": {
                  "category": {
                    "type": "string"
                  },
                  "list": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/TickerItem"
