{
  "openapi": "3.0.3",
  "info": {
    "title": "Bybit V5 API",
    "description": "Bybit cryptocurrency exchange API providing market data, trading, position management, account management, and asset management functionality.",
    "version": "5.0.0",
    "contact": {
      "name": "Bybit",
      "url": "https://bybit-exchange.github.io/docs/v5/intro"
    }
  },
  "servers": [
    {
      "url": "https://api.bybit.com",
      "description": "Main API server"
    },
    {
      "url": "https://api.bytick.com",
      "description": "Alternate API server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": [],
      "apiSignature": [],
      "timestamp": []
    }
  ],
  "paths": {
    "/v5/market/kline": {
      "get": {
        "tags": [
          "Market"
        ],
        "summary": "Get Kline (Candlestick)",
        "description": "Query the kline data. Charts are returned in groups based on the requested interval.",
        "security": [],
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "spot",
                "linear",
                "inverse"
              ]
            },
            "description": "Product type"
          },
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Symbol name, e.g. BTCUSDT"
          },
          {
            "name": "interval",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "1",
                "3",
                "5",
                "15",
                "30",
                "60",
                "120",
                "240",
                "360",
                "720",
                "D",
                "W",
                "M"
              ]
            },
            "description": "Kline interval"
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Start timestamp in milliseconds"
          },
          {
            "name": "end",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "End timestamp in milliseconds"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 200,
              "minimum": 1,
              "maximum": 1000
            },
            "description": "Limit for data size per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KlineResponse"
                }
              }
            }
          }
        },
        "operationId": "get-v5-market-kline"
      }
    },
    "/v5/market/orderbook": {
      "get": {
        "tags": [
          "Market"
        ],
        "summary": "Get Orderbook",
        "description": "Query orderbook data.",
        "security": [],
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "spot",
                "linear",
                "inverse",
                "option"
              ]
            },
            "description": "Product type"
          },
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Symbol name"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Limit for data size. spot:[1,200] default:1; linear/inverse:[1,500] default:25; option:[1,25] default:1"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderbookResponse"
                }
              }
            }
          }
        },
        "operationId": "get-v5-market-orderbook"
      }
    },
    "/v5/market/tickers": {
      "get": {
        "tags": [
          "Market"
        ],
        "summary": "Get Tickers",
        "description": "Query the latest price snapshot, best bid/ask price, and trading volume in the last 24 hours.",
        "security": [],
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "spot",
                "linear",
                "inverse",
                "option"
              ]
            },
            "description": "Product type"
          },
          {
            "name": "symbol",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Symbol name"
          },
          {
            "name": "baseCoin",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Base coin. For option only"
          },
          {
            "name": "expDate",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Expiry date. e.g., 25DEC22. For option only"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TickerResponse"
                }
              }
            }
          }
        },
        "operationId": "get-v5-market-tickers"
      }
    },
    "/v5/market/instruments-info": {
      "get": {
        "tags": [
          "Market"
        ],
        "summary": "Get Instruments Info",
        "description": "Query a list of instruments with detailed information.",
        "security": [],
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "spot",
                "linear",
                "inverse",
                "option"
              ]
            },
            "description": "Product type"
          },
          {
            "name": "symbol",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Symbol name"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Symbol status filter"
          },
          {
            "name": "baseCoin",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Base coin"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 500,
              "minimum": 1,
              "maximum": 1000
            },
            "description": "Limit for data size per page"
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
