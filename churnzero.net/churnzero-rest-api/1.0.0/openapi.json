{
  "openapi": "3.0.3",
  "info": {
    "title": "ChurnZero REST API",
    "version": "1.0.0",
    "description": "ChurnZero REST API providing read-only access to customer success data including accounts, contacts, events, segments, tasks, surveys, churn scores, and journeys. Uses OData query conventions for filtering, sorting, and pagination.",
    "x-jentic-source-url": "https://app.churnzero.net/developers",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{subdomain}.churnzero.net/public/v1",
      "variables": {
        "subdomain": {
          "default": "app",
          "description": "Your ChurnZero instance subdomain"
        }
      }
    }
  ],
