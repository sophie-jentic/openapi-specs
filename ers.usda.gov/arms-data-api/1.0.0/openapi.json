{
  "openapi": "3.0.3",
  "info": {
    "title": "USDA ARMS Data API",
    "version": "1.0.0",
    "description": "The Agricultural Resource Management Survey (ARMS) Data API provides access to USDA survey data on farm sector financial conditions, production practices, and resource use.",
    "x-jentic-source-url": "https://www.ers.usda.gov/developer/data-apis/arms-data-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.ers.usda.gov/data/arms"
    }
  ],
  "paths": {
    "/state": {
      "get": {
        "operationId": "getStates",
        "summary": "Get all states",
        "description": "Retrieves all States with available metadata and variables for each State.",
        "tags": [
          "Reference Data"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "description": "API key for authentication",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StateListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/year": {
      "get": {
        "operationId": "getYears",
        "summary": "Get all years",
        "description": "Retrieves all available years for which data exists.",
        "tags": [
          "Reference Data"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "description": "API key for authentication",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/YearListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/surveydata": {
      "get": {
        "operationId": "getSurveyData",
        "summary": "Get survey data",
        "description": "Retrieves survey data with filtering capabilities. Either report or variable must be provided.",
        "tags": [
          "Survey Data"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          },
          {
            "name": "year",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Year or range of years"
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "State filter"
          },
          {
            "name": "report",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Report name (required if variable not provided)"
          },
          {
            "name": "variable",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Variable ID (required if report not provided)"
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Category filter"
          },
          {
            "name": "category2",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Secondary category filter"
          },
          {
            "name": "farmtype",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Farm type filter"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SurveyDataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/category": {
      "get": {
        "operationId": "getCategories",
        "summary": "Get categories",
        "description": "Lists categories, subcategories, metadata, and available variables.",
        "tags": [
          "Reference Data"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Specific category name"
          },
          {
            "name": "id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Category identifier(s)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CategoryListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/report": {
      "get": {
        "operationId": "getReports",
        "summary": "Get reports",
        "description": "Retrieves available reports with metadata and variables.",
        "tags": [
          "Reference Data"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          },
          {
            "name": "name",
            "in": "query",
