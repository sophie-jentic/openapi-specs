{
  "openapi": "3.0.0",
  "info": {
    "description": "This API service will request a POST in order to make grade changes within caesar. The requests will be collected through a student-facing web form (built using Frevvo tool) built and maintained by the Registrar\u2019s Office and Frevvo vendor resources. ",
    "version": "1.0.0",
    "title": "ADO-CAESAR-PostGradeChange",
    "contact": {
      "name": "Student Enterprise System (SES)",
      "email": "SES-FT@northwestern.edu"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/northwestern/ADO-Caesar-PostGradeChange/1.0.0/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/northwestern/ADO-Caesar-PostGradeChange/1.0.0"
    },
    {
      "url": "https://northwestern-dev.apigee.net/student-system-postgradechange",
      "description": "Dev"
    },
    {
      "url": "https://northwestern-test.apigee.net/student-system-postgradechange",
      "description": "Test"
    },
    {
      "url": "https://northwestern-prod.apigee.net/student-system-postgradechange",
      "description": "Prod"
    }
  ],
  "paths": {
    "/student-system-postgradechange": {
      "post": {
        "tags": [
          "Student System PostGradeChange"
        ],
        "summary": "changes/updates students grade in Caesar",
        "description": "Updates Student's grades",
        "responses": {
          "200": {
            "description": "Successfully completed Enrollment(s):",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SuccessMessage"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Unable to read the input",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ErrorMessage"
                  }
                }
              }
            }
          },
          "201": {
            "description": "Post Schemas",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NWGradeChangeRequest"
                }
              }
            }
          }
        },
        "operationId": "post-student-system-postgradechange"
      }
    }
  },
  "components": {
    "schemas": {
      "NWGradeChangeRequest": {
        "type": "object",
        "required": [
          "Class_Namber",
          "NWGradeChangeRequest",
          "ErrorMessage",
          "SuccessMessage"
        ],
        "properties": {
          "NWGradeChangeRequest": {
            "type": "string",
            "example": " "
          },
          "Class_Namber": {
            "$ref": "#/components/schemas/Class_Namber"
          }
        }
      },
      "Class_Namber": {
        "required": [
          "Institution",
          "Career",
          "EmplID",
          "Term",
          "Class_NBR",
          "Crse_Grade_Off"
        ],
        "properties": {
          "Institution": {
            "type": "string",
            "example": "NWUNV",
            "description": "Students Class Institution"
          },
          "Career": {
            "type": "string",
            "example": "UGRD",
            "description": "Student's Career"
          },
          "EmplID": {
            "type": "string",
            "example": "1234567",
            "description": "Student's Employee ID"
          },
          "Term": {
            "type": "string",
            "example": "4040",
            "description": "Class Term"
          },
          "Class_NBR": {
            "type": "string",
            "example": "12345",
            "description": "Class Number"
          },
          "Crse_Grade_Off": {
            "type": "string",
            "example": "CR",
            "description": "Grade Change update rule in CAESAR using Component interface: P grades & D or better with CR.  Replace F or N with NC , Cannot flip K, S, U, V, W, X, Y, or NR. Use NW_GRADE_CHANGE user id for Updated by OPRID and update Date time stamp"
          }
        },
        "type": "object"
      },
      "ErrorMessage": {
        "type": "object",
        "properties": {
          "Error": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string",
                "example": "Unable to read the input data properly. Error occurred while building Document: NWGradeChangeRequest. Name:OnRequest"
              },
              "code": {
                "type": "integer",
                "example": 400
              }
            }
          }
        }
      },
      "SuccessMessage": {
        "type": "object",
        "properties": {
          "Success": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "example": "Successfully completed Enrollment(s): XXXXXXXX."
              },
              "code": {
                "type": "integer",
                "example": 200
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Student System PostGradeChange"
    }
  ]
}
