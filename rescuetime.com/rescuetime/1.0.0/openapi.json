{
  "openapi": "3.0.3",
  "info": {
    "title": "RescueTime Analytic Data API",
    "version": "1.0.0",
    "description": "The RescueTime API provides access to activity data, productivity metrics, daily summaries, alerts, highlights, focus sessions, and offline time.",
    "x-jentic-source-url": "https://www.rescuetime.com/developers",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.rescuetime.com",
      "description": "RescueTime API"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/anapi/data": {
      "get": {
        "operationId": "getAnalyticData",
        "tags": [
          "Analytics"
        ],
        "summary": "Get Analytic Data",
        "description": "Retrieves activity data and productivity metrics for a user.",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "API key (alternative to OAuth)"
          },
          {
            "name": "perspective",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "rank",
                "interval"
              ]
            },
            "description": "rank or interval"
          },
          {
            "name": "resolution_time",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "month",
                "week",
                "day",
                "hour",
                "minute"
              ]
            },
            "description": "Time resolution for interval perspective"
          },
          {
            "name": "restrict_begin",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date (YYYY-MM-DD)"
          },
          {
            "name": "restrict_end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date (YYYY-MM-DD)"
          },
          {
            "name": "restrict_kind",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "category",
                "activity",
                "productivity",
                "document"
              ]
            },
            "description": "Data type"
          },
          {
            "name": "restrict_thing",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Name of specific category/activity"
          },
          {
            "name": "restrict_source_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "computers",
                "mobile",
                "offline"
              ]
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv"
              ]
            },
            "description": "Output format"
          }
        ],
        "responses": {
          "200": {
            "description": "Analytic data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticDataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/anapi/daily_summary_feed": {
      "get": {
        "operationId": "getDailySummaryFeed",
        "tags": [
          "Analytics"
        ],
        "summary": "Daily Summary Feed",
        "description": "Returns daily summary data for the past two weeks.",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily summaries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailySummaryFeedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/anapi/alerts_feed": {
      "get": {
        "operationId": "getAlertsFeed",
        "tags": [
          "Alerts"
        ],
        "summary": "Alerts Feed",
        "description": "Provides a feed of recent alert occurrences. Premium feature.",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alerts feed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlertsFeedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/anapi/highlights_feed": {
      "get": {
        "operationId": "getHighlightsFeed",
        "tags": [
          "Highlights"
        ],
        "summary": "Daily Highlights Feed",
        "description": "Provides a feed of recently entered daily highlights. Premium feature.",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Highlights feed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HighlightsFeedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/anapi/highlights_post": {
      "post": {
        "operationId": "postHighlight",
        "tags": [
          "Highlights"
        ],
        "summary": "Post a Daily Highlight",
        "description": "Posts a daily highlight entry. Premium feature.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/PostHighlightRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Highlight created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HighlightResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/anapi/start_focustime": {
      "post": {
        "operationId": "startFocusSession",
        "tags": [
          "FocusSessions"
        ],
        "summary": "Start Focus Session",
        "description": "Triggers a Focus Session on the user's active devices. Premium feature.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/StartFocusRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Focus session started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FocusSessionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/anapi/focustime_feed": {
      "get": {
        "operationId": "getFocusSessionFeed",
        "tags": [
          "FocusSessions"
        ],
        "summary": "Focus Session Feed",
        "description": "Returns a feed of recent Focus Sessions. Premium feature.",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Focus sessions feed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FocusSessionsFeedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/anapi/offline_time_post": {
      "post": {
        "operationId": "postOfflineTime",
        "tags": [
          "OfflineTime"
        ],
        "summary": "Post Offline Time",
        "description": "Posts offline time to a user's account. Premium feature.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/PostOfflineTimeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Offline time posted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OfflineTimeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key"
      },
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://www.rescuetime.com/oauth/authorize",
            "tokenUrl": "https://www.rescuetime.com/oauth/token",
            "scopes": {
              "time_data": "Access activity history and summary time data",
              "category_data": "Access category time data",
              "productivity_data": "Access productivity level data",
              "alert_data": "Access alert history",
              "highlight_data": "Read/write daily highlights",
              "focustime_data": "Access Focus Session history"
            }
          }
        }
      }
    },
    "schemas": {
      "AnalyticDataResponse": {
        "type": "object",
        "properties": {
          "notes": {
            "type": "string"
          },
          "row_headers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {}
            }
          }
        }
      },
      "DailySummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "date": {
            "type": "string"
          },
          "productivity_pulse": {
            "type": "number"
          },
          "very_productive_percentage": {
            "type": "number"
          },
          "productive_percentage": {
            "type": "number"
          },
          "neutral_percentage": {
            "type": "number"
          },
          "distracting_percentage": {
            "type": "number"
          },
          "very_distracting_percentage": {
            "type": "number"
          },
          "all_productive_percentage": {
            "type": "number"
          },
          "all_distracting_percentage": {
            "type": "number"
          }
        }
      },
      "DailySummaryFeedResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/DailySummary"
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "alert_date": {
            "type": "string"
          },
          "alert_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "AlertsFeedResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Alert"
        }
      },
      "Highlight": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "date": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "source_url": {
            "type": "string"
          },
          "source_name": {
            "type": "string"
          }
        }
      },
      "HighlightsFeedResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Highlight"
        }
      },
      "HighlightResponse": {
        "type": "object",
        "properties": {
          "highlight": {
            "$ref": "#/components/schemas/Highlight"
          }
        }
      },
      "PostHighlightRequest": {
        "type": "object",
        "required": [
          "key",
          "description"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "source_url": {
            "type": "string"
          }
        }
      },
      "StartFocusRequest": {
        "type": "object",
        "required": [
          "key"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "duration": {
            "type": "integer",
            "description": "Duration in minutes"
          }
        }
      },
      "FocusSessionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        }
      },
      "FocusSession": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "duration": {
            "type": "integer"
          }
        }
      },
      "FocusSessionsFeedResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/FocusSession"
        }
      },
      "PostOfflineTimeRequest": {
        "type": "object",
        "required": [
          "key",
          "offline_description",
          "created_at",
          "duration_minutes"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "offline_description": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "duration_minutes": {
            "type": "integer"
          }
        }
      },
      "OfflineTimeResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Alerts"
    },
    {
      "name": "Analytics"
    },
    {
      "name": "FocusSessions"
    },
    {
      "name": "Highlights"
    },
    {
      "name": "OfflineTime"
    }
  ]
}
