    },
    "/api/oauth/offline_time_post": {
      "post": {
        "operationId": "createOfflineTime",
        "summary": "Log offline time",
        "description": "Post offline time entries for activities not tracked by the RescueTime client (e.g., meetings, phone calls).",
        "tags": [
          "Offline Time"
        ],
        "security": [
          {
            "apiKey": []
          },
          {
            "oauth2": [
              "time_data"
            ]
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "access_token",
            "in": "query",
            "description": "OAuth2 access token for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "start_time"
                ],
                "properties": {
                  "start_time": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Start time of the offline activity."
                  },
                  "end_time": {
                    "type": "string",
                    "format": "date-time",
                    "description": "End time of the offline activity. Provide either end_time or duration."
                  },
                  "duration": {
                    "type": "integer",
                    "description": "Duration in seconds. Provide either end_time or duration."
                  },
                  "activity_name": {
                    "type": "string",
                    "description": "Name of the offline activity (e.g., 'Meeting', 'Phone call')."
                  },
                  "activity_details": {
                    "type": "string",
                    "description": "Additional details about the offline activity."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Offline time logged successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Status of the operation."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/oauth/authorize": {
      "get": {
        "operationId": "authorizeOAuth",
        "summary": "OAuth2 authorization endpoint",
        "description": "Redirect users to this endpoint to authorize your application. After authorization, the user is redirected to your redirect_uri with an authorization code.",
        "tags": [
          "OAuth2"
        ],
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "description": "Your application's client ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": true,
            "description": "URI to redirect the user after authorization.",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "description": "Must be 'code' for authorization code flow.",
            "schema": {
              "type": "string",
              "enum": [
                "code"
              ]
            }
          },
          {
            "name": "scope",
            "in": "query",
            "required": true,
            "description": "Space-separated list of OAuth2 scopes to request.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to RescueTime authorization page."
          }
        }
      }
    },
    "/oauth/token": {
      "post": {
        "operationId": "getOAuthToken",
        "summary": "Exchange authorization code for access token",
        "description": "Exchange an authorization code for an OAuth2 access token.",
        "tags": [
          "OAuth2"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "client_id",
                  "client_secret",
                  "code",
                  "redirect_uri",
                  "grant_type"
                ],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Your application's client ID."
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Your application's client secret."
                  },
                  "code": {
                    "type": "string",
                    "description": "The authorization code received from the authorize endpoint."
                  },
                  "redirect_uri": {
                    "type": "string",
                    "format": "uri",
                    "description": "Must match the redirect_uri used in the authorization request."
                  },
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "authorization_code"
                    ],
                    "description": "Must be 'authorization_code'."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful token exchange.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthTokenResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key generated from RescueTime account settings."
      },
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://www.rescuetime.com/oauth/authorize",
            "tokenUrl": "https://www.rescuetime.com/oauth/token",
            "scopes": {
              "time_data": "Access to time tracking data.",
              "category_data": "Access to category data.",
              "productivity_data": "Access to productivity data.",
              "alert_data": "Access to alert data.",
              "highlight_data": "Access to highlight data.",
              "focustime_data": "Access to FocusTime data."
            }
          }
        }
      }
    },
    "schemas": {
      "AnalyticDataResponse": {
        "type": "object",
        "properties": {
          "notes": {
            "type": "string",
            "description": "Explanatory notes about the returned data."
          },
          "row_headers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels for each column in the rows array."
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {}
            },
            "description": "Array of data rows, where each row is an array of values corresponding to row_headers."
          }
        }
      },
      "DailySummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the summary."
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Date of the summary."
          },
          "productivity_pulse": {
            "type": "number",
            "description": "Overall productivity score for the day."
          },
          "total_hours": {
            "type": "number",
            "description": "Total tracked hours."
          },
          "total_duration_formatted": {
            "type": "string",
            "description": "Total tracked time as a formatted string."
          },
          "very_productive_percentage": {
            "type": "number",
            "description": "Percentage of time spent on very productive activities."
          },
          "productive_percentage": {
            "type": "number",
            "description": "Percentage of time spent on productive activities."
          },
          "neutral_percentage": {
            "type": "number",
            "description": "Percentage of time spent on neutral activities."
          },
          "distracting_percentage": {
            "type": "number",
            "description": "Percentage of time spent on distracting activities."
          },
          "very_distracting_percentage": {
            "type": "number",
            "description": "Percentage of time spent on very distracting activities."
          },
          "all_productive_percentage": {
            "type": "number",
            "description": "Combined percentage of productive and very productive time."
          },
          "all_distracting_percentage": {
            "type": "number",
            "description": "Combined percentage of distracting and very distracting time."
          },
          "uncategorized_percentage": {
            "type": "number",
            "description": "Percentage of uncategorized time."
          },
          "very_productive_hours": {
            "type": "number",
            "description": "Hours spent on very productive activities."
          },
          "productive_hours": {
            "type": "number",
            "description": "Hours spent on productive activities."
          },
          "very_productive_duration_formatted": {
            "type": "string",
            "description": "Very productive time as a formatted string."
          },
          "productive_duration_formatted": {
            "type": "string",
            "description": "Productive time as a formatted string."
          }
        }
      },
      "Alert": {
        "type": "object",
