{
  "openapi": "3.0.3",
  "info": {
    "title": "RescueTime API",
    "description": "RescueTime API provides access to productivity analytics data, daily summaries, alerts, highlights, focus sessions, and offline time tracking. Data is synced every 3 minutes for paid plans and every 30 minutes for free (Lite) plans.",
    "version": "0.9.0",
    "contact": {
      "name": "RescueTime",
      "url": "https://www.rescuetime.com/developers"
    },
    "x-jentic-source-url": "https://www.rescuetime.com/developers"
  },
  "servers": [
    {
      "url": "https://www.rescuetime.com",
      "description": "RescueTime API server"
    }
  ],
  "security": [
    {
      "apiKey": []
    },
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/api/oauth/data": {
      "get": {
        "operationId": "getAnalyticData",
        "summary": "Retrieve analytic data",
        "description": "Fetch productivity analytics data with various filtering and grouping options. Returns time spent on activities, categories, or productivity levels.",
        "tags": [
          "Analytics"
        ],
        "security": [
          {
            "apiKey": []
          },
          {
            "oauth2": [
              "time_data",
              "category_data",
              "productivity_data"
            ]
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "API key for authentication (use this or access_token, not both).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "access_token",
            "in": "query",
            "description": "OAuth2 access token for authentication (use this or key, not both).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "perspective",
            "in": "query",
            "description": "How data is organized. 'rank' organizes around a calculated value (e.g. sum of time spent). 'interval' organizes around calendar time.",
            "schema": {
              "type": "string",
              "enum": [
                "rank",
                "interval"
              ],
              "default": "rank"
            }
          },
          {
            "name": "resolution_time",
            "in": "query",
            "description": "Time resolution for grouping data. 'minute' returns five-minute buckets (most granular).",
            "schema": {
              "type": "string",
              "enum": [
                "month",
                "week",
                "day",
                "hour",
                "minute"
              ],
              "default": "hour"
            }
          },
          {
            "name": "restrict_begin",
            "in": "query",
            "description": "Start date for the data range (YYYY-MM-DD format).",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "restrict_end",
            "in": "query",
            "description": "End date for the data range (YYYY-MM-DD format).",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "restrict_kind",
            "in": "query",
            "description": "The level of detail for the data. 'overview' groups into top-level categories, 'category' into sub-categories, 'activity' shows individual apps/sites, 'productivity' shows productivity levels, 'document' shows individual documents/pages, 'efficiency' shows efficiency (not applicable with rank perspective).",
            "schema": {
              "type": "string",
              "enum": [
                "overview",
                "category",
                "activity",
                "productivity",
                "document",
                "efficiency"
              ]
            }
          },
          {
            "name": "restrict_thing",
            "in": "query",
            "description": "Restrict results to a specific category, activity, or overview name.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "restrict_source_type",
            "in": "query",
            "description": "Restrict results by source type.",
            "schema": {
              "type": "string",
              "enum": [
                "computers",
                "mobile",
                "offline"
              ]
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Output format for the response.",
            "schema": {
              "type": "string",
              "enum": [
                "csv",
                "json"
              ],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with analytic data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticDataResponse"
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string",
                  "description": "CSV formatted data with header row."
                }
              }
            }
          }
        }
      }
    },
    "/api/oauth/daily_summary_feed": {
      "get": {
        "operationId": "getDailySummaryFeed",
        "summary": "Retrieve daily summary feed",
        "description": "Returns a daily summary of productivity data including hours, percentages, and productivity pulse for recent days.",
        "tags": [
          "Daily Summary"
        ],
        "security": [
          {
            "apiKey": []
          },
          {
            "oauth2": [
              "time_data",
              "productivity_data"
            ]
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "access_token",
            "in": "query",
            "description": "OAuth2 access token for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with daily summaries.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DailySummary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/oauth/alerts_feed": {
      "get": {
        "operationId": "getAlertsFeed",
        "summary": "Retrieve alerts feed",
        "description": "Returns a list of triggered alerts or alert configurations.",
        "tags": [
          "Alerts"
        ],
        "security": [
          {
            "apiKey": []
          },
          {
            "oauth2": [
              "alert_data"
            ]
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "access_token",
            "in": "query",
            "description": "OAuth2 access token for authentication.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "op",
            "in": "query",
            "description": "Operation to perform. 'status' returns triggered alerts, 'list' returns alert configurations.",
            "schema": {
              "type": "string",
              "enum": [
                "status",
                "list"
              ]
            }
          },
          {
            "name": "alert_id",
            "in": "query",
            "description": "Filter by a specific alert ID.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with alerts.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Alert"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/oauth/highlights_feed": {
      "get": {
        "operationId": "getHighlightsFeed",
        "summary": "Retrieve highlights feed",
        "description": "Returns a list of daily highlights (accomplishments) logged by the user.",
        "tags": [
          "Highlights"
        ],
        "security": [
          {
            "apiKey": []
          },
          {
            "oauth2": [
              "highlight_data"
            ]
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "access_token",
            "in": "query",
            "description": "OAuth2 access token for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with highlights.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Highlight"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/oauth/highlights_post": {
      "post": {
        "operationId": "createHighlight",
        "summary": "Create a highlight",
        "description": "Post a new daily highlight (accomplishment).",
        "tags": [
          "Highlights"
        ],
        "security": [
          {
            "apiKey": []
          },
          {
            "oauth2": [
              "highlight_data"
            ]
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "access_token",
            "in": "query",
            "description": "OAuth2 access token for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "description"
                ],
                "properties": {
                  "highlight_date": {
                    "type": "string",
                    "format": "date",
                    "description": "Date of the highlight (YYYY-MM-DD). Defaults to today."
                  },
                  "description": {
                    "type": "string",
                    "description": "Text description of the highlight/accomplishment."
                  },
                  "source": {
                    "type": "string",
                    "description": "Source application or context for the highlight."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Highlight created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Highlight"
                }
              }
            }
          }
        }
      }
    },
    "/api/oauth/start_focustime": {
      "post": {
        "operationId": "startFocusSession",
        "summary": "Start a focus session",
        "description": "Start a FocusTime session that blocks distracting sites and applications.",
        "tags": [
          "Focus Sessions"
        ],
        "security": [
          {
            "apiKey": []
          },
          {
            "oauth2": [
              "focustime_data"
            ]
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "access_token",
            "in": "query",
            "description": "OAuth2 access token for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "duration"
                ],
                "properties": {
                  "duration": {
                    "type": "integer",
                    "description": "Duration in minutes (must be a multiple of 5). Use -1 for an indefinite session."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Focus session started successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Status of the focus session."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/oauth/end_focustime": {
      "post": {
        "operationId": "endFocusSession",
        "summary": "End a focus session",
        "description": "End the currently active FocusTime session.",
        "tags": [
          "Focus Sessions"
        ],
        "security": [
          {
            "apiKey": []
          },
          {
            "oauth2": [
              "focustime_data"
            ]
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "access_token",
            "in": "query",
            "description": "OAuth2 access token for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Focus session ended successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Status of the focus session."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
