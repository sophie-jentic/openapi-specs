  "components": {
    "schemas": {
      "BrowserProfileType": {
        "type": "string",
        "enum": [
          "light",
          "stealth",
          "tf-browser"
        ],
        "title": "BrowserProfileType",
        "description": "Browser profile types. LIGHT provides fast headless browsing for standard automation.\nSTEALTH provides enhanced anti-detection capabilities with full browser features\nTF_BROWSER provides agent-focused capabilities with full browser features."
      },
      "BrowserRequest": {
        "properties": {
          "browser_ua_preset": {
            "$ref": "#/components/schemas/BrowserUserAgentType"
          },
          "browser_profile": {
            "$ref": "#/components/schemas/BrowserProfileType"
          },
          "shutdown_mode": {
            "$ref": "#/components/schemas/ShutdownMode"
          },
          "inactivity_timeout_seconds": {
            "type": "integer",
            "maximum": 86400.0,
            "minimum": 5.0,
            "title": "Inactivity Timeout Seconds",
            "description": "The inactivity timeout in seconds (up to 24h)",
            "default": 300
          },
          "proxy": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TetraProxy"
              },
              {
                "$ref": "#/components/schemas/CustomProxy"
              }
            ],
            "title": "Proxy",
            "description": "Proxy configuration for this browser session",
            "nullable": true
          },
          "sub_user_id": {
            "title": "Sub User Id",
            "description": "Optional sub-user identifier for tracking sessions within a user account",
            "type": "string",
            "nullable": true
          }
        },
        "type": "object",
        "title": "BrowserRequest",
        "description": "Request model for browser session"
      },
      "BrowserSession": {
        "properties": {
          "session_id": {
            "type": "string",
            "title": "Session Id"
          },
          "cdp_url": {
            "type": "string",
            "title": "Cdp Url"
          },
          "base_url": {
            "type": "string",
            "title": "Base Url"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "cdp_url",
          "base_url"
        ],
        "title": "BrowserSession",
        "description": "Response model for browser session"
      },
      "BrowserUserAgentType": {
        "type": "string",
        "enum": [
          "windows",
          "macos",
          "linux"
        ],
        "title": "BrowserUserAgentType"
      },
      "CustomProxy": {
        "properties": {
          "type": {
            "type": "string",
            "title": "Type",
            "description": "Type of proxy: 'custom' for external proxy",
            "default": "custom",
            "enum": [
              "custom"
            ]
          },
          "url": {
            "type": "string",
            "title": "Url",
            "description": "Proxy server URL"
          },
          "username": {
            "title": "Username",
            "description": "Username for proxy authentication",
            "type": "string",
            "nullable": true
          },
          "password": {
            "title": "Password",
            "description": "Password for proxy authentication",
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "url"
        ],
        "title": "CustomProxy",
        "description": "Custom external proxy configuration"
      },
      "ErrorResponse": {
        "properties": {
          "error_info": {
            "type": "string",
            "title": "Error Info"
          },
          "status_code": {
            "type": "integer",
            "title": "Status Code"
          },
          "metadata": {
            "$ref": "#/components/schemas/ResponseMetadataBase"
          }
        },
        "type": "object",
        "required": [
          "error_info",
          "status_code"
        ],
        "title": "ErrorResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ModeType": {
        "type": "string",
        "enum": [
          "fast",
          "standard"
        ],
        "title": "ModeType",
        "description": "FAST: Uses a faster pipeline for generating the response.\nSTANDARD: Uses the standard pipeline for generating the response."
      },
      "ResponseMetadata": {
        "properties": {
          "request_id": {
            "type": "string",
            "title": "Request Id"
          },
          "generated_query": {
            "title": "Generated Query",
            "type": "string",
            "nullable": true
          },
          "screenshot": {
            "title": "Screenshot",
            "type": "string",
            "nullable": true
          }
        },
        "type": "object",
        "title": "ResponseMetadata"
      },
      "ResponseMetadataBase": {
        "properties": {
          "request_id": {
            "type": "string",
            "title": "Request Id"
          }
        },
        "type": "object",
        "title": "ResponseMetadataBase"
      },
      "RestQueryResponse": {
        "properties": {
          "data": {
            "additionalProperties": true,
            "type": "object",
            "title": "Data"
          },
          "metadata": {
            "$ref": "#/components/schemas/ResponseMetadata"
          }
        },
        "type": "object",
        "required": [
          "data"
        ],
        "title": "RestQueryResponse"
      },
      "RestUrlQueryParams": {
        "properties": {
          "mode": {
            "$ref": "#/components/schemas/ModeType"
          },
          "wait_for": {
            "type": "integer",
            "title": "Wait For",
            "description": "Wait for the page to load content for a specified duration (in seconds). Maximum wait time is 10 seconds",
            "default": 0
          },
          "is_scroll_to_bottom_enabled": {
            "type": "boolean",
            "title": "Is Scroll To Bottom Enabled",
            "description": "Indicates whether scroll to the bottom of the page before capturing the snapshot is enabled",
            "default": false
          },
          "is_screenshot_enabled": {
            "type": "boolean",
            "title": "Is Screenshot Enabled",
            "description": "Indicates whether screenshot capture is enabled",
            "default": false
          },
          "browser_profile": {
            "$ref": "#/components/schemas/BrowserProfileType"
          },
          "proxy": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TetraProxy"
              },
              {
                "$ref": "#/components/schemas/CustomProxy"
              }
            ],
            "title": "Proxy",
            "description": "Proxy configuration for the browser session",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "RestUrlQueryParams"
      },
      "RestWebPageQueryRequest": {
        "properties": {
          "query": {
            "title": "Query",
            "description": "AgentQL query",
            "type": "string",
            "nullable": true
          },
          "prompt": {
            "title": "Prompt",
            "description": "A description of expected data to be extracted",
            "type": "string",
            "nullable": true
          },
          "url": {
            "title": "Url",
            "description": "The URL of the webpage to query",
            "type": "string",
            "nullable": true
          },
          "html": {
            "title": "Html",
            "description": "The HTML of the webpage to query",
            "type": "string",
            "nullable": true
          },
          "params": {
            "$ref": "#/components/schemas/RestUrlQueryParams"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "RestWebPageQueryRequest"
      },
      "ShutdownMode": {
        "type": "string",
        "enum": [
          "on_disconnect",
          "on_inactivity_timeout"
        ],
        "title": "ShutdownMode",
        "description": "Controls how a browser session is torn down on disconnect."
      },
      "StatusType": {
        "type": "string",
        "enum": [
          "running",
          "ended"
        ],
        "title": "StatusType"
      },
      "SubscriptionStatus": {
        "properties": {
          "lifetime_usage_limit": {
            "title": "Lifetime Usage Limit",
            "type": "integer",
            "nullable": true
          },
          "current_cycle_free_usage_limit": {
            "title": "Current Cycle Free Usage Limit",
            "type": "integer",
            "nullable": true
          },
          "current_cycle_start": {
            "type": "string",
            "format": "date-time",
            "title": "Current Cycle Start"
          },
          "current_cycle_end": {
            "type": "string",
            "format": "date-time",
            "title": "Current Cycle End"
          }
        },
        "type": "object",
        "required": [
          "current_cycle_start",
          "current_cycle_end"
        ],
        "title": "SubscriptionStatus",
        "description": "This class represents information about the current active subscription"
      },
      "TelemetryEntry": {
        "properties": {
          "session_id": {
            "type": "string",
            "title": "Session Id"
          },
          "user_id": {
            "title": "User Id",
            "type": "string",
            "nullable": true
          },
          "sub_user_id": {
            "title": "Sub User Id",
            "type": "string",
            "nullable": true
          },
          "mode": {
            "$ref": "#/components/schemas/BrowserProfileType"
          },
          "start_time": {
            "title": "Start Time",
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "end_time": {
            "title": "End Time",
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "duration_ms": {
            "title": "Duration Ms",
            "type": "integer",
            "nullable": true
          },
          "proxy_trg_rx_bytes": {
            "title": "Proxy Trg Rx Bytes",
            "type": "integer",
            "nullable": true
          },
          "proxy_trg_tx_bytes": {
            "title": "Proxy Trg Tx Bytes",
            "type": "integer",
            "nullable": true
          },
          "status": {
            "$ref": "#/components/schemas/StatusType"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "user_id",
          "sub_user_id",
          "mode",
          "start_time",
          "end_time",
          "duration_ms",
          "proxy_trg_rx_bytes",
          "proxy_trg_tx_bytes",
          "status",
          "created_at",
          "updated_at"
        ],
        "title": "TelemetryEntry"
      },
      "TelemetryListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/TelemetryEntry"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "limit": {
            "type": "integer",
            "title": "Limit"
          },
          "page": {
            "type": "integer",
            "title": "Page"
          },
          "total_pages": {
            "type": "integer",
            "title": "Total Pages"
          },
