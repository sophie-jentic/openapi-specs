{
  "openapi": "3.0.3",
  "info": {
    "title": "AgentQL REST API",
    "version": "1.0.0",
    "description": "AgentQL REST API for querying structured data from web pages and documents (PDFs, images) using AgentQL queries or natural language prompts. Includes remote browser session management.",
    "x-jentic-source-url": "https://docs.agentql.com/rest-api/api-reference",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.agentql.com/v1",
      "description": "AgentQL API v1"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Query",
      "description": "Query web pages and documents"
    },
    {
      "name": "Browser Sessions",
      "description": "Remote browser session management"
    }
  ],
  "paths": {
    "/query-data": {
      "post": {
        "operationId": "queryData",
        "tags": [
          "Query"
        ],
        "summary": "Query data from a web page",
        "description": "Queries structured data as JSON from a web page given a URL using either an AgentQL query or a natural language prompt.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryDataRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryDataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/query-document": {
      "post": {
        "operationId": "queryDocument",
        "tags": [
          "Query"
        ],
        "summary": "Query data from a document",
        "description": "Extract data from a PDF or image file (JPEG, JPG, PNG) using an AgentQL query or natural language prompt. Consumes 1 API call per image and 1 per PDF page.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file",
                  "body"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "PDF or image file to query"
                  },
                  "body": {
                    "type": "string",
                    "description": "Stringified JSON containing query/prompt and optional params"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryDataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tetra/sessions": {
      "post": {
        "operationId": "createBrowserSession",
        "tags": [
          "Browser Sessions"
        ],
        "summary": "Create a remote browser session",
        "description": "Create a remote browser session that provides a Chrome DevTools Protocol (CDP) URL for connecting to a remote browser instance.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Browser session created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrowserSessionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "X-API-Key",
        "in": "header",
        "description": "AgentQL API key from dev.agentql.com"
      }
    },
    "schemas": {
      "QueryDataRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "AgentQL query to execute (alternative to prompt)"
          },
          "prompt": {
            "type": "string",
            "description": "Natural language description of data to extract (alternative to query)"
          },
          "url": {
            "type": "string",
            "description": "URL of the web page to query (alternative to html)"
          },
          "html": {
            "type": "string",
            "description": "Raw HTML to query (alternative to url)"
          },
          "params": {
            "$ref": "#/components/schemas/QueryParams"
          }
        }
      },
      "QueryParams": {
        "type": "object",
        "properties": {
          "wait_for": {
            "type": "number",
            "default": 0,
            "description": "Seconds to wait for page to load before querying"
          },
          "is_scroll_to_bottom_enabled": {
            "type": "boolean",
            "default": false,
            "description": "Scroll to bottom before querying"
          },
          "mode": {
            "type": "string",
            "enum": [
              "fast",
              "standard"
            ],
            "default": "fast",
            "description": "Extraction mode: standard for deep analysis, fast for speed"
          },
          "is_screenshot_enabled": {
            "type": "boolean",
            "default": false,
            "description": "Take a screenshot before extracting (returned as Base64)"
          },
          "browser_profile": {
            "type": "string",
            "enum": [
              "light",
              "stealth"
            ],
            "default": "light",
            "description": "Browser profile: light for fast, stealth for anti-detection"
          },
          "proxy": {
            "$ref": "#/components/schemas/ProxyConfig"
          }
        }
      },
      "ProxyConfig": {
        "type": "object",
        "description": "Proxy configuration for browser sessions",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "tetra",
              "custom"
            ],
            "description": "Proxy type: tetra for built-in, custom for your own"
          },
          "country_code": {
            "type": "string",
            "description": "Two-letter country code for tetra proxy location (e.g., US, UK, DE)"
          },
          "url": {
            "type": "string",
            "description": "Proxy server URL (required for custom type)"
          },
          "username": {
            "type": "string",
            "description": "Proxy auth username (optional, custom type)"
          },
          "password": {
            "type": "string",
            "description": "Proxy auth password (optional, custom type)"
          }
        },
        "required": [
          "type"
        ]
      },
      "QueryDataResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "description": "Extracted data matching the query"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "request_id": {
                "type": "string",
                "format": "uuid",
                "description": "Unique request identifier"
              },
              "screenshot": {
                "type": "string",
                "nullable": true,
                "description": "Base64 encoded screenshot if enabled"
              }
            }
          }
        }
      },
      "CreateSessionRequest": {
        "type": "object",
        "properties": {
          "browser_ua_preset": {
            "type": "string",
            "enum": [
              "windows",
              "macos",
              "linux"
            ],
            "default": "linux",
            "description": "User agent preset to simulate different operating systems"
          },
          "browser_profile": {
            "type": "string",
            "enum": [
              "light",
              "stealth"
            ],
            "default": "light",
            "description": "Browser profile"
          },
          "inactivity_timeout_seconds": {
            "type": "integer",
            "default": 300,
            "description": "Session inactivity timeout in seconds"
          },
          "proxy": {
            "$ref": "#/components/schemas/ProxyConfig"
          },
          "shutdown_mode": {
            "type": "string",
            "enum": [
              "on_disconnect",
              "on_inactivity_timeout"
            ],
            "default": "on_disconnect",
            "description": "Controls session teardown behavior"
          }
        }
      },
      "BrowserSessionResponse": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the browser session"
          },
          "cdp_url": {
            "type": "string",
            "description": "Chrome DevTools Protocol URL for connecting to the remote browser"
          },
          "base_url": {
            "type": "string",
            "description": "Base URL for accessing browser session resources and streaming endpoints"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
