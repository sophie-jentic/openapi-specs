            }
          }
        }
      },
      "post": {
        "operationId": "createDatabase",
        "summary": "Create a new database",
        "description": "Creates a new database on the server. Requires server admin credentials.",
        "tags": [
          "Database"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Database name"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "storage": {
                    "type": "string",
                    "enum": [
                      "plocal",
                      "memory"
                    ],
                    "description": "Storage type"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "graph",
                      "document"
                    ],
                    "description": "Database type"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Database created successfully"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteDatabase",
        "summary": "Delete a database",
        "description": "Deletes the specified database. Requires server admin credentials.",
        "tags": [
          "Database"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Database name"
          }
        ],
        "responses": {
          "200": {
            "description": "Database deleted successfully"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
