    "/command/{database}/sql": {
      "post": {
        "operationId": "executeSqlCommand",
        "summary": "Execute an SQL command",
        "description": "Executes an SQL command (INSERT, UPDATE, DELETE, or any non-idempotent operation) against the specified database.",
        "tags": [
          "Command"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Database name"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "command": {
                    "type": "string",
                    "description": "SQL command to execute"
                  },
                  "limit": {
                    "type": "integer",
                    "description": "Result set limit"
                  },
                  "fetchplan": {
                    "type": "string",
                    "description": "Fetch plan for eager loading"
                  }
                },
                "required": [
                  "command"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Command result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
