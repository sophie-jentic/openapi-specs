              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/database/{database}": {
      "get": {
        "operationId": "getDatabaseInfo",
        "summary": "Get database information",
        "description": "Returns metadata about the specified database including classes, clusters, and configuration.",
        "tags": [
          "Database"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Database name"
