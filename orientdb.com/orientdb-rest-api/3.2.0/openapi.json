{
  "openapi": "3.0.3",
  "info": {
    "title": "OrientDB REST API",
    "version": "3.2.0",
    "description": "REST API for OrientDB multi-model database. Provides endpoints for database management, document CRUD, SQL command execution, class and cluster management, and server administration. Uses session-based authentication via /connect endpoint.",
    "x-jentic-source-url": "https://orientdb.com/docs/3.2.x/misc/OrientDB-REST.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:2480"
    }
  ],
  "paths": {
    "/connect/{database}": {
      "get": {
        "operationId": "connectDatabase",
        "summary": "Connect to a database",
        "description": "Establishes a session with the specified database using HTTP Basic authentication. Returns a session cookie for subsequent requests.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Database name"
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully connected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    },
    "/disconnect": {
      "get": {
        "operationId": "disconnect",
        "summary": "Disconnect from the current session",
        "description": "Terminates the current database session.",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Successfully disconnected"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/server": {
      "get": {
        "operationId": "getServerInfo",
        "summary": "Get server information",
        "description": "Returns information about the OrientDB server including version, connections, databases, and storage information. Requires server admin credentials.",
