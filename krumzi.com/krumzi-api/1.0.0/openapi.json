{
  "openapi": "3.0.3",
  "info": {
    "title": "Krumzi API",
    "version": "1.0.0",
    "description": "Dynamic image and video generation API using templates with custom modifications.",
    "x-jentic-source-url": "https://zapier-docs.krumzi.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://krumzi.com"
    }
  ],
  "paths": {
    "/api/dynamic/image": {
      "post": {
        "operationId": "createImage",
        "summary": "Create an image",
        "description": "Generates a dynamic image synchronously using a template with custom modifications. Processing typically completes in under 10 seconds.",
        "tags": [
          "Images"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateImageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          },
          "402": {
            "description": "Payment required - insufficient automation credits"
          },
          "403": {
            "description": "Forbidden - free plan user"
          },
          "429": {
            "description": "Too many requests - rate limit: 10 requests per 10 seconds"
          }
        }
      }
    },
    "/api/dynamic/video": {
      "post": {
        "operationId": "createVideo",
        "summary": "Create a video",
        "description": "Initiates asynchronous video generation using a template. Completion notification arrives via webhook.",
        "tags": [
          "Videos"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateVideoRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Video generation started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "402": {
            "description": "Payment required"
          },
          "403": {
            "description": "Forbidden"
          },
          "429": {
            "description": "Too many requests"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateImageRequest": {
        "type": "object",
        "required": [
          "template_id",
          "modifications"
        ],
        "properties": {
          "template_id": {
            "type": "string"
          },
          "modifications": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "content": {
                  "type": "string"
                },
                "hide": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "CreateVideoRequest": {
        "type": "object",
        "required": [
          "template_id",
          "resolution",
          "modifications"
        ],
        "properties": {
          "template_id": {
            "type": "string"
          },
          "resolution": {
            "type": "string",
            "enum": [
              "720P",
              "FULL_HD"
            ]
          },
          "modifications": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "content": {
                  "type": "string"
                },
                "hide": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "ImageResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          }
        }
      },
      "VideoResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "credits_used": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Images"
    },
    {
      "name": "Videos"
    }
  ]
}
