                }
              }
            }
          },
          "404": {
            "description": "Song not found"
          }
        },
        "tags": [
          "song"
        ]
      }
    },
    "/resources": {
      "get": {
        "operationId": "getResources",
        "summary": "Get available resources",
        "description": "Returns a list of available streaming resources/sources.",
        "security": [],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with resource list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResourceListResponse"
                }
              }
            }
          }
        },
        "tags": [
          "resources"
        ]
      }
    },
    "/resources/{id}": {
      "get": {
        "operationId": "getResource",
        "summary": "Get resource by ID",
        "description": "Retrieve information about a specific streaming resource.",
        "security": [],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Resource ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with resource data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResourceResponse"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found"
          }
        },
        "tags": [
          "resources"
        ]
      }
    },
    "/user_story": {
      "get": {
        "operationId": "getUserStoryList",
        "summary": "List user stories (watch lists)",
        "description": "Retrieve user anime watch list entries.",
        "parameters": [
          {
            "name": "anime_id",
            "in": "query",
            "description": "Filter by anime ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "description": "Filter by user ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by status: 0=CURRENT, 1=PLANNING, 2=COMPLETED, 3=DROPPED, 4=PAUSED, 5=REPEATING",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1,
                2,
                3,
                4,
                5
              ]
            }
          },
          {
            "name": "synced",
            "in": "query",
            "description": "Filter by sync status",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with user story list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserStoryListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "user_story"
        ]
      },
      "put": {
        "operationId": "createUserStory",
        "summary": "Create a user story entry",
        "description": "Add an anime to the user's watch list.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserStoryInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully created user story",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserStoryResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "user_story"
        ]
      }
    },
    "/user_story/{id}": {
      "get": {
        "operationId": "getUserStory",
