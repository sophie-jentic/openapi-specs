{
  "openapi": "3.0.3",
  "info": {
    "title": "AniAPI",
    "description": "AniAPI is an API for anime discovery, streaming links, and tracker synchronization. It provides endpoints to search and retrieve anime, episodes, songs, user data, and streaming resource information. Authentication uses JWT tokens via OAuth.",
    "version": "1.0",
    "contact": {
      "name": "AniAPI",
      "url": "https://aniapi.com"
    }
  },
  "servers": [
    {
      "url": "https://api.aniapi.com/v1",
      "description": "AniAPI v1 production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/auth/me": {
      "get": {
        "operationId": "getMe",
        "summary": "Get current user",
        "description": "Returns the authenticated user's profile information.",
        "responses": {
          "200": {
            "description": "Successful response with user data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/anime": {
      "get": {
        "operationId": "getAnimeList",
        "summary": "List anime",
        "description": "Search and list anime with various filters. Returns paginated results.",
        "security": [],
        "parameters": [
          {
            "name": "title",
            "in": "query",
            "description": "Search by title (partial match)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "anilist_id",
            "in": "query",
            "description": "Filter by AniList ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "mal_id",
            "in": "query",
            "description": "Filter by MyAnimeList ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "tmdb_id",
            "in": "query",
            "description": "Filter by TMDB ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "formats",
            "in": "query",
            "description": "Filter by format(s): 0=TV, 1=TV_SHORT, 2=MOVIE, 3=SPECIAL, 4=OVA, 5=ONA, 6=MUSIC",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by status: 0=FINISHED, 1=RELEASING, 2=NOT_YET_RELEASED, 3=CANCELLED",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1,
                2,
                3
              ]
            }
          },
          {
            "name": "year",
            "in": "query",
            "description": "Filter by year of release",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "season",
            "in": "query",
            "description": "Filter by season: 0=WINTER, 1=SPRING, 2=SUMMER, 3=FALL",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1,
                2,
                3
              ]
            }
          },
          {
            "name": "genres",
            "in": "query",
            "description": "Filter by genre(s), comma-separated",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "nsfw",
            "in": "query",
            "description": "Include NSFW content",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "with_episodes",
            "in": "query",
            "description": "Only return anime that have episodes available",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number (1-indexed)",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page (max 100)",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with anime list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeListResponse"
                }
              }
            }
          }
        },
        "tags": [
          "anime"
        ]
      }
    },
    "/anime/{id}": {
      "get": {
        "operationId": "getAnime",
        "summary": "Get anime by ID",
        "description": "Retrieve detailed information about a specific anime.",
        "security": [],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "AniAPI anime ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with anime data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnimeResponse"
                }
              }
            }
          },
          "404": {
            "description": "Anime not found"
          }
        },
        "tags": [
          "anime"
        ]
      }
    },
    "/episode": {
      "get": {
        "operationId": "getEpisodeList",
        "summary": "List episodes",
        "description": "Search and list anime episodes with various filters.",
        "security": [],
        "parameters": [
          {
            "name": "anime_id",
            "in": "query",
            "description": "Filter by anime ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "number",
            "in": "query",
            "description": "Filter by episode number",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "source",
            "in": "query",
            "description": "Filter by streaming source",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "locale",
            "in": "query",
            "description": "Filter by locale/language (e.g., 'en', 'it', 'jp')",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "is_dub",
            "in": "query",
            "description": "Filter for dubbed episodes",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page (max 100)",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with episode list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpisodeListResponse"
                }
              }
            }
          }
        },
        "tags": [
          "episode"
        ]
      }
    },
    "/episode/{id}": {
      "get": {
        "operationId": "getEpisode",
        "summary": "Get episode by ID",
        "description": "Retrieve detailed information about a specific episode.",
        "security": [],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Episode ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with episode data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpisodeResponse"
                }
              }
            }
          },
          "404": {
            "description": "Episode not found"
          }
        },
        "tags": [
          "episode"
        ]
      }
    },
    "/song": {
      "get": {
        "operationId": "getSongList",
        "summary": "List anime songs",
        "description": "Search and list anime songs (openings and endings).",
        "security": [],
        "parameters": [
          {
            "name": "anime_id",
            "in": "query",
            "description": "Filter by anime ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "title",
            "in": "query",
            "description": "Search by song title",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "artist",
            "in": "query",
            "description": "Search by artist name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "year",
            "in": "query",
            "description": "Filter by year",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "season",
            "in": "query",
            "description": "Filter by season: 0=WINTER, 1=SPRING, 2=SUMMER, 3=FALL",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1,
                2,
                3
              ]
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by type: 0=OPENING, 1=ENDING",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page (max 100)",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with song list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SongListResponse"
                }
              }
            }
          }
        },
        "tags": [
          "song"
        ]
      }
    },
    "/song/{id}": {
      "get": {
        "operationId": "getSong",
        "summary": "Get song by ID",
        "description": "Retrieve detailed information about a specific anime song.",
        "security": [],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Song ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with song data",
