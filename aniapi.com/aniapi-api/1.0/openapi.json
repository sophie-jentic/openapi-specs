        ]
      },
      "put": {
        "operationId": "updateUserStory",
        "summary": "Update a user story entry",
        "description": "Update an existing user story entry.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "User story ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserStoryInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully updated user story",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserStoryResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "User story not found"
          }
        },
        "tags": [
          "user_story"
        ]
      },
      "delete": {
        "operationId": "deleteUserStory",
        "summary": "Delete a user story entry",
        "description": "Remove an anime from the user's watch list.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "User story ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully deleted user story"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "User story not found"
          }
        },
        "tags": [
          "user_story"
        ]
      }
    },
