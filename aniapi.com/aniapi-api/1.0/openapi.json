  "components": {
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "status_code": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "message": {
            "type": "string",
            "description": "Response message"
          },
          "data": {
            "type": "object",
            "description": "Response data"
          },
          "version": {
            "type": "string",
            "description": "API version"
          }
        }
      },
      "Anime": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "AniAPI anime ID"
          },
          "anilist_id": {
            "type": "integer",
            "description": "AniList ID"
          },
          "mal_id": {
            "type": "integer",
            "description": "MyAnimeList ID"
          },
          "tmdb_id": {
            "type": "integer",
            "description": "TMDB ID"
          },
          "format": {
            "type": "integer",
            "description": "Format: 0=TV, 1=TV_SHORT, 2=MOVIE, 3=SPECIAL, 4=OVA, 5=ONA, 6=MUSIC"
          },
          "status": {
            "type": "integer",
            "description": "Status: 0=FINISHED, 1=RELEASING, 2=NOT_YET_RELEASED, 3=CANCELLED"
          },
          "titles": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Titles in various languages"
          },
          "descriptions": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Descriptions in various languages"
          },
          "start_date": {
            "type": "string",
            "description": "Start date"
          },
          "end_date": {
            "type": "string",
            "nullable": true,
            "description": "End date"
          },
          "season_period": {
            "type": "integer",
            "description": "Season: 0=WINTER, 1=SPRING, 2=SUMMER, 3=FALL"
          },
          "season_year": {
            "type": "integer",
            "description": "Year of the season"
          },
          "episodes_count": {
            "type": "integer",
            "description": "Total episode count"
          },
          "episode_duration": {
            "type": "integer",
            "description": "Episode duration in minutes"
          },
          "cover_image": {
            "type": "string",
            "description": "Cover image URL"
          },
          "cover_color": {
            "type": "string",
            "description": "Cover dominant color"
          },
          "banner_image": {
            "type": "string",
            "nullable": true,
            "description": "Banner image URL"
          },
          "trailer_url": {
            "type": "string",
            "nullable": true,
            "description": "Trailer URL"
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of genres"
          },
          "sequel": {
            "type": "integer",
            "nullable": true,
            "description": "Sequel anime ID"
          },
          "prequel": {
            "type": "integer",
            "nullable": true,
            "description": "Prequel anime ID"
          },
