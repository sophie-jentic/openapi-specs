{
  "openapi": "3.0.3",
  "info": {
    "title": "TikTok API",
    "description": "The TikTok API allows developers to authenticate users via OAuth 2.0, manage access tokens, retrieve user profile information, and list a user's public video posts.",
    "version": "2.0.0",
    "contact": {
      "name": "TikTok for Developers",
      "url": "https://developers.tiktok.com"
    }
  },
  "servers": [
    {
      "url": "https://open.tiktokapis.com",
      "description": "TikTok Open API server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v2/oauth/token": {
      "post": {
        "operationId": "fetchAccessToken",
        "summary": "Fetch or refresh an access token",
        "description": "Exchanges an authorization code for an access token, or refreshes an existing access token using a refresh token. The grant_type parameter determines which flow is used.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "client_key",
                  "client_secret",
                  "grant_type"
                ],
                "properties": {
                  "client_key": {
                    "type": "string",
                    "description": "The unique identification key provisioned to the partner."
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "The unique identification secret provisioned to the partner."
                  },
                  "code": {
                    "type": "string",
                    "description": "The authorization code from the web authorization callback. Required when grant_type is authorization_code."
                  },
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "authorization_code",
                      "refresh_token"
                    ],
                    "description": "Set to 'authorization_code' to exchange a code for a token, or 'refresh_token' to refresh an existing token."
                  },
                  "redirect_uri": {
                    "type": "string",
                    "description": "The redirect URI used in the authorization request. Required when grant_type is authorization_code."
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "The refresh token. Required when grant_type is refresh_token."
                  },
                  "code_verifier": {
                    "type": "string",
                    "description": "PKCE code verifier. Required for mobile/desktop flows."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful token response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthError"
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ]
      }
    },
    "/v2/oauth/revoke": {
      "post": {
        "operationId": "revokeAccessToken",
        "summary": "Revoke an access token",
        "description": "Revokes an active access token. After revocation, the token can no longer be used to access TikTok APIs.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "client_key",
                  "client_secret",
                  "token"
                ],
                "properties": {
                  "client_key": {
                    "type": "string",
                    "description": "The unique identification key provisioned to the partner."
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "The unique identification secret provisioned to the partner."
                  },
                  "token": {
                    "type": "string",
                    "description": "The access token to revoke."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token successfully revoked"
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthError"
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ]
      }
    },
    "/v2/user/info": {
      "get": {
        "operationId": "getUserInfo",
        "summary": "Get user information",
        "description": "Returns profile information about the authenticated TikTok user. The fields returned depend on the scopes granted during OAuth authorization.",
        "parameters": [
          {
            "name": "fields",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of user fields to retrieve. Available fields depend on authorized scopes.",
            "schema": {
              "type": "string"
            },
            "example": "open_id,union_id,avatar_url,display_name"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "user": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    },
                    "error": {
                      "$ref": "#/components/schemas/ApiError"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ]
      }
    },
    "/v2/video/list": {
      "post": {
        "operationId": "listUserVideos",
        "summary": "List user's videos",
        "description": "Returns a paginated list of the authenticated user's public TikTok videos. Requires the video.list scope.",
        "parameters": [
          {
            "name": "fields",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of video fields to retrieve.",
            "schema": {
              "type": "string"
            },
            "example": "id,title,cover_image_url,video_description,create_time,share_url,duration,like_count,comment_count,share_count,view_count"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cursor": {
                    "type": "integer",
                    "format": "int64",
                    "description": "Cursor for pagination. Use the cursor value returned in the previous response to fetch the next page. Value is a UTC Unix timestamp in milliseconds."
                  },
                  "max_count": {
                    "type": "integer",
                    "format": "int32",
                    "minimum": 1,
                    "maximum": 20,
                    "default": 10,
                    "description": "Maximum number of videos to return per page."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "videos": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Video"
                          }
                        },
                        "cursor": {
                          "type": "integer",
                          "format": "int64",
                          "description": "Cursor for the next page of results."
                        },
                        "has_more": {
                          "type": "boolean",
                          "description": "Whether there are more videos to retrieve."
                        }
                      }
                    },
                    "error": {
                      "$ref": "#/components/schemas/ApiError"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "access_token",
        "description": "OAuth 2.0 access token obtained via the /v2/oauth/token/ endpoint."
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "open_id": {
            "type": "string",
            "description": "The unique identifier for the user."
          },
          "scope": {
            "type": "string",
            "description": "Comma-separated string of authorized scopes."
          },
          "access_token": {
            "type": "string",
            "description": "The access token (valid for 24 hours)."
          },
          "expires_in": {
            "type": "integer",
            "format": "int64",
            "description": "Access token expiration time in seconds."
          },
          "refresh_token": {
            "type": "string",
            "description": "The refresh token (valid for 365 days)."
          },
          "refresh_expires_in": {
            "type": "integer",
            "format": "int64",
            "description": "Refresh token expiration time in seconds."
          },
          "token_type": {
            "type": "string",
            "description": "Token type, always 'Bearer'.",
            "example": "Bearer"
          }
        }
      },
      "OAuthError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error code."
          },
          "error_description": {
            "type": "string",
            "description": "Human-readable error message."
          },
          "log_id": {
            "type": "string",
            "description": "Unique log identifier for debugging."
          }
        }
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code."
          },
          "message": {
            "type": "string",
            "description": "Error message."
          },
          "log_id": {
            "type": "string",
            "description": "Unique log identifier for debugging."
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "open_id": {
            "type": "string",
            "description": "The unique identifier for the user within the developer's app."
          },
          "union_id": {
            "type": "string",
            "description": "The unique identifier for the user across all of the developer's apps."
          },
          "avatar_url": {
            "type": "string",
            "description": "User's profile image URL."
          },
          "avatar_url_100": {
            "type": "string",
            "description": "User's profile image URL (100x100)."
          },
          "avatar_large_url": {
            "type": "string",
            "description": "User's large profile image URL."
          },
          "display_name": {
            "type": "string",
            "description": "User's display name."
          },
          "bio_description": {
            "type": "string",
            "description": "User's bio description."
          },
          "profile_deep_link": {
            "type": "string",
            "description": "Deep link to the user's TikTok profile."
          },
          "is_verified": {
            "type": "boolean",
            "description": "Whether the user is verified."
          },
          "username": {
            "type": "string",
            "description": "User's TikTok username."
          },
          "follower_count": {
            "type": "integer",
            "format": "int64",
            "description": "Number of followers."
          },
          "following_count": {
            "type": "integer",
            "format": "int64",
            "description": "Number of accounts the user is following."
          },
          "likes_count": {
            "type": "integer",
            "format": "int64",
            "description": "Total number of likes received."
          },
          "video_count": {
            "type": "integer",
            "format": "int64",
            "description": "Total number of public videos."
          }
        }
      },
      "Video": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the video."
          },
          "title": {
            "type": "string",
            "description": "Title of the video."
          },
          "video_description": {
            "type": "string",
            "description": "Description/caption of the video."
          },
          "create_time": {
            "type": "integer",
            "format": "int64",
            "description": "UTC Unix timestamp of when the video was created."
          },
          "cover_image_url": {
            "type": "string",
            "description": "URL of the video's cover image."
          },
          "share_url": {
            "type": "string",
            "description": "Shareable URL of the video."
          },
          "duration": {
            "type": "integer",
            "description": "Video duration in seconds."
          },
          "height": {
            "type": "integer",
            "description": "Video height in pixels."
          },
          "width": {
            "type": "integer",
            "description": "Video width in pixels."
          },
          "like_count": {
            "type": "integer",
            "format": "int64",
            "description": "Number of likes on the video."
          },
          "comment_count": {
            "type": "integer",
            "format": "int64",
            "description": "Number of comments on the video."
          },
          "share_count": {
            "type": "integer",
            "format": "int64",
            "description": "Number of shares of the video."
          },
          "view_count": {
            "type": "integer",
            "format": "int64",
            "description": "Number of views on the video."
          },
          "embed_link": {
            "type": "string",
            "description": "HTML embed link for the video."
          },
          "embed_html": {
            "type": "string",
            "description": "HTML code for embedding the video."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "v2"
    }
  ]
}
