{
  "openapi": "3.0.3",
  "info": {
    "title": "77PlaySystem API",
    "version": "1.0.0",
    "description": "API for the 77PlaySystem platform, providing game management, player management, and scoring functionality.",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/private-412/77playsystem-api/1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.77playsystem.example.com/v1"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/games": {
      "get": {
        "operationId": "listGames",
        "tags": [
          "Games"
        ],
        "summary": "List all games",
        "responses": {
          "200": {
            "description": "List of games",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all games"
      }
    },
    "/players": {
      "get": {
        "operationId": "listPlayers",
        "tags": [
          "Players"
        ],
        "summary": "List all players",
        "responses": {
          "200": {
            "description": "List of players",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all players"
      }
    },
    "/scores": {
      "get": {
        "operationId": "listScores",
        "tags": [
          "Scores"
        ],
        "summary": "List scores",
        "parameters": [
          {
            "name": "gameId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "playerId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of scores",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScoreList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List scores"
      },
      "post": {
        "operationId": "submitScore",
        "tags": [
          "Scores"
        ],
        "summary": "Submit a score",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScoreInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Score submitted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Score"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Submit a score"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      }
    },
    "schemas": {
      "Game": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "maxPlayers": {
            "type": "integer"
          }
        }
      },
      "GameList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Game"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "Player": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "level": {
            "type": "integer"
          }
        }
      },
      "PlayerList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Player"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "Score": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "gameId": {
            "type": "string"
          },
          "playerId": {
            "type": "string"
          },
          "score": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ScoreList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Score"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "ScoreInput": {
        "type": "object",
        "required": [
          "gameId",
          "playerId",
          "score"
        ],
        "properties": {
          "gameId": {
            "type": "string"
          },
          "playerId": {
            "type": "string"
          },
          "score": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Games"
    },
    {
      "name": "Players"
    },
    {
      "name": "Scores"
    }
  ]
}
