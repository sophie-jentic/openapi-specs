{
  "openapi": "3.0.3",
  "info": {
    "title": "Fibery API",
    "version": "1.0.0",
    "description": "Fibery work management platform API. Uses a command-based pattern for querying and mutating entities, plus REST endpoints for schema, automations, files, and webhooks.",
    "x-jentic-source-url": "https://api.fibery.io/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{account}.fibery.io",
      "variables": {
        "account": {
          "default": "your-account",
          "description": "Your Fibery account name"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Commands",
      "description": "Command-based entity operations"
    },
    {
      "name": "Schema",
      "description": "Schema and type information"
    },
    {
      "name": "Files",
      "description": "File upload/download"
    },
    {
      "name": "Webhooks",
      "description": "Webhook management"
    },
    {
      "name": "Automations",
      "description": "Automation rules"
    },
    {
      "name": "Users",
      "description": "User management"
    }
  ],
  "paths": {
    "/api/commands": {
      "post": {
        "operationId": "executeCommands",
        "summary": "Execute commands",
        "description": "Execute one or more commands for querying, creating, updating, or deleting entities.",
        "tags": [
          "Commands"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "command",
                    "args"
                  ],
                  "properties": {
                    "command": {
                      "type": "string",
                      "enum": [
                        "fibery.entity/query",
                        "fibery.entity/create",
                        "fibery.entity/update",
                        "fibery.entity/delete",
                        "fibery.entity/add-collection-items",
                        "fibery.entity/remove-collection-items"
                      ]
                    },
                    "args": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "success": {
                        "type": "boolean"
                      },
                      "result": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/schema": {
      "get": {
        "operationId": "getSchema",
        "summary": "Get workspace schema",
        "description": "Returns the full schema of the Fibery workspace including all types, fields, and relations.",
        "tags": [
          "Schema"
        ],
        "responses": {
          "200": {
            "description": "Schema",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fibpiery/types": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/files/{fileId}": {
      "get": {
        "operationId": "downloadFile",
        "summary": "Download file",
        "tags": [
          "Files"
        ],
        "parameters": [
          {
            "name": "fileId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        },
        "description": "Download file"
      }
    },
    "/api/files": {
      "post": {
        "operationId": "uploadFile",
        "summary": "Upload file",
        "tags": [
          "Files"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fibery/id": {
                      "type": "string"
                    },
                    "fibery/name": {
                      "type": "string"
                    },
                    "fibery/content-type": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Upload file"
      }
    },
    "/api/webhooks": {
      "get": {
        "operationId": "listWebhooks",
        "summary": "List webhooks",
        "tags": [
          "Webhooks"
        ],
        "responses": {
          "200": {
            "description": "Webhooks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Webhook"
                  }
                }
              }
            }
          }
        },
        "description": "List webhooks"
      },
      "post": {
        "operationId": "createWebhook",
        "summary": "Create webhook",
        "tags": [
          "Webhooks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url",
                  "type"
                ],
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string"
                  },
                  "filters": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          }
        },
        "description": "Create webhook"
      }
    },
    "/api/webhooks/{webhookId}": {
      "get": {
        "operationId": "getWebhook",
        "summary": "Get webhook",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "webhookId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          }
        },
        "description": "Get webhook"
      },
      "put": {
        "operationId": "updateWebhook",
        "summary": "Update webhook",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "webhookId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        },
        "description": "Update webhook"
      },
      "delete": {
        "operationId": "deleteWebhook",
        "summary": "Delete webhook",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "webhookId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          }
        },
        "description": "Delete webhook"
      }
    },
    "/api/automations/rules": {
      "get": {
        "operationId": "listAutomationRules",
        "summary": "List automation rules",
        "tags": [
          "Automations"
        ],
        "responses": {
          "200": {
            "description": "Rules",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "description": "List automation rules"
      }
    },
    "/api/automations/rules/{ruleId}": {
      "get": {
        "operationId": "getAutomationRule",
        "summary": "Get automation rule",
        "tags": [
          "Automations"
        ],
        "parameters": [
          {
            "name": "ruleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Rule",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "description": "Get automation rule"
      },
      "put": {
        "operationId": "updateAutomationRule",
        "summary": "Update automation rule",
        "tags": [
          "Automations"
        ],
        "parameters": [
          {
            "name": "ruleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        },
        "description": "Update automation rule"
      }
    },
    "/api/automations/rules/{ruleId}/enable": {
      "post": {
        "operationId": "enableAutomationRule",
        "summary": "Enable automation rule",
        "tags": [
          "Automations"
        ],
        "parameters": [
          {
            "name": "ruleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Enabled"
          }
        },
        "description": "Enable automation rule"
      }
    },
    "/api/automations/rules/{ruleId}/disable": {
      "post": {
        "operationId": "disableAutomationRule",
        "summary": "Disable automation rule",
        "tags": [
          "Automations"
        ],
        "parameters": [
          {
            "name": "ruleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Disabled"
          }
        },
        "description": "Disable automation rule"
      }
    },
    "/api/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List workspace users",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "fibery/id": {
                        "type": "string"
                      },
                      "user/name": {
                        "type": "string"
                      },
                      "user/email": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List workspace users"
      }
    },
    "/api/users/me": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current user",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "description": "Get current user"
      }
    }
  },
  "components": {
    "schemas": {
      "Webhook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "filters": {
            "type": "object"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Fibery API token"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
