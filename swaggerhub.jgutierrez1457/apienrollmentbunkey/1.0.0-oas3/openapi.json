  "paths": {
    "/auth/signup": {
      "post": {
        "description": "Registrar como usuario en el sistema.",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "confirmPassword": {
                    "type": "string"
                  }
                },
                "required": [
                  "email",
                  "name",
                  "password",
                  "confirmPassword"
                ],
                "example": {
                  "email": "test@gmail.com",
                  "name": "test",
                  "password": "123",
                  "confirmPassword": "123"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/UserRegisted"
          },
          "400": {
            "description": "Error com\u00fan como falta de campos, email en uso o passwords no coinciden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "post-auth-signup"
      }
    },
    "/auth/signin": {
      "post": {
        "description": "Identificar como usuario en el sistema.",
