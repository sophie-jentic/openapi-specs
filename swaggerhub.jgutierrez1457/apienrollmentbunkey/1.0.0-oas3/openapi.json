                },
                "required": [
                  "email",
                  "password"
                ],
                "example": {
                  "email": "admin@gmail.com",
                  "password": "admin"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/UserLoged"
          },
          "400": {
            "$ref": "#/components/responses/MissingFields"
          },
          "401": {
            "$ref": "#/components/responses/CredentialsIncorrect"
          },
          "404": {
            "$ref": "#/components/responses/UserDontExist"
          }
        },
        "operationId": "post-auth-signin"
      }
    },
