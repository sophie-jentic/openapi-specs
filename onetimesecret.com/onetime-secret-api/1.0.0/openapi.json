{
  "openapi": "3.0.3",
  "info": {
    "title": "Onetime Secret API",
    "version": "1.0.0",
    "description": "Onetime Secret is a service for sharing sensitive information securely. Secrets are encrypted and can only be viewed once before they are destroyed. The API supports creating secrets, retrieving secret metadata, generating random values, and checking system status. API v1 is the stable version.",
    "x-jentic-source-url": "https://api.onetimesecret.com",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://onetimesecret.com/api"
    }
  ],
  "paths": {
    "/v1/status": {
      "get": {
        "operationId": "getStatus",
        "summary": "Get system status",
        "description": "Returns the current status of the system.",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "System status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/share": {
      "post": {
        "operationId": "createSecret",
        "summary": "Create a secret",
        "description": "Store a secret value. The secret will be encrypted and can only be retrieved once.",
        "tags": [
          "Secrets"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "secret"
                ],
                "properties": {
                  "secret": {
                    "type": "string",
                    "description": "The secret value to share (max 25,000 characters for paid, 10,000 for free)"
                  },
                  "passphrase": {
                    "type": "string",
                    "description": "A passphrase the recipient must know to view the secret"
                  },
                  "ttl": {
                    "type": "integer",
                    "description": "Time to live in seconds (max 604800 = 7 days)",
                    "default": 604800
                  },
                  "recipient": {
                    "type": "string",
                    "description": "Email address to deliver the secret link to"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Secret created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SecretMetadata"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/generate": {
      "post": {
        "operationId": "generateSecret",
        "summary": "Generate a random secret",
        "description": "Generate a short, unique secret. Useful for temporary passwords and similar.",
        "tags": [
          "Secrets"
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "passphrase": {
                    "type": "string",
                    "description": "A passphrase the recipient must know"
                  },
                  "ttl": {
                    "type": "integer",
                    "description": "Time to live in seconds",
                    "default": 604800
                  },
                  "recipient": {
                    "type": "string",
                    "description": "Email address to deliver the secret link to"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Secret generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeneratedSecret"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/secret/{secret_key}": {
      "post": {
        "operationId": "retrieveSecret",
        "summary": "Retrieve a secret",
        "description": "Retrieve the secret value. This can only be done once after which the secret is destroyed.",
        "tags": [
          "Secrets"
        ],
        "parameters": [
          {
            "name": "secret_key",
            "in": "path",
            "required": true,
            "description": "The unique key of the secret",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "passphrase": {
                    "type": "string",
                    "description": "Required if the secret was created with a passphrase"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Secret retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SecretValue"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Secret not found or already viewed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/private/{metadata_key}": {
      "post": {
        "operationId": "getSecretMetadata",
        "summary": "Get secret metadata",
        "description": "Retrieve metadata about a secret without retrieving the secret itself. Can be used to check if a secret has been viewed.",
        "tags": [
          "Secrets"
        ],
        "parameters": [
          {
            "name": "metadata_key",
            "in": "path",
            "required": true,
            "description": "The metadata key returned when creating the secret",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Secret metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SecretMetadata"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/private/{metadata_key}/burn": {
      "post": {
        "operationId": "burnSecret",
        "summary": "Burn a secret",
        "description": "Burn (destroy) a secret that has not been read yet.",
        "tags": [
          "Secrets"
        ],
        "parameters": [
          {
            "name": "metadata_key",
            "in": "path",
            "required": true,
            "description": "The metadata key of the secret to burn",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Secret burned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SecretMetadata"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/private/recent": {
      "get": {
        "operationId": "listRecentMetadata",
        "summary": "List recent secret metadata",
        "description": "List metadata of recently created secrets for the authenticated user.",
        "tags": [
          "Secrets"
        ],
        "responses": {
          "200": {
            "description": "List of recent secret metadata",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SecretMetadata"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SecretMetadata": {
        "type": "object",
        "properties": {
          "custid": {
            "type": "string",
            "description": "Customer ID (email)"
          },
          "metadata_key": {
            "type": "string",
            "description": "Unique key for accessing metadata"
          },
          "secret_key": {
            "type": "string",
            "description": "Unique key for accessing the secret value"
          },
          "ttl": {
            "type": "integer",
            "description": "Time to live in seconds"
          },
          "metadata_ttl": {
            "type": "integer"
          },
          "secret_ttl": {
            "type": "integer"
          },
          "state": {
            "type": "string",
            "description": "State of the secret (new, viewed, received, burned)"
          },
          "updated": {
            "type": "integer",
            "description": "Last update timestamp"
          },
          "created": {
            "type": "integer",
            "description": "Creation timestamp"
          },
          "received": {
            "type": "integer"
          },
          "recipient": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "passphrase_required": {
            "type": "boolean"
          }
        }
      },
      "SecretValue": {
        "type": "object",
        "properties": {
          "secret_key": {
            "type": "string"
          },
          "value": {
            "type": "string",
            "description": "The secret value"
          }
        }
      },
      "GeneratedSecret": {
        "type": "object",
        "properties": {
          "custid": {
            "type": "string"
          },
          "metadata_key": {
            "type": "string"
          },
          "secret_key": {
            "type": "string"
          },
          "ttl": {
            "type": "integer"
          },
          "state": {
            "type": "string"
          },
          "value": {
            "type": "string",
            "description": "The generated secret value"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication using your email as username and API token as password. Get your API token from your OTS account settings."
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Secrets"
    },
    {
      "name": "System"
    }
  ]
}
