            "enum": [
              "Draft",
              "In Review",
              "Published",
              "Retired",
              "Upcoming",
              "Deleted"
            ]
          },
          "summary": {
            "type": "string"
          },
          "createdBy": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "restricted": {
            "type": "boolean"
          },
          "type": {
            "type": "integer",
            "format": "int32",
            "enum": [
              1,
              2,
              3
            ]
          }
        }
      },
      "AddCollaboratorsRequest": {
        "type": "object",
        "required": [
          "checklistInstanceId"
        ],
        "properties": {
          "checklistInstanceId": {
            "type": "string",
            "format": "uuid"
          },
          "userIds": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "nullable": true
          },
          "companyRoleIds": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "nullable": true
          }
        }
      },
