      "AssetStatusDto": {
        "type": "string",
        "description": "Status of the asset. PLANNED: asset is added but should not be operational yet. ACTIVE: enabled and ready to provide flexibility. UNAVAILABLE: for some reason it temporarily cannot provide flexibility. INACTIVE: disabled, the asset can not provide flexibility.",
        "enum": [
          "PLANNED",
          "ACTIVE",
          "UNAVAILABLE",
          "INACTIVE"
        ]
      },
      "CreateAssetRequestDto": {
        "required": [
          "assetIdExternal",
          "availableTimeseriesTypeSet",
          "downwardRegulationLimit",
          "managerId",
          "priceZone",
          "reserveMarketSet",
          "status",
          "upwardRegulationLimit",
          "activationCallbackUrl"
        ],
        "type": "object",
        "properties": {
