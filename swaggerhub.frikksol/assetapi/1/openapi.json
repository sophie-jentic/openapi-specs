          },
          "transformerId": {
            "type": "string",
            "nullable": true
          },
          "upwardRegulationLimit": {
            "type": "number",
            "description": "The theoretical maximum amount of upward regulation possible for the asset. Specified in W (watt).Most of the time, this is limited by the maximum hardware power generation of the asset. Specified in W (watt).Can be specified manually by Asset Manager.For assets that can only consume power, this value is greater than or equal to 0."
          },
          "activationCallbackUrl": {
            "type": "string",
            "description": "Callback url to use by Haflsund Flex to activate the given asset. The callback URL needs to implement the API spec defined in https://app.swaggerhub.com/apis/FRIKKSOL/AssetActivationApi/1.1"
          }
