{
  "openapi": "3.0.3",
  "info": {
    "title": "Sendy API",
    "version": "1.0.0",
    "description": "Sendy is a self-hosted email newsletter application. The API allows managing subscribers, lists, campaigns, and brands.",
    "contact": {
      "name": "Sendy",
      "url": "https://sendy.co"
    },
    "x-jentic-source-url": "https://sendy.co/api"
  },
  "servers": [
    {
      "url": "https://your-sendy-installation.com",
      "description": "Self-hosted Sendy instance"
    }
  ],
  "tags": [
    {
      "name": "Subscribers",
      "description": "Manage email subscribers"
    },
    {
      "name": "Lists",
      "description": "List management"
    },
    {
      "name": "Campaigns",
      "description": "Campaign operations"
    },
    {
      "name": "Brands",
      "description": "Brand management"
    }
  ],
  "paths": {
    "/subscribe": {
      "post": {
        "operationId": "subscribe",
        "summary": "Subscribe an email",
        "description": "Add a subscriber to a list",
        "tags": [
          "Subscribers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "email",
                  "list"
                ],
                "properties": {
                  "api_key": {
                    "type": "string",
                    "description": "API key"
                  },
                  "email": {
                    "type": "string",
                    "description": "Email address"
                  },
                  "list": {
                    "type": "string",
                    "description": "List ID"
                  },
                  "name": {
                    "type": "string",
                    "description": "Subscriber name"
                  },
                  "country": {
                    "type": "string",
                    "description": "2-letter country code"
                  },
                  "ipaddress": {
                    "type": "string",
                    "description": "Subscriber IP"
                  },
                  "referrer": {
                    "type": "string",
                    "description": "Referrer URL"
                  },
                  "gdpr": {
                    "type": "boolean",
                    "description": "GDPR consent"
                  },
                  "silent": {
                    "type": "boolean",
                    "description": "No email confirmation"
                  },
                  "hp": {
                    "type": "string",
                    "description": "Honeypot field"
                  },
                  "boolean": {
                    "type": "boolean",
                    "description": "Return plain text response"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription result",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/unsubscribe": {
      "post": {
        "operationId": "unsubscribe",
        "summary": "Unsubscribe an email",
        "description": "Remove a subscriber from a list",
        "tags": [
          "Subscribers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "email",
                  "list"
                ],
                "properties": {
                  "api_key": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "list": {
                    "type": "string"
                  },
                  "boolean": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Result",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/subscribers/delete.php": {
      "post": {
        "operationId": "deleteSubscriber",
        "summary": "Delete a subscriber",
        "description": "Permanently delete a subscriber from a list",
        "tags": [
          "Subscribers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "email",
                  "list_id"
                ],
                "properties": {
                  "api_key": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "list_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Result",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/subscribers/subscription-status.php": {
      "post": {
        "operationId": "subscriptionStatus",
        "summary": "Get subscription status",
        "description": "Check the subscription status of an email",
        "tags": [
          "Subscribers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "email",
                  "list_id"
                ],
                "properties": {
                  "api_key": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "list_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status (Subscribed/Unsubscribed/Bounced/Soft bounced/Unconfirmed/Complained/Not in list)",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/subscribers/active-subscriber-count.php": {
      "post": {
        "operationId": "activeSubscriberCount",
        "summary": "Get active subscriber count",
        "description": "Get the count of active subscribers for a list",
        "tags": [
          "Lists"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "list_id"
                ],
                "properties": {
                  "api_key": {
                    "type": "string"
                  },
                  "list_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Count",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/campaigns/create.php": {
      "post": {
        "operationId": "createCampaign",
        "summary": "Create and send a campaign",
        "description": "Create a draft or send a campaign immediately",
        "tags": [
          "Campaigns"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "from_name",
                  "from_email",
                  "reply_to",
                  "subject",
                  "html_text",
                  "list_ids",
                  "brand_id"
                ],
                "properties": {
                  "api_key": {
                    "type": "string"
                  },
                  "from_name": {
                    "type": "string"
                  },
                  "from_email": {
                    "type": "string"
                  },
                  "reply_to": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string",
                    "description": "Campaign title (internal)"
                  },
                  "subject": {
                    "type": "string"
                  },
                  "plain_text": {
                    "type": "string"
                  },
                  "html_text": {
                    "type": "string"
                  },
                  "list_ids": {
                    "type": "string",
                    "description": "Comma-separated list IDs"
                  },
                  "segment_ids": {
                    "type": "string",
                    "description": "Comma-separated segment IDs"
                  },
                  "exclude_list_ids": {
                    "type": "string"
                  },
                  "exclude_segments_ids": {
                    "type": "string"
                  },
                  "brand_id": {
                    "type": "integer"
                  },
                  "query_string": {
                    "type": "string"
                  },
                  "track_opens": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  },
                  "track_clicks": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  },
                  "send_campaign": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "0=draft, 1=send immediately"
                  },
                  "schedule_date_time": {
                    "type": "string",
                    "description": "Schedule for later (YYYY-MM-DD HH:MM:SS)"
                  },
                  "schedule_timezone": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Result (campaign ID or error)",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/lists/create-list.php": {
      "post": {
        "operationId": "createList",
        "summary": "Create a list",
        "description": "Create a new subscriber list",
        "tags": [
          "Lists"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "brand_id",
                  "list_name"
                ],
                "properties": {
                  "api_key": {
                    "type": "string"
                  },
                  "brand_id": {
                    "type": "integer"
                  },
                  "list_name": {
                    "type": "string"
                  },
                  "opt_in_type": {
                    "type": "string",
                    "enum": [
                      "single",
                      "double"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Result (list ID or error)",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/brands/get-brands.php": {
      "post": {
        "operationId": "getBrands",
        "summary": "Get brands",
        "description": "Returns a list of brands in the Sendy installation",
        "tags": [
          "Brands"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key"
                ],
                "properties": {
                  "api_key": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Brands list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer"
                      },
                      "name": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Sendy API key (passed in POST body)"
      }
    }
  }
}