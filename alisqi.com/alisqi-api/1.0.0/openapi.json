{
  "openapi": "3.0.3",
  "info": {
    "title": "AlisQI API",
    "version": "1.0.0",
    "description": "Quality management API for managing analysis sets, selection lists, results, statistics, and specification evaluations.",
    "x-jentic-source-url": "https://alisqi.readme.io/reference/developer-portal",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.alisqi.com"
    }
  ],
  "paths": {
    "/getAllSets": {
      "get": {
        "operationId": "getAllSets",
        "summary": "Get all analysis sets or selection lists",
        "tags": [
          "Sets"
        ],
        "parameters": [
          {
            "name": "groups",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "names",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Set"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get all analysis sets or selection lists"
      }
    },
    "/getSetDefinition": {
      "get": {
        "operationId": "getSetDefinition",
        "summary": "Get set definition",
        "tags": [
          "Sets"
        ],
        "parameters": [
          {
            "name": "setId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "onlyActiveFields",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get set definition"
      }
    },
    "/createSet": {
      "post": {
        "operationId": "createSet",
        "summary": "Create a set or list",
        "tags": [
          "Sets"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a set or list"
      }
    },
    "/getResults": {
      "get": {
        "operationId": "getResults",
        "summary": "Get results or master data",
        "tags": [
          "Results"
        ],
        "parameters": [
          {
            "name": "setId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeAttachments",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "includeId",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "includeLastModificationDate",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get results or master data"
      }
    },
    "/storeResults": {
      "post": {
        "operationId": "storeResults",
        "summary": "Create or update results",
        "tags": [
          "Results"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "setId": {
                    "type": "string"
                  },
                  "results": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "keyField": {
                    "type": "string"
                  },
                  "editOnly": {
                    "type": "boolean"
                  },
                  "addListOptions": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stored"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create or update results"
      }
    },
