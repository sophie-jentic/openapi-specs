        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "setId": {
                    "type": "string"
                  },
                  "specs": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "indexValue": {
                    "type": "string"
                  },
                  "startDateTime": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
