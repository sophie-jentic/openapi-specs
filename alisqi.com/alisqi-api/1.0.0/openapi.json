    "/getSpecificationVersion": {
      "get": {
        "operationId": "getSpecificationVersion",
        "summary": "Get specification versions",
        "tags": [
          "Specifications"
        ],
        "parameters": [
          {
            "name": "setId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "indexValue",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
