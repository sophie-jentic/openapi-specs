  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "Token-based authentication. Format: 'Token token=YOUR_API_TOKEN'. Generate tokens via the G2 integrations page at https://www.g2.com/static/integrations"
      }
    },
    "parameters": {
      "pageSize": {
        "name": "page[size]",
        "in": "query",
        "description": "Number of results per page (default: 10, max: 100)",
        "schema": {
          "type": "integer",
          "default": 10,
          "maximum": 100
        }
      },
      "pageNumber": {
        "name": "page[number]",
        "in": "query",
        "description": "Page number (default: 1)",
        "schema": {
          "type": "integer",
          "default": 1
        }
      }
    },
    "schemas": {
      "JsonApiResource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Resource ID"
          },
          "type": {
            "type": "string",
            "description": "Resource type"
          },
          "attributes": {
            "type": "object",
            "description": "Resource attributes"
          },
          "relationships": {
            "type": "object",
            "description": "Resource relationships"
          },
          "links": {
            "type": "object",
            "description": "Resource links"
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "total_count": {
            "type": "integer"
          },
          "page_count": {
            "type": "integer"
          },
          "current_page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          }
        }
      },
      "PaginationLinks": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string"
          },
          "next": {
            "type": "string"
          },
          "prev": {
            "type": "string"
          },
          "first": {
            "type": "string"
          },
          "last": {
            "type": "string"
          }
        }
      },
      "ProductListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Product"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          },
          "links": {
            "$ref": "#/components/schemas/PaginationLinks"
          }
        }
      },
      "ProductResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Product"
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "products"
            ]
          },
          "attributes": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "slug": {
                "type": "string"
              },
              "domain": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "star_rating": {
                "type": "number",
                "format": "float"
              },
              "review_count": {
                "type": "integer"
              },
              "updated_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "SurveyResponseListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SurveyResponse"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          },
          "links": {
            "$ref": "#/components/schemas/PaginationLinks"
          }
        }
      },
      "SurveyResponseResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/SurveyResponse"
          }
        }
      },
      "SurveyResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "survey-responses"
            ]
          },
          "attributes": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "star_rating": {
                "type": "number",
                "format": "float"
              },
              "comment_answers": {
                "type": "object"
              },
              "submitted_at": {
                "type": "string",
                "format": "date-time"
              },
              "updated_at": {
                "type": "string",
                "format": "date-time"
