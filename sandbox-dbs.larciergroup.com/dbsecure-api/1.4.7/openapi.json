{
  "openapi": "3.0.1",
  "info": {
    "title": "DbSecure API",
    "description": "Larcier's identity provider methods",
    "contact": {
      "name": "DBiT",
      "url": "http://www.dbit.lu",
      "email": "hp.cerveragarcia@dbit.lu"
    },
    "version": "1.4.7",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/DBiT/DbSecure/1.4.7"
  },
  "servers": [
    {
      "url": "https://sandbox-dbs.larciergroup.com/"
    }
  ],
  "tags": [
    {
      "name": "OAuth2",
      "description": "OAuth2 methods"
    }
  ],
  "paths": {
    "/oauth2/token": {
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Generate access token",
        "description": "Retrieve access token for a known/anonymous user.",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "required": [
                  "grant_type"
                ],
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "description": "OAuth2 flow mode",
                    "enum": [
                      "password",
                      "refresh_token",
                      "device"
                    ]
                  },
                  "username": {
                    "type": "string",
                    "description": "User login | **Required if grant_type=password**"
                  },
                  "password": {
                    "type": "string",
                    "description": "User password credentials | **Required if grant_type=password**"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Refresh token previously issued for an access token | **Required if grant_type=refresh_token**"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "JSON object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessToken"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "security": [
          {
            "ClientCredentials": []
          }
        ],
        "operationId": "post_oauth2_token"
      }
    },
    "/oauth2/info": {
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Retrieve user data",
        "description": "Retrieve user informations associated to a given access token .",
        "responses": {
          "200": {
            "description": "JSON object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InfoResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "operationId": "post_oauth2_info"
      }
    },
    "/oauth2/revoke": {
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Revoke access token",
        "description": "Explicitly remove access token from DbSecure.",
        "responses": {
          "200": {
            "description": "JSON object",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Empty response object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "security": [
          {
            "ClientCredentials": []
          }
        ],
        "operationId": "post_oauth2_revoke"
      }
    }
  },
  "components": {
    "schemas": {
      "formData_grantType": {
        "type": "string",
        "description": "OAuth2 flow mode",
        "enum": [
          "password",
          "refresh_token",
          "device"
        ]
      },
      "AccessToken": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "Access token itself",
            "example": "c463bcd32a727a7c739bd25590721d214afe6852"
          },
          "user_id": {
            "type": "integer",
            "description": "DbSecure user identifier",
            "example": 1
          },
          "expires_in": {
            "type": "integer",
            "description": "Number of seconds the access token remains valid",
            "example": 65000
          },
          "token_type": {
            "type": "string",
            "description": "Fixed token type \"bearer\". See [OAuth2 specification](https://tools.ietf.org/html/rfc6750)",
            "example": "bearer",
            "default": "bearer"
          },
          "scope": {
            "type": "string",
            "description": "Specific rights granted to this access token. Unused for now.",
            "example": ""
          },
          "refresh_token": {
            "type": "string",
            "description": "Token used to retrieve a new access_token without interaction from the user.",
            "example": "f587291bb1cc32ec184aeb203716dd87779b98a1"
          }
        },
        "description": "OAuth2 user access token"
      },
      "InfoResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "integer",
            "description": "Whether an error has occurred",
            "example": 0
          },
          "ts": {
            "type": "integer",
            "description": "Timestamp where answer was generated at",
            "example": 1475834269
          },
          "req": {
            "type": "string",
            "description": "API endpoint used",
            "example": "/oauth2/info"
          },
          "usr": {
            "type": "integer",
            "description": "DbSecure user identifier. | 0 on device token.",
            "example": 1
          },
          "ssid": {
            "type": "integer",
            "description": "Associated session identifier, if any",
            "nullable": true,
            "example": 1234567
          },
          "data": {
            "type": "string",
            "description": "Existing data field in response where main method resulting data would be stored",
            "example": "userInfo",
            "default": "userInfo"
          },
          "userInfo": {
            "$ref": "#/components/schemas/UserInfo"
          }
        },
        "description": "User data associated to an access token"
      },
      "UserInfo": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "description": "DbSecure user identifier. | 0 on device token.",
            "example": 1
          },
          "accountId": {
            "type": "integer",
            "description": "DbSecure user account identifier.",
            "example": 338800
          },
          "atlasId": {
            "type": "integer",
            "description": "Atlas user identifier.",
            "example": 0
          },
          "lastName": {
            "type": "string",
            "description": "User's last name",
            "example": "Skywalker"
          },
          "firstName": {
            "type": "string",
            "description": "User's first name",
            "example": "Luke"
          },
          "title": {
            "type": "string",
            "description": "User's titles",
            "example": "Monsieur"
          },
          "isActive": {
            "type": "string",
            "description": "Whether user is active",
            "example": "1",
            "enum": [
              "0",
              "1"
            ]
          },
          "language": {
            "type": "string",
            "description": "User's language",
            "nullable": true,
            "example": "fr",
            "enum": [
              "fr",
              "nl",
              "en"
            ]
          },
          "email": {
            "type": "string",
            "description": "User's email. Please note that this email might differ from username (login).",
            "format": "email",
            "nullable": true,
            "example": "red5@rebel-alliance.com"
          },
          "telephone": {
            "type": "string",
            "description": "User's phone",
            "nullable": true,
            "example": "+352 11 223344"
          },
          "gsm": {
            "type": "string",
            "description": "User's mobile phone",
            "nullable": true,
            "example": "+352 11 223344"
          },
          "fax": {
            "type": "string",
            "description": "User's fax",
            "nullable": true,
            "example": "+352 11 223344"
          },
          "function": {
            "type": "string",
            "description": "User's professional role",
            "nullable": true,
            "example": "Lawyer"
          },
          "dateCreated": {
            "type": "string",
            "description": "User creation date",
            "example": "2016-09-02 12:50:56"
          },
          "type": {
            "type": "string",
            "description": "User's type",
            "example": "NORM"
          },
          "readOnlyAdmin": {
            "type": "string",
            "description": "If it's admin without write access",
            "example": "0",
            "enum": [
              "0",
              "1"
            ]
          },
          "fullName": {
            "type": "string",
            "description": "User's first + last name",
            "example": "Luke Skywalker"
          },
          "username": {
            "type": "string",
            "description": "User's login, normally email but not restricted to that format.",
            "example": "red5@rebel-alliance.com"
          },
          "isOcean": {
            "type": "boolean",
            "description": "User category in Larcier's business model"
          },
          "companies": {
            "type": "object",
            "properties": {},
            "description": "User's companies. Unused for now."
          }
        },
        "description": "User data associated to an access token"
      },
      "ErrorModel": {
        "required": [
          "message",
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ClientCredentials": {
        "type": "http",
        "description": "Application **Client key** & **Client secret**",
        "scheme": "basic"
      },
      "Bearer": {
        "type": "apiKey",
        "description": "Client access token. | **Format:** \"Bearer [myAccessToken]\"",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "x-original-swagger-version": "2.0"
}
