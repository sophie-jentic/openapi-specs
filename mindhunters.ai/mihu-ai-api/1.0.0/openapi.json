  "components": {
    "schemas": {
      "InitiateCallRequest": {
        "type": "object",
        "required": [
          "agentId",
          "participant"
        ],
        "properties": {
          "agentId": {
            "type": "string",
            "format": "uuid"
          },
          "prompt": {
            "type": "object"
          },
          "participant": {
            "type": "object",
            "required": [
              "phone"
            ],
            "properties": {
              "phone": {
                "type": "string",
                "description": "E.164 format"
              }
            }
          }
        }
      },
      "CallResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "uuid": {
                "type": "string",
                "format": "uuid"
              },
              "status": {
                "type": "string"
              },
              "duration": {
                "type": "integer"
              }
            }
          }
        }
      },
      "CallListResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "uuid": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "created_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
