            "oauth2": []
          }
        ],
        "responses": {
          "200": {
            "description": "Enumerations retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "enumerations": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agent-locator/v1/locations": {
      "get": {
        "summary": "Find agent locations",
        "description": "Find MoneyGram agent locations",
        "operationId": "findAgentLocations",
        "tags": [
          "Support"
        ],
        "security": [
          {
            "oauth2": []
          }
        ],
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Country code (ISO 3166)"
          },
          {
            "name": "city",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "City name"
          },
          {
            "name": "postalCode",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Postal code"
          }
        ],
        "responses": {
          "200": {
            "description": "Agent locations retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "locations": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "agentName": {
                            "type": "string"
                          },
                          "address": {
                            "type": "string"
                          },
                          "latitude": {
                            "type": "number"
                          },
                          "longitude": {
                            "type": "number"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fxrate/v1/rates": {
      "get": {
        "summary": "Get exchange rates",
        "description": "Retrieve foreign exchange rates",
        "operationId": "getExchangeRates",
        "tags": [
          "Support"
        ],
        "security": [
          {
            "oauth2": []
          }
        ],
        "parameters": [
          {
            "name": "fromCurrency",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Source currency (ISO 4217)"
          },
          {
            "name": "toCurrency",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Target currency (ISO 4217)"
          }
        ],
        "responses": {
          "200": {
            "description": "Exchange rates retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fromCurrency": {
                      "type": "string"
                    },
                    "toCurrency": {
                      "type": "string"
                    },
                    "rate": {
                      "type": "number",
                      "description": "Exchange rate"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://api.moneygram.com/oauth/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "userLanguage": {
            "type": "string",
            "description": "Language for error messages"
          }
        }
      }
    }
  },
  "tags": [
