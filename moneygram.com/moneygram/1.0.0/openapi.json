        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": {
                    "type": "number",
                    "description": "Disbursement amount"
                  },
                  "currency": {
                    "type": "string",
                    "description": "Currency (ISO 4217)"
                  },
                  "destinationCountry": {
                    "type": "string",
                    "description": "Destination country (ISO 3166)"
                  }
                }
              }
            }
          }
