    "/reference-data/v1/countries": {
      "get": {
        "summary": "Get countries",
        "description": "Retrieve list of countries",
        "operationId": "getCountries",
        "tags": [
          "Reference Data"
        ],
        "security": [
          {
            "oauth2": []
          }
        ],
        "responses": {
          "200": {
            "description": "Countries retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "countries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": {
                            "type": "string",
                            "description": "Country code (ISO 3166)"
                          },
                          "name": {
                            "type": "string",
                            "description": "Country name"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/reference-data/v1/currencies": {
      "get": {
        "summary": "Get currencies",
        "description": "Retrieve list of currencies",
        "operationId": "getCurrencies",
        "tags": [
          "Reference Data"
        ],
        "security": [
          {
            "oauth2": []
          }
        ],
        "responses": {
          "200": {
            "description": "Currencies retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "currencies": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": {
                            "type": "string",
                            "description": "Currency code (ISO 4217)"
                          },
                          "name": {
                            "type": "string",
                            "description": "Currency name"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
