{
  "openapi": "3.0.3",
  "info": {
    "title": "MoneyGram API",
    "description": "MoneyGram API for money transfers, disbursements, transaction status, and reference data",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developer.moneygram.com/moneygram-developer/docs/api-overview",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.moneygram.com",
      "description": "Production server"
    },
    {
      "url": "https://sandboxapi.moneygram.com",
      "description": "Sandbox server"
    }
  ],
  "paths": {
    "/transfer/v1/transactions/{transactionID}/quote": {
      "post": {
        "summary": "Quote transfer transaction",
        "description": "Get a quote for a consumer-to-consumer transfer transaction",
        "operationId": "quoteTransfer",
        "tags": [
          "Transfer"
        ],
        "security": [
          {
            "oauth2": []
          }
        ],
        "parameters": [
          {
            "name": "transactionID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Transaction identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sendAmount": {
                    "type": "number",
                    "description": "Amount to send"
                  },
                  "sendCurrency": {
                    "type": "string",
                    "description": "Send currency (ISO 4217)"
                  },
                  "receiveCurrency": {
                    "type": "string",
                    "description": "Receive currency (ISO 4217)"
                  },
                  "destinationCountry": {
                    "type": "string",
                    "description": "Destination country (ISO 3166)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quote generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transactionID": {
                      "type": "string",
                      "description": "Transaction identifier"
                    },
                    "receiveAmount": {
                      "type": "number",
                      "description": "Amount to be received"
                    },
                    "fees": {
                      "type": "number",
                      "description": "Transaction fees"
                    },
                    "exchangeRate": {
                      "type": "number",
                      "description": "Exchange rate"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transfer/v1/transactions/{transactionID}": {
      "put": {
        "summary": "Update transfer transaction",
        "description": "Update a consumer-to-consumer transfer transaction",
        "operationId": "updateTransfer",
        "tags": [
          "Transfer"
        ],
        "security": [
          {
            "oauth2": []
          }
        ],
        "parameters": [
          {
            "name": "transactionID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Transaction identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "senderFirstName": {
                    "type": "string",
                    "description": "Sender first name"
                  },
                  "senderLastName": {
                    "type": "string",
                    "description": "Sender last name"
                  },
                  "receiverFirstName": {
                    "type": "string",
                    "description": "Receiver first name"
                  },
                  "receiverLastName": {
                    "type": "string",
                    "description": "Receiver last name"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transactionID": {
                      "type": "string",
                      "description": "Transaction identifier"
                    },
                    "status": {
                      "type": "string",
                      "description": "Transaction status"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transfer/v1/transactions/{transactionID}/commit": {
      "put": {
        "summary": "Commit transfer transaction",
        "description": "Commit a consumer-to-consumer transfer transaction",
        "operationId": "commitTransfer",
        "tags": [
          "Transfer"
        ],
        "security": [
          {
            "oauth2": []
          }
        ],
        "parameters": [
          {
            "name": "transactionID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Transaction identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction committed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transactionID": {
                      "type": "string",
                      "description": "Transaction identifier"
                    },
                    "referenceNumber": {
                      "type": "string",
                      "description": "Transaction reference number"
                    },
                    "status": {
                      "type": "string",
                      "description": "Transaction status"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/status/v1/transactions/": {
      "get": {
        "summary": "Get transaction status",
        "description": "Retrieve transaction status by reference number",
        "operationId": "getTransactionStatus",
        "tags": [
          "Status"
        ],
        "security": [
          {
            "oauth2": []
          }
        ],
        "parameters": [
          {
            "name": "referenceNumber",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Transaction reference number"
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction status retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "referenceNumber": {
                      "type": "string",
                      "description": "Transaction reference number"
                    },
                    "status": {
                      "type": "string",
                      "description": "Transaction status"
                    },
                    "amount": {
                      "type": "number",
                      "description": "Transaction amount"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Transaction not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/disbursement/v1/transactions/{transactionID}/quote": {
      "post": {
        "summary": "Quote disbursement",
