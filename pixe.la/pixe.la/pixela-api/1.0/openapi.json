{
  "openapi": "3.0.3",
  "info": {
    "title": "Pixela API",
    "description": "Pixela is a pixelation API service that creates GitHub-style contribution graphs. Record daily quantities, generate SVG graphs, manage users, graphs, pixels, and webhooks.",
    "version": "1.0",
    "contact": {
      "name": "Pixela",
      "url": "https://pixe.la/"
    },
    "license": {
      "name": "Pixela Terms of Service",
      "url": "https://github.com/a-know/Pixela/wiki/Terms-of-Service"
    }
  },
  "externalDocs": {
    "description": "Pixela API Documentation",
    "url": "https://docs.pixe.la/"
  },
  "servers": [
    {
      "url": "https://pixe.la/v1",
      "description": "Pixela Production"
    }
  ],
  "paths": {
    "/users": {
      "post": {
        "operationId": "createUser",
        "summary": "Create a new user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "username",
                  "agreeTermsOfService",
                  "notMinor"
                ],
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "Authentication token (8-128 printable ASCII chars)"
                  },
                  "username": {
                    "type": "string",
                    "description": "Username (pattern: [a-z][a-z0-9-]{1,32})"
                  },
                  "agreeTermsOfService": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ]
                  },
                  "notMinor": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ]
                  },
                  "thanksCode": {
                    "type": "string",
                    "description": "Optional Patreon thanks code"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "409": {
            "description": "User already exists"
          }
        },
        "description": "Create a new user",
        "tags": [
          "users"
        ]
      }
    },
    "/users/{username}": {
      "put": {
        "operationId": "updateUser",
        "summary": "Update user token",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/userToken"
          },
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "newToken"
                ],
                "properties": {
                  "newToken": {
                    "type": "string"
                  },
                  "thanksCode": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        },
        "description": "Update user token",
        "tags": [
          "users"
        ]
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete a user",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/userToken"
          },
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        },
        "description": "Delete a user",
        "tags": [
          "users"
        ]
      }
    },
    "/users/{username}/graphs": {
      "get": {
        "operationId": "listGraphs",
        "summary": "List all graphs for a user",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/userToken"
          },
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of graphs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "graphs": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Graph"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List all graphs for a user",
        "tags": [
          "users"
        ]
      },
      "post": {
        "operationId": "createGraph",
        "summary": "Create a new graph",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/userToken"
          },
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id",
                  "name",
                  "unit",
                  "type",
                  "color"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Graph ID (pattern: ^[a-z][a-z0-9-]{1,16})"
                  },
                  "name": {
                    "type": "string"
                  },
                  "unit": {
                    "type": "string",
                    "description": "Unit of quantity (e.g. commit, kilogram)"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "int",
                      "float"
                    ]
                  },
                  "color": {
                    "type": "string",
                    "enum": [
                      "shibafu",
                      "momiji",
                      "sora",
                      "ichou",
                      "ajisai",
                      "kuro"
                    ],
                    "description": "Colors: shibafu(green), momiji(red), sora(blue), ichou(yellow), ajisai(purple), kuro(black)"
                  },
                  "timezone": {
                    "type": "string",
                    "description": "TZ database name (e.g. Asia/Tokyo)"
                  },
                  "description": {
                    "type": "string",
                    "maxLength": 256
                  },
                  "startOnMonday": {
                    "type": "boolean"
                  },
                  "selfSufficient": {
                    "type": "string",
                    "enum": [
                      "none",
                      "increment",
                      "decrement"
                    ]
                  },
                  "isSecret": {
                    "type": "boolean"
                  },
                  "publishOptionalData": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Graph created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "409": {
            "description": "Graph already exists"
          }
        },
        "description": "Create a new graph",
        "tags": [
          "users"
        ]
      }
    },
    "/users/{username}/graphs/{graphId}": {
      "get": {
        "operationId": "getGraphSvg",
        "summary": "Get graph SVG",
        "description": "Returns the graph as an SVG image.",
        "security": [],
