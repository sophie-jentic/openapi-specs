          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/graphId"
          },
          {
            "name": "date",
            "in": "query",
            "description": "Display graph up to this date (yyyyMMdd)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "description": "Graph display mode",
            "schema": {
              "type": "string",
              "enum": [
                "short",
                "badge",
                "line"
              ]
            }
          },
          {
            "name": "graphId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SVG graph",
            "content": {
              "image/svg+xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "tags": [
          "users"
        ]
      },
      "put": {
        "operationId": "updateGraph",
        "summary": "Update a graph definition",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/graphId"
          },
          {
            "$ref": "#/components/parameters/userToken"
          },
          {
            "name": "graphId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "unit": {
                    "type": "string"
                  },
                  "color": {
                    "type": "string",
                    "enum": [
                      "shibafu",
                      "momiji",
                      "sora",
                      "ichou",
                      "ajisai",
                      "kuro"
                    ]
                  },
                  "timezone": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "purgeCacheURLs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "selfSufficient": {
                    "type": "string"
                  },
                  "isSecret": {
                    "type": "boolean"
                  },
                  "publishOptionalData": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Graph updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        },
        "description": "Update a graph definition",
        "tags": [
          "users"
        ]
      },
      "delete": {
        "operationId": "deleteGraph",
        "summary": "Delete a graph",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/graphId"
          },
          {
            "$ref": "#/components/parameters/userToken"
          },
          {
            "name": "graphId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Graph deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        },
        "description": "Delete a graph",
        "tags": [
          "users"
        ]
      }
    },
