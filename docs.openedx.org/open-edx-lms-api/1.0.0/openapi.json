  "info": {
    "title": "Open edX LMS API",
    "version": "1.0.0",
    "description": "The Open edX LMS API provides programmatic access to the Open edX learning management system. It supports course management, enrollment, grades, certificates, bookmarks, cohorts, content, and more.",
