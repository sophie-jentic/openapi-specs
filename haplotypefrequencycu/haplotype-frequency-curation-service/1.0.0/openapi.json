{
  "openapi": "3.0.1",
  "info": {
    "title": "Haplotype Frequency Curation Service",
    "description": "Allows to store and return haplotype frequency data",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/matthias.niemann/haplotype-frequency_curation_service/1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/hfc/{submissionId}": {
      "get": {
        "description": "Returns a submission of haplotypes",
        "parameters": [
          {
            "name": "submissionId",
            "in": "path",
            "description": "The submission id that the haplotype frequencies were submitted under",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the data set containing all references",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/HFCurationResponse"
                }
              }
            }
          },
          "500": {
            "description": "An unexpected error ocurred",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_hfc_submissionId",
        "tags": [
          "hfc"
        ]
      }
    },
    "/hfc/{submissionId}/haplotypes": {
      "get": {
        "description": "Returns the list of haplotypes attached to the given submission",
        "parameters": [
          {
            "name": "submissionId",
            "in": "path",
            "description": "The submission id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the haplotype frequency data",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/HaplotypeFrequencyData"
                }
              }
            }
          },
          "500": {
            "description": "An unexpected error ocurred",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_hfc_submissionId_haplotypes",
        "tags": [
          "hfc"
        ]
      }
    },
    "/hfc/{submissionId}/cohort": {
      "get": {
        "description": "Returns the list of haplotypes attached to the given submission",
        "parameters": [
          {
            "name": "submissionId",
            "in": "path",
            "description": "The submission id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the cohort data and genotypes if available",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/CohortData"
                }
              }
            }
          },
          "500": {
            "description": "An unexpected error ocurred",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_hfc_submissionId_cohort",
        "tags": [
          "hfc"
        ]
      }
    },
    "/hfc/{submissionId}/population": {
      "get": {
        "description": "Returns the population of the given submission",
        "parameters": [
          {
            "name": "submissionId",
            "in": "path",
            "description": "The submission id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the population",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PopulationData"
                }
              }
            }
          },
          "500": {
            "description": "An unexpected error ocurred",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_hfc_submissionId_population",
        "tags": [
          "hfc"
        ]
      }
    },
    "/hfc/{submissionId}/labels": {
      "get": {
        "description": "Returns the labels associated to the submission",
        "parameters": [
          {
            "name": "submissionId",
            "in": "path",
            "description": "The submission id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns label set",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LabelData"
                }
              }
            }
          },
          "500": {
            "description": "An unexpected error ocurred",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_hfc_submissionId_labels",
        "tags": [
          "hfc"
        ]
      }
    },
    "/hfc/{submissionId}/scope": {
      "get": {
        "description": "Returns the scope of the genotypes used for creating the submitted haplotypes",
        "parameters": [
          {
            "name": "submissionId",
            "in": "path",
            "description": "The submission id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns scope set",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ScopeData"
                }
              }
            }
          },
          "500": {
            "description": "An unexpected error ocurred",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_hfc_submissionId_scope",
        "tags": [
          "hfc"
        ]
      }
    },
    "/hfc": {
      "get": {
        "description": "Gets a list of all submission data sets\n",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/HFCurationListResponse"
                }
              }
            }
          },
          "500": {
            "description": "An unexpected error ocurred",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_hfc",
        "tags": [
          "hfc"
        ]
      },
      "post": {
        "description": "Storing of a new Haplotype Frequency set.\n",
        "requestBody": {
          "description": "Haplotype Frequency Curation Data",
          "content": {
            "*/*": {
              "schema": {
                "$ref": "#/components/schemas/HFCurationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/HFCurationResponse"
                }
              }
            }
          },
          "500": {
            "description": "An unexpected error ocurred",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "x-codegen-request-body-name": "HFCurationRequest",
        "operationId": "post_hfc",
        "tags": [
          "hfc"
        ]
      }
    },
    "/hfc/population": {
      "get": {
        "description": "Get a list of all populations\n",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PopulationResponse"
                }
              }
            }
          },
          "500": {
            "description": "An unexpected error ocurred",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_hfc_population",
        "tags": [
          "hfc"
        ]
      }
    },
    "/hfc/population/{populationId}": {
      "get": {
        "description": "Returns a population with its attached submissions",
        "parameters": [
          {
            "name": "populationId",
            "in": "path",
            "description": "The population id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the population including all attached submissions",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PopulationSubmissionResponse"
                }
              }
            }
          },
          "500": {
            "description": "An unexpected error ocurred",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_hfc_population_populationId",
        "tags": [
          "hfc"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "HFCurationListResponse": {
        "title": "HFCurationResponseList",
        "type": "object",
        "properties": {
          "HFCurationResponses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HFCurationResponse"
            }
          }
        }
      },
      "HFCurationResponse": {
        "title": "HFCurationResponse",
        "required": [
          "SubmissionID"
        ],
        "type": "object",
        "properties": {
          "SubmissionID": {
            "type": "string",
            "description": "Reference to a submission"
          },
          "PopulationID": {
            "type": "string",
            "description": "Reference to a population"
          },
          "CohortID": {
            "type": "string",
            "description": "References a cohort"
          },
          "MethodSetID": {
            "type": "string",
            "description": "References a method set"
          },
          "LabelID": {
            "type": "string",
            "description": "References a label"
          },
          "HaplotypeListID": {
            "type": "string",
            "description": "References a haplotype list"
          },
          "ScopeID": {
            "type": "string",
            "description": "References a scope"
          },
          "AccessID": {
            "type": "string",
            "description": "References a access controls"
          }
        }
      },
      "PopulationSubmissionResponse": {
        "title": "PopulationSubmissionResponse",
        "type": "object",
        "properties": {
          "PopulationSubmissionList": {
            "type": "array",
            "description": "List of populations together with all attached submissions",
            "items": {
              "$ref": "#/components/schemas/PopulationSubmissionData"
            }
          }
        }
      },
      "PopulationResponse": {
        "title": "PopulationResponse",
        "type": "object",
        "properties": {
          "PopulationList": {
            "type": "array",
            "description": "List of populations",
            "items": {
              "$ref": "#/components/schemas/PopulationData"
            }
          }
        }
      },
      "HFCurationRequest": {
        "title": "HFCurationRequest",
        "required": [
          "PopulationID"
        ],
        "type": "object",
        "properties": {
          "PopulationID": {
            "type": "string",
            "description": "Reference to a population"
          },
          "PopulationData": {
            "$ref": "#/components/schemas/PopulationData"
          },
          "CohortID": {
            "type": "string",
            "description": "Cohort ID or genotype list"
          },
          "CohortData": {
            "$ref": "#/components/schemas/CohortData"
          },
          "MethodSetID": {
            "type": "string",
            "description": "References a method set"
          },
          "MethodData": {
            "$ref": "#/components/schemas/MethodData"
          },
          "LabelID": {
            "type": "string",
            "description": "References a label"
          },
          "LabelData": {
            "$ref": "#/components/schemas/LabelData"
          },
          "HaplotypeFrequencyDataID": {
            "type": "string",
            "description": "References a haplotype list"
          },
          "HaplotypeFrequencyData": {
            "$ref": "#/components/schemas/HaplotypeFrequencyData"
          },
          "ScopeID": {
            "type": "string",
            "description": "References a scope"
          },
          "ScopeData": {
            "$ref": "#/components/schemas/ScopeData"
          },
          "AccessID": {
            "type": "string",
            "description": "References a access controls"
          },
          "AccessData": {
            "$ref": "#/components/schemas/AccessData"
          }
        }
      },
      "AccessData": {
        "title": "AccessData",
        "required": [
          "typeOfAccess"
        ],
        "type": "object",
        "properties": {
          "typeOfAccess": {
            "type": "string",
            "description": "There will be a default license if one is not provided"
          }
        }
      },
      "HaplotypeFrequencyData": {
        "title": "HaplotypeFrequencyData",
        "required": [
          "HaplotypeFrequencyList",
          "License"
        ],
        "type": "object",
        "properties": {
          "License": {
            "$ref": "#/components/schemas/License"
          },
          "ResolutionData": {
            "$ref": "#/components/schemas/ResolutionData"
          },
          "HaplotypeFrequencyList": {
            "title": "HaplotypeFrequencyList",
            "type": "array",
            "description": "List of HaplotypeFrequencys",
            "items": {
              "$ref": "#/components/schemas/HaplotypeFrequency"
            }
          },
          "QualityList": {
            "type": "array",
            "description": "List of Quality",
            "items": {
              "$ref": "#/components/schemas/Quality"
            }
          }
        }
      },
      "HaplotypeFrequency": {
        "title": "HaplotypeFrequency",
        "required": [
          "frequency",
          "haplotypeString"
        ],
        "type": "object",
        "properties": {
          "haplotypeString": {
            "type": "string",
            "description": "GL string describing the haplotype"
          },
          "frequency": {
            "type": "number",
            "description": "frequency"
          },
          "FrequencyErrorList": {
            "type": "array",
            "description": "List of frequency errors",
            "items": {
              "$ref": "#/components/schemas/FrequencyError"
            }
          }
        }
      },
      "Quality": {
        "title": "Quality",
        "required": [
          "typeOfQuality",
          "value"
        ],
        "type": "object",
        "properties": {
          "value": {
            "type": "number",
            "description": "label name"
          },
          "typeOfQuality": {
            "type": "string",
            "description": "type of quality",
            "enum": [
              "DIV_LAMBDA",
              "DIV_50",
              "DIV_50_REL",
              "SAM_SIZE",
              "SAM_POP",
              "DIV_PGD",
              "DIV_HEAVY_TAIL",
              "RES_TRS_COUNT",
              "RES_TRS",
              "RES_SHARE_AMBIG",
              "RES_MISS_LOCI",
              "DEV_HWE",
              "ERR_STD",
              "ERR_SAMP_80_100",
              "SUM_FREQ_GAP",
              "ERR_OFFSET",
              "LD_MEASURE",
              "KFOLD_IMPUTE",
              "KFOLD_PRED_ACTUAL",
              "KFOLD_N"
            ]
          }
        }
      },
      "ScopeData": {
        "title": "ScopeData",
        "required": [
          "ScopeElement"
        ],
        "type": "object",
        "properties": {
          "ScopeElement": {
            "title": "ScopeElement",
            "type": "array",
            "description": "Additional Information on genotype",
            "items": {
              "$ref": "#/components/schemas/ScopeElement"
            }
          }
        }
      },
      "PopulationSubmissionData": {
        "title": "PopulationSubmissionData",
        "required": [
          "population"
        ],
        "type": "object",
        "properties": {
          "population": {
            "$ref": "#/components/schemas/PopulationData"
          },
          "submissions": {
            "title": "attached submissions",
            "type": "array",
            "description": "submissions that describe the population",
            "items": {
              "type": "string"
            }
          }
        },
        "description": "Contains all submissions for a population"
      },
      "PopulationData": {
        "title": "PopulationData",
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "title": "id",
            "type": "string",
            "description": "id of the population"
          },
          "name": {
            "title": "Name",
            "type": "string",
            "description": "Name of the population"
          }
        }
      },
      "ScopeElement": {
        "title": "ScopeElement",
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "label name"
          },
          "freeName": {
            "type": "string",
            "description": "label name"
          },
          "typeOfScope": {
            "type": "string",
            "description": "type of label",
            "enum": [
              "gene",
              "feature"
            ]
          }
        }
      },
      "MethodData": {
        "title": "MethodData",
        "required": [
          "MethodList"
        ],
        "type": "object",
        "properties": {
          "MethodList": {
            "$ref": "#/components/schemas/MethodList"
          }
        }
      },
      "MethodList": {
        "title": "MethodList",
        "type": "object",
        "properties": {
          "Method": {
            "title": "Method",
            "type": "array",
            "description": "list of methods",
            "items": {
              "$ref": "#/components/schemas/Method"
            }
          }
        }
      },
      "LabelData": {
        "title": "LabelData",
        "required": [
          "LabelList"
        ],
        "type": "object",
        "properties": {
          "LabelList": {
            "$ref": "#/components/schemas/LabelList"
          }
        }
      },
      "LabelList": {
        "type": "object",
        "properties": {
          "Label": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Label"
            }
          }
        },
        "description": "List of labels"
      },
      "Label": {
        "title": "Label",
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "description": "label name"
          },
          "typeOfLabel": {
            "type": "string",
            "description": "type of label"
          }
        },
        "description": "List of Genotypes"
      },
      "CohortData": {
        "title": "CohortData",
        "required": [
          "GenotypeList"
        ],
        "type": "object",
        "properties": {
          "GenotypeList": {
            "$ref": "#/components/schemas/GenotypeList"
          }
        }
      },
      "GenotypeList": {
        "title": "GenotypeList",
        "type": "object",
        "properties": {
          "License": {
            "$ref": "#/components/schemas/License"
          },
          "Genotype": {
            "title": "Genotype",
            "type": "array",
            "description": "Additional Information on genotype",
            "items": {
              "$ref": "#/components/schemas/Genotype"
            }
          }
        },
        "description": "List of Genotypes"
      },
      "Genotype": {
        "title": "Genotype",
        "required": [
          "genotypeString"
        ],
        "type": "object",
        "properties": {
          "genotypeString": {
            "type": "string",
            "description": "GL string of the genotype"
          },
          "genotypingMethods": {
            "title": "GenotypingMethods",
            "type": "array",
            "description": "Additional Information on genotype",
            "items": {
              "$ref": "#/components/schemas/GenotypeMethod"
            }
          }
        }
      },
      "GenotypeMethod": {
        "title": "GenotypeMethod",
        "type": "object",
        "properties": {
          "methodLabel": {
            "type": "string",
            "description": "Type of method label",
            "enum": [
              "TYPING_METHOD",
              "TYPING_REF",
              "TYPING_DATE",
              "TYPING_IMGT_VER",
              "MIRING_REF"
            ]
          },
          "methodValue": {
            "type": "string",
            "description": "Value of method"
          },
          "methodComment": {
            "type": "string",
            "description": "Comment on method"
          },
          "methodReference": {
            "type": "string",
            "description": "To be used to refer to an external source"
          }
        },
        "description": "GenotypeMethod Record"
      },
      "License": {
        "title": "License",
        "required": [
          "typeOfLicense"
        ],
        "type": "object",
        "properties": {
          "typeOfLicense": {
            "type": "string",
            "description": "Type of creative commons license",
            "enum": [
              "CC0",
              "by",
              "by-sa",
              "by-nd",
              "by-nc",
              "by-nc-sa",
              "by-nc-nd"
            ]
          }
        },
        "description": "License models, there will be a default license if one is not provided"
      },
      "Method": {
        "title": "Method",
        "type": "object",
        "properties": {
          "typeOfMethod": {
            "type": "string",
            "description": "Type of method label",
            "enum": [
              "EM_ALGORITHM",
              "EM_VERSION",
              "EM_ALG_REF",
              "MAC_SERVICE",
              "MAC_SER_REF",
              "MAC_VERSION",
              "ARS_SERVICE",
              "ARS_SERV_REF",
              "ARS_VERSION",
              "HWE_METHOD",
              "HWE_REF",
              "LD_METHOD",
              "LD_METHOD_REF"
            ]
          },
          "methodValue": {
            "type": "string",
            "description": "Value of method"
          },
          "methodComment": {
            "type": "string",
            "description": "Comment on method"
          },
          "methodReference": {
            "type": "string",
            "description": "To be used to refer to an external source"
          }
        },
        "description": "Method Record"
      },
      "ResolutionData": {
        "title": "ResolutionData",
        "type": "array",
        "description": "List of Method",
        "items": {
          "$ref": "#/components/schemas/ResolutionInfo"
        }
      },
      "ResolutionInfo": {
        "title": "ResolutionInfo",
        "type": "object",
        "properties": {
          "scopeElement": {
            "type": "string"
          },
          "resolution": {
            "type": "string",
            "description": "resolution of the data",
            "enum": [
              "G",
              "P",
              "gNMDP",
              "gDKMS",
              "2-Field",
              "4-Field",
              "6-Field",
              "8-Field",
              "Serology"
            ]
          }
        }
      },
      "FrequencyError": {
        "title": "FrequencyError",
        "type": "object",
        "properties": {
          "value": {
            "type": "number"
          },
          "typeOfError": {
            "type": "string",
            "description": "type of error"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "Standard500ErrorResponse": {
        "description": "An unexpected error ocurred",
        "content": {
          "*/*": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "x-original-swagger-version": "2.0",
  "tags": [
    {
      "name": "hfc"
    }
  ]
}
