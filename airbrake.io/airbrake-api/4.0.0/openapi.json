    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.airbrake.io"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Session/token management"
    },
    {
      "name": "Projects",
      "description": "Project management"
    },
    {
      "name": "Groups",
      "description": "Error group management"
    },
    {
      "name": "Notices",
      "description": "Error notice management"
    },
    {
      "name": "Deploys",
      "description": "Deploy tracking"
    },
    {
      "name": "Performance",
      "description": "Performance monitoring"
    },
    {
      "name": "Source Maps",
      "description": "Source map management"
    },
    {
      "name": "Activities",
      "description": "Project activity tracking"
    },
    {
      "name": "Statistics",
      "description": "Project and group statistics"
    },
    {
      "name": "Error Notification",
