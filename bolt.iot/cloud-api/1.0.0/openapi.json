  },
  "components": {
    "schemas": {
      "BoltResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "integer",
            "description": "1 for success, 0 for failure"
          },
          "value": {
            "type": "string",
            "description": "Response value or error message"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "integer",
            "description": "0 for failure"
          },
          "value": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}
