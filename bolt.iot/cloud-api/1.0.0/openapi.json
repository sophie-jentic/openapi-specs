{
  "openapi": "3.0.3",
  "info": {
    "title": "Bolt IoT Cloud API",
    "description": "Bolt IoT Cloud API for remotely controlling Bolt WiFi modules. Supports GPIO operations (digital/analog read/write), UART communication, and device management.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.boltiot.com/api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://cloud.boltiot.com",
      "description": "Bolt IoT Cloud"
    }
  ],
  "security": [],
  "tags": [
    {
      "name": "GPIO",
      "description": "GPIO read/write operations"
    },
    {
      "name": "UART",
      "description": "UART serial communication"
    },
    {
      "name": "Utility",
      "description": "Utility commands"
    }
  ],
  "paths": {
    "/remote/{apiKey}/digitalWrite": {
      "get": {
        "tags": [
          "GPIO"
        ],
        "summary": "Digital Write",
        "description": "Set a digital pin HIGH or LOW on the Bolt device.",
        "operationId": "digitalWrite",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "description": "Your Bolt Cloud API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pin",
            "in": "query",
            "required": true,
            "description": "GPIO pin number (0-4)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 4
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "description": "Pin state: HIGH or LOW",
            "schema": {
              "type": "string",
              "enum": [
                "HIGH",
                "LOW"
              ]
            }
          },
          {
            "name": "deviceName",
            "in": "query",
            "required": true,
            "description": "Bolt device ID (e.g., BOLTXXXXXXX)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns operation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoltResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/remote/{apiKey}/digitalRead": {
      "get": {
        "tags": [
          "GPIO"
        ],
        "summary": "Digital Read",
        "description": "Read the state of a digital pin on the Bolt device.",
        "operationId": "digitalRead",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "description": "Your Bolt Cloud API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pin",
            "in": "query",
            "required": true,
            "description": "GPIO pin number (0-4)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 4
            }
          },
          {
            "name": "deviceName",
            "in": "query",
            "required": true,
            "description": "Bolt device ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns pin state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoltResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/remote/{apiKey}/analogRead": {
      "get": {
        "tags": [
          "GPIO"
        ],
        "summary": "Analog Read",
        "description": "Read the analog value from the A0 pin on the Bolt device.",
        "operationId": "analogRead",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "description": "Your Bolt Cloud API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pin",
            "in": "query",
            "required": true,
            "description": "Analog pin (A0)",
            "schema": {
              "type": "string",
              "enum": [
                "A0"
              ]
            }
          },
          {
            "name": "deviceName",
            "in": "query",
            "required": true,
            "description": "Bolt device ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns analog value (0-1023)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoltResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
