              "type": "integer",
              "minimum": 0,
              "maximum": 4
            }
          },
          {
            "name": "value",
            "in": "query",
            "required": true,
            "description": "PWM value (0-255)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 255
            }
          },
          {
            "name": "deviceName",
            "in": "query",
            "required": true,
            "description": "Bolt device ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns operation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoltResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/remote/{apiKey}/serialBegin": {
      "get": {
        "tags": [
          "UART"
        ],
        "summary": "Serial Begin",
        "description": "Initialize UART serial communication on the Bolt device.",
        "operationId": "serialBegin",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "description": "Your Bolt Cloud API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "baud",
            "in": "query",
            "required": true,
            "description": "Baud rate",
            "schema": {
              "type": "integer",
              "enum": [
                300,
                600,
                1200,
                2400,
                4800,
                9600,
                19200,
                38400,
                57600,
                115200
              ]
            }
          },
          {
            "name": "deviceName",
            "in": "query",
            "required": true,
            "description": "Bolt device ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Serial initialized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoltResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/remote/{apiKey}/serialWrite": {
      "get": {
        "tags": [
          "UART"
        ],
        "summary": "Serial Write",
        "description": "Send data over UART serial communication.",
        "operationId": "serialWrite",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "description": "Your Bolt Cloud API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "data",
            "in": "query",
            "required": true,
            "description": "Data string to send",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "deviceName",
            "in": "query",
            "required": true,
            "description": "Bolt device ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Data written",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoltResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/remote/{apiKey}/serialRead": {
      "get": {
        "tags": [
          "UART"
        ],
        "summary": "Serial Read",
        "description": "Read data from UART serial communication.",
        "operationId": "serialRead",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "description": "Your Bolt Cloud API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "till",
            "in": "query",
            "required": true,
            "description": "Read data till this character is encountered",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "deviceName",
            "in": "query",
            "required": true,
            "description": "Bolt device ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns serial data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoltResponse"
