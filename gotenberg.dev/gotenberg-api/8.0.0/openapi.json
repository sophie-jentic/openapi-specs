{
  "openapi": "3.0.3",
  "info": {
    "title": "Gotenberg API",
    "version": "8.0.0",
    "description": "Gotenberg is a Docker-powered stateless API for PDF generation. It provides endpoints for converting HTML, URLs, Markdown, and office documents to PDF using Chromium and LibreOffice engines.",
    "x-jentic-source-url": "https://gotenberg.dev/docs/routes",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    {
      "name": "Chromium",
      "description": "Convert with Chromium engine"
    },
    {
      "name": "LibreOffice",
      "description": "Convert with LibreOffice engine"
    },
    {
      "name": "PDF Engines",
      "description": "PDF manipulation operations"
    },
    {
      "name": "Health",
      "description": "Health check"
    }
  ],
  "paths": {
    "/forms/chromium/convert/url": {
      "post": {
        "operationId": "convertUrlToPdf",
        "summary": "Convert a URL to PDF",
        "description": "Navigates to the URL using Chromium and converts the page to PDF.",
        "tags": [
          "Chromium"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "URL to convert"
                  },
                  "paperWidth": {
                    "type": "number",
                    "default": 8.5
                  },
                  "paperHeight": {
                    "type": "number",
                    "default": 11
                  },
                  "marginTop": {
                    "type": "number",
                    "default": 0.39
                  },
                  "marginBottom": {
                    "type": "number",
                    "default": 0.39
                  },
                  "marginLeft": {
                    "type": "number",
                    "default": 0.39
                  },
                  "marginRight": {
                    "type": "number",
                    "default": 0.39
                  },
                  "preferCssPageSize": {
                    "type": "boolean",
                    "default": false
                  },
                  "printBackground": {
                    "type": "boolean",
                    "default": false
                  },
                  "landscape": {
                    "type": "boolean",
                    "default": false
                  },
                  "scale": {
                    "type": "number",
                    "default": 1.0
                  },
                  "nativePageRanges": {
                    "type": "string"
                  },
                  "waitDelay": {
                    "type": "string"
                  },
                  "waitForExpression": {
                    "type": "string"
                  },
                  "userAgent": {
                    "type": "string"
                  },
                  "extraHttpHeaders": {
                    "type": "string"
                  },
                  "emulatedMediaType": {
                    "type": "string",
                    "enum": [
                      "screen",
                      "print"
                    ]
                  },
                  "pdfa": {
                    "type": "string",
                    "enum": [
                      "PDF/A-1b",
                      "PDF/A-2b",
                      "PDF/A-3b"
                    ]
                  },
                  "pdfua": {
                    "type": "boolean"
                  },
                  "failOnHttpStatusCodes": {
                    "type": "string",
                    "description": "JSON array of status codes"
                  },
                  "failOnConsoleExceptions": {
                    "type": "boolean",
                    "default": false
                  },
                  "skipNetworkIdleEvent": {
                    "type": "boolean",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PDF file",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
