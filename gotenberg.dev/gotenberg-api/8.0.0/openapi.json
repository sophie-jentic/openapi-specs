    "/forms/chromium/screenshot/url": {
      "post": {
        "operationId": "screenshotUrl",
        "summary": "Screenshot a URL",
        "description": "Takes a screenshot of a URL using Chromium.",
        "tags": [
          "Chromium"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "width": {
                    "type": "integer",
                    "default": 800
                  },
                  "height": {
                    "type": "integer",
                    "default": 600
                  },
                  "clip": {
                    "type": "boolean",
                    "default": false
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "png",
                      "jpeg",
                      "webp"
                    ],
                    "default": "png"
                  },
                  "quality": {
                    "type": "integer",
                    "description": "JPEG/WebP quality 0-100"
                  },
                  "optimizeForSpeed": {
                    "type": "boolean",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Screenshot image",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
