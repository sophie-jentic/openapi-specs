                    "type": "number",
                    "default": 0.39
                  },
                  "marginLeft": {
                    "type": "number",
                    "default": 0.39
                  },
                  "marginRight": {
                    "type": "number",
                    "default": 0.39
                  },
                  "preferCssPageSize": {
                    "type": "boolean",
                    "default": false
                  },
                  "printBackground": {
                    "type": "boolean",
                    "default": false
                  },
                  "landscape": {
                    "type": "boolean",
                    "default": false
                  },
                  "scale": {
                    "type": "number",
                    "default": 1.0
                  },
                  "nativePageRanges": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PDF file",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
