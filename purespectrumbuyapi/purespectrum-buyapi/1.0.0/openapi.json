  "definitions": {
    "survey": {
      "type": "object",
      "required": [
        "survey_title"
      ],
      "properties": {
        "ps_survey_id": {
          "type": "integer",
          "readOnly": true,
          "example": 7654
        },
        "live_ps_survey_entry_link": {
          "type": "string",
          "readOnly": true,
          "example": "Live URL"
        },
        "test_ps_survey_entry_link": {
          "type": "string",
          "readOnly": true,
          "example": "Test URL"
        },
        "ps_survey_status": {
          "type": "integer",
          "readOnly": true,
          "example": 11
        },
        "survey_title": {
          "type": "string",
          "example": "Automobile Preferences"
        },
        "survey_category_code": {
          "type": "integer",
          "format": "int64",
          "example": 112
        },
        "survey_localization": {
          "type": "string",
          "example": "en_US"
        },
        "completes_required": {
          "type": "integer",
          "example": 300
        },
        "ps_incidence": {
          "type": "number",
          "example": 0.6
        },
        "length_of_interview": {
          "type": "integer",
          "example": 60
        },
        "live_url": {
          "type": "string",
          "example": "Live URL"
        },
        "test_url": {
          "type": "string",
          "example": "Test URL"
        },
        "field_time": {
          "type": "integer",
          "example": 10
        },
        "qualifications": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/targeting_structure"
          }
        },
        "quotas": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/quota"
          }
        }
      }
    },
    "quota": {
      "type": "object",
      "properties": {
        "ps_quota_id": {
          "type": "integer",
          "readOnly": true,
          "format": "int64"
        },
        "buyer_quota_id": {
          "type": "integer",
          "format": "int64"
        },
        "required_count": {
          "type": "integer",
          "format": "int64"
        },
        "criteria": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/targeting_structure"
          }
        }
      }
    },
    "quota_performance": {
      "type": "object",
      "properties": {
        "ps_completes_acheived": {
          "type": "integer",
          "readOnly": true,
          "example": 100
        },
        "quota": {
          "$ref": "#/definitions/quota"
        }
      }
    },
    "ps_recon_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ps_recon_transaction": {
      "type": "object",
      "properties": {
        "ps_transaction_id": {
          "type": "string",
          "example": "aded-cdei-338d-d4j3"
        },
        "ps_transaction_status": {
          "type": "integer",
          "description": "The result of reconciliation for this transaction.",
          "readOnly": true,
          "example": 111,
          "enum": [
            111,
            112,
            113,
            114,
            115,
            116
          ]
        },
        "ps_cpi": {
          "type": "number",
          "description": "If the ps_transation_status is 111, or 112, the CPI to the Buyer.",
          "readOnly": true,
          "example": 3.5
        }
      }
    },
    "from_to_range": {
      "type": "object",
      "properties": {
        "from": {
          "type": "integer",
          "example": 21
        },
        "from_units": {
          "type": "integer",
          "enum": [
            111,
            112,
            113
          ],
          "example": 111
        },
        "to": {
          "type": "integer",
          "example": 35
        },
        "to_units": {
          "type": "integer",
          "enum": [
            111,
            112,
            113
          ],
          "example": 111
        }
      }
    },
    "targeting_structure": {
      "type": "object",
      "properties": {
        "qualification_code": {
          "type": "integer",
          "format": "int64",
          "example": 211
        },
        "condition_codes": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int64",
            "example": "111, 112, 113"
          }
        },
        "range_sets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/from_to_range"
          }
        },
        "aux_values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "survey_performance": {
      "type": "object",
      "properties": {
        "ps_survey_status": {
          "type": "integer",
          "example": 11
        },
        "completes_goal": {
          "type": "integer",
          "description": "Total number of completes required for the survey",
          "example": 600
        },
        "completes_fielded": {
          "type": "integer",
          "description": "Number of completes attained so far",
          "example": 400
        },
        "cpi_forecast_at_launch": {
          "type": "number",
          "description": "The cost per complete as forecasted by the creator of the survey",
          "example": 3.5
        },
        "current_cpi": {
          "type": "number",
          "description": "The current CPI of the survey. This is an indicative measure of the potential cost of next complete",
          "example": 6.4
        },
        "projected_cpi": {
          "type": "number",
          "description": "Purespectrum's projection of the average CPI for the total completes",
          "example": 5.2
        },
        "total_cost_forecast_at_launch": {
          "type": "number",
          "description": "The total fielding cost forecasted by the creator of the survey at launch",
          "example": 2100
        },
        "current_cost": {
          "type": "number",
          "description": "The accrued fielding cost so far",
          "example": 2560
        },
        "projected_total_cost": {
          "type": "number",
          "description": "The projected final cost of the survey",
          "example": 3120
        },
        "stated_loi": {
          "type": "integer",
          "description": "The length of the interview in minutes",
          "example": 20
        },
        "current_loi": {
          "type": "integer",
          "description": "The current length of interview",
          "example": 30
        },
        "stated_incidence": {
          "type": "number",
          "description": "The incidence in percentage (e.g., .25 for 25%) as stated by the buyer at the creation of the survey",
          "example": 0.25
        },
        "current_incidence": {
          "type": "number",
          "description": "The current incidence of the survey",
          "example": 0.4
        }
      }
    },
    "api_response": {
      "type": "object",
      "properties": {
        "ps_api_response_code": {
          "type": "integer",
          "example": 1000
        },
        "ps_api_response_message": {
          "type": "string",
          "example": "Purespectrum Custom API Response Message"
        }
      }
    }
  },
