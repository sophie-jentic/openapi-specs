  "definitions": {
    "BidPriceListResponse": {
      "type": "object",
      "description": "The BidPrices returned.",
      "properties": {
        "Status": {
          "type": "string",
          "enum": [
            "Success",
            "Failed"
          ],
          "description": "A status describing if request was successful responsed.\n  - Success: The BidPrices list for flight and cabin specified was getted without problems.\n  - Failed: The BidPrices list for flight and cabin specified was not getted due by flight and cabin invalid parameters or an internal error.",
          "example": "Success"
        },
        "FlightLeg": {
          "$ref": "#/definitions/FlightLeg"
        },
        "ErrorMessages": {
          "type": "array",
          "description": "Represents an ErrorMessage Array.",
          "items": {
            "$ref": "#/definitions/ErrorMessage"
          }
        }
      },
      "required": [
        "Status"
      ]
    },
    "FlightLeg": {
      "type": "object",
      "description": "Represents a Flight Leg information.",
      "properties": {
        "CarrierCode": {
          "type": "string",
          "description": "IATA two letter airline code for representang the Airlines who is operating the flight.",
          "example": "CM"
        },
        "FlightNumber": {
          "type": "string",
          "description": "The airlines flight number.",
          "example": "357"
        },
        "DepartureDate": {
          "type": "string",
          "description": "Date of departure in date (YYYYMMDD) format.",
          "example": "20201012"
        },
        "OriginAirport": {
          "type": "string",
          "description": "The origin airport.",
          "example": "PTY"
        },
        "DestinationAirport": {
          "type": "string",
          "description": "The destination airport.",
          "example": "JFK"
        },
        "InvDate": {
          "type": "string",
          "description": "Last date inventory was recieved.",
          "example": "20200203"
        },
        "InvTime": {
          "type": "string",
          "description": "Last time inventory was recieved.",
          "example": "184502"
        },
        "OptType": {
          "type": "string",
          "description": "Optimization type. Describes which optimization type has triggerd the upload.",
          "example": "N"
        },
        "SkipPersistFlag": {
          "type": "string",
          "description": "Indicates if the optimization results were saved to the RM Editions backend database.",
          "example": "0"
        },
        "ArcfType": {
          "type": "string",
          "description": "The aircraft type.",
          "example": "73E"
        },
        "ArcfCfgId": {
          "type": "string",
          "description": "The aircraft configuration id.",
          "example": "1"
        },
        "BPControlFlag": {
          "type": "string",
          "description": "The BidPrice control.",
          "example": "1"
        },
        "Compartments": {
          "type": "array",
          "description": "Represents a Flight Leg compartment information (executive and economic classes) array.",
          "items": {
            "$ref": "#/definitions/FlightLegCompartment"
          }
        }
      },
      "required": [
        "CarrierCode",
        "FlightNumber",
        "DepartureDate",
        "OriginAirport",
        "DestinationAirport"
      ]
    },
    "FlightLegCompartment": {
      "type": "object",
      "description": "Represents a Flight Leg compartment information (executive and economic classes).",
      "properties": {
        "CmpCode": {
          "type": "string",
          "description": "The compartment code ('C' or 'Y').",
          "example": "Y"
        },
        "PhyCap": {
          "type": "string",
          "description": "Physical capacity.",
          "example": "84"
        },
        "AdjCap": {
          "type": "string",
          "description": "Adjusted capacity.",
          "example": "84"
        },
        "VirtCap": {
          "type": "string",
          "description": "Virtual capacity.",
          "example": "84"
        },
        "UpSts": {
          "type": "string",
          "description": "Upgrade seats.",
          "example": "0"
        },
        "ObSts": {
          "type": "string",
          "description": "Number of overbooking seats.",
          "example": "9"
        },
        "DcSts": {
          "type": "string",
          "description": "Number of decrement seats.",
          "example": "0"
        },
        "AU": {
          "type": "string",
          "description": "Compartment AU.",
          "example": "93"
        },
        "VarStsFlag": {
          "type": "string",
          "description": "Variable capacity is operated for this flight.",
          "example": "0"
        },
        "MaxUpSts": {
          "type": "string",
          "description": "The maximum number of upgrades allowed from a lower comparment to a higher, adjacent compartment.",
          "example": "999"
        },
        "CrFnlGrpOut": {
          "type": "string",
          "description": "The allotment system parameter.",
          "example": "0"
        },
        "TotAchDmd": {
          "type": "string",
          "description": "The total achievable demand.",
          "example": "67.867853"
        },
        "AllotmentFlag": {
          "type": "string",
          "description": "A flag to indicate that an allotment(s) exist on this leg compartment.",
          "example": "?"
        },
        "CapacityReduction": {
          "type": "string",
          "description": "Capacity reduction in number of seats as determined by a linked Capacity Reduction Optimizer Parameter.",
          "example": "?"
        },
        "AuIncludingNegoBlocks": {
          "type": "string",
          "description": "The compartment Au including all NegoBlocks that exist on the Leg Compartment.",
          "example": "93"
        },
        "BidPriceVector": {
          "type": "array",
          "description": "Contains all bidprices by flight/leg/compartment in JSON format.",
          "items": {
            "$ref": "#/definitions/SeatBidPriceRecord"
          },
          "example": [
            {
              "SeatIndex": "1",
              "BidPrice": "965"
            },
            {
              "SeatIndex": "2",
              "BidPrice": "686"
            },
