            },
            {
              "SeatIndex": "93",
              "BidPrice": "0"
            }
          ]
        },
        "Classes": {
          "type": "array",
          "description": "Represents a classes array.",
          "items": {
            "$ref": "#/definitions/FlightLegClass"
          }
        }
      },
      "required": [
        "CmpCode"
      ]
    },
    "SeatBidPriceRecord": {
      "type": "object",
      "description": "Represents the information of BidPrice Vector's row.",
      "properties": {
        "SeatIndex": {
          "type": "string",
          "description": "Seat index.",
          "example": "2"
        },
        "BidPrice": {
          "type": "string",
          "description": "Bid price.",
          "example": "315"
        }
      },
      "required": [
        "SeatIndex",
        "BidPrice"
      ]
    },
    "FlightLegClass": {
      "type": "object",
      "description": "Represents a Flight Leg class information (booking classes).",
      "properties": {
        "ClsCode": {
          "type": "string",
          "description": "The booking class code.",
          "example": "I"
        },
        "PrtSts": {
          "type": "string",
          "description": "Protected seats.",
          "example": "4"
        },
        "ObSts": {
          "type": "string",
          "description": "Number of overbooking seats.",
          "example": "1"
        },
        "DcSts": {
          "type": "string",
          "description": "Number of decrement seats.",
          "example": "0"
        },
        "BkgPtrs": {
          "type": "string",
          "description": "Booking protects.",
          "example": "5"
        },
        "OBDCMult": {
          "type": "string",
          "description": "Overbooking/Decrement multiplier.",
          "example": "110"
        },
        "BookingMin": {
          "type": "string",
          "description": "Booking minimum.",
          "example": "?"
        },
        "BookingMax": {
          "type": "string",
          "description": "Booking maximum.",
          "example": "?"
        },
        "TotBkd": {
          "type": "string",
          "description": "Total bookings.",
          "example": "0"
        },
        "GrpBkd": {
          "type": "string",
          "description": "Group bookings.",
          "example": "0"
        },
        "TotOut": {
          "type": "string",
          "description": "Total achievable passenger out.",
          "example": "0"
        },
        "GrpOut": {
          "type": "string",
          "description": "Group achievable passenger out.",
          "example": "0"
        },
        "SuRate": {
          "type": "string",
          "description": "Show up Rate.",
          "example": "100"
        },
        "AU": {
          "type": "string",
          "description": "AU.",
          "example": "5"
        },
        "MaxSts": {
          "type": "string",
          "description": "Class max seats.",
          "example": "?"
        },
        "GatedFlag": {
          "type": "string",
          "description": "Class gated flag.",
          "example": "?"
        },
        "TotAchDmd": {
          "type": "string",
          "description": "Total achievable demand.",
          "example": "0.024649"
        },
        "ReconstrainedOut": {
          "type": "string",
          "description": "The constrained demand for the day of departure multiplied by the class level show-up rate.",
          "example": "0.011801"
        },
        "PrntClsCode": {
          "type": "string",
          "description": "Parent booking class code in nesting hierarchy.",
          "example": "Z"
        },
        "AuIncludingNegoBlocks": {
          "type": "string",
          "description": "The class Au including the NegoBlock(s) that exist in the class.",
          "example": "5"
        },
        "NegoBlocks": {
          "type": "string",
          "description": "The total size of NegoBlock(s) in this class.",
          "example": "0"
        }
      },
      "required": [
        "ClsCode"
      ]
    },
    "ErrorMessage": {
      "type": "object",
      "description": "Represents an Error element with Error Code and Description",
      "properties": {
        "Code": {
          "type": "string",
          "example": "1002",
          "description": "Error code"
        },
        "Description": {
          "type": "string",
          "example": "Error descriptions",
          "description": "Error descriptions"
        },
        "Key": {
          "type": "string",
          "example": "Key",
          "description": "Key"
        },
        "TypeCode": {
          "type": "string",
          "example": "TypeCode",
          "description": "TypeCode"
        }
      },
      "required": [
        "Code",
        "Description"
      ]
    }
