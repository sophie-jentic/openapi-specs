{
  "openapi": "3.0.3",
  "info": {
    "title": "Momento Cache HTTP API",
    "version": "1.0.0",
    "description": "Momento serverless cache HTTP API for get, set, and delete cache operations.",
    "x-jentic-source-url": "https://docs.momentohq.com/cache/develop/api-reference/http-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.cache.cell-1-us-west-2.prod.a.momentohq.com",
      "description": "US West 2 region"
    }
  ],
  "paths": {
    "/cache/{cacheName}": {
      "get": {
        "operationId": "getCacheItem",
        "summary": "Get cache item",
        "description": "Get an item from cache by key.",
        "tags": [
          "Cache"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CacheValue"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "cacheName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": ""
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Cache key"
          },
          {
            "name": "token",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Auth token"
          }
        ]
      },
      "put": {
        "operationId": "setCacheItem",
        "summary": "Set cache item",
        "description": "Set an item in cache.",
        "tags": [
          "Cache"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "cacheName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": ""
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Cache key"
          },
          {
            "name": "ttl_seconds",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "TTL in seconds"
          }
        ]
      },
      "delete": {
        "operationId": "deleteCacheItem",
        "summary": "Delete cache item",
        "description": "Delete an item from cache.",
        "tags": [
          "Cache"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "cacheName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": ""
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Cache key"
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "code": {
            "type": "integer"
          }
        }
      },
      "CacheValue": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string"
          },
          "ttl_remaining_seconds": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Cache"
    }
  ]
}
