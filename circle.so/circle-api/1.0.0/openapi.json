{
  "openapi": "3.0.3",
  "info": {
    "title": "Circle Community API",
    "version": "1.0.0",
    "description": "Circle is a community platform. The API provides endpoints to manage communities, spaces, members, posts, comments, and events. Authentication uses an API token passed as a query parameter or Bearer token. Note: The Circle API documentation is JS-rendered and was not fully accessible; this spec is based on the known Circle v1 admin API.",
    "x-jentic-source-url": "https://developers.circle.so/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://app.circle.so/api/v1",
      "description": "Circle API v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Communities",
      "description": "Community operations"
    },
    {
      "name": "Spaces",
      "description": "Manage community spaces"
    },
    {
      "name": "Members",
      "description": "Manage community members"
    },
    {
      "name": "Posts",
      "description": "Manage posts"
    },
    {
      "name": "Comments",
      "description": "Manage comments on posts"
    },
    {
      "name": "Events",
      "description": "Manage events"
    },
    {
      "name": "Space Groups",
      "description": "Manage space groups"
    }
  ],
  "paths": {
    "/me": {
      "get": {
        "operationId": "getCurrentMember",
        "summary": "Get current member",
        "description": "Get the profile of the currently authenticated member.",
        "tags": [
          "Members"
        ],
        "responses": {
          "200": {
            "description": "Current member profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Member"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/communities": {
      "get": {
        "operationId": "listCommunities",
        "summary": "List communities",
        "description": "Get a list of communities the authenticated user has access to.",
        "tags": [
          "Communities"
        ],
        "responses": {
          "200": {
            "description": "Community list",
