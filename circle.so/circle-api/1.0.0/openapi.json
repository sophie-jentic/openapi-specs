          },
          "user_id": {
            "type": "integer"
          },
          "is_pinned": {
            "type": "boolean"
          },
          "is_comments_enabled": {
            "type": "boolean"
          },
          "is_liking_enabled": {
            "type": "boolean"
          },
          "comments_count": {
