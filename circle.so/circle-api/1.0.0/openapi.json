            "type": "string"
          },
          "community_id": {
            "type": "integer"
          },
          "space_group_id": {
            "type": "integer"
          },
          "is_private": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SpaceGroup": {
