{
  "openapi": "3.0.3",
  "info": {
    "title": "Arrangr API",
    "version": "1.0.0",
    "description": "Arrangr is a meeting scheduling platform. The API provides webhook management for meeting events including 1:1 meetings, event RSVPs, and poll responses.",
    "x-jentic-source-url": "https://arrangr.com/pdfs/ArrangrAPIDocumentation.pdf",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://arrangr.com/api/v1"
    }
  ],
  "paths": {
    "/webhooks/subscribe": {
      "post": {
        "operationId": "subscribeWebhook",
        "summary": "Subscribe to a webhook",
        "description": "Subscribe to a webhook event on behalf of an Arrangr user.",
        "tags": [
          "Webhooks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscribeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook subscribed successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/webhooks/unsubscribe": {
      "post": {
        "operationId": "unsubscribeWebhook",
        "summary": "Unsubscribe from a webhook",
        "description": "Unsubscribe from a webhook event on behalf of an Arrangr user.",
        "tags": [
          "Webhooks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookUnsubscribeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook unsubscribed successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WebhookSubscribeRequest": {
        "type": "object",
        "required": [
          "hookEvent",
          "hookUrl"
        ],
        "properties": {
          "hookEvent": {
            "type": "string",
            "description": "The event to receive webhooks for",
            "enum": [
              "scheduled_1on1",
              "sent_1on1",
              "received_1on1",
              "received_event_rsvp",
              "received_poll_response"
            ]
          },
          "hookUrl": {
            "type": "string",
            "description": "The URL to receive webhook callbacks"
          }
        }
      },
      "WebhookUnsubscribeRequest": {
        "type": "object",
        "required": [
          "hookEvent"
        ],
        "properties": {
          "hookEvent": {
            "type": "string",
            "description": "The event to unsubscribe from",
            "enum": [
              "scheduled_1on1",
              "sent_1on1",
              "received_1on1",
              "received_event_rsvp",
              "received_poll_response"
            ]
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://arrangr.com/oauth/authorize",
            "tokenUrl": "https://arrangr.com/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "Webhooks"
    }
  ]
}
