  "info": {
    "title": "Cox Automotive API",
    "version": "1.0.0",
    "description": "Cox Automotive Digital Retail API Platform provides vehicle inventory, dealer, and digital retail APIs for automotive industry integrations. Includes vehicle search, inventory management, deal creation, and trade-in valuation.",
