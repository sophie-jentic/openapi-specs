          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "dealerId": {
                    "type": "string"
                  },
                  "vin": {
                    "type": "string"
                  },
                  "customerId": {
                    "type": "string"
                  },
                  "salePrice": {
                    "type": "number"
                  },
                  "tradeInVin": {
                    "type": "string"
                  },
                  "downPayment": {
                    "type": "number"
                  },
                  "term": {
                    "type": "integer"
                  }
                },
                "required": [
                  "dealerId",
                  "vin"
                ]
              }
            }
