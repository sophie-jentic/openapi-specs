              ]
            }
          },
          {
            "name": "includeAddressCategories",
            "in": "query",
            "required": false,
            "description": "A comma-separated list of address categories to include.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "excludeAddressCategories",
            "in": "query",
            "required": false,
