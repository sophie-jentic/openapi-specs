{
  "openapi": "3.0.3",
  "info": {
    "title": "Apple Maps Server API",
    "description": "The Apple Maps Server API provides server-side geocoding, reverse geocoding, search, search autocomplete, directions, ETAs, and place lookup capabilities. Authenticate using a JWT (JSON Web Token) generated from a Maps identifier and private key. Rate limited to 25,000 calls per day per team (shared with MapKit JS).",
    "version": "1.2",
    "contact": {
      "name": "Apple Developer",
      "url": "https://developer.apple.com/documentation/applemapsserverapi"
    }
  },
  "servers": [
    {
      "url": "https://maps-api.apple.com",
      "description": "Apple Maps Server API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/token": {
      "get": {
        "operationId": "getToken",
        "summary": "Generate a Maps access token",
        "description": "Returns a JWT maps access token used to call the Apple Maps Server API. Requires an authorization header with a Maps auth token (JWT signed with your private key).",
        "tags": [
          "Token"
        ],
        "responses": {
          "200": {
            "description": "Successfully generated a maps access token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Maps token is missing or invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests - Daily quota exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/geocode": {
      "get": {
        "operationId": "geocode",
        "summary": "Geocode an address",
        "description": "Returns the latitude and longitude of the address you specify.",
        "tags": [
          "Geocoding"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "The address to geocode. For example, q=1 Apple Park, Cupertino, CA.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limitToCountries",
            "in": "query",
            "required": false,
            "description": "A comma-separated list of two-letter ISO 3166-1 country codes to limit results to.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "description": "The language the server should use when returning the response, specified using a BCP 47 language code. Default is en-US.",
            "schema": {
              "type": "string",
              "default": "en-US"
            }
          },
          {
            "name": "searchLocation",
            "in": "query",
            "required": false,
            "description": "A location defined as a hint, specified as a comma-separated string containing latitude and longitude. For example, searchLocation=37.78,-122.42.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchRegion",
            "in": "query",
            "required": false,
            "description": "A region defined as a hint, specified as a comma-separated string: north-latitude,east-longitude,south-latitude,west-longitude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "userLocation",
            "in": "query",
            "required": false,
            "description": "The location of the user, specified as a comma-separated string containing latitude and longitude.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An array of Place objects matching the geocoded address.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlaceResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid query parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid Maps access token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests - Daily quota exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/reverseGeocode": {
      "get": {
        "operationId": "reverseGeocode",
        "summary": "Reverse geocode a location",
        "description": "Returns an array of addresses present at the coordinates you provide.",
        "tags": [
          "Geocoding"
        ],
        "parameters": [
          {
            "name": "loc",
            "in": "query",
            "required": true,
            "description": "The coordinate to reverse geocode as a comma-separated string containing latitude and longitude. For example, loc=37.3316851,-122.0300674.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "description": "The language the server should use when returning the response, specified using a BCP 47 language code. Default is en-US.",
            "schema": {
              "type": "string",
              "default": "en-US"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An array of Place objects at the specified coordinates.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlaceResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/search": {
      "get": {
        "operationId": "search",
        "summary": "Search for places that match specific criteria",
        "description": "Find places by name or specific search criteria.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "The place to search for. For example, q=eiffel tower.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "excludePoiCategories",
            "in": "query",
            "required": false,
            "description": "A comma-separated list of POI categories to exclude from the results.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includePoiCategories",
            "in": "query",
            "required": false,
            "description": "A comma-separated list of POI categories to include in the results.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limitToCountries",
            "in": "query",
            "required": false,
            "description": "A comma-separated list of two-letter ISO 3166-1 country codes.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "resultTypeFilter",
            "in": "query",
            "required": false,
            "description": "A comma-separated list of result types to include. For example, resultTypeFilter=Poi.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "description": "The language the server should use when returning the response, specified using a BCP 47 language code. Default is en-US.",
            "schema": {
              "type": "string",
              "default": "en-US"
            }
          },
          {
            "name": "searchLocation",
            "in": "query",
            "required": false,
            "description": "A location defined as a hint, specified as a comma-separated string containing latitude and longitude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchRegion",
            "in": "query",
            "required": false,
            "description": "A region defined as a hint, specified as a comma-separated string: north-latitude,east-longitude,south-latitude,west-longitude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "userLocation",
            "in": "query",
            "required": false,
            "description": "The location of the user, specified as a comma-separated string containing latitude and longitude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchRegionPriority",
            "in": "query",
            "required": false,
            "description": "A value that indicates the importance of the search region. Allowed values: default, required.",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "required"
              ]
            }
          },
          {
            "name": "enablePagination",
            "in": "query",
            "required": false,
            "description": "When true, the response includes pagination information. Default is false.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "pageToken",
            "in": "query",
            "required": false,
            "description": "A page token for paginated results.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeAddressCategories",
            "in": "query",
            "required": false,
            "description": "A comma-separated list of address categories to include. Requires address in resultTypeFilter.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "excludeAddressCategories",
            "in": "query",
            "required": false,
            "description": "A comma-separated list of address categories to exclude. Requires address in resultTypeFilter.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results matching the query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
