    "/v1/directions": {
      "get": {
        "operationId": "getDirections",
        "summary": "Get directions between locations",
        "description": "Find directions and estimated travel time between locations.",
        "tags": [
          "Directions"
        ],
        "parameters": [
          {
            "name": "origin",
            "in": "query",
            "required": true,
            "description": "The starting location as an address or comma-separated latitude,longitude coordinates.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "destination",
            "in": "query",
            "required": true,
            "description": "The destination as an address or comma-separated latitude,longitude coordinates.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "arrivalDate",
            "in": "query",
            "required": false,
            "description": "The intended arrival date in ISO 8601 UTC format. Cannot be used with departureDate.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "departureDate",
            "in": "query",
            "required": false,
            "description": "The departure date in ISO 8601 UTC format. Defaults to current time if neither date is specified.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "avoid",
            "in": "query",
            "required": false,
            "description": "A comma-separated list of features to avoid. For example, avoid=Tolls.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "transportType",
            "in": "query",
            "required": false,
            "description": "The mode of transport. Default is Automobile.",
            "schema": {
              "type": "string",
              "enum": [
                "Automobile",
                "Walking",
                "Cycling"
              ],
              "default": "Automobile"
            }
          },
          {
            "name": "requestsAlternateRoutes",
            "in": "query",
            "required": false,
            "description": "When true, the server returns additional routes when available. Default is false.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "description": "The language the server should use when returning the response. Default is en-US.",
            "schema": {
              "type": "string",
              "default": "en-US"
            }
          },
          {
            "name": "searchLocation",
            "in": "query",
            "required": false,
            "description": "A location defined as a hint for origin/destination search, specified as latitude,longitude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchRegion",
            "in": "query",
            "required": false,
            "description": "A region defined as a hint, specified as north-latitude,east-longitude,south-latitude,west-longitude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "userLocation",
            "in": "query",
            "required": false,
            "description": "The location of the user, specified as latitude,longitude.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
