    "/v1/etas": {
      "get": {
        "operationId": "getEtas",
        "summary": "Get estimated arrival times and distances",
        "description": "Determine the estimated arrival times and distances to one or more destinations.",
        "tags": [
          "Directions"
        ],
        "parameters": [
          {
            "name": "origin",
            "in": "query",
            "required": true,
            "description": "The starting point as comma-separated latitude,longitude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "destinations",
            "in": "query",
            "required": true,
            "description": "One to ten destination coordinates separated by a pipe (|). For example, 37.325,-121.946|37.441,-122.172.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "transportType",
            "in": "query",
            "required": false,
            "description": "The mode of transport. Default is Automobile.",
            "schema": {
              "type": "string",
              "enum": [
                "Automobile",
                "Transit",
                "Walking",
                "Cycling"
              ],
              "default": "Automobile"
            }
          },
          {
            "name": "departureDate",
            "in": "query",
            "required": false,
            "description": "The departure date in ISO 8601 UTC format. Defaults to current time.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "arrivalDate",
            "in": "query",
            "required": false,
            "description": "The intended arrival date in ISO 8601 UTC format.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Estimated arrival times and distances to each destination.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EtaResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
