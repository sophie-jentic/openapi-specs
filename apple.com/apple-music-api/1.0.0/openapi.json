{
  "openapi": "3.1.0",
  "info": {
    "title": "Apple Music API",
    "version": "1.0.0",
    "description": "The Apple Music API lets you access information about media in the Apple Music Catalog and a user's personal iCloud Music Library. Use this REST API to retrieve information about albums, songs, artists, playlists, music videos, Apple Music stations, ratings, charts, recommendations, and the user's most recently played content.",
    "contact": {
      "name": "Apple Developer",
      "url": "https://developer.apple.com/documentation/applemusicapi"
    },
    "x-apisguru-categories": [
      "media"
    ],
    "x-logo": {
      "url": "https://developer.apple.com/assets/elements/icons/apple-music-api/apple-music-api-128x128.png"
    }
  },
  "servers": [
    {
      "url": "https://api.music.apple.com/v1"
    }
  ],
  "security": [
    {
      "developerToken": []
    }
  ],
  "components": {
    "securitySchemes": {
      "developerToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "A developer token generated from a MusicKit private key."
      },
      "musicUserToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Music-User-Token",
        "description": "A music user token for authenticated requests to a user's library."
      }
    },
    "schemas": {
