  "paths": {
    "/catalog/{storefront}/search": {
      "get": {
        "operationId": "searchCatalog",
        "summary": "Search the Apple Music Catalog",
        "description": "Search the catalog by using a query.",
        "tags": [
          "Catalog"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/storefront"
          },
          {
            "name": "term",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The entered text for the search."
          },
          {
            "name": "types",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The list of the types of resources to include in the results. Possible values: activities, albums, apple-curators, artists, curators, music-videos, playlists, record-labels, songs, stations"
          },
          {
            "$ref": "#/components/parameters/limit"
          },
          {
            "$ref": "#/components/parameters/offset"
          },
          {
            "name": "storefront",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          }
        }
      }
    },
