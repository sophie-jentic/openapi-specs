      },
      "limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 25
        },
        "description": "The number of objects or number of objects in the specified relationship returned."
      },
      "offset": {
        "name": "offset",
        "in": "query",
        "schema": {
