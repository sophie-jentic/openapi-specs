{
  "openapi": "3.0.3",
  "info": {
    "title": "Anti-Captcha API",
    "version": "2.0",
    "description": "CAPTCHA solving service API. Supports creating tasks, checking results, getting balance, queue stats, and more.",
    "x-jentic-source-url": "https://anti-captcha.com/apidoc",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.anti-captcha.com"
    }
  ],
  "paths": {
    "/createTask": {
      "post": {
        "operationId": "createTask",
        "summary": "Create a captcha solving task",
        "description": "Creates a new captcha solving task.",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getTaskResult": {
      "post": {
        "operationId": "getTaskResult",
        "summary": "Get task result",
        "description": "Retrieves the result of a previously created task.",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "clientKey",
                  "taskId"
                ],
                "properties": {
                  "clientKey": {
                    "type": "string"
                  },
                  "taskId": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResultResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getBalance": {
      "post": {
        "operationId": "getBalance",
        "summary": "Get account balance",
        "description": "Returns current account balance.",
        "tags": [
          "Account"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "clientKey"
                ],
                "properties": {
                  "clientKey": {
                    "type": "string",
                    "description": "API key"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Balance info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errorId": {
                      "type": "integer"
                    },
                    "balance": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getQueueStats": {
      "post": {
        "operationId": "getQueueStats",
        "summary": "Get queue statistics",
        "description": "Returns statistics about the solving queue (waiting time, workers, etc.).",
        "tags": [
          "Queue"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "queueId"
                ],
                "properties": {
                  "queueId": {
                    "type": "integer",
                    "description": "Queue type ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Queue stats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "waiting": {
                      "type": "integer",
                      "description": "Number of tasks waiting"
                    },
                    "load": {
                      "type": "number",
                      "description": "Queue load"
                    },
                    "bid": {
                      "type": "string",
                      "description": "Average task cost"
                    },
                    "speed": {
                      "type": "number",
                      "description": "Average solve speed in seconds"
                    },
                    "total": {
                      "type": "integer",
                      "description": "Total workers online"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getAppStats": {
      "post": {
        "operationId": "getAppStats",
        "summary": "Get application statistics",
        "description": "Returns statistics for the specified application (softId).",
        "tags": [
          "Account"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "clientKey",
                  "softId"
                ],
                "properties": {
                  "clientKey": {
                    "type": "string"
                  },
                  "softId": {
                    "type": "integer",
                    "description": "Application ID"
                  },
                  "mode": {
                    "type": "string",
                    "description": "Stats mode",
                    "enum": [
                      "errors",
                      "views",
                      "downloads"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Application stats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errorId": {
                      "type": "integer"
                    },
                    "chartData": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "fromDate": {
                      "type": "string"
                    },
                    "toDate": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sendFunds": {
      "post": {
        "operationId": "sendFunds",
        "summary": "Send funds to another account",
        "description": "Transfer funds from your account to another Anti-Captcha account.",
        "tags": [
          "Account"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "clientKey",
                  "accountLogin",
                  "amount"
                ],
                "properties": {
                  "clientKey": {
                    "type": "string"
                  },
                  "accountLogin": {
                    "type": "string",
                    "description": "Recipient account login"
                  },
                  "accountEmail": {
                    "type": "string",
                    "description": "Recipient account email"
                  },
                  "amount": {
                    "type": "number",
                    "description": "Amount to send"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Funds sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errorId": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/test": {
      "post": {
        "operationId": "testMethod",
        "summary": "Test method for debugging",
        "description": "Reads POST data, parses it, and outputs as array. Useful for debugging.",
        "tags": [
          "Debug"
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Parsed POST data",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateTaskRequest": {
        "type": "object",
        "required": [
          "clientKey",
          "task"
        ],
        "properties": {
          "clientKey": {
            "type": "string",
            "description": "API key"
          },
          "task": {
            "type": "object",
            "description": "Task object describing what captcha to solve",
            "properties": {
              "type": {
                "type": "string",
                "description": "Task type (e.g., NoCaptchaTaskProxyless, ImageToTextTask)"
              },
              "websiteURL": {
                "type": "string",
                "description": "URL of the target page"
              },
              "websiteKey": {
                "type": "string",
                "description": "reCAPTCHA site key"
              },
              "body": {
                "type": "string",
                "description": "Base64 encoded image (for ImageToTextTask)"
              }
            }
          },
          "softId": {
            "type": "integer",
            "description": "Optional application ID"
          },
          "languagePool": {
            "type": "string",
            "description": "Worker language pool",
            "enum": [
              "en",
              "rn"
            ]
          }
        }
      },
      "CreateTaskResponse": {
        "type": "object",
        "properties": {
          "errorId": {
            "type": "integer",
            "description": "0 if no error"
          },
          "taskId": {
            "type": "integer",
            "description": "ID of the created task"
          }
        }
      },
      "TaskResultResponse": {
        "type": "object",
        "properties": {
          "errorId": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "processing",
              "ready"
            ]
          },
          "solution": {
            "type": "object",
            "description": "Solution data (varies by task type)",
            "properties": {
              "gRecaptchaResponse": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            }
          },
          "cost": {
            "type": "string",
            "description": "Task cost"
          },
          "ip": {
            "type": "string",
            "description": "Worker IP"
          },
          "createTime": {
            "type": "integer"
          },
          "endTime": {
            "type": "integer"
          },
          "solveCount": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errorId": {
            "type": "integer",
            "description": "Error ID (non-zero for errors)"
          },
          "errorCode": {
            "type": "string",
            "description": "Error code string"
          },
          "errorDescription": {
            "type": "string",
            "description": "Human readable error description"
          }
        }
      }
    },
    "securitySchemes": {
      "clientKey": {
        "type": "apiKey",
        "in": "query",
        "name": "clientKey",
        "description": "Client API key passed in request body"
      }
    }
  },
  "security": [
    {
      "clientKey": []
    }
  ],
  "tags": [
    {
      "name": "Account"
    },
    {
      "name": "Debug"
    },
    {
      "name": "Queue"
    },
    {
      "name": "Tasks"
    }
  ]
}
