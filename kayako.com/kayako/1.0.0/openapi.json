                    "status": {
                      "type": "integer"
                    },
                    "resource": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "tests"
        ]
      },
      "post": {
        "summary": "Test API (POST)",
        "operationId": "testPost",
        "description": "Test endpoint for POST requests",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "tags": [
          "tests"
        ]
      },
      "put": {
        "summary": "Test API (PUT)",
        "operationId": "testPut",
        "description": "Test endpoint for PUT requests",
        "responses": {
          "200": {
            "description": "OK"
          }
