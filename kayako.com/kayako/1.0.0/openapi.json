{
  "openapi": "3.0.3",
  "info": {
    "title": "Kayako API",
    "version": "1.0.0",
    "description": "RESTful API for customer support case management",
    "x-jentic-source-url": "https://developer.kayako.com/api/v1/reference/introduction/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{instance}.kayako.com/api/v1",
      "description": "Kayako instance",
      "variables": {
        "instance": {
          "default": "yourinstance",
          "description": "Your Kayako instance subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/tests": {
      "get": {
        "summary": "Test API (GET)",
        "operationId": "testGet",
        "description": "Test endpoint for verifying API connectivity",
        "responses": {
          "200": {
            "description": "OK",
