{
  "openapi": "3.0.3",
  "info": {
    "title": "PANDA API",
    "description": "PANDA (A Newsroom Data Appliance) API provides endpoints for managing users, tasks, datasets, data uploads, and more. Authentication via email and API key required for all requests.",
    "version": "1.0.0",
    "contact": {
      "name": "PANDA Documentation",
      "url": "https://panda.readthedocs.io"
    }
  },
  "servers": [
    {
      "url": "https://example.pandaproject.net",
      "description": "PANDA instance server"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "paths": {
    "/api/1.0/user/schema": {
      "get": {
        "summary": "Get User Schema",
        "description": "Returns the schema definition for user objects",
        "operationId": "getUserSchema",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/user": {
      "get": {
        "summary": "List Users",
        "description": "Returns a list of all users",
        "operationId": "listUsers",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    },
                    "objects": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/User"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create User",
        "description": "Creates a new user",
        "operationId": "createUser",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "first_name",
                  "last_name"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/user/{id}": {
      "get": {
        "summary": "Get User",
        "description": "Fetches a single user by ID",
        "operationId": "getUser",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update User",
        "description": "Updates a user",
        "operationId": "updateUser",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "patch",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Set to true for partial updates"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated successfully"
          }
        }
      }
    },
    "/api/1.0/task/schema": {
      "get": {
        "summary": "Get Task Schema",
        "description": "Returns the schema definition for task objects",
        "operationId": "getTaskSchema",
        "tags": [
          "Tasks"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/task": {
      "get": {
        "summary": "List Tasks",
        "description": "Returns a list of tasks with optional filtering by status or date",
        "operationId": "listTasks",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "PENDING",
                "STARTED",
                "SUCCESS",
                "FAILURE",
                "ABORT REQUESTED",
                "ABORTED"
              ]
            }
          },
          {
            "name": "end__year",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "end__month",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "end__day",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    },
                    "objects": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Task"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/task/{id}": {
      "get": {
        "summary": "Get Task",
        "description": "Fetches a single task by ID",
        "operationId": "getTask",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/dataset/schema": {
      "get": {
        "summary": "Get Dataset Schema",
        "description": "Returns the schema definition for dataset objects",
        "operationId": "getDatasetSchema",
        "tags": [
          "Datasets"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/dataset": {
      "get": {
        "summary": "List Datasets",
        "description": "Returns a list of datasets with optional filtering",
        "operationId": "listDatasets",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by category slug"
          },
          {
            "name": "creator_email",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "email"
            },
            "description": "Filter by creator email"
          },
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Full-text search query"
          },
          {
            "name": "simple",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Return simplified objects"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    },
                    "objects": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Dataset"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Dataset",
        "description": "Creates a new dataset",
        "operationId": "createDataset",
        "tags": [
          "Datasets"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "description"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Dataset created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Dataset"
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/dataset/{slug}": {
      "get": {
        "summary": "Get Dataset",
        "description": "Fetches a single dataset by slug",
        "operationId": "getDataset",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Dataset"
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/dataset/{slug}/data": {
      "get": {
        "summary": "List Dataset Data",
        "description": "Returns data records from a dataset",
        "operationId": "listDatasetData",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sort order (e.g., 'column_name asc' or 'column_name desc')"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    },
                    "objects": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DataRecord"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Dataset Record",
        "description": "Creates or updates a single data record",
        "operationId": "createDatasetRecord",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DataRecord"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Record created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataRecord"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Bulk Update Dataset Records",
        "description": "Creates or updates multiple data records",
        "operationId": "bulkUpdateDatasetRecords",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "objects"
                ],
                "properties": {
                  "objects": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/DataRecord"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Records updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete All Dataset Data",
        "description": "Deletes all data records from a dataset",
        "operationId": "deleteAllDatasetData",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "All data deleted successfully"
          }
        }
      }
    },
    "/api/1.0/dataset/{slug}/data/{external_id}": {
      "get": {
        "summary": "Get Dataset Record",
        "description": "Fetches a single data record by external ID",
        "operationId": "getDatasetRecord",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "external_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataRecord"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update Dataset Record",
        "description": "Updates a single data record",
        "operationId": "updateDatasetRecord",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "external_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DataRecord"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete Dataset Record",
        "description": "Deletes a single data record",
        "operationId": "deleteDatasetRecord",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "external_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Record deleted successfully"
          }
        }
      }
    },
    "/api/1.0/category/schema": {
      "get": {
        "summary": "Get Category Schema",
        "description": "Returns the schema definition for category objects",
        "operationId": "getCategorySchema",
        "tags": [
          "Categories"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/category": {
      "get": {
        "summary": "List Categories",
        "description": "Returns a list of all categories including 'Uncategorized'",
        "operationId": "listCategories",
        "tags": [
          "Categories"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    },
                    "objects": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Category"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/category/{slug}": {
      "get": {
        "summary": "Get Category",
        "description": "Fetches a single category by slug",
        "operationId": "getCategory",
        "tags": [
          "Categories"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Category"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "total_count": {
            "type": "integer"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "STARTED",
              "SUCCESS",
              "FAILURE",
              "ABORT REQUESTED",
              "ABORTED"
            ]
          },
          "end": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "Dataset": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "creator_email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "DataRecord": {
        "type": "object",
        "properties": {
          "external_id": {
            "type": "string",
            "description": "Unique identifier for the record"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of data values"
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API authentication requires email and api_key parameters. Also provide format=json parameter. Alternatively, use PANDA_EMAIL and PANDA_API_KEY headers."
      }
    }
  },
  "tags": [
    {
      "name": "Categories"
    },
    {
      "name": "Data"
    },
    {
      "name": "Datasets"
    },
    {
      "name": "Tasks"
    },
    {
      "name": "Users"
    }
  ]
}
