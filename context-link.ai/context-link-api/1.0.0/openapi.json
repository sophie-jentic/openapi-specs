{
  "openapi": "3.0.3",
  "info": {
    "title": "Context Link API",
    "version": "1.0.0",
    "description": "Context-aware AI API. Retrieves responses from connected knowledge sources based on search queries.",
    "x-jentic-source-url": "https://context-link.ai/docs/context-endpoint",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://context-link.ai"
    }
  ],
  "paths": {
    "/api/v1/context": {
      "get": {
        "operationId": "getContext",
        "summary": "Get context response",
        "tags": [
          "Context"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search question; dashes/underscores convert to spaces"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContextResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing query parameter"
          },
          "401": {
            "description": "Missing API key or subscription required"
          },
          "404": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limit exceeded (5 requests per 10 seconds)"
          }
        },
        "description": "Get context response"
      }
    }
  },
  "components": {
    "schemas": {
      "ContextResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Response content in Markdown format"
          },
          "format": {
            "type": "string",
            "enum": [
              "markdown"
            ]
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Context"
    }
  ]
}
