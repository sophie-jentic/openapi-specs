{
  "openapi": "3.0.3",
  "info": {
    "title": "Home Assistant REST API",
    "version": "1.0.0",
    "description": "Home Assistant RESTful API for controlling smart home devices, retrieving state data, viewing history and logbook entries, managing calendars, firing events, calling services, rendering templates, and checking configuration. Runs on port 8123 alongside the web frontend.",
    "x-jentic-source-url": "https://developers.home-assistant.io/docs/api/rest/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://{ha-host}:8123/api",
      "description": "Home Assistant instance"
    }
  ],
  "tags": [
    {
      "name": "General",
      "description": "API health and configuration"
    },
    {
      "name": "States",
      "description": "Entity state management"
    },
    {
      "name": "Events",
      "description": "Event firing"
    },
    {
      "name": "Services",
      "description": "Service invocation"
    },
    {
      "name": "History",
      "description": "State change history"
    },
    {
      "name": "Logbook",
      "description": "Logbook entries"
    },
    {
      "name": "Calendars",
      "description": "Calendar events"
    },
    {
      "name": "Templates",
      "description": "Template rendering"
    },
    {
      "name": "Configuration",
      "description": "Configuration checking"
    },
    {
      "name": "Camera",
      "description": "Camera proxy"
    },
    {
      "name": "Intents",
      "description": "Intent handling"
    },
    {
      "name": "Diagnostics",
      "description": "Error logs"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "checkApi",
        "summary": "Check if the API is running",
        "tags": [
          "General"
        ],
        "responses": {
          "200": {
            "description": "API running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "API running."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Check if the API is running"
      }
    },
    "/config": {
      "get": {
        "operationId": "getConfig",
        "summary": "Get the current configuration",
        "description": "Returns the current configuration including components, location, time zone, and unit system.",
        "tags": [
          "General"
        ],
        "responses": {
          "200": {
            "description": "Configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Config"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/components": {
      "get": {
        "operationId": "getComponents",
        "summary": "Get list of loaded components",
        "tags": [
          "General"
        ],
        "responses": {
          "200": {
            "description": "Component list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get list of loaded components"
      }
    },
    "/events": {
      "get": {
        "operationId": "listEvents",
        "summary": "List all event types",
        "description": "Returns an array of event objects with event name and listener count.",
        "tags": [
          "Events"
        ],
        "responses": {
          "200": {
            "description": "Event list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EventType"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/services": {
      "get": {
        "operationId": "listServices",
        "summary": "List all available services",
        "description": "Returns an array of service objects grouped by domain.",
        "tags": [
          "Services"
        ],
        "responses": {
          "200": {
            "description": "Service list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ServiceDomain"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/history/period/{timestamp}": {
      "get": {
        "operationId": "getHistory",
        "summary": "Get state change history",
        "description": "Returns an array of state changes for the specified period. Timestamp is optional and defaults to 1 day before the request.",
        "tags": [
          "History"
        ],
        "parameters": [
          {
            "name": "timestamp",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start of period (YYYY-MM-DDThh:mm:ssTZD). Defaults to 1 day ago."
          },
          {
            "name": "filter_entity_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated entity IDs to filter on"
          },
          {
            "name": "end_time",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End of period (URL encoded)"
          },
          {
            "name": "minimal_response",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Only return last_changed and state for non-boundary states"
          },
          {
            "name": "no_attributes",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Skip returning attributes"
          },
          {
            "name": "significant_changes_only",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Only return significant state changes"
          }
        ],
        "responses": {
          "200": {
            "description": "History data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/State"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/logbook/{timestamp}": {
      "get": {
        "operationId": "getLogbook",
        "summary": "Get logbook entries",
        "description": "Returns an array of logbook entries. Timestamp is optional and defaults to 1 day before the request.",
        "tags": [
          "Logbook"
        ],
        "parameters": [
          {
            "name": "timestamp",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start of period"
          },
          {
            "name": "entity",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter on one entity ID"
          },
          {
            "name": "end_time",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End of period"
          }
        ],
        "responses": {
          "200": {
            "description": "Logbook entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LogbookEntry"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/states": {
      "get": {
        "operationId": "listStates",
        "summary": "Get all entity states",
        "description": "Returns an array of state objects for all entities.",
        "tags": [
          "States"
        ],
        "responses": {
          "200": {
            "description": "State list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/State"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/states/{entity_id}": {
      "get": {
        "operationId": "getState",
        "summary": "Get state of a specific entity",
        "tags": [
          "States"
        ],
        "parameters": [
          {
            "name": "entity_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Entity ID (e.g. sensor.temperature)"
          }
        ],
        "responses": {
          "200": {
            "description": "Entity state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/State"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get state of a specific entity"
      },
      "post": {
        "operationId": "setState",
        "summary": "Update or create an entity state",
        "description": "Sets the state representation of an entity. Does not communicate with the actual device.",
        "tags": [
          "States"
        ],
        "parameters": [
          {
            "name": "entity_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Entity ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetStateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "State updated (entity existed)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/State"
                }
              }
            }
          },
          "201": {
            "description": "State created (new entity)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/State"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteState",
        "summary": "Delete an entity",
        "tags": [
          "States"
        ],
        "parameters": [
          {
            "name": "entity_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Entity ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Entity deleted"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete an entity"
      }
    },
    "/events/{event_type}": {
      "post": {
        "operationId": "fireEvent",
        "summary": "Fire an event",
        "description": "Fires an event with the given event_type. Optional JSON body used as event_data.",
        "tags": [
          "Events"
        ],
        "parameters": [
          {
            "name": "event_type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Event type to fire"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "description": "Event data"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event fired",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/services/{domain}/{service}": {
      "post": {
        "operationId": "callService",
        "summary": "Call a service",
        "description": "Calls a service within a specific domain. Returns list of states that changed during execution. Add ?return_response for services that return data.",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Service domain (e.g. light, switch)"
          },
          {
            "name": "service",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Service name (e.g. turn_on, turn_off)"
          },
          {
            "name": "return_response",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include service response data in the response"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "entity_id": {
                    "type": "string",
                    "description": "Target entity ID"
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Service called, returns changed states",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/State"
                      }
                    },
                    {
                      "$ref": "#/components/schemas/ServiceResponseWithData"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/template": {
      "post": {
        "operationId": "renderTemplate",
        "summary": "Render a Home Assistant template",
        "tags": [
          "Templates"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "template"
                ],
                "properties": {
                  "template": {
                    "type": "string",
                    "description": "Jinja2 template string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rendered template",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Render a Home Assistant template"
      }
    },
    "/config/core/check_config": {
      "post": {
        "operationId": "checkConfig",
        "summary": "Check configuration.yaml validity",
        "tags": [
          "Configuration"
        ],
        "responses": {
          "200": {
            "description": "Config check result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigCheckResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Check configuration.yaml validity"
      }
    },
    "/error_log": {
      "get": {
        "operationId": "getErrorLog",
        "summary": "Get error log",
        "description": "Retrieve all errors logged during the current session as plaintext.",
        "tags": [
          "Diagnostics"
        ],
        "responses": {
          "200": {
            "description": "Error log",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/camera_proxy/{entity_id}": {
      "get": {
        "operationId": "getCameraImage",
        "summary": "Get camera image",
        "description": "Returns the current image from the specified camera entity.",
        "tags": [
          "Camera"
        ],
        "parameters": [
          {
            "name": "entity_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Camera entity ID"
          },
          {
            "name": "time",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Cache-busting timestamp"
          }
        ],
        "responses": {
          "200": {
            "description": "Camera image",
            "content": {
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/calendars": {
      "get": {
        "operationId": "listCalendars",
        "summary": "List calendar entities",
        "tags": [
          "Calendars"
        ],
        "responses": {
          "200": {
            "description": "Calendar list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CalendarEntity"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List calendar entities"
      }
    },
    "/calendars/{entity_id}": {
      "get": {
        "operationId": "getCalendarEvents",
        "summary": "Get calendar events",
        "description": "Returns events for a calendar entity between start and end times.",
        "tags": [
          "Calendars"
        ],
        "parameters": [
          {
            "name": "entity_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Calendar entity ID"
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start time (exclusive)"
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End time (exclusive)"
          }
        ],
        "responses": {
          "200": {
            "description": "Calendar events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CalendarEvent"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
