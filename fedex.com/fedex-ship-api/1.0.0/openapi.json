{
  "openapi": "3.0.3",
  "info": {
    "title": "FedEx Ship API",
    "version": "1.0.0",
    "description": "FedEx Ship API allows creation, validation, and cancellation of shipments, as well as tag management for FedEx Express and Ground services.",
    "x-jentic-source-url": "https://developer.fedex.com/api/en-us/catalog/ship/docs.html",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://apis.fedex.com"
    }
  ],
  "paths": {
    "/ship/v1/shipments": {
      "post": {
        "operationId": "createShipment",
        "summary": "Create Shipment",
        "description": "Create a FedEx shipment with all necessary shipping information.",
        "tags": [
          "Shipments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateShipmentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful shipment creation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShipmentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ship/v1/shipments/validate": {
      "post": {
        "operationId": "validateShipment",
        "summary": "Validate Shipment",
        "description": "Validate the accuracy of shipment details prior to submitting the final shipment request.",
        "tags": [
          "Shipments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateShipmentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ship/v1/shipments/async/{jobId}": {
      "get": {
        "operationId": "retrieveAsyncShipment",
        "summary": "Retrieve Async Ship",
        "description": "Retrieve shipments processed asynchronously using the job ID.",
        "tags": [
          "Shipments"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Async job identifier"
          },
          {
            "name": "accountNumber",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "FedEx account number"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShipmentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ship/v1/shipments/{trackingNumber}": {
      "delete": {
        "operationId": "cancelShipment",
        "summary": "Cancel Shipment",
        "description": "Cancel an already created FedEx shipment/package.",
        "tags": [
          "Shipments"
        ],
        "parameters": [
          {
            "name": "trackingNumber",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Tracking number of the shipment to cancel"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelShipmentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shipment cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CancelResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ship/v1/tags": {
      "post": {
        "operationId": "createTag",
        "summary": "Create Tag",
        "description": "Create tag requests for FedEx Express and FedEx Ground shipments.",
        "tags": [
          "Tags"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTagRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tag created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TagResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ship/v1/tags/{confirmationNumber}": {
      "delete": {
        "operationId": "cancelTag",
        "summary": "Cancel Tag",
        "description": "Cancel a FedEx Return Tag and the associated pickup.",
        "tags": [
          "Tags"
        ],
        "parameters": [
          {
            "name": "confirmationNumber",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Tag confirmation number"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelTagRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tag cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CancelResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateShipmentRequest": {
        "type": "object",
        "properties": {
          "accountNumber": {
            "type": "string",
            "description": "FedEx account number"
          },
          "requestedShipment": {
            "$ref": "#/components/schemas/RequestedShipment"
          }
        }
      },
      "RequestedShipment": {
        "type": "object",
        "properties": {
          "pickupType": {
            "type": "string",
            "enum": [
              "DROPOFF_AT_FEDEX_LOCATION",
              "CONTACT_FEDEX_TO_SCHEDULE",
              "USE_SCHEDULED_PICKUP"
            ]
          },
          "serviceType": {
            "type": "string",
            "description": "FedEx service type (e.g., FEDEX_GROUND, STANDARD_OVERNIGHT)"
          },
          "packagingType": {
            "type": "string",
            "description": "Packaging type (e.g., YOUR_PACKAGING, FEDEX_BOX)"
          },
          "shipper": {
            "$ref": "#/components/schemas/Party"
          },
          "recipients": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Party"
            }
          },
          "shippingChargesPayment": {
            "$ref": "#/components/schemas/Payment"
          },
          "requestedPackageLineItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PackageLineItem"
            }
          },
          "labelSpecification": {
            "$ref": "#/components/schemas/LabelSpecification"
          }
        }
      },
      "Party": {
        "type": "object",
        "properties": {
          "contact": {
            "type": "object",
            "properties": {
              "personName": {
                "type": "string"
              },
              "phoneNumber": {
                "type": "string"
              },
              "companyName": {
                "type": "string"
              }
            }
          },
          "address": {
            "type": "object",
            "properties": {
              "streetLines": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "city": {
                "type": "string"
              },
              "stateOrProvinceCode": {
                "type": "string"
              },
              "postalCode": {
                "type": "string"
              },
              "countryCode": {
                "type": "string"
              }
            }
          }
        }
      },
      "Payment": {
        "type": "object",
        "properties": {
          "paymentType": {
            "type": "string",
            "enum": [
              "SENDER",
              "RECIPIENT",
              "THIRD_PARTY"
            ]
          },
          "payor": {
            "type": "object",
            "properties": {
              "responsibleParty": {
                "$ref": "#/components/schemas/Party"
              },
              "accountNumber": {
                "type": "string"
              }
            }
          }
        }
      },
      "PackageLineItem": {
        "type": "object",
        "properties": {
          "weight": {
            "type": "object",
            "properties": {
              "units": {
                "type": "string",
                "enum": [
                  "LB",
                  "KG"
                ]
              },
              "value": {
                "type": "number"
              }
            }
          },
          "dimensions": {
            "type": "object",
            "properties": {
              "length": {
                "type": "integer"
              },
              "width": {
                "type": "integer"
              },
              "height": {
                "type": "integer"
              },
              "units": {
                "type": "string",
                "enum": [
                  "IN",
                  "CM"
                ]
              }
            }
          }
        }
      },
      "LabelSpecification": {
        "type": "object",
        "properties": {
          "labelFormatType": {
            "type": "string",
            "enum": [
              "COMMON2D",
              "LABEL_DATA_ONLY"
            ]
          },
          "imageType": {
            "type": "string",
            "enum": [
              "PDF",
              "PNG",
              "ZPLII"
            ]
          },
          "labelStockType": {
            "type": "string"
          }
        }
      },
      "ShipmentResponse": {
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string"
          },
          "output": {
            "type": "object",
            "properties": {
              "transactionShipments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "masterTrackingNumber": {
                      "type": "string"
                    },
                    "serviceType": {
                      "type": "string"
                    },
                    "pieceResponses": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "trackingNumber": {
                            "type": "string"
                          },
                          "packageDocuments": {
                            "type": "array",
                            "items": {
                              "type": "object"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ValidationResponse": {
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string"
          },
          "output": {
            "type": "object",
            "properties": {
              "alerts": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Alert"
                }
              }
            }
          }
        }
      },
      "CancelShipmentRequest": {
        "type": "object",
        "properties": {
          "accountNumber": {
            "type": "string"
          },
          "deletionControl": {
            "type": "string",
            "enum": [
              "DELETE_ALL_PACKAGES",
              "DELETE_ONE_PACKAGE"
            ]
          },
          "emailReturnShipment": {
            "type": "boolean"
          }
        }
      },
      "CreateTagRequest": {
        "type": "object",
        "properties": {
          "accountNumber": {
            "type": "string"
          },
          "requestedShipment": {
            "$ref": "#/components/schemas/RequestedShipment"
          }
        }
      },
      "CancelTagRequest": {
        "type": "object",
        "properties": {
          "accountNumber": {
            "type": "string"
          },
          "serviceType": {
            "type": "string"
          },
          "dispatchDate": {
            "type": "string",
            "format": "date"
          },
          "location": {
            "type": "string"
          }
        }
      },
      "TagResponse": {
        "type": "object",
        "properties": {
          "confirmationNumber": {
            "type": "string"
          },
          "applicableService": {
            "type": "string"
          },
          "dispatchDate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "CancelResponse": {
        "type": "object",
        "properties": {
          "cancelledIndicator": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "alertType": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2.0 Bearer token obtained from FedEx authentication API"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Shipments"
    },
    {
      "name": "Tags"
    }
  ]
}
