  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Token",
        "description": "API key for authentication."
      }
    },
    "schemas": {
      "Fees": {
        "type": "object",
        "properties": {
          "makerRate": {
            "type": "string",
            "description": "Maker fee rate."
          },
          "takerRate": {
            "type": "string",
            "description": "Taker fee rate."
          },
          "volumeInUSD": {
            "type": "string",
            "description": "30-day trading volume in USD."
          }
        }
      },
      "BaseOrder": {
        "type": "object",
        "required": [
          "clOrdId",
          "ordType",
          "symbol",
          "side",
          "orderQty"
        ],
        "properties": {
          "clOrdId": {
            "type": "string",
            "maxLength": 20,
            "description": "Client order ID. Max 20 alphanumeric characters."
          },
          "ordType": {
            "type": "string",
            "enum": [
              "MARKET",
              "LIMIT",
              "STOP",
              "STOPLIMIT"
            ],
            "description": "Order type."
          },
          "symbol": {
            "type": "string",
            "description": "Trading symbol (e.g., BTC-USD)."
          },
          "side": {
            "type": "string",
            "enum": [
              "BUY",
              "SELL"
