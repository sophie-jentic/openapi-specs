              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepositAddressCrypto"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
