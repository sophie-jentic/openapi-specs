        }
      }
    },
    "/accounts/{account}/{currency}": {
      "get": {
        "operationId": "getAccountByTypeAndCurrency",
        "summary": "Receive current account balance",
        "description": "Returns the balance for a specific account type and currency.",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "account",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account type (e.g., primary)."
          },
          {
            "name": "currency",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Currency code (e.g., BTC)."
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
