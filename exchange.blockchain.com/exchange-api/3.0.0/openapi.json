    "/internal/orders": {
      "get": {
        "operationId": "getOrdersInternal",
        "summary": "Get orders directly from the matching engine",
        "description": "Returns orders as pulled directly from the matching engine. Supports pagination by orderId.",
        "tags": [
          "Trading"
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Epoch timestamp in ms."
          },
          {
            "name": "orderId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Last orderId seen in paginated responses."
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
