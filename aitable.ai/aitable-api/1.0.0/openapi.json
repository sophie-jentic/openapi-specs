{
  "openapi": "3.0.3",
  "info": {
    "title": "AITable API",
    "version": "1.0.0",
    "description": "AITable is a collaborative data platform. The API provides RESTful endpoints for managing spaces, datasheets, records, fields, views, attachments, and contacts.",
    "x-jentic-source-url": "https://developers.aitable.ai",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://aitable.ai/fusion/v1"
    }
  ],
  "tags": [
    {
      "name": "Spaces",
      "description": "Space management"
    },
    {
      "name": "Records",
      "description": "Record CRUD operations"
    },
    {
      "name": "Fields",
      "description": "Field management"
    },
    {
      "name": "Views",
      "description": "View operations"
    },
    {
      "name": "Attachments",
      "description": "Attachment upload"
    },
    {
      "name": "Nodes",
      "description": "Work directory node operations"
    },
    {
      "name": "Contacts",
      "description": "Contact/member management"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/spaces": {
      "get": {
        "operationId": "getSpaces",
        "summary": "Get list of spaces",
        "description": "Get a list of all spaces the authenticated user has access to.",
        "tags": [
          "Spaces"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpaceListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/spaces/{spaceId}/nodes": {
      "get": {
        "operationId": "getNodes",
        "summary": "Get list of nodes",
        "description": "Get the list of file nodes in a space's work directory.",
        "tags": [
          "Nodes"
        ],
        "parameters": [
          {
            "name": "spaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Space ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NodeListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/datasheets/{datasheetId}/records": {
      "get": {
        "operationId": "getRecords",
        "summary": "Get records",
        "description": "Get a paginated list of records from a datasheet.",
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "datasheetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Datasheet ID (starts with dst)"
          },
          {
            "name": "viewId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "View ID to filter records"
          },
          {
            "name": "pageNum",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 1000
            },
            "description": "Records per page (max 1000)"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sort rules as JSON array"
          },
          {
            "name": "recordIds",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated record IDs to retrieve"
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated field names to return"
          },
          {
            "name": "filterByFormula",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter formula"
          },
          {
            "name": "cellFormat",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "string"
              ]
            },
            "description": "Cell value format"
          },
          {
            "name": "fieldKey",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "name",
                "id"
              ]
            },
            "description": "Use field name or ID as key"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createRecords",
        "summary": "Create records",
        "description": "Create one or more records in a datasheet.",
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "datasheetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Datasheet ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRecordsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Records created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateRecords",
        "summary": "Update records",
        "description": "Update one or more records in a datasheet.",
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "datasheetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Datasheet ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateRecordsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Records updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteRecords",
        "summary": "Delete records",
        "description": "Delete one or more records from a datasheet.",
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "datasheetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Datasheet ID"
          },
          {
            "name": "recordIds",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated record IDs to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Records deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/datasheets/{datasheetId}/fields": {
