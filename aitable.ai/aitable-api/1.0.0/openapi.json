  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API token obtained from AITable settings"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Error code"
          },
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "SUCCESS"
          }
        }
      },
      "RecordListResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer",
                "description": "Total number of records"
              },
              "pageNum": {
                "type": "integer"
              },
              "pageSize": {
                "type": "integer"
              },
              "records": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Record"
                }
              }
            }
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Record": {
        "type": "object",
        "properties": {
          "recordId": {
            "type": "string",
            "description": "Record ID (starts with rec)"
          },
          "createdAt": {
            "type": "integer",
            "description": "Creation timestamp in milliseconds"
          },
          "updatedAt": {
            "type": "integer",
            "description": "Last update timestamp in milliseconds"
          },
          "fields": {
            "type": "object",
            "description": "Field name/ID to value mapping",
            "additionalProperties": true
          }
        }
      },
      "CreateRecordsRequest": {
        "type": "object",
        "properties": {
          "records": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fields": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "Field name/ID to value mapping"
                }
              },
              "required": [
                "fields"
              ]
            },
            "maxItems": 10
          },
          "fieldKey": {
            "type": "string",
            "enum": [
              "name",
              "id"
            ],
            "description": "Use field name or ID as key"
          }
        },
        "required": [
          "records"
        ]
      },
      "UpdateRecordsRequest": {
        "type": "object",
        "properties": {
          "records": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "recordId": {
                  "type": "string",
                  "description": "Record ID to update"
                },
                "fields": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "Field name/ID to value mapping"
                }
              },
              "required": [
                "recordId",
                "fields"
              ]
            },
            "maxItems": 10
          },
          "fieldKey": {
            "type": "string",
            "enum": [
              "name",
              "id"
            ]
          }
        },
        "required": [
          "records"
