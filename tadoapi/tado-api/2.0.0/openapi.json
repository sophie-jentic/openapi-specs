{
  "openapi": "3.0.3",
  "info": {
    "title": "Tado API",
    "description": "Tado api version 2 as used by Tado webapp",
    "version": "2.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/bartvanraalte/tado-api/2.0.0",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://my.tado.com/api/v2"
    }
  ],
  "security": [
    {
      "oAuthSecurity": [
        "home.user"
      ]
    }
  ],
  "paths": {
    "/me": {
      "get": {
        "tags": [
          "Profile"
        ],
        "summary": "User Profile",
        "description": "The User Profile endpoint returns information about the Tado user that has \nauthorized with the application. This includes\nthe home and mobiledevices.\n",
        "responses": {
          "200": {
            "description": "Object with user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Profile"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get-me"
      }
    },
    "/homes/{home}": {
      "get": {
        "tags": [
          "Home"
        ],
        "summary": "Description of home",
        "parameters": [
          {
            "name": "home",
            "in": "path",
            "description": "Unique identifier of home",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object with home details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/home"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "description": "Description of home",
        "operationId": "get-homes-by-home"
      }
    },
