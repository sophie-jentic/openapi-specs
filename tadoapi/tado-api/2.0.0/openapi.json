    "/homes/{home}/zones/{zone}/overlay": {
      "put": {
        "tags": [
          "Zone"
        ],
        "summary": "Change settings of zone",
        "parameters": [
          {
            "name": "home",
            "in": "path",
            "description": "Unique identifier of home",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "zone",
            "in": "path",
            "description": "Unique identifier of zone",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Overlay response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/overlay"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "description": "Change settings of zone",
        "operationId": "put-homes-by-home-zones-by-zone-overlay"
      },
      "delete": {
        "tags": [
          "Zone"
        ],
        "summary": "Delete overlay settings and return to scheduled program",
        "parameters": [
          {
            "name": "home",
            "in": "path",
            "description": "Unique identifier of home",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "zone",
            "in": "path",
            "description": "Unique identifier of zone",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Overlay removed",
            "content": {}
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "description": "Delete overlay settings and return to scheduled program",
        "operationId": "delete-homes-by-home-zones-by-zone-overlay"
      }
    },
    "/homes/{home}/zones/{zone}/state": {
