      }
    },
    "/homes/{home}/weather": {
      "get": {
        "tags": [
          "Home"
        ],
        "summary": "Weather at location of a home",
        "parameters": [
          {
            "name": "home",
            "in": "path",
            "description": "Unique identifier of home",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Current weather information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/weather"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "description": "Weather at location of a home",
        "operationId": "get-homes-by-home-weather"
      }
    }
  },
  "components": {
    "schemas": {
      "Profile": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Fullname of the user."
          },
          "email": {
            "type": "string",
            "description": "Email address of the user."
          },
          "username": {
            "type": "string",
            "description": "Username of the user, for now same as email"
          },
          "locale": {
            "type": "string",
            "description": "Two letter locale setting"
          },
          "homes": {
            "type": "array",
            "description": "List of homes linked to profile.",
            "items": {
              "$ref": "#/components/schemas/basicHome"
            }
          },
          "mobileDevices": {
            "type": "array",
            "description": "List of mobile devices linked to profile",
            "items": {
              "$ref": "#/components/schemas/mobileDevice"
            }
          }
        }
      },
      "basicHome": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Numeric unique identifier of the home"
          },
          "name": {
            "type": "string",
            "description": "Name of the home as set by user"
          }
        }
      },
      "home": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Numeric unique identifier of the home"
          },
          "name": {
            "type": "string",
            "description": "Name of the home as set by user"
          },
          "dateTimeZone": {
            "type": "string",
            "example": "Europe/Amsterdam"
          },
          "temperatureUnit": {
            "type": "string",
            "enum": [
              "CELCIUS"
            ]
          },
          "installationCompleted": {
            "type": "boolean"
          },
          "partner": {
            "type": "string"
          },
          "simpleSmartScheduleEnabled": {
            "type": "boolean"
          },
          "christmasModeEnabled": {
            "type": "boolean"
          },
          "contactDetails": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "phone": {
                "type": "string"
              }
            }
          },
          "address": {
            "type": "object",
            "properties": {
              "addressLine1": {
                "type": "string"
              },
              "addressLine2": {
                "type": "string"
              },
              "zipCode": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "state": {
                "type": "string"
              },
              "country": {
                "type": "string",
                "description": "Three letter country code",
                "example": "NLD"
              }
            }
          },
          "geolocation": {
            "type": "object",
            "properties": {
              "latitude": {
                "type": "integer"
              },
              "longitude": {
                "type": "integer"
              }
            }
          }
        },
        "description": "Complete home object"
      },
      "timetableBlock": {
        "type": "object",
        "properties": {
          "dayType": {
            "type": "string",
            "enum": [
              "MONDAY_TO_SUNDAY"
            ]
          },
          "start": {
            "type": "string",
            "format": "time"
          },
          "end": {
            "type": "string",
            "format": "time"
          },
          "geolocationOverride": {
            "type": "boolean"
          },
          "modeId": {
            "type": "integer"
          },
          "setting": {
            "required": [
              "power",
              "type"
            ],
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "HEATING"
                ]
              },
              "power": {
                "type": "string",
                "enum": [
                  "OFF",
                  "ON"
                ]
              },
              "temperature": {
                "type": "object",
                "properties": {
                  "celcius": {
                    "type": "integer"
                  },
                  "fahrenheit": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      },
      "timetable": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "enum": [
              "ONE_DAY",
              "THREE_DAY",
              "SEVEN_DAY"
            ]
          }
        }
      },
      "mobileDevice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Numeric unique identifier of the mobile device"
          },
          "name": {
            "type": "string",
            "description": "Name of the device as set by user"
          },
          "settings": {
            "type": "object",
            "properties": {
              "geoTrackingEnabled": {
                "type": "boolean"
              }
            }
          },
          "location": {
            "type": "object",
            "properties": {
              "stale": {
                "type": "boolean"
              },
              "atHome": {
                "type": "boolean"
              },
              "relativeDistanceFromHomeFence": {
                "type": "integer"
              },
              "bearingFromHome": {
                "type": "object",
                "properties": {
                  "degrees": {
                    "type": "integer"
                  },
                  "radians": {
                    "type": "integer",
                    "format": "float"
                  }
                }
              }
            }
          }
        }
      },
      "device": {
        "type": "object",
        "properties": {
          "deviceType": {
            "type": "string",
            "enum": [
              "RU01",
              "VA01",
              "GW03"
            ]
          },
          "serialNo": {
            "type": "string"
          },
          "shortSerialNo": {
            "type": "string"
          },
          "gatewayOperation": {
            "type": "string",
            "enum": [
              "NORMAL"
            ]
          },
          "connectionState": {
            "type": "object",
            "properties": {
              "value": {
                "type": "boolean"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "mountingState": {
            "type": "object",
            "properties": {
              "value": {
                "type": "boolean"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "characteristics": {
            "type": "object",
            "properties": {
              "capabilities": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "INSIDE_TEMPERATURE_MEASUREMENT",
                    "IDENTIFY"
                  ]
                }
              }
            }
          }
        },
        "description": "Tado device"
      },
      "zone": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Numeric unique identifier of the zone"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "HEATING"
            ]
          },
          "reportAvailable": {
            "type": "boolean"
          },
          "supportsDazzle": {
            "type": "boolean"
          },
          "deviceTypes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "RU01",
                "VA01"
              ]
            }
          },
          "devices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/device"
            }
          }
        },
        "description": "zone object"
      },
      "overlay": {
        "required": [
          "setting",
          "termination"
        ],
        "type": "object",
        "properties": {
          "setting": {
            "required": [
              "power",
              "type"
            ],
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "HEATING"
                ]
              },
              "power": {
                "type": "string",
                "enum": [
                  "OFF",
                  "ON"
                ]
              },
              "temperature": {
                "type": "object",
                "properties": {
                  "celcius": {
                    "type": "integer"
                  }
                }
              }
            }
          },
          "termination": {
            "required": [
              "type"
            ],
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "MANUAL",
                  "TIMER",
                  "TADO_MODE"
                ]
              },
              "durationInSeconds": {
                "type": "integer"
              }
            }
          }
        },
        "description": "overlay object"
      },
      "installation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Numeric unique identifier of the installation"
          },
          "type": {
