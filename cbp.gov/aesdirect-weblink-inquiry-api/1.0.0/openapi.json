{
  "openapi": "3.0.3",
  "info": {
    "title": "AESDirect WebLink Inquiry API",
    "version": "1.0.0",
    "description": "U.S. Customs and Border Protection AESDirect WebLink API for filing status inquiries and creating export filings.",
    "x-jentic-source-url": "https://www.cbp.gov/trade/automated/aesdirect-weblink-inquiry-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://trade.cbp.dhs.gov",
      "description": "Production"
    },
    {
      "url": "https://trade-test.cbp.dhs.gov",
      "description": "Test/Training"
    }
  ],
  "paths": {
    "/ace/aes/aesdirect-ui/secured/weblinkFilingInquiry": {
      "get": {
        "operationId": "inquireFilingStatus",
        "summary": "Inquire filing status",
        "description": "Inquires filing status within AESWebLink using Filer ID and Shipment Reference Number.",
        "tags": [
          "Filing"
        ],
        "parameters": [
          {
            "name": "FID",
            "in": "query",
            "description": "Filer ID (alphanumeric, max 11 characters)",
            "required": true,
            "schema": {
              "type": "string",
              "maxLength": 11
            }
          },
          {
            "name": "SRN",
            "in": "query",
            "description": "Shipment Reference Number (alphanumeric, max 17 characters)",
            "required": true,
            "schema": {
              "type": "string",
              "maxLength": 17
            }
          },
          {
            "name": "URL",
            "in": "query",
            "description": "Return URL for automated redirect (HTTPS only, max 150 characters)",
            "required": false,
            "schema": {
              "type": "string",
              "maxLength": 150
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Filing status returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FilingStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ace/aes/aesdirect-ui/secured/createWeblinkFiling": {
      "post": {
        "operationId": "createWeblinkFiling",
        "summary": "Create WebLink filing",
        "description": "Creates a new WebLink filing in AESWebLink.",
        "tags": [
          "Filing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "FID",
                  "SRN"
                ],
                "properties": {
                  "FID": {
                    "type": "string",
                    "maxLength": 11,
                    "description": "Filer ID"
                  },
                  "SRN": {
                    "type": "string",
                    "maxLength": 17,
                    "description": "Shipment Reference Number"
                  },
                  "URL": {
                    "type": "string",
                    "maxLength": 150,
                    "description": "Return URL (HTTPS only)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Filing created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FilingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FilingStatusResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "filingId": {
            "type": "string"
          },
          "shipmentReferenceNumber": {
            "type": "string"
          }
        }
      },
      "FilingResponse": {
        "type": "object",
        "properties": {
          "filingId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Filing"
    }
  ]
}
