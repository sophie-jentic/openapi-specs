{
  "openapi": "3.0.3",
  "info": {
    "title": "Remark42 API",
    "version": "1.0.0",
    "description": "Remark42 is a self-hosted, lightweight commenting engine. The API provides public endpoints for reading comments, authenticated endpoints for posting/editing comments, and admin endpoints for moderation and site management.",
    "x-jentic-source-url": "https://remark42.com/docs/contributing/api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "security": [
    {
      "CookieAuth": []
    }
  ],
  "tags": [
    {
      "name": "Public",
      "description": "Public comment reading endpoints"
    },
    {
      "name": "Comments",
      "description": "Authenticated comment operations"
    },
    {
      "name": "Admin",
      "description": "Admin moderation and management"
    },
    {
      "name": "Auth",
      "description": "Authentication"
    },
    {
      "name": "RSS",
      "description": "RSS feeds"
    }
  ],
  "paths": {
    "/api/v1/find": {
      "get": {
        "operationId": "findComments",
        "summary": "Find comments for a URL",
        "tags": [
          "Public"
        ],
        "security": [],
        "parameters": [
          {
            "name": "site",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "-time",
                "+time",
                "-score",
                "+score",
                "-controversy"
              ]
            }
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "plain",
                "tree"
              ],
              "default": "tree"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommentListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Find comments for a URL"
      }
    },
