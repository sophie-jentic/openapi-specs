  "components": {
    "securitySchemes": {
      "CookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "JWT"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          },
          "details": {
            "type": "string"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "pid": {
            "type": "string",
            "description": "Parent comment ID"
          },
          "text": {
            "type": "string"
          },
          "orig": {
            "type": "string",
            "description": "Original text"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          },
          "locator": {
            "$ref": "#/components/schemas/Locator"
          },
          "score": {
            "type": "integer"
          },
          "vote": {
            "type": "integer"
          },
          "controversy": {
            "type": "number"
          },
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "edit": {
            "type": "object",
            "properties": {
              "time": {
                "type": "string",
                "format": "date-time"
              },
              "summary": {
                "type": "string"
              }
            }
          },
          "pin": {
            "type": "boolean"
          },
          "delete": {
            "type": "boolean"
          }
        }
      },
      "CommentInput": {
        "type": "object",
        "required": [
          "text",
          "locator"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "pid": {
            "type": "string"
          },
          "locator": {
            "$ref": "#/components/schemas/Locator"
          }
        }
      },
      "Locator": {
        "type": "object",
        "properties": {
          "site": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "picture": {
            "type": "string"
          },
          "admin": {
            "type": "boolean"
          },
          "blocked": {
            "type": "boolean"
          },
          "verified": {
            "type": "boolean"
          },
          "ip": {
            "type": "string"
          }
        }
      },
      "SiteConfig": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string"
          },
          "edit_duration": {
            "type": "integer"
          },
          "max_comment_size": {
            "type": "integer"
          },
          "admins": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "admin_email": {
            "type": "string"
          },
          "low_score": {
            "type": "integer"
          },
          "critical_score": {
            "type": "integer"
          },
          "positive_score": {
            "type": "boolean"
          },
          "readonly_age": {
            "type": "integer"
          },
          "max_image_size": {
            "type": "integer"
          },
          "emoji_enabled": {
            "type": "boolean"
          }
        }
      },
      "CommentListResponse": {
        "type": "object",
        "properties": {
          "comments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Comment"
            }
          },
          "count": {
            "type": "integer"
          }
        }
      },
      "CommentArrayResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Comment"
        }
      },
      "CountResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "CountsResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "count": {
              "type": "integer"
            },
            "url": {
              "type": "string"
            }
          }
        }
      },
      "PreviewResponse": {
        "type": "object",
        "properties": {
          "html": {
            "type": "string"
          }
        }
      }
    }
  }
