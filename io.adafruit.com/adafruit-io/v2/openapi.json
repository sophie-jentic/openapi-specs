  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-AIO-Key",
        "description": "Adafruit IO API Key. Also accepted as query param x-aio-key."
      }
    },
    "schemas": {
      "Feed": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "unit_type": {
            "type": "string"
          },
          "unit_symbol": {
            "type": "string"
          },
          "history": {
            "type": "boolean"
          },
          "visibility": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "last_value": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateFeedRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "unit_type": {
            "type": "string"
          },
          "unit_symbol": {
            "type": "string"
          },
          "history": {
            "type": "boolean"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "private"
            ]
          }
        }
      },
      "DataPoint": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "feed_id": {
            "type": "integer"
          },
          "feed_key": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lon": {
            "type": "number"
          },
          "ele": {
            "type": "number"
          },
          "created_epoch": {
            "type": "number"
          },
          "expiration": {
            "type": "string"
          }
        }
      },
      "CreateDataRequest": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lon": {
            "type": "number"
          },
          "ele": {
            "type": "number"
          },
          "created_at": {
            "type": "string"
          }
        }
      },
      "BatchCreateDataRequest": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateDataRequest"
            }
          }
        }
      },
      "ChartResponse": {
        "type": "object",
        "properties": {
          "feed": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "key": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "parameters": {
            "type": "object",
            "description": "Parameters used for chart generation"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "data": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "feeds": {
