            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get all data for the given feed"
      },
      "post": {
        "operationId": "createFeedData",
        "tags": [
          "Data"
        ],
        "summary": "Create new Data",
        "parameters": [
