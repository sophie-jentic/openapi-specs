{
  "openapi": "3.0.3",
  "info": {
    "title": "Adafruit IO API",
    "version": "2.0.0",
    "description": "The Adafruit IO HTTP API provides access to IoT data streams (feeds), dashboards, groups, and more. All data modification actions count against your rate limit (30 per minute for free, 60 for IO+).",
    "x-jentic-source-url": "https://io.adafruit.com/api/docs/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://io.adafruit.com/api/v2",
      "description": "Adafruit IO API v2"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
