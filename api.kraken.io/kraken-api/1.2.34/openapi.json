                      "wait": true,
                      "resize": [
                        {
                          "id": "thumbnail",
                          "width": 150,
                          "height": 150,
                          "strategy": "fit"
                        },
                        {
                          "id": "medium",
                          "width": 600,
                          "height": 400,
                          "strategy": "auto"
                        },
                        {
                          "id": "large",
                          "width": 1200,
                          "height": 800,
                          "strategy": "crop"
                        }
                      ]
                    }
                  }
                },
                "convertExample": {
                  "summary": "Image Format Conversion to WebP",
                  "value": {
                    "file": "<<BINARY_FILE>>",
                    "data": {
                      "auth": {
                        "api_key": "API_KEY",
