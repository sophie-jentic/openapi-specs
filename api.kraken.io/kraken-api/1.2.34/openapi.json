      "Auth": {
        "type": "object",
        "properties": {
          "api_key": {
            "type": "string"
          },
          "api_secret": {
            "type": "string"
          }
        },
        "required": [
          "api_key",
          "api_secret"
        ]
      },
      "Resize": {
        "type": "object",
        "properties": {
          "width": {
            "type": "integer"
          },
