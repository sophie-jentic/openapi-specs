{
  "openapi": "3.1.0",
  "info": {
    "title": "Kraken.io API Documentation",
    "version": "1.2.34",
    "description": "Comprehensive API documentation for Kraken.io including full input support for optimization, conversion, and storage operations via URL and file upload, along with user status retrieval.",
    "contact": {
      "name": "API Support"
    }
  },
  "tags": [
    {
      "name": "URL Operations"
    },
    {
      "name": "File Upload Operations"
    },
    {
      "name": "User Status"
    }
  ],
  "paths": {
    "/v1/url": {
      "post": {
        "tags": [
          "URL Operations"
        ],
        "summary": "URL-based image operations",
        "description": "Handles image optimization, conversion, and storage via URL with comprehensive input support.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlRequest"
              },
              "examples": {
                "defaultExample": {
                  "summary": "Default Image Optimization",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true
                  }
                },
                "resizeExample": {
                  "summary": "Single Resize Adjustment",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true,
                    "resize": {
                      "width": 800,
                      "height": 600,
                      "strategy": "crop"
                    }
                  }
                },
                "multipleResizeExample": {
                  "summary": "Multiple Resize Configurations",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true,
                    "resize": [
                      {
                        "id": "thumbnail",
                        "width": 150,
                        "height": 150,
                        "strategy": "fit"
                      },
                      {
                        "id": "medium",
                        "width": 600,
                        "height": 400,
                        "strategy": "auto"
                      },
                      {
                        "id": "large",
                        "width": 1200,
                        "height": 800,
                        "strategy": "crop"
                      }
                    ]
                  }
                },
                "convertExample": {
                  "summary": "Image Format Conversion to WebP",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true,
                    "convert": {
                      "format": "webp"
                    }
                  }
                },
                "callbackExample": {
                  "summary": "Asynchronous Processing with Callback",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": false,
                    "callback_url": "https://your-server-address.any/callback"
                  }
                },
                "s3StoreExample": {
                  "summary": "Store Optimized Image in Amazon S3",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true,
                    "s3_store": {
                      "key": "YOUR_AWS_ACCESS_KEY",
                      "secret": "YOUR_AWS_SECRET_KEY",
                      "bucket": "your-bucket-name",
                      "region": "us-east-1",
                      "path": "optimized-images/"
                    }
                  }
                },
                "gcsStoreExample": {
                  "summary": "Store Optimized Image in Google Cloud Storage",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true,
                    "gcs_store": {
                      "acl": "private",
                      "bucket": "your-gcs-bucket-name",
                      "path": "optimized-images/",
                      "credentials": "YOUR_GCS_CREDENTIALS"
                    }
                  }
                },
                "rackspaceStoreExample": {
                  "summary": "Store Optimized Image in Rackspace Cloud Files",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true,
                    "cf_store": {
                      "user": "YOUR_RACKSPACE_USERNAME",
                      "key": "YOUR_RACKSPACE_API_KEY",
                      "container": "your-container-name",
                      "region": "DFW",
                      "path": "optimized-images/"
                    }
                  }
                },
                "azureStoreExample": {
                  "summary": "Store Optimized Image in Microsoft Azure Blob Storage",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true,
                    "azure_store": {
                      "account": "your-azure-account",
                      "key": "your-azure-key",
                      "container": "destination-container",
                      "headers": {
                        "Cache-Control": "public, max-age=31536000"
                      }
                    }
                  }
                },
                "softlayerStoreExample": {
                  "summary": "Store Optimized Image in SoftLayer Object Storage",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true,
                    "sl_store": {
                      "user": "YOUR_SOFTLAYER_USERNAME",
                      "key": "YOUR_SOFTLAYER_API_KEY",
                      "container": "your-container-name",
                      "region": "your-container-location"
                    }
                  }
                },
                "lossyOptimizationExample": {
                  "summary": "Lossy Image Optimization",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.png",
                    "wait": true,
                    "lossy": true
                  }
                },
                "losslessOptimizationExample": {
                  "summary": "Lossless Image Optimization",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.png",
                    "wait": true,
                    "lossy": false
                  }
                },
                "autoOrientExample": {
                  "summary": "Auto-Orient Image Adjustment",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-rotated.jpg",
                    "wait": true,
                    "auto_orient": true,
                    "preserve_meta": [
                      "orientation"
                    ]
                  }
                },
                "chromaSubsamplingExample": {
                  "summary": "Chroma Subsampling Optimization",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true,
                    "chroma_subsampling": "4:2:0"
                  }
                },
                "customQualityExample": {
                  "summary": "Custom Image Quality Setting",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true,
                    "quality": 85
                  }
                },
                "sandboxModeExample": {
                  "summary": "Sandbox Mode for Development Testing",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    },
                    "url": "https://assets.kraken.io/assets/images/index-results/01-original.jpg",
                    "wait": true,
                    "dev": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operation completed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationResponse"
                }
              }
            }
          }
        },
        "operationId": "post_v1_url"
      }
    },
    "/v1/upload": {
      "post": {
        "summary": "Upload file + JSON data (with oneOf)",
        "tags": [
          "File Upload Operations"
        ],
        "description": "Endpoint to upload a file and additional JSON data in a single multipart/form-data request.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/FileRequest"
              },
              "examples": {
                "basicExample": {
                  "summary": "Basic Image Optimization",
                  "value": {
                    "file": "<<BINARY_FILE>>",
                    "data": {
                      "auth": {
                        "api_key": "API_KEY",
                        "api_secret": "API_SECRET"
                      },
                      "wait": true
                    }
                  }
                },
                "resizeExample": {
                  "summary": "Single Resize Adjustment",
                  "value": {
                    "file": "<<BINARY_FILE>>",
                    "data": {
                      "auth": {
                        "api_key": "API_KEY",
                        "api_secret": "API_SECRET"
                      },
                      "resize": {
                        "width": 800,
                        "height": 600,
                        "strategy": "crop"
                      },
                      "wait": true
                    }
                  }
                },
                "multipleResizeExample": {
                  "summary": "Multiple Resize Configurations",
                  "value": {
                    "file": "<<BINARY_FILE>>",
