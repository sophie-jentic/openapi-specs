                      "wait": true,
                      "dev": true
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload processed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          }
        },
        "operationId": "post_v1_upload"
      }
    },
    "/user_status": {
      "post": {
        "tags": [
          "User Status"
        ],
        "summary": "Retrieve user status",
        "description": "Fetches the current user status, including plan information and quota details.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserStatusResponse"
              },
              "examples": {
                "defaultExample": {
                  "summary": "Default user status request",
                  "value": {
                    "auth": {
                      "api_key": "API_KEY",
                      "api_secret": "API_SECRET"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User status successfully retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserStatusResponse"
                }
              }
            }
          }
        },
        "operationId": "post_user_status"
      }
    }
  },
  "components": {
    "schemas": {
      "UrlRequest": {
        "type": "object",
        "required": [
          "auth",
          "url"
        ],
        "properties": {
          "auth": {
            "$ref": "#/components/schemas/Auth"
          },
          "url": {
            "type": "string",
            "description": "Image URL."
          },
          "wait": {
            "type": "boolean",
            "default": true
          },
          "dev": {
            "type": "boolean",
            "default": false,
            "description": "Enable sandbox mode for development testing (returns randomized results)"
          },
          "resize": {
            "$ref": "#/components/schemas/Resize"
          },
          "convert": {
            "$ref": "#/components/schemas/Convert"
          },
          "quality": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Custom quality level for JPG, PNG, and GIF (1-100)"
          },
          "callback_url": {
            "type": "string",
            "nullable": true,
            "default": null,
            "description": "URL for asynchronous callback notification"
          },
          "s3_store": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string"
              },
              "secret": {
                "type": "string"
              },
              "bucket": {
                "type": "string"
              },
              "region": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "description": "Store optimized image in Amazon S3"
          },
          "gcs_store": {
            "type": "object",
            "properties": {
              "acl": {
                "type": "string"
              },
              "bucket": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "credentials": {
                "type": "string"
              }
            },
            "description": "Store optimized image in Google Cloud Storage"
          },
          "cf_store": {
            "type": "object",
            "properties": {
              "username": {
                "type": "string"
              },
              "api_key": {
                "type": "string"
              },
              "container": {
                "type": "string"
              },
              "region": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "description": "Store optimized image in Rackspace Cloud Files"
          },
          "azure_store": {
            "type": "object",
            "properties": {
              "account": {
                "type": "string"
              },
              "key": {
                "type": "string"
              },
              "container": {
                "type": "string"
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "description": "Store optimized image in Microsoft Azure Blob Storage"
          },
          "sl_store": {
            "type": "object",
            "properties": {
              "user": {
                "type": "string"
              },
              "key": {
                "type": "string"
              },
              "container": {
                "type": "string"
              },
              "region": {
                "type": "string"
              }
            },
            "description": "Store optimized image in SoftLayer Object Storage"
          },
          "lossy": {
            "type": "boolean",
            "default": false,
            "description": "Enable lossy compression for better optimization (defaults to false for lossless)"
          },
          "preserve_meta": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "profile",
                "date",
                "copyright",
                "geotag",
                "orientation"
              ]
            },
            "description": "Preserve specific metadata (EXIF, XMP, IPTC, etc.) in the optimized image"
          },
          "auto_orient": {
            "type": "boolean",
            "default": false,
            "description": "Automatically orient the image based on EXIF orientation data"
          },
          "chroma_subsampling": {
            "type": "string",
            "enum": [
              "4:2:0",
              "4:2:2",
              "4:4:4"
            ],
            "description": "Specify chroma subsampling for JPEG images"
          }
        }
      },
      "FileRequest": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "The file to be uploaded."
          },
          "data": {
            "description": "JSON object for additional parameters (auth, wait, resize, convert, etc.)",
            "anyOf": [
              {
                "$ref": "#/components/schemas/DataBasic"
              },
              {
                "$ref": "#/components/schemas/DataResize"
              },
              {
                "$ref": "#/components/schemas/DataConvert"
              }
            ]
          }
        },
        "required": [
          "file",
          "data"
        ]
      },
      "DataBasic": {
        "type": "object",
        "properties": {
          "auth": {
            "$ref": "#/components/schemas/Auth"
          },
          "wait": {
            "type": "boolean",
            "default": true
          }
        },
        "examples": {
          "basicExample": {
            "summary": "Basic Image Optimization",
            "value": {
              "file": "<<BINARY_FILE>>",
              "data": {
                "auth": {
                  "api_key": "API_KEY",
                  "api_secret": "API_SECRET"
                },
                "wait": true
              }
            }
          },
          "resizeExample": {
            "summary": "Single Resize Adjustment",
            "value": {
              "file": "<<BINARY_FILE>>",
              "data": {
                "auth": {
                  "api_key": "API_KEY",
                  "api_secret": "API_SECRET"
                },
                "resize": {
                  "width": 800,
                  "height": 600,
                  "strategy": "crop"
                }
              }
            }
          },
          "multipleResizeExample": {
            "summary": "Multiple Resize Configurations",
            "value": {
              "file": "<<BINARY_FILE>>",
              "data": {
                "auth": {
                  "api_key": "API_KEY",
                  "api_secret": "API_SECRET"
                },
                "wait": true,
                "resize": [
                  {
                    "id": "thumbnail",
                    "width": 150,
                    "height": 150,
