{
  "openapi": "3.0.0",
  "info": {
    "title": "AlgaCalendar",
    "version": "1.0",
    "description": "REST API AlgaCalendar.",
    "contact": {
      "email": "contato@algaworks.com",
      "name": "AlgaWorks",
      "url": "https://www.algaworks.com"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/AlgaWorks/AlgaCalendar/1.0/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/AlgaWorks/AlgaCalendar/1.0"
    },
    {
      "description": "Ambiente de produ\u00e7\u00e3o",
      "url": "https://algacalendar-3aftpocd4a-uc.a.run.app"
    },
    {
      "description": "Ambiente local de desenvolvimento",
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/api-key": {
      "post": {
        "operationId": "createApiKey",
        "summary": "Gera token de acesso",
        "tags": [
          "Token"
        ],
        "security": [],
        "responses": {
          "201": {
            "description": "Token de acesso criado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Token"
                }
              }
            }
          }
        },
        "description": "Gera token de acesso"
      }
    },
    "/reminders/{reminderId}": {
      "parameters": [
        {
          "schema": {
            "type": "integer",
            "format": "int64"
          },
          "name": "reminderId",
          "in": "path",
          "required": true
        }
      ],
      "get": {
        "operationId": "getReminderById",
        "summary": "Busca um lembrete por ID",
        "tags": [
          "Reminders"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reminder"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "description": "Busca um lembrete por ID"
      },
      "put": {
        "operationId": "updateReminder",
        "summary": "Atualiza um lembrete",
        "tags": [
          "Reminders"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReminderInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lembrete atualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reminder"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "description": "Atualiza um lembrete"
      },
      "delete": {
        "operationId": "removeReminder",
        "summary": "Remove um lembrete",
        "tags": [
          "Reminders"
        ],
        "responses": {
          "204": {
            "description": "Lembrete removido"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "description": "Remove um lembrete"
      }
    },
    "/reminders": {
      "get": {
        "operationId": "getReminders",
        "summary": "Consulta os lembretes",
        "tags": [
          "Reminders"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "2022-01"
            },
            "name": "yearMonth",
            "description": "Ano-M\u00eas",
            "in": "query",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Reminder"
                  }
                }
              }
            }
          }
        },
        "description": "Consulta os lembretes"
      },
      "post": {
        "operationId": "createReminder",
        "summary": "Cria um novo lembrete",
        "tags": [
          "Reminders"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReminderInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Lembrete criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reminder"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        },
        "description": "Cria um novo lembrete"
      }
    }
  },
  "security": [
    {
      "ApiKey": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "name": "X-Authorization",
        "in": "header",
        "description": "Token de autentica\u00e7\u00e3o."
      }
    },
    "responses": {
      "NotFound": {
        "description": "Recurso n\u00e3o encontrado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "BadRequest": {
        "description": "Requisi\u00e7\u00e3o inv\u00e1lida",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      }
    },
    "schemas": {
      "Reminder": {
        "description": "Lembrete.",
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "date"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 29
          },
          "title": {
            "type": "string",
            "example": "Reuni\u00e3o semanal com o Thiago."
          },
          "description": {
            "type": "string",
            "example": "Reuni\u00e3o semanal com o Thiago para entender sobre o projeto."
          },
          "date": {
            "type": "string",
            "format": "date",
            "example": "2022-01-01"
          }
        }
      },
      "ReminderInput": {
        "description": "Lembrete.",
        "type": "object",
        "required": [
          "title",
          "description",
          "date"
        ],
        "properties": {
          "title": {
            "type": "string",
            "example": "Reuni\u00e3o semanal com o Thiago."
          },
          "description": {
            "type": "string",
            "example": "Reuni\u00e3o semanal com o Thiago para entender sobre o projeto."
          },
          "date": {
            "type": "string",
            "format": "date",
            "example": "2022-01-01"
          }
        }
      },
      "Token": {
        "description": "Token de acesso.",
        "type": "object",
        "required": [
          "apiKey"
        ],
        "properties": {
          "apiKey": {
            "type": "string",
            "example": "5750bc15-e6c2-4d76-8b5b-07d62f1a76f1"
          }
        }
      },
      "ProblemObject": {
        "type": "object",
        "required": [
          "type",
          "userMessage"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "amount"
          },
          "userMessage": {
            "type": "string",
            "example": "O valor \u00e9 obrigat\u00f3rio"
          }
        },
        "title": "ProblemObject"
      },
      "Problem": {
        "title": "Problem",
        "type": "object",
        "required": [
          "status",
          "timestamp",
          "type",
          "title",
          "detail"
        ],
        "description": "Representa um problema na comunica\u00e7\u00e3o com a API. Este modelo de representa\u00e7\u00e3o \u00e9 baseado na RFC 7807 (Problem Details for HTTP APIs)",
        "properties": {
          "status": {
            "type": "integer",
            "format": "int32",
            "example": 400
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2022-11-01T18:09:02Z"
          },
          "type": {
            "type": "string",
            "example": "https://algaworks.com/dados-invalidos"
          },
          "title": {
            "type": "string",
            "example": "Dados inv\u00e1lidos"
          },
          "detail": {
            "type": "string",
            "example": "Um ou mais campos est\u00e3o inv\u00e1lidos. Fa\u00e7a o preenchimento correto e tente novamente."
          },
          "objects": {
            "type": "array",
            "description": "Lista de objetos ou campos que geraram o erro (opcional)",
            "items": {
              "$ref": "#/components/schemas/ProblemObject"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Reminders",
      "description": "Lembretes"
    },
    {
      "name": "Token",
      "description": "Token"
    }
  ]
}
