{
  "openapi": "3.0.3",
  "info": {
    "title": "Orshot API",
    "version": "1.0.0",
    "description": "Orshot is an image generation API that allows you to design templates in Orshot Studio or import from Canva/Figma, then generate renders via REST API.",
