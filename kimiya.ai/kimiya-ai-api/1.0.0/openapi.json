    "/api/auth/login": {
      "get": {
        "operationId": "validateApiKey",
        "summary": "Validate API key",
        "tags": [
          "Auth"
        ],
        "responses": {
          "200": {
            "description": "API key valid"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Validate API key"
      }
    },
