        "operationId": "sendChatRequest",
        "summary": "Send chat request to Kimiya AI",
        "tags": [
          "Chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
