          }
        },
        "required": [
          "api_key",
          "api_key_secret"
        ]
      },
      "UserCreateInput": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "locked": {
            "type": "boolean"
          },
          "disabled": {
            "type": "boolean"
          },
