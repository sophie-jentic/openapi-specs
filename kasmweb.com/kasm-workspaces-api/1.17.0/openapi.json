{
  "openapi": "3.0.3",
  "info": {
    "title": "Kasm Workspaces Developer API",
    "version": "1.17.0",
    "description": "Kasm Workspaces Developer API for managing sessions, users, groups, images, and system configuration. All endpoints accept JSON with api_key and api_key_secret for authentication. All endpoints use POST method.",
    "x-jentic-source-url": "https://kasm.com/docs/latest/developers/developer_api.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{kasm_server}",
      "variables": {
        "kasm_server": {
          "default": "kasm.example.com",
          "description": "Kasm Workspaces server hostname"
        }
      }
    }
  ],
  "paths": {
    "/api/public/create_user": {
      "post": {
        "operationId": "createUser",
        "summary": "Create a new user",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/AuthRequest"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "target_user": {
                        "$ref": "#/components/schemas/UserCreateInput"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create a new user"
      }
    },
