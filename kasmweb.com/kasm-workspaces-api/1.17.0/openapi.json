    "/api/public/request_kasm": {
      "post": {
        "operationId": "requestKasm",
        "summary": "Request a new Kasm session",
        "tags": [
          "Sessions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/AuthRequest"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "user_id": {
                        "type": "string",
                        "description": "User ID to create session for. If omitted, anonymous user is created."
                      },
                      "image_id": {
                        "type": "string",
                        "description": "Workspace image ID"
                      },
                      "enable_sharing": {
                        "type": "boolean",
                        "description": "Enable session sharing"
                      },
                      "kasm_url": {
                        "type": "string",
                        "description": "URL to navigate browser-based sessions to"
                      },
                      "environment": {
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        },
                        "description": "Environment variables to inject"
                      },
                      "connection_info": {
                        "type": "object",
                        "description": "Custom RDP/VNC/SSH connection settings"
                      },
                      "client_language": {
                        "type": "string"
                      },
                      "client_timezone": {
                        "type": "string"
                      },
                      "egress_gateway_id": {
                        "type": "string"
                      },
                      "persistent_profile_mode": {
                        "type": "string",
                        "enum": [
                          "Enabled",
                          "Disabled",
                          "Reset"
                        ]
                      },
                      "rdp_client_type": {
                        "type": "string",
                        "enum": [
                          "GUAC",
                          "RDP_CLIENT"
                        ]
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KasmSession"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Request a new Kasm session"
      }
    },
