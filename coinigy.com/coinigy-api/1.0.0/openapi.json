    "/orderTypes": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Get Order Types",
        "description": "Returns available order types.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-ordertypes"
      }
    },
    "/refreshBalance": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Refresh Balance",
        "description": "Refresh balances for a linked exchange account.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "auth_id"
                ],
                "properties": {
                  "auth_id": {
                    "type": "integer",
                    "description": "Exchange account auth ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-refreshbalance"
      }
    },
    "/addAlert": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Add Alert",
        "description": "Create a new price alert.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "exch_code",
                  "market_name",
                  "alert_price"
                ],
                "properties": {
                  "exch_code": {
                    "type": "string",
                    "description": "Exchange code"
                  },
                  "market_name": {
                    "type": "string",
                    "description": "Market pair, e.g. BTC/USD"
                  },
                  "alert_price": {
                    "type": "number",
                    "description": "Alert trigger price"
                  },
                  "alert_note": {
                    "type": "string",
                    "description": "Optional alert message"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          }
        },
        "operationId": "post-addalert"
      }
    },
    "/deleteAlert": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Delete Alert",
        "description": "Delete an existing price alert.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "alert_id"
                ],
                "properties": {
                  "alert_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          }
        },
        "operationId": "post-deletealert"
      }
    },
    "/addApiKey": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Add API Key",
        "description": "Link a new exchange account via API key.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "api_secret",
                  "api_exch_id",
                  "api_nickname"
                ],
                "properties": {
                  "api_key": {
                    "type": "string"
                  },
                  "api_secret": {
                    "type": "string"
                  },
                  "api_exch_id": {
                    "type": "integer",
                    "description": "Exchange ID"
                  },
                  "api_nickname": {
                    "type": "string",
                    "description": "Friendly name for the account"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          }
        },
        "operationId": "post-addapikey"
      }
    },
    "/deleteApiKey": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Delete API Key",
        "description": "Remove a linked exchange account.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "auth_id"
                ],
                "properties": {
                  "auth_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          }
        },
        "operationId": "post-deleteapikey"
      }
    },
    "/activateApiKey": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Activate API Key",
        "description": "Activate or deactivate a linked exchange account.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "auth_id",
                  "auth_active"
                ],
                "properties": {
                  "auth_id": {
                    "type": "integer"
                  },
                  "auth_active": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          }
        },
        "operationId": "post-activateapikey"
      }
    },
    "/activateTradingKey": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Activate Trading",
        "description": "Enable or disable trading for a linked exchange account.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "auth_id",
                  "auth_trade"
                ],
                "properties": {
                  "auth_id": {
                    "type": "integer"
                  },
                  "auth_trade": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          }
        },
        "operationId": "post-activatetradingkey"
      }
    },
    "/addOrder": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Place Order",
        "description": "Place an order on a linked exchange.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "auth_id",
                  "exch_id",
                  "mkt_id",
                  "order_type_id",
                  "price_type_id",
                  "limit_price",
                  "order_quantity"
                ],
                "properties": {
                  "auth_id": {
                    "type": "integer",
                    "description": "Exchange account auth ID"
                  },
                  "exch_id": {
                    "type": "integer",
                    "description": "Exchange ID"
                  },
                  "mkt_id": {
                    "type": "integer",
                    "description": "Market ID"
                  },
                  "order_type_id": {
                    "type": "integer",
                    "description": "Order type (1=Buy, 2=Sell)"
                  },
                  "price_type_id": {
                    "type": "integer",
                    "description": "Price type ID"
                  },
                  "limit_price": {
                    "type": "number",
                    "description": "Limit price"
                  },
                  "order_quantity": {
                    "type": "number",
                    "description": "Order quantity"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          }
        },
        "operationId": "post-addorder"
      }
    },
    "/cancelOrder": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Cancel Order",
        "description": "Cancel an open order on a linked exchange.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "internal_order_id"
                ],
                "properties": {
                  "internal_order_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          }
        },
        "operationId": "post-cancelorder"
      }
    },
    "/exchanges": {
      "post": {
        "tags": [
          "Market Data"
        ],
        "summary": "Get Exchanges",
        "description": "Returns list of supported exchanges.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-exchanges"
      }
    },
    "/markets": {
      "post": {
        "tags": [
          "Market Data"
        ],
        "summary": "Get Markets",
        "description": "Returns list of markets for a given exchange.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "exchange_code"
                ],
                "properties": {
                  "exchange_code": {
                    "type": "string",
                    "description": "Exchange code, e.g. GDAX"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-markets"
      }
    },
    "/data": {
      "post": {
        "tags": [
          "Market Data"
        ],
        "summary": "Get Market Data",
        "description": "Returns market data including trade history, order book (asks/bids), or all data combined.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "exchange_code",
                  "exchange_market",
                  "type"
                ],
                "properties": {
                  "exchange_code": {
                    "type": "string",
                    "description": "Exchange code, e.g. GDAX"
                  },
                  "exchange_market": {
                    "type": "string",
                    "description": "Market pair, e.g. BTC/USD"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "history",
                      "asks",
                      "bids",
                      "orders",
                      "all"
                    ],
                    "description": "Type of data to return"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-data"
      }
    },
    "/ticker": {
      "post": {
        "tags": [
          "Market Data"
        ],
        "summary": "Get Ticker",
        "description": "Returns current ticker data for a market.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "exchange_code",
                  "exchange_market"
                ],
                "properties": {
                  "exchange_code": {
                    "type": "string"
                  },
                  "exchange_market": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-ticker"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "Coinigy API key"
      },
      "apiSecret": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-SECRET",
        "description": "Coinigy API secret"
      }
    },
    "schemas": {
      "DataResponse": {
        "type": "object",
        "properties": {
          "data": {
            "description": "Response data (array or object depending on endpoint"
          },
          "notifications": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Notification"
            }
          }
        }
      },
      "NotificationResponse": {
        "type": "object",
        "properties": {
          "data": {},
          "notifications": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Notification"
            }
          }
