{
  "openapi": "3.0.3",
  "info": {
    "title": "Coinigy API",
    "description": "Coinigy's REST API allows you to interact with your Coinigy account and exchange accounts directly, to refresh balances, place and cancel orders, set and cancel alerts, and poll for market data.",
    "version": "1.0.0",
    "contact": {
      "name": "Coinigy Inc",
      "url": "https://coinigy.docs.apiary.io"
    }
  },
  "servers": [
    {
      "url": "https://api.coinigy.com/api/v1",
      "description": "Production API"
    }
  ],
  "security": [
    {
      "apiKey": [],
      "apiSecret": []
    }
  ],
  "paths": {
    "/userInfo": {
      "post": {
        "tags": [
          "Account Data"
        ],
        "summary": "Get User Info",
        "description": "Returns user account information including email, login status, chat settings, and ticker preferences.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-userinfo"
      }
    },
    "/activity": {
      "post": {
        "tags": [
          "Account Data"
        ],
        "summary": "Get Activity Log",
        "description": "Returns account activity log including logins and other events.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-activity"
      }
    },
    "/pushNotifications": {
      "get": {
        "tags": [
          "Account Data"
        ],
        "summary": "Get Push Notifications",
        "description": "Returns push notification settings.",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "operationId": "get-pushnotifications"
      }
    },
    "/accounts": {
      "post": {
        "tags": [
          "Account Data"
        ],
        "summary": "Get Accounts",
        "description": "Returns list of linked exchange accounts.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-accounts"
      }
    },
    "/balances": {
      "post": {
        "tags": [
          "Account Data"
        ],
        "summary": "Get Balances",
        "description": "Returns account balances across all linked exchanges.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "show_nils": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Show zero balances"
                  },
                  "auth_ids": {
                    "type": "string",
                    "description": "Comma-separated auth IDs to filter"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-balances"
      }
    },
    "/balanceHistory": {
      "post": {
        "tags": [
          "Account Data"
        ],
        "summary": "Get Balance History",
        "description": "Returns balance history for a specific date.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "date": {
                    "type": "string",
                    "format": "date",
                    "description": "Date in YYYY-MM-DD format"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-balancehistory"
      }
    },
    "/orders": {
      "post": {
        "tags": [
          "Account Data"
        ],
        "summary": "Get Orders",
        "description": "Returns open orders across all linked exchanges.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-orders"
      }
    },
    "/alerts": {
      "post": {
        "tags": [
          "Account Data"
        ],
        "summary": "Get Alerts",
        "description": "Returns open price alerts.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-alerts"
      }
    },
    "/userWatchList": {
      "post": {
        "tags": [
          "Account Data"
        ],
        "summary": "Get Watch List",
        "description": "Returns user's watched markets.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-userwatchlist"
      }
    },
    "/newsFeed": {
      "post": {
        "tags": [
          "Account Data"
        ],
        "summary": "Get News Feed",
        "description": "Returns cryptocurrency news feed.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          }
        },
        "operationId": "post-newsfeed"
      }
    },
    "/updateUser": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Update User",
        "description": "Update user profile information.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "company": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "street1": {
                    "type": "string"
                  },
                  "street2": {
                    "type": "string"
                  },
                  "city": {
                    "type": "string"
                  },
                  "state": {
                    "type": "string"
                  },
                  "zip": {
                    "type": "string"
                  },
                  "country": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          }
        },
        "operationId": "post-updateuser"
      }
    },
    "/savePrefs": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Save Preferences",
        "description": "Update notification preferences.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "alert_email": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  },
                  "alert_sms": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  },
                  "trade_email": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  },
                  "trade_sms": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  },
                  "balance_email": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          }
        },
        "operationId": "post-saveprefs"
      }
    },
    "/updateTickers": {
      "post": {
        "tags": [
          "Account Functions"
        ],
        "summary": "Update Tickers",
        "description": "Update ticker display settings.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "exch_mkt_ids": {
                    "type": "string",
                    "description": "Comma-separated exchange market IDs"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationResponse"
                }
              }
            }
          }
        },
        "operationId": "post-updatetickers"
      }
