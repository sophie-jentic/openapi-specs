{
  "openapi": "3.0.3",
  "info": {
    "title": "Marketstack API",
    "description": "Real-time, intraday, and historical stock market data API. Covers 125,000+ stock tickers from 72+ worldwide exchanges across 50+ countries. Provides end-of-day data, intraday prices, ticker information, exchange listings, dividends, splits, currencies, and timezones.",
    "version": "1.0.0",
    "contact": {
      "name": "Marketstack Support",
      "url": "https://marketstack.com",
      "email": "support@apilayer.com"
    },
    "x-jentic-source-url": "https://marketstack.com/documentation"
  },
  "servers": [
    {
      "url": "https://api.marketstack.com/v1",
      "description": "Production server (HTTPS - paid plans)"
    },
    {
      "url": "http://api.marketstack.com/v1",
      "description": "Production server (HTTP - free plan)"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    {
      "name": "End-of-Day",
      "description": "End-of-day stock price data"
    },
    {
      "name": "Intraday",
      "description": "Intraday stock price data"
    },
    {
      "name": "Tickers",
      "description": "Stock ticker symbols and metadata"
    },
    {
      "name": "Exchanges",
      "description": "Stock exchange listings"
    },
    {
      "name": "Currencies",
      "description": "Supported currencies"
    },
    {
      "name": "Timezones",
      "description": "Supported timezones"
    },
    {
      "name": "Dividends",
      "description": "Dividend data"
    },
    {
      "name": "Splits",
      "description": "Stock split data"
    }
  ],
  "paths": {
    "/eod": {
      "get": {
        "tags": ["End-of-Day"],
        "summary": "End-of-Day Data",
        "description": "Retrieve end-of-day stock price data for one or more symbols. Returns open, high, low, close, volume, and adjusted close values.",
        "operationId": "getEOD",
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "description": "One or more comma-separated stock ticker symbols (e.g., AAPL or AAPL,MSFT)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "exchange",
            "in": "query",
            "description": "Filter by stock exchange MIC code (e.g., XNAS)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order by date",
            "schema": {
              "type": "string",
              "enum": ["DESC", "ASC"],
              "default": "DESC"
            }
          },
          {
            "name": "date_from",
            "in": "query",
            "description": "Filter by start date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date_to",
            "in": "query",
            "description": "Filter by end date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "$ref": "#/components/parameters/limit"
          },
          {
            "$ref": "#/components/parameters/offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with EOD data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EODResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
