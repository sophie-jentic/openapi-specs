        "summary": "wallet_watchAsset",
        "description": "Request MetaMask to track a token.",
        "tags": [
          "MetaMask Specific"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "jsonrpc": {
                    "type": "string",
                    "default": "2.0"
                  },
                  "method": {
                    "type": "string",
                    "enum": [
                      "wallet_watchAsset"
                    ]
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": [
                          "ERC20"
                        ]
                      },
                      "options": {
                        "type": "object",
                        "properties": {
                          "address": {
                            "type": "string"
