  },
  "components": {
    "securitySchemes": {
      "InfuraProjectId": {
        "type": "apiKey",
        "in": "path",
        "name": "projectId",
        "description": "Infura project ID for RPC endpoint access"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "jsonrpc": {
            "type": "string"
          },
          "id": {
            "type": "integer"
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "integer"
              },
              "message": {
                "type": "string"
              },
              "data": {
                "type": "string"
              }
            }
          }
        }
      },
      "JsonRpcRequest": {
        "type": "object",
        "required": [
          "jsonrpc",
          "method",
          "id"
        ],
        "properties": {
          "jsonrpc": {
            "type": "string",
            "default": "2.0"
          },
          "method": {
            "type": "string",
            "description": "RPC method name"
          },
          "params": {
            "type": "array",
            "items": {},
            "description": "Method parameters"
          },
          "id": {
            "type": "integer",
            "default": 1
          }
        }
      },
      "JsonRpcResponse": {
        "type": "object",
        "properties": {
          "jsonrpc": {
            "type": "string"
          },
          "id": {
            "type": "integer"
          },
          "result": {
            "description": "Method-specific result"
          }
        }
      },
      "TransactionParams": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "description": "Sender address"
          },
          "to": {
            "type": "string",
            "description": "Recipient address"
          },
          "gas": {
            "type": "string",
            "description": "Gas limit (hex)"
          },
          "gasPrice": {
            "type": "string",
            "description": "Gas price (hex wei)"
          },
          "maxFeePerGas": {
            "type": "string"
          },
          "maxPriorityFeePerGas": {
            "type": "string"
          },
          "value": {
            "type": "string",
            "description": "Value to send (hex wei)"
          },
          "data": {
            "type": "string",
            "description": "Contract call data"
          },
          "nonce": {
            "type": "string",
            "description": "Transaction nonce (hex)"
          }
        }
      },
      "AddChainParams": {
        "type": "object",
        "required": [
          "chainId",
          "chainName",
          "rpcUrls"
        ],
        "properties": {
          "chainId": {
            "type": "string",
