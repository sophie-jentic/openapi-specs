{
  "openapi": "3.0.3",
  "info": {
    "title": "MetaMask SDK API",
    "version": "1.0.0",
    "description": "MetaMask SDK provides a JSON-RPC interface for dApp integration with MetaMask wallets. This spec models the Ethereum JSON-RPC methods accessible through MetaMask's SDK and Infura provider endpoints. MetaMask is primarily a browser extension/mobile wallet SDK rather than a traditional REST API.",
    "x-jentic-source-url": "https://docs.metamask.io/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://mainnet.infura.io/v3/{projectId}",
      "description": "Ethereum Mainnet via Infura",
      "variables": {
        "projectId": {
          "default": "YOUR_PROJECT_ID",
          "description": "Infura project ID"
        }
      }
    },
    {
      "url": "https://polygon-mainnet.infura.io/v3/{projectId}",
      "description": "Polygon Mainnet via Infura",
      "variables": {
        "projectId": {
          "default": "YOUR_PROJECT_ID"
        }
      }
    },
    {
      "url": "https://sepolia.infura.io/v3/{projectId}",
      "description": "Sepolia Testnet via Infura",
      "variables": {
        "projectId": {
          "default": "YOUR_PROJECT_ID"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Ethereum JSON-RPC",
      "description": "Standard Ethereum JSON-RPC methods"
    },
    {
      "name": "MetaMask Specific",
      "description": "MetaMask-specific RPC methods"
    },
    {
      "name": "Account Management",
      "description": "Account and wallet methods"
    },
    {
      "name": "Transaction",
      "description": "Transaction methods"
    },
    {
      "name": "Chain",
      "description": "Chain/network methods"
    },
    {
      "name": "Signing",
      "description": "Message signing methods"
    }
  ],
  "paths": {
    "/": {
      "post": {
        "operationId": "jsonRpcCall",
        "summary": "JSON-RPC Call",
        "description": "Send a JSON-RPC request. All Ethereum interactions go through this single endpoint with different method names.",
        "tags": [
          "Ethereum JSON-RPC"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JsonRpcRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JSON-RPC response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JsonRpcResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/#eth_accounts": {
      "post": {
        "operationId": "ethAccounts",
        "summary": "eth_accounts",
        "description": "Returns a list of addresses owned by client. In MetaMask, returns the currently selected account.",
        "tags": [
          "Account Management"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "jsonrpc": {
                    "type": "string",
                    "default": "2.0"
                  },
                  "method": {
                    "type": "string",
                    "enum": [
                      "eth_accounts"
                    ]
                  },
                  "params": {
                    "type": "array",
                    "items": {},
                    "default": []
                  },
                  "id": {
                    "type": "integer",
                    "default": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of account addresses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "jsonrpc": {
                      "type": "string"
                    },
                    "id": {
                      "type": "integer"
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "description": "Ethereum address"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/#eth_requestAccounts": {
      "post": {
        "operationId": "ethRequestAccounts",
        "summary": "eth_requestAccounts",
        "description": "Requests user to provide an Ethereum address. Causes MetaMask to pop up and request account access.",
        "tags": [
          "Account Management"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "jsonrpc": {
                    "type": "string",
                    "default": "2.0"
                  },
                  "method": {
                    "type": "string",
                    "enum": [
                      "eth_requestAccounts"
                    ]
                  },
                  "params": {
                    "type": "array",
                    "default": []
                  },
                  "id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of account addresses"
          }
        }
      }
    },
