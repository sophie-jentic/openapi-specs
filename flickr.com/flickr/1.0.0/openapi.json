        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Flickr API key"
      },
      "oauth1": {
        "type": "oauth2",
        "description": "OAuth 1.0a for authenticated API requests",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://www.flickr.com/services/oauth/authorize",
            "tokenUrl": "https://www.flickr.com/services/oauth/access_token",
            "scopes": {
              "read": "Read access to all photos",
              "write": "Write access to create and update photos",
              "delete": "Delete access"
            }
          }
        }
      }
    },
