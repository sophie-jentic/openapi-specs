{
  "openapi": "3.0.3",
  "info": {
    "title": "Mloflo API",
    "description": "Mloflo mortgage lending platform API. Provides webhook endpoints for adding leads and managing milestone status update triggers via Zapier integration.",
    "version": "1.0.0",
    "contact": {
      "name": "Mloflo",
      "url": "https://mloflo.com"
    }
  },
  "servers": [
    {
      "url": "https://mloflo.com/api",
      "description": "Production server"
    }
  ],
  "paths": {
    "/webhooks/zapier/add-lead": {
      "post": {
        "tags": [
          "Leads"
        ],
        "summary": "Add New Lead To Mloflo",
        "description": "Add a new lead to the Mloflo platform. This endpoint inserts a lead record with borrower and co-borrower information.",
        "operationId": "addLead",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddLeadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lead added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddLeadResponse"
                }
              }
            }
          }
        }
      }
    },
    "/webhooks/zapier/milestone-status-subscribe": {
      "post": {
        "tags": [
          "Milestones"
        ],
        "summary": "Subscribe Updated Milestone Trigger",
        "description": "Subscribe to receive notifications when milestone statuses are updated. Used for Zapier trigger integration.",
        "operationId": "subscribeMilestoneStatus",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "hookUrl": {
                    "type": "string",
                    "format": "uri",
                    "description": "The webhook URL to send milestone update notifications to"
                  }
                },
                "required": [
                  "hookUrl"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully subscribed to milestone updates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "api_key": {
                      "type": "string",
                      "description": "API key identifier for the subscription"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/webhooks/zapier/milestone-status-unsubscribe": {
      "delete": {
        "tags": [
          "Milestones"
        ],
        "summary": "Unsubscribe Updated Milestone Trigger",
        "description": "Unsubscribe from milestone status update notifications. Removes the identifier from the collection used to trigger milestone updates.",
        "operationId": "unsubscribeMilestoneStatus",
        "responses": {
          "200": {
            "description": "Successfully unsubscribed from milestone updates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "api_key": {
                      "type": "string",
                      "description": "API key identifier that was removed"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddLeadRequest": {
        "type": "object",
        "properties": {
          "borrowerFirstName": {
            "type": "string",
            "description": "First name of the borrower"
          },
          "borrowerLastName": {
            "type": "string",
            "description": "Last name of the borrower"
          },
          "borrowerEmail": {
            "type": "string",
            "format": "email",
            "description": "Email address of the borrower"
          },
          "borrowerHomePhone": {
            "type": "string",
            "description": "Home phone number of the borrower"
          },
          "borrowerCellPhone": {
            "type": "string",
            "description": "Cell phone number of the borrower"
          },
          "borrowerWorkPhone": {
            "type": "string",
            "description": "Work phone number of the borrower"
          },
          "coBorrowerFirstName": {
            "type": "string",
            "description": "First name of the co-borrower"
          },
          "coBorrowerLastName": {
            "type": "string",
            "description": "Last name of the co-borrower"
          },
          "coBorrowerEmail": {
            "type": "string",
            "format": "email",
            "description": "Email address of the co-borrower"
          },
          "coBorrowerHomePhone": {
            "type": "string",
            "description": "Home phone number of the co-borrower"
          },
          "coBorrowerCellPhone": {
            "type": "string",
            "description": "Cell phone number of the co-borrower"
          },
          "coBorrowerWorkPhone": {
            "type": "string",
            "description": "Work phone number of the co-borrower"
          },
          "loanPurpose": {
            "type": "string",
            "description": "Purpose of the loan"
          },
          "loanAmount": {
            "type": "number",
            "description": "Amount of the loan"
          },
          "propertyAddress": {
            "type": "string",
            "description": "Property address"
          },
          "propertyCity": {
            "type": "string",
            "description": "Property city"
          },
          "propertyState": {
            "type": "string",
            "description": "Property state"
          },
          "propertyZip": {
            "type": "string",
            "description": "Property ZIP code"
          },
          "referralSource": {
            "type": "string",
            "description": "Source of the referral"
          },
          "notes": {
            "type": "string",
            "description": "Additional notes"
          }
        },
        "required": [
          "borrowerFirstName",
          "borrowerLastName",
          "borrowerEmail"
        ]
      },
      "AddLeadResponse": {
        "type": "object",
        "properties": {
          "borrowerFirstName": {
            "type": "string"
          },
          "borrowerLastName": {
            "type": "string"
          },
          "borrowerEmail": {
            "type": "string",
            "format": "email"
          },
          "borrowerHomePhone": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "description": "Unique identifier of the created lead"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Leads"
    },
    {
      "name": "Milestones"
    }
  ]
}
