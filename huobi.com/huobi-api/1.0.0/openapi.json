{
  "openapi": "3.0.3",
  "info": {
    "title": "Huobi Spot API",
    "description": "Huobi Global cryptocurrency exchange REST API for spot trading, market data, account management, margin trading, and wallet operations.",
    "version": "1.0.0",
    "contact": {
      "name": "Huobi",
      "url": "https://www.huobi.com"
    }
  },
  "servers": [
    {
      "url": "https://api.huobi.pro",
      "description": "Huobi Global API"
    },
    {
      "url": "https://api-aws.huobi.pro",
      "description": "Huobi Global API (AWS)"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": [],
      "SignatureAuth": []
    }
  ],
  "paths": {
    "/v2/market-status": {
      "get": {
        "operationId": "getMarketStatus",
        "summary": "Get market status",
        "description": "Returns the current market operational status.",
        "tags": [
          "Market Data"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketStatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/settings/common/symbols": {
      "get": {
        "operationId": "getSymbols",
        "summary": "Get trading symbols",
        "description": "Returns all supported trading symbols and their configuration.",
        "tags": [
          "Reference Data"
        ],
        "security": [],
        "parameters": [
          {
            "name": "ts",
            "in": "query",
            "description": "Incremental timestamp for data updates.",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SymbolsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/settings/common/currencies": {
      "get": {
        "operationId": "getCurrencies",
        "summary": "Get supported currencies",
        "description": "Returns all supported currencies.",
        "tags": [
          "Reference Data"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrenciesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/market/history/kline": {
      "get": {
        "operationId": "getKline",
        "summary": "Get candlestick data",
        "description": "Returns candlestick/kline data for a given symbol.",
        "tags": [
          "Market Data"
        ],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "description": "Trading symbol, e.g. btcusdt.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "period",
            "in": "query",
            "required": true,
            "description": "Candlestick period.",
            "schema": {
              "type": "string",
              "enum": [
                "1min",
                "5min",
                "15min",
                "30min",
                "60min",
                "4hour",
                "1day",
                "1mon",
                "1week",
                "1year"
              ]
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Number of records to return.",
            "schema": {
              "type": "integer",
              "default": 150,
              "minimum": 1,
              "maximum": 2000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KlineResponse"
                }
              }
            }
          }
        }
      }
    },
    "/market/detail/merged": {
      "get": {
        "operationId": "getMergedTicker",
        "summary": "Get merged ticker",
        "description": "Returns the aggregated ticker for a given symbol including best bid/ask.",
        "tags": [
          "Market Data"
        ],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "description": "Trading symbol.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MergedTickerResponse"
                }
              }
            }
          }
        }
      }
    },
    "/market/tickers": {
      "get": {
        "operationId": "getAllTickers",
        "summary": "Get all tickers",
        "description": "Returns tickers for all trading symbols.",
        "tags": [
          "Market Data"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AllTickersResponse"
                }
              }
            }
          }
        }
      }
    },
    "/market/depth": {
      "get": {
        "operationId": "getDepth",
        "summary": "Get market depth",
        "description": "Returns the order book depth for a given symbol.",
        "tags": [
          "Market Data"
        ],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "description": "Trading symbol.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "depth",
            "in": "query",
            "description": "Depth level.",
            "schema": {
              "type": "integer",
              "default": 20,
              "enum": [
                5,
                10,
                20
              ]
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Depth aggregation level.",
            "schema": {
              "type": "string",
              "enum": [
                "step0",
                "step1",
                "step2",
                "step3",
                "step4",
                "step5"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/market/trade": {
      "get": {
        "operationId": "getLastTrade",
        "summary": "Get last trade",
        "description": "Returns the most recent trade for a given symbol.",
        "tags": [
          "Market Data"
        ],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "description": "Trading symbol.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TradeResponse"
                }
              }
            }
          }
        }
      }
    },
    "/market/history/trade": {
      "get": {
        "operationId": "getHistoricalTrades",
        "summary": "Get historical trades",
        "description": "Returns historical trades for a given symbol.",
        "tags": [
          "Market Data"
        ],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "description": "Trading symbol.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Number of records to return.",
            "schema": {
              "type": "integer",
              "default": 1,
              "maximum": 2000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HistoricalTradesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/account/accounts": {
      "get": {
        "operationId": "getAccounts",
        "summary": "Get all accounts",
        "description": "Returns a list of all accounts for the current user.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/account/accounts/{account-id}/balance": {
      "get": {
        "operationId": "getAccountBalance",
        "summary": "Get account balance",
        "description": "Returns the balance details of a specific account.",
        "tags": [
          "Account"
        ],
        "parameters": [
          {
            "name": "account-id",
            "in": "path",
            "required": true,
            "description": "Account ID.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BalanceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/order/orders/place": {
      "post": {
        "operationId": "placeOrder",
        "summary": "Place an order",
        "description": "Places a new trading order.",
        "tags": [
          "Trading"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order placed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlaceOrderResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/order/orders/{order-id}": {
      "get": {
        "operationId": "getOrder",
        "summary": "Get order details",
        "description": "Returns the details of a specific order.",
        "tags": [
          "Trading"
        ],
        "parameters": [
          {
            "name": "order-id",
            "in": "path",
            "required": true,
            "description": "Order ID.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderDetailResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/order/orders/{order-id}/submitcancel": {
      "post": {
        "operationId": "cancelOrder",
        "summary": "Cancel an order",
        "description": "Submits a cancel request for a specific order.",
        "tags": [
          "Trading"
        ],
        "parameters": [
          {
            "name": "order-id",
            "in": "path",
            "required": true,
            "description": "Order ID.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cancel request submitted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CancelOrderResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/order/orders": {
      "get": {
        "operationId": "getOrders",
        "summary": "Query orders",
        "description": "Returns a list of orders matching specified criteria.",
        "tags": [
          "Trading"
        ],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "description": "Trading symbol.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "states",
            "in": "query",
            "required": true,
            "description": "Order states to query, comma-separated.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "types",
            "in": "query",
            "description": "Order types to query, comma-separated.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start-date",
            "in": "query",
            "description": "Start date (yyyy-mm-dd).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end-date",
            "in": "query",
            "description": "End date (yyyy-mm-dd).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Number of records to return.",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 500
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrdersResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/order/orders/batchcancel": {
      "post": {
        "operationId": "batchCancelOrders",
        "summary": "Batch cancel orders",
        "description": "Cancels multiple orders in a single request.",
        "tags": [
          "Trading"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "order-ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of order IDs to cancel",
                    "maxItems": 50
                  }
                },
                "required": [
                  "order-ids"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch cancel submitted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchCancelResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/query/deposit-withdraw": {
      "get": {
        "operationId": "getDepositWithdrawHistory",
        "summary": "Get deposit/withdrawal history",
        "description": "Returns deposit or withdrawal records.",
        "tags": [
          "Wallet"
        ],
        "parameters": [
          {
            "name": "currency",
            "in": "query",
            "description": "Currency name.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "description": "Record type.",
            "schema": {
              "type": "string",
              "enum": [
                "deposit",
                "withdraw"
              ]
            }
          },
          {
            "name": "from",
            "in": "query",
            "description": "Query start ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Number of records to return.",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 500
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepositWithdrawResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MarketStatusResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "marketStatus": {
                "type": "integer",
                "description": "Market status: 1=normal, 2=halted, 3=cancel-only"
              }
            }
          }
        }
      },
      "SymbolsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "symbol": {
                  "type": "string"
                },
                "bc": {
                  "type": "string",
                  "description": "Base currency"
                },
                "qc": {
                  "type": "string",
                  "description": "Quote currency"
                },
                "state": {
                  "type": "string",
                  "description": "Symbol state: online, offline, suspend"
                },
                "sp": {
                  "type": "string",
                  "description": "Symbol partition"
                },
                "pp": {
                  "type": "integer",
                  "description": "Price precision"
                },
                "ap": {
                  "type": "integer",
                  "description": "Amount precision"
                },
                "vp": {
                  "type": "integer",
                  "description": "Value precision"
                }
              }
            }
          }
        }
      },
      "CurrenciesResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "currency": {
                  "type": "string"
                },
                "assetType": {
                  "type": "integer"
                },
                "instStatus": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "KlineResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "ch": {
            "type": "string",
            "description": "Channel name"
          },
          "ts": {
            "type": "integer",
            "format": "int64",
            "description": "Response timestamp"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int64",
                  "description": "Kline ID (Unix timestamp)"
                },
                "open": {
                  "type": "number",
                  "description": "Open price"
                },
                "close": {
                  "type": "number",
                  "description": "Close price"
                },
                "low": {
                  "type": "number",
                  "description": "Low price"
                },
                "high": {
                  "type": "number",
                  "description": "High price"
                },
                "amount": {
                  "type": "number",
                  "description": "Trading volume in base currency"
                },
                "vol": {
                  "type": "number",
                  "description": "Trading volume in quote currency"
                },
                "count": {
                  "type": "integer",
                  "description": "Number of trades"
                }
              }
            }
          }
        }
      },
      "MergedTickerResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "tick": {
            "type": "object",
            "properties": {
              "open": {
                "type": "number"
              },
              "close": {
                "type": "number"
              },
              "low": {
                "type": "number"
              },
              "high": {
                "type": "number"
              },
              "amount": {
                "type": "number"
              },
              "vol": {
                "type": "number"
              },
              "count": {
                "type": "integer"
              },
              "bid": {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "description": "Best bid [price, amount]"
              },
              "ask": {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "description": "Best ask [price, amount]"
              }
            }
          }
        }
      },
      "AllTickersResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "symbol": {
                  "type": "string"
                },
                "open": {
                  "type": "number"
                },
                "close": {
                  "type": "number"
                },
                "low": {
                  "type": "number"
                },
                "high": {
                  "type": "number"
                },
                "amount": {
                  "type": "number"
                },
                "vol": {
                  "type": "number"
                },
                "count": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "DepthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "tick": {
            "type": "object",
            "properties": {
              "bids": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                },
                "description": "Bid orders [price, amount]"
              },
              "asks": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                },
                "description": "Ask orders [price, amount]"
              }
            }
          }
        }
      },
      "TradeResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "tick": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "format": "int64"
              },
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/TradeDetail"
                }
              }
            }
          }
        }
      },
      "HistoricalTradesResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int64"
                },
                "data": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TradeDetail"
                  }
                }
              }
            }
          }
        }
      },
      "TradeDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Trade ID"
          },
          "ts": {
            "type": "integer",
            "format": "int64",
            "description": "Trade timestamp"
          },
          "amount": {
            "type": "number",
            "description": "Trade amount"
          },
          "price": {
            "type": "number",
            "description": "Trade price"
          },
          "direction": {
            "type": "string",
            "enum": [
              "buy",
              "sell"
            ],
            "description": "Trade direction"
          }
        }
      },
      "AccountsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int64",
                  "description": "Account ID"
                },
                "type": {
                  "type": "string",
                  "description": "Account type: spot, margin, otc, point, super-margin"
                },
                "subtype": {
                  "type": "string"
                },
                "state": {
                  "type": "string",
                  "description": "Account state: working, lock"
                }
              }
            }
          }
        }
      },
      "BalanceResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
