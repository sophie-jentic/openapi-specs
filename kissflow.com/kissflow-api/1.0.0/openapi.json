{
  "openapi": "3.0.3",
  "info": {
    "title": "KiSSFLOW REST API",
    "version": "1.0.0",
    "description": "KiSSFLOW REST API allows you to create, update, and manage workflow processes programmatically. The API provides endpoints for process management, request handling, and workflow operations.",
    "contact": {
      "url": "https://help.kissflow.com"
    }
  },
  "servers": [
    {
      "url": "https://{account_id}.appspot.com/api/1",
      "description": "KiSSFLOW API Server",
      "variables": {
        "account_id": {
          "default": "your_account_id",
          "description": "Your KiSSFLOW account identifier"
        }
      }
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/verify": {
      "get": {
        "summary": "Verify API connectivity",
        "description": "Validates that your API key is working and the connection is established",
        "operationId": "verifyConnection",
        "responses": {
          "200": {
            "description": "Connection verified successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          }
        },
        "tags": [
          "verify"
        ]
      }
    },
    "/process": {
      "get": {
        "summary": "List all processes",
        "description": "Retrieves a list of all active processes in your account",
        "operationId": "listProcesses",
        "responses": {
          "200": {
            "description": "List of processes retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "process_name": {
                        "type": "string"
                      },
                      "process_id": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          }
        },
        "tags": [
          "process"
        ]
      }
    },
    "/{process_name}/create": {
      "post": {
        "summary": "Create draft request",
        "description": "Creates a new draft request in the specified process",
        "operationId": "createDraftRequest",
        "parameters": [
          {
            "name": "process_name",
            "in": "path",
            "required": true,
            "description": "The name of the process",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Draft request created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "request_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Authentication failed"
          }
        },
        "tags": [
          "create"
        ]
      }
    },
    "/{process_name}/submit": {
      "post": {
        "summary": "Create and submit request",
        "description": "Creates a new request and immediately submits it to the workflow",
        "operationId": "submitRequest",
        "parameters": [
          {
            "name": "process_name",
            "in": "path",
            "required": true,
            "description": "The name of the process",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Request submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "request_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Authentication failed"
          }
        },
        "tags": [
          "submit"
        ]
      }
    },
    "/{process_name}/{request_id}/update": {
      "put": {
        "summary": "Update request",
        "description": "Modifies an existing request",
        "operationId": "updateRequest",
        "parameters": [
          {
            "name": "process_name",
            "in": "path",
            "required": true,
            "description": "The name of the process",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Request updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Authentication failed"
          },
          "404": {
            "description": "Request not found"
          }
        },
        "tags": [
          "update"
        ]
      }
    },
    "/{process_name}/{request_id}/delete": {
      "delete": {
        "summary": "Delete request",
        "description": "Removes a request from the system",
        "operationId": "deleteRequest",
        "parameters": [
          {
            "name": "process_name",
            "in": "path",
            "required": true,
            "description": "The name of the process",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request deleted successfully"
          },
          "401": {
            "description": "Authentication failed"
          },
          "404": {
            "description": "Request not found"
          }
        },
        "tags": [
          "delete"
        ]
      }
    },
    "/{process_name}/{request_id}/approve": {
      "post": {
        "summary": "Approve request",
        "description": "Approves a pending request in the workflow",
        "operationId": "approveRequest",
        "parameters": [
          {
            "name": "process_name",
            "in": "path",
            "required": true,
            "description": "The name of the process",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request approved successfully"
          },
          "401": {
            "description": "Authentication failed"
          },
          "404": {
            "description": "Request not found"
          }
        },
        "tags": [
          "approve"
        ]
      }
    },
    "/{process_name}/{request_id}/reject": {
      "post": {
        "summary": "Reject request",
        "description": "Rejects a pending request with a comment",
        "operationId": "rejectRequest",
        "parameters": [
          {
            "name": "process_name",
            "in": "path",
            "required": true,
            "description": "The name of the process",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "Comment"
                ],
                "properties": {
                  "Comment": {
                    "type": "string",
                    "description": "Reason for rejection"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Request rejected successfully"
          },
          "400": {
            "description": "Invalid request - Comment is required"
          },
          "401": {
            "description": "Authentication failed"
          },
          "404": {
            "description": "Request not found"
          }
        },
        "tags": [
          "reject"
        ]
      }
    },
    "/{process_name}/{request_id}/done": {
      "post": {
        "summary": "Complete input step",
        "description": "Marks an input step as complete",
        "operationId": "completeStep",
        "parameters": [
          {
            "name": "process_name",
            "in": "path",
            "required": true,
            "description": "The name of the process",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Step completed successfully"
          },
          "401": {
            "description": "Authentication failed"
          },
          "404": {
            "description": "Request not found"
          }
        },
        "tags": [
          "done"
        ]
      }
    },
    "/{process_name}/{request_id}/clarify": {
      "post": {
        "summary": "Seek clarification",
        "description": "Requests clarification on a pending request",
        "operationId": "seekClarification",
        "parameters": [
          {
            "name": "process_name",
            "in": "path",
            "required": true,
            "description": "The name of the process",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "Comment"
                ],
                "properties": {
                  "Comment": {
                    "type": "string",
                    "description": "Clarification request details"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Clarification request sent successfully"
          },
          "400": {
            "description": "Invalid request - Comment is required"
          },
          "401": {
            "description": "Authentication failed"
          },
          "404": {
            "description": "Request not found"
          }
        },
        "tags": [
          "clarify"
        ]
      }
    },
    "/{process_name}/{request_id}/read": {
      "get": {
        "summary": "Get request details",
        "description": "Retrieves detailed information about a specific request",
        "operationId": "getRequest",
        "parameters": [
          {
            "name": "process_name",
            "in": "path",
            "required": true,
            "description": "The name of the process",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "request_id": {
                      "type": "string"
                    },
                    "process_name": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "fields": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "404": {
            "description": "Request not found"
          }
        },
        "tags": [
          "read"
        ]
      }
    },
    "/{process_name}/list/p{page}/{size}": {
      "get": {
        "summary": "List paginated requests",
        "description": "Retrieves a paginated list of requests for a specific process",
        "operationId": "listRequests",
        "parameters": [
          {
            "name": "process_name",
            "in": "path",
            "required": true,
            "description": "The name of the process",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "path",
            "required": true,
            "description": "Page number",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "size",
            "in": "path",
            "required": true,
            "description": "Number of items per page",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of requests retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "requests": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "request_id": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "total": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          }
        },
        "tags": [
          "list"
        ]
      }
    },
    "/{process_name}/{request_id}/progress": {
      "get": {
        "summary": "Get workflow progress",
        "description": "Retrieves the current progress and tracking information for a request",
        "operationId": "getProgress",
        "parameters": [
          {
            "name": "process_name",
            "in": "path",
            "required": true,
            "description": "The name of the process",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Progress information retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "current_step": {
                      "type": "string"
                    },
                    "progress": {
                      "type": "number"
                    },
                    "history": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "404": {
            "description": "Request not found"
          }
        },
        "tags": [
          "progress"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "api_key",
        "description": "API key for authentication. Optionally include 'email_id' header to perform operations on behalf of other users."
      }
    }
  },
  "tags": [
    {
      "name": "approve"
    },
    {
      "name": "clarify"
    },
    {
      "name": "create"
    },
    {
      "name": "delete"
    },
    {
      "name": "done"
    },
    {
      "name": "list"
    },
    {
      "name": "process"
    },
    {
      "name": "progress"
    },
    {
      "name": "read"
    },
    {
      "name": "reject"
    },
    {
      "name": "submit"
    },
    {
      "name": "update"
    },
    {
      "name": "verify"
    }
  ]
}
