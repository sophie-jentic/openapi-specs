{
  "openapi": "3.0.3",
  "info": {
    "title": "Apache Solr API",
    "version": "9.0",
    "description": "Apache Solr is an open-source enterprise search platform. This API covers SolrCloud Collections API, CoreAdmin API, search/query endpoints, document indexing, schema management, and config management.",
    "x-jentic-source-url": "https://solr.apache.org/guide/solr/latest/configuration-guide/collections-api.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://{host}:{port}/solr",
      "variables": {
        "host": {
          "default": "host"
        },
        "port": {
          "default": "port"
        }
      }
    }
  ],
  "paths": {
    "/admin/collections": {
      "get": {
        "operationId": "collectionsAction",
        "summary": "Execute a Collections API action",
        "description": "The Collections API manages SolrCloud collections, shards, replicas, aliases, and cluster properties. Use the 'action' parameter to specify the operation.",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "CREATE",
                "DELETE",
                "RELOAD",
                "MODIFYCOLLECTION",
                "LIST",
                "RENAME",
                "COLSTATUS",
                "BACKUP",
                "RESTORE",
                "REQUESTSTATUS",
                "DELETESTATUS",
                "MIGRATE",
                "REBALANCELEADERS",
                "CLUSTERSTATUS",
                "CLUSTERPROP",
                "OVERSEERSTATUS",
                "ADDROLE",
                "REMOVEROLE"
              ]
            },
            "description": "The collection action to perform"
          },
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Collection name (for CREATE, DELETE, RELOAD, etc.)"
          },
          {
            "name": "numShards",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of shards (CREATE)"
          },
          {
            "name": "replicationFactor",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Replication factor (CREATE)"
          },
          {
            "name": "collection.configName",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Config set name (CREATE)"
          },
          {
            "name": "maxShardsPerNode",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Max shards per node (CREATE)"
          },
          {
            "name": "router.name",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "compositeId",
                "implicit"
              ]
            },
            "description": "Router type (CREATE)"
          },
          {
            "name": "shards",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated shard names (CREATE with implicit router)"
          },
          {
            "name": "async",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Async request ID"
          },
          {
            "name": "requestid",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Request ID for REQUESTSTATUS/DELETESTATUS"
          },
          {
            "name": "flush",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Flush all statuses (DELETESTATUS)"
          },
          {
            "name": "wt",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml"
              ],
              "default": "json"
            },
            "description": "Response format"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SolrResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
