    "/{collection}/select": {
      "get": {
        "operationId": "searchDocuments",
        "summary": "Search/query documents",
        "description": "Execute a search query against a Solr collection. Supports standard query parser, DisMax, eDisMax, and various response writers.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "collection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Main query string"
          },
          {
            "name": "fq",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter query (can be repeated)"
          },
          {
            "name": "fl",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of fields to return"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sort specification (e.g., 'price asc, score desc')"
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset for pagination"
          },
          {
            "name": "rows",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of results to return"
          },
          {
            "name": "wt",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "csv",
                "python",
                "ruby",
                "php"
              ],
              "default": "json"
            },
            "description": "Response writer type"
          },
          {
            "name": "indent",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Indent the response"
          },
          {
            "name": "defType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "lucene",
                "dismax",
                "edismax"
              ]
            },
            "description": "Query parser type"
          },
          {
            "name": "qf",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Query fields with boosts (dismax/edismax)"
          },
          {
            "name": "mm",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Minimum should match (dismax/edismax)"
          },
          {
            "name": "facet",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Enable faceting"
          },
          {
            "name": "facet.field",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Field to facet on"
          },
          {
            "name": "facet.query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Facet query"
          },
          {
            "name": "hl",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Enable highlighting"
          },
          {
            "name": "hl.fl",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Fields to highlight"
          },
          {
            "name": "group",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Enable result grouping"
          },
          {
            "name": "group.field",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Field to group by"
          },
          {
            "name": "stats",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Enable statistics"
          },
          {
            "name": "stats.field",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Field for statistics"
          },
          {
            "name": "debug",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "query",
                "timing",
                "results",
                "all"
              ]
            },
            "description": "Debug mode"
          },
          {
            "name": "cursorMark",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Cursor mark for deep paging"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{collection}/update": {
      "post": {
        "operationId": "indexDocuments",
        "summary": "Index/update documents",
        "description": "Add, update, or delete documents in a collection. Supports JSON, XML, CSV, and Javabin formats.",
        "tags": [
          "Indexing"
        ],
        "parameters": [
          {
            "name": "collection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "commit",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Commit after update"
          },
          {
            "name": "commitWithin",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Auto-commit within N milliseconds"
          },
          {
            "name": "overwrite",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": true
            },
            "description": "Overwrite existing documents"
          },
          {
            "name": "wt",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "json"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "array",
                    "items": {
                      "type": "object"
                    },
                    "description": "Array of documents to add"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "add": {
                        "type": "object",
                        "properties": {
                          "doc": {
                            "type": "object"
                          },
                          "overwrite": {
                            "type": "boolean"
                          },
                          "commitWithin": {
                            "type": "integer"
                          }
                        }
                      },
                      "delete": {
                        "oneOf": [
                          {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              }
                            }
                          },
                          {
                            "type": "object",
                            "properties": {
                              "query": {
                                "type": "string"
                              }
                            }
                          }
                        ]
                      },
                      "commit": {
                        "type": "object"
                      },
                      "optimize": {
                        "type": "object"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SolrResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{collection}/schema": {
      "get": {
        "operationId": "getSchema",
        "summary": "Get the schema for a collection",
        "tags": [
          "Schema"
        ],
        "parameters": [
          {
            "name": "collection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "wt",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "version": {
                          "type": "number"
                        },
                        "uniqueKey": {
                          "type": "string"
                        },
                        "fieldTypes": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        },
                        "fields": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        },
                        "dynamicFields": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        },
                        "copyFields": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get the schema for a collection"
      },
      "post": {
        "operationId": "modifySchema",
        "summary": "Modify the schema",
        "tags": [
          "Schema"
        ],
        "parameters": [
          {
            "name": "collection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "add-field": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "type": {
                        "type": "string"
                      },
                      "stored": {
                        "type": "boolean"
                      },
                      "indexed": {
                        "type": "boolean"
                      },
                      "multiValued": {
                        "type": "boolean"
                      }
                    }
                  },
