          },
          {
            "name": "collections",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated collection names (CREATEALIAS)"
          },
          {
            "name": "wt",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "json"
            }
          }
