{
  "openapi": "3.0.3",
  "info": {
    "title": "Countly Server API",
    "version": "24.0.0",
    "description": "Countly is an open-source analytics platform. The REST API provides endpoints for data ingestion (/i), data reading (/o), and management. Authentication uses API keys passed as query parameters.",
    "x-jentic-source-url": "https://api.count.ly/reference",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://your-countly-server.com",
      "description": "Your Countly server instance"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Data Read",
      "description": "Read analytics data (/o endpoints)"
    },
    {
      "name": "Data Write",
      "description": "Write/ingest data (/i endpoints)"
    },
    {
      "name": "User Management",
      "description": "User and app management"
    },
    {
      "name": "Feedback",
      "description": "Feedback widget management"
    },
    {
      "name": "Dashboards",
      "description": "Dashboard management"
    },
    {
      "name": "Alerts",
      "description": "Alert management"
    },
    {
      "name": "Remote Config",
      "description": "Remote configuration management"
    },
    {
      "name": "System",
      "description": "System utilities"
    },
    {
      "name": "Tasks",
      "description": "Background task management"
    },
    {
      "name": "Groups",
      "description": "User group management"
    }
  ],
  "paths": {
    "/o": {
      "get": {
        "operationId": "readAnalyticsData",
        "summary": "Read analytics data",
        "description": "Main endpoint for reading analytics data. Use the 'method' parameter to specify what data to retrieve (sessions, users, devices, carriers, etc.).",
        "tags": [
          "Data Read"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key of user with permission to access this app"
          },
          {
            "name": "app_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Application ID"
          },
          {
            "name": "method",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "sessions",
                "users",
                "devices",
                "carriers",
                "app_versions",
                "cities",
                "events",
                "get_events",
                "retention",
                "star",
                "notes",
                "remote-config",
                "ab-testing"
              ]
            },
            "description": "Data method to query"
          },
          {
            "name": "period",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Time period: month, 60days, 30days, 7days, yesterday, hour, or [startMs,endMs]"
          },
          {
            "name": "callback",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "JSONP callback function name"
          }
        ],
        "responses": {
          "200": {
            "description": "Analytics data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
