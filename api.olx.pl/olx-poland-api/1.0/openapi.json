                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "regions"
        ],
        "description": "List all regions"
      }
    },
    "/cities": {
      "get": {
        "operationId": "listCities",
        "summary": "List cities",
        "parameters": [
          {
            "name": "region_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of cities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
