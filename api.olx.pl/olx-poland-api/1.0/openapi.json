        "parameters": [
          {
            "name": "categoryId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Category attributes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Attribute"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "categories"
        ]
      }
    },
    "/regions": {
      "get": {
        "operationId": "listRegions",
        "summary": "List all regions",
        "responses": {
          "200": {
            "description": "List of regions",
