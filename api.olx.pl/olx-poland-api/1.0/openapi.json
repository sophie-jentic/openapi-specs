    "/users/me": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current user profile",
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "users"
        ],
        "description": "Get current user profile"
      }
    },
    "/threads": {
      "get": {
        "operationId": "listThreads",
        "summary": "List message threads",
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "advert_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of threads",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Thread"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "threads"
        ],
        "description": "List message threads"
      }
    },
    "/threads/{threadId}/messages": {
      "get": {
        "operationId": "listMessages",
        "summary": "List messages in a thread",
        "parameters": [
          {
            "name": "threadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of messages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Message"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "threads"
        ],
        "description": "List messages in a thread"
      },
      "post": {
        "operationId": "sendMessage",
        "summary": "Send a message in a thread",
        "parameters": [
          {
            "name": "threadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Message sent"
          },
          "400": {
            "description": "Validation error"
          }
        },
        "tags": [
          "threads"
        ],
        "description": "Send a message in a thread"
      }
    },
    "/delivery/settings": {
      "get": {
        "operationId": "getDeliverySettings",
        "summary": "Get delivery settings",
        "description": "Returns categories where delivery is available with minimum/maximum eligible item prices and available shipping methods.",
        "responses": {
          "200": {
            "description": "Delivery settings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "tags": [
          "delivery"
        ]
      }
    },
    "/payments": {
      "get": {
        "operationId": "listPayments",
