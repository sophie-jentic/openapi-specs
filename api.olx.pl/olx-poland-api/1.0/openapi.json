{
  "openapi": "3.0.3",
  "info": {
    "title": "OLX Poland API",
    "description": "OLX Poland API for managing adverts, categories, user accounts, messages, payments, and delivery (Przesyłki OLX). Requires OAuth2 authentication.",
    "version": "1.0",
    "contact": {
      "name": "OLX Developer Portal",
      "url": "https://developer.olx.pl/"
    },
    "license": {
      "name": "Proprietary",
      "url": "https://developer.olx.pl/"
    }
  },
  "externalDocs": {
    "description": "OLX Developer Portal Documentation",
    "url": "https://developer.olx.pl/api/doc"
  },
  "servers": [
    {
      "url": "https://api.olx.pl/v1",
      "description": "OLX Poland Production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/adverts": {
      "get": {
        "operationId": "listAdverts",
        "summary": "List user's adverts",
        "description": "Get a list of adverts for the authenticated user.",
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of adverts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Advert"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "adverts"
        ]
      },
      "post": {
        "operationId": "createAdvert",
        "summary": "Create a new advert",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdvertCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Advert created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Advert"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "adverts"
        ],
        "description": "Create a new advert"
      }
    },
    "/adverts/{advertId}": {
      "get": {
        "operationId": "getAdvert",
        "summary": "Get an advert by ID",
        "parameters": [
          {
            "name": "advertId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Advert details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Advert"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "tags": [
          "adverts"
        ],
        "description": "Get an advert by ID"
      },
      "put": {
        "operationId": "updateAdvert",
        "summary": "Update an advert",
        "parameters": [
          {
            "name": "advertId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdvertCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Advert updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Advert"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "404": {
            "description": "Not found"
          }
        },
        "tags": [
          "adverts"
        ],
        "description": "Update an advert"
      },
      "delete": {
        "operationId": "deleteAdvert",
        "summary": "Delete an advert",
        "parameters": [
          {
            "name": "advertId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Advert deleted"
          },
          "404": {
            "description": "Not found"
          }
        },
        "tags": [
          "adverts"
        ],
        "description": "Delete an advert"
      }
    },
    "/adverts/{advertId}/activate": {
      "post": {
        "operationId": "activateAdvert",
        "summary": "Activate an advert",
        "parameters": [
          {
            "name": "advertId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Advert activated"
          },
          "404": {
            "description": "Not found"
          }
        },
        "tags": [
          "adverts"
        ],
        "description": "Activate an advert"
      }
    },
    "/adverts/{advertId}/deactivate": {
      "post": {
        "operationId": "deactivateAdvert",
        "summary": "Deactivate an advert",
        "parameters": [
          {
            "name": "advertId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Advert deactivated"
          },
          "404": {
            "description": "Not found"
          }
        },
        "tags": [
          "adverts"
        ],
        "description": "Deactivate an advert"
      }
    },
    "/categories": {
      "get": {
        "operationId": "listCategories",
        "summary": "List all categories",
        "responses": {
