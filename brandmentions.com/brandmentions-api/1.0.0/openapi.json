            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "keywords"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "keywords": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "excluded_keywords": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "language": {
                    "type": "string"
                  },
                  "country": {
                    "type": "string"
                  }
