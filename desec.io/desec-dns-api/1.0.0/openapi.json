{
  "openapi": "3.0.3",
  "info": {
    "title": "deSEC DNS API",
    "version": "1.0.0",
    "description": "deSEC is a free, open-source, non-profit DNS hosting service with a focus on security (DNSSEC). The API provides domain management, DNS record (RRset) management, token management, and account operations.",
    "x-jentic-source-url": "https://desec.readthedocs.io/en/latest/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://desec.io/api/v1"
    }
  ],
  "paths": {
    "/domains/": {
      "get": {
        "operationId": "listDomains",
        "summary": "List all domains",
        "description": "Retrieve an overview of all domains you own. Returns up to 500 items per page.",
        "tags": [
          "Domains"
        ],
        "parameters": [
          {
            "name": "owns_qname",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter domain that is responsible for the given DNS query name"
          }
        ],
        "responses": {
          "200": {
            "description": "List of domains",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Domain"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createDomain",
        "summary": "Create a new domain",
        "description": "Create a new domain. Requires perm_create_domain permission on the token.",
        "tags": [
          "Domains"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Domain name (max 191 chars, lowercase)"
                  },
                  "zonefile": {
                    "type": "string",
                    "description": "Optional zonefile content to import"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Domain created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Domain"
                }
              }
            }
          },
          "403": {
            "description": "Maximum domains reached or insufficient permissions"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/domains/{name}/": {
      "get": {
        "operationId": "getDomain",
        "summary": "Retrieve a specific domain",
        "tags": [
          "Domains"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Domain name"
          }
        ],
        "responses": {
          "200": {
            "description": "Domain details including DNSSEC keys",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Domain"
                }
              }
            }
          },
          "404": {
            "description": "Domain not found"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Retrieve a specific domain"
      },
      "delete": {
        "operationId": "deleteDomain",
        "summary": "Delete a domain",
        "description": "Requires perm_delete_domain permission on the token.",
        "tags": [
          "Domains"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Domain deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/domains/{name}/zonefile/": {
      "get": {
        "operationId": "exportZonefile",
        "summary": "Export domain as zonefile",
        "description": "Export domain data in plain-text zonefile format.",
        "tags": [
          "Domains"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Zonefile in plain text",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/domains/{name}/rrsets/": {
      "get": {
        "operationId": "listRRsets",
        "summary": "List all RRsets in a zone",
        "description": "Retrieve all DNS record sets for a domain. Supports filtering by type and subname.",
        "tags": [
          "RRsets"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Domain name"
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by record type (e.g. A, AAAA, MX)"
          },
          {
            "name": "subname",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by subname (empty string for apex)"
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Pagination cursor"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of RRsets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RRset"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createRRset",
        "summary": "Create an RRset",
        "description": "Create a new DNS record set. Can also accept an array for bulk creation.",
        "tags": [
          "RRsets"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/RRsetCreate"
                  },
                  {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/RRsetCreate"
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "RRset(s) created",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/RRset"
                    },
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/RRset"
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "bulkUpdateRRsets",
        "summary": "Bulk create/update RRsets (PUT)",
        "description": "Atomically create or update multiple RRsets. All fields required per RRset.",
        "tags": [
          "RRsets"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/RRsetCreate"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "RRsets updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RRset"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "bulkPatchRRsets",
        "summary": "Bulk patch RRsets (PATCH)",
        "description": "Atomically patch multiple RRsets. Only subname and type required; ttl and records optional.",
        "tags": [
          "RRsets"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/RRsetPatch"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "RRsets patched",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RRset"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/domains/{name}/rrsets/{subname}/{type}/": {
      "get": {
        "operationId": "getRRset",
        "summary": "Retrieve a specific RRset",
        "description": "Get a single RRset by subname and type. Use @ for zone apex.",
        "tags": [
          "RRsets"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "subname",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Subdomain string or @ for zone apex"
          },
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Record type (uppercase)"
          }
        ],
        "responses": {
          "200": {
            "description": "RRset details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RRset"
                }
              }
            }
          },
          "404": {
            "description": "RRset not found"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateRRset",
        "summary": "Update an RRset (full replacement)",
        "tags": [
          "RRsets"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "subname",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RRsetCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "RRset updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RRset"
                }
              }
            }
          },
          "204": {
            "description": "RRset deleted (empty records)"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Update an RRset (full replacement)"
      },
      "patch": {
        "operationId": "patchRRset",
        "summary": "Partially update an RRset",
        "tags": [
          "RRsets"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "subname",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RRsetPatch"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "RRset patched",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RRset"
                }
              }
            }
          },
          "204": {
            "description": "RRset deleted (empty records)"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Partially update an RRset"
      },
      "delete": {
        "operationId": "deleteRRset",
        "summary": "Delete an RRset",
        "tags": [
          "RRsets"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "subname",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "RRset deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete an RRset"
      }
    },
    "/auth/tokens/": {
      "get": {
        "operationId": "listTokens",
        "summary": "List all tokens",
        "description": "Retrieve a list of all known API tokens. Requires perm_manage_tokens.",
        "tags": [
          "Tokens"
        ],
        "responses": {
          "200": {
            "description": "List of tokens",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
