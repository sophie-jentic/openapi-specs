            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "publisherId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with transaction details.",
