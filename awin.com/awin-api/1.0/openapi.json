        "type": "http",
        "scheme": "bearer",
        "description": "Awin API uses OAuth 2.0 Bearer tokens for authentication. Obtain your API token from the Awin interface under Tools > Publisher API / Advertiser API. Pass the token in the Authorization header as: Bearer {your_token}"
      }
    },
    "parameters": {
      "publisherId": {
        "name": "publisherId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the publisher account.",
        "schema": {
          "type": "integer"
        }
      },
      "advertiserId": {
        "name": "advertiserId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the advertiser account.",
        "schema": {
          "type": "integer"
        }
      },
      "rowLimit": {
        "name": "rowLimit",
        "in": "query",
        "required": false,
        "description": "Maximum number of rows to return per page.",
        "schema": {
          "type": "integer",
          "default": 100,
          "maximum": 1000
        }
      },
      "pageNumber": {
        "name": "pageNumber",
        "in": "query",
        "required": false,
        "description": "Page number for paginated results (1-indexed).",
        "schema": {
          "type": "integer",
          "default": 1,
          "minimum": 1
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Authentication required. Provide a valid Bearer token.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Access denied. The token does not have permission for this resource.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Rate limit exceeded. The API enforces request rate limits per account.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error code."
          },
          "description": {
            "type": "string",
            "description": "Human-readable error description."
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique transaction identifier."
          },
          "advertiserId": {
            "type": "integer",
            "description": "The advertiser's account ID."
          },
          "publisherId": {
            "type": "integer",
            "description": "The publisher's account ID."
          },
          "commissionSharingPublisherId": {
            "type": "integer",
            "description": "Publisher ID for commission sharing, if applicable."
          },
          "commissionSharingSelectedRatePublisherId": {
            "type": "integer",
            "description": "Publisher ID whose commission rate was selected."
          },
          "siteName": {
            "type": "string",
            "description": "Name of the publisher site."
          },
          "url": {
            "type": "string",
            "description": "The referring URL for the transaction."
          },
          "commissionStatus": {
            "type": "string",
            "enum": [
              "pending",
              "approved",
              "declined",
              "deleted"
            ],
            "description": "Current status of the commission."
          },
          "commissionAmount": {
            "$ref": "#/components/schemas/MonetaryAmount"
          },
          "saleAmount": {
            "$ref": "#/components/schemas/MonetaryAmount"
          },
          "ipHash": {
            "type": "string",
            "description": "Hashed IP address of the customer."
          },
          "customerCountry": {
            "type": "string",
            "description": "Country of the customer."
          },
          "clickDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time of the click."
          },
          "transactionDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time of the transaction."
          },
          "validationDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time of transaction validation."
          },
          "type": {
            "type": "string",
            "description": "Transaction type (e.g., sale, lead)."
          },
          "declineReason": {
            "type": "string",
            "description": "Reason for decline, if applicable."
          },
          "voucherCodeUsed": {
            "type": "boolean",
            "description": "Whether a voucher code was used."
          },
          "voucherCode": {
            "type": "string",
            "description": "The voucher code used, if any."
          },
          "lapseTime": {
            "type": "integer",
            "description": "Time in seconds between click and transaction."
          },
          "amended": {
            "type": "boolean",
            "description": "Whether the transaction has been amended."
          },
          "amendReason": {
            "type": "string",
            "description": "Reason for amendment, if applicable."
          },
          "oldSaleAmount": {
            "$ref": "#/components/schemas/MonetaryAmount"
          },
          "oldCommissionAmount": {
            "$ref": "#/components/schemas/MonetaryAmount"
          },
          "clickDevice": {
            "type": "string",
            "description": "Device type used for the click."
          },
          "transactionDevice": {
            "type": "string",
            "description": "Device type used for the transaction."
          },
          "publisherUrl": {
            "type": "string",
            "description": "The publisher's referring URL."
          },
          "advertiserCountry": {
            "type": "string",
            "description": "Country of the advertiser."
          },
          "orderRef": {
            "type": "string",
            "description": "The advertiser's order reference."
          },
          "customParameters": {
            "type": "array",
            "description": "Custom tracking parameters.",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          },
          "transactionParts": {
            "type": "array",
            "description": "Breakdown of transaction parts with individual commission amounts.",
            "items": {
              "$ref": "#/components/schemas/TransactionPart"
            }
          },
          "paidToPublisher": {
            "type": "boolean",
            "description": "Whether commission has been paid to the publisher."
          },
          "paymentId": {
            "type": "integer",
            "description": "Payment batch ID, if paid."
          },
          "transactionQueryId": {
            "type": "integer",
            "description": "ID of any associated transaction query."
          },
          "originalSaleAmount": {
            "$ref": "#/components/schemas/MonetaryAmount"
          }
        }
      },
      "TransactionPart": {
        "type": "object",
        "properties": {
          "commissionGroupId": {
            "type": "integer",
            "description": "The commission group ID."
          },
          "commissionGroupCode": {
            "type": "string",
            "description": "The commission group code."
          },
          "commissionGroupName": {
            "type": "string",
            "description": "The commission group name."
          },
          "amount": {
            "$ref": "#/components/schemas/MonetaryAmount"
          },
          "commissionAmount": {
            "$ref": "#/components/schemas/MonetaryAmount"
          }
        }
      },
      "MonetaryAmount": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "format": "double",
            "description": "The monetary value."
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code."
          }
        }
      },
      "PerformanceReport": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "description": "The date of the report row."
          },
          "impressions": {
            "type": "integer",
            "description": "Number of impressions."
          },
          "clicks": {
            "type": "integer",
            "description": "Number of clicks."
          },
          "transactions": {
            "type": "integer",
            "description": "Number of transactions."
          },
          "commissionAmount": {
            "$ref": "#/components/schemas/MonetaryAmount"
          },
          "saleAmount": {
            "$ref": "#/components/schemas/MonetaryAmount"
          },
          "conversionRate": {
            "type": "number",
            "format": "double",
            "description": "Conversion rate (transactions / clicks)."
          },
          "epc": {
            "type": "number",
            "format": "double",
            "description": "Earnings per click."
          },
          "advertiserId": {
            "type": "integer",
            "description": "Advertiser ID (when grouped by advertiser)."
          },
          "advertiserName": {
            "type": "string",
            "description": "Advertiser name (when grouped by advertiser)."
          },
          "publisherId": {
            "type": "integer",
            "description": "Publisher ID (when grouped by publisher)."
          },
          "publisherName": {
            "type": "string",
            "description": "Publisher name (when grouped by publisher)."
          }
        }
      },
      "Programme": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Programme (advertiser) ID."
          },
          "name": {
            "type": "string",
            "description": "Programme name."
          },
          "displayUrl": {
            "type": "string",
            "description": "Display URL for the programme."
          },
          "clickThroughUrl": {
            "type": "string",
            "description": "Click-through URL for the programme."
          },
          "logoUrl": {
            "type": "string",
            "description": "URL of the programme logo."
          },
          "primarySector": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              }
            },
            "description": "Primary business sector."
          },
          "currencyCode": {
            "type": "string",
            "description": "ISO 4217 currency code."
          },
          "validDomains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of valid tracking domains."
          },
          "commissionRange": {
            "type": "object",
            "properties": {
              "min": {
                "type": "number",
                "format": "double"
              },
              "max": {
                "type": "number",
                "format": "double"
              },
              "type": {
                "type": "string",
                "enum": [
                  "percentage",
                  "fixed"
                ]
              }
            },
            "description": "Commission range offered."
          },
          "approvalPercentage": {
            "type": "number",
            "format": "double",
            "description": "Percentage of transactions typically approved."
          },
          "epc": {
            "type": "number",
            "format": "double",
            "description": "Average earnings per click."
          },
          "averagePaymentDays": {
            "type": "integer",
            "description": "Average number of days for payment."
          },
          "validationDays": {
            "type": "integer",
            "description": "Number of days for transaction validation."
          },
          "kipiStatus": {
            "type": "string",
            "description": "Key Performance Indicator status."
          },
          "relationship": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "joined",
                  "notJoined",
                  "pending"
                ]
              }
            },
            "description": "Publisher's relationship with this programme."
          },
          "country": {
            "type": "object",
            "properties": {
              "countryCode": {
                "type": "string"
              },
              "currencyCode": {
                "type": "string"
              }
            },
            "description": "Country information for the programme."
          }
        }
      },
      "CommissionGroup": {
        "type": "object",
        "properties": {
          "groupId": {
            "type": "integer",
            "description": "Commission group ID."
          },
          "groupCode": {
            "type": "string",
            "description": "Commission group code."
          },
          "groupName": {
            "type": "string",
            "description": "Commission group name."
          },
          "type": {
            "type": "string",
            "enum": [
              "percentage",
              "fixed"
            ],
            "description": "Commission type."
          },
          "amount": {
            "type": "number",
            "format": "double",
            "description": "Commission amount or percentage."
          },
          "currency": {
            "type": "string",
            "description": "Currency code (for fixed commissions)."
          },
          "advertiserId": {
            "type": "integer",
            "description": "The associated advertiser ID."
          }
        }
      },
      "Creative": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Creative asset ID."
          },
          "advertiserId": {
            "type": "integer",
            "description": "Advertiser ID."
          },
          "name": {
            "type": "string",
            "description": "Creative name."
          },
          "type": {
            "type": "string",
            "enum": [
              "banner",
              "text",
              "deeplink"
            ],
            "description": "Creative type."
          },
          "width": {
            "type": "integer",
            "description": "Width in pixels (for banners)."
          },
          "height": {
            "type": "integer",
            "description": "Height in pixels (for banners)."
          },
          "imageUrl": {
            "type": "string",
            "description": "URL of the creative image."
          },
          "clickThroughUrl": {
            "type": "string",
            "description": "Click-through destination URL."
          },
          "code": {
            "type": "string",
            "description": "HTML embed code for the creative."
          },
          "description": {
            "type": "string",
            "description": "Description of the creative."
          },
          "startDate": {
            "type": "string",
            "format": "date-time",
            "description": "Start date of the creative."
          },
          "endDate": {
            "type": "string",
            "format": "date-time",
            "description": "End date of the creative."
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Categories associated with the creative."
          },
          "language": {
            "type": "string",
            "description": "Language of the creative content."
          }
        }
      },
      "Publisher": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Publisher account ID."
          },
          "name": {
            "type": "string",
            "description": "Publisher name."
          },
          "url": {
            "type": "string",
            "description": "Publisher website URL."
          },
          "primarySector": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              }
            },
            "description": "Primary sector of the publisher."
          },
          "type": {
            "type": "string",
            "description": "Publisher type (e.g., content, voucher, cashback)."
          },
          "relationship": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "joined",
                  "notJoined",
                  "pending"
                ]
              }
            },
            "description": "Advertiser's relationship with this publisher."
          },
          "country": {
            "type": "string",
            "description": "Country of the publisher."
          }
        }
      }
    }
  }
}
