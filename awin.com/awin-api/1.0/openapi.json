{
  "openapi": "3.0.3",
  "info": {
    "title": "Awin API",
    "description": "The Awin API provides programmatic access to the Awin affiliate marketing network. It enables publishers (affiliates) and advertisers to retrieve transaction data, performance reports, programme information, commission groups, and creative assets. The API supports both Publisher and Advertiser account types with role-specific endpoints.",
    "version": "1.0",
    "contact": {
      "name": "Awin",
      "url": "https://www.awin.com"
    },
    "termsOfService": "https://www.awin.com/us/legal",
    "x-jentic-source-url": "https://help.awin.com/apidocs/publisher-and-advertiser-awin-api-documentation"
  },
  "externalDocs": {
    "description": "Awin API Documentation",
    "url": "https://help.awin.com/apidocs/publisher-and-advertiser-awin-api-documentation"
  },
  "servers": [
    {
      "url": "https://api.awin.com",
      "description": "Awin API Production Server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Publisher - Transactions",
      "description": "Retrieve and query transaction data for publisher accounts"
    },
    {
      "name": "Publisher - Reports",
      "description": "Access performance reports for publisher accounts"
    },
    {
      "name": "Publisher - Programmes",
      "description": "Browse and query advertiser programmes"
    },
    {
      "name": "Publisher - Commission Groups",
      "description": "Retrieve commission group details"
    },
    {
      "name": "Publisher - Creative",
      "description": "Access creative/banner assets from advertisers"
    },
    {
      "name": "Advertiser - Transactions",
      "description": "Retrieve and manage transaction data for advertiser accounts"
    },
    {
      "name": "Advertiser - Reports",
      "description": "Access performance reports for advertiser accounts"
    },
    {
      "name": "Advertiser - Publishers",
      "description": "Browse and query publisher relationships"
    },
    {
      "name": "Advertiser - Commission Groups",
      "description": "Manage commission groups for advertiser accounts"
    }
  ],
  "paths": {
    "/publishers/{publisherId}/transactions/": {
      "get": {
        "operationId": "getPublisherTransactions",
        "summary": "Get publisher transactions",
        "description": "Retrieves a list of transactions for the specified publisher within a date range. Supports filtering by status, date type, and other criteria.",
        "tags": [
          "Publisher - Transactions"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publisherId"
          },
          {
            "name": "startDate",
            "in": "query",
            "required": true,
            "description": "Start date for the transaction query in YYYY-MM-ddTHH:mm:ss format.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": true,
            "description": "End date for the transaction query in YYYY-MM-ddTHH:mm:ss format.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "dateType",
            "in": "query",
            "required": false,
            "description": "The type of date to filter on.",
            "schema": {
              "type": "string",
              "enum": [
                "transaction",
                "validation"
              ]
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "Filter transactions by status.",
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "approved",
                "declined",
                "deleted"
              ]
            }
          },
          {
            "name": "timezone",
            "in": "query",
            "required": false,
            "description": "Timezone for date parameters (e.g., Europe/London, UTC).",
            "schema": {
              "type": "string",
              "default": "UTC"
            }
          },
          {
            "name": "advertiserId",
            "in": "query",
            "required": false,
            "description": "Filter transactions by a specific advertiser ID.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "#/components/parameters/rowLimit"
          },
          {
            "$ref": "#/components/parameters/pageNumber"
          },
          {
            "name": "publisherId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with transaction data.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Transaction"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/publishers/{publisherId}/transactions/{transactionId}": {
