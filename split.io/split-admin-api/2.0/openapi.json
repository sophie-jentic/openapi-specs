  "components": {
    "schemas": {
      "Split": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "trafficType": {
            "$ref": "#/components/schemas/TrafficType"
          },
          "creationTime": {
            "type": "integer",
            "description": "Unix timestamp"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tag"
            }
          }
        }
      },
      "SplitList": {
        "type": "object",
        "properties": {
          "objects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Split"
            }
          },
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "totalCount": {
            "type": "integer"
          }
        }
      },
      "CreateSplitRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "trafficTypeName": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "trafficTypeName"
        ]
      },
      "SplitDefinition": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "environment": {
            "$ref": "#/components/schemas/Environment"
          },
          "trafficType": {
            "$ref": "#/components/schemas/TrafficType"
          },
          "killed": {
            "type": "boolean"
          },
          "treatments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Treatment"
            }
          },
          "defaultTreatment": {
            "type": "string"
          },
          "baselineTreatment": {
            "type": "string"
          },
          "rules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Rule"
            }
          },
          "defaultRule": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Bucket"
            }
          },
          "trafficAllocation": {
            "type": "integer"
          },
          "trafficAllocationSeed": {
            "type": "integer"
          }
        }
      },
      "Treatment": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "configurations": {
            "type": "string",
            "description": "JSON configuration"
          }
        }
      },
      "Rule": {
        "type": "object",
        "properties": {
          "buckets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Bucket"
            }
          },
          "condition": {
            "$ref": "#/components/schemas/Condition"
          }
        }
      },
      "Bucket": {
        "type": "object",
        "properties": {
          "treatment": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          }
        }
      },
      "Condition": {
        "type": "object",
        "properties": {
          "combiner": {
            "type": "string",
            "enum": [
              "AND",
              "OR"
            ]
          },
          "matchers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Matcher"
            }
          }
        }
      },
      "Matcher": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "attribute": {
            "type": "string"
          },
          "strings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "negate": {
            "type": "boolean"
          }
        }
      },
      "Segment": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "environment": {
            "$ref": "#/components/schemas/Environment"
          },
          "creationTime": {
            "type": "integer"
          }
        }
      },
      "SegmentList": {
        "type": "object",
        "properties": {
          "objects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Segment"
            }
          },
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "totalCount": {
            "type": "integer"
          }
        }
      },
      "CreateSegmentRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "SegmentKeyList": {
        "type": "object",
        "properties": {
          "keys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "totalCount": {
            "type": "integer"
          }
        }
      },
      "Environment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Workspace": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "requiresTitleAndComments": {
            "type": "boolean"
          }
        }
      },
      "TrafficType": {
        "type": "object",
        "properties": {
