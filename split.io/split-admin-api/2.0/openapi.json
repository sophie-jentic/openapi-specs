              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Split details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Split"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Split not found"
          }
        },
        "description": "Get a feature flag"
      },
      "delete": {
        "operationId": "deleteSplit",
        "summary": "Delete a feature flag",
        "tags": [
          "Splits"
        ],
        "parameters": [
          {
            "name": "workspaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "splitName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Split deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Split not found"
          }
        },
        "description": "Delete a feature flag"
      }
    },
