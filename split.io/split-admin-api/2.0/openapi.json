{
  "openapi": "3.0.3",
  "info": {
    "title": "Split Admin API",
    "version": "2.0",
    "description": "Split.io is a feature flagging and experimentation platform. The Admin API provides programmatic access to manage feature flags (splits), environments, segments, users, workspaces, and API keys.",
    "x-jentic-source-url": "https://docs.split.io/reference",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.split.io/internal/api/v2",
      "description": "Split Admin API v2"
    }
  ],
  "paths": {
    "/splits/ws/{workspaceId}": {
      "get": {
        "operationId": "listSplits",
        "summary": "List feature flags (splits)",
        "tags": [
          "Splits"
        ],
        "parameters": [
          {
            "name": "workspaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "Filter by name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tags",
            "in": "query",
            "description": "Filter by tags",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of splits",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SplitList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Workspace not found"
          }
        },
        "description": "List feature flags (splits)"
      },
      "post": {
        "operationId": "createSplit",
        "summary": "Create a feature flag (split)",
        "tags": [
          "Splits"
        ],
        "parameters": [
          {
            "name": "workspaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSplitRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Split created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Split"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "409": {
            "description": "Conflict - split already exists"
          }
        },
        "description": "Create a feature flag (split)"
      }
    },
    "/splits/ws/{workspaceId}/{splitName}": {
      "get": {
        "operationId": "getSplit",
        "summary": "Get a feature flag",
        "tags": [
