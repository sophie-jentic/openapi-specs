          "404": {
            "description": "Not found"
          }
        },
        "description": "Get split definition for an environment"
      },
      "put": {
        "operationId": "updateSplitDefinition",
        "summary": "Update split definition for an environment",
        "tags": [
          "Split Definitions"
        ],
        "parameters": [
          {
            "name": "workspaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "splitName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environmentName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SplitDefinition"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Split definition updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SplitDefinition"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Update split definition for an environment"
      },
      "delete": {
        "operationId": "killSplit",
        "summary": "Kill (disable) split in environment",
        "tags": [
          "Split Definitions"
        ],
        "parameters": [
          {
            "name": "workspaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "splitName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environmentName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Split killed"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Kill (disable) split in environment"
      }
    },
