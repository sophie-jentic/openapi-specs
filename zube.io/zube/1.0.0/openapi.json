  "paths": {
    "/users/tokens": {
      "post": {
        "summary": "Get access token",
        "description": "Exchange refresh JWT for access token valid for 24 hours",
        "operationId": "getAccessToken",
        "security": [],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "description": "Bearer refresh JWT signed with RS256",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Client-ID",
            "in": "header",
            "required": true,
            "description": "Client ID from API Access settings",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Access token granted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "description": "JWT access token valid for 24 hours"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "users"
        ]
      }
    },
    "/current_person": {
      "get": {
        "summary": "Get current user",
