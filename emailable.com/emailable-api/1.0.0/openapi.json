{
  "openapi": "3.0.3",
  "info": {
    "title": "Emailable API",
    "version": "1.0.0",
    "description": "Emailable provides email verification and deliverability tools. The API supports single and batch email verification, account management, and checking batch status.",
    "x-jentic-source-url": "https://emailable.com/docs/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.emailable.com",
      "description": "Emailable API"
    }
  ],
  "tags": [
    {
      "name": "Verification",
      "description": "Email verification endpoints"
    },
    {
      "name": "Batch",
      "description": "Batch verification"
    },
    {
      "name": "Account",
      "description": "Account management"
    }
  ],
  "paths": {
    "/v1/verify": {
      "get": {
        "operationId": "verifyEmail",
        "summary": "Verify a single email",
        "description": "Verify a single email address. Returns detailed verification results including status, domain info, and risk assessment.",
        "tags": [
          "Verification"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "description": "The email address to verify",
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "smtp",
            "in": "query",
            "required": false,
            "description": "Whether to include SMTP check. Default true.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "accept_all",
            "in": "query",
            "required": false,
            "description": "Whether to accept all (catch-all) check.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "timeout",
            "in": "query",
            "required": false,
            "description": "Timeout in seconds for SMTP checks.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerificationResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid API key"
          },
          "402": {
            "description": "Insufficient credits"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/batch": {
      "post": {
        "operationId": "createBatch",
        "summary": "Create a batch verification",
        "description": "Submit a batch of email addresses for verification. Upload emails as a list.",
        "tags": [
          "Batch"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchCreateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/batch/{batchId}": {
      "get": {
        "operationId": "getBatchStatus",
        "summary": "Get batch verification status",
        "description": "Check the status and results of a batch verification job.",
        "tags": [
          "Batch"
        ],
        "parameters": [
          {
            "name": "batchId",
            "in": "path",
            "required": true,
            "description": "Batch ID returned from create batch",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "partial",
            "in": "query",
            "required": false,
            "description": "Whether to return partial results",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Batch status and results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchStatusResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Batch not found"
          }
        }
      }
    },
    "/v1/account": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get account information",
        "description": "Retrieve account details including remaining credits and usage information.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Account info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountInfo"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VerificationResult": {
        "type": "object",
        "properties": {
          "accept_all": {
            "type": "boolean",
            "description": "Whether the domain accepts all emails (catch-all)"
          },
          "did_you_mean": {
            "type": "string",
            "nullable": true,
            "description": "Suggested correction if typo detected"
          },
          "disposable": {
            "type": "boolean",
            "description": "Whether the domain is disposable"
          },
          "domain": {
            "type": "string",
            "description": "Domain part of the email"
          },
          "duration": {
            "type": "number",
            "description": "Verification duration in seconds"
          },
          "email": {
            "type": "string",
            "description": "The email verified"
          },
          "first_name": {
            "type": "string",
            "nullable": true,
            "description": "Detected first name"
          },
          "free": {
            "type": "boolean",
            "description": "Whether the email uses a free provider"
          },
          "full_name": {
            "type": "string",
            "nullable": true,
            "description": "Detected full name"
          },
          "gender": {
            "type": "string",
            "nullable": true,
            "description": "Detected gender"
          },
          "last_name": {
            "type": "string",
            "nullable": true,
            "description": "Detected last name"
          },
          "mx_record": {
            "type": "string",
            "nullable": true,
            "description": "MX record for the domain"
          },
          "reason": {
            "type": "string",
            "description": "Reason for the verification result"
          },
          "role": {
            "type": "boolean",
            "description": "Whether the email is role-based"
          },
          "score": {
            "type": "integer",
            "description": "Deliverability score 0-100"
          },
          "smtp_provider": {
            "type": "string",
            "nullable": true,
            "description": "SMTP provider name"
          },
          "state": {
            "type": "string",
            "enum": [
              "deliverable",
              "undeliverable",
              "risky",
              "unknown"
            ],
            "description": "Verification state"
          },
          "tag": {
            "type": "string",
            "nullable": true,
            "description": "Tag part of email (after +)"
          },
          "user": {
            "type": "string",
            "description": "User part of the email"
          }
        }
      },
      "BatchCreateRequest": {
        "type": "object",
        "required": [
          "emails"
        ],
        "properties": {
          "emails": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "email"
            },
            "description": "List of emails to verify"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook URL for completion notification"
          },
          "retries": {
            "type": "boolean",
            "description": "Whether to retry failed verifications"
          }
        }
      },
      "BatchCreateResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Batch ID"
          },
          "message": {
            "type": "string",
            "description": "Status message"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "BatchStatusResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "processing",
              "complete"
            ]
          },
          "total_counts": {
            "type": "object",
            "properties": {
              "deliverable": {
                "type": "integer"
              },
              "undeliverable": {
                "type": "integer"
              },
              "risky": {
                "type": "integer"
              },
              "unknown": {
                "type": "integer"
              },
              "processed": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              }
            }
          },
          "emails": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VerificationResult"
            }
          },
          "download_url": {
            "type": "string",
            "format": "uri",
            "nullable": true
          }
        }
      },
      "AccountInfo": {
        "type": "object",
        "properties": {
          "owner_email": {
            "type": "string"
          },
          "available_credits": {
            "type": "integer",
            "description": "Remaining verification credits"
          },
          "plan_name": {
            "type": "string"
          },
          "plan_credits": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}
