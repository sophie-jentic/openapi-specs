{
  "openapi": "3.0.3",
  "info": {
    "title": "Satispay Business API",
    "description": "Satispay API for payment processing, meal vouchers, fringe benefits, and pre-authorized payments",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developers.satispay.com/docs/welcome",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://authservices.satispay.com",
      "description": "Production server"
    },
    {
      "url": "https://staging.authservices.satispay.com",
      "description": "Staging server"
    }
  ],
  "paths": {
    "/g_business/v1/payments": {
      "post": {
        "summary": "Create payment",
        "description": "Create a payment transaction",
        "operationId": "createPayment",
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "rsaSignature": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "flow",
                  "amount_unit",
                  "currency"
                ],
                "properties": {
                  "flow": {
                    "type": "string",
                    "description": "Payment flow type",
                    "enum": [
                      "MATCH_CODE",
                      "MATCH_USER",
                      "PRE_AUTHORIZED"
                    ]
                  },
                  "amount_unit": {
                    "type": "integer",
                    "description": "Amount in cents"
                  },
                  "currency": {
                    "type": "string",
                    "description": "Currency code",
                    "example": "EUR"
                  },
                  "callback_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Callback URL for payment status"
                  },
                  "external_code": {
                    "type": "string",
                    "description": "External reference code"
                  },
                  "metadata": {
                    "type": "object",
                    "description": "Additional metadata"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Payment identifier"
                    },
                    "code_identifier": {
                      "type": "string",
                      "description": "Payment code identifier"
                    },
                    "status": {
                      "type": "string",
                      "description": "Payment status"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Get list of payments",
        "description": "Retrieve list of payments for the shop",
        "operationId": "getPayments",
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "rsaSignature": []
          }
        ],
        "parameters": [
          {
            "name": "starting_after",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Pagination cursor"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of results to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Payments list retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "has_more": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/g_business/v1/payments/{id}": {
      "get": {
        "summary": "Get payment details",
        "description": "Retrieve the details of a payment",
        "operationId": "getPayment",
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "rsaSignature": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Payment identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Payment details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Payment identifier"
                    },
                    "status": {
                      "type": "string",
                      "description": "Payment status"
                    },
                    "amount_unit": {
                      "type": "integer",
                      "description": "Payment amount in cents"
                    },
                    "currency": {
                      "type": "string",
                      "description": "Currency code"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Payment not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update payment",
        "description": "Update a payment",
        "operationId": "updatePayment",
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "rsaSignature": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Payment identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "description": "Action to perform",
                    "enum": [
                      "ACCEPT",
                      "CANCEL"
                    ]
                  },
                  "metadata": {
                    "type": "object",
                    "description": "Additional metadata"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Payment identifier"
                    },
                    "status": {
                      "type": "string",
                      "description": "Updated payment status"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Payment not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
