{
  "openapi": "3.0.3",
  "info": {
    "title": "Mitigant Cloud Security API",
    "version": "1.0",
    "description": "Mitigant (formerly Resility) is a cloud infrastructure security platform that provides attack surface management, cloud security posture assessment, and chaos engineering for cloud environments (AWS, Azure, GCP). The API enables programmatic access to scan management, findings, assets, attack simulations, and compliance reporting.",
    "x-jentic-source-url": "https://docs.mitigant.io/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.mitigant.io/v1"
    }
  ],
  "paths": {
    "/cloud-accounts": {
      "get": {
        "operationId": "listCloudAccounts",
        "summary": "List connected cloud accounts",
        "tags": [
          "Cloud Accounts"
        ],
        "responses": {
          "200": {
            "description": "Cloud account list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CloudAccount"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List connected cloud accounts"
      },
      "post": {
        "operationId": "addCloudAccount",
        "summary": "Connect a new cloud account",
        "tags": [
          "Cloud Accounts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddCloudAccountRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Cloud account added"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Connect a new cloud account"
      }
    },
    "/cloud-accounts/{accountId}": {
      "get": {
        "operationId": "getCloudAccount",
        "summary": "Get cloud account details",
        "tags": [
          "Cloud Accounts"
        ],
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Account details"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get cloud account details"
      },
      "delete": {
        "operationId": "removeCloudAccount",
        "summary": "Remove a cloud account",
        "tags": [
          "Cloud Accounts"
        ],
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Account removed"
          }
        },
        "description": "Remove a cloud account"
      }
    },
    "/scans": {
      "get": {
        "operationId": "listScans",
        "summary": "List security scans",
        "tags": [
          "Scans"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "running",
                "completed",
                "failed"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Scan list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List security scans"
      },
      "post": {
        "operationId": "createScan",
        "summary": "Start a new security scan",
        "tags": [
          "Scans"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "account_id"
                ],
                "properties": {
                  "account_id": {
                    "type": "string"
                  },
                  "scan_type": {
                    "type": "string",
                    "enum": [
                      "full",
                      "quick",
                      "targeted"
                    ]
                  },
                  "targets": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Scan started"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Start a new security scan"
      }
    },
    "/scans/{scanId}": {
      "get": {
        "operationId": "getScan",
        "summary": "Get scan details and results",
        "tags": [
          "Scans"
        ],
        "parameters": [
          {
            "name": "scanId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Scan details"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get scan details and results"
      },
      "delete": {
        "operationId": "cancelScan",
        "summary": "Cancel a running scan",
        "tags": [
          "Scans"
        ],
        "parameters": [
          {
            "name": "scanId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Scan cancelled"
          }
        },
        "description": "Cancel a running scan"
      }
    },
    "/findings": {
      "get": {
        "operationId": "listFindings",
        "summary": "List security findings",
        "tags": [
          "Findings"
        ],
        "parameters": [
          {
            "name": "severity",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "critical",
                "high",
                "medium",
                "low",
                "info"
              ]
            }
          },
          {
            "name": "account_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scan_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "resolved",
                "suppressed"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Finding list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "findings": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Finding"
                      }
                    },
                    "total": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List security findings"
      }
    },
    "/findings/{findingId}": {
      "get": {
        "operationId": "getFinding",
        "summary": "Get finding details",
        "tags": [
          "Findings"
        ],
        "parameters": [
          {
            "name": "findingId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Finding details"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get finding details"
      },
      "patch": {
        "operationId": "updateFinding",
        "summary": "Update finding status (suppress, resolve)",
        "tags": [
          "Findings"
        ],
        "parameters": [
          {
            "name": "findingId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "open",
                      "resolved",
                      "suppressed"
                    ]
                  },
                  "comment": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Finding updated"
          }
        },
        "description": "Update finding status (suppress, resolve)"
      }
    },
    "/assets": {
      "get": {
        "operationId": "listAssets",
        "summary": "List discovered cloud assets",
        "tags": [
          "Assets"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Asset list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List discovered cloud assets"
      }
    },
    "/assets/{assetId}": {
      "get": {
        "operationId": "getAsset",
        "summary": "Get asset details",
        "tags": [
          "Assets"
        ],
        "parameters": [
          {
            "name": "assetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Asset details"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get asset details"
      }
    },
    "/attack-simulations": {
      "get": {
        "operationId": "listAttackSimulations",
        "summary": "List attack simulations",
        "tags": [
          "Attack Simulations"
        ],
        "responses": {
          "200": {
            "description": "Simulation list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List attack simulations"
      },
      "post": {
        "operationId": "createAttackSimulation",
        "summary": "Create and run an attack simulation",
        "tags": [
          "Attack Simulations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "account_id",
                  "attack_type"
                ],
                "properties": {
                  "account_id": {
                    "type": "string"
                  },
                  "attack_type": {
                    "type": "string",
                    "description": "Type of attack simulation"
                  },
                  "target_resources": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "parameters": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Simulation started"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Create and run an attack simulation"
      }
    },
    "/attack-simulations/{simulationId}": {
      "get": {
        "operationId": "getAttackSimulation",
        "summary": "Get simulation details and results",
        "tags": [
          "Attack Simulations"
        ],
        "parameters": [
          {
            "name": "simulationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Simulation details"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get simulation details and results"
      },
      "delete": {
        "operationId": "cancelAttackSimulation",
        "summary": "Cancel a running simulation",
        "tags": [
          "Attack Simulations"
        ],
        "parameters": [
          {
            "name": "simulationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Simulation cancelled"
          }
        },
        "description": "Cancel a running simulation"
      }
    },
    "/compliance/reports": {
      "get": {
        "operationId": "listComplianceReports",
        "summary": "List compliance reports",
        "tags": [
          "Compliance"
        ],
        "parameters": [
          {
            "name": "framework",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "Compliance framework (e.g., CIS, SOC2, PCI-DSS)"
            }
          },
          {
            "name": "account_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Report list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List compliance reports"
      }
    },
    "/compliance/reports/{reportId}": {
      "get": {
        "operationId": "getComplianceReport",
        "summary": "Get compliance report",
        "tags": [
          "Compliance"
        ],
        "parameters": [
          {
            "name": "reportId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Compliance report"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get compliance report"
      }
    },
    "/dashboards/summary": {
      "get": {
        "operationId": "getDashboardSummary",
        "summary": "Get security dashboard summary",
        "tags": [
          "Dashboard"
        ],
        "responses": {
          "200": {
            "description": "Dashboard summary"
          }
        },
        "description": "Get security dashboard summary"
      }
    }
  },
  "components": {
    "schemas": {
      "CloudAccount": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "provider": {
            "type": "string",
            "enum": [
              "aws",
              "azure",
              "gcp"
            ]
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "last_scan": {
            "type": "string",
            "format": "date-time"
          },
          "finding_count": {
            "type": "integer"
          }
        }
      },
      "AddCloudAccountRequest": {
        "type": "object",
        "required": [
          "provider",
          "name"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "aws",
              "azure",
              "gcp"
            ]
          },
          "name": {
            "type": "string"
          },
          "credentials": {
            "type": "object",
            "properties": {
              "role_arn": {
                "type": "string"
              },
              "external_id": {
                "type": "string"
              }
            }
          }
        }
      },
      "Finding": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "status": {
            "type": "string"
          },
          "resource_id": {
            "type": "string"
          },
          "resource_type": {
            "type": "string"
          },
          "account_id": {
            "type": "string"
          },
          "remediation": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "status_code": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Mitigant API token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Assets"
    },
    {
      "name": "Attack Simulations"
    },
    {
      "name": "Cloud Accounts"
    },
    {
      "name": "Compliance"
    },
    {
      "name": "Dashboard"
    },
    {
      "name": "Findings"
    },
    {
      "name": "Scans"
    }
  ]
}
