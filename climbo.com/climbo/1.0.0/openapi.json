{
  "openapi": "3.0.3",
  "info": {
    "title": "Climbo API",
    "version": "1.0.0",
    "description": "API for managing clients, plans, webhooks, businesses, locations, and reviews in Climbo's reputation management platform.",
    "x-jentic-source-url": "https://climbo.readme.io",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.climbo.com",
      "description": "Climbo API Server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/client": {
      "post": {
        "summary": "Add client",
        "description": "Create a new client account",
        "operationId": "addClient",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "plan_id"
                ],
                "properties": {
                  "user_name": {
                    "type": "string",
                    "description": "Customer name"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Customer email"
                  },
                  "plan_id": {
                    "type": "string",
                    "description": "Plan ID to associate with the client"
                  },
                  "welcome": {
                    "type": "boolean",
                    "default": true,
                    "description": "Send welcome email to customer"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "description": "Password for the client account (minimum 8 characters)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Client created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "client"
        ]
      }
    },
    "/client/{client_id}": {
      "get": {
        "summary": "Get client",
        "description": "Retrieve details of a specific client",
        "operationId": "getClient",
        "parameters": [
          {
            "name": "client_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client ID"
          },
          {
            "name": "login_link",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Include login link in response"
          }
        ],
        "responses": {
          "200": {
            "description": "Client details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientWithLoginLink"
                }
              }
            }
          },
          "404": {
            "description": "Client not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "client"
        ]
      },
      "delete": {
        "summary": "Delete client",
        "description": "Delete a client account",
        "operationId": "deleteClient",
        "parameters": [
          {
            "name": "client_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client ID"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Page number"
          }
        ],
        "responses": {
          "204": {
            "description": "Client deleted successfully"
          },
          "404": {
            "description": "Client not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "client"
        ]
      }
    },
    "/clients": {
      "get": {
        "summary": "List clients",
        "description": "Retrieve a list of clients with optional filtering",
        "operationId": "listClients",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination"
          },
          {
            "name": "plan_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by plan ID"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "incomplete",
                "trialing",
                "incomplete_expired",
                "active",
                "past_due",
                "canceled",
                "unpaid",
                "paused"
              ]
            },
            "description": "Filter by client status"
          },
          {
            "name": "email",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by email"
          }
        ],
        "responses": {
          "200": {
            "description": "List of clients",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Client"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "clients"
        ]
      }
    },
    "/client/{client_id}/change-plan": {
      "post": {
        "summary": "Change client plan",
        "description": "Change the subscription plan for a client",
        "operationId": "changeClientPlan",
        "parameters": [
          {
            "name": "client_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client ID"
          },
          {
            "name": "plan_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "New plan ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Plan changed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          },
          "404": {
            "description": "Client or plan not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "client"
        ]
      }
    },
    "/client/{client_id}/change-status": {
      "post": {
        "summary": "Change client status",
        "description": "Change the status of a client account",
        "operationId": "changeClientStatus",
        "parameters": [
          {
            "name": "client_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client ID"
          },
          {
            "name": "status",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "trialing",
                "unpaid",
                "paused"
              ]
            },
            "description": "New status"
          }
        ],
        "responses": {
          "200": {
            "description": "Status changed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          },
          "404": {
            "description": "Client not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "client"
        ]
      }
    },
    "/plan/{plan_id}": {
      "get": {
        "summary": "Get plan",
        "description": "Retrieve details of a specific plan",
        "operationId": "getPlan",
        "parameters": [
          {
            "name": "plan_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Plan ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Plan details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Plan"
                }
              }
            }
          },
          "404": {
            "description": "Plan not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "plan"
        ]
      }
    },
    "/plans": {
      "get": {
        "summary": "List plans",
        "description": "Retrieve a list of available plans",
        "operationId": "listPlans",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "List of plans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Plan"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "plans"
        ]
      }
    },
    "/webhook/subscribe": {
      "post": {
        "summary": "Create webhook subscription",
        "description": "Subscribe to webhook events",
        "operationId": "createWebhookSubscription",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url",
                  "events"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Webhook endpoint URL"
                  },
                  "events": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "client_created",
                        "client_deleted",
                        "client_status_changed",
                        "client_plan_changed",
                        "client_trial_ending",
                        "client_trial_ended",
                        "new_charge",
                        "location_created",
                        "location_deleted",
                        "review_site_created",
                        "review_site_deleted",
                        "new_google_review",
                        "new_private_feedback",
                        "new_video_testimonial"
                      ]
                    },
                    "description": "List of events to subscribe to"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Subscription created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookSubscription"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "webhook"
        ]
      }
    },
    "/webhook/unsubscribe/{webhook_id}": {
      "delete": {
        "summary": "Delete webhook subscription",
        "description": "Unsubscribe from webhook events",
        "operationId": "deleteWebhookSubscription",
        "parameters": [
          {
            "name": "webhook_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Webhook subscription ID"
          }
        ],
        "responses": {
          "204": {
            "description": "Subscription deleted successfully"
          },
          "404": {
            "description": "Subscription not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "webhook"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "Client": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Client unique identifier"
          },
          "business_name": {
            "type": "string",
            "description": "Business name"
          },
          "user_name": {
            "type": "string",
            "description": "User name"
          },
          "plan_id": {
            "type": "string",
            "description": "Associated plan ID"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Client email"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "source": {
            "type": "string",
            "description": "Client source"
          },
          "location_count": {
            "type": "integer",
            "description": "Number of locations"
          },
          "status": {
            "type": "string",
            "enum": [
              "incomplete",
              "trialing",
              "incomplete_expired",
              "active",
              "past_due",
              "canceled",
              "unpaid",
              "paused"
            ],
            "description": "Client status"
          }
        }
      },
      "ClientWithLoginLink": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Client"
          },
          {
            "type": "object",
            "properties": {
              "login_link": {
                "type": "string",
                "format": "uri",
                "description": "Login link for the client"
              }
            }
          }
        ]
      },
      "Plan": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Plan unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Plan name"
          },
          "amount": {
            "type": "number",
            "description": "Plan amount"
          },
          "link": {
            "type": "string",
            "format": "uri",
            "description": "Plan link"
          },
          "currency": {
            "type": "string",
            "description": "Currency code"
          },
          "interval": {
            "type": "string",
            "description": "Billing interval"
          }
        }
      },
      "WebhookSubscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Webhook subscription ID"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook endpoint URL"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Subscribed events"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "client"
    },
    {
      "name": "clients"
    },
    {
      "name": "plan"
    },
    {
      "name": "plans"
    },
    {
      "name": "webhook"
    }
  ]
}
