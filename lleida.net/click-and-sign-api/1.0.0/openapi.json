  "components": {
    "schemas": {
      "ConfigRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "expire_lapse": {
            "type": "integer"
          }
        }
      },
      "StartSignatureRequest": {
        "type": "object",
        "required": [
          "signature"
        ],
        "properties": {
          "signature": {
            "type": "object",
            "properties": {
              "config_id": {
                "type": "integer"
              },
              "contract_id": {
                "type": "string"
              },
              "level": {
                "type": "string"
              }
            }
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "request": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
