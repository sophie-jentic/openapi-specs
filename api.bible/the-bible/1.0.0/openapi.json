{
  "openapi": "3.0.3",
  "info": {
    "title": "The Bible API",
    "description": "Scripture API by American Bible Society providing access to Bible content, including books, chapters, verses, passages, sections, and search functionality across multiple Bible translations.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.api.bible",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.scripture.api.bible/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "bibles",
      "description": "Operations for managing and retrieving Bible translations"
    },
    {
      "name": "books",
      "description": "Operations for Bible books"
    },
    {
      "name": "chapters",
      "description": "Operations for Bible chapters"
    },
    {
      "name": "verses",
      "description": "Operations for Bible verses"
    },
    {
      "name": "passages",
      "description": "Operations for Bible passages"
    },
    {
      "name": "search",
      "description": "Search operations"
    }
  ],
  "paths": {
    "/bibles": {
      "get": {
        "operationId": "getBibles",
        "summary": "Get all Bibles",
        "description": "Retrieve a list of all available Bible translations",
        "tags": [
          "bibles"
        ],
        "parameters": [
          {
            "name": "language",
            "in": "query",
            "description": "Filter by ISO language code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "abbreviation",
            "in": "query",
            "description": "Filter by Bible abbreviation",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "Filter by Bible name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ids",
            "in": "query",
            "description": "Comma-separated list of Bible IDs",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include-full-details",
            "in": "query",
            "description": "Include full details for each Bible",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BiblesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bibles/{bibleId}": {
      "get": {
        "operationId": "getBible",
        "summary": "Get a Bible",
        "description": "Retrieve details for a specific Bible translation",
        "tags": [
          "bibles"
        ],
        "parameters": [
          {
            "name": "bibleId",
            "in": "path",
            "required": true,
            "description": "Bible ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BibleResponse"
                }
              }
            }
          },
          "404": {
            "description": "Bible not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bibles/{bibleId}/books": {
      "get": {
        "operationId": "getBooks",
        "summary": "Get books in a Bible",
        "description": "Retrieve all books for a specific Bible",
        "tags": [
          "books"
        ],
        "parameters": [
          {
            "name": "bibleId",
            "in": "path",
            "required": true,
            "description": "Bible ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include-chapters",
            "in": "query",
            "description": "Include chapter summaries",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "include-chapters-and-sections",
            "in": "query",
            "description": "Include chapter and section summaries",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BooksResponse"
                }
              }
            }
          },
          "404": {
            "description": "Bible not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bibles/{bibleId}/books/{bookId}": {
      "get": {
        "operationId": "getBook",
        "summary": "Get a book",
        "description": "Retrieve details for a specific book",
        "tags": [
          "books"
        ],
        "parameters": [
          {
            "name": "bibleId",
            "in": "path",
            "required": true,
            "description": "Bible ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bookId",
            "in": "path",
            "required": true,
            "description": "Book ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include-chapters",
            "in": "query",
            "description": "Include chapter summaries",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookResponse"
                }
              }
            }
          },
          "404": {
            "description": "Book not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bibles/{bibleId}/chapters/{chapterId}": {
      "get": {
        "operationId": "getChapter",
        "summary": "Get a chapter",
        "description": "Retrieve content and details for a specific chapter",
        "tags": [
          "chapters"
        ],
        "parameters": [
          {
            "name": "bibleId",
            "in": "path",
            "required": true,
            "description": "Bible ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "chapterId",
            "in": "path",
            "required": true,
            "description": "Chapter ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "content-type",
            "in": "query",
            "description": "Content type (html, json, text)",
            "schema": {
              "type": "string",
              "enum": [
                "html",
                "json",
                "text"
              ],
              "default": "html"
            }
          },
          {
            "name": "include-notes",
            "in": "query",
            "description": "Include footnotes and cross references",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "include-titles",
            "in": "query",
            "description": "Include section titles",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "include-chapter-numbers",
            "in": "query",
            "description": "Include chapter numbers",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "include-verse-numbers",
            "in": "query",
            "description": "Include verse numbers",
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChapterResponse"
                }
              }
            }
          },
          "404": {
            "description": "Chapter not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bibles/{bibleId}/passages/{passageId}": {
      "get": {
        "operationId": "getPassage",
        "summary": "Get a passage",
        "description": "Retrieve content for a specific passage",
        "tags": [
          "passages"
        ],
        "parameters": [
          {
            "name": "bibleId",
            "in": "path",
            "required": true,
            "description": "Bible ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "passageId",
            "in": "path",
            "required": true,
            "description": "Passage ID (e.g., 'JHN.3.16' or 'JHN.3.16-JHN.3.18')",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "content-type",
            "in": "query",
            "description": "Content type (html, json, text)",
            "schema": {
              "type": "string",
              "enum": [
                "html",
                "json",
                "text"
              ],
              "default": "html"
            }
          },
          {
            "name": "include-notes",
            "in": "query",
            "description": "Include footnotes and cross references",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PassageResponse"
                }
              }
            }
          },
          "404": {
            "description": "Passage not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bibles/{bibleId}/verses/{verseId}": {
      "get": {
        "operationId": "getVerse",
        "summary": "Get a verse",
        "description": "Retrieve content for a specific verse",
        "tags": [
          "verses"
        ],
        "parameters": [
          {
            "name": "bibleId",
            "in": "path",
            "required": true,
            "description": "Bible ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "verseId",
            "in": "path",
            "required": true,
            "description": "Verse ID (e.g., 'JHN.3.16')",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "content-type",
            "in": "query",
            "description": "Content type (html, json, text)",
            "schema": {
              "type": "string",
              "enum": [
                "html",
                "json",
                "text"
              ],
              "default": "html"
            }
          },
          {
            "name": "include-notes",
            "in": "query",
            "description": "Include footnotes and cross references",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerseResponse"
                }
              }
            }
          },
          "404": {
            "description": "Verse not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bibles/{bibleId}/search": {
      "get": {
        "operationId": "searchBible",
        "summary": "Search a Bible",
        "description": "Search for verses within a specific Bible translation",
        "tags": [
          "search"
        ],
        "parameters": [
          {
            "name": "bibleId",
            "in": "path",
            "required": true,
            "description": "Bible ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "Search query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results to return (max 50)",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Offset for pagination",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order (relevance or canonical)",
            "schema": {
              "type": "string",
              "enum": [
                "relevance",
                "canonical"
              ],
              "default": "relevance"
            }
          },
          {
            "name": "range",
            "in": "query",
            "description": "Restrict search to specific book or passage range",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fuzziness",
            "in": "query",
            "description": "Fuzzy search level (0, 1, or 2)",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1,
                2
              ],
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid search parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "api-key"
      }
    },
    "schemas": {
      "BiblesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Bible"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "BibleResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Bible"
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "Bible": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "dblId": {
            "type": "string"
          },
          "abbreviation": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "language": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "script": {
                "type": "string"
              }
            }
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BooksResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Book"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "BookResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Book"
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "Book": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "bibleId": {
            "type": "string"
          },
          "abbreviation": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "nameLong": {
            "type": "string"
          },
          "chapters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "number": {
                  "type": "string"
                },
                "reference": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ChapterResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Chapter"
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "Chapter": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "bibleId": {
            "type": "string"
          },
          "bookId": {
            "type": "string"
          },
          "number": {
            "type": "string"
          },
          "reference": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "verseCount": {
            "type": "integer"
          },
          "copyright": {
            "type": "string"
          }
        }
      },
      "PassageResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Passage"
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "Passage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "bibleId": {
            "type": "string"
          },
          "reference": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "verseCount": {
            "type": "integer"
          },
          "copyright": {
            "type": "string"
          }
        }
      },
      "VerseResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Verse"
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "Verse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "bibleId": {
            "type": "string"
          },
          "bookId": {
            "type": "string"
          },
          "chapterId": {
            "type": "string"
          },
          "reference": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "copyright": {
            "type": "string"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string"
              },
              "limit": {
                "type": "integer"
              },
              "offset": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              },
              "verses": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/SearchVerse"
                }
              },
              "passages": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "SearchVerse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "bibleId": {
            "type": "string"
          },
          "bookId": {
            "type": "string"
          },
          "chapterId": {
            "type": "string"
          },
          "reference": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      },
      "Meta": {
        "type": "object",
        "properties": {
          "fums": {
            "type": "string"
          },
          "fumsId": {
            "type": "string"
          },
          "fumsJsInclude": {
            "type": "string"
          },
          "fumsJs": {
            "type": "string"
          },
          "fumsNoScript": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "statusCode": {
            "type": "integer",
            "description": "HTTP status code"
          }
        }
      }
    }
  }
}
