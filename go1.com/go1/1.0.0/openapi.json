        "description": "Retrieves a specific learning object by ID",
        "operationId": "getLearningObject",
        "tags": [
          "Learning Objects"
        ],
        "servers": [
          {
            "url": "https://api.go1.com"
          }
        ],
        "parameters": [
          {
            "name": "lo_id",
            "in": "path",
