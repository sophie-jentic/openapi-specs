{
  "openapi": "3.0.3",
  "info": {
    "title": "GO1 API",
    "description": "GO1 API for learning management, user authentication, enrollments, and content delivery. Supports OAuth 2.0 with multiple grant types.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://go1developer.readme.io",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://auth.go1.com",
      "description": "Authentication server"
    },
    {
      "url": "https://api.go1.com",
      "description": "Main API server"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/oauth/authorize": {
      "get": {
        "summary": "Start OAuth2 Authorization",
        "description": "Initiates the OAuth2 authorization flow",
        "operationId": "oauthAuthorize",
        "tags": [
          "OAuth"
        ],
        "security": [],
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "code",
                "token"
              ]
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "scope",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to authorization page"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/oauth/token": {
      "post": {
        "summary": "Get Access Token",
        "description": "Retrieves access tokens using various grant types",
        "operationId": "oauthToken",
        "tags": [
          "OAuth"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "authorization_code",
                      "refresh_token",
                      "client_credentials",
                      "go1_jwt",
                      "password"
                    ]
                  },
                  "code": {
                    "type": "string"
                  },
                  "redirect_uri": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_secret": {
                    "type": "string"
                  },
                  "refresh_token": {
                    "type": "string"
                  },
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string"
                    },
                    "token_type": {
                      "type": "string",
                      "example": "Bearer"
                    },
                    "expires_in": {
                      "type": "integer"
                    },
                    "refresh_token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/oauth/validate": {
      "get": {
        "summary": "Validate Access Token",
        "description": "Validates the status of an access token",
        "operationId": "oauthValidate",
        "tags": [
          "OAuth"
        ],
        "parameters": [
          {
            "name": "access_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Token is valid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "valid": {
                      "type": "boolean"
                    },
                    "user_id": {
                      "type": "string"
                    },
                    "client_id": {
                      "type": "string"
                    },
                    "expires_at": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/oauth/revoke": {
      "post": {
        "summary": "Revoke Access Token",
        "description": "Revokes a user's access token",
        "operationId": "oauthRevoke",
        "tags": [
          "OAuth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token revoked successfully"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/oauth/public-key": {
      "get": {
        "summary": "Get Public Key",
        "description": "Retrieves RSA public key for offline token validation",
        "operationId": "oauthPublicKey",
        "tags": [
          "OAuth"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Public key",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/client": {
      "get": {
        "summary": "List OAuth Clients",
        "description": "Retrieves a list of OAuth clients",
        "operationId": "listClients",
        "tags": [
          "OAuth Clients"
        ],
        "responses": {
          "200": {
            "description": "List of OAuth clients",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OAuthClient"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create OAuth Client",
        "description": "Creates a new OAuth client",
        "operationId": "createClient",
        "tags": [
          "OAuth Clients"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OAuthClientInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "OAuth client created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthClient"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/client/{clientId}": {
      "put": {
        "summary": "Update OAuth Client",
        "description": "Updates an existing OAuth client",
        "operationId": "updateClient",
        "tags": [
          "OAuth Clients"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OAuthClientInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OAuth client updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthClient"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      },
      "delete": {
        "summary": "Delete OAuth Client",
        "description": "Deletes an OAuth client",
        "operationId": "deleteClient",
        "tags": [
          "OAuth Clients"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "OAuth client deleted"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/client/{clientId}/regenerate-secret": {
      "post": {
        "summary": "Regenerate Client Secret",
        "description": "Changes the client secret for an OAuth client",
        "operationId": "regenerateClientSecret",
        "tags": [
          "OAuth Clients"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "New client secret",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "client_secret": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "List Users",
        "description": "Retrieves a list of users",
        "operationId": "listUsers",
        "tags": [
