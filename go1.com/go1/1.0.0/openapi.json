          }
        }
      },
      "post": {
        "summary": "Create Webhook",
        "description": "Creates a new webhook",
        "operationId": "createWebhook",
        "tags": [
          "Webhooks"
        ],
        "servers": [
          {
            "url": "https://api.go1.com"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook created",
            "content": {
              "application/json": {
                "schema": {
