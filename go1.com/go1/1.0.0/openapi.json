        ],
        "servers": [
          {
            "url": "https://api.go1.com"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/users/{user_id}": {
      "patch": {
        "summary": "Update User",
        "description": "Updates a user",
        "operationId": "updateUser",
        "tags": [
          "Users"
        ],
        "servers": [
          {
            "url": "https://api.go1.com"
          }
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/enrollments": {
      "get": {
        "summary": "List Enrollments",
        "description": "Retrieves a list of enrollments",
        "operationId": "listEnrollments",
        "tags": [
          "Enrollments"
        ],
        "servers": [
          {
            "url": "https://api.go1.com"
          }
        ],
        "responses": {
          "200": {
            "description": "List of enrollments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Enrollment"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Enrollment",
        "description": "Creates a new enrollment",
        "operationId": "createEnrollment",
        "tags": [
          "Enrollments"
        ],
        "servers": [
          {
            "url": "https://api.go1.com"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
