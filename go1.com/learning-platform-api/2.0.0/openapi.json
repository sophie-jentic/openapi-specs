{
  "openapi": "3.0.3",
  "info": {
    "title": "GO1 Learning Platform API",
    "description": "GO1 API for authentication, user management, and learning content",
    "version": "2.0.0",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://auth.go1.com",
      "description": "Authentication"
    },
    {
      "url": "https://api.go1.com/v2",
      "description": "API"
    }
  ],
  "security": [
    {
      "OAuth2": []
    }
  ],
  "paths": {
    "/oauth/authorize": {
      "get": {
        "summary": "OAuth2 authorization",
        "servers": [
          {
            "url": "https://auth.go1.com"
          }
        ],
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect"
          }
        },
        "tags": [
          "oauth"
        ],
        "description": "OAuth2 authorization",
        "operationId": "get-oauth-authorize"
      }
    },
    "/oauth/token": {
      "post": {
        "summary": "Get access token",
        "servers": [
          {
            "url": "https://auth.go1.com"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  }
                },
                "required": [
                  "grant_type",
                  "client_id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "oauth"
        ],
        "description": "Get access token",
        "operationId": "post-oauth-token"
      }
    },
    "/account": {
      "get": {
        "summary": "Get account",
        "servers": [
          {
            "url": "https://api.go1.com/v2"
          }
        ],
        "responses": {
          "200": {
            "description": "Account",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "tags": [
          "account"
        ],
        "description": "Get account",
        "operationId": "get-account"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://auth.go1.com/oauth/authorize",
            "tokenUrl": "https://auth.go1.com/oauth/token",
            "scopes": {
              "account.read": "Read account"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "account"
    },
    {
      "name": "oauth"
    }
  ]
}
