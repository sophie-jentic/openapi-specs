{
  "openapi": "3.0.3",
  "info": {
    "title": "Number Verification API",
    "version": "1.0.0",
    "description": "The Number Verification API validates if a provided phone number matches the device's registered number by comparing against the IP address assigned by the mobile network operator.",
    "x-jentic-source-url": "https://developers.opengateway.telefonica.com/docs/numberverification",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://opengateway.telefonica.com/api"
    }
  ],
  "paths": {
    "/verify": {
      "post": {
        "operationId": "verifyPhoneNumber",
        "summary": "Verify a phone number",
        "description": "Validates if the provided phone number matches the device's registered number",
        "tags": [
          "Verification"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phoneNumber"
                ],
                "properties": {
                  "phoneNumber": {
                    "type": "string",
                    "description": "Phone number (MSISDN) to verify"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerificationResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/device-phone-number": {
      "get": {
        "operationId": "getDevicePhoneNumber",
        "summary": "Get device phone number",
        "description": "Retrieves the phone number associated with the user's device without requiring input parameters",
        "tags": [
          "Verification"
        ],
        "responses": {
          "200": {
            "description": "Device phone number",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phoneNumber": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VerificationResult": {
        "type": "object",
        "properties": {
          "devicePhoneNumberVerified": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://opengateway.telefonica.com/authorize",
            "tokenUrl": "https://opengateway.telefonica.com/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "Verification"
    }
  ]
}
