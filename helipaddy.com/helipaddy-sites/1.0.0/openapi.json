{
  "openapi": "3.0.3",
  "info": {
    "title": "Helipaddy Sites API",
    "description": "Helicopter and passenger drone landing site directory. Access the Helipaddy database of landing sites, search by location, and retrieve detailed site information.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://helipaddy.com/api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.helipaddy.com/api",
      "description": "Helipaddy API Production Server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication and token management"
    },
    {
      "name": "Sites",
      "description": "Landing site data retrieval and search"
    },
    {
      "name": "Usage",
      "description": "API usage monitoring"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Authenticate user",
        "description": "Authenticate with email and password to receive a bearer token for subsequent API requests.",
        "operationId": "login",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/callback": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "OAuth callback",
        "description": "Handle OAuth authentication callback from Google.",
        "operationId": "authCallback",
        "security": [],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "OAuth access token",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "driver",
            "in": "query",
            "required": true,
            "description": "OAuth provider name",
            "schema": {
              "type": "string",
              "enum": [
                "google"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid token or driver",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid OAuth token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sites": {
      "get": {
        "tags": [
          "Sites"
        ],
        "summary": "List landing sites",
        "description": "Retrieve the full database of helicopter and drone landing sites.",
        "operationId": "listSites",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of landing sites",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SiteListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sites/nearest": {
      "get": {
        "tags": [
          "Sites"
        ],
        "summary": "Find nearest landing sites",
        "description": "Locate the closest landing sites to the given geographic coordinates within a specified radius.",
        "operationId": "findNearestSites",
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "description": "Latitude of the search center point",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "lng",
            "in": "query",
            "required": true,
            "description": "Longitude of the search center point",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "required": false,
            "description": "Search radius in kilometers",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 50
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Nearest landing sites retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SiteListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid coordinates",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sites/{id}": {
      "get": {
        "tags": [
          "Sites"
        ],
        "summary": "Get site details",
        "description": "Access individual landing site details. Requires partner-level access for full information.",
        "operationId": "getSiteById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Unique identifier of the landing site",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Site details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SiteDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Site not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/usage": {
      "get": {
        "tags": [
          "Usage"
        ],
        "summary": "Get API usage statistics",
        "description": "Monitor API request consumption for the authenticated account.",
        "operationId": "getUsage",
        "responses": {
          "200": {
            "description": "Usage data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Bearer token obtained from the /auth/login endpoint. Format: Bearer {token}"
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "description": "User password"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Bearer token for authenticating subsequent requests"
          }
        }
      },
      "Site": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the landing site"
          },
          "name": {
            "type": "string",
            "description": "Name of the landing site"
          },
          "latitude": {
            "type": "number",
            "format": "double",
            "description": "Latitude coordinate"
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "description": "Longitude coordinate"
          },
          "type": {
            "type": "string",
            "description": "Type of landing site (e.g., helipad, heliport, hospital)",
            "enum": [
              "helipad",
              "heliport",
              "hospital",
              "private",
              "military",
              "commercial"
            ]
          },
          "status": {
            "type": "string",
            "description": "Current operational status",
            "enum": [
              "active",
              "inactive",
              "restricted",
              "seasonal"
            ]
          },
          "elevation": {
            "type": "number",
            "format": "double",
            "description": "Elevation in feet"
          },
          "country": {
            "type": "string",
            "description": "Country code (ISO 3166-1 alpha-2)"
          },
          "region": {
            "type": "string",
            "description": "Region or state"
          },
          "distance": {
            "type": "number",
            "format": "double",
            "description": "Distance from search point in kilometers (only present in nearest search results)"
          }
        }
      },
      "SiteDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Site"
          },
          {
            "type": "object",
            "properties": {
              "description": {
                "type": "string",
                "description": "Detailed description of the landing site"
              },
              "contact_name": {
                "type": "string",
                "description": "Primary contact name"
              },
              "contact_phone": {
                "type": "string",
                "description": "Primary contact phone number"
              },
              "contact_email": {
                "type": "string",
                "format": "email",
                "description": "Primary contact email"
              },
              "facilities": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Available facilities at the site"
              },
              "surface_type": {
                "type": "string",
                "description": "Landing surface type (e.g., concrete, grass, gravel)"
              },
              "max_weight": {
                "type": "number",
                "description": "Maximum allowed aircraft weight in kg"
              },
              "lighting": {
                "type": "boolean",
                "description": "Whether the site has lighting for night operations"
              },
              "fuel_available": {
                "type": "boolean",
                "description": "Whether fuel is available at the site"
              },
              "ppr_required": {
                "type": "boolean",
                "description": "Whether prior permission is required"
              },
              "images": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uri"
                },
                "description": "URLs of site images"
              },
              "updated_at": {
                "type": "string",
                "format": "date-time",
                "description": "Last update timestamp"
              }
            }
          }
        ]
      },
      "SiteListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Site"
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "current_page": {
                "type": "integer"
              },
              "total_pages": {
                "type": "integer"
              },
              "total_count": {
                "type": "integer"
              },
              "per_page": {
                "type": "integer"
              }
            }
          }
        }
      },
      "SiteDetailResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/SiteDetail"
          }
        }
      },
      "UsageResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "plan": {
                "type": "string",
                "description": "Current subscription plan"
              },
              "requests_today": {
                "type": "integer",
                "description": "Number of requests made today"
              },
              "daily_limit": {
                "type": "integer",
                "description": "Maximum requests allowed per day"
              },
              "requests_this_minute": {
                "type": "integer",
                "description": "Number of requests made this minute"
              },
              "rate_limit_per_minute": {
                "type": "integer",
                "description": "Maximum requests allowed per minute"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Error messages keyed by field name"
          },
          "message": {
            "type": "string",
            "description": "General error message"
          }
        }
      }
    }
  }
}
