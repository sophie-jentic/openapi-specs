  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "Account": {
        "type": "object",
        "required": [
          "id",
          "first_name",
          "last_name",
          "account_state",
          "agent_ids",
          "email"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "account_state": {
            "type": "string",
            "enum": [
              "active",
              "deactivating",
              "unlinked"
            ]
          },
          "activated_at": {
            "type": "string",
            "format": "date-time"
          },
          "active_date": {
            "type": "string",
            "format": "date-time"
          },
          "agent_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "Subscription": {
        "type": "object",
        "required": [
          "id",
          "hook_url",
          "resource",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "hook_url": {
            "type": "string"
          },
          "resource": {
            "type": "string",
            "enum": [
              "agent",
              "client",
              "client_invitation",
              "event",
              "search"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "secret": {
            "type": "string"
          }
        }
      },
      "Agent": {
        "type": "object",
        "required": [
          "id",
          "name",
          "first_name",
          "last_name",
          "mls",
          "mls_id",
          "modified_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "mls": {
            "type": "string"
          },
          "mls_id": {
            "type": "string"
          },
          "modified_at": {
            "type": "string",
            "format": "date-time"
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "claimed": {
            "type": "boolean"
          },
          "claimed_at": {
            "type": "string",
            "format": "date-time"
          },
          "account_id": {
            "type": "string"
          },
          "account": {
            "$ref": "#/components/schemas/Account"
          }
        }
      },
      "AgentCursor": {
        "type": "object",
        "required": [
          "data",
          "cursor",
          "has_next_page",
          "total"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Agent"
            }
          },
          "cursor": {
            "type": "string"
          },
          "has_next_page": {
            "type": "boolean"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "ClientCursor": {
        "type": "object",
        "required": [
          "data",
          "cursor",
          "has_next_page",
          "total"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Client"
            }
          },
          "cursor": {
            "type": "string"
          },
          "has_next_page": {
            "type": "boolean"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "Client": {
        "type": "object",
        "required": [
          "id",
          "name",
          "first_name",
          "last_name",
          "email",
          "phone",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "agent_id": {
            "type": "string"
          },
          "modified_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Search": {
        "type": "object",
        "required": [
          "id",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
