{
  "openapi": "3.0.3",
  "info": {
    "title": "Zenlist Partner Integration API",
    "description": "Partner API used for integration. This is not a general purpose API and access is granted specifically to partners and brokerages we work with.",
    "version": "2.0.0",
    "contact": {
      "name": "API Support",
      "url": "https://zenlist.com",
      "email": "support@zenlist.com"
    },
    "x-jentic-source-url": "https://openapidocs.zenlist.com/openapi.yaml"
  },
  "servers": [
    {
      "url": "https://openapi.zenlist.com/v2",
      "description": "Main (production) server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "subscription",
      "description": "Subscription represents an active webhook registered endpoint for this Api Key."
    },
    {
      "name": "agent",
      "description": "Agents represent an active Zenlist user that is registered with their local MLS."
    },
    {
      "name": "client",
      "description": "Clients represent an active Zenlist user that is connected to an agent."
    },
    {
      "name": "client_invitation",
      "description": "Client invitations represent a pending Zenlist user that is connected to an agent."
    },
    {
      "name": "event",
      "description": "Client events represent the activity of an active Zenlist user that is connected to an agent."
    },
    {
      "name": "chat",
      "description": "Chat events."
    },
    {
      "name": "search",
      "description": "Searches represent an active Zenlist client search."
    }
  ],
  "paths": {
    "/subscriptions": {
      "get": {
        "summary": "Returns a list of subscriptions",
        "description": "Returns the list of subscriptions that the provided key has currently active.",
        "tags": [
          "subscription"
        ],
        "parameters": [
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 200
            }
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A JSON array of subscriptions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Subscription"
                  }
                }
              }
            }
          }
        },
        "operationId": "get_subscriptions"
      },
      "post": {
        "summary": "Subscribe to a webhook",
        "tags": [
          "subscription"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "hook_url",
                  "resource"
                ],
                "properties": {
                  "hook_url": {
                    "type": "string",
                    "format": "uri",
                    "example": "https://myserver.com/send/callback/here"
                  },
                  "resource": {
                    "type": "string",
                    "enum": [
                      "agent",
                      "client",
                      "client_invitation",
                      "event",
                      "search"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subscription"
                }
              }
            }
          }
        },
        "description": "Subscribe to a webhook",
        "operationId": "post_subscriptions"
      }
    },
    "/subscriptions/{subscriptionId}": {
      "get": {
        "summary": "Get the details of a webhook",
        "tags": [
          "subscription"
        ],
        "parameters": [
          {
            "name": "subscriptionId",
            "in": "path",
            "required": true,
            "description": "The Zenlist ID for the subscription",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subscription"
                }
              }
            }
          }
        },
        "description": "Get the details of a webhook",
        "operationId": "get_subscriptions_subscriptionId"
      },
      "put": {
        "summary": "Update a webhook",
        "tags": [
          "subscription"
        ],
        "parameters": [
          {
            "name": "subscriptionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "hook_url",
                  "resource"
                ],
                "properties": {
                  "hook_url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "resource": {
                    "type": "string",
                    "enum": [
                      "agent",
                      "client",
                      "client_invitation",
                      "event",
                      "search"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subscription"
                }
              }
            }
          }
        },
        "description": "Update a webhook",
        "operationId": "put_subscriptions_subscriptionId"
      },
      "delete": {
        "summary": "Remove a webhook",
        "tags": [
          "subscription"
        ],
        "parameters": [
          {
            "name": "subscriptionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subscription"
                }
              }
            }
          }
        },
        "description": "Remove a webhook",
        "operationId": "delete_subscriptions_subscriptionId"
      }
    },
