    "/agents_cursor": {
      "get": {
        "summary": "Returns a list of agents with cursor pagination",
        "description": "Returns the list of agents that the provided key has access to.",
        "tags": [
          "agent"
        ],
        "parameters": [
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 200
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "A cursor returned from a previous query for additional results",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "modified_at_start",
            "in": "query",
            "description": "An inclusive start datetime in rfc3339 format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "modified_at_end",
            "in": "query",
            "description": "An exclusive end datetime in rfc3339 format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A JSON array of agents in a cursor response",
