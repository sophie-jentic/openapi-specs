{
  "openapi": "3.0.3",
  "info": {
    "title": "Cloverly Carbon Offset API",
    "description": "The Cloverly API calculates the impact of common carbon-intensive activities in real time and enables the purchase of carbon offsets to neutralize that impact. It supports estimates and purchases for shipping, vehicle transport, direct carbon weight, and currency-based offsets.",
    "version": "2019-03-beta",
    "contact": {
      "name": "Cloverly",
      "url": "https://www.cloverly.com"
    },
    "x-jentic-source-url": "https://www.cloverly.com/carbon-offset-documentation"
  },
  "servers": [
    {
      "url": "https://api.cloverly.com/2019-03-beta",
      "description": "Cloverly API (Beta)"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Estimates",
      "description": "Generate carbon offset estimates without purchasing"
    },
    {
      "name": "Purchases",
      "description": "Purchase carbon offsets"
    },
    {
      "name": "Account",
      "description": "Account information"
    }
  ],
  "paths": {
    "/account": {
      "get": {
        "tags": ["Account"],
        "summary": "Get account information",
        "description": "Retrieve the authenticated account's information.",
        "operationId": "getAccount",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/estimates/shipping": {
      "post": {
        "tags": ["Estimates"],
        "summary": "Estimate shipping offset",
        "description": "Generate a carbon offset estimate for shipping. Provide either distance and weight, or origin/destination locations with weight.",
        "operationId": "estimateShipping",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShippingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful estimate",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Estimate"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/estimates/vehicle": {
      "post": {
        "tags": ["Estimates"],
        "summary": "Estimate vehicle offset",
        "description": "Generate a carbon offset estimate for vehicle travel. Provide distance and fuel efficiency, or origin/destination locations with fuel efficiency.",
        "operationId": "estimateVehicle",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VehicleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful estimate",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Estimate"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/estimates/carbon": {
      "post": {
        "tags": ["Estimates"],
        "summary": "Estimate carbon weight offset",
        "description": "Generate a carbon offset estimate for a direct carbon weight measurement.",
        "operationId": "estimateCarbon",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CarbonRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful estimate",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Estimate"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/estimates/currency": {
      "post": {
        "tags": ["Estimates"],
        "summary": "Estimate currency-based offset",
        "description": "Generate a carbon offset estimate based on a fixed currency amount.",
        "operationId": "estimateCurrency",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CurrencyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful estimate",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Estimate"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/estimates": {
      "get": {
        "tags": ["Estimates"],
        "summary": "List all estimates",
        "description": "Retrieve a list of all estimates for the authenticated account.",
        "operationId": "listEstimates",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Estimate"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/estimates/{slug}": {
      "get": {
        "tags": ["Estimates"],
        "summary": "Retrieve an estimate",
        "description": "Retrieve a previously created estimate by its slug.",
        "operationId": "getEstimate",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "The unique slug identifier for the estimate",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Estimate"
                }
              }
            }
          },
          "404": {
            "description": "Estimate not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Estimates"],
        "summary": "Cancel an estimate",
        "description": "Cancel a previously created estimate.",
        "operationId": "cancelEstimate",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "The unique slug identifier for the estimate",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Estimate cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Estimate"
                }
              }
            }
          },
          "404": {
            "description": "Estimate not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/purchases/shipping": {
      "post": {
        "tags": ["Purchases"],
        "summary": "Purchase shipping offset",
        "description": "Purchase a carbon offset for shipping.",
        "operationId": "purchaseShipping",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShippingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful purchase",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Purchase"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/purchases/vehicle": {
      "post": {
        "tags": ["Purchases"],
        "summary": "Purchase vehicle offset",
        "description": "Purchase a carbon offset for vehicle travel.",
        "operationId": "purchaseVehicle",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VehicleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful purchase",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Purchase"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/purchases/carbon": {
      "post": {
        "tags": ["Purchases"],
        "summary": "Purchase carbon weight offset",
        "description": "Purchase a carbon offset for a direct carbon weight measurement.",
        "operationId": "purchaseCarbon",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CarbonRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful purchase",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Purchase"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/purchases/currency": {
      "post": {
        "tags": ["Purchases"],
        "summary": "Purchase currency-based offset",
        "description": "Purchase a carbon offset based on a fixed currency amount.",
        "operationId": "purchaseCurrency",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CurrencyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful purchase",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Purchase"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/purchases": {
      "get": {
        "tags": ["Purchases"],
        "summary": "List all purchases",
        "description": "Retrieve a list of all purchases for the authenticated account.",
        "operationId": "listPurchases",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Purchase"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/purchases/{slug}": {
      "get": {
        "tags": ["Purchases"],
        "summary": "Retrieve a purchase",
        "description": "Retrieve a previously made purchase by its slug.",
        "operationId": "getPurchase",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "The unique slug identifier for the purchase",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Purchase"
                }
              }
            }
          },
          "404": {
            "description": "Purchase not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Purchases"],
        "summary": "Cancel a purchase",
        "description": "Cancel a previously made purchase.",
        "operationId": "cancelPurchase",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "The unique slug identifier for the purchase",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Purchase cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Purchase"
                }
              }
            }
          },
          "404": {
            "description": "Purchase not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key passed as a Bearer token in the Authorization header."
      }
    },
    "schemas": {
      "LocationInput": {
        "type": "object",
        "properties": {
          "zip": {
            "type": "string",
            "description": "ZIP or postal code",
            "example": "35209"
          },
          "postal_code": {
            "type": "string",
            "description": "Postal code (alternative to zip)",
            "example": "54000"
          },
          "country": {
            "type": "string",
            "description": "Two-letter country code",
            "example": "US"
          }
        }
      },
      "Distance": {
        "type": "object",
        "required": ["value", "units"],
        "properties": {
          "value": {
            "type": "number",
            "description": "Distance value",
            "example": 100
          },
          "units": {
            "type": "string",
            "description": "Distance units",
            "enum": ["miles", "km"],
            "example": "miles"
          }
        }
      },
      "Weight": {
        "type": "object",
        "required": ["value", "units"],
        "properties": {
          "value": {
            "type": "number",
            "description": "Weight value",
            "example": 5
          },
          "units": {
            "type": "string",
            "description": "Weight units",
            "enum": ["kg", "pounds", "lbs"],
            "example": "kg"
          }
        }
      },
      "FuelEfficiency": {
        "type": "object",
        "required": ["value", "units", "of"],
        "properties": {
          "value": {
            "type": "number",
            "description": "Fuel efficiency value",
            "example": 35
          },
          "units": {
            "type": "string",
            "description": "Fuel efficiency units",
            "enum": ["mpg", "km/l"],
            "example": "km/l"
          },
          "of": {
            "type": "string",
            "description": "Fuel type",
            "enum": ["gasoline", "diesel"],
            "example": "diesel"
          }
        }
      },
      "Currency": {
        "type": "object",
        "required": ["value", "unit"],
        "properties": {
          "value": {
            "type": "number",
            "description": "Currency amount",
            "example": 285
          },
          "unit": {
            "type": "string",
            "description": "Currency unit",
            "enum": ["usd", "usd cents"],
            "example": "usd cents"
          }
        }
      },
      "ShippingRequest": {
        "type": "object",
        "properties": {
          "distance": {
            "$ref": "#/components/schemas/Distance"
          },
          "weight": {
            "$ref": "#/components/schemas/Weight"
          },
          "to": {
            "$ref": "#/components/schemas/LocationInput"
          },
          "from": {
            "$ref": "#/components/schemas/LocationInput"
          }
        },
        "description": "Provide either distance+weight or to+from+weight"
      },
      "VehicleRequest": {
        "type": "object",
        "properties": {
          "distance": {
            "$ref": "#/components/schemas/Distance"
          },
          "fuel_efficiency": {
            "$ref": "#/components/schemas/FuelEfficiency"
          },
          "to": {
            "$ref": "#/components/schemas/LocationInput"
          },
          "from": {
            "$ref": "#/components/schemas/LocationInput"
          }
        },
        "description": "Provide either distance+fuel_efficiency or to+from+fuel_efficiency"
      },
      "CarbonRequest": {
        "type": "object",
        "required": ["weight"],
        "properties": {
          "weight": {
            "$ref": "#/components/schemas/Weight"
          }
        }
      },
      "CurrencyRequest": {
        "type": "object",
        "required": ["currency"],
        "properties": {
          "currency": {
            "$ref": "#/components/schemas/Currency"
          }
        }
      },
      "Offset": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the carbon offset project"
          },
          "type": {
            "type": "string",
            "description": "Type of offset project"
          },
          "registry": {
            "type": "string",
            "description": "Offset registry name"
          },
          "registry_url": {
            "type": "string",
            "description": "URL of the offset project on the registry"
          }
        }
      },
      "Estimate": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "description": "Unique identifier for the estimate"
          },
          "state": {
            "type": "string",
            "description": "Current state of the estimate",
            "example": "estimated"
          },
          "transaction_cost_in_usd_cents": {
            "type": "integer",
            "description": "Cost of the offset in USD cents"
          },
          "environment": {
            "type": "string",
            "description": "API environment (e.g., sandbox, production)"
          },
          "estimated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of when the estimate was created"
          },
          "equivalent_carbon_in_kg": {
            "type": "number",
            "description": "Equivalent carbon weight in kilograms"
          },
          "offset": {
            "$ref": "#/components/schemas/Offset"
          }
        }
      },
      "Purchase": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "description": "Unique identifier for the purchase"
          },
          "state": {
            "type": "string",
            "description": "Current state of the purchase",
            "example": "purchased"
          },
          "transaction_cost_in_usd_cents": {
            "type": "integer",
            "description": "Cost of the offset in USD cents"
          },
          "environment": {
            "type": "string",
            "description": "API environment"
          },
          "purchased_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of when the purchase was made"
          },
          "equivalent_carbon_in_kg": {
            "type": "number",
            "description": "Equivalent carbon weight in kilograms"
          },
          "offset": {
            "$ref": "#/components/schemas/Offset"
          },
          "rec": {
            "type": "object",
            "description": "Renewable Energy Certificate details",
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "description": "Account identifier"
          },
          "name": {
            "type": "string",
            "description": "Account name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Account email"
          },
          "environment": {
            "type": "string",
            "description": "API environment"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error description"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              }
            }
          }
        }
      }
    }
  }
}