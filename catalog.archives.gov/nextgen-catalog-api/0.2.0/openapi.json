  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "RecordsSearchResponse": {
        "type": "object",
        "properties": {
          "opaResponse": {
            "type": "object",
            "properties": {
              "result": {
                "type": "object",
                "properties": {
                  "total": {
                    "type": "integer"
                  },
                  "rows": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Record"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Record": {
        "type": "object",
        "properties": {
          "naId": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "level": {
            "type": "string"
          },
          "dateRangeStart": {
            "type": "string"
          },
          "dateRangeEnd": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "contributionId": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          },
          "targetNaId": {
            "type": "integer"
          },
          "userId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "TagBody": {
        "type": "object",
        "required": [
          "tag",
          "targetNaId",
          "userId"
        ],
        "properties": {
          "tag": {
            "type": "string"
          },
          "targetNaId": {
            "type": "integer"
          },
          "userId": {
            "type": "string",
            "description": "UUID of the user"
          }
        }
      },
      "CommentBody": {
        "type": "object",
        "required": [
          "comment",
          "targetNaId",
          "userId"
        ],
        "properties": {
          "comment": {
            "type": "string"
          },
          "targetNaId": {
            "type": "integer"
          },
          "userId": {
            "type": "string"
          }
        }
      },
      "TranscriptionBody": {
        "type": "object",
        "required": [
          "transcription",
          "targetNaId",
          "userId"
        ],
        "properties": {
          "transcription": {
            "type": "string"
          },
          "targetNaId": {
            "type": "integer"
          },
          "userId": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Comments"
    },
    {
      "name": "Contributions"
    },
    {
      "name": "Records"
    },
    {
      "name": "Tags"
    },
    {
      "name": "Transcriptions"
    }
  ]
}
