{
  "openapi": "3.0.0",
  "info": {
    "title": "NextGen Catalog API",
    "version": "0.2.0",
    "description": "The NextGen Catalog API for the National Archives Catalog. Requires an API key passed in x-api-key header. For write operations, a UUID userId is required in the request body. Contact Catalog_API@nara.gov for an API Key.",
    "x-jentic-source-url": "https://catalog.archives.gov/api/v2/swagger.json",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://catalog.archives.gov/api/v2/"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/records/search": {
      "get": {
        "operationId": "searchRecords",
        "tags": [
          "Records"
        ],
        "summary": "Get records by using url parameters to perform a catalog search.",
        "description": "Get records by using url parameters to perform a catalog search. Returns a JSON result.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Search query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "title",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "naId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "level",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startDate",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "objectType",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "creators",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "recordGroupNumber",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A body of response data containing full record objects if any were found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordsSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request. Invalid search terms, revise terms."
          },
          "401": {
            "description": "Unauthorized. Invalid or missing API key."
          },
          "422": {
            "description": "Unprocessable Entity."
          }
        }
      }
    },
