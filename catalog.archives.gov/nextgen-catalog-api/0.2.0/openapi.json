          "400": {
            "description": "Bad Request."
          },
          "401": {
            "description": "Unauthorized."
          },
          "422": {
            "description": "Unprocessable Entity."
          }
        },
        "description": "Get records by using other extracted text to perform a catalog search."
      }
    },
