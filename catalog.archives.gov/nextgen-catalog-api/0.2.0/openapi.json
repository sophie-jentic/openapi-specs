    "/records/parentNaId/{parentNaId}": {
      "get": {
        "operationId": "getRecordsByParentNaId",
        "tags": [
          "Records"
        ],
        "summary": "Get records which are immediate children of a specified parentNaId.",
        "parameters": [
          {
            "name": "parentNaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "7005"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A body of response data containing full record objects, if any were found."
          },
          "401": {
            "description": "Unauthorized."
          },
          "422": {
            "description": "Unprocessable Entity."
          }
        },
        "description": "Get records which are immediate children of a specified parentNaId."
      }
    },
