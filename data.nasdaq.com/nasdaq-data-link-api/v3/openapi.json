        "operationId": "getDatabaseDatasetCodes",
        "summary": "Get all dataset codes in a database",
        "description": "Returns a ZIP file containing a CSV of all dataset codes in a database.",
        "tags": [
          "Databases"
        ],
        "parameters": [
          {
            "name": "database_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ZIP file containing CSV of dataset codes",
            "content": {
              "application/zip": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
