    "/datatables/{datatable_code}": {
      "get": {
        "operationId": "getDatatable",
        "summary": "Get datatable data",
        "description": "Returns data from a specified datatable (tabular data). Supports filtering, column selection, and pagination via cursor.",
        "tags": [
          "Datatables"
        ],
        "parameters": [
          {
            "name": "datatable_code",
            "in": "path",
            "required": true,
            "description": "The unique datatable code (e.g., WIKI/PRICES)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "qopts.columns",
            "in": "query",
            "description": "Comma-separated list of columns to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "qopts.per_page",
            "in": "query",
            "description": "Number of rows per page",
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "qopts.cursor_id",
            "in": "query",
            "description": "Cursor ID for pagination (returned in previous response)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "qopts.export",
            "in": "query",
            "description": "Request full data download as file",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatatableResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
