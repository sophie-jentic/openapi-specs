{
  "openapi": "3.0.3",
  "info": {
    "title": "Nasdaq Data Link API",
    "version": "v3",
    "description": "Nasdaq Data Link (formerly Quandl) provides access to financial, economic, and alternative datasets. The API supports time-series data and tables (datatables) with filtering, sorting, and pagination capabilities.",
    "x-jentic-source-url": "https://docs.data.nasdaq.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://data.nasdaq.com/api/v3"
    }
  ],
  "paths": {
    "/datasets/{database_code}/{dataset_code}": {
      "get": {
        "operationId": "getTimeSeriesDataset",
        "summary": "Get time-series dataset",
        "description": "Returns data from a specified time-series dataset. Supports filtering by date range, frequency collapsing, and transformations.",
        "tags": [
          "Time Series"
        ],
        "parameters": [
          {
            "name": "database_code",
            "in": "path",
            "required": true,
            "description": "The unique database code (e.g., WIKI, FRED)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dataset_code",
            "in": "path",
            "required": true,
            "description": "The unique dataset code within the database (e.g., AAPL, GDP)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "description": "Retrieve data rows on and after the specified start date",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "description": "Retrieve data rows up to and including the specified end date",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort order of returned data",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            }
          },
          {
            "name": "collapse",
            "in": "query",
            "description": "Collapse data to specified frequency",
            "schema": {
              "type": "string",
              "enum": [
                "none",
                "daily",
                "weekly",
                "monthly",
                "quarterly",
                "annual"
              ]
            }
          },
          {
            "name": "transform",
            "in": "query",
            "description": "Perform calculation on data before returning",
            "schema": {
              "type": "string",
              "enum": [
                "none",
                "diff",
                "rdiff",
                "rdiff_from",
                "cumul",
                "normalize"
              ]
            }
          },
          {
            "name": "rows",
            "in": "query",
            "description": "Maximum number of rows to return",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "column_index",
            "in": "query",
            "description": "Return only the specified column (1-indexed, date is column 0)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Dataset not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/datasets/{database_code}/{dataset_code}/data": {
      "get": {
        "operationId": "getTimeSeriesData",
        "summary": "Get time-series data only",
        "description": "Returns only the data portion of a time-series dataset without metadata.",
