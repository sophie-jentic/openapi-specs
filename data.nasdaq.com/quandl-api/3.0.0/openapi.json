{
  "openapi": "3.0.3",
  "info": {
    "title": "Nasdaq Data Link API (formerly Quandl)",
    "description": "Access financial, economic, and alternative data via the Nasdaq Data Link platform (formerly Quandl). Provides time-series and tabular data across thousands of databases with support for filtering, transformations, and bulk downloads.",
    "version": "3.0.0",
    "contact": {
      "name": "Nasdaq Data Link",
      "url": "https://data.nasdaq.com"
    },
    "termsOfService": "https://data.nasdaq.com/terms-of-use",
    "x-documentation-url": "https://docs.data.nasdaq.com/docs/getting-started"
  },
  "servers": [
    {
      "url": "https://data.nasdaq.com/api/v3",
      "description": "Nasdaq Data Link API v3"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "paths": {
    "/datasets/{database_code}/{dataset_code}/data.{return_format}": {
      "get": {
        "operationId": "getTimeSeriesData",
        "summary": "Get time-series data",
        "description": "Retrieve data for a specific time-series dataset. Returns observations with date and value columns.",
        "tags": [
          "Time Series"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/database_code"
          },
          {
            "$ref": "#/components/parameters/dataset_code"
          },
          {
            "$ref": "#/components/parameters/return_format"
          },
          {
            "$ref": "#/components/parameters/start_date"
          },
          {
            "$ref": "#/components/parameters/end_date"
          },
          {
            "$ref": "#/components/parameters/order"
          },
          {
            "$ref": "#/components/parameters/limit"
          },
          {
            "$ref": "#/components/parameters/column_index"
          },
          {
            "$ref": "#/components/parameters/collapse"
          },
          {
            "$ref": "#/components/parameters/transform"
          },
          {
            "name": "database_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "return_format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dataset_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with time-series data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TimeSeriesDataResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/datasets/{database_code}/{dataset_code}/metadata.{return_format}": {
      "get": {
        "operationId": "getTimeSeriesMetadata",
        "summary": "Get time-series metadata",
        "description": "Retrieve metadata (column names, frequency, description, etc.) for a specific time-series dataset without the data itself.",
        "tags": [
          "Time Series"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/database_code"
          },
          {
            "$ref": "#/components/parameters/dataset_code"
          },
          {
            "$ref": "#/components/parameters/return_format"
          },
          {
            "name": "database_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "return_format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dataset_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with dataset metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetMetadataResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/datasets/{database_code}/{dataset_code}.{return_format}": {
      "get": {
        "operationId": "getTimeSeriesDataAndMetadata",
        "summary": "Get time-series data and metadata combined",
        "description": "Retrieve both data and metadata for a specific time-series dataset in a single call. CSV format is not available for this endpoint.",
        "tags": [
          "Time Series"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/database_code"
          },
          {
            "$ref": "#/components/parameters/dataset_code"
          },
          {
            "name": "return_format",
            "in": "path",
            "required": true,
            "description": "Response format. Note: CSV is not available for this endpoint.",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml"
              ]
            }
          },
          {
            "$ref": "#/components/parameters/start_date"
          },
          {
            "$ref": "#/components/parameters/end_date"
          },
          {
            "$ref": "#/components/parameters/order"
          },
          {
            "$ref": "#/components/parameters/limit"
          },
          {
            "$ref": "#/components/parameters/column_index"
          },
          {
            "$ref": "#/components/parameters/collapse"
          },
          {
            "$ref": "#/components/parameters/transform"
          },
          {
            "name": "database_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dataset_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with time-series data and metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetFullResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/databases/{database_code}.{return_format}": {
      "get": {
        "operationId": "getDatabaseMetadata",
        "summary": "Get database metadata",
        "description": "Retrieve metadata about an entire database, including its name, description, number of datasets, and other properties.",
        "tags": [
          "Databases"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/database_code"
          },
          {
            "$ref": "#/components/parameters/return_format"
          },
          {
            "name": "database_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "return_format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with database metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatabaseMetadataResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/databases/{database_code}/data": {
      "get": {
        "operationId": "downloadEntireDatabase",
        "summary": "Download entire time-series database",
        "description": "Download all data from a time-series database as a zipped CSV file. Available for premium data products only.",
        "tags": [
          "Databases"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/database_code"
          },
          {
            "name": "download_type",
            "in": "query",
            "required": false,
            "description": "Type of download. 'full' returns the entire database; 'partial' returns only data updated since the last full download.",
            "schema": {
              "type": "string",
              "enum": [
                "full",
                "partial"
              ],
              "default": "full"
            }
          },
          {
            "name": "database_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Zipped CSV file of the entire database",
            "content": {
              "application/zip": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/datatables/{datatable_code}.{return_format}": {
      "get": {
        "operationId": "getTableData",
        "summary": "Get table data",
        "description": "Retrieve data from a Nasdaq Data Link table with optional row and column filtering. Default page size is 10,000 rows.",
        "tags": [
          "Tables"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/datatable_code"
          },
          {
            "$ref": "#/components/parameters/return_format"
          },
          {
            "name": "qopts.columns",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of column names to return.",
            "schema": {
              "type": "string"
            },
            "example": "ticker,date,close"
          },
          {
            "name": "qopts.per_page",
            "in": "query",
            "required": false,
            "description": "Number of rows per page (max 10,000).",
            "schema": {
              "type": "integer",
              "maximum": 10000
            }
          },
          {
            "name": "qopts.cursor_id",
            "in": "query",
            "required": false,
            "description": "Cursor ID for pagination. Use the next_cursor_id value from the previous response.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "qopts.export",
            "in": "query",
            "required": false,
            "description": "Set to 'true' to trigger a bulk download file generation instead of paginated results.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "return_format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "datatable_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with table data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TableDataResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/datatables/{datatable_code}/metadata.{return_format}": {
      "get": {
        "operationId": "getTableMetadata",
        "summary": "Get table metadata",
        "description": "Retrieve metadata for a table including column definitions, filterable fields, primary keys, and refresh status.",
        "tags": [
          "Tables"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/datatable_code"
          },
          {
            "$ref": "#/components/parameters/return_format"
          },
          {
            "name": "return_format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "datatable_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with table metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TableMetadataResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key for authentication. Obtain from https://data.nasdaq.com/account/profile"
      }
    },
    "parameters": {
      "database_code": {
        "name": "database_code",
        "in": "path",
        "required": true,
        "description": "Code identifying the database (e.g., 'WIKI', 'FRED').",
        "schema": {
          "type": "string"
        },
        "example": "WIKI"
      },
      "dataset_code": {
        "name": "dataset_code",
        "in": "path",
        "required": true,
        "description": "Code identifying the dataset within a database (e.g., 'FB', 'AAPL').",
        "schema": {
          "type": "string"
        },
        "example": "AAPL"
      },
      "datatable_code": {
        "name": "datatable_code",
        "in": "path",
        "required": true,
        "description": "Code identifying the table in VENDOR/TABLE format (e.g., 'SHARADAR/SF1').",
        "schema": {
          "type": "string"
        },
        "example": "SHARADAR/SF1"
      },
      "return_format": {
        "name": "return_format",
        "in": "path",
        "required": true,
        "description": "Response format: json, xml, or csv.",
        "schema": {
          "type": "string",
          "enum": [
            "json",
            "xml",
            "csv"
          ]
        }
      },
      "start_date": {
        "name": "start_date",
        "in": "query",
        "required": false,
        "description": "Retrieve data rows on and after the specified start date (yyyy-mm-dd).",
        "schema": {
          "type": "string",
          "format": "date"
        },
        "example": "2020-01-01"
      },
      "end_date": {
        "name": "end_date",
        "in": "query",
        "required": false,
        "description": "Retrieve data rows up to and including the specified end date (yyyy-mm-dd).",
        "schema": {
          "type": "string",
          "format": "date"
        },
        "example": "2024-12-31"
      },
      "order": {
        "name": "order",
        "in": "query",
        "required": false,
        "description": "Return data in ascending or descending order of date. Default is 'desc'.",
        "schema": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ],
          "default": "desc"
        }
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "Number of rows to return. Use limit=1 to get only the latest observation.",
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      },
      "column_index": {
        "name": "column_index",
        "in": "query",
        "required": false,
        "description": "Request a specific column by index. Column 0 is the date column and is always returned.",
        "schema": {
          "type": "integer",
          "minimum": 0
        }
      },
      "collapse": {
        "name": "collapse",
        "in": "query",
        "required": false,
        "description": "Change the sampling frequency of the data. Returns the last observation for each period.",
        "schema": {
          "type": "string",
          "enum": [
            "none",
            "daily",
            "weekly",
            "monthly",
            "quarterly",
            "annual"
          ]
        }
      },
      "transform": {
        "name": "transform",
        "in": "query",
        "required": false,
        "description": "Apply a calculation to the data before returning. 'diff' = row-on-row change, 'rdiff' = row-on-row % change, 'rdiff_from' = latest value as % increment, 'cumul' = cumulative sum, 'normalize' = scale to start at 100.",
        "schema": {
          "type": "string",
          "enum": [
            "none",
            "diff",
            "rdiff",
            "rdiff_from",
            "cumul",
            "normalize"
          ]
        }
      }
    },
    "schemas": {
      "TimeSeriesDataResponse": {
        "type": "object",
        "properties": {
          "dataset_data": {
            "type": "object",
            "properties": {
              "limit": {
                "type": "integer",
                "nullable": true
              },
              "transform": {
                "type": "string",
                "nullable": true
              },
              "column_index": {
                "type": "integer",
                "nullable": true
              },
              "column_names": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "start_date": {
                "type": "string",
                "format": "date"
              },
              "end_date": {
                "type": "string",
                "format": "date"
              },
              "frequency": {
                "type": "string"
              },
              "data": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {}
                }
              },
              "collapse": {
                "type": "string",
                "nullable": true
              },
              "order": {
                "type": "string",
                "nullable": true
              }
            }
          }
        }
      },
      "DatasetMetadataResponse": {
        "type": "object",
        "properties": {
          "dataset": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "dataset_code": {
                "type": "string"
              },
              "database_code": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "refreshed_at": {
                "type": "string",
                "format": "date-time"
              },
              "newest_available_date": {
                "type": "string",
                "format": "date"
              },
              "oldest_available_date": {
                "type": "string",
                "format": "date"
              },
              "column_names": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "frequency": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "premium": {
                "type": "boolean"
              },
              "database_id": {
                "type": "integer"
              }
            }
          }
        }
      },
      "DatasetFullResponse": {
        "type": "object",
        "properties": {
          "dataset": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "dataset_code": {
                "type": "string"
              },
              "database_code": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "refreshed_at": {
                "type": "string",
                "format": "date-time"
              },
              "newest_available_date": {
                "type": "string",
                "format": "date"
              },
              "oldest_available_date": {
                "type": "string",
                "format": "date"
              },
              "column_names": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "frequency": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "premium": {
                "type": "boolean"
              },
              "database_id": {
                "type": "integer"
              },
              "data": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {}
                }
              }
            }
          }
        }
      },
      "DatabaseMetadataResponse": {
        "type": "object",
        "properties": {
          "database": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "database_code": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "datasets_count": {
                "type": "integer"
              },
              "downloads": {
                "type": "integer"
              },
              "premium": {
                "type": "boolean"
              },
              "image": {
                "type": "string",
                "format": "uri"
              },
              "favorite": {
                "type": "boolean"
              },
              "url_name": {
                "type": "string"
              }
            }
          }
        }
      },
      "TableDataResponse": {
        "type": "object",
        "properties": {
          "datatable": {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {}
                }
              },
              "columns": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "next_cursor_id": {
