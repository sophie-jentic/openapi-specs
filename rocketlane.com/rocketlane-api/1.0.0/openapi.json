        "summary": "Create user API key",
        "description": "Create a new API key for the current user.",
        "operationId": "createUserApiKey",
        "responses": {
          "200": {
            "description": "API key created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "apiKey": {
                      "type": "string"
                    }
