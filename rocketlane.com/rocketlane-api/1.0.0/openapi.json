                    }
                  },
                  "required": [
                    "emailId"
                  ]
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Users created successfully"
          }
        }
      }
    },
    "/users/photo": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Profile Picture Upload",
        "description": "Upload a profile picture for the current user.",
        "operationId": "uploadProfilePicture",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile picture uploaded successfully"
          }
        }
      }
    },
    "/users/meta": {
      "put": {
        "tags": [
          "Users"
        ],
        "summary": "Update user meta",
        "description": "Update user metadata.",
        "operationId": "updateUserMeta",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "metaData": {
                    "type": "object",
                    "properties": {
                      "profileSetupDone": {
                        "type": "boolean"
