  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "api-key",
        "in": "header",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "CreateProjectRequest": {
        "type": "object",
        "required": [
          "projectName"
        ],
        "properties": {
          "projectName": {
            "type": "string",
            "description": "Name of the project"
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "description": "Project start date (YYYY-MM-DD)"
          },
          "dueDate": {
            "type": "string",
            "format": "date",
            "description": "Project due date (YYYY-MM-DD)"
          },
          "projectFee": {
            "type": "number",
            "description": "Fee for the project"
          },
          "annualizedRecurringRevenue": {
            "type": "number",
            "description": "ARR value"
          },
          "customerChampion": {
            "type": "object",
            "properties": {
              "userId": {
                "type": "integer"
              }
            }
          },
          "customer": {
            "type": "object",
            "properties": {
              "companyId": {
                "type": "integer"
              }
            }
          },
          "projectOwner": {
            "type": "object",
            "properties": {
              "userId": {
                "type": "integer"
              }
            }
          },
          "teamMembers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "userId": {
                  "type": "integer"
                }
              }
            }
          },
          "source": {
            "type": "string"
          }
        }
      },
      "UpdateProjectRequest": {
        "type": "object",
        "properties": {
          "projectName": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "dueDate": {
            "type": "string",
            "format": "date"
          },
          "projectFee": {
            "type": "number"
          },
          "annualizedRecurringRevenue": {
            "type": "number"
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "integer"
          },
          "projectName": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "dueDate": {
            "type": "string",
            "format": "date"
          },
          "projectFee": {
            "type": "number"
          },
          "annualizedRecurringRevenue": {
            "type": "number"
          }
        }
      },
      "CreateTaskRequest": {
        "type": "object",
        "required": [
          "taskName"
        ],
        "properties": {
          "taskName": {
            "type": "string",
            "description": "Name of the task"
          },
          "taskDescription": {
            "type": "string",
            "description": "Description of the task"
          },
          "effort": {
            "type": "integer",
            "description": "Effort estimate"
          },
          "atRisk": {
            "type": "boolean",
            "description": "Whether the task is at risk"
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaskField"
            },
            "description": "Custom fields for the task"
          },
          "assignees": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "userId": {
                  "type": "integer"
                }
              }
            }
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "dueDate": {
            "type": "string",
            "format": "date"
          },
          "projectId": {
            "type": "integer"
          },
          "phaseId": {
            "type": "integer"
          }
        }
      },
      "UpdateTaskRequest": {
        "type": "object",
        "properties": {
          "taskName": {
            "type": "string"
          },
          "taskDescription": {
            "type": "string"
          },
          "effort": {
            "type": "integer"
          },
          "atRisk": {
            "type": "boolean"
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaskField"
            }
          },
          "assignees": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "userId": {
                  "type": "integer"
                }
              }
            }
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "dueDate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "taskId": {
            "type": "integer"
          },
          "taskName": {
            "type": "string"
          },
          "taskDescription": {
            "type": "string"
          },
          "effort": {
