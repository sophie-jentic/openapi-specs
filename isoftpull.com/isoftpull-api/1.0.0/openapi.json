{
  "openapi": "3.0.3",
  "x-jentic-source-url": "https://desk.isoftpull.com/portal/en/kb/articles/api-documentation",
  "info": {
    "title": "iSoftpull API",
    "description": "iSoftpull provides credit reporting APIs for soft and hard credit pulls from major credit bureaus including TransUnion and Equifax. This API enables running credit checks and retrieving applicant data.",
    "version": "1.0.0",
    "contact": {
      "name": "iSoftpull Support",
      "email": "support@isoftpull.com",
      "url": "https://www.isoftpull.com"
    }
  },
  "servers": [
    {
      "url": "https://api.isoftpull.com/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/soft-pull": {
      "post": {
        "summary": "Run soft pull",
        "description": "Executes a soft credit inquiry for an applicant without affecting their credit score",
        "operationId": "runSoftPull",
        "tags": [
          "Credit Reports"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "first_name",
                  "last_name",
                  "address",
                  "city",
                  "state",
                  "zip_code"
                ],
                "properties": {
                  "first_name": {
                    "type": "string",
                    "description": "Applicant's first name"
                  },
                  "middle_name": {
                    "type": "string",
                    "description": "Applicant's middle name"
                  },
                  "last_name": {
                    "type": "string",
                    "description": "Applicant's last name"
                  },
                  "address": {
                    "type": "string",
                    "description": "Street address"
                  },
                  "city": {
                    "type": "string",
                    "description": "City"
                  },
                  "state": {
                    "type": "string",
                    "description": "State (2-letter code)"
                  },
                  "zip_code": {
                    "type": "string",
                    "description": "ZIP code"
                  },
                  "dob": {
                    "type": "string",
                    "format": "date",
                    "description": "Date of birth (YYYY-MM-DD)"
                  },
                  "ssn": {
                    "type": "string",
                    "description": "Social Security Number (optional for soft pull)"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email address"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Phone number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Soft pull completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreditReport"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/hard-pull": {
      "post": {
        "summary": "Run hard pull",
        "description": "Performs a hard credit inquiry for applicant verification (affects credit score)",
        "operationId": "runHardPull",
        "tags": [
          "Credit Reports"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "first_name",
                  "last_name",
                  "address",
                  "city",
                  "state",
                  "zip_code",
                  "dob",
                  "ssn"
                ],
                "properties": {
                  "first_name": {
                    "type": "string",
                    "description": "Applicant's first name"
                  },
                  "last_name": {
                    "type": "string",
                    "description": "Applicant's last name"
                  },
                  "address": {
                    "type": "string",
                    "description": "Street address"
                  },
                  "city": {
                    "type": "string",
                    "description": "City"
                  },
                  "state": {
                    "type": "string",
                    "description": "State (2-letter code)"
                  },
                  "zip_code": {
                    "type": "string",
                    "description": "ZIP code"
                  },
                  "dob": {
                    "type": "string",
                    "format": "date",
                    "description": "Date of birth (YYYY-MM-DD)"
                  },
                  "ssn": {
                    "type": "string",
                    "description": "Social Security Number"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email address"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Phone number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hard pull completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreditReport"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/applicants/{applicant_id}": {
      "get": {
        "summary": "Find applicant",
        "description": "Retrieves applicant data by ID",
        "operationId": "findApplicant",
        "tags": [
          "Applicants"
        ],
        "parameters": [
          {
            "name": "applicant_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Applicant identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Applicant data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Applicant"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Applicant not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API Key ID"
      },
      "apiSecretAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Secret",
        "description": "API Secret Access Token"
      }
    },
    "schemas": {
      "CreditReport": {
        "type": "object",
        "properties": {
          "applicant_id": {
            "type": "string",
            "description": "Applicant identifier"
          },
          "report_type": {
            "type": "string",
            "enum": [
              "soft_pull",
              "hard_pull"
            ],
            "description": "Type of credit pull"
          },
          "credit_score": {
            "type": "integer",
            "description": "Credit score"
          },
          "bureau": {
            "type": "string",
            "enum": [
              "TransUnion",
              "Equifax",
              "Experian"
            ],
            "description": "Credit bureau"
          },
          "report_date": {
            "type": "string",
            "format": "date-time",
            "description": "Report generation date"
          },
          "status": {
            "type": "string",
            "description": "Report status"
          },
          "data": {
            "type": "object",
            "description": "Full credit report data",
            "additionalProperties": true
          }
        }
      },
      "Applicant": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Applicant identifier"
          },
          "first_name": {
            "type": "string",
            "description": "First name"
          },
          "last_name": {
            "type": "string",
            "description": "Last name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address"
          },
          "phone": {
            "type": "string",
            "description": "Phone number"
          },
          "address": {
            "type": "object",
            "properties": {
              "street": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "state": {
                "type": "string"
              },
              "zip_code": {
                "type": "string"
              }
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Record creation timestamp"
          },
          "processed_at": {
            "type": "string",
            "format": "date-time",
            "description": "Processing timestamp"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "message": {
            "type": "string",
            "description": "Detailed error description"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Applicants"
    },
    {
      "name": "Credit Reports"
    }
  ]
}
