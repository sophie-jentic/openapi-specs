{
  "openapi": "3.0.3",
  "info": {
    "title": "NeetoForm API",
    "version": "1.0.0",
    "description": "NeetoForm API allows you to manage forms, submissions, and team members programmatically. It provides endpoints for listing forms, retrieving form submissions, and managing team members in your NeetoForm workspace.",
    "x-jentic-source-url": "https://apidocs.neetoform.com/getting-started/introduction",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{subdomain}.neetoform.com/api/external/v1",
      "variables": {
        "subdomain": {
          "default": "your-subdomain",
          "description": "Your NeetoForm workspace subdomain"
        }
      }
    }
  ],
  "paths": {
    "/forms": {
      "get": {
        "operationId": "listForms",
        "summary": "List forms",
        "description": "Returns a paginated list of all forms in your workspace.",
        "tags": [
          "Forms"
        ],
        "parameters": [
          {
            "name": "page_number",
            "in": "query",
            "description": "Page number for pagination",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "Number of results per page",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 30
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FormListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/forms/{form_id}/submissions": {
      "get": {
        "operationId": "listSubmissions",
        "summary": "List submissions",
        "description": "Returns a paginated list of submissions for a specific form.",
        "tags": [
          "Submissions"
        ],
        "parameters": [
          {
            "name": "form_id",
            "in": "path",
            "description": "Unique ID of the form",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page_number",
            "in": "query",
            "description": "Page number for pagination",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "Number of results per page",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 30
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/team_members": {
      "get": {
        "operationId": "listTeamMembers",
        "summary": "List team members",
        "description": "Returns a paginated list of team members in your workspace.",
        "tags": [
          "Team Members"
        ],
        "parameters": [
          {
            "name": "page_number",
            "in": "query",
            "description": "Page number for pagination",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "Number of results per page",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 30
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TeamMemberListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "addTeamMembers",
        "summary": "Add team members",
        "description": "Adds one or more team members to the workspace by email.",
        "tags": [
          "Team Members"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddTeamMembersRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Team members added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Users added successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "removeTeamMembers",
        "summary": "Remove team members",
        "description": "Removes one or more team members from the workspace by email.",
        "tags": [
          "Team Members"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "emails"
                ],
                "properties": {
                  "emails": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "email"
                    },
                    "description": "Array of email addresses to remove"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Team members removed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Team member has been removed"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/team_members/{team_member_id}": {
      "patch": {
        "operationId": "updateTeamMember",
        "summary": "Update team member",
        "description": "Updates a specific team member's details.",
        "tags": [
          "Team Members"
        ],
        "parameters": [
          {
            "name": "team_member_id",
            "in": "path",
            "description": "ID of the team member to update",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTeamMemberRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Team member updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "team_member": {
                      "$ref": "#/components/schemas/TeamMember"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Form": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique form identifier"
          },
          "title": {
            "type": "string",
            "description": "Form title"
          },
          "is_published": {
            "type": "boolean",
            "description": "Whether the form is published"
          },
          "state": {
            "type": "string",
            "description": "Form state"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          },
          "submissions_count": {
            "type": "integer",
            "description": "Total number of submissions"
          },
          "attempt_url": {
            "type": "string",
            "description": "URL to attempt the form"
          },
          "is_archived": {
            "type": "boolean",
            "description": "Whether the form is archived"
          },
          "is_disabled": {
            "type": "boolean",
            "description": "Whether the form is disabled"
          },
          "is_suspended": {
            "type": "boolean",
            "description": "Whether the form is suspended"
          },
          "created_by": {
            "type": "string",
            "description": "Creator identifier"
          }
        }
      },
      "FormListResponse": {
        "type": "object",
        "properties": {
          "forms": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Form"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          },
          "total_count": {
            "type": "integer"
          }
        }
      },
      "Submission": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique submission identifier"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Submission timestamp"
          },
          "field_values": {
            "type": "object",
            "description": "Key-value map of field responses"
          },
          "user_agent": {
            "type": "string",
            "description": "Browser user agent string"
          },
          "responses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "position": {
                  "type": "integer"
                },
                "kind": {
                  "type": "string"
                },
                "slug": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "SubmissionListResponse": {
        "type": "object",
        "properties": {
          "submissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Submission"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          },
          "total_count": {
            "type": "integer"
          }
        }
      },
      "TeamMember": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique team member identifier"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address"
          },
          "first_name": {
            "type": "string",
            "description": "First name"
          },
          "last_name": {
            "type": "string",
            "description": "Last name"
          },
          "time_zone": {
            "type": "string",
            "description": "Timezone identifier"
          },
          "organization_role": {
            "type": "string",
            "description": "Role in the organization"
          },
          "active": {
            "type": "boolean",
            "description": "Whether the member is active"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TeamMemberListResponse": {
        "type": "object",
        "properties": {
          "team_members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TeamMember"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "AddTeamMembersRequest": {
        "type": "object",
        "required": [
          "emails"
        ],
        "properties": {
          "emails": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "email"
            },
            "description": "Array of email addresses to invite"
          },
          "organization_role": {
            "type": "string",
            "description": "Role to assign",
            "default": "Standard"
          },
          "invited_by": {
            "type": "string",
            "format": "email",
            "description": "Admin email sending the invitation"
          },
          "send_invitation_email": {
            "type": "boolean",
            "description": "Whether to send invitation emails",
            "default": true
          }
        }
      },
      "UpdateTeamMemberRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "time_zone": {
            "type": "string"
          },
          "organization_role": {
            "type": "string"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "total_records": {
            "type": "integer"
          },
          "total_pages": {
            "type": "integer"
          },
          "current_page_number": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Api-Key",
        "description": "API key for authentication"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Forms"
    },
    {
      "name": "Submissions"
    },
    {
      "name": "Team Members"
    }
  ]
}
