  "components": {
    "parameters": {
      "format": {
        "name": "format",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": [
            "xml",
            "json",
            "csl",
            "bibtex",
            "endnote"
          ],
          "default": "xml"
        },
        "description": "Response format. CSL, BibTeX, and EndNote are output-only for publications."
      },
      "start": {
        "name": "start",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "description": "Pagination start index (0-based)."
      },
      "end": {
        "name": "end",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 0,
          "default": 20
        },
        "description": "Pagination end index (exclusive)."
      },
      "username": {
        "name": "username",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Username."
      },
      "resourceHash": {
        "name": "resourceHash",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Resource hash identifier for a post."
      },
      "fileName": {
        "name": "fileName",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Document file name."
      },
      "groupname": {
        "name": "groupname",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Group name."
      },
      "personid": {
        "name": "personid",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Person identifier."
      },
      "conceptname": {
        "name": "conceptname",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Concept name."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Username."
          }
        }
      },
      "UserList": {
        "type": "object",
        "properties": {
          "stat": {
            "type": "string",
            "enum": [
              "ok",
              "fail"
            ]
          },
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          }
        }
      },
      "Post": {
        "type": "object",
        "properties": {
          "resource": {
            "type": "object",
            "description": "The publication or bookmark resource."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags associated with the post."
          },
          "user": {
            "type": "string",
            "description": "Owner username."
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "Post creation date."
          }
        }
      },
      "PostList": {
        "type": "object",
        "properties": {
          "stat": {
            "type": "string",
            "enum": [
              "ok",
              "fail"
            ]
          },
          "posts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Post"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "stat": {
            "type": "string",
            "enum": [
              "fail"
            ]
          },
          "error": {
            "type": "string",
            "description": "Error message."
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication with BibSonomy username and API key."
      }
    }
