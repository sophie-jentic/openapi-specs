{
  "openapi": "3.0.3",
  "info": {
    "title": "Instafill API",
    "description": "Instafill AI automates form filling using AI-powered document processing. Upload forms, manage profiles, and create sessions to automatically populate PDF forms with data.",
    "version": "1.0.5",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.instafill.ai"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/v1/account/me": {
      "get": {
        "summary": "Get Account Information",
        "description": "Retrieve information about the current authenticated account.",
        "tags": [
          "Account"
        ],
        "operationId": "getAccountInfo",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/forms/upload": {
      "post": {
        "summary": "Upload Form",
        "description": "Upload a PDF form to be used for filling.",
        "tags": [
          "Forms"
        ],
        "operationId": "uploadForm",
        "parameters": [
          {
            "name": "X-File-Name",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The PDF form file to upload"
                  },
                  "payload": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    },
                    "description": "Optional key-value pairs, e.g. url: value"
                  }
                }
              }
            },
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            },
            "application/pdf": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Form uploaded successfully"
          }
        }
      }
    },
    "/v1/forms/{id}": {
      "get": {
        "summary": "Get Form by ID",
        "description": "Retrieve a specific form by its ID.",
        "tags": [
          "Forms"
        ],
        "operationId": "getFormById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The form ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/forms": {
      "get": {
        "summary": "List Forms",
        "description": "Retrieve a list of all uploaded forms.",
        "tags": [
          "Forms"
        ],
        "operationId": "listForms",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/forms/search": {
      "get": {
        "summary": "Search Forms",
        "description": "Search for forms using a query string.",
        "tags": [
          "Forms"
        ],
        "operationId": "searchForms",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            },
            "description": "Number of results to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            },
            "description": "Offset for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/integrations/n8n/hooks/subscribe": {
      "post": {
        "summary": "Subscribe N8n Webhook",
        "description": "Subscribe to webhook events for N8n integration.",
        "tags": [
          "N8n"
        ],
        "operationId": "subscribeN8nWebhook",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscribeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/integrations/n8n/hooks/{id}": {
      "delete": {
        "summary": "Delete N8n Webhook",
        "description": "Delete a subscribed N8n webhook.",
        "tags": [
          "N8n"
        ],
        "operationId": "deleteN8nWebhook",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Webhook ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/profiles": {
      "get": {
        "summary": "List Profiles",
        "description": "Retrieve a paginated list of profiles.",
        "tags": [
          "Profile"
        ],
        "operationId": "listProfiles",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "default": ""
            }
          },
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string",
              "default": ""
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "post": {
        "summary": "Create Profile",
        "description": "Create a new profile for form filling.",
        "tags": [
          "Profile"
        ],
        "operationId": "createProfile",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/profiles/{profileId}": {
      "get": {
        "summary": "Get Profile",
        "description": "Retrieve a specific profile by ID.",
        "tags": [
          "Profile"
        ],
        "operationId": "getProfile",
        "parameters": [
          {
            "name": "profileId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "put": {
        "summary": "Update Profile Text Info",
        "description": "Update the text information of a profile.",
        "tags": [
          "Profile"
        ],
        "operationId": "updateProfileTextInfo",
        "parameters": [
          {
            "name": "profileId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileTextInfoRequestBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/profiles/{profileId}/name": {
      "patch": {
        "summary": "Update Profile Name",
        "description": "Update the name of a profile.",
        "tags": [
          "Profile"
        ],
        "operationId": "updateProfileName",
        "parameters": [
          {
            "name": "profileId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileNameRequestBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/profiles/{profileId}/files": {
      "post": {
        "summary": "Upload Profile Files",
        "description": "Upload files associated with a profile.",
        "tags": [
          "Profile"
        ],
        "operationId": "uploadProfileFiles",
        "parameters": [
          {
            "name": "profileId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "files"
                ],
                "properties": {
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  },
                  "textInfo": {
                    "type": "string",
                    "nullable": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/sessions": {
      "post": {
        "summary": "Create Session",
        "description": "Create a new form filling session.",
        "tags": [
          "Session"
        ],
        "operationId": "createSession",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequestBody"
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "formId"
                ],
                "properties": {
                  "formId": {
                    "type": "string"
                  },
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  },
                  "profileIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "textInfo": {
                    "type": "string",
                    "nullable": true
                  },
                  "signatureUrl": {
                    "type": "string",
                    "nullable": true
                  },
                  "sessionId": {
                    "type": "string",
                    "nullable": true
                  },
                  "isBatch": {
                    "type": "boolean",
                    "nullable": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "get": {
        "summary": "List Sessions",
        "description": "Retrieve a list of all sessions.",
        "tags": [
          "Session"
        ],
        "operationId": "listSessions",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/sessions/{id}": {
      "get": {
        "summary": "Get Session",
        "description": "Retrieve a specific session by ID, including the filled form.",
        "tags": [
          "Session"
        ],
        "operationId": "getSession",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetSessionResponseBody"
                }
              },
              "application/pdf": {
                "schema": {
                  "$ref": "#/components/schemas/GetSessionResponseBody"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseBody"
                }
              }
            }
          },
          "500": {
            "description": "Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseBody"
                }
              }
            }
          }
        }
      }
    },
    "/v1/utils/convert": {
      "post": {
        "summary": "Convert PDF to Fillable Form",
        "description": "Convert a PDF document to a fillable form.",
        "tags": [
          "Utils"
        ],
        "operationId": "convertPdfToForm",
        "parameters": [
          {
            "name": "pages",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "confidence",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 0.1
            }
          },
          {
            "name": "resolution",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1600
            }
          },
          {
            "name": "allowCheckboxes",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "autoConfirm",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "X-File-Name",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Use-Cache",
            "in": "header",
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "payload": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    },
                    "description": "Optional key-value pairs"
                  }
                }
              }
            },
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            },
            "application/pdf": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/utils/convert/{jobId}/status": {
      "get": {
        "summary": "Get Conversion Status",
        "description": "Check the status of a PDF conversion job.",
        "tags": [
          "Utils"
        ],
        "operationId": "getConversionStatus",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/utils/check-flat": {
      "post": {
        "summary": "Check if PDF is Flat",
        "description": "Check if a PDF document is flat (non-fillable).",
        "tags": [
          "Utils"
        ],
        "operationId": "checkPdfFlat",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "payload": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            },
            "application/pdf": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/integrations/zapier/hooks/subscribe": {
      "post": {
        "summary": "Subscribe Zapier Webhook",
        "description": "Subscribe to webhook events for Zapier integration.",
        "tags": [
          "Zapier"
        ],
        "operationId": "subscribeZapierWebhook",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscribeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/integrations/zapier/hooks/{id}": {
      "delete": {
        "summary": "Delete Zapier Webhook",
        "description": "Delete a subscribed Zapier webhook.",
        "tags": [
          "Zapier"
        ],
        "operationId": "deleteZapierWebhook",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/v1/integrations/zapier/hooks/sample": {
      "get": {
        "summary": "Get Sample Webhook Payload",
        "description": "Retrieve a sample webhook payload for testing.",
        "tags": [
          "Zapier"
        ],
        "operationId": "getZapierWebhookSample",
        "parameters": [
          {
            "name": "event_type",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateSessionRequestBody": {
        "type": "object",
        "properties": {
          "form_id": {
            "type": "string",
            "nullable": true
          },
          "file_urls": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "text_info": {
            "type": "string",
            "nullable": true
          },
          "profile_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "session_id": {
            "type": "string",
            "nullable": true
          },
          "is_batch": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponseBody": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "statusCode": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "error_message": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "GetSessionResponseBody": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "filled_form_url": {
            "type": "string",
            "nullable": true
          },
          "filled_form_base64": {
            "type": "string",
            "nullable": true
          },
          "fields": {
            "type": "array",
            "items": {},
            "nullable": true
          }
        }
      },
      "UpdateProfileNameRequestBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "UpdateProfileTextInfoRequestBody": {
        "type": "object",
        "properties": {
          "textInfo": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "WebhookSubscribeRequest": {
        "type": "object",
        "properties": {
          "hookUrl": {
            "type": "string",
            "nullable": true
          },
          "event_type": {
            "type": "string",
            "nullable": true
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Key",
        "description": "Enter your API key like: Bearer {API_KEY}"
      }
    }
  },
  "tags": [
    {
      "name": "Account"
    },
    {
      "name": "Forms"
    },
    {
      "name": "N8n"
    },
    {
      "name": "Profile"
    },
    {
      "name": "Session"
    },
    {
      "name": "Utils"
    },
    {
      "name": "Zapier"
    }
  ]
}
