{
  "openapi": "3.0.3",
  "info": {
    "title": "Bitdefender GravityZone Public API",
    "version": "1.0.0",
    "description": "Bitdefender GravityZone Control Center API for automating business workflows. Uses JSON-RPC 2.0 protocol over HTTP POST. Each API targets a distinct product area (Accounts, Companies, Network, Policies, etc.). Rate limited to a specific number of requests per second per API key.",
    "x-jentic-source-url": "https://www.bitdefender.com/business/support/en/77209-125277-public-api.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{accessUrl}",
      "description": "GravityZone Control Center API. Replace {accessUrl} with your CONTROL_CENTER_APIs_ACCESS_URL found in My Account > Control Center API section.",
      "variables": {
        "accessUrl": {
          "default": "gravityzone.bitdefender.com",
          "description": "Your GravityZone access URL"
        }
      }
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Accounts",
      "description": "User account management"
    },
    {
