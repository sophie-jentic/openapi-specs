    },
    {
      "name": "Policies",
      "description": "Security policy management"
    },
    {
      "name": "Push",
      "description": "Push notification settings"
    },
    {
      "name": "Quarantine",
      "description": "Quarantine management"
    },
    {
      "name": "Reports",
      "description": "Report generation and management"
    }
  ],
  "paths": {
    "/v1.0/jsonrpc/accounts": {
      "post": {
        "operationId": "accountsJsonRpc",
        "summary": "Accounts API (JSON-RPC 2.0)",
        "description": "Manage user accounts. Supported methods: getAccountsList, deleteAccount, createAccount, updateAccount, configureNotificationsSettings, getNotificationsSettings.",
        "tags": [
          "Accounts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JsonRpcRequest"
              },
              "examples": {
                "getAccountsList": {
                  "summary": "List user accounts",
                  "value": {
                    "id": "787b5e36-89a8-4353-88b9-6b7a32e9c87f",
                    "jsonrpc": "2.0",
                    "method": "getAccountsList",
                    "params": {
                      "perPage": 20,
                      "page": 1
                    }
                  }
                },
                "createAccount": {
                  "summary": "Create user account",
                  "value": {
                    "id": "91d6430d-bfd4-494f-8d4d-4947406d21a7",
                    "jsonrpc": "2.0",
                    "method": "createAccount",
                    "params": {
                      "email": "user@example.com",
                      "profile": {
                        "fullName": "User Name",
                        "language": "en_US",
                        "timezone": "US/Eastern"
                      },
                      "role": 5,
                      "rights": {
                        "manageNetworks": true,
                        "manageReports": true
                      }
                    }
                  }
                },
                "deleteAccount": {
                  "summary": "Delete user account",
                  "value": {
                    "id": "91d6430d-bfd4-494f-8d4d-4947406d21a7",
                    "jsonrpc": "2.0",
                    "method": "deleteAccount",
                    "params": {
                      "accountId": "585d3170aaed70b7048b4633"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JSON-RPC response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JsonRpcResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed (incorrect or missing API key)."
          },
          "403": {
            "description": "API not enabled for this key."
          },
          "405": {
            "description": "HTTP method not POST."
          },
          "429": {
            "description": "Rate limit exceeded (>10 req/s per API key).",
            "headers": {
              "Retry-After": {
                "schema": {
                  "type": "integer"
                },
                "description": "Seconds until rate limit resets."
              }
            }
          }
        }
      }
    },
