  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Auth. Username is the API key, password is empty. API keys are generated in GravityZone Control Center > My Account > API Keys."
      }
    },
    "schemas": {
      "JsonRpcRequest": {
        "type": "object",
        "required": [
          "id",
          "jsonrpc",
          "method"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique request identifier."
          },
          "jsonrpc": {
            "type": "string",
            "enum": [
              "2.0"
            ],
            "description": "JSON-RPC version (always '2.0')."
          },
          "method": {
            "type": "string",
            "description": "The API method to call."
          },
          "params": {
            "type": "object",
            "description": "Method parameters (required and optional vary by method)."
          }
        }
      },
      "JsonRpcResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Request identifier from the original request."
          },
          "jsonrpc": {
            "type": "string",
            "enum": [
              "2.0"
            ]
          },
          "result": {
            "description": "Method result (null for void methods, object for data-returning methods)."
          },
          "error": {
            "$ref": "#/components/schemas/JsonRpcError"
          }
        }
      },
      "JsonRpcError": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Error code per JSON-RPC 2.0 spec. -32700=Parse error, -32600=Invalid request, -32601=Method not found, -32602=Invalid params, -32000=Server error."
          },
          "message": {
            "type": "string",
            "description": "Error message."
          },
          "data": {
            "type": "object",
            "properties": {
              "details": {
                "type": "string",
                "description": "Full error description."
              }
            }
          }
        }
      },
      "AccountListResult": {
        "type": "object",
        "description": "Result from getAccountsList method.",
        "properties": {
          "total": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "perPage": {
            "type": "integer"
          },
          "pagesCount": {
            "type": "integer"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Account"
            }
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "profile": {
            "type": "object",
            "properties": {
              "fullName": {
                "type": "string"
              },
              "timezone": {
                "type": "string"
              },
              "language": {
                "type": "string"
              },
              "landingPage": {
                "type": "string"
              }
            }
          },
          "role": {
            "type": "integer",
            "description": "1=Company Admin, 2=Network Admin, 3=Reporter, 5=Custom."
          },
          "rights": {
            "type": "object",
            "properties": {
              "companyManager": {
                "type": "boolean"
              },
              "manageCompanies": {
                "type": "boolean"
              },
              "manageNetworks": {
                "type": "boolean"
              },
              "manageInventory": {
                "type": "boolean"
              },
              "managePoliciesRead": {
                "type": "boolean"
              },
              "managePoliciesWrite": {
                "type": "boolean"
              },
              "manageReports": {
                "type": "boolean"
              },
              "manageUsers": {
                "type": "boolean"
              },
              "manageRemoteShell": {
                "type": "boolean"
              }
            }
          },
          "passwordLifetime": {
            "type": "integer",
            "description": "0=never expires, 90=expires every 90 days."
          },
          "accountLockdown": {
            "type": "boolean"
          },
          "twoFactorAuthenticationStatus": {
            "type": "boolean"
          },
          "companyName": {
            "type": "string"
          },
          "companyId": {
            "type": "string"
          },
          "authenticationMethod": {
            "type": "integer",
            "description": "0=GravityZone, 1=IdP, 2=GravityZone IdP, -1=Invalid."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "integer"
              },
              "message": {
                "type": "string"
              },
              "data": {
                "type": "object",
                "properties": {
                  "details": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
