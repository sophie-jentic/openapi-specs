    "/recipe/signin": {
      "post": {
        "tags": [
          "Auth"
        ],
        "operationId": "signIn",
        "summary": "Sign in with email/password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "formFields": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "value": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sign in result"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Sign in with email/password"
      }
    },
    "/recipe/signup": {
      "post": {
