    "contact": {
      "name": "SuperTokens",
      "url": "https://supertokens.com"
    }
  },
  "servers": [
    {
      "url": "https://try.supertokens.com",
      "description": "SuperTokens Core (demo)"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
