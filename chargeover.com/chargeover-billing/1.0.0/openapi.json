{
  "openapi": "3.0.3",
  "info": {
    "title": "ChargeOver Billing API",
    "version": "1.0.0",
    "description": "ChargeOver is a recurring billing and invoicing platform. The REST API provides endpoints for managing customers, contacts, subscriptions, invoices, payments, credit cards, and ACH accounts. Supports JSON request/response format.",
    "x-jentic-source-url": "https://developer.chargeover.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{subdomain}.chargeover.com/api/v3",
      "description": "ChargeOver REST API v3",
      "variables": {
        "subdomain": {
          "default": "yourcompany",
          "description": "Your ChargeOver subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Customers",
      "description": "Customer management"
    },
    {
      "name": "Contacts",
      "description": "Contact management"
    },
    {
      "name": "Subscriptions",
      "description": "Subscription/package management"
    },
    {
      "name": "Invoices",
      "description": "Invoice management"
    },
    {
      "name": "Payments",
      "description": "Payment management"
    },
    {
      "name": "Credit Cards",
      "description": "Credit card management"
    },
    {
      "name": "ACH",
      "description": "ACH/bank account management"
    }
  ],
  "paths": {
    "/customer": {
      "get": {
        "operationId": "listCustomers",
        "summary": "List customers",
        "description": "Returns a list of customer accounts.",
        "tags": [
          "Customers"
        ],
        "parameters": [
          {
            "name": "where",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter condition (e.g., company_name:EQUALS:Acme)"
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sort order (e.g., customer_id:ASC)"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Pagination offset"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Maximum results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Customer list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomerListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCustomer",
        "summary": "Create a customer",
        "tags": [
          "Customers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCustomerRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Customer created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create a customer"
      }
    },
