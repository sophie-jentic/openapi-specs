                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Delete Contact"
      }
    },
    "/forms": {
      "get": {
        "summary": "Get Forms",
        "operationId": "getForms",
        "tags": [
          "Forms"
        ],
        "parameters": [
          {
            "name": "list",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "published",
                "drafts",
                "archived",
                "all_with_archived"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page_length",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "description": "Get Forms"
      },
      "delete": {
        "summary": "Delete Form",
        "operationId": "deleteForm",
