{
  "openapi": "3.0.3",
  "info": {
    "title": "Findwork API",
    "description": "The Findwork API provides access to job listings aggregated from multiple sources, focusing on tech and remote positions. Built on Django REST Framework, it returns JSON responses with job data including company info, roles, locations, and application details.",
    "version": "1.0.0",
    "contact": {
      "name": "Findwork",
      "url": "https://findwork.dev"
    },
    "x-jentic-source-url": "https://findwork.dev/developers/"
  },
  "servers": [
    {
      "url": "https://findwork.dev/api",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "Jobs",
      "description": "Job listing operations"
    }
  ],
  "paths": {
    "/jobs": {
      "get": {
        "operationId": "listJobs",
        "summary": "List job listings",
        "description": "Retrieve a paginated list of job listings. Supports filtering by search query, location, company, and other parameters.",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Free text search query for job title or keywords",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Filter by job location",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "company_name",
            "in": "query",
            "description": "Filter by company name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "remote",
            "in": "query",
            "description": "Filter for remote positions only",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "employment_type",
            "in": "query",
            "description": "Filter by employment type (e.g., full time, part time, contract)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Sort results (e.g., relevance, date)",
            "schema": {
              "type": "string",
              "enum": [
                "relevance",
                "date"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Response format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "api"
              ],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with paginated job listings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedJobList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token-based authentication. Format: 'Token YOUR_API_KEY'"
      }
    },
    "schemas": {
      "PaginatedJobList": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "description": "Total number of results"
          },
          "next": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "URL for the next page of results"
          },
          "previous": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "URL for the previous page of results"
          },
          "results": {
            "type": "array",
            "description": "Array of job listings",
            "items": {
              "$ref": "#/components/schemas/Job"
            }
          }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique job identifier"
          },
          "role": {
            "type": "string",
            "description": "Job role/title"
          },
          "company_name": {
            "type": "string",
            "description": "Name of the hiring company"
          },
          "company_num_employees": {
            "type": "string",
            "nullable": true,
            "description": "Company size range"
          },
          "employment_type": {
            "type": "string",
            "nullable": true,
            "description": "Type of employment (full time, part time, contract, etc.)"
          },
          "location": {
            "type": "string",
            "description": "Job location"
          },
          "remote": {
            "type": "boolean",
            "description": "Whether the position is remote"
          },
          "logo": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "URL of the company logo"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the job listing"
          },
          "text": {
            "type": "string",
            "description": "Job description text"
          },
          "date_posted": {
            "type": "string",
            "format": "date-time",
            "description": "Date the job was posted"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Keywords/tags associated with the job"
          },
          "source": {
            "type": "string",
            "description": "Source of the job listing"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "description": "Error detail message"
          }
        }
      }
    }
  }
}
