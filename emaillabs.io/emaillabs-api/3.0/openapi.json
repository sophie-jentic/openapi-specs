  "components": {
    "schemas": {
      "SendEmailRequest": {
        "type": "object",
        "required": [
          "to",
          "smtp_account",
          "subject"
        ],
        "properties": {
          "to": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "message_id": {
                  "type": "string"
                }
              }
            }
          },
          "smtp_account": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "from": {
            "type": "string",
            "format": "email"
          },
          "from_name": {
            "type": "string"
          },
          "reply_to": {
            "type": "string"
          },
          "headers": {
            "type": "object"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "template_id": {
            "type": "string"
          },
          "vars": {
            "type": "object"
          }
        }
      },
      "SendEmailResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        }
      },
      "TemplateListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Template"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "Email": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        }
      },
      "EmailListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Email"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "EventListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "event_type": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "message_id": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "string"
