        "responses": {
          "200": {
            "description": "Blacklist entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "email": {
                            "type": "string"
                          },
                          "created_at": {
                            "type": "string"
                          },
                          "reason": {
                            "type": "string"
                          }
