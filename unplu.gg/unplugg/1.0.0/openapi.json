{
  "openapi": "3.0.3",
  "info": {
    "title": "Unplugg API",
    "description": "Forecasting API for timeseries data with seasonal patterns. Provides asynchronous forecast generation with webhook-based result delivery. Supports automatic resampling for non-equally-spaced data.",
    "version": "1.0.0",
    "contact": {
      "name": "Unplugg",
      "url": "https://unplu.gg"
    },
    "x-jentic-source-url": "https://unplu.gg/test_api.html"
  },
  "servers": [
    {
      "url": "https://api.unplu.gg",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "accessToken": []
    }
  ],
  "tags": [
    {
      "name": "Forecasting",
      "description": "Generate forecasts for timeseries data"
    }
  ],
  "paths": {
    "/forecast": {
      "post": {
        "operationId": "createForecast",
        "summary": "Generate a timeseries forecast",
        "description": "Submits timeseries data for asynchronous forecast generation. Results are delivered via the specified callback webhook URL. If forecast_to is not specified, the forecast length defaults to 1/8 of the input data points. The API automatically resamples non-equally-spaced data.",
        "tags": [
          "Forecasting"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForecastRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Forecast job accepted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForecastAccepted"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable entity - malformed payload or invalid data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ForecastRequest": {
        "type": "object",
        "required": [
          "data",
          "callback"
        ],
        "properties": {
          "data": {
            "type": "array",
            "description": "Timeseries data points with timestamp and value pairs.",
            "items": {
              "$ref": "#/components/schemas/DataPoint"
            },
            "minItems": 1
          },
          "callback": {
            "type": "string",
            "format": "uri",
            "description": "Webhook URL where forecast results will be delivered."
          },
          "forecast_to": {
            "type": "integer",
            "description": "Unix timestamp (seconds) for the forecast end date. If omitted, defaults to 1/8 of the input data length."
          }
        },
        "example": {
          "data": [
            {
              "timestamp": 1466640000,
              "value": 0.275
            },
            {
              "timestamp": 1466726400,
              "value": 0.312
            },
            {
              "timestamp": 1466812800,
              "value": 0.289
            }
          ],
          "forecast_to": 1458136800,
          "callback": "http://your.domain/yourcallback"
        }
      },
      "DataPoint": {
        "type": "object",
        "required": [
          "timestamp",
          "value"
        ],
        "properties": {
          "timestamp": {
            "type": "integer",
            "description": "Unix timestamp in seconds."
          },
          "value": {
            "type": "number",
            "description": "Numeric value at the given timestamp."
          }
        }
      },
      "ForecastAccepted": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "string",
            "description": "Unique identifier for the forecast job."
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error type or code."
          },
          "message": {
            "type": "string",
            "description": "Human-readable error description."
          }
        }
      }
    },
    "securitySchemes": {
      "accessToken": {
        "type": "apiKey",
        "in": "header",
        "name": "accessToken"
      }
    }
  }
}
