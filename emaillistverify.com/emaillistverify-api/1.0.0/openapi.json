{
  "openapi": "3.0.3",
  "info": {
    "title": "EmailListVerify API",
    "version": "1.0.0",
    "description": "EmailListVerify provides email verification services to validate email addresses in real-time. Supports single email verification and bulk list verification.",
    "x-jentic-source-url": "https://emaillistverify.com/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://apps.emaillistverify.com",
      "description": "EmailListVerify API"
    }
  ],
  "tags": [
    {
      "name": "Single Verification",
      "description": "Verify individual email addresses"
    },
    {
      "name": "Bulk Verification",
      "description": "Bulk email list verification"
    },
    {
      "name": "Disposable Check",
      "description": "Disposable email detection"
    }
  ],
  "paths": {
    "/api/verifyEmail": {
      "get": {
        "operationId": "verifyEmail",
        "summary": "Verify single email address",
        "description": "Verify an email address in real-time. Returns verification status and details.",
        "tags": [
          "Single Verification"
        ],
        "parameters": [
          {
            "name": "secret",
            "in": "query",
            "required": true,
            "description": "Your API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "email",
            "in": "query",
            "required": true,
            "description": "Email address to verify",
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "timeout",
            "in": "query",
            "required": false,
            "description": "Timeout in seconds",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "Status code: ok, fail, unknown, email_disabled, domain_error, disposable, catch_all, role_based, etc."
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid API key"
          }
        }
      }
    },
    "/api/verifyApiEmailList": {
      "post": {
        "operationId": "submitBulkVerification",
        "summary": "Submit bulk email list for verification",
        "description": "Upload a file with email addresses for bulk verification.",
        "tags": [
          "Bulk Verification"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "secret",
                  "filename"
                ],
                "properties": {
                  "secret": {
                    "type": "string",
                    "description": "API key"
                  },
                  "filename": {
                    "type": "string",
                    "format": "binary",
                    "description": "CSV file with email addresses"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk job submitted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkSubmitResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/getApiFileInfo": {
      "get": {
        "operationId": "getBulkFileInfo",
        "summary": "Get bulk verification file status",
        "description": "Check the status and info for a bulk verification file.",
        "tags": [
          "Bulk Verification"
        ],
        "parameters": [
          {
            "name": "secret",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "File ID from the submit response",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkFileInfo"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/disposable": {
      "get": {
        "operationId": "checkDisposable",
        "summary": "Check if email is disposable",
        "description": "Check whether an email address uses a disposable/temporary domain.",
        "tags": [
          "Disposable Check"
        ],
        "parameters": [
          {
            "name": "secret",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Disposable check result",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "true or false"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BulkSubmitResponse": {
        "type": "object",
        "properties": {
          "file_id": {
            "type": "string",
            "description": "ID of the uploaded file"
          },
          "message": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "BulkFileInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "description": "Processing status: pending, processing, completed"
          },
          "total": {
            "type": "integer",
            "description": "Total emails in file"
          },
          "processed": {
            "type": "integer",
            "description": "Emails processed"
          },
          "ok": {
            "type": "integer",
            "description": "Valid emails count"
          },
          "fail": {
            "type": "integer",
            "description": "Invalid emails count"
          },
          "unknown": {
            "type": "integer",
            "description": "Unknown status count"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}
