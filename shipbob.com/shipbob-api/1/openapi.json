  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Personal Access Token (PAT) or OAuth2 bearer token"
      }
    },
    "schemas": {
      "ChannelListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Channel"
            }
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "Channel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "application_name": {
            "type": "string"
          }
        }
      },
      "OrderViewModel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "reference_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "created_date": {
            "type": "string",
            "format": "date-time"
          },
          "shipments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ShipmentViewModel"
            }
          }
        }
      },
      "OrderListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderViewModel"
            }
          }
        }
      },
      "CreateOrderModel": {
        "type": "object",
        "properties": {
          "reference_id": {
            "type": "string"
          },
          "shipping_method": {
            "type": "string"
          },
          "recipient": {
            "$ref": "#/components/schemas/Recipient"
          },
          "products": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderProduct"
            }
          }
        },
        "required": [
          "reference_id",
          "recipient",
          "products"
        ]
      },
      "Recipient": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "email": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "address1": {
            "type": "string"
          },
          "address2": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "zip_code": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        }
      },
      "OrderProduct": {
        "type": "object",
        "properties": {
          "reference_id": {
            "type": "string"
          },
          "quantity": {
            "type": "integer"
          }
        }
      },
      "ShipmentViewModel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "tracking_number": {
            "type": "string"
          },
          "shipping_method": {
            "type": "string"
          },
          "estimated_delivery_date": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CancelledOrderResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "reference_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ShipmentLogList": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/ShipmentLog"
        }
      },
      "ShipmentLog": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "BatchCancelShipmentsModel": {
        "type": "object",
        "properties": {
          "shipment_ids": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        }
      },
      "CancelledShipmentsResponse": {
        "type": "object",
        "properties": {
          "cancelled": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "failed": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        }
      },
      "ShippingMethodList": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/ShippingMethod"
        }
      },
      "ShippingMethod": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
