              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/2026-01/order/{orderId}:cancel": {
      "post": {
        "operationId": "cancel-order",
        "summary": "Cancel Order",
        "description": "Cancels an order and all associated shipments.",
