{
  "openapi": "3.1.0",
  "info": {
    "title": "ShipBob API Reference",
    "version": "1.0.0",
    "description": "ShipBob fulfillment API for managing orders, shipments, channels, and shipping methods.",
    "x-jentic-source-url": "https://developer.shipbob.com/openapi.json?api=9ee91019-6c6d-450d-ac5f-ed738d912fbc",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.shipbob.com"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
