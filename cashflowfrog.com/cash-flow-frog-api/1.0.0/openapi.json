{
  "openapi": "3.0.3",
  "info": {
    "title": "Cash Flow Frog API",
    "version": "1.0.0",
    "description": "Cash Flow Frog API for creating financial projections programmatically.",
    "x-jentic-source-url": "https://help.cashflowfrog.com/en/articles/5900737-cash-flow-frog-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.cashflowfrog.com"
    }
  ],
  "paths": {
    "/webhooks/projections": {
      "post": {
        "operationId": "createProjection",
        "summary": "Create a projection",
        "description": "Create a new cash flow projection entry.",
        "tags": [
          "Projections"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProjectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Projection created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Projection"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
