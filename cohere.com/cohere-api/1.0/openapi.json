{
  "openapi": "3.0.3",
  "info": {
    "title": "Cohere API",
    "version": "1.0",
    "description": "The Cohere API for interacting with Chat, Embed, and Rerank models. Provides endpoints for text generation, embeddings, and reranking.",
    "x-jentic-source-url": "https://docs.cohere.com/reference/about",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.cohere.com"
    }
  ],
  "paths": {
    "/v1/chat": {
      "post": {
        "operationId": "chatV1",
        "summary": "Chat (v1)",
        "description": "Generates a text response to a user message with streaming support",
        "tags": [
          "Chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string"
                  },
                  "model": {
                    "type": "string"
                  },
                  "stream": {
                    "type": "boolean"
                  },
                  "temperature": {
                    "type": "number"
                  },
                  "max_tokens": {
                    "type": "integer"
                  },
                  "documents": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "tools": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  }
                },
                "required": [
                  "message"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/chat": {
      "post": {
        "operationId": "chatV2",
        "summary": "Chat (v2)",
        "description": "Generates a text response with SSE streaming support and tool calling",
        "tags": [
          "Chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "model": {
                    "type": "string"
                  },
                  "messages": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "stream": {
                    "type": "boolean"
                  },
                  "temperature": {
                    "type": "number"
                  },
                  "max_tokens": {
                    "type": "integer"
                  },
                  "tools": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "documents": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "safety_mode": {
                    "type": "string",
                    "enum": [
                      "CONTEXTUAL",
                      "STRICT",
                      "OFF"
                    ]
                  },
                  "response_format": {
                    "type": "object"
                  },
                  "tool_choice": {
                    "type": "string",
                    "enum": [
                      "REQUIRED",
                      "NONE"
                    ]
                  }
                },
                "required": [
                  "model",
                  "messages"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/embed": {
      "post": {
        "operationId": "embed",
        "summary": "Generate embeddings",
        "description": "Returns text embeddings for semantic search and classification",
        "tags": [
          "Embed"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "texts": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "model": {
                    "type": "string"
                  },
                  "input_type": {
                    "type": "string"
                  },
                  "embedding_types": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "truncate": {
                    "type": "string"
                  }
                },
                "required": [
                  "texts",
                  "model",
                  "input_type"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/rerank": {
      "post": {
        "operationId": "rerank",
        "summary": "Rerank documents",
        "description": "Reranks documents by relevance to a query",
        "tags": [
          "Rerank"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "documents": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "model": {
                    "type": "string"
                  },
                  "top_n": {
                    "type": "integer"
                  },
                  "return_documents": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "query",
                  "documents",
                  "model"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Chat"
    },
    {
      "name": "Embed"
    },
    {
      "name": "Rerank"
    }
  ]
}
