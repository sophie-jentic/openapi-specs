{
  "openapi": "3.0.3",
  "info": {
    "title": "Cockpit CMS Content API",
    "version": "2.0.0",
    "description": "Cockpit is a headless CMS with a REST API for managing content items (collections and singletons) and assets. Uses API key authentication via the api-key header. Supports MongoDB-style filtering, sorting, field projection, and pagination.",
    "x-jentic-source-url": "https://getcockpit.com/documentation/core/api/content",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{cockpit_host}/api",
      "variables": {
        "cockpit_host": {
          "default": "cockpit.example.com",
          "description": "Your Cockpit CMS instance hostname"
        }
      }
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Content",
      "description": "Manage content items and collections"
    },
    {
      "name": "Assets",
      "description": "Manage and retrieve assets"
    }
  ],
  "paths": {
    "/content/item/{model}": {
      "get": {
        "operationId": "getContentItem",
        "summary": "Get single content item",
        "description": "Get a single content item from a model (singleton).",
        "tags": [
          "Content"
        ],
        "parameters": [
          {
            "name": "model",
            "in": "path",
            "required": true,
            "description": "Model name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "locale",
            "in": "query",
            "description": "Return content for specified locale",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "URL-encoded filter JSON (MongoDB query syntax)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "URL-encoded fields projection as JSON",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "populate",
            "in": "query",
            "description": "Populate item with linked content items (1 to enable)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Content item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentItem"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "post": {
        "operationId": "createOrUpdateContentItem",
        "summary": "Create or update content item",
        "description": "Create a new content item or update an existing one in the specified model.",
        "tags": [
          "Content"
        ],
        "parameters": [
          {
            "name": "model",
            "in": "path",
            "required": true,
            "description": "Model name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContentItemCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Content item created or updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentItem"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/content/item/{model}/{id}": {
      "get": {
        "operationId": "getContentItemById",
        "summary": "Get content item by ID",
        "description": "Get a single content item by its ID.",
        "tags": [
          "Content"
        ],
        "parameters": [
          {
            "name": "model",
            "in": "path",
            "required": true,
            "description": "Model name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Content item ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "locale",
            "in": "query",
            "description": "Return content for specified locale",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "URL-encoded fields projection as JSON",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "populate",
            "in": "query",
            "description": "Populate item with linked content items",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Content item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentItem"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "operationId": "deleteContentItem",
        "summary": "Delete content item",
        "description": "Delete a content item by its ID.",
        "tags": [
          "Content"
        ],
        "parameters": [
          {
            "name": "model",
            "in": "path",
            "required": true,
            "description": "Model name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Content item ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Content item deleted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/content/items/{model}": {
      "get": {
        "operationId": "listContentItems",
        "summary": "List content items",
        "description": "Fetch data from a collection (content model with a list of items). Supports filtering, sorting, pagination, and field projection.",
        "tags": [
          "Content"
        ],
        "parameters": [
          {
            "name": "model",
            "in": "path",
            "required": true,
            "description": "Model name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "locale",
            "in": "query",
            "description": "Return content for specified locale",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "URL-encoded filter JSON (MongoDB query syntax)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "URL-encoded sort JSON (e.g., {_created:-1})",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "URL-encoded fields projection as JSON",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Max amount of items to return",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Amount of items to skip",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "populate",
            "in": "query",
            "description": "Populate items with linked content items",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of content items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ContentItem"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/content/items": {
      "get": {
        "operationId": "batchGetContentItems",
        "summary": "Batch request content from multiple models",
        "description": "Fetch content from multiple content models in a single request.",
        "tags": [
          "Content"
        ],
        "parameters": [
          {
            "name": "models",
            "in": "query",
            "required": true,
            "description": "Models query config as JSON string (e.g., {faq:{}, articles:{sort:{_created:-1}}})",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "locale",
            "in": "query",
            "description": "Return content for specified locale",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "populate",
            "in": "query",
            "description": "Populate items with linked content items",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Batch content results keyed by model name",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/ContentItem"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/content/tree/{model}": {
      "get": {
        "operationId": "getContentTree",
        "summary": "Get nested tree model items",
        "description": "Fetch nested tree model items for hierarchical content structures.",
        "tags": [
          "Content"
        ],
        "parameters": [
          {
            "name": "model",
            "in": "path",
            "required": true,
            "description": "Model name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "locale",
            "in": "query",
            "description": "Return content for specified locale",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "URL-encoded fields projection as JSON",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "populate",
            "in": "query",
            "description": "Populate items with linked content items",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tree of content items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TreeItem"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/assets/{id}": {
      "get": {
        "operationId": "getAsset",
        "summary": "Get asset by ID",
        "description": "Get asset object by asset ID.",
        "tags": [
          "Assets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Asset ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Asset object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Asset"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/assets/image/{id}": {
      "get": {
        "operationId": "getAssetImage",
        "summary": "Get asset image thumbnail",
        "description": "Generate thumbnails of image assets using the Image API.",
        "tags": [
          "Assets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Asset ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "m",
            "in": "query",
            "description": "Resize mode: thumbnail, bestFit, resize, fitToWidth, fitToHeight",
            "schema": {
              "type": "string",
              "enum": [
                "thumbnail",
                "bestFit",
                "resize",
                "fitToWidth",
                "fitToHeight"
              ]
            }
          },
          {
            "name": "w",
            "in": "query",
            "description": "Width in pixels",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "h",
            "in": "query",
            "description": "Height in pixels",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Quality (1-100)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "mime",
            "in": "query",
            "description": "Output MIME type: auto, gif, jpeg, png, webp, bmp",
            "schema": {
              "type": "string",
              "enum": [
                "auto",
                "gif",
                "jpeg",
                "png",
                "webp",
                "bmp"
              ]
            }
          },
          {
            "name": "re",
            "in": "query",
            "description": "Auto redirect to generated thumbnail (1 to enable)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "t",
            "in": "query",
            "description": "Time string for cache invalidation",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "o",
            "in": "query",
            "description": "Get binary of generated thumbnail (1 to enable)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Thumbnail image or metadata",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              },
              "image/*": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "api-key",
        "description": "Cockpit API key"
      }
    },
    "schemas": {
      "ContentItem": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "description": "Content item ID"
          },
          "_created": {
            "type": "integer",
            "description": "Unix timestamp of creation"
          },
          "_modified": {
            "type": "integer",
            "description": "Unix timestamp of last modification"
          }
        },
        "additionalProperties": true
      },
      "ContentItemCreateRequest": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "object",
            "description": "Content item data fields",
            "additionalProperties": true
          }
        }
      },
      "TreeItem": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TreeItem"
            }
          }
        },
        "additionalProperties": true
      },
      "Asset": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "mime": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "_created": {
            "type": "integer"
          },
          "_modified": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - missing or invalid API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}
