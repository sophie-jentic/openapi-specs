{
  "openapi": "3.0.3",
  "info": {
    "title": "Gathr API",
    "version": "1.0.0",
    "description": "Gathr API for managing events, profiles, and orders on the Gathr platform.",
    "x-jentic-source-url": "https://gathr.com/docs/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://gathr.com/api"
    }
  ],
  "paths": {
    "/me": {
      "post": {
        "operationId": "verifyApiKey",
        "summary": "Verify API key",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "API key verified",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "verified": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": [],
            "emailAuth": []
          }
        ],
        "description": "Verify API key"
      }
    },
    "/me/profiles": {
      "get": {
        "operationId": "listProfiles",
        "summary": "Get all profiles",
        "description": "Retrieve user's profiles (Host or Talent).",
        "tags": [
          "Profiles"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Profile"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": [],
            "emailAuth": []
          }
        ]
      }
    },
    "/me/hosts": {
      "get": {
        "operationId": "listHostProfiles",
        "summary": "Get host profiles",
        "tags": [
          "Profiles"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HostProfile"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": [],
            "emailAuth": []
          }
        ],
        "description": "Get host profiles"
      }
    },
    "/me/talent": {
      "get": {
        "operationId": "listTalentProfiles",
        "summary": "Get talent profiles",
        "tags": [
          "Profiles"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TalentProfile"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": [],
            "emailAuth": []
          }
        ],
        "description": "Get talent profiles"
      }
    },
    "/me/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "Get orders",
        "description": "Retrieve all orders for events that a user's profile has created or been booked into.",
        "tags": [
          "Orders"
        ],
        "parameters": [
          {
            "name": "profile_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "profile_slug",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Order"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": [],
            "emailAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Profile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "profile_name": {
            "type": "string"
          },
          "profile_type": {
            "type": "string"
          },
          "profile_description": {
            "type": "string"
          },
          "profile_url": {
            "type": "string"
          },
          "profile_avatar": {
            "type": "string"
          }
        }
      },
      "HostProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "host_name": {
            "type": "string"
          },
          "host_description": {
            "type": "string"
          },
          "host_url": {
            "type": "string"
          },
          "host_avatar": {
            "type": "string"
          }
        }
      },
      "TalentProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "talent_name": {
            "type": "string"
          },
          "talent_description": {
            "type": "string"
          },
          "talent_url": {
            "type": "string"
          },
          "talent_avatar": {
            "type": "string"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "order_date": {
            "type": "string",
            "format": "date-time"
          },
          "user_first_name": {
            "type": "string"
          },
          "user_last_name": {
            "type": "string"
          },
          "user_email": {
            "type": "string"
          },
          "order_total": {
            "type": "number"
          },
          "ticket_face_value_total": {
            "type": "number"
          },
          "donation_total": {
            "type": "number"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-gathr-api-key"
      },
      "emailAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-user-email"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": [],
      "emailAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication"
    },
    {
      "name": "Orders"
    },
    {
      "name": "Profiles"
    }
  ]
}
