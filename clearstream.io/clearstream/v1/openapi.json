    "schemas": {
      "AccountResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "business": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "phone": {
                "type": "string"
              },
              "credits": {
