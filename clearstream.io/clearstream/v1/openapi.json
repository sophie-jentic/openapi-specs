          }
        }
      },
      "CreateSubscriberRequest": {
        "type": "object",
        "required": [
          "mobile_number"
        ],
        "properties": {
          "mobile_number": {
            "type": "string"
          },
          "first": {
            "type": "string"
          },
          "last": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "lists": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "double_optin": {
            "type": "boolean"
          },
          "override_optouts": {
            "type": "boolean"
          }
        }
      },
      "UpdateSubscriberRequest": {
        "type": "object",
        "properties": {
          "first": {
            "type": "string"
          },
          "last": {
            "type": "string"
          },
