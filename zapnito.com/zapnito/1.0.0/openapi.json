{
  "openapi": "3.0.3",
  "info": {
    "title": "Zapnito API",
    "version": "1.0.0",
    "description": "Zapnito API for community platform management. The API uses token-based authentication and provides endpoints for validating API keys.",
    "x-jentic-source-url": "https://docs.zapnito.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{your-domain}/api/v1",
      "description": "Production server",
      "variables": {
        "your-domain": {
          "default": "example.zapnito.com",
          "description": "Your Zapnito domain"
        }
      }
    }
  ],
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "paths": {
    "/ping": {
      "get": {
        "operationId": "validateApiKey",
        "summary": "Validate API Key",
        "description": "Verify API key validity",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "API key is valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - API key invalid",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "HTTP Token: Access denied."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token-based authentication. Use format: 'Token token=<your-api-key>'"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "PingResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Nice one, your API key is valid"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Authentication"
    }
  ]
}
