  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "schemas": {
      "WebhookOutput": {
        "type": "object",
        "required": [
          "secret",
          "webhook_url"
        ],
        "properties": {
          "secret": {
            "type": "string",
            "maxLength": 255
          },
          "webhook_url": {
            "type": "string",
            "format": "uri",
            "maxLength": 200
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 254,
            "nullable": true
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 32
            },
            "nullable": true
          }
        }
      },
      "WebhookCreateInput": {
        "type": "object",
        "required": [
          "webhook_url"
        ],
        "properties": {
          "webhook_url": {
            "type": "string",
            "format": "uri",
            "maxLength": 200
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 254,
            "nullable": true
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 32
            },
            "nullable": true
          }
        }
      },
      "WebhookUpdateInput": {
        "type": "object",
        "properties": {
          "webhook_url": {
            "type": "string",
            "format": "uri",
            "maxLength": 200
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 254,
            "nullable": true
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 32
            },
            "nullable": true
          }
        }
      },
      "ZapierApiKeyOutput": {
        "type": "object",
        "required": [
          "api_key"
        ],
        "properties": {
          "api_key": {
            "type": "string",
            "maxLength": 255
          }
        }
      },
      "TemplateDropdown": {
        "type": "object",
        "required": [
          "id",
          "sample",
          "value",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "sample": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      },
      "TemplateDocumentSubscriptionInput": {
        "type": "object",
        "required": [
          "template_id",
          "webhook_url"
        ],
        "properties": {
          "template_id": {
            "type": "string"
          },
          "webhook_url": {
            "type": "string",
            "format": "uri"
          },
          "delay": {
            "type": "integer"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true
          },
          "username": {
            "type": "string",
            "readOnly": true
          },
          "first_name": {
            "type": "string",
            "maxLength": 30
          },
          "last_name": {
            "type": "string",
            "maxLength": 150
          },
          "email": {
            "type": "string",
            "format": "email",
            "readOnly": true
          },
          "is_active": {
            "type": "boolean",
            "readOnly": true
          },
          "date_joined": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "profile_image": {
            "type": "string",
            "format": "uri",
            "readOnly": true,
            "nullable": true
          },
          "show_onboarding_screen": {
            "type": "boolean"
          },
          "company_name": {
            "type": "string",
            "maxLength": 512,
            "nullable": true
          },
          "company_size": {
            "type": "string",
            "maxLength": 512,
            "nullable": true
          },
          "company_role": {
            "type": "string",
            "maxLength": 512,
            "nullable": true
          },
          "phone_number": {
            "type": "string",
            "maxLength": 12,
            "nullable": true
          }
        }
      },
      "Login": {
        "type": "object",
        "required": [
          "password"
        ],
        "properties": {
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "PasswordChange": {
        "type": "object",
        "required": [
          "new_password1",
          "new_password2"
        ],
        "properties": {
          "new_password1": {
            "type": "string",
            "maxLength": 128
          },
          "new_password2": {
            "type": "string",
            "maxLength": 128
          }
        }
      },
      "PasswordReset": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "PasswordResetConfirm": {
        "type": "object",
        "required": [
          "new_password1",
          "new_password2",
          "uid",
          "token"
        ],
        "properties": {
          "new_password1": {
            "type": "string",
            "maxLength": 128
          },
          "new_password2": {
            "type": "string",
            "maxLength": 128
          },
          "uid": {
            "type": "string"
          },
          "token": {
            "type": "string"
          }
        }
      },
      "Register": {
        "type": "object",
        "required": [
          "email",
          "password1",
