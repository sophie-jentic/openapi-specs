    "contact": {
      "email": "contact@crove.app"
    },
    "license": {
      "name": "BSD License"
    }
  },
  "x-jentic-source-url": "https://api.swaggerhub.com/apis/RethinkUX/CroveZapier/v1",
  "servers": [
    {
      "url": "https://app.crove.app",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
