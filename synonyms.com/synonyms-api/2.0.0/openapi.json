{
  "openapi": "3.0.3",
  "info": {
    "title": "Synonyms API",
    "description": "Access synonyms and antonyms for English words. Free to use for up to 100 queries per day.",
    "version": "2.0.0",
    "contact": {
      "url": "https://www.synonyms.com/synonyms_api.php"
    }
  },
  "servers": [
    {
      "url": "https://www.stands4.com/services/v2"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/syno.php": {
      "get": {
        "summary": "Get synonyms and antonyms for a word",
        "description": "Retrieve synonyms and antonyms for the specified word along with definitions and part of speech information.",
        "operationId": "getSynonyms",
        "parameters": [
          {
            "name": "uid",
            "in": "query",
            "description": "Your API user ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tokenid",
            "in": "query",
            "description": "Your valid developer token ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "word",
            "in": "query",
            "description": "The word to retrieve synonyms and antonyms for",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "consistent"
          },
          {
            "name": "format",
            "in": "query",
            "description": "Output format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "xml",
                "json"
              ],
              "default": "xml"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "object",
                      "properties": {
                        "result": {
                          "oneOf": [
                            {
                              "type": "object",
                              "properties": {
                                "term": {
                                  "type": "string",
                                  "description": "The queried word"
                                },
                                "definition": {
                                  "type": "string",
                                  "description": "Sense definition for that word"
                                },
                                "partofspeech": {
                                  "type": "string",
                                  "description": "Part of speech (adj, verb, etc.)"
                                },
                                "synonyms": {
                                  "type": "string",
                                  "description": "Comma-separated list of synonyms"
                                },
                                "antonyms": {
                                  "type": "string",
                                  "description": "Comma-separated list of antonyms"
                                }
                              }
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "term": {
                                    "type": "string"
                                  },
                                  "definition": {
                                    "type": "string"
                                  },
                                  "partofspeech": {
                                    "type": "string"
                                  },
                                  "synonyms": {
                                    "type": "string"
                                  },
                                  "antonyms": {
                                    "type": "string"
                                  }
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  }
                }
              },
              "application/xml": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "tags": [
          "syno.php"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "uid and tokenid",
        "description": "API authentication requires both uid (user ID) and tokenid (token ID) as query parameters"
      }
    }
  },
  "tags": [
    {
      "name": "syno.php"
    }
  ]
}
