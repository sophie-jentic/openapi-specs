{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Authentication Token for Ingress and Egress APIs",
    "description": "These HTTPS endpoints are used to obtain a token that allows partners to push or request data from the RapidSOS Emergency Data Platform API endpoints. \n",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/RapidSOS_API/authentication-token_for_ingress_and_egress_ap_is/1.0.0/swagger.json",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api{environment}.rapidsos.com",
      "variables": {
        "environment": {
          "enum": [
            "-sandbox",
            ""
          ],
          "default": "-sandbox"
        }
      }
    }
  ],
  "paths": {
    "/oauth/token": {
      "post": {
        "tags": [
          "Client Credential Grant Flow"
        ],
        "description": "Returns an access token for the client credentials.",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "example": "tJbG1SWsJaqd1JxCko403sdXbf"
                    },
                    "token_type": {
                      "type": "string",
                      "example": "Bearer"
                    },
                    "issued_at": {
                      "type": "integer",
                      "example": 1605805540651
                    },
                    "expires_in": {
                      "type": "integer",
                      "example": 3599
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "description": "Always `\"client_credentials\"`",
                    "example": "client_credentials"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Requesting client's ID to generate a token with",
                    "example": "adsfjkbj4b3473"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Requesting client's secret to generate a token with",
                    "example": "ah33bfafd78"
                  }
                },
                "required": [
                  "grant_type",
                  "client_id",
                  "client_secret"
                ]
              }
            }
          }
        },
        "operationId": "post-oauth-token"
      }
    },
    "/oauth/v2/token": {
      "post": {
        "tags": [
          "Password Grant Flow"
        ],
        "description": "Returns an access token for the combo of the client and user credentials.",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwiZW1haWwiOiJqZG9lQHJhcGlkc29zLmNvbSIsImV4cCI6MTUxNjIzOTAyMjAwMCwiYXVkIjoiUmFwaWRTT1MifQ.sZuKQTsIafbHD8cMH_k6yuK5RXjrTc7Oo1wABygdkRQ"
                    },
                    "token_type": {
                      "type": "string",
                      "example": "Bearer"
                    },
                    "issued_at": {
                      "type": "integer",
                      "example": 1605805540651
                    },
                    "expires_in": {
                      "type": "integer",
                      "example": 3599
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "description": "Always `\"password\"`",
                    "example": "password"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Requesting client's ID to generate a token with",
                    "example": "adsfjkbj4b3473"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Requesting client's secret to generate a token with",
                    "example": "ah33bfafd78"
                  },
                  "username": {
                    "type": "string",
                    "description": "Username of the RapidSOS Portal user to associate with this access token",
                    "example": "jdoe@rapidsos.com"
                  },
                  "password": {
                    "type": "string",
                    "description": "Password of the RapidSOS Portal user to associate with this access token",
                    "example": "SecurePassword123!"
                  }
                },
                "required": [
                  "grant_type",
                  "client_id",
                  "client_secret",
                  "username",
                  "password"
                ]
              }
            }
          }
        },
        "operationId": "post-oauth-v2-token"
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "description": "Detailed error message of what the error was"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Client Credential Grant Flow"
    },
    {
      "name": "Password Grant Flow"
    }
  ]
}
