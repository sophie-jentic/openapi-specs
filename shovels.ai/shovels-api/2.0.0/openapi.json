{
  "openapi": "3.0.3",
  "info": {
    "title": "Shovels API",
    "version": "2.0.0",
    "description": "Building contractor and permit data API providing access to permits, contractors, and property information.",
    "x-jentic-source-url": "https://docs.shovels.ai/api-reference/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.shovels.ai/v2"
    }
  ],
  "paths": {
    "/permits/search": {
      "get": {
        "operationId": "searchPermits",
        "summary": "Search permits",
        "description": "Returns a list of matching permit records filtered by various criteria",
        "tags": [
          "Permits"
        ],
        "parameters": [
          {
            "name": "permit_from",
            "in": "query",
            "required": true,
            "description": "Start date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "permit_to",
            "in": "query",
            "required": true,
            "description": "End date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "geo_id",
            "in": "query",
            "required": true,
            "description": "Geolocation ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "permit_tags",
            "in": "query",
            "description": "Filter by tags",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "permit_status",
            "in": "query",
            "description": "Filter by status",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "final",
                  "in_review",
                  "inactive",
                  "active"
                ]
              }
            }
          },
          {
            "name": "permit_q",
            "in": "query",
            "description": "Substring search in description (max 50 chars)",
            "schema": {
              "type": "string",
              "maxLength": 50
            }
          },
          {
            "name": "permit_min_job_value",
            "in": "query",
            "description": "Minimum job value",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "property_type",
            "in": "query",
            "description": "Property type filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "contractor_name",
            "in": "query",
            "description": "Filter by contractor name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Pagination cursor",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Page size",
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PermitSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/permits/{id}": {
      "get": {
        "operationId": "getPermit",
        "summary": "Get permit by ID",
        "tags": [
          "Permits"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Permit"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get permit by ID"
      }
    },
    "/contractors/search": {
      "get": {
        "operationId": "searchContractors",
        "summary": "Search contractors",
        "tags": [
          "Contractors"
        ],
        "parameters": [
          {
            "name": "geo_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "contractor_name",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "contractor_classification_derived",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContractorSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Search contractors"
      }
    },
    "/contractors/{id}": {
      "get": {
        "operationId": "getContractor",
        "summary": "Get contractor by ID",
        "tags": [
          "Contractors"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contractor"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get contractor by ID"
      }
    },
    "/properties/{id}": {
      "get": {
        "operationId": "getProperty",
        "summary": "Get property by ID",
        "tags": [
          "Properties"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Property"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get property by ID"
      }
    }
  },
  "components": {
    "schemas": {
      "Permit": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "job_value": {
            "type": "number"
          },
          "issue_date": {
            "type": "string",
            "format": "date"
          },
          "geo_id": {
            "type": "string"
          }
        }
      },
      "PermitSearchResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Permit"
            }
          },
          "cursor": {
            "type": "string"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "Contractor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "classification": {
            "type": "string"
          },
          "license": {
            "type": "string"
          }
        }
      },
      "ContractorSearchResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contractor"
            }
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "Property": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "property_type": {
            "type": "string"
          },
          "market_value": {
            "type": "number"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "ApiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Contractors"
    },
    {
      "name": "Permits"
    },
    {
      "name": "Properties"
    }
  ]
}
