{
  "openapi": "3.0.3",
  "info": {
    "title": "Planful REST API",
    "version": "1.0.0",
    "description": "Planful financial planning and analysis API for managing budgets, forecasts, consolidations, and financial data.",
    "x-jentic-source-url": "https://developers.planful.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.planful.com/v1"
    }
  ],
  "paths": {
    "/data/import": {
      "post": {
        "operationId": "importData",
        "summary": "Import financial data",
        "tags": [
          "Data"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Import financial data"
      }
    },
    "/data/export": {
      "post": {
        "operationId": "exportData",
        "summary": "Export financial data",
        "tags": [
          "Data"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
