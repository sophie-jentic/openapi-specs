{
  "openapi": "3.0.3",
  "info": {
    "title": "Flock API",
    "version": "1.0.0",
    "description": "Flock team messaging platform API. Send messages, manage channels, list contacts, and interact with the Flock chat platform programmatically. Uses FlockOS methods accessed via POST requests with token authentication.",
    "x-jentic-source-url": "https://dev.flock.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.flock.com/v2"
    }
  ],
  "paths": {
    "/chat.sendMessage": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send a message",
        "description": "Send a message to a channel or direct message conversation. Supports text, FlockML, and attachments.",
        "tags": [
          "Chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chat.fetchMessages": {
      "post": {
        "operationId": "fetchMessages",
        "summary": "Fetch messages from a conversation",
        "description": "Retrieve messages from a channel or direct message conversation.",
        "tags": [
          "Chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FetchMessagesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Messages fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FetchMessagesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/channels.list": {
      "post": {
        "operationId": "listChannels",
        "summary": "List channels",
        "description": "Get a list of all channels the authenticated user is a member of.",
        "tags": [
          "Channels"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "Authentication token"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Channels listed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChannelListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/channels.getInfo": {
      "post": {
        "operationId": "getChannelInfo",
        "summary": "Get channel info",
        "description": "Get detailed information about a specific channel.",
        "tags": [
          "Channels"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "to"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "to": {
                    "type": "string",
                    "description": "Channel ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Channel info retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Channel"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/channels.create": {
      "post": {
        "operationId": "createChannel",
        "summary": "Create a channel",
        "description": "Create a new channel in the team.",
        "tags": [
          "Channels"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "name"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string",
                    "description": "Channel name"
                  },
                  "description": {
                    "type": "string",
                    "description": "Channel description"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Channel created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Channel"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/channels.addMembers": {
      "post": {
        "operationId": "addChannelMembers",
        "summary": "Add members to a channel",
        "description": "Add one or more members to a channel.",
        "tags": [
          "Channels"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "to",
                  "members"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "to": {
                    "type": "string",
                    "description": "Channel ID"
                  },
                  "members": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of user IDs to add"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Members added",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "uid": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/channels.removeMembers": {
      "post": {
        "operationId": "removeChannelMembers",
        "summary": "Remove members from a channel",
        "tags": [
          "Channels"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "to",
                  "members"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "to": {
                    "type": "string"
                  },
                  "members": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Members removed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "uid": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Remove members from a channel"
      }
    },
    "/channels.listMembers": {
      "post": {
        "operationId": "listChannelMembers",
        "summary": "List channel members",
        "tags": [
          "Channels"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "to"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "to": {
                    "type": "string",
                    "description": "Channel ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Members listed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "members": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List channel members"
      }
    },
    "/roster.listContacts": {
      "post": {
        "operationId": "listContacts",
        "summary": "List contacts",
        "description": "Get a list of all contacts (team members) visible to the authenticated user.",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contacts listed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/users.getInfo": {
      "post": {
        "operationId": "getUserInfo",
        "summary": "Get user info",
        "description": "Get profile information for a specific user.",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "userId"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "userId": {
                    "type": "string",
                    "description": "User ID to lookup"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User info retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/users.getPublicProfile": {
      "post": {
        "operationId": "getUserPublicProfile",
        "summary": "Get user public profile",
        "description": "Get the public profile of a user.",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "userId"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "userId": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Public profile retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SendMessageRequest": {
        "type": "object",
        "required": [
          "token",
          "to",
          "text"
        ],
        "properties": {
          "token": {
            "type": "string",
            "description": "Authentication token"
          },
          "to": {
            "type": "string",
            "description": "Channel or user ID to send message to"
          },
          "text": {
            "type": "string",
            "description": "Message text (supports FlockML)"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            },
            "description": "Message attachments"
          },
          "flockml": {
            "type": "string",
            "description": "FlockML formatted message content"
          }
        }
      },
      "FetchMessagesRequest": {
        "type": "object",
        "required": [
          "token",
          "to"
        ],
        "properties": {
          "token": {
            "type": "string"
          },
          "to": {
            "type": "string",
            "description": "Channel or user ID"
          },
          "start": {
            "type": "string",
            "description": "Message UID to start from"
          },
          "count": {
            "type": "integer",
            "default": 20,
            "description": "Number of messages to fetch"
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "uid": {
            "type": "string",
            "description": "Unique message ID"
          }
        }
      },
      "FetchMessagesResponse": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Message"
            }
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "uid": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            }
          }
        }
      },
      "Attachment": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "color": {
            "type": "string"
          },
          "views": {
            "type": "object"
          }
        }
      },
      "Channel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "channel",
              "group"
            ]
          },
          "memberCount": {
            "type": "integer"
          },
          "createdBy": {
            "type": "string"
          }
        }
      },
      "ChannelListResponse": {
        "type": "object",
        "properties": {
          "channels": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Channel"
            }
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "profileImage": {
            "type": "string",
            "format": "uri"
          },
          "role": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          }
        }
      },
      "ContactListResponse": {
        "type": "object",
        "properties": {
          "contacts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error code"
          },
          "description": {
            "type": "string",
            "description": "Error description"
          }
        }
      }
    },
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "name": "token",
        "in": "query",
        "description": "FlockOS authentication token (can also be passed in request body)"
      }
    }
  },
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "Channels"
    },
    {
      "name": "Chat"
    },
    {
      "name": "Contacts"
    },
    {
      "name": "Users"
    }
  ]
}
