{
  "openapi": "3.0.3",
  "info": {
    "title": "Flock Messaging API",
    "version": "2.0",
    "description": "Flock is a team messaging and collaboration platform. The API provides endpoints for sending messages, managing channels, contacts, and integrating bots and apps with the Flock ecosystem. All API calls use POST with JSON body and require an authentication token.",
    "x-jentic-source-url": "https://docs.flock.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.flock.com/v2"
    }
  ],
  "paths": {
    "/chat.sendMessage": {
      "post": {
        "operationId": "chatSendMessage",
        "summary": "Send a message to a channel or user",
        "tags": [
          "Chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "to",
                  "text"
                ],
                "properties": {
                  "to": {
                    "type": "string",
                    "description": "Channel ID or user ID"
                  },
                  "text": {
                    "type": "string"
                  },
                  "attachments": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Attachment"
                    }
                  },
                  "flockml": {
                    "type": "string",
                    "description": "FlockML formatted message"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Send a message to a channel or user"
      }
    },
    "/chat.fetchMessages": {
      "post": {
        "operationId": "chatFetchMessages",
        "summary": "Fetch messages from a channel",
        "tags": [
          "Chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "chat"
                ],
                "properties": {
                  "chat": {
                    "type": "string"
                  },
                  "uids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "start": {
                    "type": "string"
                  },
                  "end": {
                    "type": "string"
                  },
                  "count": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Messages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Message"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Fetch messages from a channel"
      }
    },
    "/chat.deleteMessage": {
      "post": {
        "operationId": "chatDeleteMessage",
        "summary": "Delete a message",
        "tags": [
          "Chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "chat",
                  "uid"
                ],
                "properties": {
                  "chat": {
                    "type": "string"
                  },
                  "uid": {
                    "type": "string",
                    "description": "Message UID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete a message"
      }
    },
