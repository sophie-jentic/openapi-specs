            "type": "integer"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "order_number": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "customer_name": {
            "type": "string"
          },
          "shipping_address": {
            "type": "object",
            "properties": {
              "street": {
