{
  "openapi": "3.0.3",
  "info": {
    "title": "Not Diamond API",
    "version": "2.0.0",
    "description": "Not Diamond is an intelligent AI optimization platform for automatically optimizing prompts, improving agents, and routing queries across models.",
    "x-jentic-source-url": "https://docs.notdiamond.ai/reference",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.notdiamond.ai"
    }
  ],
  "paths": {
    "/v2/modelRouter/modelSelect": {
      "post": {
        "operationId": "modelSelect",
        "summary": "Model Selection",
        "description": "Route queries to optimal LLM based on capabilities and preferences",
        "tags": [
          "Routing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ModelSelectRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelSelectResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/preferences/userPreferenceCreate": {
      "post": {
        "operationId": "createPreference",
        "summary": "Create Preference",
        "tags": [
          "Preferences"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "preference_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create Preference"
      }
    },
    "/v2/preferences/userPreferenceUpdate": {
      "put": {
        "operationId": "updatePreference",
        "summary": "Update Preference",
        "tags": [
          "Preferences"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "preference_id"
                ],
                "properties": {
                  "preference_id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Update Preference"
      }
    },
    "/v2/preferences/userPreferenceDelete/{preference_id}": {
      "delete": {
        "operationId": "deletePreference",
        "summary": "Delete Preference",
        "tags": [
          "Preferences"
        ],
        "parameters": [
          {
            "name": "preference_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete Preference"
      }
    },
    "/v2/prompt/optimize": {
      "post": {
        "operationId": "optimizePrompt",
        "summary": "Submit Prompt Optimization",
        "tags": [
          "Prompt Optimization"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OptimizeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "optimization_run_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Submit Prompt Optimization"
      }
    },
    "/v2/prompt/optimizeStatus/{optimization_run_id}": {
      "get": {
        "operationId": "getOptimizeStatus",
        "summary": "Check Optimization Status",
        "tags": [
          "Prompt Optimization"
        ],
        "parameters": [
          {
            "name": "optimization_run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "created",
                        "queued",
                        "processing",
                        "completed",
                        "failed"
                      ]
                    },
                    "queue_position": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Check Optimization Status"
      }
    },
    "/v2/prompt/optimizeResults/{optimization_run_id}": {
      "get": {
        "operationId": "getOptimizeResults",
        "summary": "Get Optimization Results",
        "tags": [
          "Prompt Optimization"
        ],
        "parameters": [
          {
            "name": "optimization_run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OptimizeResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get Optimization Results"
      }
    },
    "/v2/prompt/optimize/{optimization_run_id}/costs": {
      "get": {
        "operationId": "getOptimizeCosts",
        "summary": "Get Optimization Costs",
        "tags": [
          "Prompt Optimization"
        ],
        "parameters": [
          {
            "name": "optimization_run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total_cost_usd": {
                      "type": "number"
                    },
                    "usage_records": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get Optimization Costs"
      }
    }
  },
  "components": {
    "schemas": {
      "ModelSelectRequest": {
        "type": "object",
        "required": [
          "messages",
          "llm_providers"
        ],
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "llm_providers": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "preference_id": {
            "type": "string"
          },
          "metric": {
            "type": "string",
            "default": "accuracy"
          },
          "tradeoff": {
            "type": "string",
            "enum": [
              "cost",
              "latency"
            ]
          }
        }
      },
      "ModelSelectResponse": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string"
          },
          "provider": {
            "type": "object"
          },
          "model": {
            "type": "string"
          }
        }
      },
      "OptimizeRequest": {
        "type": "object",
        "required": [
          "system_prompt",
          "template",
          "fields",
          "target_models",
          "train_goldens",
          "test_goldens"
        ],
        "properties": {
          "system_prompt": {
            "type": "string"
          },
          "template": {
            "type": "string"
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target_models": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "train_goldens": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "test_goldens": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "origin_model": {
            "type": "object"
          },
          "evaluation_metric": {
            "type": "string"
          },
          "prototype_mode": {
            "type": "boolean"
          }
        }
      },
      "OptimizeResults": {
        "type": "object",
        "properties": {
          "origin_baseline": {
            "type": "object"
          },
          "optimized_prompts": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Preferences"
    },
    {
      "name": "Prompt Optimization"
    },
    {
      "name": "Routing"
    }
  ]
}
