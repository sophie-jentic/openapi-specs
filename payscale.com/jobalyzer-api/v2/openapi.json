            "type": "boolean"
          },
          {
            "in": "query",
            "name": "CustomerId",
            "type": "string"
          },
          {
            "in": "query",
            "name": "User",
            "type": "string"
          },
          {
            "in": "query",
            "name": "Test",
            "type": "boolean"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "$ref": "#/definitions/ImpactResponseSuccess"
            }
          },
          "404": {
            "description": "Not Found",
            "schema": {
              "$ref": "#/definitions/ImpactResponseError"
            }
          },
          "500": {
            "description": "Server Error",
