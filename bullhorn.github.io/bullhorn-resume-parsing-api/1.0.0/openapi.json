{
  "openapi": "3.0.3",
  "info": {
    "title": "Bullhorn Resume Parsing API",
    "version": "1.0.0",
    "description": "Bullhorn REST API for parsing resumes into candidate data, creating candidate entities, managing education and work history, and handling file attachments.",
    "x-jentic-source-url": "https://bullhorn.github.io/Resume-Parsing/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://rest.bullhornstaffing.com/rest-services/{corpToken}",
      "variables": {
        "corpToken": {
          "default": "YOUR_CORP_TOKEN",
          "description": "Corporation token"
        }
      }
    }
  ],
  "paths": {
    "/resume/parseToCandidate": {
      "post": {
        "operationId": "parseResumeToCandidate",
        "summary": "Parse resume to candidate",
        "description": "Parses a resume file and extracts candidate-related data including personal information, education, work history, and skills",
        "tags": [
          "Resume"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "DOC",
                "PDF",
                "TXT",
                "HTML",
                "RTF"
              ]
            }
          },
          {
            "name": "populateDescription",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "text",
                "html"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParsedCandidate"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/entity/Candidate": {
      "put": {
        "operationId": "createCandidate",
        "summary": "Create a candidate",
        "tags": [
          "Candidates"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CandidateCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntityChangeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a candidate"
      }
    },
    "/entity/Candidate/{candidateId}": {
      "get": {
        "operationId": "getCandidate",
        "summary": "Get a candidate",
        "tags": [
          "Candidates"
        ],
        "parameters": [
          {
            "name": "candidateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Candidate"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get a candidate"
      }
    },
    "/entity/CandidateEducation": {
      "put": {
        "operationId": "createCandidateEducation",
        "summary": "Create candidate education",
        "tags": [
          "Education"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CandidateEducation"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntityChangeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create candidate education"
      }
    },
    "/entity/CandidateWorkHistory": {
      "put": {
        "operationId": "createCandidateWorkHistory",
        "summary": "Create candidate work history",
        "tags": [
          "WorkHistory"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CandidateWorkHistory"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntityChangeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create candidate work history"
      }
    },
    "/entity/Candidate/{candidateId}/primarySkills/{skillIds}": {
      "put": {
        "operationId": "addPrimarySkills",
        "summary": "Add primary skills to candidate",
        "tags": [
          "Skills"
        ],
        "parameters": [
          {
            "name": "candidateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "skillIds",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated skill IDs"
          }
        ],
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntityChangeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Add primary skills to candidate"
      }
    },
    "/options/Skill": {
      "get": {
        "operationId": "listSkills",
        "summary": "List available skills",
        "tags": [
          "Skills"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Skill"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List available skills"
      }
    },
    "/file/Candidate/{candidateId}/raw": {
      "put": {
        "operationId": "attachResumeFile",
        "summary": "Attach resume file to candidate",
        "tags": [
          "Files"
        ],
        "parameters": [
          {
            "name": "candidateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "externalID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fileType",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fileId": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Attach resume file to candidate"
      }
    },
    "/entityFiles/Candidate/{candidateId}": {
      "get": {
        "operationId": "listCandidateFiles",
        "summary": "List candidate files",
        "tags": [
          "Files"
        ],
        "parameters": [
          {
            "name": "candidateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "EntityFiles": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List candidate files"
      }
    }
  },
  "components": {
    "schemas": {
      "ParsedCandidate": {
        "type": "object",
        "properties": {
          "candidate": {
            "type": "object"
          },
          "candidateEducation": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "candidateWorkHistory": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "skillList": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Candidate": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "primarySkills": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "CandidateCreate": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "CandidateEducation": {
        "type": "object",
        "properties": {
          "candidate": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              }
            }
          },
          "school": {
            "type": "string"
          },
          "degree": {
            "type": "string"
          },
          "major": {
            "type": "string"
          }
        }
      },
      "CandidateWorkHistory": {
        "type": "object",
        "properties": {
          "candidate": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              }
            }
          },
          "companyName": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "startDate": {
            "type": "integer"
          },
          "endDate": {
            "type": "integer"
          }
        }
      },
      "EntityChangeResponse": {
        "type": "object",
        "properties": {
          "changedEntityType": {
            "type": "string"
          },
          "changedEntityId": {
            "type": "integer"
          },
          "changeType": {
            "type": "string"
          }
        }
      },
      "Skill": {
        "type": "object",
        "properties": {
          "value": {
            "type": "integer"
          },
          "label": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errorMessage": {
            "type": "string"
          },
          "errorCode": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://auth.bullhornstaffing.com/oauth/authorize",
            "tokenUrl": "https://auth.bullhornstaffing.com/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "Candidates"
    },
    {
      "name": "Education"
    },
    {
      "name": "Files"
    },
    {
      "name": "Resume"
    },
    {
      "name": "Skills"
    },
    {
      "name": "WorkHistory"
    }
  ]
}
