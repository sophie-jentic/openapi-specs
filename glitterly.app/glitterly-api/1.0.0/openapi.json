{
  "openapi": "3.0.0",
  "info": {
    "title": "Glitterly API",
    "description": "API for Glitterly video generation platform. Note: Documentation is not publicly accessible.",
    "version": "1.0.0",
    "contact": {
      "url": "https://glitterly.app"
    }
  },
  "servers": [
    {
      "url": "https://api.glitterly.app/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/videos": {
      "get": {
        "summary": "List videos",
        "description": "Returns a list of videos",
        "operationId": "listVideos",
        "tags": [
          "Videos"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of videos to return",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of videos to skip",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Video"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "summary": "Create video",
        "description": "Creates a new video",
        "operationId": "createVideo",
        "tags": [
          "Videos"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VideoRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Video created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Video"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/videos/{videoId}": {
      "get": {
        "summary": "Get video by ID",
        "description": "Returns information about a specific video",
        "operationId": "getVideoById",
        "tags": [
          "Videos"
        ],
        "parameters": [
          {
            "name": "videoId",
            "in": "path",
            "required": true,
            "description": "ID of the video",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Video"
                }
              }
            }
          },
          "404": {
            "description": "Video not found"
          }
        }
      },
      "delete": {
        "summary": "Delete video",
        "description": "Deletes a specific video",
        "operationId": "deleteVideo",
        "tags": [
          "Videos"
        ],
        "parameters": [
          {
            "name": "videoId",
            "in": "path",
            "required": true,
            "description": "ID of the video",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Video deleted successfully"
          },
          "404": {
            "description": "Video not found"
          }
        }
      }
    },
    "/templates": {
      "get": {
        "summary": "List templates",
        "description": "Returns a list of available video templates",
        "operationId": "listTemplates",
        "tags": [
          "Templates"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Template"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "Video": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Video ID"
          },
          "title": {
            "type": "string",
            "description": "Video title"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "description": "Video processing status"
          },
          "url": {
            "type": "string",
            "description": "URL to the video file"
          },
          "thumbnail": {
            "type": "string",
            "description": "URL to the video thumbnail"
          },
          "templateId": {
            "type": "string",
            "description": "ID of the template used"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        }
      },
      "VideoRequest": {
        "type": "object",
        "required": [
          "templateId",
          "title"
        ],
        "properties": {
          "templateId": {
            "type": "string",
            "description": "ID of the template to use"
          },
          "title": {
            "type": "string",
            "description": "Video title"
          },
          "data": {
            "type": "object",
            "description": "Template-specific data",
            "additionalProperties": true
          }
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Template ID"
          },
          "name": {
            "type": "string",
            "description": "Template name"
          },
          "description": {
            "type": "string",
            "description": "Template description"
          },
          "thumbnail": {
            "type": "string",
            "description": "URL to the template thumbnail"
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "required": {
                  "type": "boolean"
                }
              }
            },
            "description": "Required fields for this template"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Templates"
    },
    {
      "name": "Videos"
    }
  ]
}
