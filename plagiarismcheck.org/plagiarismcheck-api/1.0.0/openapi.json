                }
              }
            }
          }
        },
        "description": "Check AI detection status"
      }
    }
  },
  "components": {
    "schemas": {
      "TextSubmission": {
        "type": "object",
        "required": [
          "language",
          "text"
        ],
        "properties": {
          "language": {
            "type": "string",
            "description": "Language code (e.g., en)"
          },
          "text": {
            "type": "string",
            "description": "Text to check (minimum 80 characters)"
          }
        }
      },
      "SubmissionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "TextStatus": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "state": {
            "type": "integer",
            "description": "2=queued, 3=processing, 4=error, 5=checked"
          },
          "percent": {
            "type": "number"
          }
        }
      },
      "PlagiarismReport": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "OrgTextSubmission": {
        "type": "object",
        "required": [
          "author",
          "group_token",
          "text"
        ],
        "properties": {
          "author": {
            "type": "string"
          },
          "group_token": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "custom_author": {
            "type": "string"
          }
        }
      },
      "AICheckSubmission": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "file": {
            "type": "string",
            "format": "binary"
          },
          "group_id": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-TOKEN"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "AI Detection"
    },
    {
      "name": "Organization"
    },
    {
      "name": "Plagiarism Check"
    }
  ]
}
