  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "bfx-apikey",
        "description": "Bitfinex API key."
      },
      "apiKeyNonce": {
        "type": "apiKey",
        "in": "header",
        "name": "bfx-nonce",
        "description": "Unique nonce (e.g., UTC timestamp in milliseconds)."
      },
      "apiKeySignature": {
        "type": "apiKey",
        "in": "header",
        "name": "bfx-signature",
        "description": "HMAC-SHA384 signature."
      }
    },
    "schemas": {
      "OrderSubmit": {
        "type": "object",
        "required": [
          "type",
          "symbol",
          "amount"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Order type.",
            "enum": [
              "LIMIT",
              "EXCHANGE LIMIT",
              "MARKET",
              "EXCHANGE MARKET",
              "STOP",
              "EXCHANGE STOP",
              "STOP LIMIT",
              "EXCHANGE STOP LIMIT",
              "TRAILING STOP",
              "EXCHANGE TRAILING STOP",
              "FOK",
              "EXCHANGE FOK",
              "IOC",
              "EXCHANGE IOC"
            ]
          },
          "symbol": {
            "type": "string",
            "description": "Trading pair symbol (e.g., tBTCUSD)."
          },
          "amount": {
            "type": "string",
            "description": "Order amount. Positive for buy, negative for sell."
          },
          "price": {
            "type": "string",
            "description": "Order price."
          },
          "price_trailing": {
            "type": "string",
            "description": "Trailing price delta."
          },
          "price_aux_limit": {
            "type": "string",
            "description": "Auxiliary limit price for stop limit orders."
          },
          "price_oco_stop": {
            "type": "string",
            "description": "OCO stop price."
          },
          "gid": {
            "type": "integer",
            "format": "int64",
            "description": "Group ID for the order."
          },
          "cid": {
            "type": "integer",
            "format": "int64",
            "description": "Client Order ID."
          },
          "flags": {
            "type": "integer",
            "description": "Order flags (bitmask)."
          },
          "lev": {
            "type": "integer",
            "description": "Leverage for derivative orders."
          },
          "tif": {
            "type": "string",
            "description": "Time in Force (datetime for GTD orders)."
          },
          "meta": {
            "type": "object",
            "description": "Additional order metadata."
          }
        }
      }
    }
  },
