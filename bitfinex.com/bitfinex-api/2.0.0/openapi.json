{
  "openapi": "3.0.3",
  "info": {
    "title": "Bitfinex API",
    "description": "The Bitfinex API provides programmatic access to the Bitfinex cryptocurrency exchange platform, offering endpoints for market data, trading, wallet management, funding, and account operations.",
    "version": "2.0.0",
    "contact": {
      "name": "Bitfinex",
      "url": "https://docs.bitfinex.com"
    }
  },
  "servers": [
    {
      "url": "https://api-pub.bitfinex.com/v2",
      "description": "Bitfinex Public API v2"
    },
    {
      "url": "https://api.bitfinex.com/v2",
      "description": "Bitfinex Authenticated API v2"
    }
  ],
  "paths": {
    "/platform/status": {
      "get": {
        "tags": [
          "Public"
        ],
        "summary": "Platform status",
        "description": "Get the current status of the platform. Returns 1 for operative, 0 for maintenance.",
        "operationId": "getPlatformStatus",
        "responses": {
          "200": {
            "description": "Platform status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  },
                  "example": [
                    1
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/ticker/{symbol}": {
      "get": {
        "tags": [
          "Public"
        ],
        "summary": "Ticker",
        "description": "Returns the ticker for a specified trading pair or funding currency. Use 't' prefix for trading pairs and 'f' prefix for funding currencies.",
        "operationId": "getTicker",
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "description": "The symbol (e.g., tBTCUSD for Bitcoin/USD trading pair, fUSD for USD funding).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ticker data as array",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tickers": {
      "get": {
        "tags": [
          "Public"
        ],
        "summary": "Tickers",
        "description": "Returns tickers for multiple trading pairs or funding currencies with a single request.",
        "operationId": "getTickers",
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of symbols or 'ALL' for all symbols.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of ticker arrays",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tickers/hist": {
      "get": {
        "tags": [
          "Public"
        ],
        "summary": "Tickers history",
        "description": "Returns historic hourly ticker data for multiple pairs.",
        "operationId": "getTickersHistory",
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Millisecond start time.",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "Millisecond end time.",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of records (max 250).",
            "schema": {
              "type": "integer",
              "default": 120
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Historic ticker data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/trades/{symbol}/hist": {
      "get": {
        "tags": [
          "Public"
        ],
        "summary": "Trades",
        "description": "Returns past public trades with price and size details.",
        "operationId": "getTrades",
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of records (max 10000).",
            "schema": {
              "type": "integer",
              "default": 120
            }
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "end",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort direction: 1 for ascending, -1 for descending.",
            "schema": {
              "type": "integer",
              "enum": [
                -1,
                1
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trade data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/book/{symbol}/{precision}": {
      "get": {
        "tags": [
          "Public"
        ],
        "summary": "Order book",
        "description": "Returns the order book for the given trading pair with customizable precision.",
        "operationId": "getBook",
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "precision",
            "in": "path",
            "required": true,
            "description": "Level of price aggregation (P0, P1, P2, P3, P4, R0).",
            "schema": {
              "type": "string",
              "enum": [
                "P0",
                "P1",
                "P2",
                "P3",
                "P4",
                "R0"
              ]
            }
          },
          {
            "name": "len",
            "in": "query",
            "description": "Number of price points (1, 25, 100).",
            "schema": {
              "type": "integer",
              "enum": [
                1,
                25,
                100
              ],
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order book data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stats1/{key}:{size}:{symbol}:{side}/{section}": {
      "get": {
        "tags": [
          "Public"
        ],
        "summary": "Stats",
