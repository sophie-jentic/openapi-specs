{
  "openapi": "3.0.3",
  "info": {
    "title": "Bitfinex API",
    "version": "2.0",
    "description": "Bitfinex cryptocurrency exchange REST API v2. Provides market data, trading, wallet management, and account features.",
    "x-jentic-source-url": "https://docs.bitfinex.com/docs/introduction",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api-pub.bitfinex.com/v2"
    }
  ],
  "tags": [
    {
      "name": "Public",
      "description": "Public market data endpoints (no auth required)"
    },
    {
      "name": "Authenticated",
      "description": "Authenticated endpoints requiring API key"
    }
  ],
  "paths": {
    "/platform/status": {
      "get": {
        "operationId": "getPlatformStatus",
        "summary": "Platform status",
        "description": "Returns 1 if operative, 0 if in maintenance mode.",
        "tags": [
          "Public"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tickers": {
      "get": {
        "operationId": "getTickers",
        "summary": "Get tickers",
        "description": "Returns ticker data for multiple trading pairs and funding currencies.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of symbols (e.g. tBTCUSD,tETHUSD) or ALL"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ticker/{Symbol}": {
      "get": {
        "operationId": "getTicker",
        "summary": "Get ticker for a pair",
        "description": "Returns ticker data for a single trading pair or funding currency.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "Symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Trading pair (e.g. tBTCUSD) or funding currency (e.g. fUSD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tickers/hist": {
      "get": {
        "operationId": "getTickersHistory",
        "summary": "Get tickers history",
        "description": "Returns historical ticker data.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of symbols"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 250
            },
            "description": "Number of records"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Millisecond start time"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Millisecond end time"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/trades/{Symbol}/hist": {
      "get": {
        "operationId": "getTrades",
        "summary": "Get trades",
        "description": "Returns the most recent trades for a given trading pair.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "Symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Trading pair symbol (e.g. tBTCUSD)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 120
            },
            "description": "Number of records (max 10000)"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Millisecond start time"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Millisecond end time"
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                -1,
                1
              ]
            },
            "description": "Sort direction: 1 = old>new, -1 = new>old"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/book/{Symbol}/{Precision}": {
      "get": {
        "operationId": "getOrderBook",
        "summary": "Get order book",
        "description": "Returns the order book for a trading pair at specified precision.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "Symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Trading pair (e.g. tBTCUSD)"
          },
          {
            "name": "Precision",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "P0",
                "P1",
                "P2",
                "P3",
                "P4",
                "R0"
              ]
            },
            "description": "Level of price aggregation"
          },
          {
            "name": "len",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                1,
                25,
                100
              ]
            },
            "description": "Number of price points"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/candles/trade:{TimeFrame}:{Symbol}/{Section}": {
      "get": {
        "operationId": "getCandles",
        "summary": "Get candles",
        "description": "Returns OHLCV candle data for a trading pair.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "TimeFrame",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "1m",
                "5m",
                "15m",
                "30m",
                "1h",
                "3h",
                "6h",
                "12h",
                "1D",
                "1W",
                "14D",
                "1M"
              ]
            },
            "description": "Candle time frame"
          },
          {
            "name": "Symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Trading pair (e.g. tBTCUSD)"
          },
          {
            "name": "Section",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "last",
                "hist"
              ]
            },
            "description": "last = last candle, hist = historical candles"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            },
            "description": "Number of candles (max 10000)"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Millisecond start time"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Millisecond end time"
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                -1,
                1
              ]
            },
            "description": "Sort direction"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stats1/{Key}:{Size}:{Symbol}:{Side}/{Section}": {
      "get": {
        "operationId": "getStats",
        "summary": "Get stats",
        "description": "Returns various statistics about the requested entity.",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "Key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "funding.size",
                "credits.size",
                "credits.size.sym",
                "pos.size",
                "vol.1d",
                "vol.7d",
                "vol.30d",
                "vwap"
              ]
            },
            "description": "Stat key"
          },
          {
            "name": "Size",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Size parameter"
          },
          {
            "name": "Symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Symbol"
          },
          {
            "name": "Side",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Side (long/short)"
          },
          {
            "name": "Section",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "last",
                "hist"
              ]
            },
            "description": "Section"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/conf/pub:list:pair:exchange": {
      "get": {
        "operationId": "getExchangePairs",
