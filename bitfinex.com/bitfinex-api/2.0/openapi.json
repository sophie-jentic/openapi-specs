  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "bfx-apikey",
        "description": "Bitfinex API key. Requests also require bfx-nonce and bfx-signature headers."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Wallet": {
        "type": "object",
        "description": "Array: [WALLET_TYPE, CURRENCY, BALANCE, UNSETTLED_INTEREST, BALANCE_AVAILABLE]",
        "properties": {
          "walletType": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "balance": {
            "type": "number"
          },
          "unsettledInterest": {
            "type": "number"
          },
          "balanceAvailable": {
            "type": "number"
          }
        }
      },
      "Order": {
        "type": "object",
        "description": "Array representation of an order",
        "properties": {
          "id": {
            "type": "integer"
          },
          "gid": {
            "type": "integer"
          },
          "cid": {
            "type": "integer"
          },
          "symbol": {
            "type": "string"
          },
          "mtsCreate": {
            "type": "integer"
          },
          "mtsUpdate": {
            "type": "integer"
          },
          "amount": {
            "type": "number"
          },
          "amountOrig": {
            "type": "number"
          },
          "type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "priceAvg": {
            "type": "number"
          }
        }
      },
      "Position": {
        "type": "object",
        "description": "Array representation of a position",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "basePrice": {
            "type": "number"
          },
          "marginFunding": {
            "type": "number"
          },
          "pl": {
            "type": "number"
          },
          "plPerc": {
            "type": "number"
          }
        }
      },
      "NewOrderRequest": {
        "type": "object",
        "required": [
          "type",
          "symbol",
          "amount"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "LIMIT",
              "MARKET",
              "STOP",
              "STOP LIMIT",
              "TRAILING STOP",
              "EXCHANGE MARKET",
              "EXCHANGE LIMIT",
              "EXCHANGE STOP",
              "EXCHANGE STOP LIMIT",
              "EXCHANGE TRAILING STOP",
              "FOK",
              "EXCHANGE FOK",
              "IOC",
              "EXCHANGE IOC"
            ],
            "description": "Order type"
          },
          "symbol": {
            "type": "string",
            "description": "Trading pair (e.g. tBTCUSD)"
          },
          "amount": {
            "type": "string",
            "description": "Order amount (positive=buy, negative=sell)"
          },
          "price": {
            "type": "string",
            "description": "Price (required for limit orders)"
          },
          "lev": {
            "type": "integer",
            "description": "Leverage for margin order"
          },
          "price_trailing": {
            "type": "string"
          },
          "price_aux_limit": {
            "type": "string"
          },
          "flags": {
            "type": "integer"
          },
          "gid": {
            "type": "integer"
          }
        }
      }
    }
  },
