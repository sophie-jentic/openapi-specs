        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/conf/pub:map:currency:sym": {
      "get": {
        "operationId": "getCurrencySymbolMap",
        "summary": "Get currency symbol map",
        "description": "Returns the mapping between currency codes and symbols.",
        "tags": [
          "Public"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/r/wallets": {
      "post": {
        "operationId": "getWallets",
        "summary": "Get wallets",
        "description": "Returns wallet balances for all currencies.",
        "tags": [
          "Authenticated"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
