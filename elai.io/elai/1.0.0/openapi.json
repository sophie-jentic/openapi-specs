{
  "openapi": "3.0.3",
  "info": {
    "title": "Elai API",
    "description": "Elai API for AI-powered video creation, rendering, and management",
    "version": "1.0.0",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://apis.elai.io/api/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token authentication. Get your API token from https://app.elai.io/api"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/videos": {
      "post": {
        "summary": "Create video",
        "description": "Create a new video",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Video created successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "videos"
        ],
        "operationId": "post-videos"
      },
      "get": {
        "summary": "List videos",
        "description": "Retrieve list of videos",
        "responses": {
          "200": {
            "description": "List of videos retrieved successfully"
          }
        },
        "tags": [
          "videos"
        ],
        "operationId": "get-videos"
      }
    },
    "/videos/render/{videoId}": {
      "post": {
        "summary": "Render video",
        "description": "Render a video by ID",
        "parameters": [
          {
            "name": "videoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Video rendered successfully"
          }
        },
        "tags": [
          "videos"
        ],
        "operationId": "post-videos-render-by-videoid"
      }
    },
    "/videos/{videoId}": {
      "get": {
        "summary": "Retrieve video",
        "description": "Get video details by ID",
        "parameters": [
          {
            "name": "videoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Video details retrieved successfully"
          },
          "404": {
            "description": "Video not found"
          }
        },
        "tags": [
          "videos"
        ],
        "operationId": "get-videos-by-videoid"
      },
      "patch": {
        "summary": "Update video",
        "description": "Update video by ID",
        "parameters": [
          {
            "name": "videoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Video updated successfully"
          }
        },
        "tags": [
          "videos"
        ],
        "operationId": "patch-videos-by-videoid"
      },
      "delete": {
        "summary": "Delete video",
        "description": "Delete video by ID",
        "parameters": [
          {
            "name": "videoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Video deleted successfully"
          }
        },
        "tags": [
          "videos"
        ],
        "operationId": "delete-videos-by-videoid"
      }
    },
    "/videos/renderTemplate/{videoId}": {
      "post": {
        "summary": "Render personalized batch",
        "description": "Render personalized video batch from template",
        "parameters": [
          {
            "name": "videoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Template rendered successfully"
          }
        },
        "tags": [
          "videos"
        ],
        "operationId": "post-videos-rendertemplate-by-videoid"
      }
    },
    "/videos/copy": {
      "post": {
        "summary": "Copy/transform video",
        "description": "Copy or transform an existing video",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Video copied successfully"
          }
        },
        "tags": [
          "videos"
        ],
        "operationId": "post-videos-copy"
      }
    },
    "/videos/translate/{videoId}": {
      "post": {
        "summary": "Translate video",
        "description": "Translate video to another language",
        "parameters": [
          {
            "name": "videoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Video translation initiated"
          }
        },
        "tags": [
          "videos"
        ],
        "operationId": "post-videos-translate-by-videoid"
      }
    },
    "/videos/from-presentation": {
      "post": {
        "summary": "Create from presentation",
        "description": "Create video from PPTX/PPT file",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Video created from presentation"
          }
        },
        "tags": [
          "videos"
        ],
        "operationId": "post-videos-from-presentation"
      }
    },
    "/videos/text/{type}": {
      "post": {
        "summary": "Create from text",
        "description": "Create video from text, HTML, or URL",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "text",
                "html",
                "url"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Video created from text"
          }
        },
        "tags": [
          "videos"
        ],
        "operationId": "post-videos-text-by-type"
      }
    },
    "/streams": {
      "post": {
        "summary": "Create stream",
        "description": "Create a real-time stream (Beta)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stream created successfully"
          }
        },
        "tags": [
          "streams"
        ],
        "operationId": "post-streams"
      }
    },
    "/streams/{streamId}": {
      "get": {
        "summary": "Retrieve stream",
