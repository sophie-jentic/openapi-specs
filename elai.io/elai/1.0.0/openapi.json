      "put": {
        "summary": "Start stream",
        "description": "Start a stream",
        "parameters": [
          {
            "name": "streamId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stream started"
          }
        },
        "tags": [
          "streams"
        ],
        "operationId": "put-streams-by-streamid"
      },
      "delete": {
        "summary": "Close stream",
        "description": "Close a stream",
        "parameters": [
          {
            "name": "streamId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stream closed"
          }
        },
        "tags": [
          "streams"
        ],
        "operationId": "delete-streams-by-streamid"
      }
    },
    "/story/generate-slides/{videoId}": {
      "post": {
        "summary": "Generate slides",
