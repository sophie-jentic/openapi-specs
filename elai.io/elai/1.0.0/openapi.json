        "parameters": [
          {
            "name": "videoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Slides generated"
          }
        },
        "tags": [
          "story"
        ],
        "operationId": "post-story-generate-slides-by-videoid"
      }
    },
    "/gpt/{videoId}": {
      "post": {
        "summary": "Enhance video with GPT",
        "description": "Enhance video using GPT capabilities",
        "parameters": [
          {
            "name": "videoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Video enhanced with GPT"
          }
        },
        "tags": [
          "gpt"
        ],
        "operationId": "post-gpt-by-videoid"
      }
