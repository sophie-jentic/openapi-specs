        "parameters": [
          {
            "name": "streamId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stream details retrieved"
          }
        },
        "tags": [
          "streams"
        ],
        "operationId": "get-streams-by-streamid"
