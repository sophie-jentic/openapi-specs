            "description": "The player's gamertag",
            "schema": { "type": "string" }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Image size (95, 128, 190, 256, 512)",
            "schema": { "type": "integer", "enum": [95, 128, 190, 256, 512] }
          }
        ],
        "responses": {
          "200": {
            "description": "Player Spartan appearance image",
            "content": {
              "image/png": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
