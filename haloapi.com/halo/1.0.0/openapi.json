    "/profile/h5/profiles/{player}/appearance": {
      "get": {
        "operationId": "getPlayerAppearance",
        "summary": "Get player appearance",
        "description": "Returns the player's Spartan appearance image.",
        "tags": ["Profile"],
        "parameters": [
          {
            "name": "player",
            "in": "path",
