  "components": {
    "schemas": {
      "CommandResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "error"
            ]
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "values": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "output": {
            "type": "string",
            "description": "Raw text output"
          },
          "error": {
            "type": "string",
            "description": "Error message if status is error"
          }
        }
      }
    },
