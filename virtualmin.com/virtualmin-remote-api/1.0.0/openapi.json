{
  "openapi": "3.0.3",
  "info": {
    "title": "Virtualmin Remote API",
    "version": "1.0.0",
    "description": "Virtualmin is a web hosting control panel for managing virtual servers, domains, users, databases, and email. The Remote API provides programmatic access to all Virtualmin operations through a CGI-based HTTP interface. All commands use GET/POST requests to the remote.cgi endpoint with an action parameter specifying the program to run.",
    "x-jentic-source-url": "https://www.virtualmin.com/docs/development/remote-api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://localhost:10000",
      "description": "Virtualmin server (replace with your hostname:port)"
    }
  ],
  "paths": {
    "/virtual-server/remote.cgi": {
      "get": {
        "operationId": "executeCommand",
        "summary": "Execute a Virtualmin command",
        "description": "Executes a Virtualmin CLI command via the remote API. The 'program' parameter specifies the command to run (e.g., list-domains, create-domain, delete-domain). Additional parameters are command-specific. Response format is controlled by the 'json' parameter.",
        "tags": [
          "Commands"
        ],
        "parameters": [
          {
            "name": "program",
            "in": "query",
            "required": true,
            "description": "Virtualmin program/command to execute (e.g., list-domains, create-domain, modify-domain, delete-domain, list-users, create-user, modify-user, delete-user, list-databases, create-database, delete-database, backup-domain, restore-domain, list-plans, modify-dns, install-cert, list-scripts)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "json",
            "in": "query",
            "description": "Set to 1 for JSON output format",
            "schema": {
              "type": "integer",
              "enum": [
                1
              ]
            }
          },
          {
            "name": "multiline",
            "in": "query",
            "description": "Set to empty string for multiline text output",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "domain",
            "in": "query",
            "description": "Domain name (used by most domain-related commands)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user",
            "in": "query",
            "description": "Username (for user-related commands)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Command output",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandResponse"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Command execution error"
          }
        }
      },
      "post": {
        "operationId": "executeCommandPost",
        "summary": "Execute a Virtualmin command (POST)",
        "description": "Same as GET but with POST method. Useful for commands with large payloads.",
        "tags": [
          "Commands"
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "program": {
                    "type": "string",
                    "description": "Virtualmin command name"
                  },
                  "json": {
                    "type": "integer"
                  },
                  "domain": {
                    "type": "string"
                  },
                  "user": {
                    "type": "string"
                  }
                },
                "required": [
                  "program"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Command output",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Command execution error"
          }
        }
      }
    },
    "/virtual-server/remote.cgi?program=list-domains": {
      "get": {
        "operationId": "listDomains",
        "summary": "List virtual servers (domains)",
        "description": "Lists all virtual servers (domains) managed by Virtualmin.",
        "tags": [
          "Domains"
        ],
        "parameters": [
          {
            "name": "program",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "list-domains"
              ]
            }
          },
          {
            "name": "json",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                1
              ]
            }
          },
          {
            "name": "domain",
            "in": "query",
            "description": "Filter by specific domain",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user",
            "in": "query",
            "description": "Filter by owner username",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name-only",
            "in": "query",
            "description": "Only return domain names",
            "schema": {
              "type": "integer",
              "enum": [
                1
              ]
            }
          },
          {
            "name": "multiline",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Domain list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandResponse"
                }
              }
            }
          }
        }
      }
    },
