{
  "openapi": "3.0.3",
  "info": {
    "title": "numverify API",
    "version": "1.0.0",
    "description": "numverify offers a full-featured phone number validation and lookup JSON API. Validate phone numbers, get line type, carrier, location, and more.",
    "x-jentic-source-url": "https://numverify.com/documentation",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://apilayer.net/api",
      "description": "numverify API"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "paths": {
    "/validate": {
      "get": {
        "operationId": "validatePhoneNumber",
        "tags": [
          "Validation"
        ],
        "summary": "Validate a phone number",
        "description": "Validate a phone number and retrieve detailed information including carrier, line type, location, and more.",
        "parameters": [
          {
            "name": "access_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your numverify API access key"
          },
          {
            "name": "number",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The phone number to validate. Must be in E.164 format (e.g., +14158586273)"
          },
          {
            "name": "country_code",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "ISO 3166-1 alpha-2 country code. Optional if number is in E.164 format."
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                1
              ]
            },
            "description": "Set to 1 to enable JSON pretty-print"
          }
        ],
        "responses": {
          "200": {
            "description": "Phone validation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "access_key",
        "description": "API access key passed as a query parameter"
      }
    },
    "schemas": {
      "ValidationResponse": {
        "type": "object",
        "properties": {
          "valid": {
            "type": "boolean",
            "description": "Whether the phone number is valid"
          },
          "number": {
            "type": "string",
            "description": "The phone number in E.164 format"
          },
          "local_format": {
            "type": "string",
            "description": "Local format of the phone number"
          },
          "international_format": {
            "type": "string",
            "description": "International format of the phone number"
          },
          "country_prefix": {
            "type": "string",
            "description": "Country calling code prefix"
          },
          "country_code": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code"
          },
          "country_name": {
            "type": "string",
            "description": "Full country name"
          },
          "location": {
            "type": "string",
            "description": "Geographic location (city, region)"
          },
          "carrier": {
            "type": "string",
            "description": "Telecom carrier"
          },
          "line_type": {
            "type": "string",
            "description": "Type of line (mobile, landline, special_services, toll_free, premium_rate, shared_cost, personal_number, pager, voip, unknown)"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        }
      },
      "ErrorDetail": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Error code"
          },
          "type": {
            "type": "string",
            "description": "Error type"
          },
          "info": {
            "type": "string",
            "description": "Error info"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Validation"
    }
  ]
}
