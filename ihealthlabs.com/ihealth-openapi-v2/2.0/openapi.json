            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User ID"
          },
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "client_secret",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sc",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Serial number of device"
          },
          {
            "name": "sv",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API version"
          },
          {
