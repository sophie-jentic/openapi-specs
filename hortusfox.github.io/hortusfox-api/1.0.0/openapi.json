              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Plant"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get plant details"
      },
      "put": {
        "operationId": "updatePlant",
        "summary": "Update a plant",
        "tags": [
          "Plants"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlantInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Plant updated"
          }
        },
        "description": "Update a plant"
      },
      "delete": {
        "operationId": "deletePlant",
        "summary": "Delete a plant",
        "tags": [
          "Plants"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Plant deleted"
          }
        },
        "description": "Delete a plant"
      }
    },
