{
  "openapi": "3.0.3",
  "info": {
    "title": "HortusFox API",
    "version": "1.0.0",
    "description": "HortusFox is a self-hosted plant management system. The API provides endpoints for managing plants, locations, tasks, inventory, and logging care activities.",
    "x-jentic-source-url": "https://hortusfox.github.io/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/api"
    }
  ],
  "paths": {
    "/plants": {
      "get": {
        "operationId": "listPlants",
        "summary": "List all plants",
        "tags": [
          "Plants"
        ],
        "parameters": [
          {
            "name": "location",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by location ID"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "name",
                "last_watered",
                "health",
                "date_added"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Plant list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Plant"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all plants"
      },
      "post": {
        "operationId": "createPlant",
        "summary": "Add a new plant",
        "tags": [
          "Plants"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "scientific_name": {
                    "type": "string"
                  },
                  "location_id": {
                    "type": "integer"
                  },
                  "notes": {
                    "type": "string"
                  },
                  "photo": {
                    "type": "string",
                    "format": "binary"
                  },
                  "perennial": {
                    "type": "boolean"
                  },
                  "cutting_month": {
                    "type": "integer"
                  },
                  "light_level": {
                    "type": "string",
                    "enum": [
                      "light_sunny",
                      "light_bright",
                      "light_shade"
                    ]
                  },
                  "humidity": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "location_id"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Plant created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Plant"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Add a new plant"
      }
    },
    "/plants/{id}": {
      "get": {
        "operationId": "getPlant",
        "summary": "Get plant details",
        "tags": [
