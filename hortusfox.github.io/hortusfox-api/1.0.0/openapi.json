  "components": {
    "schemas": {
      "Plant": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "scientific_name": {
            "type": "string"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "photo_url": {
            "type": "string"
          },
          "last_watered": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "last_fertilized": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "last_repotted": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "health": {
            "type": "string",
            "enum": [
              "good",
              "fair",
              "poor"
            ]
          },
          "perennial": {
            "type": "boolean"
          },
          "light_level": {
            "type": "string"
          },
          "humidity": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PlantInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "scientific_name": {
            "type": "string"
          },
          "location_id": {
            "type": "integer"
          },
          "notes": {
            "type": "string"
          },
          "perennial": {
            "type": "boolean"
          },
          "light_level": {
            "type": "string"
          },
          "humidity": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          },
          "plant_count": {
            "type": "integer"
          }
        }
      },
      "LocationInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          }
        },
        "required": [
          "name"
        ]
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "due_date": {
            "type": "string",
            "format": "date"
          },
          "done": {
            "type": "boolean"
          },
          "plant_id": {
            "type": "integer",
            "nullable": true
          }
        }
      },
      "TaskInput": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "due_date": {
            "type": "string",
            "format": "date"
          },
          "plant_id": {
            "type": "integer"
          }
        },
        "required": [
          "title"
        ]
      },
      "InventoryInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "amount": {
            "type": "integer"
          }
        },
        "required": [
          "name"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "CookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "laravel_session",
        "description": "Laravel session cookie"
      }
    }
  },
  "security": [
    {
      "CookieAuth": []
    }
