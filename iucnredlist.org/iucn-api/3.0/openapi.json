        },
        "tags": [
          "species"
        ]
      }
    },
    "/species/{name}": {
      "get": {
        "operationId": "getSpeciesByName",
        "summary": "Get species by name",
        "description": "Returns assessment information for a species by its scientific name.",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "Scientific name of the species (genus and species, e.g., 'Panthera leo')",
