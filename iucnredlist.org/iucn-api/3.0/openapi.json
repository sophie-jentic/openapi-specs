    "/species/category/{category}": {
      "get": {
        "operationId": "getSpeciesByCategory",
        "summary": "Get species by Red List category",
        "description": "Returns species filtered by their IUCN Red List category.",
        "parameters": [
          {
            "name": "category",
            "in": "path",
            "required": true,
            "description": "IUCN Red List category code",
            "schema": {
              "type": "string",
              "enum": [
                "DD",
                "LC",
                "NT",
                "VU",
                "EN",
                "CR",
                "EW",
                "EX",
                "LR/lc",
                "LR/nt",
                "LR/cd"
              ]
            }
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "API authentication token",
            "schema": {
