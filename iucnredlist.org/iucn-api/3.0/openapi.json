{
  "openapi": "3.0.3",
  "info": {
    "title": "IUCN Red List API",
    "description": "The IUCN Red List API provides programmatic access to the IUCN Red List of Threatened Species data. It enables retrieval of species assessments, conservation status, habitats, threats, conservation measures, and other biodiversity data. An API token is required for authentication.",
    "version": "3.0",
    "contact": {
      "name": "IUCN Red List",
      "url": "https://www.iucnredlist.org"
    },
    "license": {
      "name": "IUCN Red List Terms of Use",
      "url": "https://www.iucnredlist.org/terms/terms-of-use"
    }
  },
  "servers": [
    {
      "url": "https://apiv3.iucnredlist.org/api/v3",
      "description": "IUCN Red List API v3 server"
    }
  ],
  "paths": {
    "/version": {
      "get": {
        "operationId": "getVersion",
        "summary": "Get Red List version",
        "description": "Returns the current version of the IUCN Red List.",
        "responses": {
          "200": {
            "description": "Successful response with version information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionResponse"
                }
              }
            }
          }
        },
        "tags": [
          "version"
        ]
      }
    },
    "/species/page/{page_number}": {
      "get": {
        "operationId": "listSpeciesByPage",
        "summary": "List species by page",
        "description": "Returns a paginated list of all species in the IUCN Red List. Each page returns up to 10,000 records.",
        "parameters": [
          {
            "name": "page_number",
            "in": "path",
            "required": true,
            "description": "Page number (0-indexed)",
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "API authentication token",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with species list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpeciesListResponse"
                }
              }
            }
          }
        },
        "tags": [
          "species"
        ]
      }
    },
    "/species/count": {
      "get": {
        "operationId": "getSpeciesCount",
        "summary": "Get total species count",
        "description": "Returns the total count of species assessed in the IUCN Red List.",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "API authentication token",
            "schema": {
              "type": "string"
            }
