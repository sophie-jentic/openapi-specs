{
  "openapi": "3.0.3",
  "info": {
    "title": "Hastewire API",
    "version": "1.0.0",
    "description": "Hastewire AI content detection and humanization API for detecting AI-generated text and transforming it into natural human-sounding prose.",
    "x-jentic-source-url": "https://hastewire.com/docs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.hastewire.com/api/v1"
    }
  ],
  "paths": {
    "/detect": {
      "post": {
        "operationId": "detectAiContent",
        "summary": "Detect AI-generated content",
        "tags": [
          "Detection"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Text to analyze"
                  },
                  "language": {
                    "type": "string",
                    "description": "Language code"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Detection result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetectionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "402": {
            "description": "Insufficient balance"
          }
        },
        "description": "Detect AI-generated content"
      }
    },
    "/humanize": {
      "post": {
        "operationId": "humanizeText",
        "summary": "Humanize AI-generated text",
        "tags": [
          "Humanization"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string"
                  },
                  "style": {
                    "type": "string",
                    "enum": [
                      "formal",
                      "reddit",
                      "standard"
                    ]
                  },
                  "language": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Humanized text",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HumanizeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "402": {
            "description": "Insufficient balance"
          }
        },
        "description": "Humanize AI-generated text"
      }
    }
  },
  "components": {
    "schemas": {
      "DetectionResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "ai_probability": {
                "type": "number"
              },
              "classification": {
                "type": "string"
              }
            }
          },
          "cost_in_cents": {
            "type": "integer"
          },
          "remaining_balance_cents": {
            "type": "integer"
          }
        }
      },
      "HumanizeResponse": {
        "type": "object",
        "properties": {
          "humanized_text": {
            "type": "string"
          },
          "text_score": {
            "type": "number"
          },
          "cost_in_cents": {
            "type": "integer"
          },
          "remaining_balance_cents": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Detection"
    },
    {
      "name": "Humanization"
    }
  ]
}
