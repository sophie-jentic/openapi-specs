{
  "openapi": "3.0.3",
  "info": {
    "title": "Backendless REST API",
    "description": "Backendless is a mobile and web backend-as-a-service (BaaS) platform providing user management, data persistence, file storage, messaging, and more. This API covers user registration, login, data object CRUD operations, file management, and push notifications via a REST interface.",
    "version": "1.0.0",
    "contact": {
      "name": "Backendless Support",
      "url": "https://backendless.com/docs/rest"
    },
    "x-categories": [
      "Backend as a Service",
      "Mobile"
    ],
    "x-logo": {
      "url": "https://backendless.com/favicon.ico"
    }
  },
  "servers": [
    {
      "url": "https://{subdomain}.backendless.app/api",
      "description": "Backendless application endpoint",
      "variables": {
        "subdomain": {
          "default": "xxxx",
          "description": "Your Backendless application subdomain"
        }
      }
    }
  ],
  "paths": {
    "/users/register": {
      "post": {
        "operationId": "registerUser",
        "summary": "Register a new user",
        "description": "Creates a new user account. The request body must include the user identity property (usually email) and password. Additional properties can be included and will be stored in the Users table.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegistration"
              },
              "example": {
                "email": "alice@wonderland.com",
                "password": "secret123",
                "name": "Alice"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Registration error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendlessError"
                }
              }
            }
          }
        },
        "tags": [
          "Users"
        ]
      }
    },
    "/users/login": {
      "post": {
        "operationId": "loginUser",
        "summary": "User login",
        "description": "Authenticates a user with identity (usually email) and password. Returns a user object with a user-token that must be included in subsequent requests to maintain the session.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "login",
                  "password"
                ],
                "properties": {
                  "login": {
                    "type": "string",
                    "description": "User identity value (usually email)",
                    "example": "alice@wonderland.com"
                  },
                  "password": {
                    "type": "string",
                    "description": "User password",
                    "example": "secret123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Login error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendlessError"
                }
              }
            }
          }
        },
        "tags": [
          "Users"
        ]
      }
    },
    "/users/logout": {
      "get": {
        "operationId": "logoutUser",
        "summary": "User logout",
        "description": "Invalidates the user session.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          }
        ],
        "responses": {
          "200": {
            "description": "Logout successful"
          },
          "400": {
            "description": "Logout error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendlessError"
                }
              }
            }
          }
        },
        "tags": [
          "Users"
        ]
      }
    },
    "/users/restorepassword/{identity}": {
      "get": {
        "operationId": "restorePassword",
        "summary": "Restore password",
        "description": "Sends a password reset email to the user.",
        "parameters": [
          {
            "name": "identity",
            "in": "path",
            "required": true,
            "description": "User identity (email)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Password reset email sent"
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendlessError"
                }
              }
            }
          }
        },
        "tags": [
          "Users"
        ]
      }
    },
    "/users/{objectId}": {
      "get": {
        "operationId": "getUserById",
        "summary": "Get user by ID",
        "description": "Retrieves a user object by objectId.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "description": "The user's objectId",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        },
        "tags": [
          "Users"
        ]
      },
      "put": {
        "operationId": "updateUser",
        "summary": "Update user",
        "description": "Updates properties of an existing user.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "description": "The user's objectId",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        },
        "tags": [
          "Users"
        ]
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete user",
        "description": "Deletes a user by objectId.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          }
        },
        "tags": [
          "Users"
        ]
      }
    },
    "/data/{tableName}": {
      "post": {
        "operationId": "createDataObject",
        "summary": "Save a data object",
        "description": "Saves a new object in the specified table. If the table does not exist and Dynamic Schema Definition is enabled, Backendless creates the table and configures its schema automatically.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "$ref": "#/components/parameters/TableName"
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "description": "JSON object to save (properties match table columns)"
              },
              "example": {
                "name": "Bob",
                "age": 20
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Object saved with generated objectId",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataObject"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendlessError"
                }
              }
            }
          }
        },
        "tags": [
          "Data"
        ]
      },
      "get": {
        "operationId": "findDataObjects",
        "summary": "Search data objects",
        "description": "Retrieves objects from the specified table. Supports where clause filtering, sorting, pagination, property selection, and related object loading.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "$ref": "#/components/parameters/TableName"
          },
          {
            "name": "where",
            "in": "query",
            "description": "SQL-like where clause for filtering",
            "schema": {
              "type": "string"
            },
            "example": "age > 18"
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "Comma-separated list of columns to sort by",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of objects to skip",
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of objects to return (max 100)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            }
          },
          {
            "name": "property",
            "in": "query",
            "description": "Comma-separated list of properties to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "loadRelations",
            "in": "query",
            "description": "Comma-separated list of relations to load",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of matching objects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DataObject"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Data"
        ]
      }
    },
    "/data/{tableName}/{objectId}": {
      "get": {
        "operationId": "getDataObjectById",
        "summary": "Get a data object by ID",
        "description": "Retrieves a single object from the table by its objectId.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "$ref": "#/components/parameters/TableName"
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Data object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataObject"
                }
              }
            }
          }
        },
        "tags": [
          "Data"
        ]
      },
      "put": {
        "operationId": "updateDataObject",
        "summary": "Update a data object",
        "description": "Updates an existing object in the specified table.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "$ref": "#/components/parameters/TableName"
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataObject"
                }
              }
            }
          }
        },
        "tags": [
          "Data"
        ]
      },
      "delete": {
        "operationId": "deleteDataObject",
        "summary": "Delete a data object",
        "description": "Deletes a single object from the table by its objectId.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "$ref": "#/components/parameters/TableName"
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deletion timestamp",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deletionTime": {
                      "type": "integer",
                      "format": "int64"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Data"
        ]
      }
    },
    "/data/{tableName}/count": {
      "get": {
        "operationId": "getObjectCount",
        "summary": "Get object count",
        "description": "Returns the number of objects in the table matching the optional where clause.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "$ref": "#/components/parameters/TableName"
          },
          {
            "name": "where",
            "in": "query",
            "description": "SQL-like where clause for filtering",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object count",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "tags": [
          "Data"
        ]
      }
    },
    "/data/bulk/{tableName}": {
      "post": {
        "operationId": "bulkCreate",
        "summary": "Bulk create objects",
        "description": "Creates multiple objects in a single request.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Array of created objectIds",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Data"
        ]
      },
      "put": {
        "operationId": "bulkUpdate",
        "summary": "Bulk update objects",
        "description": "Updates multiple objects matching a where clause.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "where",
            "in": "query",
            "required": true,
            "description": "Where clause to select objects to update",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Number of updated objects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "tags": [
          "Data"
        ]
      },
      "delete": {
        "operationId": "bulkDelete",
        "summary": "Bulk delete objects",
        "description": "Deletes multiple objects matching a where clause.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "where",
            "in": "query",
            "required": true,
            "description": "Where clause to select objects to delete",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Number of deleted objects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "tags": [
          "Data"
        ]
      }
    },
    "/files/{filePath}": {
      "post": {
        "operationId": "uploadFile",
        "summary": "Upload a file",
        "description": "Uploads a file to the specified path in Backendless file storage.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "name": "filePath",
            "in": "path",
            "required": true,
            "description": "Full path including filename",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fileURL": {
                      "type": "string",
                      "format": "uri"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Files"
        ]
      },
      "delete": {
        "operationId": "deleteFile",
        "summary": "Delete a file",
        "description": "Deletes a file from Backendless file storage.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "name": "filePath",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File deleted"
          }
        },
        "tags": [
          "Files"
        ]
      }
    },
    "/messaging/{channel}": {
      "post": {
        "operationId": "publishMessage",
        "summary": "Publish a message",
        "description": "Publishes a message to the specified messaging channel.",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserToken"
          },
          {
            "name": "channel",
            "in": "path",
            "required": true,
            "description": "Channel name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "Message content"
                  },
                  "headers": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "publishPolicy": {
                    "type": "string"
                  },
                  "subtopic": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message published",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "messageId": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Messaging"
        ]
      }
    }
  },
  "components": {
    "parameters": {
      "UserToken": {
        "name": "user-token",
        "in": "header",
        "description": "User session token from login response",
        "schema": {
          "type": "string"
        }
      },
      "TableName": {
        "name": "tableName",
        "in": "path",
        "required": true,
        "description": "Name of the data table",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "UserRegistration": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email (identity property)"
          },
          "password": {
            "type": "string",
            "description": "User password"
          },
          "name": {
            "type": "string",
            "description": "User display name"
          }
        },
        "additionalProperties": true
      },
      "User": {
        "type": "object",
        "properties": {
          "objectId": {
            "type": "string",
            "description": "Unique user identifier"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string"
          },
          "user-token": {
            "type": "string",
            "description": "Session token (returned on login)"
          },
          "ownerId": {
            "type": "string"
          },
          "created": {
            "type": "integer",
            "format": "int64",
            "description": "Creation timestamp"
          },
          "updated": {
            "type": "integer",
            "format": "int64"
          }
        },
        "additionalProperties": true
      },
      "DataObject": {
        "type": "object",
        "properties": {
          "objectId": {
            "type": "string",
            "description": "Unique object identifier assigned by Backendless"
          },
          "ownerId": {
            "type": "string"
          },
          "created": {
            "type": "integer",
            "format": "int64"
          },
          "updated": {
            "type": "integer",
            "format": "int64"
          }
        },
        "additionalProperties": true
      },
      "BackendlessError": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Users",
      "description": "User registration, authentication, and management"
    },
    {
      "name": "Data",
      "description": "Data table CRUD operations"
    },
