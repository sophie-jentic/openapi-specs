{
  "openapi": "3.0.3",
  "info": {
    "title": "Chatfuel API",
    "version": "1.0.0",
    "description": "Chatfuel API provides endpoints for broadcasting messages to subscribers and sending messages via the JSON API. Chatfuel is a platform for building chatbots for Facebook Messenger and other platforms.",
    "x-jentic-source-url": "https://docs.chatfuel.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.chatfuel.com",
      "description": "Chatfuel API Server"
    }
  ],
  "tags": [
    {
      "name": "Broadcasting",
      "description": "Send broadcast messages to subscribers"
    },
    {
      "name": "Bot Users",
      "description": "Manage bot users"
    }
  ],
  "paths": {
    "/bots/{botId}/users/{userId}/send": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send message to user",
        "description": "Send a message or trigger a block/flow for a specific bot user. The user must have interacted with the bot previously.",
        "tags": [
          "Bot Users"
        ],
        "parameters": [
          {
            "name": "botId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Bot ID"
          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User ID (Messenger PSID or platform-specific ID)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "chatfuel_token": {
                    "type": "string",
                    "description": "Chatfuel API token for authentication"
                  },
                  "chatfuel_message_tag": {
                    "type": "string",
                    "description": "Message tag for sending outside 24-hour window"
                  },
                  "chatfuel_block_name": {
                    "type": "string",
                    "description": "Name of the block to trigger"
                  },
                  "chatfuel_block_id": {
                    "type": "string",
                    "description": "ID of the block to trigger"
                  },
                  "chatfuel_flow_name": {
                    "type": "string",
                    "description": "Name of the flow to trigger"
                  }
                },
                "additionalProperties": {
                  "type": "string",
                  "description": "Custom user attributes to set"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "result": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "User or bot not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bots/{botId}/users": {
      "get": {
        "operationId": "getUsers",
        "summary": "Get bot users",
        "description": "Retrieve a list of users who have interacted with the bot.",
        "tags": [
          "Bot Users"
        ],
        "parameters": [
          {
            "name": "botId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Bot ID"
          },
          {
            "name": "chatfuel_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Chatfuel API token"
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter users by tag"
          },
          {
            "name": "segment",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter users by segment"
          }
        ],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/BotUser"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bots/{botId}/users/{userId}/attributes": {
      "put": {
        "operationId": "setUserAttributes",
        "summary": "Set user attributes",
        "description": "Set custom attributes for a bot user.",
        "tags": [
          "Bot Users"
        ],
        "parameters": [
          {
            "name": "botId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Bot ID"
          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "chatfuel_token"
                ],
                "properties": {
                  "chatfuel_token": {
                    "type": "string",
                    "description": "Chatfuel API token"
                  }
                },
                "additionalProperties": {
                  "type": "string",
                  "description": "Custom attribute key-value pairs to set"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Attributes updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bots/{botId}/broadcast": {
      "post": {
        "operationId": "sendBroadcast",
        "summary": "Send broadcast",
        "description": "Send a broadcast message to all subscribers or a segment. The Broadcasting API allows you to send messages outside the 24-hour window using approved message tags.",
        "tags": [
          "Broadcasting"
        ],
        "parameters": [
          {
            "name": "botId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Bot ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "chatfuel_token",
                  "chatfuel_block_name"
                ],
                "properties": {
                  "chatfuel_token": {
                    "type": "string",
                    "description": "Chatfuel API token"
                  },
                  "chatfuel_block_name": {
                    "type": "string",
                    "description": "Name of the block to broadcast"
                  },
                  "chatfuel_block_id": {
                    "type": "string",
                    "description": "ID of the block to broadcast"
                  },
                  "chatfuel_message_tag": {
                    "type": "string",
                    "description": "Message tag for the broadcast"
                  },
                  "segment": {
                    "type": "string",
                    "description": "Segment to target (optional, broadcasts to all if omitted)"
                  },
                  "tag": {
                    "type": "string",
                    "description": "Tag to filter target users"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Broadcast sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "total_count": {
                      "type": "integer",
                      "description": "Number of users who received the broadcast"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BotUser": {
        "type": "object",
        "properties": {
          "messenger_user_id": {
            "type": "string",
            "description": "Messenger PSID"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "gender": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "description": "How the user was acquired"
          },
          "last_interaction": {
            "type": "string",
            "format": "date-time"
          },
          "signed_up": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}
