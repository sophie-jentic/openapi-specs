{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Fake fake-detection API (Backend Recruiting Homework)",
    "description": "The api describes a simple, fake-detetion API endpoint which is used for recruiting purposes.",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Jaumo/backend-recruiting-homework_fake-detection/1.0.0/swagger.json",
    "contact": {}
  },
  "servers": [
    {
      "description": "Hosted API",
      "url": "https://api.jaumo.com/recruiting/fake_detection"
    }
  ],
  "paths": {
    "/": {
      "post": {
        "summary": "Perform fake-detection",
        "description": "Perform fake-detection and return a score based on the given user. May take multiple seconds.",
        "tags": [
          "fake-detection"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/User"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A fake-detection score",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FakeScore"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "5XX": {
            "description": "Unexpected Server Error"
          }
        },
        "operationId": "post"
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "foo@example.org",
            "format": "email"
          },
          "gender": {
            "type": "string",
            "enum": [
              "male",
              "female",
              "other"
            ]
          },
          "birthday": {
            "type": "string",
            "format": "date",
            "example": "1970-01-01"
          }
        }
      },
      "FakeScore": {
        "type": "object",
        "properties": {
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "The value tells the likelihood that the given user is fake.",
            "example": 0.6281
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "A error message describing the problem."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "fake-detection"
    }
  ]
}
