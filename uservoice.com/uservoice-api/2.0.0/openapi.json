{
  "openapi": "3.0.3",
  "info": {
    "title": "UserVoice API",
    "version": "2.0.0",
    "description": "UserVoice is a product management and customer feedback platform. The API provides operations for managing suggestions, forums, users, tickets, and feedback.",
    "x-jentic-source-url": "https://developer.uservoice.com/docs/api/v2/reference/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{subdomain}.uservoice.com/api/v2",
      "variables": {
        "subdomain": {
          "default": "yoursite",
          "description": "Your UserVoice subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://{subdomain}.uservoice.com/api/v2/oauth/token",
            "scopes": {}
          },
          "authorizationCode": {
            "authorizationUrl": "https://{subdomain}.uservoice.com/api/v2/oauth/authorize",
            "tokenUrl": "https://{subdomain}.uservoice.com/api/v2/oauth/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "Suggestion": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "body_mime_type": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "status": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "hex_color": {
                "type": "string"
              }
            }
          },
          "vote_count": {
            "type": "integer"
          },
          "supporter_count": {
            "type": "integer"
          },
          "comments_count": {
            "type": "integer"
          },
          "creator": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "email": {
                "type": "string"
              }
            }
          },
          "category": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "forum": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Forum": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "welcome_message": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "is_public": {
            "type": "boolean"
          },
          "suggestions_count": {
            "type": "integer"
          },
          "open_suggestions_count": {
            "type": "integer"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "supported_suggestions_count": {
            "type": "integer"
          },
          "is_admin": {
            "type": "boolean"
          }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "body": {
            "type": "string"
          },
          "creator": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Status": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "hex_color": {
            "type": "string"
          },
          "is_open": {
            "type": "boolean"
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "suggestions_count": {
            "type": "integer"
          }
        }
      },
      "Label": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "NpsRating": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "rating": {
            "type": "integer"
          },
          "body": {
            "type": "string"
          },
          "user": {
            "type": "object"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Feature": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "links": {
            "type": "object"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ListResponse": {
        "type": "object",
        "properties": {
          "suggestions": {
            "type": "array",
            "items": {}
          },
          "pagination": {
            "type": "object",
            "properties": {
              "page": {
                "type": "integer"
              },
              "per_page": {
                "type": "integer"
              },
              "total_records": {
                "type": "integer"
              },
              "total_pages": {
                "type": "integer"
              }
            }
          }
        }
      }
    },
    "parameters": {
      "page": {
        "name": "page",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 1
        }
      },
      "per_page": {
        "name": "per_page",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 20,
          "maximum": 100
        }
      },
      "sort": {
        "name": "sort",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": [
            "newest",
            "oldest",
            "most_votes",
            "most_important",
            "trending"
          ]
        }
      }
    }
  },
  "paths": {
    "/admin/suggestions": {
      "get": {
        "summary": "List suggestions",
        "operationId": "suggestions_list",
        "tags": [
          "Suggestions"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/page"
          },
          {
            "$ref": "#/components/parameters/per_page"
          },
          {
            "$ref": "#/components/parameters/sort"
          },
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "approved",
                "published",
                "closed"
              ]
            }
          },
          {
            "name": "forum_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "status_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "category_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "label_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "suggestions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Suggestion"
                      }
                    },
                    "pagination": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List suggestions"
      }
    },
    "/admin/suggestions/{id}": {
      "get": {
        "summary": "Retrieve a suggestion",
        "operationId": "suggestions_get",
        "tags": [
          "Suggestions"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Suggestion",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "suggestion": {
                      "$ref": "#/components/schemas/Suggestion"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Retrieve a suggestion"
      },
      "put": {
        "summary": "Update a suggestion",
        "operationId": "suggestions_update",
        "tags": [
          "Suggestions"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "suggestion": {
                    "type": "object",
                    "properties": {
                      "title": {
                        "type": "string"
                      },
                      "body": {
                        "type": "string"
                      },
                      "category_id": {
                        "type": "integer"
                      },
                      "status_id": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        },
        "description": "Update a suggestion"
      }
    },
    "/admin/suggestions/{id}/convert": {
      "put": {
        "summary": "Convert suggestion to ticket",
        "operationId": "suggestions_convert",
        "tags": [
          "Suggestions"
        ],
        "parameters": [
          {
            "name": "id",
