{
  "openapi": "3.0.3",
  "info": {
    "title": "Billplz API",
    "version": "v4",
    "description": "Billplz provides a REST API for bill creation and payment collection in Malaysia",
    "x-jentic-source-url": "https://www.billplz.com/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.billplz.com/api",
      "description": "Production"
    },
    {
      "url": "https://www.billplz-sandbox.com/api",
      "description": "Sandbox"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/v3/collections": {
      "post": {
        "summary": "Create a collection",
        "description": "Create a new collection to group related bills",
        "operationId": "createCollection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Collection title"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Collection created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Collection"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        },
        "tags": [
          "v3"
        ]
      }
    },
    "/v3/bills": {
      "post": {
        "summary": "Create a bill",
        "description": "Create a new bill for payment",
        "operationId": "createBill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "collection_id",
                  "email",
                  "name",
                  "amount"
                ],
                "properties": {
                  "collection_id": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "name": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "integer",
                    "description": "Amount in cents"
                  },
                  "callback_url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bill created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bill"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        },
        "tags": [
          "v3"
        ]
      }
    },
    "/v3/bills/{billId}": {
      "get": {
        "summary": "Get bill status",
        "description": "Retrieve the status of a specific bill",
        "operationId": "getBill",
        "parameters": [
          {
            "name": "billId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bill details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bill"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        },
        "tags": [
          "v3"
        ]
      },
      "delete": {
        "summary": "Delete a bill",
        "description": "Delete a due bill",
        "operationId": "deleteBill",
        "parameters": [
          {
            "name": "billId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bill deleted successfully"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        },
        "tags": [
          "v3"
        ]
      }
    },
    "/v4/payment_gateways": {
      "get": {
        "summary": "List payment gateways",
        "description": "Get available payment options with codes",
        "operationId": "listPaymentGateways",
        "responses": {
          "200": {
            "description": "List of payment gateways",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PaymentGateway"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "v4"
        ]
      }
    },
    "/v4/cards": {
      "post": {
        "summary": "Tokenize card",
        "description": "Tokenize a card for future charges",
        "operationId": "tokenizeCard",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "card_number": {
                    "type": "string"
                  },
                  "expiry_month": {
                    "type": "integer"
                  },
                  "expiry_year": {
                    "type": "integer"
                  },
                  "cvv": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Card tokenized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        },
        "tags": [
          "v4"
        ]
      }
    },
    "/v5/payment_order_collections": {
      "post": {
        "summary": "Create payment order collection",
        "description": "Create a payment order group",
        "operationId": "createPaymentOrderCollection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment order collection created"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        },
        "tags": [
          "v5"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication with API Secret Key as username"
      }
    },
    "schemas": {
      "Collection": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "logo": {
            "type": "object"
          },
          "split_payment": {
            "type": "object"
          }
        }
      },
      "Bill": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "collection_id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "amount": {
            "type": "integer"
          },
          "paid": {
            "type": "boolean"
          },
          "state": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "PaymentGateway": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "ErrorResponse": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "v3"
    },
    {
      "name": "v4"
    },
    {
      "name": "v5"
    }
  ]
}
