          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ReviewInput": {
        "type": "object",
        "required": [
          "productId",
          "userId",
          "rating"
        ],
        "properties": {
          "productId": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "rating": {
            "type": "number",
            "format": "double",
            "minimum": 1,
