    "contact": {
      "name": "Dummy Products API",
      "url": "https://dummyproducts-api.herokuapp.com"
    },
    "x-jentic-source-url": "https://dummyproducts-api.herokuapp.com/"
  },
  "servers": [
    {
      "url": "https://dummyproducts-api.herokuapp.com/api/v1",
      "description": "Production server"
    }
  ],
