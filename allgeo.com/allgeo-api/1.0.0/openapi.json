{
  "openapi": "3.0.3",
  "info": {
    "title": "allGeo API",
    "version": "1.0.0",
    "description": "allGeo provides workforce management APIs for managing work orders, job sites, devices, time clock entries, and messaging.",
    "x-jentic-source-url": "https://www.allgeo.com/API-Document.html",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.allgeo.com/track"
    }
  ],
  "paths": {
    "/react/v1/login": {
      "post": {
        "operationId": "login",
        "summary": "Authenticate and get access token",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "accountId",
                  "userId",
                  "password"
                ],
                "properties": {
                  "accountId": {
                    "type": "string"
                  },
                  "userId": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful login",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Authenticate and get access token"
      }
    },
    "/react/v1/refresh": {
      "get": {
        "operationId": "refreshToken",
        "summary": "Refresh access token",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "New token"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Refresh access token"
      }
    },
    "/api/v1/schedule": {
      "post": {
        "operationId": "createWorkOrder",
        "summary": "Create or update work order",
        "tags": [
          "Work Orders"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create or update work order"
      }
    },
    "/api/v1/deleteSchedule/{workOrderNumber}": {
      "delete": {
        "operationId": "deleteWorkOrder",
        "summary": "Delete a work order",
        "tags": [
          "Work Orders"
        ],
        "parameters": [
          {
            "name": "workOrderNumber",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete a work order"
      }
    },
    "/api/v1/createSites": {
      "post": {
        "operationId": "createJobSite",
        "summary": "Create a job site",
        "tags": [
          "Job Sites"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "siteID",
                  "name",
                  "address"
                ],
                "properties": {
                  "siteID": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "address": {
                    "type": "string"
                  },
                  "radius": {
                    "type": "number"
                  },
                  "latitude": {
                    "type": "number"
                  },
                  "longitude": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a job site"
      }
    },
    "/api/v1/deleteSite/{name}": {
      "delete": {
        "operationId": "deleteJobSite",
        "summary": "Delete a job site",
        "tags": [
          "Job Sites"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete a job site"
      }
    },
    "/api/v1/createDevices": {
      "post": {
        "operationId": "createDevice",
        "summary": "Register a device",
        "tags": [
          "Devices"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "deviceID",
                  "deviceDesc"
                ],
                "properties": {
                  "deviceID": {
                    "type": "string"
                  },
                  "deviceDesc": {
                    "type": "string"
                  },
                  "timezone": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Register a device"
      }
    },
    "/api/v1/device/{deviceID}/delete": {
      "delete": {
        "operationId": "deleteDevice",
        "summary": "Delete a device",
        "tags": [
          "Devices"
        ],
        "parameters": [
          {
            "name": "deviceID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete a device"
      }
    },
    "/api/v1/createTimeClock": {
      "post": {
        "operationId": "createTimeClock",
        "summary": "Record a time clock entry",
        "tags": [
          "Time Clock"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "deviceID",
                  "timeClockSentTime",
                  "stageName"
                ],
                "properties": {
                  "deviceID": {
                    "type": "string"
                  },
                  "timeClockSentTime": {
                    "type": "string"
                  },
                  "stageName": {
                    "type": "string"
                  },
                  "address": {
                    "type": "string"
                  },
                  "customerName": {
                    "type": "string"
                  },
                  "jobName": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Record a time clock entry"
      }
    },
    "/api/v1/updateTimeClock": {
      "post": {
        "operationId": "updateTimeClock",
        "summary": "Update a time clock entry",
        "tags": [
          "Time Clock"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "txnID",
                  "deviceID",
                  "timeClockSentTime"
                ],
                "properties": {
                  "txnID": {
                    "type": "string"
                  },
                  "deviceID": {
                    "type": "string"
                  },
                  "timeClockSentTime": {
                    "type": "string"
                  },
                  "stageName": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update a time clock entry"
      }
    },
    "/api/v1/allgeo/sendMessage": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send SMS or push notification",
        "tags": [
          "Messaging"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "deviceID",
                  "messageType"
                ],
                "properties": {
                  "deviceID": {
                    "type": "string"
                  },
                  "messageType": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Send SMS or push notification"
      }
    },
    "/api/v1/logout": {
      "post": {
        "operationId": "logout",
        "summary": "Logout and invalidate token",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Logged out"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Logout and invalidate token"
      }
    }
  },
  "components": {
    "schemas": {
      "WorkOrderRequest": {
        "type": "object",
        "required": [
          "workOrderNumber",
          "workOrderType",
          "deviceDesc",
          "deviceID",
          "locatable",
          "startDate",
          "endDate",
          "startTime",
          "endTime"
        ],
        "properties": {
          "workOrderNumber": {
            "type": "string"
          },
          "workOrderType": {
            "type": "string"
          },
          "deviceDesc": {
            "type": "string"
          },
          "deviceID": {
            "type": "string"
          },
          "locatable": {
            "type": "string"
          },
          "startDate": {
            "type": "string"
          },
          "endDate": {
            "type": "string"
          },
          "startTime": {
            "type": "string"
          },
          "endTime": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication"
    },
    {
      "name": "Devices"
    },
    {
