{
  "openapi": "3.0.3",
  "info": {
    "title": "RepliQ API",
    "version": "2.0.0",
    "description": "RepliQ API for generating personalized videos, images, and AI-powered email content. All endpoints require Bearer token authentication. Generate videos, images, and text with personalization at scale.",
    "x-jentic-source-url": "https://developer.repliq.co/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.repliq.co/v2"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "components": {
    "schemas": {
      "CreditsResponse": {
        "type": "object",
        "properties": {
          "creditsCount": {
            "type": "number",
            "description": "Number of credits you have left on your account"
          },
          "linkedinTodayCredits": {
            "type": "number",
            "description": "Number of linkedin credits you can still use today"
          }
        }
      },
      "TemplateListResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "The id of the template"
            },
            "name": {
              "type": "string",
              "description": "The name of the template"
            }
          }
        }
      },
      "VideoScaleRequest": {
        "type": "object",
        "required": [
          "templateId",
          "url"
        ],
        "properties": {
          "templateId": {
            "type": "string",
            "description": "Template identifier"
          },
          "url": {
            "type": "string",
            "description": "Website URL to use as video background"
          },
          "firstName": {
            "type": "string",
            "description": "Recipient's first name"
          },
          "lastName": {
            "type": "string",
            "description": "Recipient's last name"
          },
          "email": {
            "type": "string",
            "description": "Email address for video delivery"
          },
          "webhook": {
            "type": "string",
            "description": "Webhook URL triggered upon completion"
          }
        }
      },
      "TemplateResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "placeholder": {
            "type": "object"
          }
        }
      },
      "WebhookSubscriptionRequest": {
        "type": "object",
        "required": [
          "hookUrl"
        ],
        "properties": {
          "hookUrl": {
            "type": "string",
            "description": "A valid HTTPS URL. Only one video-view URL is stored per account"
          }
        }
      },
      "WebhookSubscriptionResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "hookUrl": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "nullable": true
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "paths": {
    "/getCreditsCount": {
      "get": {
        "summary": "Get credits count",
        "description": "Retrieve the number of credits remaining in your account and LinkedIn credits available today",
        "operationId": "getCreditsCount",
        "tags": [
          "Credits"
        ],
        "responses": {
          "200": {
            "description": "Credits information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreditsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/templateList": {
      "get": {
        "summary": "Get template list",
        "description": "Retrieve all templates available in your RepliQ account",
        "operationId": "getTemplateList",
        "tags": [
          "Templates"
        ],
        "responses": {
          "200": {
            "description": "List of templates",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/launchTemplate": {
      "post": {
        "summary": "Launch template",
        "description": "Generate personalized content from a template. Used for Video Scale, AI Avatar, GPT Image, Text to Video, AI Email, and AI Image templates. Takes approximately 1 minute per request.",
        "operationId": "launchTemplate",
        "tags": [
          "Content Generation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VideoScaleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Template launched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateResponse"
                }
              }
            }
          }
        }
      }
    },
    "/createVideoViewWebhookSubscription": {
      "post": {
        "summary": "Create video view webhook subscription",
        "description": "Register a webhook URL to receive notifications when videos are viewed at different milestone percentages (started, 25%, 50%, 75%, 100%)",
        "operationId": "createVideoViewWebhook",
        "tags": [
          "Webhooks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscriptionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook subscription created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookSubscriptionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input or token issue"
          },
          "403": {
            "description": "Feature unavailable on free tier"
          },
          "404": {
            "description": "User account not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/deleteVideoViewWebhookSubscription": {
      "delete": {
        "summary": "Delete video view webhook subscription",
        "description": "Remove the registered video view webhook URL from your account",
        "operationId": "deleteVideoViewWebhook",
        "tags": [
          "Webhooks"
        ],
        "responses": {
          "200": {
            "description": "Webhook subscription deleted"
          },
          "404": {
            "description": "User account not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Credits",
      "description": "Credit management endpoints"
    },
    {
      "name": "Templates",
      "description": "Template management endpoints"
    },
    {
      "name": "Content Generation",
      "description": "Generate personalized videos, images, and text"
    },
    {
      "name": "Webhooks",
      "description": "Webhook subscription management"
    }
  ]
}
