{
  "openapi": "3.0.3",
  "info": {
    "title": "Alchemy API",
    "version": "2.0.0",
    "description": "Alchemy is a blockchain infrastructure platform providing enhanced APIs for Ethereum, Polygon, Arbitrum, and other chains. The REST API provides endpoints for NFTs, tokens, transfers, webhooks (Notify), and enhanced blockchain data queries.",
    "x-jentic-source-url": "https://docs.alchemy.com",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://eth-mainnet.g.alchemy.com/v2/{apiKey}",
      "variables": {
        "apiKey": {
          "default": "demo",
          "description": "Your Alchemy API key"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "NFT",
      "description": "NFT data endpoints"
    },
    {
      "name": "Token",
      "description": "Token balance and metadata endpoints"
    },
    {
      "name": "Transfers",
      "description": "Asset transfer history"
    },
    {
      "name": "Notify",
      "description": "Webhook notification management"
    },
    {
      "name": "Core",
      "description": "Enhanced Ethereum JSON-RPC methods"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/getNFTsForOwner": {
      "get": {
        "operationId": "getNFTsForOwner",
        "summary": "Get NFTs for owner",
        "description": "Get all NFTs currently owned by a given address.",
        "tags": [
          "NFT"
        ],
        "parameters": [
          {
            "name": "owner",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Owner wallet address"
          },
          {
            "name": "pageKey",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Pagination key"
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100
            },
            "description": "Results per page (max 100)"
          },
          {
            "name": "contractAddresses[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Filter by contract addresses"
          },
          {
            "name": "withMetadata",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": true
            },
            "description": "Include NFT metadata"
          },
          {
            "name": "excludeFilters[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "SPAM",
                  "AIRDROPS"
                ]
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "NFTs for owner",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NFTListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/getNFTMetadata": {
      "get": {
        "operationId": "getNFTMetadata",
        "summary": "Get NFT metadata",
        "tags": [
          "NFT"
        ],
        "parameters": [
          {
            "name": "contractAddress",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tokenId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tokenType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "ERC721",
                "ERC1155"
              ]
            }
          },
          {
            "name": "refreshCache",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "NFT metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NFT"
                }
              }
            }
          }
        },
        "description": "Get NFT metadata"
      }
    },
    "/getContractMetadata": {
      "get": {
        "operationId": "getContractMetadata",
        "summary": "Get contract metadata",
        "tags": [
          "NFT"
        ],
        "parameters": [
          {
            "name": "contractAddress",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Contract metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContractMetadata"
                }
              }
            }
          }
        },
        "description": "Get contract metadata"
      }
    },
    "/getNFTsForContract": {
      "get": {
        "operationId": "getNFTsForContract",
        "summary": "Get NFTs for contract",
        "tags": [
          "NFT"
        ],
        "parameters": [
          {
            "name": "contractAddress",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startToken",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "withMetadata",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "NFTs in contract"
          }
        },
        "description": "Get NFTs for contract"
      }
    },
    "/getOwnersForNFT": {
      "get": {
        "operationId": "getOwnersForNFT",
        "summary": "Get owners for an NFT",
        "tags": [
          "NFT"
        ],
        "parameters": [
          {
            "name": "contractAddress",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tokenId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Owners list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "owners": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get owners for an NFT"
      }
    },
    "/getTokenBalances": {
      "get": {
        "operationId": "getTokenBalances",
        "summary": "Get token balances for address",
        "tags": [
          "Token"
        ],
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Wallet address"
          },
          {
            "name": "tokenAddresses[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Specific token contracts"
          }
        ],
        "responses": {
          "200": {
            "description": "Token balances",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenBalanceResponse"
                }
              }
            }
          }
        },
        "description": "Get token balances for address"
      }
    },
    "/getTokenMetadata": {
      "get": {
        "operationId": "getTokenMetadata",
        "summary": "Get token metadata",
        "tags": [
          "Token"
        ],
        "parameters": [
          {
            "name": "contractAddress",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Token metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenMetadata"
                }
              }
            }
          }
        },
        "description": "Get token metadata"
      }
    },
    "/getAssetTransfers": {
      "post": {
        "operationId": "getAssetTransfers",
        "summary": "Get asset transfers",
        "description": "Get historical asset transfers for an address.",
        "tags": [
          "Transfers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "example": 1
                  },
                  "jsonrpc": {
                    "type": "string",
                    "example": "2.0"
                  },
                  "method": {
                    "type": "string",
                    "example": "alchemy_getAssetTransfers"
                  },
                  "params": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "fromBlock": {
                          "type": "string"
                        },
                        "toBlock": {
                          "type": "string"
                        },
                        "fromAddress": {
                          "type": "string"
                        },
                        "toAddress": {
                          "type": "string"
                        },
                        "category": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": [
                              "external",
                              "internal",
                              "erc20",
                              "erc721",
                              "erc1155",
                              "specialnft"
                            ]
                          }
                        },
                        "withMetadata": {
                          "type": "boolean"
                        },
                        "maxCount": {
                          "type": "string",
                          "description": "Hex string"
                        },
                        "pageKey": {
                          "type": "string"
                        },
                        "order": {
                          "type": "string",
                          "enum": [
                            "asc",
                            "desc"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer results"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "path",
        "name": "apiKey",
        "description": "Alchemy API key embedded in URL path"
      }
    },
    "schemas": {
      "NFTListResponse": {
        "type": "object",
        "properties": {
          "ownedNfts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NFT"
            }
          },
          "totalCount": {
            "type": "integer"
          },
          "pageKey": {
            "type": "string"
          }
        }
      },
      "NFT": {
        "type": "object",
        "properties": {
          "contract": {
            "type": "object",
            "properties": {
              "address": {
                "type": "string"
              }
            }
          },
          "tokenId": {
            "type": "string"
          },
          "tokenType": {
            "type": "string",
            "enum": [
              "ERC721",
              "ERC1155"
            ]
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "tokenUri": {
            "type": "object",
            "properties": {
              "raw": {
                "type": "string"
              },
              "gateway": {
                "type": "string"
              }
            }
          },
          "media": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "raw": {
                  "type": "string"
                },
                "gateway": {
                  "type": "string"
                },
                "thumbnail": {
                  "type": "string"
                },
                "format": {
                  "type": "string"
                }
              }
            }
          },
          "balance": {
            "type": "string"
          }
        }
      },
      "ContractMetadata": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "contractMetadata": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "symbol": {
                "type": "string"
              },
              "totalSupply": {
                "type": "string"
              },
              "tokenType": {
                "type": "string"
              },
              "openSea": {
                "type": "object"
              }
            }
          }
        }
      },
      "TokenBalanceResponse": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "tokenBalances": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "contractAddress": {
                  "type": "string"
                },
                "tokenBalance": {
                  "type": "string"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "TokenMetadata": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "decimals": {
            "type": "integer"
          },
          "logo": {
            "type": "string"
          }
        }
      }
    }
  }
}
