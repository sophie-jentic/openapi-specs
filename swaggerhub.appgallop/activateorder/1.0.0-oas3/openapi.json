{
  "openapi": "3.0.0",
  "info": {
    "description": "This API validates an order ref number, Creates Customer and initializes subscription.",
    "version": "1.0.0-oas3",
    "title": "ActivateOrder",
    "contact": {
      "email": "gagan.s@appgallop.com"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/AppGallop/Activateorder/1.0.0-oas3/swagger.json"
  },
  "tags": [
    {
      "name": "customer"
    }
  ],
  "paths": {
    "/orders/postorder": {
      "post": {
        "tags": [
          "customer"
        ],
        "summary": "Authorization Bearer Token (JWT)",
        "description": "Activate order",
        "responses": {
          "200": {
            "description": "success"
          },
          "401": {
            "description": "unauthorized"
          },
          "500": {
            "description": "internal server error"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/requestBody"
              }
            }
          }
        },
        "operationId": "post-orders-postorder"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "requestBody": {
        "type": "object",
        "properties": {
          "digitalServiceOrder": {
            "type": "object",
            "properties": {
              "orderHeader": {
                "type": "object",
                "required": [
                  "orderRefNo",
                  "orderType",
                  "orderEntryTimeStamp",
                  "channelId",
                  "agentCode"
                ],
                "properties": {
                  "orderRefNo": {
                    "type": "string",
                    "example": "XXXXXXXXNR81"
                  },
                  "orderType": {
                    "type": "string",
                    "example": "ACTIVATE"
                  },
                  "orderEntryTimeStamp": {
                    "type": "string",
                    "example": "2019-09-03T13:54:46"
                  },
                  "channelId": {
                    "type": "string",
                    "example": "30"
                  },
                  "agentCode": {
                    "type": "string",
                    "example": "55018940"
                  }
                }
              },
              "customers": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/customersArray"
                    }
                  ]
                }
              },
              "addresses": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/addressesArray"
                    }
                  ]
                }
              },
              "planOfferings": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/planOfferingsArr"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "accountsArray": {
        "type": "object",
        "properties": {
          "accountId": {
            "type": "string",
            "example": "500000026273"
          },
          "accountType": {
            "type": "string",
            "example": "1"
          },
          "subscriptionType": {
            "type": "string",
            "example": "1"
          },
          "companyCode": {
            "type": "string",
            "example": "XX00"
          },
          "circleId": {
            "type": "string",
            "example": "KL"
          }
        }
      },
      "characterArray": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "NAME_OF_CHARACTERISTICS"
          },
          "value": {
            "type": "string",
            "example": "VALUE_OF_CHARACTERISTICS"
          }
        }
      },
      "planOfferingsArr": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "tranRefNo": {
            "type": "string",
            "example": "10"
          },
          "id": {
            "type": "string",
            "example": "5109"
          },
          "accounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/accountsArray"
            }
          },
          "characteristics": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/characterArray"
                },
                {
                  "$ref": "#/components/schemas/characterArray"
                }
              ]
            }
          }
        }
      },
      "addressesArray": {
        "type": "object",
        "required": [
          "addressType",
          "buildingId",
          "street",
          "pinCode",
          "city",
          "district",
          "state",
          "country"
        ],
        "properties": {
          "addressId": {
            "type": "string",
            "example": "0001660639"
          },
          "addressType": {
            "type": "string",
            "example": "SHIP_TO"
          },
          "buildingId": {
            "type": "string",
            "example": "XXXXXXXX10889"
          },
          "wing": {
            "type": "string"
          },
          "floor": {
            "type": "string"
          },
          "houseNo": {
            "type": "string",
            "example": "22"
          },
          "buildingName": {
            "type": "string",
            "example": "Kerala University bldg 1"
          },
          "societyName": {
            "type": "string"
          },
          "locality": {
            "type": "string",
            "example": "Kerala mandir"
          },
          "subLocality": {
            "type": "string"
          },
          "street": {
            "type": "string",
            "example": "Kozhikode Krishnagiri"
          },
          "landmark": {
            "type": "string",
            "example": "Near high street"
          },
          "pinCode": {
            "type": "string",
            "example": "673006"
          },
          "city": {
            "type": "string",
            "example": "Calicut"
          },
          "district": {
            "type": "string",
            "example": "Kozhikode"
          },
          "state": {
            "type": "string",
            "example": "kl"
          },
          "country": {
            "type": "string",
            "example": "INDIA"
          }
        }
      },
      "rolesArr": {
        "type": "object",
        "properties": {
          "roleType": {
            "type": "string"
          }
        }
      },
      "customersArray": {
        "type": "object",
        "required": [
          "customerId"
        ],
        "properties": {
          "customerId": {
            "type": "string",
            "example": "ABC1234"
          },
          "roles": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/rolesArr"
                }
              ]
            }
          },
          "organization": {
            "type": "object",
            "required": [
              "organizationName"
            ],
            "properties": {
              "organizationName": {
                "type": "string",
                "example": "XYZ"
              }
            }
          },
          "customerName": {
            "type": "object",
            "required": [
              "firstName"
            ],
            "properties": {
              "firstName": {
                "type": "string",
                "example": "Rahul"
              },
              "middleName": {
                "type": "string",
                "example": "P"
              },
              "lastName": {
                "type": "string",
                "example": "Sharma"
              }
            }
          },
          "contactDetails": {
            "type": "object",
            "required": [
              "contactNo",
              "emailId"
            ],
            "properties": {
              "contactNo": {
                "type": "string",
                "example": "+919004615667"
              },
              "emailId": {
                "type": "string",
                "example": "sharma@abc.com"
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "https://api.appgallop.com/Appgallop-APICenter"
    }
  ]
}
