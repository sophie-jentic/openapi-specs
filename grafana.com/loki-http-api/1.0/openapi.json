{
  "openapi": "3.0.3",
  "info": {
    "title": "Grafana Loki HTTP API",
    "version": "1.0",
    "description": "Grafana Loki is a horizontally scalable, highly available, multi-tenant log aggregation system. This API provides endpoints for querying logs, pushing log entries, managing labels/series, and performing administrative operations.",
    "x-jentic-source-url": "https://grafana.com/docs/loki/latest/reference/loki-http-api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://{loki-host}:3100"
    }
  ],
  "paths": {
    "/loki/api/v1/push": {
      "post": {
        "operationId": "pushLogEntries",
        "summary": "Push log entries",
        "description": "Push a set of log streams to Loki. Each stream has a set of labels and a list of log entries.",
        "tags": [
          "Ingestion"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushRequest"
              }
            },
            "application/x-protobuf": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Log entries pushed successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limited"
          }
        }
      }
    },
    "/loki/api/v1/query": {
      "get": {
        "operationId": "queryLogs",
        "summary": "Query logs (instant)",
        "description": "Evaluates a LogQL query at a single point in time. Can query for logs or metric results.",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "LogQL query string"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            },
            "description": "Maximum number of entries to return"
          },
          {
            "name": "time",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Evaluation timestamp (RFC3339 or Unix epoch)"
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "forward",
                "backward"
              ],
              "default": "backward"
            },
            "description": "Sort order"
          },
          {
            "name": "X-Scope-OrgID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Tenant ID for multi-tenant mode"
          }
        ],
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/loki/api/v1/query_range": {
      "get": {
        "operationId": "queryLogsRange",
        "summary": "Query logs over a time range",
        "description": "Evaluates a LogQL query over a range of time. Returns logs or aggregated metric results.",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "LogQL query string"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Start time (RFC3339 or Unix epoch, default 1h ago)"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "End time (RFC3339 or Unix epoch, default now)"
          },
          {
            "name": "step",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Query resolution step width (duration or float seconds)"
          },
          {
            "name": "interval",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Return entries at specified intervals (only for log queries)"
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "forward",
                "backward"
              ],
              "default": "backward"
            }
          },
          {
            "name": "X-Scope-OrgID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Tenant ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/loki/api/v1/labels": {
      "get": {
        "operationId": "listLabels",
        "summary": "List label names",
        "description": "Returns the list of known label names within a given time span.",
        "tags": [
          "Labels"
        ],
        "parameters": [
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Start time"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "End time"
          },
          {
            "name": "X-Scope-OrgID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Label names",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LabelsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/loki/api/v1/label/{name}/values": {
      "get": {
        "operationId": "listLabelValues",
        "summary": "List values for a label",
        "description": "Returns the list of known values for a given label within a given time span.",
        "tags": [
          "Labels"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Label name"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "LogQL stream selector to filter label values"
          },
          {
            "name": "X-Scope-OrgID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Label values",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LabelsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/loki/api/v1/series": {
      "get": {
        "operationId": "listSeries",
        "summary": "List series",
        "description": "Returns the list of time series that match a certain label set.",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "match[]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Log stream selector (repeated for OR matching)"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Scope-OrgID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching series",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SeriesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/loki/api/v1/index/stats": {
      "get": {
        "operationId": "getIndexStats",
        "summary": "Get index stats",
        "description": "Returns index statistics for the given time range and optional matcher.",
        "tags": [
          "Index"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "LogQL matcher"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Scope-OrgID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Index statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndexStatsResponse"
