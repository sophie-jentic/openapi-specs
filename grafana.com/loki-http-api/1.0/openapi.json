    "/loki/api/v1/tail": {
      "get": {
        "operationId": "tailLogs",
        "summary": "Tail logs (WebSocket)",
        "description": "Stream log entries in real-time via WebSocket connection. Initiates a WebSocket upgrade.",
        "tags": [
          "Streaming"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "LogQL query"
          },
          {
            "name": "delay_for",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Seconds to delay retrieving logs to let slow loggers catch up"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Scope-OrgID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "101": {
            "description": "WebSocket upgrade for streaming"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
