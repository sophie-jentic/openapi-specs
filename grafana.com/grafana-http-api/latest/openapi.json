{
  "openapi": "3.0.0",
  "info": {
    "title": "Grafana HTTP API",
    "version": "latest",
    "description": "Grafana HTTP API reference. Every Grafana instance exposes an HTTP API, which is the same API used by the Grafana frontend to manage resources like saving dashboards, creating users, updating data sources, and more.",
    "contact": {
      "name": "Grafana",
      "url": "https://grafana.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://raw.githubusercontent.com/grafana/grafana/main/public/openapi3.json"
  },
  "servers": [
    {
      "url": "https://{your-grafana-instance}.grafana.com",
      "description": "Your Grafana instance"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    },
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/api/org": {
      "get": {
        "operationId": "getCurrentOrg",
        "summary": "Get current Organization",
        "description": "Gets the current organization.",
        "tags": [
          "Organizations"
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/getCurrentOrgResponse"
          },
          "401": {
            "$ref": "#/components/responses/unauthorisedError"
          },
          "403": {
            "$ref": "#/components/responses/forbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        }
      }
    },
    "/api/dashboards/db": {
      "post": {
        "operationId": "postDashboard",
        "summary": "Create / Update dashboard",
        "description": "Creates a new dashboard or updates an existing dashboard.",
        "tags": [
          "Dashboards"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveDashboardCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/postDashboardResponse"
          },
          "400": {
            "$ref": "#/components/responses/badRequestError"
          },
          "401": {
            "$ref": "#/components/responses/unauthorisedError"
          },
          "403": {
            "$ref": "#/components/responses/forbiddenError"
          },
          "412": {
            "$ref": "#/components/responses/preconditionFailedError"
          },
          "422": {
            "$ref": "#/components/responses/unprocessableEntityError"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        }
      }
    },
    "/api/dashboards/uid/{uid}": {
      "get": {
        "operationId": "getDashboardByUID",
        "summary": "Get dashboard by uid",
        "description": "Will return the dashboard given the dashboard unique identifier (uid).",
        "tags": [
          "Dashboards"
        ],
        "parameters": [
          {
            "name": "uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/dashboardResponse"
          },
          "400": {
            "$ref": "#/components/responses/badRequestError"
          },
          "401": {
            "$ref": "#/components/responses/unauthorisedError"
          },
          "403": {
            "$ref": "#/components/responses/forbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/notFoundError"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        }
      },
      "delete": {
        "operationId": "deleteDashboardByUID",
        "summary": "Delete dashboard by uid",
        "description": "Will delete the dashboard given the specified unique identifier (uid).",
        "tags": [
          "Dashboards"
        ],
        "parameters": [
          {
            "name": "uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/deleteDashboardResponse"
          },
          "400": {
            "$ref": "#/components/responses/badRequestError"
          },
          "401": {
            "$ref": "#/components/responses/unauthorisedError"
          },
          "403": {
            "$ref": "#/components/responses/forbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/notFoundError"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        }
      }
    },
    "/api/datasources": {
      "get": {
        "operationId": "getDataSources",
        "summary": "Get all data sources",
        "description": "If you are running Grafana Enterprise and have Fine-grained access control enabled, you need to have a permission with action: datasources:read and target: datasources:*.",
        "tags": [
          "Datasources"
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/getDataSourcesResponse"
          },
          "401": {
            "$ref": "#/components/responses/unauthorisedError"
          },
          "403": {
            "$ref": "#/components/responses/forbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        }
      },
      "post": {
        "operationId": "addDataSource",
        "summary": "Create a data source",
        "description": "By defining value of optional parameter named withCredentials Grafana enables sending credentials like cookies or auth headers when making cross-site requests.",
        "tags": [
          "Datasources"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddDataSourceCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/createOrUpdateDatasourceResponse"
          },
          "400": {
            "$ref": "#/components/responses/badRequestError"
          },
          "401": {
            "$ref": "#/components/responses/unauthorisedError"
          },
          "403": {
            "$ref": "#/components/responses/forbiddenError"
          },
          "409": {
            "$ref": "#/components/responses/conflictError"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        }
      }
    },
    "/api/annotations": {
      "get": {
        "operationId": "getAnnotations",
        "summary": "Find Annotations",
        "description": "Starting in Grafana v6.4 regions annotations are now returned in one entity that now includes the timeEnd property.",
        "tags": [
          "Annotations"
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "epoch datetime in milliseconds. Optional.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "to",
            "in": "query",
            "description": "epoch datetime in milliseconds. Optional.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Max limit for results returned.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/getAnnotationsResponse"
          },
          "401": {
            "$ref": "#/components/responses/unauthorisedError"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        }
      },
      "post": {
        "operationId": "createAnnotation",
        "summary": "Create Annotation",
        "description": "Creates an annotation in the Grafana database.",
        "tags": [
          "Annotations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostAnnotationsCmd"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/postAnnotationResponse"
          },
          "400": {
            "$ref": "#/components/responses/badRequestError"
          },
          "401": {
            "$ref": "#/components/responses/unauthorisedError"
          },
          "403": {
            "$ref": "#/components/responses/forbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        }
      }
    },
    "/api/folders": {
      "get": {
        "operationId": "getFolders",
        "summary": "Get all folders",
        "description": "Returns all folders that the authenticated user has permission to view. If nested folders are enabled, it expects an additional query parameter with the parent folder UID.",
        "tags": [
          "Folders"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "default": 1000
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/getFoldersResponse"
          },
          "401": {
            "$ref": "#/components/responses/unauthorisedError"
          },
          "403": {
            "$ref": "#/components/responses/forbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        }
      },
      "post": {
        "operationId": "createFolder",
        "summary": "Create folder",
        "description": "If nested folders are enabled then it also expects the parent folder UID.",
        "tags": [
          "Folders"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFolderCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/folderResponse"
          },
          "400": {
            "$ref": "#/components/responses/badRequestError"
          },
          "401": {
            "$ref": "#/components/responses/unauthorisedError"
          },
          "403": {
            "$ref": "#/components/responses/forbiddenError"
          },
          "409": {
            "$ref": "#/components/responses/conflictError"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Service account token"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "responses": {
      "getCurrentOrgResponse": {
        "description": "Current org details",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/OrgDetailsDTO"
            }
          }
        }
      },
      "postDashboardResponse": {
        "description": "Dashboard created/updated",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int64"
                },
                "slug": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "uid": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                },
                "version": {
                  "type": "integer",
                  "format": "int64"
                }
              }
            }
          }
        }
      },
      "dashboardResponse": {
        "description": "Dashboard details",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/DashboardFullWithMeta"
            }
          }
        }
      },
      "deleteDashboardResponse": {
        "description": "Dashboard deleted",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "uid": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "getDataSourcesResponse": {
        "description": "List of data sources",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/DataSourceList"
            }
          }
        }
      },
      "createOrUpdateDatasourceResponse": {
        "description": "Data source created/updated",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "datasource": {
                  "$ref": "#/components/schemas/DataSource"
                },
                "id": {
                  "type": "integer",
                  "format": "int64"
                },
                "message": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "getAnnotationsResponse": {
        "description": "List of annotations",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Annotation"
              }
            }
          }
        }
      },
      "postAnnotationResponse": {
        "description": "Annotation created",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int64"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "getFoldersResponse": {
        "description": "List of folders",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/FolderSearchHit"
              }
            }
          }
        }
      },
      "folderResponse": {
        "description": "Folder details",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Folder"
            }
          }
        }
      },
      "badRequestError": {
        "description": "BadRequestError",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponseBody"
            }
          }
        }
      },
      "unauthorisedError": {
        "description": "UnauthorisedError",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponseBody"
            }
          }
        }
      },
      "forbiddenError": {
        "description": "ForbiddenError",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponseBody"
            }
          }
        }
      },
      "notFoundError": {
        "description": "NotFoundError",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponseBody"
            }
          }
        }
      },
      "conflictError": {
        "description": "ConflictError",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponseBody"
            }
          }
        }
      },
      "unprocessableEntityError": {
        "description": "UnprocessableEntityError",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponseBody"
            }
          }
        }
      },
      "preconditionFailedError": {
        "description": "PreconditionFailedError",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponseBody"
            }
          }
        }
      },
      "internalServerError": {
        "description": "InternalServerError",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponseBody"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponseBody": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "messageId": {
            "type": "string"
          },
          "statusCode": {
            "type": "integer"
          },
          "traceID": {
            "type": "string"
          }
        }
      },
      "OrgDetailsDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "address1": {
            "type": "string"
          },
          "address2": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "zipCode": {
            "type": "string"
          }
        }
      },
      "DashboardFullWithMeta": {
        "type": "object",
        "properties": {
          "dashboard": {
            "type": "object",
            "additionalProperties": true
          },
          "meta": {
            "$ref": "#/components/schemas/DashboardMeta"
          }
        }
      },
      "DashboardMeta": {
        "type": "object",
        "properties": {
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "createdBy": {
            "type": "string"
          },
          "expires": {
            "type": "string",
            "format": "date-time"
          },
          "folderTitle": {
            "type": "string"
          },
          "folderUid": {
            "type": "string"
          },
          "folderUrl": {
            "type": "string"
          },
          "isHome": {
            "type": "boolean"
          },
          "isSnapshot": {
            "type": "boolean"
          },
          "isStarred": {
            "type": "boolean"
          },
          "provisioned": {
            "type": "boolean"
          },
          "provisionedExternalId": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "updated": {
            "type": "string",
            "format": "date-time"
          },
          "updatedBy": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "version": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "SaveDashboardCommand": {
        "type": "object",
        "required": [
          "dashboard"
        ],
        "properties": {
          "dashboard": {
            "type": "object",
            "additionalProperties": true,
            "description": "The complete dashboard model, id = null to create a new dashboard."
          },
          "folderId": {
            "type": "integer",
            "format": "int64",
            "description": "The id of the folder to save the dashboard in."
          },
          "folderUid": {
            "type": "string",
            "description": "The UID of the folder to save the dashboard in."
          },
          "message": {
            "type": "string",
            "description": "Set a commit message for the version history."
          },
          "overwrite": {
            "type": "boolean",
            "description": "Set to true if you want to overwrite existing dashboard with newer version or with the same dashboard title."
          }
        }
      },
      "DataSource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "uid": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "isDefault": {
            "type": "boolean"
          },
          "readOnly": {
            "type": "boolean"
          }
        }
      },
      "DataSourceList": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/DataSource"
        }
      },
      "AddDataSourceCommand": {
        "type": "object",
        "required": [
          "name",
          "type"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "access": {
            "type": "string",
            "default": "proxy"
          },
          "isDefault": {
            "type": "boolean"
          },
          "withCredentials": {
            "type": "boolean"
          },
          "secureJsonData": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "Annotation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "dashboardId": {
            "type": "integer",
            "format": "int64"
          },
          "dashboardUID": {
            "type": "string"
          },
          "panelId": {
            "type": "integer",
            "format": "int64"
          },
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "login": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "text": {
            "type": "string"
          },
          "time": {
            "type": "integer",
            "format": "int64"
          },
          "timeEnd": {
            "type": "integer",
            "format": "int64"
          },
          "type": {
            "type": "string"
          },
          "updated": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "PostAnnotationsCmd": {
        "type": "object",
        "required": [
          "text",
          "time"
        ],
        "properties": {
          "dashboardId": {
            "type": "integer",
            "format": "int64"
          },
          "dashboardUID": {
            "type": "string"
          },
          "panelId": {
            "type": "integer",
            "format": "int64"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "text": {
            "type": "string"
          },
          "time": {
            "type": "integer",
            "format": "int64"
          },
          "timeEnd": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "FolderSearchHit": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "title": {
            "type": "string"
          },
          "uid": {
            "type": "string"
          }
        }
      },
      "Folder": {
        "type": "object",
        "properties": {
          "canAdmin": {
            "type": "boolean"
          },
          "canDelete": {
            "type": "boolean"
          },
          "canEdit": {
            "type": "boolean"
          },
          "canSave": {
            "type": "boolean"
          },
          "created": {
            "type": "string",
            "format": "date-time"
