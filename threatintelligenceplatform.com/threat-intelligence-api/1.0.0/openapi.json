{
  "openapi": "3.0.3",
  "info": {
    "title": "Threat Intelligence Platform API",
    "version": "1.0.0",
    "description": "Provides threat intelligence data for domains and IP addresses, including infrastructure analysis. Requires an API key. Rate limit: 100 requests per minute.",
    "x-jentic-source-url": "https://threatintelligenceplatform.com/api-docs",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.threatintelligenceplatform.com/v1",
      "description": "Threat Intelligence Platform API v1"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/infrastructureAnalysis": {
      "get": {
        "operationId": "getInfrastructureAnalysis",
        "tags": [
          "Infrastructure"
        ],
        "summary": "Get infrastructure analysis for a domain or IP",
        "description": "Retrieves infrastructure analysis data for the specified domain name or IP address.",
        "parameters": [
          {
            "name": "domainName",
            "in": "query",
            "required": true,
            "description": "Domain name or IP address to analyze",
            "schema": {
              "type": "string",
              "example": "threatintelligenceplatform.com"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "description": "Analysis mode: 'fast' or 'full'",
            "schema": {
              "type": "string",
              "enum": [
                "fast",
                "full"
              ]
            },
            "required": false
          },
          {
            "name": "apiKey",
            "in": "query",
            "description": "API key for authentication (can also be passed in Authorization header)",
            "schema": {
              "type": "string"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Infrastructure analysis data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InfrastructureAnalysisResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized. Possible reasons: No API key passed, Invalid/obsolete API key, or insufficient credits.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity. Possible reasons: Domain name doesn't exist, Domain name is required, Invalid domain name or IP address, Only public IPv4 addresses allowed, or invalid mode parameter.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded. Limit is 100 requests per minute.",
            "headers": {
              "X-RateLimit-Limit": {
                "schema": {
                  "type": "integer"
                },
                "description": "Rate limit (100 requests/min)"
              },
              "X-RateLimit-Remaining": {
                "schema": {
                  "type": "integer"
                },
                "description": "Remaining requests this minute"
              },
              "Retry-After": {
                "schema": {
                  "type": "integer"
                },
                "description": "Seconds until rate limit resets"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key for authentication. Can also be passed as query parameter apiKey."
      }
    },
    "schemas": {
      "InfrastructureAnalysisResponse": {
        "type": "object",
        "properties": {
          "domainName": {
            "type": "string"
          },
          "ipAddresses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ip": {
                  "type": "string"
                },
                "organization": {
                  "type": "string"
                },
                "country": {
                  "type": "string"
                },
                "isp": {
                  "type": "string"
                }
              }
            }
          },
          "serverType": {
            "type": "string"
          },
          "openPorts": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "sslCertificate": {
            "type": "object",
            "properties": {
              "issuer": {
                "type": "string"
              },
              "validFrom": {
                "type": "string"
              },
              "validTo": {
                "type": "string"
              },
              "subject": {
                "type": "string"
              }
            }
          },
          "malwareDetected": {
            "type": "boolean"
          },
          "blacklistedOn": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "domainReputation": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Infrastructure"
    }
  ]
}
