    "/indices/{symbol_set}/ticker/all": {
      "get": {
        "tags": [
          "Ticker"
        ],
        "summary": "Get all tickers",
        "description": "Returns ticker data for all symbols from the specified symbol set.",
        "operationId": "getAllTickers",
        "parameters": [
          {
            "name": "symbol_set",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "global",
                "local",
                "crypto",
                "tokens"
              ]
            }
          },
          {
            "name": "crypto",
            "in": "query",
            "description": "Filter by crypto symbol(s).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fiat",
            "in": "query",
            "description": "Filter by fiat currency symbol(s).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "All ticker data",
