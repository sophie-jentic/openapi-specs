    "/indices/ticker/custom/{inex}/{symbol}": {
      "get": {
        "tags": [
          "Ticker"
        ],
        "summary": "Get custom ticker",
        "description": "Returns ticker values with custom exchange inclusion or exclusion filters.",
        "operationId": "getCustomTicker",
        "parameters": [
          {
            "name": "inex",
            "in": "path",
            "required": true,
            "description": "Include or exclude the specified exchanges.",
            "schema": {
              "type": "string",
              "enum": [
                "include",
                "exclude"
              ]
            }
          },
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "exchanges",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of exchange names.",
            "schema": {
              "type": "string"
            }
