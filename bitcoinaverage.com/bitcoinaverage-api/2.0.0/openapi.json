{
  "openapi": "3.0.3",
  "info": {
    "title": "BitcoinAverage API",
    "description": "BitcoinAverage provides a comprehensive set of APIs for cryptocurrency price data, including global and local indices, exchange-specific data, historical data, and real-time ticker information.",
    "version": "2.0.0",
    "contact": {
      "name": "BitcoinAverage",
      "url": "https://apiv2.bitcoinaverage.com/"
    }
  },
  "servers": [
    {
      "url": "https://apiv2.bitcoinaverage.com",
      "description": "BitcoinAverage API v2"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/constants/exchangerates/{market}": {
      "get": {
        "tags": [
          "Constants"
        ],
        "summary": "Get exchange rates",
        "description": "Returns global fiat exchange rates used in the current indices calculations.",
        "operationId": "getExchangeRates",
        "parameters": [
          {
            "name": "market",
            "in": "path",
            "required": true,
            "description": "Market type.",
            "schema": {
              "type": "string",
              "enum": [
                "global",
                "local"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Exchange rates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rates": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "rate": {
                            "type": "number"
                          },
                          "name": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "time": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/constants/time": {
      "get": {
        "tags": [
          "Constants"
        ],
        "summary": "Get server time",
        "description": "Returns the current server time in epoch and ISO format.",
        "operationId": "getServerTime",
        "security": [],
        "responses": {
          "200": {
            "description": "Server time",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "epoch": {
                      "type": "integer"
                    },
                    "iso": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
