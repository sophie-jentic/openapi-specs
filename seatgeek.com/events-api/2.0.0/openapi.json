  },
  "components": {
    "securitySchemes": {
      "ClientAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "client_id",
        "description": "Client ID for API authentication"
      }
    },
    "schemas": {
      "EventsResponse": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "short_title": {
            "type": "string"
          },
          "datetime_local": {
            "type": "string",
            "format": "date-time"
          },
          "datetime_utc": {
            "type": "string",
            "format": "date-time"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "score": {
            "type": "number"
          },
          "venue": {
            "$ref": "#/components/schemas/Venue"
          },
          "performers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Performer"
            }
          },
          "taxonomies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Taxonomy"
            }
          },
          "stats": {
            "type": "object",
            "properties": {
              "listing_count": {
                "type": "integer"
              },
              "average_price": {
                "type": "number"
              },
              "lowest_price": {
                "type": "number"
              },
              "highest_price": {
                "type": "number"
              }
            }
          }
        }
      },
      "PerformersResponse": {
        "type": "object",
        "properties": {
          "performers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Performer"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        }
      },
      "Performer": {
        "type": "object",
        "properties": {
