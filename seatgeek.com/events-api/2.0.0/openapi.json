          },
          "postal_code": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "location": {
            "type": "object",
            "properties": {
              "lat": {
                "type": "number",
                "format": "double"
              },
              "lon": {
                "type": "number",
                "format": "double"
              }
            }
          },
          "capacity": {
            "type": "integer"
          },
          "score": {
            "type": "number"
          }
        }
      },
      "Taxonomy": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "parent_id": {
            "type": "integer",
            "nullable": true
          }
        }
      },
      "Meta": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "took": {
            "type": "integer"
          },
          "page": {
