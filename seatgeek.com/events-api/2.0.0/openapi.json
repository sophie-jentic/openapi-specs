            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "image": {
            "type": "string",
            "format": "uri"
          },
          "score": {
            "type": "number"
          },
          "taxonomies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Taxonomy"
            }
          },
          "stats": {
            "type": "object",
            "properties": {
              "event_count": {
                "type": "integer"
              }
            }
          }
        }
      },
      "VenuesResponse": {
