{
  "openapi": "3.0.0",
  "info": {
    "title": "SeatGeek API",
    "description": "SeatGeek's event discovery and ticketing API. Search for events, venues, and performers across sports, concerts, and theater.",
    "version": "2.0.0",
    "contact": {
      "name": "SeatGeek",
      "url": "https://seatgeek.com"
    },
    "termsOfService": "https://seatgeek.com/terms"
  },
  "servers": [
    {
      "url": "https://api.seatgeek.com/2",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ClientAuth": []
    }
  ],
  "paths": {
    "/events": {
      "get": {
        "summary": "Search events",
        "description": "Search for events with various filters including location, date range, performers, and categories",
        "operationId": "searchEvents",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Application client ID"
          },
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "lat",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Latitude for location-based search"
          },
          {
            "name": "lon",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Longitude for location-based search"
          },
          {
            "name": "range",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Distance range for location search (e.g., '25mi')"
          },
          {
            "name": "geoip",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Use IP-based geolocation"
          },
          {
            "name": "datetime_local.gte",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter events on or after this datetime"
          },
          {
            "name": "datetime_local.lte",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter events on or before this datetime"
          },
          {
            "name": "taxonomies.name",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by taxonomy (e.g., 'sports', 'concert', 'theater')"
          },
          {
            "name": "performers.slug",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by performer slug"
          },
          {
            "name": "venue.id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by venue ID"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            },
            "description": "Number of results per page"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["score.desc", "datetime_local.asc", "datetime_local.desc"]
            },
            "description": "Sort order"
          }
        ],
        "responses": {
          "200": {
            "description": "Event search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventsResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - invalid or missing client ID"
          }
        }
      }
    },
    "/events/{event_id}": {
      "get": {
        "summary": "Get event by ID",
        "description": "Retrieve detailed information about a specific event",
        "operationId": "getEvent",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "event_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Event ID"
          },
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Application client ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Event details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - invalid or missing client ID"
          },
          "404": {
            "description": "Event not found"
          }
        }
      }
    },
