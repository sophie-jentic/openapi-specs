            "name": "lon",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Longitude"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            },
            "description": "Number of results"
          }
        ],
        "responses": {
          "200": {
            "description": "Recommended events",
            "content": {
              "application/json": {
