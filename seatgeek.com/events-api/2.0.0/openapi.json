    "/recommendations": {
      "get": {
        "summary": "Get event recommendations",
        "description": "Get personalized event recommendations based on location or preferences",
        "operationId": "getRecommendations",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Application client ID"
          },
          {
            "name": "lat",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Latitude"
          },
