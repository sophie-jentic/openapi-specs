{
  "openapi": "3.0.3",
  "info": {
    "title": "Phraseanet API",
    "version": "1.0.0",
    "description": "Digital asset management API. Search, manage, and organize records, stories, baskets, and feeds. Supports media asset operations including metadata management and embedding.",
    "x-jentic-source-url": "https://docs.phraseanet.com/4.0/en/Devel/API/V1.html",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{instance}.phraseanet.com/api/v1",
      "variables": {
        "instance": {
          "default": "your-instance",
          "description": "Your Phraseanet instance name"
        }
      }
    }
  ],
  "paths": {
    "/me": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current user info",
        "tags": [
          "User"
        ],
        "responses": {
          "200": {
            "description": "User info"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get current user info"
      }
    },
    "/records/search": {
      "post": {
        "operationId": "searchRecords",
        "summary": "Search records",
        "tags": [
          "Records"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Search records"
      }
    },
    "/records/{databox_id}/{record_id}": {
      "get": {
        "operationId": "getRecord",
        "summary": "Get a specific record",
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "databox_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "record_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Record details"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a specific record"
      }
    },
    "/records/{databox_id}/{record_id}/caption": {
      "get": {
        "operationId": "getRecordCaption",
        "summary": "Get record caption/metadata",
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "databox_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "record_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Caption data"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get record caption/metadata"
      }
    },
    "/records/{databox_id}/{record_id}/setmetadatas": {
      "post": {
        "operationId": "setRecordMetadatas",
        "summary": "Set record metadata",
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "databox_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "record_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Metadata set"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Set record metadata"
      }
    },
    "/records/{databox_id}/{record_id}/setstatus": {
      "post": {
        "operationId": "setRecordStatus",
        "summary": "Set record status",
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "databox_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "record_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status set"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Set record status"
      }
    },
    "/records/{databox_id}/{record_id}/embed": {
      "get": {
        "operationId": "getRecordEmbed",
        "summary": "Get record embed URLs",
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "databox_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "record_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Embed URLs"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get record embed URLs"
      }
    },
    "/records/add": {
      "post": {
        "operationId": "addRecord",
        "summary": "Add a new record",
        "tags": [
          "Records"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "base_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record added"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Add a new record"
      }
    },
    "/stories/{databox_id}/{story_id}": {
      "get": {
        "operationId": "getStory",
        "summary": "Get a story",
        "tags": [
          "Stories"
        ],
        "parameters": [
          {
            "name": "databox_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "story_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Story details"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get a story"
      }
    },
    "/baskets/list": {
      "get": {
        "operationId": "listBaskets",
        "summary": "List baskets",
        "tags": [
          "Baskets"
        ],
        "responses": {
          "200": {
            "description": "Baskets list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List baskets"
      }
    },
    "/baskets/add": {
      "post": {
        "operationId": "addBasket",
        "summary": "Create a basket",
        "tags": [
          "Baskets"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Basket created"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a basket"
      }
    },
    "/baskets/{basket_id}/content": {
      "get": {
        "operationId": "getBasketContent",
        "summary": "Get basket content",
        "tags": [
          "Baskets"
        ],
        "parameters": [
          {
            "name": "basket_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Basket content"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get basket content"
      }
    },
    "/feeds/list": {
      "get": {
        "operationId": "listFeeds",
        "summary": "List feeds",
        "tags": [
          "Feeds"
        ],
        "responses": {
          "200": {
            "description": "Feeds list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List feeds"
      }
    },
    "/feeds/{feed_id}/content": {
      "get": {
        "operationId": "getFeedContent",
        "summary": "Get feed content",
        "tags": [
          "Feeds"
        ],
        "parameters": [
          {
            "name": "feed_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Feed content"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get feed content"
      }
    },
    "/databoxes/list": {
      "get": {
        "operationId": "listDataboxes",
        "summary": "List databoxes",
        "tags": [
          "Databoxes"
        ],
        "responses": {
          "200": {
            "description": "Databoxes list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List databoxes"
      }
    },
    "/databoxes/{databox_id}/collections": {
      "get": {
        "operationId": "listCollections",
        "summary": "List collections in databox",
        "tags": [
          "Databoxes"
        ],
        "parameters": [
          {
            "name": "databox_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collections list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List collections in databox"
      }
    }
  },
  "components": {
    "schemas": {
      "SearchRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "bases": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "offset_start": {
            "type": "integer",
            "default": 1
          },
          "per_page": {
            "type": "integer",
            "default": 10
          },
          "sort": {
            "type": "string",
            "enum": [
              "relevance",
              "created_on",
              "random"
            ]
          },
          "record_type": {
            "type": "string",
            "enum": [
              "audio",
              "video",
              "image",
              "document",
              "flash"
            ]
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "offset_start": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "available_results": {
            "type": "integer"
          },
          "total_results": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "Baskets"
    },
    {
      "name": "Databoxes"
    },
    {
      "name": "Feeds"
    },
    {
      "name": "Records"
    },
    {
      "name": "Stories"
    },
    {
      "name": "User"
    }
  ]
}
