  "components": {
    "schemas": {
      "Recipient": {
        "type": "object",
        "required": [
          "address"
        ],
        "properties": {
          "address": {
            "oneOf": [
              {
                "type": "string",
                "format": "email"
              },
              {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "name": {
                    "type": "string"
                  }
                }
              }
            ]
          },
          "metadata": {
            "type": "object"
          },
          "substitution_data": {
            "type": "object"
          }
        }
      },
      "Content": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "template_id": {
            "type": "string"
          },
          "reply_to": {
            "type": "string"
          }
        }
      },
      "TransmissionOptions": {
        "type": "object",
        "properties": {
          "open_tracking": {
            "type": "boolean"
          },
          "click_tracking": {
            "type": "boolean"
          },
          "transactional": {
            "type": "boolean"
          },
          "ip_pool": {
            "type": "string"
          },
          "inline_css": {
            "type": "boolean"
          }
        }
      },
      "Transmission": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "campaign_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "generation_time": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TransmissionList": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transmission"
            }
          }
        }
      },
      "MetricsResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
