  "paths": {
    "/transmissions": {
      "post": {
        "summary": "Create a transmission",
        "description": "Creates and sends email messages to one or multiple recipients",
        "tags": [
          "Transmissions"
        ],
        "operationId": "createTransmission",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "recipients",
                  "content"
                ],
                "properties": {
                  "recipients": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Recipient"
                    }
                  },
                  "content": {
                    "$ref": "#/components/schemas/Content"
                  },
                  "campaign_id": {
                    "type": "string",
                    "maxLength": 64
                  },
                  "description": {
                    "type": "string",
                    "maxLength": 1024
                  },
                  "metadata": {
                    "type": "object"
                  },
                  "substitution_data": {
                    "type": "object"
                  },
                  "options": {
                    "$ref": "#/components/schemas/TransmissionOptions"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transmission created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "total_accepted_recipients": {
                          "type": "integer"
                        },
                        "total_rejected_recipients": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "422": {
            "description": "Validation error"
          }
        }
      },
      "get": {
        "summary": "List scheduled transmissions",
        "tags": [
          "Transmissions"
        ],
        "operationId": "listTransmissions",
        "parameters": [
          {
            "name": "campaign_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransmissionList"
                }
              }
            }
          }
        },
        "description": "List scheduled transmissions"
      }
    },
    "/transmissions/{id}": {
      "get": {
        "summary": "Get transmission details",
        "tags": [
          "Transmissions"
        ],
        "operationId": "getTransmission",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transmission"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get transmission details"
      },
      "delete": {
        "summary": "Delete scheduled transmission",
        "tags": [
          "Transmissions"
        ],
        "operationId": "deleteTransmission",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted successfully"
          },
          "404": {
            "description": "Not found"
          },
          "409": {
            "description": "Invalid state"
          }
        },
        "description": "Delete scheduled transmission"
      }
    },
