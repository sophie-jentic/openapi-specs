{
  "openapi": "3.0.3",
  "info": {
    "title": "UserCheck API",
    "description": "An API designed to help businesses and developers detect and block disposable (temporary) email addresses",
    "version": "1.0.0",
    "contact": {
      "url": "https://www.usercheck.com"
    }
  },
  "servers": [
    {
      "url": "https://api.usercheck.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/email/{email}": {
      "get": {
        "summary": "Validate email address",
        "description": "Check if an email address is disposable, valid, and get detailed information about it",
        "operationId": "validateEmail",
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "description": "The email address to check (e.g., [email protected])",
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmailValidationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid email format"
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "tags": [
          "email"
        ]
      }
    },
    "/domain/{domain}": {
      "get": {
        "summary": "Validate domain",
        "description": "Validate domain information and check if it's disposable",
        "operationId": "validateDomain",
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "description": "The domain to check (e.g., github.com)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DomainValidationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid domain format"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "tags": [
          "domain"
        ]
      }
    },
    "/blocklist": {
      "get": {
        "summary": "List blocklisted domains",
        "description": "Get paginated list of blocklisted domains (Pro account required)",
        "operationId": "listBlocklist",
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "description": "Number of domains per page (1-100, default 25)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlocklistListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Pro account required"
          }
        },
        "tags": [
          "blocklist"
        ]
      },
      "post": {
        "summary": "Add domain to blocklist",
        "description": "Add a single domain to the blocklist (Pro account required)",
        "operationId": "addToBlocklist",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "domain"
                ],
                "properties": {
                  "domain": {
                    "type": "string",
                    "description": "Domain to add to blocklist"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Domain added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlocklistDomain"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Pro account required"
          },
          "422": {
            "description": "Domain already exists"
          }
        },
        "tags": [
          "blocklist"
        ]
      }
    },
    "/blocklist/bulk": {
      "post": {
        "summary": "Bulk add domains to blocklist",
        "description": "Add multiple domains to blocklist (max 1,000 entries, Pro account required)",
        "operationId": "bulkAddToBlocklist",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "domains"
                ],
                "properties": {
                  "domains": {
                    "type": "array",
                    "maxItems": 1000,
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of domains to add"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk operation completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkBlocklistResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Pro account required"
          }
        },
        "tags": [
          "blocklist"
        ]
      }
    },
    "/blocklist/{domain}": {
      "get": {
        "summary": "Check domain blocklist status",
        "description": "Check if a specific domain is blocklisted (Pro account required)",
        "operationId": "checkBlocklistStatus",
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Domain found in blocklist",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlocklistDomain"
                }
              }
            }
          },
          "404": {
            "description": "Domain not in blocklist"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "blocklist"
        ]
      },
      "delete": {
        "summary": "Remove domain from blocklist",
        "description": "Remove a domain from the blocklist (Pro account required)",
        "operationId": "removeFromBlocklist",
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Domain removed successfully"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Domain not found"
          }
        },
        "tags": [
          "blocklist"
        ]
      }
    },
    "/status": {
      "get": {
        "summary": "Get API status",
        "description": "Verify API setup and get account information",
        "operationId": "getStatus",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "tags": [
          "status"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Get your API key from app.usercheck.com"
      }
    },
    "schemas": {
      "EmailValidationResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "email": {
            "type": "string",
            "description": "Original email checked"
          },
          "normalized_email": {
            "type": "string",
            "description": "Standardized email form"
          },
          "domain": {
            "type": "string",
            "description": "Extracted domain portion"
          },
          "domain_authority": {
            "type": "integer",
            "nullable": true,
            "description": "0-100 score indicating domain credibility (Pro Plan only)"
          },
          "domain_age_in_days": {
            "type": "integer",
            "nullable": true,
            "description": "Days since domain registration"
          },
          "mx": {
            "type": "boolean",
            "description": "Indicates whether the domain has valid MX records"
          },
          "mx_records": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "hostname": {
                  "type": "string"
                },
                "priority": {
                  "type": "integer"
                }
              }
            }
          },
          "mx_providers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "slug": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "grade": {
                  "type": "string"
                }
              }
            }
          },
          "disposable": {
            "type": "boolean",
            "description": "Disposable email indicator"
          },
          "public_domain": {
            "type": "boolean",
            "description": "Public email service flag"
          },
          "relay_domain": {
            "type": "boolean",
            "description": "Email forwarding service indicator"
          },
          "role_account": {
            "type": "boolean",
            "description": "Shared/role account flag"
          },
          "spam": {
            "type": "boolean",
            "description": "Spam/abuse association flag"
          },
          "did_you_mean": {
            "type": "string",
            "nullable": true,
            "description": "Typo correction suggestion"
          },
          "blocklisted": {
            "type": "boolean",
            "description": "Custom blocklist status (Pro Plan only)"
          }
        }
      },
      "DomainValidationResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "domain": {
            "type": "string"
          },
          "domain_authority": {
            "type": "integer",
            "nullable": true
          },
          "domain_age_in_days": {
            "type": "integer",
            "nullable": true
          },
          "mx": {
            "type": "boolean"
          },
          "mx_records": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "mx_providers": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "disposable": {
            "type": "boolean"
          },
          "disposable_provider": {
            "type": "string",
            "nullable": true
          },
          "public_domain": {
            "type": "boolean"
          },
          "relay_domain": {
            "type": "boolean"
          },
          "did_you_mean": {
            "type": "string",
            "nullable": true
          },
          "blocklisted": {
            "type": "boolean"
          },
          "spam": {
            "type": "boolean"
          }
        }
      },
      "BlocklistDomain": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BlocklistListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BlocklistDomain"
            }
          }
        }
      },
      "BulkBlocklistResponse": {
        "type": "object",
        "properties": {
          "success_count": {
            "type": "integer"
          },
          "failed_count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "account": {
            "type": "object",
            "properties": {
              "plan": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "credits": {
                    "type": "integer"
                  },
                  "rate_limit": {
                    "type": "integer"
                  }
                }
              },
              "user": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "usage": {
            "type": "object",
            "properties": {
              "limit": {
                "type": "integer"
              },
              "current": {
                "type": "integer"
              },
              "remaining": {
                "type": "integer"
              },
              "reset_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "blocklist"
    },
    {
      "name": "domain"
    },
    {
      "name": "email"
    },
    {
      "name": "status"
    }
  ]
}
