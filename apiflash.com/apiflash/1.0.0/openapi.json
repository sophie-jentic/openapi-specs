{
  "openapi": "3.0.0",
  "info": {
    "title": "ApiFlash Screenshot API",
    "version": "1.0.0",
    "description": "ApiFlash is a powerful screenshot API that allows you to capture screenshots of any website. Supports multiple formats (PNG, JPEG, WebP), full-page captures, custom viewports, and advanced features like geo-location emulation, custom CSS/JS injection, and S3 storage integration.",
    "contact": {
      "name": "ApiFlash Support",
      "url": "https://apiflash.com"
    }
  },
  "servers": [
    {
      "url": "https://api.apiflash.com/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "accessKey": []
    }
  ],
  "paths": {
    "/urltoimage": {
      "get": {
        "summary": "Capture Screenshot (GET)",
        "description": "Capture a screenshot of a URL using GET request with query parameters",
        "operationId": "captureScreenshotGet",
        "parameters": [
          {
            "name": "access_key",
            "in": "query",
            "description": "Your API access key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "url",
            "in": "query",
            "description": "The URL to capture (must include protocol)",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri",
              "example": "https://example.com"
            }
          },
          {
            "name": "width",
            "in": "query",
            "description": "Viewport width in pixels",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1920,
              "example": 1920
            }
          },
          {
            "name": "height",
            "in": "query",
            "description": "Viewport height in pixels",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1080,
              "example": 1080
            }
          },
          {
            "name": "full_page",
            "in": "query",
            "description": "Capture entire page",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Output format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "jpeg",
                "png",
                "webp"
              ],
              "default": "jpeg"
            }
          },
          {
            "name": "quality",
            "in": "query",
            "description": "Image quality (0-100, for jpeg/webp only)",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "default": 80
            }
          },
          {
            "name": "delay",
            "in": "query",
            "description": "Wait time in seconds before capture (0-10)",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10,
              "default": 0
            }
          },
          {
            "name": "wait_until",
            "in": "query",
            "description": "When to consider the page loaded",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "dom_loaded",
                "page_loaded",
                "network_idle"
              ],
              "default": "network_idle"
            }
          },
          {
            "name": "scroll_page",
            "in": "query",
            "description": "Enable page scrolling in screenshots",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "no_ads",
            "in": "query",
            "description": "Block advertisements",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "no_cookie_banners",
            "in": "query",
            "description": "Hide cookie consent banners",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "element",
            "in": "query",
            "description": "CSS selector to capture specific element",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "css",
            "in": "query",
            "description": "Custom CSS to inject into page",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "accept_language",
            "in": "query",
            "description": "Set language preferences",
            "required": false,
            "schema": {
              "type": "string",
              "example": "en-US"
            }
          },
          {
            "name": "ip_location",
            "in": "query",
            "description": "Simulate geographic location",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "response_type",
            "in": "query",
            "description": "Response format (default is binary image, or JSON)",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "image",
                "json"
              ],
              "default": "image"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Screenshot captured successfully",
            "headers": {
              "Content-Type": {
                "description": "MIME type of the image",
                "schema": {
                  "type": "string"
                }
              },
              "Content-Length": {
                "description": "Size of the image in bytes",
                "schema": {
                  "type": "integer"
                }
              },
              "X-Quota-Limit": {
                "description": "Total quota limit",
                "schema": {
                  "type": "integer"
                }
              },
              "X-Quota-Remaining": {
                "description": "Remaining quota",
                "schema": {
                  "type": "integer"
                }
              },
              "X-Quota-Reset": {
                "description": "Quota reset timestamp",
                "schema": {
                  "type": "integer"
                }
              }
            },
            "content": {
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/webp": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string",
                      "description": "URL to the screenshot"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters or unreachable URL"
          },
          "401": {
            "description": "Invalid or revoked access key"
          },
          "402": {
            "description": "Quota exceeded"
          },
          "403": {
            "description": "Feature unsupported in current plan"
          },
          "429": {
            "description": "Rate limit exceeded (20 requests/second with 400-request burst)"
          },
          "500": {
            "description": "Server error"
          }
        },
        "tags": [
          "urltoimage"
        ]
      },
      "post": {
        "summary": "Capture Screenshot (POST)",
        "description": "Capture a screenshot of a URL using POST request with form data",
        "operationId": "captureScreenshotPost",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "access_key",
                  "url"
                ],
                "properties": {
                  "access_key": {
                    "type": "string",
                    "description": "Your API access key"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "The URL to capture"
                  },
                  "width": {
                    "type": "integer",
                    "default": 1920
                  },
                  "height": {
                    "type": "integer",
                    "default": 1080
                  },
                  "full_page": {
                    "type": "boolean",
                    "default": false
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "jpeg",
                      "png",
                      "webp"
                    ],
                    "default": "jpeg"
                  },
                  "quality": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 100,
                    "default": 80
                  },
                  "delay": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 10,
                    "default": 0
                  },
                  "wait_until": {
                    "type": "string",
                    "enum": [
                      "dom_loaded",
                      "page_loaded",
                      "network_idle"
                    ],
                    "default": "network_idle"
                  },
                  "scroll_page": {
                    "type": "boolean",
                    "default": false
                  },
                  "no_ads": {
                    "type": "boolean",
                    "default": false
                  },
                  "no_cookie_banners": {
                    "type": "boolean",
                    "default": false
                  },
                  "element": {
                    "type": "string"
                  },
                  "css": {
                    "type": "string"
                  },
                  "accept_language": {
                    "type": "string"
                  },
                  "ip_location": {
                    "type": "string"
                  },
                  "response_type": {
                    "type": "string",
                    "enum": [
                      "image",
                      "json"
                    ],
                    "default": "image"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Screenshot captured successfully",
            "headers": {
              "Content-Type": {
                "schema": {
                  "type": "string"
                }
              },
              "X-Quota-Limit": {
                "schema": {
                  "type": "integer"
                }
              },
              "X-Quota-Remaining": {
                "schema": {
                  "type": "integer"
                }
              },
              "X-Quota-Reset": {
                "schema": {
                  "type": "integer"
                }
              }
            },
            "content": {
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/webp": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters or unreachable URL"
          },
          "401": {
            "description": "Invalid or revoked access key"
          },
          "402": {
            "description": "Quota exceeded"
          },
          "403": {
            "description": "Feature unsupported in current plan"
          },
          "429": {
            "description": "Rate limit exceeded"
          },
          "500": {
            "description": "Server error"
          }
        },
        "tags": [
          "urltoimage"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "accessKey": {
        "type": "apiKey",
        "in": "query",
        "name": "access_key",
        "description": "API access key obtained from dashboard"
      }
    }
  },
  "tags": [
    {
      "name": "urltoimage"
    }
  ]
}
