      "description": "Repository management"
    },
    {
      "name": "Changesets",
      "description": "Commit changesets"
    },
    {
      "name": "Permissions",
      "description": "Repository permissions"
    },
    {
      "name": "Deployments",
      "description": "Server environments, release servers, and releases"
    },
    {
      "name": "Comments",
      "description": "Code comments"
    },
    {
      "name": "Integrations",
      "description": "Repository integrations"
    },
    {
      "name": "SSH Keys",
      "description": "SSH public key management"
    },
    {
      "name": "Invitations",
      "description": "User invitations"
    }
