{
  "openapi": "3.0.3",
  "info": {
    "title": "Beanstalk API",
    "version": "1.0.0",
    "description": "Beanstalk is a hosted version control service with deployment features. The API provides access to accounts, repositories, users, changesets (commits), permissions, deployments (server environments, release servers, releases), comments, integrations, SSH keys, and invitations. All requests use HTTP Basic Authentication and JSON format.",
    "x-jentic-source-url": "https://api.beanstalkapp.com",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{account}.beanstalkapp.com",
      "description": "Beanstalk API (per-account subdomain)",
      "variables": {
        "account": {
          "default": "example",
          "description": "Your Beanstalk account subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "BasicAuth": []
    }
  ],
