{
  "openapi": "3.0.3",
  "info": {
    "title": "UptimeToolbox API",
    "description": "Official API for UptimeToolbox. Monitor your infrastructure with heartbeat checks, node monitoring, and response tracking.",
    "contact": {
      "name": "Petronald Green",
      "email": "contact@uptimetoolbox.com"
    },
    "version": "v1",
    "x-jentic-source-url": "https://app.uptimetoolbox.com/api/swagger/"
  },
  "servers": [
    {
      "url": "https://app.uptimetoolbox.com/api/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "Bearer": [],
      "X-ORGANIZATION-ID": []
    }
  ],
  "tags": [
    {
      "name": "heartbeat",
      "description": "Heartbeat monitoring operations"
    },
    {
      "name": "node",
      "description": "Node management operations"
    },
    {
      "name": "node-response",
      "description": "Node response tracking"
    }
  ],
  "paths": {
    "/heartbeat/{heartbeat}": {
      "get": {
        "tags": [
          "heartbeat"
        ],
        "summary": "Get heartbeat details",
        "description": "Retrieve details for a specific heartbeat monitor",
        "operationId": "heartbeat_read",
        "parameters": [
          {
            "name": "heartbeat",
            "in": "path",
            "required": true,
            "description": "Heartbeat identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "last_ping": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        }
      },
      "post": {
        "tags": [
          "heartbeat"
        ],
        "summary": "Create heartbeat ping",
        "description": "Register a heartbeat ping to indicate the monitor is alive",
        "operationId": "heartbeat_create",
        "parameters": [
          {
            "name": "heartbeat",
            "in": "path",
            "required": true,
            "description": "Heartbeat identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "success",
                      "failure"
                    ]
                  },
                  "message": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Heartbeat ping created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/node-response": {
      "post": {
        "tags": [
          "node-response"
        ],
        "summary": "Create node response",
        "description": "Record a response from a monitored node",
        "operationId": "node-response_create",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "node_id",
                  "response_time"
                ],
                "properties": {
                  "node_id": {
                    "type": "string",
                    "description": "Node identifier"
                  },
                  "response_time": {
                    "type": "number",
                    "description": "Response time in milliseconds"
                  },
                  "status_code": {
                    "type": "integer",
                    "description": "HTTP status code"
                  },
                  "error_message": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Node response recorded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/node/by-guid/{guid}": {
      "get": {
        "tags": [
          "node"
        ],
        "summary": "Get node by GUID",
        "description": "Retrieve node information by its globally unique identifier",
        "operationId": "node_by-guid_read",
        "parameters": [
          {
            "name": "guid",
            "in": "path",
            "required": true,
            "description": "Node GUID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "guid": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "name": {
                      "type": "string"
                    },
                    "url": {
                      "type": "string",
                      "format": "uri"
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "up",
                        "down",
                        "maintenance"
                      ]
                    },
                    "last_check": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      },
      "X-ORGANIZATION-ID": {
        "type": "apiKey",
        "name": "X-ORGANIZATION-ID",
        "in": "header",
        "description": "Organization ID header"
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Authentication information is missing or invalid",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFoundError": {
        "description": "The specified resource was not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  }
}
