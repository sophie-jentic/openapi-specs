{
  "openapi": "3.0.3",
  "info": {
    "title": "BRI API",
    "version": "1.0.0",
    "description": "BRI (Bank Rakyat Indonesia) API platform providing BRI Direct Debit, BRIZZI e-money, BRIVA payment processing, and Banking as a Service (BaaS) for account management.",
    "x-jentic-source-url": "https://developers.bri.co.id/en",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://sandbox.partner.api.bri.co.id",
      "description": "Sandbox server"
    },
    {
      "url": "https://partner.api.bri.co.id",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/direct-debit/payment": {
      "post": {
        "operationId": "processDirectDebitPayment",
        "summary": "Process direct debit payment",
        "description": "Integrates debit card payments into applications",
        "tags": [
          "Direct Debit"
        ],
        "parameters": [
          {
            "name": "BRI-Timestamp",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Request timestamp in ISO 8601 format"
          },
          {
            "name": "BRI-Signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Request signature for validation"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cardNumber": {
                    "type": "string"
                  },
                  "phoneNumber": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "number"
                  },
                  "transactionId": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful payment",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "transactionId": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/brizzi/payment": {
      "post": {
        "operationId": "processBrizziPayment",
        "summary": "Process BRIZZI e-money payment",
        "description": "E-money payment integration service",
        "tags": [
          "BRIZZI"
        ],
        "parameters": [
          {
            "name": "BRI-Timestamp",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Request timestamp in ISO 8601 format"
          },
          {
            "name": "BRI-Signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Request signature for validation"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cardNumber": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "number"
                  },
                  "merchantId": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful payment",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "transactionId": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/briva/payment": {
      "post": {
        "operationId": "processBrivaPayment",
        "summary": "Process BRIVA payment",
        "description": "Unique code-based payment processing",
        "tags": [
          "BRIVA"
        ],
        "parameters": [
          {
            "name": "BRI-Timestamp",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Request timestamp in ISO 8601 format"
          },
          {
            "name": "BRI-Signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Request signature for validation"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "brivaNumber": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "number"
                  },
                  "customerId": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful payment",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "paymentCode": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/accounts/savings": {
      "post": {
        "operationId": "createSavingsAccount",
        "summary": "Create savings account",
        "description": "Banking as a Service (BaaS) - Open a new savings account",
        "tags": [
          "Banking as a Service"
        ],
        "parameters": [
          {
            "name": "BRI-Timestamp",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "BRI-Signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerName": {
                    "type": "string"
                  },
                  "identificationNumber": {
                    "type": "string"
                  },
                  "initialDeposit": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accountNumber": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token authentication"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "BRIVA"
    },
    {
      "name": "BRIZZI"
    },
    {
      "name": "Banking as a Service"
    },
    {
      "name": "Direct Debit"
    }
  ]
}
