{
  "openapi": "3.0.3",
  "info": {
    "title": "MLflow REST API",
    "version": "2.0",
    "description": "MLflow open source platform REST API for managing the ML lifecycle. Supports experiment tracking, model registry, run management, artifact logging, and model serving. This covers the Tracking Server REST API.",
