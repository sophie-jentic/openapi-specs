  },
  "host": "apitestenv.vnforapps.com",
  "basePath": "/api.visanet/v1",
  "tags": [
    {
      "name": "Financial API",
      "description": "RESTful API for Visanet Financial operations"
    },
    {
      "name": "Accept conditions and terms"
    }
  ],
  "schemes": [
    "https"
  ],
  "paths": {
    "/query/summary": {
      "post": {
        "tags": [
          "Financial API"
        ],
        "summary": "Query financial summary items for specified business",
        "description": "Query financial summary items for specified business",
        "operationId": "getHistory",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Business info to query",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FinancialHistoryRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/FinancialHistoryResponse"
            }
          }
        },
        "security": [
          {
            "accessToken": []
          }
        ]
      }
    },
    "/conditionsandterms": {
      "post": {
        "tags": [
          "Accept conditions and terms"
        ],
        "summary": "insert data of client",
        "description": "insert data of client",
        "operationId": "conditions",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Business info to query",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ClientItem"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/ClientResponse"
            }
          }
        },
        "security": [
          {
            "accessToken": []
          }
        ]
      }
    }
  },
  "securityDefinitions": {
    "accessToken": {
      "description": "Access token obtained from api.security",
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "definitions": {
    "FinancialHistoryRequest": {
      "type": "object",
      "properties": {
        "businessId": {
          "type": "string",
          "maxLength": 20,
          "description": "RUC"
        },
        "businessName": {
          "type": "string",
          "maxLength": 100,
          "description": "Nombre de la empresa"
        },
        "legalRepresentativeId": {
          "type": "string",
          "maxLength": 8,
          "description": "DNI del representante legal"
        },
        "legalRepresentativeName": {
          "type": "string",
          "maxLength": 100,
          "description": "Nombre del representante legal"
        },
        "externalId": {
          "type": "string",
          "maxLength": 6,
          "description": "Identificador de la transacci\u00f3n"
        },
        "checkContractTerm": {
          "type": "boolean",
          "description": "T\u00e9rminos y condiciones"
        },
        "companyId": {
          "type": "string",
          "maxLength": 3,
          "description": "N\u00famero de empresa, ser\u00e1 '165'"
        },
        "functionId": {
          "type": "string",
          "maxLength": 3,
          "description": "Id de la funci\u00f3n, ser\u00e1 '636'"
        }
      }
    },
    "FinancialHistoryResponse": {
      "type": "object",
      "properties": {
        "header": {
          "$ref": "#/definitions/ResponseHeader"
        },
        "data": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/FinancialItem"
          }
        }
      }
    },
    "FinancialItem": {
      "type": "object",
      "properties": {
        "month": {
          "type": "integer",
          "format": "int32"
        },
        "year": {
          "type": "integer",
          "format": "int32"
        },
        "totalTransactions": {
          "type": "integer"
        },
        "totalAmount": {
          "type": "number"
        },
        "currency": {
          "type": "string",
          "enum": [
            "PEN",
            "USD"
          ]
        },
        "businessId": {
          "type": "string",
          "maxLength": 20,
          "description": "RUC"
        }
      }
    },
    "ResponseHeader": {
      "type": "object",
      "properties": {
        "errorCode": {
          "type": "string"
        },
        "errorMessage": {
          "type": "string"
        },
        "userName": {
          "type": "string"
        },
        "executionDate": {
          "type": "integer",
          "format": "int64"
        },
        "transactionUUID": {
          "type": "string"
        }
      }
    },
    "ClientItem": {
      "type": "object",
      "required": [
        "businessId",
        "legalRepresentativeName",
        "legalRepresentativeLastName",
        "legalRepresentativeId",
        "businessName",
        "totalAmount",
        "billingDate"
      ],
      "properties": {
        "businessId": {
          "type": "string",
          "maxLength": 11,
          "description": "RUC"
        },
        "legalRepresentativeName": {
          "type": "string",
          "maxLength": 100,
          "description": "Nombre del representante legal"
        },
        "legalRepresentativeLastName": {
          "type": "string",
          "maxLength": 100,
          "description": "Apellido Paterno del representante legal"
        },
        "legalRepresentativeSurname": {
          "type": "string",
          "maxLength": 100,
          "description": "Apellido Materno del representante legal"
        },
        "legalRepresentativeId": {
          "type": "string",
          "maxLength": 16,
          "description": "DNI del representante legal"
        },
        "businessName": {
          "type": "string",
          "maxLength": 100,
          "description": "Raz\u00f3n social asociado al RUC"
        },
        "totalAmount": {
          "type": "number",
          "description": "Monto total de la deuda con 2 decimales"
        },
        "billingDate": {
          "type": "string",
          "maxLength": 10,
          "description": "Fecha de inicio de cobranza. Formato DD/MM/YYYY"
        }
      }
    },
    "ClientResponse": {
      "type": "object",
      "properties": {
        "header": {
          "$ref": "#/definitions/ResponseHeader"
        }
      }
    }
  }
}
