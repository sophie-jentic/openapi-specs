            "description": "P\u00e1gina de inicio",
            "required": true
          },
          {
            "name": "finalPage",
            "in": "path",
            "type": "string",
            "description": "P\u00e1gina de fin",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
