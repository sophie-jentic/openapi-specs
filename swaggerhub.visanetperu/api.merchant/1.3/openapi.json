  "securityDefinitions": {
    "accessToken": {
      "description": "Access token obtained from api.security",
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "definitions": {
    "MerchantRequest": {
      "type": "object",
      "required": [
        "businessId",
        "externalId",
        "companyId",
        "functionId"
      ],
      "properties": {
        "businessId": {
          "type": "string",
          "maxLength": 20,
          "description": "RUC"
        },
        "externalId": {
          "type": "string",
          "maxLength": 6,
          "description": "Id de transacci\u00f3n"
        },
        "companyId": {
          "type": "string",
          "maxLength": 3,
          "description": "N\u00famero de empresa, ser\u00e1 '165'"
        },
        "functionId": {
          "type": "string",
          "description": "Id de la funci\u00f3n, ser\u00e1 '651'"
        }
      }
    },
    "MerchantResponse": {
      "type": "object",
      "properties": {
        "header": {
          "$ref": "#/definitions/ResponseHeader"
        },
        "data": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/MerchantItem"
          }
        }
      }
    },
    "MerchantItem": {
