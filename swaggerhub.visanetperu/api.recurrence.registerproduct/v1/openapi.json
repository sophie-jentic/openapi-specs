            "productCode",
            "cardNumber",
            "expirationMonth",
            "expirationYear",
            "firstNameCardHolder",
            "lastNameCardHolder",
            "beneficiaryId",
            "channelId",
            "chargeType",
            "chargeAmount",
            "chargeDate",
            "periodicity",
            "automaticRetry"
