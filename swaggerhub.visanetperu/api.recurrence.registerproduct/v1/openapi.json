              "description": "Nombre beneficiario"
            },
            "lastNameBeneficiary": {
              "type": "string",
              "maxLength": 100,
              "example": "G\u00f3mez",
              "description": "Apellido beneficiario"
            },
            "maximunAmount": {
              "type": "string",
              "maxLength": 16,
              "example": "100.00",
              "description": "Monto m\u00e1ximo"
            },
            "channelId": {
              "type": "string",
              "maxLength": 1,
              "example": "6",
              "description": "Canal consumidor. Puede ser 6 (CE)"
            },
            "chargeType": {
              "type": "string",
              "maxLength": 1,
              "example": "0",
              "description": "Tipo Cargo Cobro, puede ser: \u201c0\u201d fijo o \u201c1\u201d variable (Plataforma REC)"
            },
            "chargeAmount": {
              "type": "string",
              "maxLength": 16,
              "example": "100.00",
              "description": "Monto del cargo"
            },
            "chargeDate": {
              "type": "string",
              "maxLength": 10,
              "example": "2019-10-01",
              "description": "Fecha del cargo pago. Plataforma CE (Primera Transacci\u00f3n) y REC, con este campo se puede manejar el concepto de periodo de gracia. Formato (YYYY-MM-DD)"
            },
            "periodicity": {
              "type": "string",
              "maxLength": 1,
              "example": "1",
              "description": "Periodicidad. puede ser: \u201c1\u201d mensual, \u201c2\u201d semestral, \u201c3\u201d anual, \u201c4\u201d Trimestral."
            },
            "automaticRetry": {
              "type": "string",
              "maxLength": 1,
              "example": "1",
              "description": "Reintento autom\u00e1tico. Puede ser: \u201c0\u201d No, \u201c1\u201d Si"
            }
          }
