            },
            "expirationMonth": {
              "type": "string",
              "maxLength": 2,
              "example": "10",
              "description": "Mes de expiraci\u00f3n de tarjeta"
            },
            "expirationYear": {
              "type": "string",
              "maxLength": 4,
              "example": "10",
              "description": "A\u00f1o de expiraci\u00f3n de tarjeta"
            },
            "firstNameCardHolder": {
              "type": "string",
              "maxLength": 100,
              "example": "Mar\u00eda",
              "description": "Nombre tarjeta habiente"
            },
            "lastNameCardHolder": {
              "type": "string",
              "maxLength": 100,
              "example": "G\u00f3mez",
              "description": "Apellido tarjeta habiente"
            },
            "documentTypeCardHolder": {
              "type": "string",
              "maxLength": 1,
              "example": "1",
