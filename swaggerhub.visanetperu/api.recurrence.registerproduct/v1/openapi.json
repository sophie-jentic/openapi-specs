            },
            "documentIdCardHolder": {
              "type": "string",
              "maxLength": 50,
              "example": "43657877",
              "description": "Id documento tarjeta habiente (Plataforma REC)"
            },
            "telephoneCardHolder": {
              "type": "string",
              "maxLength": 25,
              "example": "980987890",
              "description": "Tel\u00e9fono tarjeta habiente (Plataforma REC)"
            },
            "emailCardHolder": {
              "type": "string",
              "maxLength": 200,
              "example": "prueba@gmail.com",
              "description": "Correo tarjeta habiente (Plataforma REC)"
            },
            "beneficiaryId": {
              "type": "string",
              "maxLength": 50,
              "example": "897767",
