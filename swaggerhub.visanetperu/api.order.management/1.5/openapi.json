    "/api/v1/order/filter/{pageSize}/{pageNumber}": {
      "get": {
        "tags": [
          "order"
        ],
        "summary": "Query orders by filter",
        "description": "Query orders by filter",
        "operationId": "getOrderListByFilter",
        "parameters": [
          {
            "name": "pageSize",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "pageNumber",
            "in": "path",
            "description": "Important: Starts in page 1",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "merchantId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "createdBefore",
            "in": "query",
            "description": "Creation time in yyyy-MM-dd format, it will automatically add 23:59:59 to include all day.",
            "schema": {
              "type": "string"
            },
            "example": "2020-04-01"
          },
          {
            "name": "createdAfter",
            "in": "query",
            "description": "Creation time in yyyy-MM-dd format, it will automatically add 00:00:00 to include all day.",
            "schema": {
              "type": "string"
            },
            "example": "2020-04-01"
          },
          {
            "name": "orderId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "externalId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "amount",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "PENDING",
                "COMPLETED",
                "FAILED",
                "CANCELED",
                "EXPIRED"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderQueryResponse"
                }
              }
            }
          },
          "404": {
            "description": "Order not found"
          }
        }
      }
    }
  },
