{
  "openapi": "3.0.3",
  "info": {
    "title": "EmailEngine API",
    "version": "1.0.0",
    "description": "Self-hosted email API that provides REST access to email accounts via IMAP/SMTP, including mailbox management, message operations, templates, and webhooks.",
    "x-jentic-source-url": "https://emailengine.app/",
    "contact": {}
  },
