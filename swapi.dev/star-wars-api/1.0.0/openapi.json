{
  "openapi": "3.0.3",
  "info": {
    "title": "SWAPI - The Star Wars API",
    "description": "The Star Wars API (SWAPI) provides data about the Star Wars universe including people, planets, films, species, vehicles, and starships. All data is freely available with no authentication required.",
    "version": "1.0.0",
    "contact": {
      "url": "https://swapi.dev"
    }
  },
  "servers": [
    {
      "url": "https://swapi.dev/api",
      "description": "Production server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getRoot",
        "summary": "List all available resources",
        "description": "Returns links to all available resource collections.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "people": {
                      "type": "string",
                      "format": "uri"
                    },
                    "planets": {
                      "type": "string",
                      "format": "uri"
                    },
                    "films": {
                      "type": "string",
                      "format": "uri"
                    },
                    "species": {
                      "type": "string",
                      "format": "uri"
                    },
                    "vehicles": {
                      "type": "string",
                      "format": "uri"
                    },
                    "starships": {
                      "type": "string",
                      "format": "uri"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "default"
        ]
      }
    },
    "/people/": {
      "get": {
        "operationId": "listPeople",
        "summary": "List all people",
        "description": "Returns a paginated list of people resources.",
        "parameters": [
          {
            "$ref": "#/components/parameters/search"
          },
          {
            "$ref": "#/components/parameters/page"
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/PaginatedResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "results": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Person"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "people"
        ]
      }
    },
    "/people/{id}/": {
      "get": {
        "operationId": "getPerson",
        "summary": "Get a specific person",
        "description": "Returns a single person resource by ID.",
        "parameters": [
          {
            "$ref": "#/components/parameters/resourceId"
          },
          {
            "$ref": "#/components/parameters/format"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
