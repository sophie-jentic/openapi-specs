              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "couchdb": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    },
                    "vendor": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get server information"
      }
    },
