{
  "openapi": "3.0.3",
  "info": {
    "title": "Product Hunt API",
    "description": "The best new products in tech. Product Hunt API v2 is GraphQL-based, providing a single POST endpoint for all queries and mutations. Authenticate via OAuth 2.0 or a developer token.",
    "version": "2.0.0",
    "contact": {
      "name": "Product Hunt",
      "url": "https://www.producthunt.com"
    },
    "termsOfService": "https://www.producthunt.com/terms"
  },
  "servers": [
    {
      "url": "https://api.producthunt.com/v2",
      "description": "Production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/graphql": {
      "post": {
        "operationId": "executeGraphQL",
        "summary": "Execute GraphQL query or mutation",
        "description": "Single GraphQL endpoint for all Product Hunt API operations including querying posts, users, topics, collections, and performing mutations such as voting.",
        "tags": [
          "GraphQL"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GraphQLRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful GraphQL response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraphQLResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication token"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/oauth/token": {
      "post": {
        "operationId": "obtainAccessToken",
        "summary": "Obtain an OAuth access token",
        "description": "Exchange an authorization code for an access token, or obtain a client-level token for read-only access.",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OAuthTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthTokenResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/oauth/authorize": {
      "get": {
        "operationId": "authorizeUser",
        "summary": "Authorize a user via OAuth",
        "description": "Redirect the user to this endpoint to initiate the OAuth authorization flow.",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "description": "Your application's client ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": true,
            "description": "The URI to redirect to after authorization.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "description": "Must be 'code'.",
            "schema": {
              "type": "string",
              "enum": [
                "code"
              ]
            }
          },
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "description": "Requested scope: public, private, or write.",
            "schema": {
              "type": "string",
              "enum": [
                "public",
                "private",
                "write"
              ]
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to authorization page"
          }
        }
      }
    },
    "/oauth/test": {
      "get": {
        "operationId": "testToken",
        "summary": "Test an access token",
        "description": "Validate whether the current access token is functional.",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Token is valid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token is invalid"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2.0 Bearer token or Developer token. Pass as: Authorization: Bearer {token}"
      }
    },
    "schemas": {
      "GraphQLRequest": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "The GraphQL query or mutation string."
          },
          "variables": {
            "type": "object",
            "additionalProperties": true,
            "description": "Variables for the GraphQL query."
          },
          "operationName": {
            "type": "string",
            "description": "The name of the operation to execute if the query contains multiple operations."
          }
        }
      },
      "GraphQLResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "additionalProperties": true,
            "description": "The result data from the query."
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GraphQLError"
            },
            "description": "Errors encountered during query execution."
          }
        }
      },
      "GraphQLError": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message."
          },
          "locations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "line": {
                  "type": "integer"
                },
                "column": {
                  "type": "integer"
                }
              }
            }
          },
          "path": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "OAuthTokenRequest": {
        "type": "object",
        "required": [
          "client_id",
          "client_secret",
          "grant_type"
        ],
        "properties": {
          "client_id": {
            "type": "string",
            "description": "Your application's client ID."
          },
          "client_secret": {
            "type": "string",
            "description": "Your application's client secret."
          },
          "grant_type": {
            "type": "string",
            "description": "The grant type: 'authorization_code' or 'client_credentials'.",
            "enum": [
              "authorization_code",
              "client_credentials"
            ]
          },
          "code": {
            "type": "string",
            "description": "The authorization code (required for authorization_code grant)."
          },
          "redirect_uri": {
            "type": "string",
            "description": "The redirect URI used in the authorization request."
          }
        }
      },
      "OAuthTokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The access token."
          },
          "token_type": {
            "type": "string",
            "description": "The token type (bearer)."
          },
          "scope": {
            "type": "string",
            "description": "The granted scope."
          },
          "created_at": {
            "type": "integer",
            "description": "Token creation timestamp."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Authentication"
    },
    {
      "name": "GraphQL"
    }
  ]
}
