  "components": {
    "schemas": {
      "ConversionPaths": {
        "type": "object",
        "properties": {
          "alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "converters": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "ConversionResult": {
        "type": "object",
        "properties": {
          "resultUrl": {
            "type": "string",
            "description": "URL to download the converted file"
          },
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "AnalysisResult": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "description": "Analysis data depending on the analyzer used"
          },
          "id": {
            "type": "string"
          }
        }
      },
      "ProcessResult": {
        "type": "object",
        "properties": {
          "resultUrl": {
            "type": "string",
            "description": "URL to download the processed file"
          },
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      }
    }
  },
