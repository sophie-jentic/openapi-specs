{
  "openapi": "3.0.3",
  "info": {
    "title": "Vector Express API",
    "version": "2.0.0",
    "description": "Free vector file conversion, analyzing and processing API. Supports SVG, EPS, PDF, DXF, DWG, AI, CDR, HPGL, PLT, PS formats.",
    "x-jentic-source-url": "https://vector.express/api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://vector.express/api/v2"
    }
  ],
  "paths": {
    "/public/convert/{input_format}/auto/{output_format}": {
      "get": {
        "operationId": "get_conversion_paths",
        "summary": "Get possible conversion paths between formats",
        "description": "Returns the most efficient conversion path between the input and output formats.",
        "tags": [
          "Convert"
        ],
        "parameters": [
          {
            "name": "input_format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "ai",
                "cdr",
                "dwg",
                "dxf",
                "eps",
                "hpgl",
                "pdf",
                "plt",
                "ps",
                "svg"
              ]
            }
          },
          {
            "name": "output_format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "dwg",
                "dxf",
                "eps",
                "pdf",
                "plt",
                "ps",
                "svg"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversion paths found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversionPaths"
                }
              }
            }
          },
          "400": {
            "description": "Invalid format specified"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/public/convert/{input_format}/{converter}/{output_format}": {
      "post": {
        "operationId": "convert_file_single",
        "summary": "Convert a file using a single converter",
        "description": "Convert a vector file from one format to another using a specific converter program.",
        "tags": [
          "Convert"
        ],
        "parameters": [
          {
            "name": "input_format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "ai",
                "cdr",
                "dwg",
                "dxf",
                "eps",
                "hpgl",
                "pdf",
                "plt",
                "ps",
                "svg"
              ]
            }
          },
          {
            "name": "converter",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "cad2pdf",
                "cad2svg",
                "cadlib",
                "gs",
                "hp2xx",
                "libcdr",
                "librsvg",
                "pdf2svg",
                "pstoedit",
                "svg2cad",
                "svgo",
                "uniconvertor"
              ]
            }
          },
          {
            "name": "output_format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "dwg",
                "dxf",
                "eps",
                "pdf",
                "plt",
                "ps",
                "svg"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversion started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversionResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/public/convert/{in_fmt}/{conv1}/{mid_fmt}/{conv2}/{out_fmt}": {
      "post": {
        "operationId": "convert_file_chain",
        "summary": "Convert a file using chained converters",
        "description": "Chain up to three conversion programs for complex format conversions.",
        "tags": [
          "Convert"
        ],
        "parameters": [
          {
            "name": "in_fmt",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "conv1",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mid_fmt",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "conv2",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "out_fmt",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversion started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversionResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/public/files/{file_id}": {
      "get": {
        "operationId": "get_file",
        "summary": "Download a converted file",
        "description": "Retrieve a file by its ID after conversion.",
        "tags": [
          "Files"
        ],
        "parameters": [
          {
            "name": "file_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "File not found"
          }
        }
      }
    },
