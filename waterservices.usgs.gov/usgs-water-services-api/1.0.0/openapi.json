{
  "openapi": "3.0.3",
  "info": {
    "title": "USGS Water Services API",
    "version": "1.0.0",
    "description": "U.S. Geological Survey water data APIs providing instantaneous values, daily statistics, site information, and groundwater level data for monitoring stations across the United States.",
    "x-jentic-source-url": "https://waterservices.usgs.gov/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://waterservices.usgs.gov"
    }
  ],
  "paths": {
    "/nwis/iv/": {
      "get": {
        "operationId": "getInstantaneousValues",
        "summary": "Get instantaneous values",
        "description": "Returns instantaneous time-series water data (e.g., streamflow, gage height, temperature) for USGS monitoring stations.",
        "tags": [
          "Instantaneous Values"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "description": "Response format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "waterml,2.0",
                "rdb"
              ],
              "default": "json"
            }
          },
          {
            "name": "sites",
            "in": "query",
            "description": "Comma-separated list of site numbers",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "stateCd",
            "in": "query",
            "description": "U.S. state code (e.g., ny, ca)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "huc",
            "in": "query",
            "description": "Hydrologic unit code(s)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bBox",
            "in": "query",
            "description": "Bounding box (west,south,east,north) in decimal degrees",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "countyCd",
            "in": "query",
            "description": "County FIPS code(s)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "parameterCd",
            "in": "query",
            "description": "Parameter code(s) - e.g., 00060 for discharge, 00065 for gage height",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "siteType",
            "in": "query",
            "description": "Site type filter",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "period",
            "in": "query",
            "description": "ISO 8601 duration (e.g., P7D for 7 days)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startDT",
            "in": "query",
            "description": "Start date-time (ISO 8601)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endDT",
            "in": "query",
            "description": "End date-time (ISO 8601)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "siteStatus",
            "in": "query",
            "description": "Site status filter",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "active",
                "inactive"
              ],
              "default": "all"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Time series data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TimeSeriesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
