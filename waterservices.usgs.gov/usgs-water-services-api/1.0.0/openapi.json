            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "countyCd",
            "in": "query",
            "description": "County FIPS code(s)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "parameterCd",
            "in": "query",
            "description": "Parameter code(s)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startDT",
            "in": "query",
            "description": "Start date (ISO 8601)",
