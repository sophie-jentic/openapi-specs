            "name": "format",
            "in": "query",
            "description": "Response format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "waterml,2.0",
                "rdb"
              ],
              "default": "json"
            }
          },
          {
            "name": "sites",
            "in": "query",
            "description": "Comma-separated site numbers",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "stateCd",
            "in": "query",
            "description": "U.S. state code",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startDT",
            "in": "query",
            "description": "Start date",
            "required": false,
            "schema": {
              "type": "string",
