          },
          {
            "name": "period",
            "in": "query",
            "description": "ISO 8601 duration",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "siteStatus",
            "in": "query",
            "description": "Site status filter",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "active",
                "inactive"
              ],
              "default": "all"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily values data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TimeSeriesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/nwis/site/": {
      "get": {
        "operationId": "getSiteInfo",
        "summary": "Get site information",
        "description": "Returns information about USGS monitoring sites.",
        "tags": [
          "Site Information"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "description": "Response format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "rdb",
                "mapper"
              ],
              "default": "rdb"
            }
          },
          {
            "name": "sites",
            "in": "query",
            "description": "Comma-separated list of site numbers",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "stateCd",
            "in": "query",
            "description": "U.S. state code",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "huc",
            "in": "query",
            "description": "Hydrologic unit code(s)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bBox",
            "in": "query",
            "description": "Bounding box",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "countyCd",
            "in": "query",
            "description": "County FIPS code(s)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "siteType",
            "in": "query",
            "description": "Site type filter",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "siteOutput",
            "in": "query",
            "description": "Output level",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "basic",
                "expanded"
              ]
            }
          },
          {
            "name": "siteStatus",
            "in": "query",
            "description": "Site status",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "active",
                "inactive"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Site information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SiteResponse"
                }
              }
            }
          },
          "400": {
