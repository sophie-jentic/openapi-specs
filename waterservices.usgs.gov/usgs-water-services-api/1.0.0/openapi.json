  },
  "components": {
    "schemas": {
      "TimeSeriesResponse": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "declaredType": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "value": {
            "type": "object",
            "properties": {
              "queryInfo": {
                "type": "object"
              },
              "timeSeries": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/TimeSeries"
                }
              }
            }
          }
        }
      },
      "TimeSeries": {
        "type": "object",
        "properties": {
          "sourceInfo": {
            "type": "object",
            "properties": {
              "siteName": {
                "type": "string"
              },
              "siteCode": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string"
                    },
                    "network": {
                      "type": "string"
                    },
                    "agencyCode": {
                      "type": "string"
                    }
                  }
                }
              },
              "geoLocation": {
                "type": "object"
              }
            }
          },
          "variable": {
            "type": "object",
            "properties": {
              "variableCode": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "variableName": {
                "type": "string"
              },
              "variableDescription": {
                "type": "string"
              },
              "unit": {
                "type": "object"
              }
            }
          },
          "values": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "value": {
                        "type": "string"
                      },
                      "qualifiers": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "dateTime": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "SiteResponse": {
        "type": "object",
        "properties": {
          "value": {
            "type": "object",
            "properties": {
              "queryInfo": {
                "type": "object"
              },
              "timeSeries": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
