              "country_of_affiliation": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "address": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "org_name": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
