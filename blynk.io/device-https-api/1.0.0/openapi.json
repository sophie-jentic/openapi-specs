{
  "openapi": "3.0.0",
  "info": {
    "title": "Blynk Cloud Device HTTPS API",
    "description": "The Blynk Device HTTPS API allows you to interact with your IoT devices, retrieve and update datastream values, manage device metadata, and access device history.",
    "version": "1.0.0",
    "contact": {
      "name": "Blynk",
      "url": "https://blynk.io"
    }
  },
  "servers": [
    {
      "url": "https://blynk.cloud/external/api",
      "description": "Blynk Cloud Production Server"
    },
    {
      "url": "https://{server_address}/external/api",
      "description": "Custom Blynk Server",
      "variables": {
        "server_address": {
          "default": "blynk.cloud",
          "description": "Your Blynk server address"
        }
      }
    }
  ],
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "paths": {
    "/get": {
      "get": {
        "summary": "Get Datastream Value",
        "description": "Retrieve the current value of a datastream by pin or datastream ID",
        "operationId": "getDatastreamValue",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "Device authentication token",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pin",
            "in": "query",
            "required": false,
            "description": "Virtual pin identifier (e.g., v1, v2). Use either pin or dataStreamId.",
            "schema": {
              "type": "string",
              "pattern": "^v\\d+$"
            }
          },
          {
            "name": "dataStreamId",
            "in": "query",
            "required": false,
            "description": "Unique datastream identifier. Use either pin or dataStreamId.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with datastream value",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "The current value of the datastream"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid token or pin format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "invalidToken": {
                    "value": {
                      "error": {
                        "message": "Invalid token."
                      }
                    }
                  },
                  "wrongPinFormat": {
                    "value": {
                      "error": {
                        "message": "Wrong pin format."
                      }
                    }
                  },
                  "datastreamNotFound": {
                    "value": {
                      "error": {
                        "message": "Requested dataStream doesn't exist in the product"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "get"
        ]
      }
    },
    "/update": {
      "get": {
        "summary": "Update Datastream Value",
        "description": "Update the value of a datastream by pin or datastream ID",
        "operationId": "updateDatastreamValue",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "Device authentication token",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pin",
            "in": "query",
            "required": false,
            "description": "Virtual pin identifier with value (e.g., v1=100). Use either pin or dataStreamId.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dataStreamId",
            "in": "query",
            "required": false,
            "description": "Unique datastream identifier. Use with value parameter.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "value",
            "in": "query",
            "required": false,
            "description": "The value to set for the datastream. Can be specified multiple times for multi-value datastreams.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully updated datastream value"
          },
          "400": {
            "description": "Bad request - invalid parameters or value type mismatch",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "update"
        ]
      }
    },
    "/batch/update": {
      "get": {
        "summary": "Batch Update Datastreams",
        "description": "Update multiple datastream values in a single request",
        "operationId": "batchUpdateDatastreams",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "Device authentication token",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully updated datastream values"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "batch"
        ]
      }
    },
    "/logEvent": {
      "get": {
        "summary": "Trigger Log Event",
        "description": "Trigger a log event for the device",
        "operationId": "logEvent",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "Device authentication token",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code",
            "in": "query",
            "required": true,
            "description": "Event code to log",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Event logged successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "logEvent"
        ]
      }
    },
    "/data": {
      "get": {
        "summary": "Get Device History Data",
        "description": "Retrieve historical data for a device datastream",
        "operationId": "getDeviceHistoryData",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "Device authentication token",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "period",
            "in": "query",
            "required": false,
            "description": "Time period for historical data",
            "schema": {
              "type": "string",
              "enum": [
                "day",
                "week",
                "month"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Historical data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "ts": {
                        "type": "integer",
                        "description": "Timestamp"
                      },
                      "value": {
                        "description": "Datastream value"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "data"
        ]
      }
    },
    "/isHardwareConnected": {
      "get": {
        "summary": "Check Device Connection Status",
        "description": "Check if a device is currently connected to the Blynk server",
        "operationId": "isDeviceConnected",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "Device authentication token",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Device connection status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "online": {
                      "type": "boolean",
                      "description": "Whether the device is currently connected"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "isHardwareConnected"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "Device authentication token obtained from the Blynk platform"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message describing what went wrong"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "batch"
    },
    {
      "name": "data"
    },
    {
      "name": "get"
    },
    {
      "name": "isHardwareConnected"
    },
    {
      "name": "logEvent"
    },
    {
      "name": "update"
    }
  ]
}
