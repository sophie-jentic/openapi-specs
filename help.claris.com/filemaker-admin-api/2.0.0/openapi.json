{
  "openapi": "3.0.3",
  "info": {
    "title": "Claris FileMaker Admin API",
    "version": "2.0.0",
    "description": "The FileMaker Admin API v2 is a REST API that allows web services to perform administrative tasks on FileMaker Cloud and FileMaker Server. It returns data in JSON format and supports authentication, database management, client management, schedule management, server configuration, and more.",
    "x-jentic-source-url": "https://help.claris.com/en/admin-api-guide/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{host}/fmi/admin/api/v2",
      "description": "FileMaker Server Admin API v2",
      "variables": {
        "host": {
          "default": "your-server.example.com",
          "description": "FileMaker Server hostname"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Authentication and access token management"
    },
    {
      "name": "Server",
      "description": "Server configuration and metadata"
    },
    {
      "name": "Databases",
      "description": "Database management"
    },
    {
      "name": "Clients",
      "description": "Client connection management"
    },
    {
      "name": "Schedules",
      "description": "Schedule management"
    },
    {
      "name": "Settings",
      "description": "Server settings and configuration"
    }
  ],
  "paths": {
    "/user/auth": {
      "post": {
        "operationId": "requestAccessToken",
        "summary": "Request access token",
        "description": "Authenticate and obtain a JSON Web Token (access token) for subsequent API calls. Uses HTTP Basic authentication with admin username and password.",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Access token returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      },
      "delete": {
        "operationId": "invalidateAccessToken",
        "summary": "Invalidate access token",
        "description": "Log out and invalidate the current access token.",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Token invalidated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
