{
  "openapi": "3.0.3",
  "info": {
    "title": "Claris FileMaker OData API",
    "version": "4.01",
    "description": "The FileMaker OData API implements the Open Data Protocol (OData 4.01) standard for querying and updating data in FileMaker databases hosted by FileMaker Cloud and FileMaker Server. It provides a standard REST interface that works with OData-compatible clients like Excel, Power BI, and other tools. Supports JSON and Atom (XML) response formats.",
    "x-jentic-source-url": "https://help.claris.com/en/odata-guide/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{host}/fmi/odata/v4",
      "description": "FileMaker OData API v4",
      "variables": {
        "host": {
          "default": "your-server.example.com",
          "description": "FileMaker Server hostname"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Service",
      "description": "Service document and metadata"
    },
    {
      "name": "Entity Sets",
      "description": "Entity set (table) operations"
    },
    {
      "name": "Entities",
      "description": "Individual entity (record) operations"
    }
  ],
  "paths": {
    "/{database}": {
      "get": {
        "operationId": "getServiceDocument",
        "summary": "Get OData service document",
        "description": "Retrieve the OData service document listing all available entity sets (tables) in the database.",
        "tags": [
          "Service"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Database name"
          }
        ],
        "responses": {
          "200": {
            "description": "OData service document",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceDocument"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          }
        }
      }
    },
    "/{database}/$metadata": {
      "get": {
        "operationId": "getMetadata",
        "summary": "Get OData metadata document",
        "description": "Retrieve the OData metadata document (CSDL) describing all entity types, properties, and relationships.",
        "tags": [
          "Service"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OData CSDL metadata document",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          }
        }
      }
    },
    "/{database}/{tableName}": {
      "get": {
        "operationId": "getEntitySet",
        "summary": "Get records from a table",
        "description": "Retrieve records from an entity set (table). Supports OData query options including $filter, $select, $orderby, $top, $skip, and $count.",
        "tags": [
          "Entity Sets"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Table/entity set name"
          },
          {
            "name": "$filter",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "OData filter expression"
          },
          {
            "name": "$select",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of fields to return"
          },
          {
            "name": "$orderby",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sort order (field asc/desc)"
          },
          {
            "name": "$top",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Maximum number of records to return"
          },
          {
            "name": "$skip",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of records to skip"
          },
          {
            "name": "$count",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include total count in response"
          }
        ],
        "responses": {
          "200": {
            "description": "Entity set data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntitySetResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createEntity",
        "summary": "Create a record",
        "description": "Create a new record (entity) in a table.",
        "tags": [
          "Entity Sets"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "description": "Field name-value pairs for the new record"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Entity created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          }
        }
      }
    },
    "/{database}/{tableName}({primaryKey})": {
      "get": {
        "operationId": "getEntity",
        "summary": "Get a single record",
        "description": "Retrieve a single record by its primary key.",
        "tags": [
          "Entities"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "primaryKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Primary key value of the record"
          }
        ],
        "responses": {
          "200": {
            "description": "Entity data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          },
          "404": {
            "description": "Entity not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateEntity",
        "summary": "Update a record",
        "description": "Update an existing record's field values.",
        "tags": [
          "Entities"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "primaryKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "description": "Fields to update"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Entity updated (no content)"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteEntity",
        "summary": "Delete a record",
        "description": "Delete a record by its primary key.",
        "tags": [
          "Entities"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "primaryKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Entity deleted (no content)"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          },
          "404": {
            "description": "Entity not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ODataError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication with FileMaker database credentials"
      },
      "fmidAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Claris ID token. Format: 'FMID {fmid-token}'"
      }
    },
    "schemas": {
      "ServiceDocument": {
        "type": "object",
        "properties": {
          "@odata.context": {
            "type": "string"
          },
          "value": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                },
                "kind": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "EntitySetResponse": {
        "type": "object",
        "properties": {
          "@odata.context": {
            "type": "string"
          },
          "@odata.count": {
            "type": "integer"
          },
          "value": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "ODataError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    },
    {
      "fmidAuth": []
    }
  ]
}
