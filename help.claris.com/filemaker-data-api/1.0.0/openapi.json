                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/databases/{database}/layouts/{layout}/_find": {
      "post": {
        "operationId": "performFind",
        "summary": "Perform a find request",
        "description": "Perform a find request to search for records matching specified criteria.",
        "tags": [
          "Find"
        ],
        "parameters": [
          {
            "name": "database",
