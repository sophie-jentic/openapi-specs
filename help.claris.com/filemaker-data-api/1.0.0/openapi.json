{
  "openapi": "3.0.3",
  "info": {
    "title": "Claris FileMaker Data API",
    "version": "1.0.0",
    "description": "The FileMaker Data API allows web services to access databases hosted by FileMaker Server or FileMaker Cloud. It supports authentication, record CRUD operations, find requests, script execution, container data upload, and metadata retrieval. All responses are in JSON format.",
    "x-jentic-source-url": "https://help.claris.com/en/data-api-guide/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{host}/fmi/data/vLatest",
      "description": "FileMaker Data API (latest version)",
      "variables": {
        "host": {
          "default": "your-server.example.com",
          "description": "FileMaker Server hostname"
        }
      }
    },
    {
      "url": "https://{host}/fmi/data/v1",
      "description": "FileMaker Data API v1",
      "variables": {
        "host": {
          "default": "your-server.example.com"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Database session authentication"
    },
    {
      "name": "Records",
      "description": "Record CRUD operations"
    },
    {
      "name": "Find",
      "description": "Find/search operations"
    },
    {
      "name": "Globals",
      "description": "Global field operations"
    },
    {
      "name": "Metadata",
      "description": "Database and layout metadata"
    },
    {
      "name": "Containers",
      "description": "Container field operations"
    },
    {
      "name": "Scripts",
      "description": "Script execution"
    }
  ],
  "paths": {
    "/databases/{database}/sessions": {
      "post": {
        "operationId": "loginDatabase",
        "summary": "Log in to a database session",
        "description": "Authenticate to a hosted database and receive a session token. Uses HTTP Basic authentication or Claris ID token (FMID).",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Database name"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fmDataSource": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "database": {
                          "type": "string"
                        },
                        "username": {
                          "type": "string"
                        },
                        "password": {
                          "type": "string"
                        }
                      }
                    },
                    "description": "External data source credentials"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created, token returned in response header and body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    },
    "/databases/{database}/sessions/{sessionToken}": {
      "delete": {
        "operationId": "logoutDatabase",
        "summary": "Log out of a database session",
        "description": "Close the database session and invalidate the session token.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sessionToken",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Session token to invalidate"
          }
        ],
        "responses": {
          "200": {
            "description": "Session closed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/databases/{database}/layouts/{layout}/records": {
      "get": {
        "operationId": "getRecords",
        "summary": "Get a range of records",
        "description": "Retrieve a range of records from a layout.",
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "layout",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Layout name"
          },
          {
            "name": "_offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Starting record number"
          },
          {
            "name": "_limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            },
            "description": "Maximum number of records to return"
          },
          {
            "name": "_sort",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "JSON array of sort fields"
          },
          {
            "name": "portal",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "JSON array of portal names to include"
          },
          {
            "name": "script",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Script to run after the request"
          },
          {
            "name": "script.param",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Script parameter"
          },
          {
            "name": "script.prerequest",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Script to run before the request"
          },
          {
            "name": "script.presort",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Script to run before sorting"
          }
        ],
        "responses": {
          "200": {
            "description": "List of records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createRecord",
        "summary": "Create a record",
        "description": "Create a new record on a layout.",
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "layout",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRecordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateRecordResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/databases/{database}/layouts/{layout}/records/{recordId}": {
