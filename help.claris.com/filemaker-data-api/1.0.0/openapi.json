    "/databases/{database}/globals": {
      "patch": {
        "operationId": "setGlobalFields",
        "summary": "Set global field values",
        "description": "Set global field values for the current session.",
        "tags": [
          "Globals"
        ],
        "parameters": [
          {
            "name": "database",
            "in": "path",
