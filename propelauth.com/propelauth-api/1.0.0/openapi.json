{
  "openapi": "3.1.0",
  "info": {
    "title": "PropelAuth API",
    "description": "PropelAuth is a B2B authentication service. The backend API provides endpoints for managing users, organizations, API keys, and access tokens. Supports user creation, fetching, updating, role management, organization management, and magic link generation.",
    "version": "1.0.0",
    "contact": {
      "name": "PropelAuth",
      "url": "https://www.propelauth.com"
    },
    "x-jentic-source-url": "https://docs.propelauth.com/reference"
  },
  "servers": [
    {
      "url": "https://{auth_url}",
      "description": "PropelAuth backend API",
      "variables": {
        "auth_url": {
          "default": "auth.yourdomain.com",
          "description": "Your PropelAuth auth URL from the dashboard"
        }
      }
    }
  ],
  "security": [
    {
      "bearerApiKey": []
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "User management"
    },
    {
      "name": "Organizations",
      "description": "Organization management"
    },
    {
      "name": "Magic Links",
      "description": "Magic link generation"
    },
    {
      "name": "API Keys",
      "description": "API key management"
    },
    {
      "name": "Access Tokens",
      "description": "Access token validation"
    }
  ],
  "paths": {
    "/api/backend/v1/user/{user_id}": {
      "get": {
        "operationId": "fetchUser",
        "summary": "Fetch user by ID",
        "description": "Fetches a user by their user ID.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "include_orgs",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Include organizations the user belongs to"
          }
        ],
        "responses": {
          "200": {
            "description": "User found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateUser",
        "summary": "Update user",
        "description": "Updates a user's metadata or properties.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "metadata": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "properties": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "picture_url": {
                    "type": "string"
                  },
                  "update_password_required": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete user",
        "description": "Deletes a user permanently.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
