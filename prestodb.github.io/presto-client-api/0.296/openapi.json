{
  "openapi": "3.0.3",
  "info": {
    "title": "Presto Client API",
    "version": "0.296",
    "description": "Presto distributed SQL query engine client REST API. Allows submitting SQL queries via POST to /v1/statement, polling for results via GET on nextUri, and managing query lifecycle. Supports session management via X-Presto-* headers, binary result format, and cross-cluster retry.",
    "x-jentic-source-url": "https://prestodb.github.io/docs/current/develop/client-protocol.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/v1/statement": {
      "post": {
        "operationId": "submitQuery",
        "summary": "Submit a SQL query",
        "description": "Submits a SQL query for execution. The query SQL is sent as the POST body (plain text). Returns a QueryResults JSON document. If nextUri is present in the response, the client should poll it for more results.",
        "tags": [
          "Statement"
        ],
        "parameters": [
          {
            "name": "X-Presto-User",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Session user name"
          },
          {
            "name": "X-Presto-Source",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Name of the software submitting the query"
          },
          {
            "name": "X-Presto-Catalog",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Default catalog for the query"
          },
          {
            "name": "X-Presto-Schema",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Default schema for the query"
          },
          {
            "name": "X-Presto-Time-Zone",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Timezone for query execution"
          },
          {
            "name": "X-Presto-Language",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Language for formatting results"
          },
          {
            "name": "X-Presto-Trace-Token",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Trace token for log correlation"
          },
          {
            "name": "X-Presto-Session",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of name=value session properties"
          },
          {
            "name": "X-Presto-Role",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Catalog role for the session"
          },
          {
            "name": "X-Presto-Prepared-Statement",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of name=key prepared statement mappings"
          },
          {
            "name": "X-Presto-Transaction-Id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Transaction ID for transactional queries"
          },
          {
            "name": "X-Presto-Client-Info",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Arbitrary client program information"
          },
          {
            "name": "X-Presto-Client-Tags",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of tags for resource group identification"
          },
          {
            "name": "X-Presto-Resource-Estimate",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of resource=value estimates (EXECUTION_TIME, CPU_TIME, PEAK_MEMORY, PEAK_TASK_MEMORY)"
          },
          {
            "name": "X-Presto-Extra-Credential",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Extra credentials for the connector (name=value)"
          },
          {
            "name": "binaryResults",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "When true, return results in binary SerializedPage format (base64 encoded)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "text/plain": {
              "schema": {
                "type": "string",
                "description": "SQL query string"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResults"
                }
              }
            },
            "headers": {
              "X-Presto-Set-Catalog": {
                "schema": {
                  "type": "string"
                },
                "description": "Instructs client to set the catalog for subsequent requests"
              },
              "X-Presto-Set-Schema": {
                "schema": {
                  "type": "string"
                },
                "description": "Instructs client to set the schema for subsequent requests"
              },
              "X-Presto-Set-Session": {
                "schema": {
                  "type": "string"
                },
                "description": "Session property name=value to add"
              },
              "X-Presto-Clear-Session": {
                "schema": {
                  "type": "string"
                },
                "description": "Session property name to remove"
              },
              "X-Presto-Set-Role": {
                "schema": {
                  "type": "string"
                },
                "description": "Catalog role to set"
              },
              "X-Presto-Added-Prepare": {
                "schema": {
                  "type": "string"
                },
                "description": "Prepared statement name=key to add"
              },
              "X-Presto-Deallocated-Prepare": {
                "schema": {
                  "type": "string"
                },
                "description": "Prepared statement name to remove"
              },
              "X-Presto-Started-Transaction-Id": {
                "schema": {
                  "type": "string"
                },
                "description": "Transaction ID for subsequent requests"
              },
              "X-Presto-Clear-Transaction-Id": {
                "schema": {
                  "type": "string"
                },
                "description": "Instructs client to clear transaction ID"
              }
            }
          },
          "400": {
            "description": "Bad request - invalid query syntax",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Server busy - client should retry in 50-100ms"
          }
        }
      }
    },
    "/v1/query/{queryId}": {
      "get": {
        "operationId": "getQueryInfo",
        "summary": "Get query information",
        "description": "Returns detailed information about a query including its state, stats, and query plan.",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "queryId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Query ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Query information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryInfo"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "cancelQuery",
        "summary": "Cancel a running query",
        "description": "Cancels a running query by query ID.",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "queryId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Query ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Query cancelled"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/query": {
      "get": {
        "operationId": "listQueries",
        "summary": "List all queries",
        "description": "Returns information about all currently known queries on the server.",
        "tags": [
          "Query"
        ],
        "responses": {
          "200": {
            "description": "List of queries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/QueryInfo"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/info": {
      "get": {
        "operationId": "getServerInfo",
        "summary": "Get server information",
        "description": "Returns Presto server information including version, environment, and uptime.",
        "tags": [
          "Server"
        ],
        "responses": {
          "200": {
            "description": "Server info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerInfo"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/info/state": {
      "get": {
        "operationId": "getServerState",
        "summary": "Get server state",
        "description": "Returns the current state of the server (ACTIVE, INACTIVE, SHUTTING_DOWN).",
        "tags": [
          "Server"
        ],
        "responses": {
          "200": {
            "description": "Server state",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "enum": [
                    "ACTIVE",
                    "INACTIVE",
                    "SHUTTING_DOWN"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/cluster": {
      "get": {
        "operationId": "getClusterInfo",
        "summary": "Get cluster information",
        "description": "Returns information about all nodes in the Presto cluster.",
        "tags": [
          "Cluster"
        ],
        "responses": {
          "200": {
            "description": "Cluster node information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NodeInfo"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/node": {
      "get": {
        "operationId": "listNodes",
        "summary": "List worker nodes",
        "description": "Returns information about active worker nodes in the cluster.",
        "tags": [
          "Cluster"
        ],
        "responses": {
          "200": {
            "description": "List of nodes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NodeInfo"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/node/failed": {
      "get": {
        "operationId": "listFailedNodes",
        "summary": "List failed worker nodes",
        "description": "Returns information about recently failed worker nodes.",
        "tags": [
          "Cluster"
        ],
        "responses": {
          "200": {
            "description": "List of failed nodes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NodeInfo"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/task/{taskId}": {
      "get": {
        "operationId": "getTaskInfo",
        "summary": "Get task information",
        "description": "Returns detailed information about a specific task.",
        "tags": [
          "Task"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Task ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Task information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "cancelTask",
        "summary": "Cancel a task",
        "description": "Cancels a running task.",
        "tags": [
          "Task"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Task ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Task cancelled"
          },
          "400": {
            "description": "Bad request",
