                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QueryResults": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Query ID"
          },
          "infoUri": {
            "type": "string",
            "format": "uri",
            "description": "URI for query info"
          },
          "nextUri": {
            "type": "string",
            "format": "uri",
            "description": "URI for next batch of results. If absent, query is complete."
          },
          "columns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Column"
            },
            "description": "Column names and types"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {}
            },
            "description": "Result rows as arrays of values"
          },
          "binaryData": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Base64-encoded binary result pages (when binaryResults=true)"
          },
          "stats": {
            "$ref": "#/components/schemas/StatementStats"
          },
          "error": {
            "$ref": "#/components/schemas/QueryError"
          },
          "warnings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PrestoWarning"
            }
          },
          "updateType": {
            "type": "string",
            "description": "Human-readable operation type (e.g., CREATE TABLE, SET SESSION)"
          }
        }
      },
      "Column": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Column name"
          },
          "type": {
            "type": "string",
            "description": "Column type (e.g., varchar, bigint, boolean)"
          },
          "typeSignature": {
            "type": "object",
            "description": "Detailed type signature"
          }
        }
      },
      "QueryError": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "errorCode": {
            "type": "integer",
            "description": "Error code"
          },
          "errorName": {
            "type": "string",
            "description": "Error name"
          },
          "errorType": {
            "type": "string",
            "description": "Error type (USER_ERROR, INTERNAL_ERROR, INSUFFICIENT_RESOURCES, EXTERNAL)"
          },
          "failureInfo": {
            "type": "object",
            "description": "Detailed failure information including stack trace"
          }
        }
      },
      "StatementStats": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "description": "Query state (QUEUED, PLANNING, STARTING, RUNNING, FINISHED, FAILED)"
          },
          "queued": {
            "type": "boolean"
          },
          "scheduled": {
            "type": "boolean"
          },
          "nodes": {
            "type": "integer",
            "description": "Number of nodes"
          },
          "totalSplits": {
            "type": "integer"
          },
          "queuedSplits": {
            "type": "integer"
          },
          "runningSplits": {
            "type": "integer"
          },
          "completedSplits": {
            "type": "integer"
          },
          "cpuTimeMillis": {
            "type": "integer"
          },
          "wallTimeMillis": {
            "type": "integer"
          },
          "processedRows": {
            "type": "integer"
          },
          "processedBytes": {
            "type": "integer"
          },
          "peakMemoryBytes": {
            "type": "integer"
          },
          "rootStage": {
            "type": "object",
            "description": "Root stage statistics"
          }
        }
      },
      "PrestoWarning": {
        "type": "object",
        "properties": {
          "warningCode": {
            "type": "object",
            "properties": {
              "code": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "message": {
            "type": "string"
          }
        }
      },
      "QueryInfo": {
        "type": "object",
        "properties": {
          "queryId": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "QUEUED",
              "PLANNING",
              "STARTING",
              "RUNNING",
              "FINISHING",
              "FINISHED",
              "FAILED"
            ]
          },
          "self": {
            "type": "string",
            "format": "uri"
          },
          "query": {
            "type": "string",
            "description": "SQL query text"
          },
          "queryStats": {
            "type": "object"
          },
          "errorCode": {
            "type": "object"
          },
          "warnings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PrestoWarning"
            }
          }
        }
      },
      "ServerInfo": {
        "type": "object",
        "properties": {
          "nodeVersion": {
            "type": "object",
            "properties": {
              "version": {
                "type": "string"
              }
            }
          },
          "environment": {
            "type": "string"
          },
          "coordinator": {
            "type": "boolean"
          },
          "starting": {
            "type": "boolean"
          },
          "uptime": {
            "type": "string"
          }
        }
      },
      "NodeInfo": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "recentRequests": {
            "type": "number"
          },
          "recentFailures": {
            "type": "number"
          },
          "recentSuccesses": {
            "type": "number"
          },
          "lastRequestTime": {
            "type": "string",
            "format": "date-time"
          },
          "lastResponseTime": {
            "type": "string",
            "format": "date-time"
          },
          "age": {
            "type": "string"
          },
          "recentFailureRatio": {
            "type": "number"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "errorCode": {
            "type": "integer"
          },
          "errorName": {
            "type": "string"
          },
          "errorType": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "prestoUser": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Presto-User",
        "description": "Presto user identity header. Required for all requests."
      }
    }
  },
  "security": [
    {
      "prestoUser": []
    }
  ],
  "tags": [
    {
      "name": "Cluster"
    },
    {
      "name": "Query"
    },
    {
      "name": "Server"
    },
    {
      "name": "Statement"
    },
    {
      "name": "Task"
    }
  ]
}
