{
  "openapi": "3.0.3",
  "info": {
    "title": "Ubidots IoT Platform API",
    "description": "Ubidots IoT platform API for managing devices, variables, data, organizations, events, and more. Empowers hardware and software developers to build innovative IoT applications.",
    "version": "1.6",
    "contact": {
      "url": "https://ubidots.com"
    }
  },
  "servers": [
    {
      "url": "https://industrial.api.ubidots.com/api/v1.6",
      "description": "Industrial API server"
    }
  ],
  "tags": [
    {
      "name": "Devices",
      "description": "Device management operations"
    },
    {
      "name": "Variables",
      "description": "Variable management operations"
    },
    {
      "name": "Data",
      "description": "Data operations (send, retrieve, aggregate)"
    },
    {
      "name": "Organizations",
      "description": "Organization management"
    },
    {
      "name": "Events",
      "description": "Event and alert management"
    },
    {
      "name": "Auth",
      "description": "Authentication and token management"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/devices": {
      "get": {
        "operationId": "listDevices",
        "summary": "List All Devices",
        "description": "Retrieves a paginated list of all devices.",
        "tags": [
          "Devices"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination"
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            },
            "description": "Number of results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Devices list returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedDeviceList"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createDevice",
        "summary": "Create Device",
        "description": "Create a new device.",
        "tags": [
          "Devices"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Device created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Device"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/devices/{device_label}": {
      "get": {
        "operationId": "getDevice",
        "summary": "Get Device",
        "description": "Retrieve a specific device by its label.",
        "tags": [
          "Devices"
        ],
        "parameters": [
          {
            "name": "device_label",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The device label"
          }
        ],
        "responses": {
          "200": {
            "description": "Device returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Device"
                }
              }
            }
          },
          "404": {
            "description": "Device not found"
          }
        }
      },
      "post": {
        "operationId": "sendDataToDevice",
        "summary": "Send Data to Device",
        "description": "Send data points to a device. The request body should contain variable names as keys and their values.",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "device_label",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The device label"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": {
                  "oneOf": [
                    {
                      "type": "number"
                    },
                    {
                      "$ref": "#/components/schemas/DataPoint"
                    }
                  ]
                },
                "example": {
                  "temperature": 23.5,
                  "humidity": 60
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data sent successfully"
          },
          "400": {
            "description": "Invalid data format"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      },
      "patch": {
        "operationId": "updateDeviceFields",
        "summary": "Update Device Fields",
        "description": "Update specific fields of a device.",
        "tags": [
          "Devices"
        ],
        "parameters": [
          {
            "name": "device_label",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Device updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Device"
                }
              }
            }
          },
          "404": {
            "description": "Device not found"
          }
        }
      },
      "put": {
        "operationId": "replaceDevice",
        "summary": "Replace Device",
        "description": "Replace all fields of a device.",
        "tags": [
          "Devices"
        ],
        "parameters": [
          {
            "name": "device_label",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Device replaced",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Device"
                }
              }
            }
          },
          "404": {
            "description": "Device not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteDevice",
        "summary": "Delete Device",
        "description": "Delete a specific device.",
        "tags": [
          "Devices"
        ],
        "parameters": [
          {
            "name": "device_label",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Device deleted"
          },
          "404": {
            "description": "Device not found"
          }
        }
      }
    },
