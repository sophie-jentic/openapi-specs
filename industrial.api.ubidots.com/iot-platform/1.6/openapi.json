        ],
        "responses": {
          "200": {
            "description": "Data returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DataPoint"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Device or variable not found"
          }
        }
