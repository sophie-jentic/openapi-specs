{
  "openapi": "3.0.3",
  "info": {
    "title": "WAVE Web Accessibility Evaluation API",
    "version": "1.0.0",
    "description": "Automated web accessibility analysis API using the WAVE processing engine.",
    "x-jentic-source-url": "https://wave.webaim.org/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://wave.webaim.org"
    }
  ],
  "paths": {
    "/api/request": {
      "get": {
        "operationId": "analyzeAccessibility",
        "summary": "Analyze page accessibility",
        "description": "Performs automated accessibility analysis of a web page",
        "tags": [
          "Analysis"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key"
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "URL of the page to analyze"
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml"
              ],
              "default": "json"
            },
            "description": "Response format"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessibilityReport"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccessibilityReport": {
        "type": "object",
        "properties": {
          "status": {
            "type": "object",
            "properties": {
              "success": {
                "type": "boolean"
              },
              "httpstatuscode": {
                "type": "integer"
              }
            }
          },
          "statistics": {
            "type": "object",
            "properties": {
              "pagetitle": {
                "type": "string"
              },
              "pageurl": {
                "type": "string"
              },
              "allitemcount": {
                "type": "integer"
              },
              "totalelements": {
                "type": "integer"
              }
            }
          },
          "categories": {
            "type": "object",
            "properties": {
              "error": {
                "type": "object",
                "properties": {
                  "count": {
                    "type": "integer"
                  },
                  "items": {
                    "type": "object"
                  }
                }
              },
              "alert": {
                "type": "object",
                "properties": {
                  "count": {
                    "type": "integer"
                  },
                  "items": {
                    "type": "object"
                  }
                }
              },
              "feature": {
                "type": "object",
                "properties": {
                  "count": {
                    "type": "integer"
                  }
                }
              },
              "structure": {
                "type": "object",
                "properties": {
                  "count": {
                    "type": "integer"
                  }
                }
              },
              "contrast": {
                "type": "object",
                "properties": {
                  "count": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Analysis"
    }
  ]
}
