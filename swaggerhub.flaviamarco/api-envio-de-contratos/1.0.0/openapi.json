{
  "openapi": "3.0.0",
  "info": {
    "title": "API Envio de Contratos",
    "description": "Esta API \u00e9 respons\u00e1vel pela gest\u00e3o do envio de contratos para o Cadbenef Online. Ela \u00e9 mantida pela equipe de TI da Unimed Brasil.\n# Observa\u00e7\u00f5es Importantes\n- Esta API \u00e9 de uso exclusivo das Unimeds Singulares.\n- O funcionamento dos recursos desta API somente ocorrer\u00e1 mediante o envio do access token gerado previamente com o uso de `CLIENT_ID` e `CLIENT_SECRET`.\n- Todos os campos de data e data/hora seguem o padr\u00e3o ISO-8601.\n- Todos os campos do tipo boolean podem ser enviados como `true` ou `false`, ou tamb\u00e9m como `1` ou `0`. `true` e `1` significam \"Verdadeiro\", enquanto `false` e `0` significam \"Falso\".\n",
    "version": "1.0.0",
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0"
    },
    "contact": {
      "name": "Unimed Brasil",
      "email": "api@unimedbrasil.coop.br",
      "url": "http://unimed.coop.br"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/FLAVIAMARCO/api-envio_de_contratos/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://gateway-sandbox.unimed.coop.br/cadbenef-online/v1",
      "description": "Sandbox"
    },
    {
      "url": "https://ua-gateway-hml.unimed.coop.br/cadbenef-online/v1",
      "description": "HML (mTLS)"
    },
    {
      "url": "https://gateway-hml2.unimed.coop.br/cadbenef-online/v1",
      "description": "HML2"
    },
    {
      "url": "https://ua-gateway.unimed.coop.br/cadbenef-online/v1",
      "description": "Produ\u00e7\u00e3o (mTLS)"
    }
  ],
  "paths": {
    "/contratos": {
      "post": {
        "tags": [
          "Contratos"
        ],
        "description": "Envio de informa\u00e7\u00e3o de novos contratos para posteriormente vinculo com benefici\u00e1rios quando n\u00e3o utilizado fluxo de prospec\u00e7\u00e3o de vendas.",
        "operationId": "postContratos",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "body": {
                    "$ref": "#/components/schemas/ContratosRequest"
                  },
                  "arquivoAcordo": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "body": {
                  "contentType": "application/json"
                },
                "arquivoAcordo": {
                  "contentType": "application/pdf"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Benefici\u00e1rio cadastrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContratosResponse"
                }
              }
            }
          },
          "400": {
            "description": "Erro - A requisi\u00e7\u00e3o foi malformada, omitindo atributos necess\u00e1rios, seja no payload ou atrav\u00e9s de atributos no header ou na URL.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContratosResponse"
                },
                "example": {
                  "cabecalho": {
                    "codigoControleTransacao": 12345678901234567000,
                    "codigoVersaoPTU": "001",
                    "codigoUnimedDestino": 865,
                    "dataGeracao": "2023-04-02T09:06:05-03:00"
                  },
                  "statusProcessamento": [
                    {
                      "status": "E",
                      "codigoMensagem": "400.001",
                      "descricaoMensagem": "O campo dadosAcordo.indicadorAcordo \u00e9 obrigat\u00f3rio."
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Erro - Cabe\u00e7alho de autentica\u00e7\u00e3o ausente/inv\u00e1lido ou token inv\u00e1lido."
          },
          "405": {
            "description": "Erro - O consumidor tentou acessar o recurso com um m\u00e9todo que n\u00e3o existe."
          },
          "422": {
            "description": "Erro - Erro de neg\u00f3cio.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContratosResponse"
                },
                "example": {
                  "cabecalho": {
                    "codigoControleTransacao": 12345678901234567000,
                    "codigoVersaoPTU": "001",
                    "codigoUnimedDestino": 865,
                    "dataGeracao": "2023-04-02T09:06:05-03:00"
                  },
                  "statusProcessamento": [
                    {
                      "status": "E",
                      "codigoMensagem": "422.004",
                      "descricaoMensagem": "C\u00f3digo Unimed inv\u00e1lido no campo codigoUnimedOrigem."
                    }
                  ]
                }
              }
            }
          },
          "429": {
            "description": "Erro - A opera\u00e7\u00e3o foi recusada, por exceder o limite de chamadas feitas dentro de um determinado per\u00edodo ou o limite de requisi\u00e7\u00f5es concorrentes foi atingido."
          },
          "500": {
            "description": "Erro - Erro do servidor, ccorreu um erro no gateway da API ou no microsservi\u00e7o."
          },
          "504": {
            "description": "Erro - A requisi\u00e7\u00e3o n\u00e3o foi atendida dentro do tempo limite estabelecido, gateway timeout."
          }
        },
        "security": [
          {
            "OAuth2": []
          }
        ]
      }
    },
    "/contratos/{protocoloContrato}": {
      "put": {
        "tags": [
          "Contratos"
        ],
        "description": "Indica o encerramento do envio de benefici\u00e1rios para o contrato.",
        "operationId": "putContratos",
        "parameters": [
          {
            "name": "protocoloContrato",
            "in": "path",
            "required": true,
            "description": "N\u00famero do protocolo gerado no recebimento da mensagem de inclus\u00e3o da empresa",
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0,
              "maximum": 99999999999999999999
            },
            "example": 12345678901234567890
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContratosRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Benefici\u00e1rio cadastrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContratosResponse"
                }
              }
            }
          },
          "400": {
            "description": "Erro - A requisi\u00e7\u00e3o foi malformada, omitindo atributos necess\u00e1rios, seja no payload ou atrav\u00e9s de atributos no header ou na URL.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContratosResponse"
                },
                "example": {
                  "cabecalho": {
                    "codigoControleTransacao": 12345678901234567000,
                    "codigoVersaoPTU": "001",
                    "codigoUnimedDestino": 865,
                    "dataGeracao": "2023-04-02T09:06:05-03:00"
                  },
                  "statusProcessamento": [
                    {
                      "status": "E",
                      "codigoMensagem": "400.001",
                      "descricaoMensagem": "O campo dadosAcordo.indicadorAcordo \u00e9 obrigat\u00f3rio."
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Erro - Cabe\u00e7alho de autentica\u00e7\u00e3o ausente/inv\u00e1lido ou token inv\u00e1lido."
          },
          "405": {
            "description": "Erro - O consumidor tentou acessar o recurso com um m\u00e9todo que n\u00e3o existe."
          },
          "422": {
            "description": "Erro - Erro de neg\u00f3cio.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContratosResponse"
                },
                "example": {
                  "cabecalho": {
                    "codigoControleTransacao": 12345678901234567000,
                    "codigoVersaoPTU": "001",
                    "codigoUnimedDestino": 865,
                    "dataGeracao": "2023-04-02T09:06:05-03:00"
                  },
                  "statusProcessamento": [
                    {
                      "status": "E",
                      "codigoMensagem": "422.004",
                      "descricaoMensagem": "C\u00f3digo Unimed inv\u00e1lido no campo codigoUnimedOrigem."
                    }
                  ]
                }
              }
            }
          },
          "429": {
            "description": "Erro - A opera\u00e7\u00e3o foi recusada, por exceder o limite de chamadas feitas dentro de um determinado per\u00edodo ou o limite de requisi\u00e7\u00f5es concorrentes foi atingido."
          },
          "500": {
            "description": "Erro - Erro do servidor, ccorreu um erro no gateway da API ou no microsservi\u00e7o."
          },
          "504": {
            "description": "Erro - A requisi\u00e7\u00e3o n\u00e3o foi atendida dentro do tempo limite estabelecido, gateway timeout."
          }
        },
        "security": [
          {
            "OAuth2": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "/oauth/v1/access-token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "ContratosRequest": {
        "type": "object",
        "required": [
          "cabecalho",
          "dadosEmpresaContratante",
          "dadosAcordo"
        ],
        "properties": {
          "cabecalho": {
            "type": "object",
            "required": [
              "codigoControleTransacao",
              "codigoVersaoPTU",
              "codigoUnimedOrigem",
              "dataGeracao"
            ],
            "properties": {
              "codigoControleTransacao": {
                "type": "integer",
                "description": "C\u00f3digo de transa\u00e7\u00e3o do PTU",
                "format": "int64",
                "minimum": 0,
                "maximum": 99999999999999999999,
                "example": 12345678901234567890
              },
              "codigoVersaoPTU": {
                "type": "string",
                "description": "C\u00f3digo da Vers\u00e3o do PTU trafegando",
                "minimum": 0,
                "maximum": 999,
                "example": "001"
              },
              "codigoUnimedOrigem": {
                "type": "integer",
                "description": "C\u00f3digo da Unimed origem da mensagem",
                "format": "int32",
                "minimum": 1,
                "maximum": 9999,
                "example": 865
              },
              "dataGeracao": {
                "type": "string",
                "description": "Data de gera\u00e7\u00e3o da mensagem",
                "format": "date-time",
                "example": "2023-04-02T09:06:05-03:00"
              }
            }
          },
          "dadosEmpresaContratante": {
            "type": "object",
            "required": [
              "tipoEmpresa",
              "nomeEmpresa",
              "quantidadeBeneficiariosInicial",
              "indicadorProcesso"
            ],
            "properties": {
              "tipoEmpresa": {
                "type": "object",
                "properties": {
                  "cnpj": {
                    "type": "string",
                    "description": "C\u00f3digo do CNPJ",
                    "maxLength": 14,
                    "example": "12345678901234"
                  },
                  "caepf": {
                    "type": "string",
                    "description": "C\u00f3digo do CAEPF (Cadastro de Atividade Economica Pessoa F\u00edsica)",
                    "maxLength": 14,
                    "example": "12345678901234"
                  }
                }
              },
              "cnpjEmpresaMatriz": {
                "type": "string",
                "description": "C\u00f3digo do CNPJ da Empresa Matriz",
                "maxLength": 14,
                "example": "12345678901234"
              },
              "nomeEmpresa": {
                "type": "string",
                "description": "Nome completo da Empresa (Raz\u00e3o Social)",
                "minLength": 3,
                "maxLength": 40,
                "example": "Lorem ipsum aliquet eget litorv avsvsrnm"
              },
              "quantidadeBeneficiariosInicial": {
                "type": "integer",
                "description": "Quantidade de benefici\u00e1rios que ser\u00e3o inclu\u00eddos na massa inicial da empresa",
                "format": "int32",
                "minLength": 1,
                "maxLength": 99999,
                "example": 10
              },
              "indicadorProcesso": {
                "type": "integer",
                "description": "Indica o cadastro de nova empresa OU encerramento do envio de benefici\u00e1rios para valida\u00e7\u00e3o da ND13 0 = Abertura / cadastro da empresa 1 \u2013 Encerramento do envio dos benefici\u00e1rios do contrato.",
                "format": "int32",
                "minimum": 0,
                "maximum": 1,
                "enum": [
                  0,
                  1
                ],
                "example": 0
              }
            }
          },
          "dadosAcordo": {
            "required": [
              "indicadorAcordo"
            ],
            "type": "object",
            "properties": {
              "indicadorAcordo": {
                "type": "boolean",
                "description": "Indicador de acordo sobre a comercializa\u00e7\u00e3o de planos entre as Unimeds. Quando \u201cTrue\u201d, a Unimed possui acordo de comercializa\u00e7\u00e3o de plano com outra Unimed e ir\u00e1 passar a um fluxo de aprova\u00e7\u00e3o de acordos.",
                "example": true
              }
            }
          }
        }
      },
      "ContratosResponse": {
        "type": "object",
        "required": [
          "cabecalho",
          "statusProcessamento"
        ],
        "properties": {
          "cabecalho": {
            "type": "object",
            "required": [
              "codigoControleTransacao",
              "codigoVersaoPTU",
              "codigoUnimedDestino",
              "dataGeracao"
            ],
            "properties": {
              "codigoControleTransacao": {
                "type": "integer",
                "description": "C\u00f3digo de transa\u00e7\u00e3o do PTU",
                "format": "int64",
                "minimum": 0,
                "maximum": 99999999999999999999,
                "example": 12345678901234567890
              },
              "codigoVersaoPTU": {
                "type": "string",
                "description": "C\u00f3digo da Vers\u00e3o do PTU trafegando",
                "minimum": 0,
                "maximum": 999,
                "example": "001"
              },
              "codigoUnimedDestino": {
                "type": "integer",
                "description": "C\u00f3digo da Unimed destino da mensagem",
                "format": "int32",
                "minimum": 1,
                "maximum": 9999,
                "example": 865
              },
              "dataGeracao": {
                "type": "string",
                "description": "Data de gera\u00e7\u00e3o da mensagem",
                "format": "date-time",
                "example": "2023-04-02T09:06:05-03:00"
              }
            }
          },
          "protocoloContrato": {
            "type": "integer",
            "description": "N\u00famero do protocolo gerado no recebimento da mensagem de inclus\u00e3o da empresa",
            "format": "int64",
            "minimum": 0,
            "maximum": 99999999999999999999,
            "example": 12345678901234567890
          },
          "statusProcessamento": {
            "type": "array",
            "items": {
              "required": [
                "status",
                "codigoMensagem",
                "descricaoMensagem"
              ],
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "S"
                },
                "codigoMensagem": {
                  "type": "string",
                  "example": "200.004"
                },
                "descricaoMensagem": {
                  "type": "string",
                  "example": "Contrato cadastrado com sucesso"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Contratos"
    }
  ]
}
