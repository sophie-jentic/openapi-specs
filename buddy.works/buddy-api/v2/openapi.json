  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Workspaces",
      "description": "Manage workspaces."
    },
    {
      "name": "Projects",
      "description": "Manage projects within workspaces."
    },
    {
      "name": "Pipelines",
      "description": "Manage CI/CD pipelines."
