  "components": {
    "schemas": {
      "Workspace": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "html_url": {
            "type": "string"
          },
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "owner_id": {
            "type": "integer"
          },
          "frozen": {
            "type": "boolean"
          },
          "create_date": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "html_url": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "CLOSED"
            ]
          },
          "create_date": {
            "type": "string",
            "format": "date-time"
          },
          "created_by": {
            "$ref": "#/components/schemas/Member"
          },
          "http_repository": {
            "type": "string"
          },
          "ssh_repository": {
            "type": "string"
          }
        }
      },
      "CreateProjectRequest": {
        "type": "object",
        "properties": {
          "display_name": {
            "type": "string",
            "description": "Display name of the project."
          },
          "integration": {
            "type": "object",
            "description": "Integration configuration.",
            "properties": {
              "hash_id": {
                "type": "string",
                "description": "Integration identifier."
              }
            }
          },
          "external_project_id": {
            "type": "string",
            "description": "External project identifier (repo path)."
          }
        },
        "required": [
          "display_name"
        ]
      },
      "Pipeline": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "html_url": {
            "type": "string"
          },
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "on": {
            "type": "string",
            "description": "Trigger mode.",
            "enum": [
              "CLICK",
              "EVENT",
              "SCHEDULE"
            ]
          },
          "last_execution_status": {
            "type": "string",
            "enum": [
              "SUCCESSFUL",
              "FAILED",
              "TERMINATED",
              "INPROGRESS",
              "ENQUEUED",
              "SKIPPED",
              "NOT_EXECUTED",
              "INITIAL"
            ]
          },
          "last_execution_revision": {
            "type": "string"
          },
          "create_date": {
            "type": "string",
            "format": "date-time"
          },
          "priority": {
            "type": "string",
            "enum": [
              "LOW",
              "NORMAL",
              "HIGH"
            ]
          },
          "refs": {
            "type": "array",
            "description": "Git refs this pipeline operates on.",
            "items": {
              "type": "string"
            }
          },
          "disabled": {
            "type": "boolean"
          },
          "disabling_reason": {
            "type": "string"
          },
          "project": {
            "$ref": "#/components/schemas/Project"
          },
          "creator": {
            "$ref": "#/components/schemas/Member"
          }
        }
      },
      "CreatePipelineRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Pipeline name."
          },
          "on": {
            "type": "string",
            "description": "Trigger mode.",
            "enum": [
              "CLICK",
              "EVENT",
              "SCHEDULE"
            ]
          },
          "refs": {
            "type": "array",
            "description": "Git refs this pipeline operates on.",
            "items": {
              "type": "string"
            }
          },
          "always_from_scratch": {
            "type": "boolean"
          },
          "auto_clear_cache": {
            "type": "boolean"
          },
          "no_skip_to_most_recent": {
            "type": "boolean"
          },
