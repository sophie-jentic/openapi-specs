  "components": {
    "securitySchemes": {
      "basic": {
        "type": "http",
        "scheme": "basic"
      },
      "api-key": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "CollectionDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "handle": {
            "type": "string"
          },
          "bodyHtml": {
            "type": "string"
          },
          "externalId": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "feedId": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "feedId"
        ]
      },
      "ProductDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "originalPrice": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "isForSale": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "title",
          "type",
          "id"
        ]
      },
      "UpsertCollectionDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "bodyHtml": {
            "type": "string"
          },
          "handle": {
            "type": "string"
          },
          "externalId": {
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        },
        "required": [
          "title"
        ]
      },
      "UpsertProductDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "bodyHtml": {
            "type": "string"
          },
          "handle": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        }
      },
      "CreateFeedContactDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
