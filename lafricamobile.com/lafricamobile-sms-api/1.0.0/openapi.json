{
  "openapi": "3.0.3",
  "info": {
    "title": "LAfricaMobile SMS API",
    "version": "1.0.0",
    "description": "LAfricaMobile provides SMS messaging services for Africa. The API allows sending SMS messages and checking credit balance.",
    "x-jentic-source-url": "https://developers.lafricamobile.com/docs/sms",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.lafricamobile.com"
    }
  ],
  "paths": {
    "/api": {
      "get": {
        "operationId": "sendSmsGet",
        "summary": "Send SMS via GET",
        "tags": [
          "SMS"
        ],
        "parameters": [
          {
            "name": "xml",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "XML content containing SMS data"
          }
        ],
        "responses": {
          "200": {
            "description": "SMS sent",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Send SMS via GET"
      },
      "post": {
        "operationId": "sendSmsPost",
        "summary": "Send SMS via POST",
        "tags": [
          "SMS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "type": "string"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SmsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS sent"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Send SMS via POST"
      }
    },
    "/credits": {
      "get": {
        "operationId": "checkCredits",
        "summary": "Check credit balance",
        "tags": [
          "Credits"
        ],
        "parameters": [
          {
            "name": "xml",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "XML with credentials"
          }
        ],
        "responses": {
          "200": {
            "description": "Credit balance",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Check credit balance"
      }
    }
  },
  "components": {
    "schemas": {
      "SmsRequest": {
        "type": "object",
        "required": [
          "accountid",
          "password",
          "to",
          "text"
        ],
        "properties": {
          "accountid": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "from": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Credits"
    },
    {
      "name": "SMS"
    }
  ]
}
