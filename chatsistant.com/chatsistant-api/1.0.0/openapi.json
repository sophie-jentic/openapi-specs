{
  "openapi": "3.0.3",
  "info": {
    "title": "Chatsistant API",
    "version": "1.0.0",
    "description": "Chatsistant API allows you to manage chatbots, sessions, messages, agents, and data sources for AI-powered chatbot applications.",
    "x-jentic-source-url": "https://docs.chatsistant.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://app.chatsistant.com/api/v1",
      "description": "Chatsistant API Server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Chatbots",
      "description": "Manage chatbots"
    },
    {
      "name": "Sessions",
      "description": "Manage chat sessions"
    },
    {
      "name": "Messages",
      "description": "Send messages to chat sessions"
    },
    {
      "name": "Agents",
      "description": "Manage chatbot agents"
    },
    {
      "name": "Data Sources",
      "description": "Manage chatbot data sources"
    }
  ],
  "paths": {
    "/chatbot/create": {
      "post": {
        "operationId": "createChatbot",
        "summary": "Create chatbot",
        "description": "Create a chatbot that belongs to the authenticated user.",
        "tags": [
          "Chatbots"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateChatbotRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chatbot created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Chatbot"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chatbots": {
      "get": {
        "operationId": "listChatbots",
        "summary": "Fetch all chatbots",
        "description": "Fetch the list of chatbots for the current user.",
        "tags": [
          "Chatbots"
        ],
        "responses": {
          "200": {
            "description": "List of chatbots",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Chatbot"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chatbot/{uuid}": {
      "get": {
        "operationId": "getChatbot",
        "summary": "Fetch a chatbot",
        "description": "Fetch a single chatbot by its UUID.",
        "tags": [
          "Chatbots"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Chatbot UUID"
          }
        ],
        "responses": {
          "200": {
            "description": "Chatbot details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Chatbot"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chatbot/{uuid}/update": {
      "post": {
        "operationId": "updateChatbot",
        "summary": "Update chatbot",
        "description": "Update chatbot metadata by chatbot UUID.",
        "tags": [
          "Chatbots"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Chatbot UUID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateChatbotRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chatbot updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Chatbot"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chatbot/{uuid}/delete": {
      "delete": {
        "operationId": "deleteChatbot",
        "summary": "Delete chatbot",
        "description": "Delete a single chatbot by its UUID.",
        "tags": [
          "Chatbots"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Chatbot UUID"
          }
        ],
        "responses": {
          "200": {
            "description": "Chatbot deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chatbot/{uuid}/session/create": {
      "post": {
        "operationId": "createSession",
        "summary": "Create session",
        "description": "Create a chat session for a chatbot specified by chatbot UUID.",
        "tags": [
          "Sessions"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Chatbot UUID"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Session"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/session/{uuid}/message/stream": {
      "post": {
        "operationId": "createMessage",
        "summary": "Create message (streaming)",
        "description": "Create a session message for a chatbot session specified by session UUID. Uses streaming to transmit data as a continuous string over the connection.",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Session UUID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Streaming chat response",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string",
                  "description": "Streaming response text"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chatbot/{uuid}/agent/create": {
      "post": {
        "operationId": "createAgent",
        "summary": "Create agent",
        "description": "Create an agent for a chatbot specified by chatbot UUID.",
        "tags": [
          "Agents"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Chatbot UUID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAgentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chatbot/{uuid}/data-source/upload": {
      "post": {
        "operationId": "uploadDataSource",
        "summary": "Upload a file data source",
        "description": "Upload a file as a data source for a chatbot specified by chatbot UUID.",
        "tags": [
          "Data Sources"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Chatbot UUID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UploadDataSourceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data source uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataSource"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    },
    "schemas": {
      "CreateChatbotRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the chatbot"
          },
          "visibility": {
            "type": "string",
            "description": "Visibility setting (e.g., private)"
          },
          "rate_limit": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 2,
            "maxItems": 2,
            "description": "Rate limit as [max_messages, time_window_seconds]"
          },
          "rate_limit_message": {
            "type": "string",
            "description": "Message shown when rate limit is exceeded"
          },
          "show_citations": {
            "type": "boolean",
            "description": "Whether to show citations in responses"
          }
        }
      },
      "UpdateChatbotRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the chatbot"
          },
          "visibility": {
            "type": "string",
            "description": "Visibility setting"
          },
          "rate_limit": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 2,
            "maxItems": 2,
            "description": "Rate limit as [max_messages, time_window_seconds]"
          },
          "rate_limit_message": {
            "type": "string",
            "description": "Message shown when rate limit is exceeded"
          },
          "show_citations": {
            "type": "boolean",
            "description": "Whether to show citations in responses"
          }
        }
      },
      "Chatbot": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "Unique identifier for the chatbot"
          },
          "name": {
            "type": "string",
            "description": "Name of the chatbot"
          },
          "created_at": {
            "type": "string",
            "description": "Creation timestamp"
          },
          "modified_at": {
            "type": "string",
            "description": "Last modification timestamp"
          },
          "meta": {
            "$ref": "#/components/schemas/ChatbotMeta"
          }
        }
      },
      "ChatbotMeta": {
        "type": "object",
        "properties": {
          "rate_limit": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "Rate limit as [max_messages, time_window_seconds]"
          },
          "rate_limit_message": {
            "type": "string",
            "description": "Message shown when rate limit is exceeded"
          },
          "show_citations": {
            "type": "boolean",
            "description": "Whether citations are shown"
          },
          "visibility": {
            "type": "string",
            "description": "Visibility setting"
          }
        }
      },
      "CreateSessionRequest": {
        "type": "object",
        "properties": {
          "initial_variables": {
            "type": "object",
            "additionalProperties": true,
            "description": "Flat object with initial data to store and reuse later"
          }
        }
      },
      "Session": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "Unique identifier for the session"
          },
          "created_at": {
            "type": "string",
            "description": "Creation timestamp"
          },
          "modified_at": {
            "type": "string",
            "description": "Last modification timestamp"
          },
          "initial_variables": {
            "type": "object",
            "additionalProperties": true,
            "description": "Initial variables passed during session creation"
          }
        }
      },
      "CreateMessageRequest": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "The user's query message"
          }
        }
      },
      "CreateAgentRequest": {
        "type": "object",
        "required": [
          "name",
          "type"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the agent"
          },
          "type": {
            "type": "string",
            "enum": [
              "user-facing",
              "background",
              "human-escalation",
              "pre-canned",
              "spam-defense"
            ],
            "description": "Type of agent"
          },
          "description": {
            "type": "string",
            "description": "Description of the agent"
          },
          "prompt": {
            "type": "string",
            "description": "The agent's system prompt"
          },
          "temperature": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "maximum": 1,
            "description": "Temperature for response generation (user-facing agents only)"
          },
          "meta": {
            "type": "object",
            "properties": {
              "model": {
                "type": "string",
                "description": "The AI model to use (e.g., gpt-4o-mini-4k, gpt-4o-8k)"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Tags for the agent (background agents only)"
              },
              "temperature": {
                "type": "number",
                "format": "float",
                "description": "Temperature setting"
              }
            }
          },
          "bias": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "maximum": 1,
            "description": "Agent bias (for user-facing, human-escalation, pre-canned, spam-defense agents)"
          },
          "stickness": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "maximum": 1,
            "description": "Agent stickiness (for user-facing, human-escalation, pre-canned, spam-defense agents)"
          },
          "default_message": {
            "type": "string",
            "description": "Default message (for pre-canned and spam-defense agents)"
          },
          "use_all_sources": {
            "type": "boolean",
            "description": "Whether to use all data sources (user-facing agents only)"
          }
        }
      },
      "Agent": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "Unique identifier for the agent"
          },
          "name": {
            "type": "string",
            "description": "Name of the agent"
          },
          "type": {
            "type": "string",
            "description": "Type of agent"
          },
          "description": {
            "type": "string",
            "description": "Description of the agent"
          },
          "prompt": {
            "type": "string",
            "description": "Agent system prompt"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether the agent is enabled (default: false for new agents)"
          },
          "created_at": {
            "type": "string",
            "description": "Creation timestamp"
          },
          "modified_at": {
            "type": "string",
            "description": "Last modification timestamp"
          },
          "meta": {
            "type": "object",
            "properties": {
              "model": {
                "type": "string"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "temperature": {
                "type": "number",
                "format": "float"
              }
            }
          },
          "data_source_uuids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of data source UUIDs"
          },
          "variables": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Agent variables"
          }
        }
      },
      "UploadDataSourceRequest": {
        "type": "object",
        "required": [
          "file"
        ],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "File to upload as a data source"
          },
          "reference_source_link": {
            "type": "string",
            "description": "Optional reference source link for the file"
          }
        }
      },
      "DataSource": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "Unique identifier for the data source"
          },
          "file_name": {
            "type": "string",
            "description": "Name of the uploaded file"
          },
          "file_size": {
            "type": "number",
            "description": "Size of the uploaded file in bytes"
          },
          "title": {
            "type": "string",
            "description": "Title of the data source"
          },
          "type": {
            "type": "string",
            "description": "Type of data source"
          },
          "status": {
            "type": "string",
            "description": "Processing status"
          },
          "tokens": {
            "type": "number",
            "description": "Number of tokens in the data source"
          },
          "meta_json": {
            "type": "string",
            "description": "Additional metadata as JSON string"
          },
          "created_at": {
            "type": "string",
            "description": "Creation timestamp"
          },
          "modified_at": {
            "type": "string",
            "description": "Last modification timestamp"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the operation was successful"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "message": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      }
    }
  }
}
