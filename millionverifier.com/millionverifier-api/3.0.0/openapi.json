{
  "openapi": "3.0.3",
  "info": {
    "title": "MillionVerifier API",
    "version": "3.0.0",
    "description": "MillionVerifier Real-Time Email Verification API. Verify email addresses in real time to check if they are deliverable, risky, disposable, or part of a catch-all domain.",
    "x-jentic-source-url": "https://github.com/hubuco/millionverifier-real-time-api-v3",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.millionverifier.com/api/v3"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "verifyEmail",
        "summary": "Verify a single email address",
        "description": "Check if an email is deliverable, risky, disposable, or part of a catch-all domain",
        "tags": [
          "Verification"
        ],
        "parameters": [
          {
            "name": "api",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your API key"
          },
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Email address to verify"
          },
          {
            "name": "timeout",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 2,
              "maximum": 60,
              "default": 20
            },
            "description": "Connection timeout in seconds"
          }
        ],
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerificationResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/credits": {
      "get": {
        "operationId": "checkCredits",
        "summary": "Check remaining credits",
        "tags": [
          "Account"
        ],
        "parameters": [
          {
            "name": "api",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your API key"
          }
        ],
        "responses": {
          "200": {
            "description": "Credits balance",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreditsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Check remaining credits"
      }
    }
  },
  "components": {
    "schemas": {
      "VerificationResult": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "quality": {
            "type": "string"
          },
          "result": {
            "type": "string"
          },
          "resultcode": {
            "type": "integer",
            "description": "1=ok, 2=catch_all, 3=unknown, 4=error, 5=disposable, 6=invalid"
          },
          "subresult": {
            "type": "string"
          },
          "free": {
            "type": "boolean"
          },
          "role": {
            "type": "boolean"
          },
          "credits": {
            "type": "integer"
          }
        }
      },
      "CreditsResponse": {
        "type": "object",
        "properties": {
          "credits": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api",
        "description": "API key passed as query parameter"
      }
    }
  },
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    {
      "name": "Account"
    },
    {
      "name": "Verification"
    }
  ]
}
