    "/api/vehicles": {
      "get": {
        "summary": "checks if there is any vehicles in system which matched vin code or chassis number",
        "operationId": "getVehicleBorderCross",
        "description": "check if there is any vehicles which crossed border matched to vin code or chassis number",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "securityKey",
            "description": "unique key by which we will validate third party user through their respective service  side",
            "required": true,
            "type": "string"
          },
          {
            "in": "query",
            "name": "vinChassisNumber",
            "description": "pass an optional vin code or chassis number to service to check whether vehicle has crossed border",
            "required": false,
            "type": "string"
          },
          {
            "in": "query",
            "name": "vehicleRegistratioNumber",
            "description": "pass vehicle vehicle registration number to service to check whether vehicle has crossed border",
            "required": false,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "there is one or more matches",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/VehicleInfo"
              }
            }
          },
          "404": {
            "description": "nothing found"
          }
        },
        "tags": [
          "api"
        ]
      }
    }
  },
