  "paths": {
    "/api/policies": {
      "get": {
        "summary": "returns policies",
        "operationId": "getPolicies",
        "description": "by default returns policies registered today",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "sessionKey",
            "description": "unique key by which we will validate third party user through their respective service  side",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "policies",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Policy"
              }
            }
          },
          "400": {
            "description": "The server cannot or will not process the request due to an apparent client error"
          }
        },
        "tags": [
          "api"
        ]
      },
      "post": {
        "summary": "registers policy to GIA system",
        "operationId": "registerPolicy",
        "description": "Adds an item to the system",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "sessionKey",
            "description": "unique key by which we will validate third party user through their respective service  side",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "policyRegistration",
            "description": "Policy registration",
            "schema": {
              "$ref": "#/definitions/Policy"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "policy created"
          },
          "400": {
            "description": "invalid input, object invalid",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "tags": [
          "api"
        ]
      }
    },
