{
  "swagger": "2.0",
  "info": {
    "description": "Police Border Cross Api",
    "version": "1.0.0",
    "title": "Police Border Cross Api",
    "contact": {
      "email": "nika.nikabadze@asseco.ge"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/AssecoGeorgia/BorderPoliceSecurity/1.0.0/swagger.json"
  },
  "paths": {
    "/api/bordercross": {
      "get": {
        "summary": "searches border cross recrods",
        "operationId": "getBorderCross",
        "description": "By passing in the appropriate options, you can search for\nvehicle border cross\n",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "requestId",
            "description": "pass an required parameter, by which we can afterwards identify transaction on submitters side",
            "required": true,
            "type": "string",
            "format": "uuid"
          },
          {
            "in": "query",
            "name": "securityKey",
            "description": "unique key by which we will validate border police user through their respective service  side",
            "required": true,
            "type": "string"
          },
          {
            "in": "query",
            "name": "vinChassisNumber",
            "description": "pass an optional vin code or chassis number to service to check whether vehicle has active policy",
            "required": false,
            "type": "string"
          },
          {
            "in": "query",
            "name": "vehicleRegistratioNumber",
            "description": "pass vehicle vehicle registration number to service to check whether vehicle has active policy",
            "required": false,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "search results matching criteria",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/BorderCrossInfo"
              }
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        },
        "tags": [
          "api"
        ]
      }
    }
  },
  "definitions": {
    "BorderCrossInfo": {
      "type": "object",
      "required": [
        "vin",
        "chassisNumber",
        "borderId"
      ],
      "properties": {
        "borderId": {
          "type": "integer",
          "example": 1
        },
        "crossTypeId": {
          "type": "integer",
          "example": 1
        },
        "vin": {
          "type": "string",
          "example": "4T1BK46K87U548149"
        },
        "chassisNumber": {
          "type": "string"
        },
        "owner": {
          "type": "string",
          "example": "NAME LASTNAME"
        },
        "ownerDocumentNumber": {
          "type": "string",
          "example": "TEST1234"
        },
        "ownerCitizenship": {
          "type": "string",
          "example": "TURKEY"
        },
        "category": {
          "type": "string",
          "example": "SEDAN"
        },
        "categoryId": {
          "type": "integer",
          "example": 2
        },
        "vehicleManufacturer": {
          "type": "string",
          "example": "Mercedes-Benz"
        },
        "vehicleManufacturerId": {
          "type": "integer",
          "example": 5
        },
        "vehicleModel": {
          "type": "string",
          "example": "ML320"
        },
        "vehicleModelId": {
          "type": "integer",
          "example": 6
        },
        "borderCrossDate": {
          "type": "string",
          "format": "date-time",
          "example": "2017-01-06T13:45:30"
        }
      }
    }
  },
  "host": "virtserver.swaggerhub.com",
  "basePath": "/AssecoGeorgia/BorderPoliceSecurity/1.0.0",
  "schemes": [
    "https"
  ],
  "tags": [
    {
      "name": "api"
    }
  ]
}
