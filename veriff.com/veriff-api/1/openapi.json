{
  "openapi": "3.0.3",
  "info": {
    "title": "Veriff Public API",
    "version": "1.0.0",
    "description": "Veriff's Identity Verification API allows you to create verification sessions, upload end-user media, and retrieve verification decisions. Use this API when you wish to implement your own front-end or collect media yourself without using Veriff's native SDKs.",
    "x-jentic-source-url": "https://devdocs.veriff.com/apidocs",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{base-url}/v1",
      "description": "Veriff API. Find your Base URL from the Integrations page in Veriff Customer Portal.",
      "variables": {
        "base-url": {
          "default": "veriff.me.api",
          "description": "Your Veriff API base URL from the Customer Portal."
        }
      }
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Sessions",
      "description": "Create and manage verification sessions."
    },
    {
      "name": "Media",
      "description": "Upload and retrieve media for verification sessions."
    },
    {
      "name": "Decisions",
      "description": "Retrieve verification decisions and extracted data."
    },
    {
      "name": "Feedback",
      "description": "Submit and retrieve fraud reports."
    },
    {
      "name": "Registries",
      "description": "Mexican registry verification endpoints."
    }
  ],
  "paths": {
    "/sessions": {
      "post": {
        "summary": "Create a verification session",
        "operationId": "createSession",
        "description": "Creates a new verification session. Returns a session ID and URL needed for further steps.",
        "tags": [
          "Sessions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateSessionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid input.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key or HMAC signature."
          }
        }
      }
    },
    "/sessions/{sessionId}": {
      "parameters": [
        {
          "name": "sessionId",
          "in": "path",
          "required": true,
          "description": "The ID of the verification session.",
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "patch": {
        "summary": "Update a verification session",
        "operationId": "updateSession",
        "description": "Update the session status to 'submitted' to begin the verification process. All required media must be uploaded before calling this endpoint.",
        "tags": [
          "Sessions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSessionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found - Session does not exist."
          }
        }
      },
      "delete": {
        "summary": "Delete a verification session",
        "operationId": "deleteSession",
        "description": "Delete a verification session. Useful for testing. Not available by default.",
        "tags": [
          "Sessions"
        ],
        "responses": {
          "200": {
            "description": "Session deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/sessions/validate-registry": {
      "post": {
        "summary": "Create session and validate national ID",
        "operationId": "createSessionValidateRegistry",
        "description": "Create a session and validate the person's national ID number (SSN) with provided data.",
        "tags": [
          "Sessions",
          "Registries"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ValidateRegistryRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session created and registry validated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateRegistryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/sessions/{sessionId}/media": {
      "parameters": [
        {
          "name": "sessionId",
          "in": "path",
          "required": true,
          "description": "The ID of the verification session.",
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "summary": "Upload media for a session",
        "operationId": "uploadSessionMedia",
        "description": "Upload images (document, selfie) and PDFs for a verification session. Upload all required images one by one using this endpoint.",
        "tags": [
          "Media"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UploadMediaRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Media uploaded successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadMediaResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found - Session does not exist."
          }
        }
      },
      "get": {
        "summary": "Query session media",
        "operationId": "getSessionMedia",
        "description": "Query information about all media uploaded during a verification session.",
        "tags": [
          "Media"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionMediaList"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/sessions/{sessionId}/collected-data": {
      "parameters": [
        {
          "name": "sessionId",
          "in": "path",
          "required": true,
          "description": "The ID of the verification session.",
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "summary": "Upload collected data",
        "operationId": "uploadCollectedData",
        "description": "Upload additional end-user data for improved fraud detection. Highly recommended but not mandatory.",
        "tags": [
          "Sessions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CollectedDataRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data uploaded successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/sessions/{sessionId}/decision": {
      "parameters": [
        {
          "name": "sessionId",
          "in": "path",
          "required": true,
          "description": "The ID of the verification session.",
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "summary": "Get verification decision",
        "operationId": "getSessionDecision",
        "description": "Retrieve verification session decision data and extracted information.",
        "tags": [
          "Decisions"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DecisionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/sessions/{sessionId}/person": {
      "parameters": [
        {
          "name": "sessionId",
          "in": "path",
          "required": true,
          "description": "The ID of the verification session.",
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "summary": "Get person data",
        "operationId": "getSessionPerson",
        "description": "Get data about the person verified in the session.",
        "tags": [
          "Decisions"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersonResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/sessions/{sessionId}/attempts": {
      "parameters": [
        {
          "name": "sessionId",
          "in": "path",
          "required": true,
          "description": "The ID of the verification session.",
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "summary": "Get session attempts",
        "operationId": "getSessionAttempts",
        "description": "Get IDs of different verification attempts within one session.",
        "tags": [
          "Sessions"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttemptsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/media/{mediaId}": {
      "parameters": [
        {
          "name": "mediaId",
          "in": "path",
          "required": true,
          "description": "The ID of the media file.",
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Get media by ID",
        "operationId": "getMedia",
        "description": "Retrieve a specific media file using media ID.",
        "tags": [
          "Media"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/feedback/fraud-reports": {
      "post": {
        "summary": "Submit fraud reports",
        "operationId": "submitFraudReport",
        "description": "Submit one or more fraud reports about sessions for evaluation and processing.",
        "tags": [
          "Feedback"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FraudReportRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fraud report submitted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FraudReportResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/feedback/fraud-categories": {
      "get": {
        "summary": "Get fraud categories",
        "operationId": "getFraudCategories",
        "description": "Get a list of available fraud categories that can be reported.",
        "tags": [
          "Feedback"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FraudCategoriesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-auth-client",
        "description": "Your integration's API key from the Veriff Customer Portal."
      },
      "HmacAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-hmac-signature",
        "description": "HMAC-SHA256 hex encoded keyed hash using your shared secret key."
      }
    },
    "schemas": {
      "CreateSessionRequest": {
        "type": "object",
        "required": [
          "verification"
        ],
        "properties": {
          "verification": {
            "type": "object",
            "properties": {
              "callback": {
                "type": "string",
                "description": "Callback URL for verification events."
              },
              "person": {
                "type": "object",
                "properties": {
                  "firstName": {
                    "type": "string"
                  },
                  "lastName": {
                    "type": "string"
                  },
                  "idNumber": {
                    "type": "string"
                  },
                  "dateOfBirth": {
                    "type": "string",
                    "format": "date"
                  }
                }
              },
              "document": {
                "type": "object",
                "properties": {
                  "number": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string"
                  },
                  "country": {
                    "type": "string"
                  }
                }
              },
              "lang": {
                "type": "string",
                "description": "Language code for the verification flow."
              },
              "features": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "CreateSessionResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "verification": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "url": {
                "type": "string"
              },
              "vendorData": {
                "type": "string"
              },
              "host": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "sessionToken": {
                "type": "string"
              }
            }
          }
        }
      },
      "UpdateSessionRequest": {
        "type": "object",
        "properties": {
          "verification": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "submitted"
                ]
              }
            }
          }
        }
      },
      "SessionStatusResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "verification": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "status": {
                "type": "string"
              }
            }
          }
        }
      },
      "ValidateRegistryRequest": {
        "type": "object",
        "properties": {
          "verification": {
            "type": "object",
            "properties": {
              "person": {
                "type": "object",
                "properties": {
                  "idNumber": {
                    "type": "string"
                  },
                  "firstName": {
                    "type": "string"
                  },
                  "lastName": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "ValidateRegistryResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "verification": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "registryResult": {
                "type": "string"
              }
            }
          }
        }
      },
      "UploadMediaRequest": {
        "type": "object",
        "properties": {
          "image": {
            "type": "string",
            "format": "binary",
            "description": "The image file to upload."
          },
          "context": {
            "type": "string",
            "description": "The context of the image (e.g., 'document-front', 'document-back', 'face')."
          },
          "timestamp": {
            "type": "string",
            "description": "ISO 8601 timestamp of when the image was captured."
          }
        }
      },
      "UploadMediaResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "image": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "size": {
                "type": "integer"
              },
              "mimeType": {
                "type": "string"
              }
            }
          }
        }
      },
      "SessionMediaList": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "CollectedDataRequest": {
        "type": "object",
        "properties": {
          "verification": {
            "type": "object",
            "properties": {
              "ipAddress": {
                "type": "string"
              },
              "device": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "model": {
                    "type": "string"
                  },
                  "os": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "DecisionResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "verification": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "code": {
                "type": "integer"
              },
              "reason": {
                "type": "string"
              },
              "reasonCode": {
                "type": "integer"
              },
              "acceptanceTime": {
                "type": "string"
              },
              "person": {
                "type": "object",
                "properties": {
                  "firstName": {
                    "type": "string"
                  },
                  "lastName": {
                    "type": "string"
                  },
                  "idNumber": {
                    "type": "string"
                  },
                  "dateOfBirth": {
                    "type": "string"
                  },
                  "nationality": {
                    "type": "string"
                  },
                  "gender": {
                    "type": "string"
                  }
                }
              },
              "document": {
                "type": "object",
                "properties": {
                  "number": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string"
                  },
                  "country": {
                    "type": "string"
                  },
                  "validUntil": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "PersonResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "person": {
            "type": "object",
            "properties": {
              "firstName": {
                "type": "string"
              },
              "lastName": {
                "type": "string"
              },
              "idNumber": {
                "type": "string"
              },
              "dateOfBirth": {
                "type": "string"
              }
            }
          }
        }
      },
      "AttemptsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "attempts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "FraudReportRequest": {
        "type": "object",
        "properties": {
          "reports": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "sessionId": {
                  "type": "string"
                },
                "category": {
                  "type": "string"
                },
                "comment": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "FraudReportResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
