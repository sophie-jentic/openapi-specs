{
  "openapi": "3.0.0",
  "servers": [
    {
      "description": "APIHub API Auto Mocking court-hearing-judges",
      "url": "https://virtserver.swaggerhub.com/HMCTS-DTS/api-cp-refdata-courthearing-judges/0.3.10"
    }
  ],
  "info": {
    "title": "Common Platform API Refdata Court Hearing Judges",
    "description": "Reference Data API providing information on Judges associated with a Court Hearing",
    "version": "0.3.10",
    "contact": {
      "email": "no-reply@hmcts.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/HMCTS-DTS/api-cp-refdata-courthearing-judges/0.3.10/swagger.json"
  },
  "paths": {
    "/judges/{judge_id}": {
      "get": {
        "description": "Retrieve details of a judge by judge ID.",
        "operationId": "getJudgeById",
        "tags": [
          "Judges"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "judge_id",
            "required": true,
            "description": "Unique reference number for the court house",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "judge details found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Judges"
                }
              }
            }
          },
          "400": {
            "description": "bad input parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Judges": {
        "type": "object",
        "properties": {
          "judiciary": {
            "type": "object",
            "description": "Can be an array of objects as such will be a collective and use plurals for object arrays (clerks and scribes etc included)",
            "properties": {
              "johTitle": {
                "type": "string",
                "description": "The title for the judiciary",
                "default": "",
                "example": "His Honour"
              },
              "johNameSurname": {
                "type": "string",
                "description": "First and Surname of the JOH",
                "pattern": "^.*$",
                "default": "",
                "example": "John Smith"
              },
              "role": {
                "type": "string",
                "description": "Role of the judiciary",
                "enum": [
                  "judge",
                  "magistrate",
                  "clerk"
                ],
                "example": "judge"
              },
              "johKnownAs": {
                "type": "string",
                "description": "Name and salutations, titles to be presented on publications",
                "pattern": "^.*$",
                "default": "",
                "example": "His Honour Judge Smith"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Machine-readable error code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "details": {
            "type": "object",
            "additionalProperties": true,
            "description": "Additional error context"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "traceId": {
            "type": "string",
            "description": "Unique identifier for error tracing"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Judges"
    }
  ]
}
