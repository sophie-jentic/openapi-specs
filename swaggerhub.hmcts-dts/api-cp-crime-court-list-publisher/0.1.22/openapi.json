{
  "openapi": "3.0.3",
  "servers": [
    {
      "description": "APIHub API Auto Mocking Scheduling and Listing court-schedule",
      "url": "https://virtserver.swaggerhub.com/HMCTS-DTS/api-cp-crime-court-list-publisher/0.1.22"
    }
  ],
  "info": {
    "title": "Common Platform API Crime Court List Publisher",
    "description": "API for court list publishing service",
    "version": "0.1.22",
    "contact": {
      "email": "no-reply@hmcts.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/HMCTS-DTS/api-cp-crime-court-list-publisher/0.1.22/swagger.json"
  },
  "paths": {
    "/api/court-list-publish/publish": {
      "post": {
        "summary": "Publish court list",
        "description": "Creates or updates a court list publish status",
        "operationId": "publishCourtList",
        "tags": [
          "court-list-publish"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/vnd.courtlistpublishing-service.publish.post+json": {
              "schema": {
                "$ref": "#/components/schemas/CourtListPublishRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully created or updated court list publish status",
            "content": {
              "application/vnd.courtlistpublishing-service.publish.post+json": {
                "schema": {
                  "$ref": "#/components/schemas/CourtListPublishResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CourtListPublishResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid request body or missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/court-list-publish/sjp/publishCourtList": {
      "post": {
        "summary": "Publish SJP court list to CaTH",
        "description": "SJP-specific endpoint. Accepts the full payload from SJP (Single Justice Procedure) and publishes the court list to Courts and Tribunals Hearings (CaTH).\nThe request body carries a large SJP payload (e.g. listType, language, requestType, listPayload with readyCases and metadata). The service transforms it to CaTH format and POSTs to Azure APIM, equivalent to the flow in PubHub.\nlistType (court list type) must be SJP_PUBLISH_LIST (SJP Pending cases public list) or SJP_PRESS_LIST (SJP Press transparency list).\n",
        "operationId": "publishSjpCourtList",
        "tags": [
          "court-list-publish"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PublishCourtListRequest"
              }
            },
            "application/vnd.courtlistpublishing-service.sjp.post+json": {
              "schema": {
                "$ref": "#/components/schemas/PublishCourtListRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SJP court list publish request accepted or completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublishCourtListResponse"
                }
              },
              "application/vnd.courtlistpublishing-service.sjp.post+json": {
                "schema": {
                  "$ref": "#/components/schemas/PublishCourtListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid or missing listType (or invalid SJP payload)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/court-list-publish/publish-status": {
      "get": {
        "summary": "Get court list publish statuses",
        "description": "Retrieves court list publish statuses. Can be queried by:\n- courtListId (UUID), OR\n- courtCentreId (required) and publishDate (required) with optional courtListType\n",
        "operationId": "findCourtListPublishStatus",
        "tags": [
          "court-list-publish"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "courtListId",
            "required": false,
            "description": "The UUID of the court list. If provided, other parameters are ignored.",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          {
            "in": "query",
            "name": "courtCentreId",
            "required": false,
            "description": "The UUID of the court centre. Required if courtListId is not provided.",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426614174001"
          },
          {
            "in": "query",
            "name": "publishDate",
            "required": false,
            "description": "The publish date in format 'YYYY-MM-DD'. Required if courtListId is not provided.",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "example": "2024-01-15"
          },
          {
            "in": "query",
            "name": "courtListType",
            "required": false,
            "description": "The type of court list. Optional when querying by courtCentreId and publishDate.",
            "schema": {
              "$ref": "#/components/schemas/CourtListType"
            },
            "example": "STANDARD"
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved court list publish statuses. Returns an empty array if no matching records are found.",
            "content": {
              "application/vnd.courtlistpublishing-service.publish.get+json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CourtListPublishResponse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters. Either courtListId must be provided, or both courtCentreId and publishDate must be provided.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/court-list-publish/publish-status-cleanup": {
      "get": {
        "summary": "Cleanup old publish status records and blob files",
        "description": "Deletes rows from the publish-status table (and associated PDF files in blob storage) where\n`last_updated` is older than the retention period. The retention period is configured via the\nenvironment variable `PUBLISH_STATUS_CLEANUP_DAYS` (default **90** days); records with\n`last_updated` on or before (now \u2212 N days) are removed.\n**System Users only** (not other publishing roles).\n",
        "operationId": "publishStatusCleanup",
        "tags": [
          "court-list-publish"
        ],
        "responses": {
          "200": {
            "description": "`success` is true if cleanup completed; false if a fatal error occurred (e.g. database failure).\n",
            "content": {
              "application/vnd.courtlistpublishing-service.publish-status-cleanup.get+json": {
                "schema": {
                  "$ref": "#/components/schemas/PublishStatusCleanupResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublishStatusCleanupResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden \u2014 caller is not a System User",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/court-list-publish/download": {
      "post": {
        "summary": "Download court list (e.g. PDF)",
        "description": "Returns the court list as a file (e.g. PDF) for the given court centre, court list type, and date range.\nUse courtListType to distinguish the kind of list (e.g. PUBLIC, ONLINE_PUBLIC, STANDARD). Data is fetched\nfrom the court list (listing) API and rendered via the document generator. Shared by multiple consumers;\nrequest type is distinguished by courtListType.\n",
        "operationId": "downloadCourtList",
        "tags": [
          "court-list-publish"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/vnd.courtlistpublishing-service.download.post+json": {
              "schema": {
                "$ref": "#/components/schemas/CourtListDownloadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully generated court list file (e.g. PDF)",
            "headers": {
              "Content-Disposition": {
                "description": "Attachment filename",
                "schema": {
                  "type": "string",
                  "example": "attachment; filename=\"CourtList.pdf\""
                }
              }
            },
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid request body or missing required fields (e.g. invalid UUID, invalid date format, endDate before startDate)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Bad gateway - court list data or document generation failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/files/download/{fileId}": {
      "get": {
        "summary": "Download file by ID",
        "description": "Downloads the full file named {fileId}.pdf from blob storage in a single shot and returns it as an array of bytes.\n",
        "operationId": "downloadFile",
        "tags": [
          "files"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "fileId",
            "required": true,
            "description": "The UUID of the file to download. The blob is stored as {fileId}.pdf",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426614174002"
          },
          {
            "in": "header",
            "name": "Accept",
            "required": true,
            "description": "Must be application/vnd.courtlistpublishing-service.files.download+json",
            "schema": {
              "type": "string",
              "enum": [
                "application/vnd.courtlistpublishing-service.files.download+json"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully downloaded the file. Response body is application/pdf.",
            "headers": {
              "Content-Disposition": {
                "description": "Attachment filename as {fileId}.pdf",
                "schema": {
                  "type": "string",
                  "example": "attachment; filename=\"123e4567-e89b-12d3-a456-426614174002.pdf\""
                }
              }
            },
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/vnd.courtlistpublishing-service.files.download+json": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "File not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SjpListType": {
        "description": "SJP list variant for the SJP publish endpoint (which SJP list to publish to CaTH).",
        "type": "string",
        "enum": [
          "SJP_PUBLISH_LIST",
          "SJP_PRESS_LIST"
        ],
        "example": "SJP_PUBLISH_LIST"
      },
      "PublishCourtListRequest": {
        "description": "Request to publish an SJP court list to CaTH. listType determines which list is published (SJP_PUBLISH_LIST for public/pending list or SJP_PRESS_LIST for press transparency list).",
        "type": "object",
        "required": [
          "listType"
        ],
        "properties": {
          "listType": {
            "$ref": "#/components/schemas/SjpListType"
          }
        }
      },
      "PublishCourtListResponse": {
        "description": "Response after accepting or completing an SJP court list publish request",
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Status of the publish request",
            "example": "ACCEPTED"
          },
          "listType": {
            "$ref": "#/components/schemas/SjpListType"
          },
          "message": {
            "type": "string",
            "description": "Optional human-readable message",
            "example": "SJP court list publish request accepted"
          }
        }
      },
      "PublishStatusCleanupResponse": {
        "description": "Result of publish-status cleanup (old rows and blob PDFs removed per retention policy)",
        "type": "object",
        "required": [
          "success"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "description": "True if cleanup completed successfully; false if a fatal error occurred"
          }
        }
      },
      "CourtListType": {
        "description": "The type of court list",
        "type": "string",
        "enum": [
          "ALPHABETICAL",
          "PUBLIC",
          "STANDARD",
          "BENCH",
          "JUDGE",
          "USHERS_CROWN",
          "USHERS_MAGISTRATE",
          "ONLINE_PUBLIC",
          "PRISON",
          "WARN",
          "DRAFT",
          "FINAL",
          "FIRM",
          "SJP"
        ],
        "example": "STANDARD"
      },
      "Status": {
        "description": "A generic status that can be used for various operations",
        "type": "string",
        "enum": [
          "REQUESTED",
          "SUCCESSFUL",
          "FAILED"
        ],
        "example": "REQUESTED"
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Machine-readable error code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "details": {
            "type": "object",
            "additionalProperties": true,
            "description": "Additional error context"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "traceId": {
            "type": "string",
            "description": "Unique identifier for error tracing"
          }
        }
      },
      "CourtListPublishRequest": {
        "description": "Request to publish a court list. The courtListId is generated internally by the backend, and publishStatus is set to COURT_LIST_REQUESTED.",
        "type": "object",
        "required": [
          "courtCentreId",
          "courtListType",
          "startDate",
          "endDate"
        ],
        "properties": {
          "courtCentreId": {
            "description": "The UUID of the court centre",
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174001"
          },
          "startDate": {
            "description": "Hearing start date in format 'YYYY-MM-DD'",
            "type": "string",
            "format": "date",
            "example": "2024-01-15"
          },
          "endDate": {
            "description": "Hearing end date in format 'YYYY-MM-DD'",
            "type": "string",
            "format": "date",
            "example": "2024-01-15"
          },
          "courtListType": {
            "$ref": "#/components/schemas/CourtListType"
          }
        }
      },
      "CourtListDownloadRequest": {
        "description": "Request to download a court list (e.g. as PDF). courtListType distinguishes the kind of list (PUBLIC, ONLINE_PUBLIC, STANDARD, etc.) so multiple consumers can use this endpoint without separate operations.",
        "type": "object",
        "required": [
          "courtCentreId",
          "courtListType",
          "startDate",
          "endDate"
        ],
        "properties": {
          "courtCentreId": {
            "description": "The UUID of the court centre",
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174001"
          },
          "startDate": {
            "description": "Hearing start date in format 'YYYY-MM-DD'",
            "type": "string",
            "format": "date",
            "example": "2024-01-15"
          },
          "endDate": {
            "description": "Hearing end date in format 'YYYY-MM-DD'. Must be on or after startDate.",
            "type": "string",
            "format": "date",
            "example": "2024-01-15"
          },
          "courtListType": {
            "$ref": "#/components/schemas/CourtListType"
          },
          "courtRoomId": {
            "description": "Reference data ID for the court room. Optional; needed for alphabetical label.",
            "type": "string",
            "format": "uuid",
            "example": "f8254db1-1683-483e-afb3-b87fde5a0a26"
          }
        }
      },
      "CourtListPublishResponse": {
        "description": "Response containing court list publish status information",
        "type": "object",
        "required": [
          "courtListId",
          "courtCentreId",
          "publishStatus",
          "courtListType"
        ],
        "properties": {
          "courtListId": {
            "description": "The UUID of the court list",
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "courtCentreId": {
            "description": "The UUID of the court centre",
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174001"
          },
          "publishStatus": {
            "$ref": "#/components/schemas/Status"
          },
          "fileStatus": {
            "$ref": "#/components/schemas/Status"
          },
          "courtListType": {
            "$ref": "#/components/schemas/CourtListType"
          },
          "lastUpdated": {
            "description": "The timestamp when the publish status was last updated",
            "type": "string",
            "format": "date-time",
            "example": "2024-01-15T10:30:00Z"
          },
          "fileUrl": {
            "description": "The name of the court list file or its URL",
            "type": "string",
            "example": "https://sastecourtlistpublisher.blob.core.windows.net/courtpublisher-blob-container/Online%20Public%20court%20list%20-%20Lavender%20Hill%20Magistrates'%20Court%2C%20All%20courtrooms%20-%2026-01-2026.pdf?st=2026-01-26T13:22:49Z&se=2026-12-31T21:37:49Z&moreParam=111"
          },
          "fileId": {
            "description": "The UUID of the court list file in blob storage or document store",
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174002"
          },
          "fileErrorMessage": {
            "description": "Error message if file upload failed",
            "type": "string",
            "example": "Failed to upload file"
          },
          "publishErrorMessage": {
            "description": "Error message if publishing failed",
            "type": "string",
            "example": "Failed to publish file"
          },
          "publishDate": {
            "description": "The date when the court list was published",
            "type": "string",
            "format": "date",
            "example": "2024-01-15"
          }
        }
      },
      "HearingDateEntry": {
        "description": "Court list data for a single hearing date",
        "type": "object",
        "properties": {
          "hearingDate": {
            "type": "string",
            "format": "date",
            "description": "The hearing date (YYYY-MM-DD)"
          },
          "hearingDateWelsh": {
            "type": "string",
            "description": "Welsh translation of the hearing date"
          },
          "courtRooms": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CourtRoomEntry"
            }
          }
        }
      },
      "CourtRoomEntry": {
        "description": "Court room with timeslots and hearings",
        "type": "object",
        "properties": {
          "courtRoomName": {
            "type": "string"
          },
          "welshCourtRoomName": {
            "type": "string"
          },
          "judiciaryNames": {
            "type": "string"
          },
          "welshJudiciaryNames": {
            "type": "string"
          },
          "timeslots": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Timeslot"
            }
          }
        }
      },
      "Timeslot": {
        "description": "A time slot containing one or more hearings",
        "type": "object",
        "properties": {
          "hearings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Hearing"
            }
          }
        }
      },
      "Hearing": {
        "description": "A single hearing within the court list",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "sequence": {
            "type": "integer"
          },
          "reportingRestrictionReason": {
            "type": "string"
          },
          "welshReportingRestrictionReason": {
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "description": "Time in HH:mm format"
          },
          "hearingType": {
            "type": "string"
          },
          "welshHearingType": {
            "type": "string"
          },
          "caseNumber": {
            "type": "string"
          },
          "caseId": {
            "type": "string",
            "format": "uuid"
          },
          "prosecutorType": {
            "type": "string"
          },
          "hearingPublicListNote": {
            "type": "string"
          },
          "defendants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Defendant"
            }
          },
          "adjournedHearingDate": {
            "type": "string"
          }
        }
      },
      "Defendant": {
        "description": "Defendant in a hearing",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "organisationName": {
            "type": "string"
          },
          "welshOrganisationName": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "surname": {
            "type": "string"
          },
          "welshSurname": {
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string"
          },
          "age": {
            "type": "string"
          },
          "nationality": {
            "type": "string"
          },
          "address": {
            "$ref": "#/components/schemas/CourtListAddress"
          },
          "reportingRestrictions": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "List of reporting restriction entries"
          },
          "offences": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Offence"
            }
          }
        }
      },
      "CourtListAddress": {
        "description": "Address used in court list data (defendant address etc.)",
        "type": "object",
        "properties": {
          "address1": {
            "type": "string"
          },
          "address2": {
            "type": "string"
          },
          "address3": {
