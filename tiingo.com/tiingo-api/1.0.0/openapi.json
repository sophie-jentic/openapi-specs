          "Crypto"
        ],
        "parameters": [
          {
            "name": "tickers",
            "in": "query",
            "description": "Comma-separated crypto tickers (e.g. btcusd,ethusd)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startDate",
            "in": "query",
            "description": "Start date (YYYY-MM-DD)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "description": "End date (YYYY-MM-DD)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "resampleFreq",
            "in": "query",
            "description": "Resample frequency",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Crypto price data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/iex/{ticker}/prices": {
      "get": {
        "operationId": "getIexPrices",
        "summary": "Get IEX intraday prices",
        "description": "Returns intraday price data from the IEX exchange.",
        "tags": [
          "IEX"
        ],
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
