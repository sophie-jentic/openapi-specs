{
  "openapi": "3.0.3",
  "info": {
    "title": "Fulcrum API",
    "description": "Fulcrum is a mobile data collection platform. The Fulcrum REST API allows you to programmatically create, read, update, and delete records, forms, and other objects in your Fulcrum account.",
    "version": "2.0.0",
    "contact": {
      "name": "Fulcrum",
      "url": "https://docs.fulcrumapp.com"
    },
    "x-jentic-source-url": "http://developer.fulcrumapp.com/api/intro/"
  },
