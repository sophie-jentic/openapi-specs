{
  "openapi": "3.0.3",
  "info": {
    "title": "CAMB.AI API",
    "version": "1.0.0",
    "description": "AI-powered audio and speech processing API for text-to-speech, dubbing, translation, transcription, story narration, voice generation, sound generation, and audio separation across 140+ languages.",
    "x-jentic-source-url": "https://docs.camb.ai/introduction",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://client.camb.ai/apis"
    }
  ],
  "paths": {
    "/tts-stream": {
      "post": {
        "operationId": "createTtsStream",
        "summary": "Text-to-Speech",
        "description": "Transform text into natural-sounding speech with customizable voice features",
        "tags": [
          "Speech"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TtsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audio stream in requested format",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/translated-tts": {
      "post": {
        "operationId": "createTranslatedTts",
        "summary": "Translated Text-to-Speech",
        "description": "Translate text and synthesize speech in one step across 140+ languages",
        "tags": [
          "Speech"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslatedTtsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/dub": {
      "post": {
        "operationId": "createDubbing",
        "summary": "End-to-End Dubbing",
        "description": "Localize content using AI that preserves emotional delivery across 140+ languages",
        "tags": [
          "Dubbing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DubbingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/translate": {
      "post": {
        "operationId": "createTranslation",
        "summary": "Translation",
        "description": "Cross-language translation support",
        "tags": [
          "Translation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transcribe": {
      "post": {
        "operationId": "createTranscription",
        "summary": "Transcription",
        "description": "Convert speech to text with speaker identification",
        "tags": [
          "Transcription"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/TranscriptionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/story": {
      "post": {
        "operationId": "createStory",
        "summary": "Create Story",
        "description": "Convert narratives into audiobooks",
        "tags": [
          "Stories"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/StoryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/translated-story/{run_id}": {
      "post": {
        "operationId": "createTranslatedStory",
        "summary": "Create Translated Story",
        "description": "Translate and convert narratives into audiobooks in 140+ languages",
        "tags": [
          "Stories"
        ],
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Unique identifier of the original story"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "target_language"
                ],
                "properties": {
                  "target_language": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 150
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/text-to-voice": {
      "post": {
        "operationId": "createTextToVoice",
        "summary": "Voice from Description",
        "description": "Create or clone voices from text description",
        "tags": [
          "Voices"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text",
                  "voice_description"
                ],
                "properties": {
                  "text": {
                    "type": "string"
                  },
                  "voice_description": {
                    "type": "string",
                    "minLength": 100
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/text-to-sound": {
      "post": {
        "operationId": "createTextToSound",
        "summary": "Sound and Music Generation",
        "description": "Generate audio from text descriptions",
        "tags": [
          "Audio"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextToSoundRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/audio-separation": {
      "post": {
        "operationId": "createAudioSeparation",
        "summary": "Audio Separation",
        "description": "Extract distinct audio components from mixed recordings",
        "tags": [
          "Audio"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "media_file"
                ],
                "properties": {
                  "media_file": {
                    "type": "string",
                    "format": "binary",
                    "description": "AAC, FLAC, MP3 or WAV file"
                  },
                  "project_name": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 255
                  },
                  "project_description": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 5000
                  },
                  "folder_id": {
                    "type": "integer",
                    "minimum": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TtsRequest": {
        "type": "object",
        "required": [
          "text",
          "language",
          "voice_id"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3000
          },
          "language": {
            "type": "string",
            "description": "BCP-47 locale"
          },
          "voice_id": {
            "type": "integer",
            "minimum": 1
          },
          "speech_model": {
            "type": "string",
            "enum": [
              "mars-pro",
              "mars-flash",
              "mars-instruct"
            ],
            "default": "mars-pro"
          },
          "user_instructions": {
            "type": "string",
            "maxLength": 1000
          },
          "enhance_named_entities_pronunciation": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "TranslatedTtsRequest": {
        "type": "object",
        "required": [
          "text",
          "source_language",
          "target_language"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "source_language": {
            "type": "integer"
          },
          "target_language": {
            "type": "integer"
          },
          "voice_id": {
            "type": "integer",
            "default": 147320
          },
          "age": {
            "type": "integer",
            "default": 28
          },
          "formality": {
            "type": "integer",
            "enum": [
              1,
              2
            ],
            "default": 2
          },
          "gender": {
            "type": "integer",
            "enum": [
              0,
              1,
              2,
              9
            ],
            "default": 1
          },
          "project_name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 255
          },
          "project_description": {
            "type": "string",
            "minLength": 3,
            "maxLength": 5000
          },
          "folder_id": {
            "type": "integer"
          },
          "chosen_dictionaries": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        }
      },
      "DubbingRequest": {
        "type": "object",
        "required": [
          "video_url",
          "source_language",
          "target_languages"
        ],
        "properties": {
          "video_url": {
            "type": "string"
          },
          "source_language": {
            "type": "integer"
          },
          "target_languages": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "project_name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 255
          },
          "project_description": {
            "type": "string",
            "minLength": 3,
            "maxLength": 5000
          },
          "folder_id": {
            "type": "integer"
          },
          "selected_audio_tracks": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "add_output_as_an_audio_track": {
            "type": "boolean"
          },
          "chosen_dictionaries": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "ai_optimization": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "TranslationRequest": {
        "type": "object",
        "required": [
          "source_language",
          "target_language",
          "texts"
        ],
        "properties": {
          "source_language": {
            "type": "integer"
          },
          "target_language": {
            "type": "integer"
          },
          "texts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "formality": {
            "type": "integer",
            "enum": [
              1,
              2
            ]
          },
          "gender": {
            "type": "integer",
            "enum": [
              0,
              1,
              2,
              9
            ]
          },
          "age": {
            "type": "integer"
          },
          "chosen_dictionaries": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "project_name": {
            "type": "string"
          },
          "project_description": {
            "type": "string"
          },
          "folder_id": {
            "type": "integer"
          }
        }
      },
      "TranscriptionRequest": {
        "type": "object",
        "required": [
          "language"
        ],
        "properties": {
          "language": {
            "type": "integer"
          },
          "media_file": {
            "type": "string",
            "format": "binary"
          },
          "media_url": {
            "type": "string"
          },
          "project_name": {
            "type": "string"
          },
          "project_description": {
            "type": "string"
          },
          "folder_id": {
            "type": "integer"
          }
        }
      },
      "StoryRequest": {
        "type": "object",
        "required": [
          "file",
          "source_language",
          "narrator_voice_id"
        ],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary"
          },
          "title": {
            "type": "string",
            "minLength": 3,
            "maxLength": 255
          },
          "description": {
            "type": "string",
            "minLength": 3,
            "maxLength": 5000
          },
          "source_language": {
            "type": "integer"
          },
          "narrator_voice_id": {
            "type": "integer"
          },
          "chosen_dictionaries": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "folder_id": {
            "type": "integer"
          }
        }
      },
      "TextToSoundRequest": {
        "type": "object",
        "required": [
          "prompt"
        ],
        "properties": {
          "prompt": {
            "type": "string"
          },
          "audio_type": {
            "type": "string",
            "enum": [
              "music",
              "sound"
            ],
            "default": "sound"
          },
          "duration": {
            "type": "number",
            "default": 8.0,
            "maximum": 10
          },
          "project_name": {
            "type": "string"
          },
          "project_description": {
            "type": "string"
          },
          "folder_id": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "TaskResponse": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "loc": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "msg": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Audio"
    },
    {
      "name": "Dubbing"
    },
    {
      "name": "Speech"
    },
    {
      "name": "Stories"
    },
    {
      "name": "Transcription"
    },
    {
      "name": "Translation"
    },
    {
      "name": "Voices"
    }
  ]
}
