{
  "openapi": "3.0.3",
  "info": {
    "title": "Pusher Channels HTTP API",
    "description": "REST API for triggering events and querying channel information in Pusher Channels",
    "version": "1.0.0",
    "x-jentic-source-url": "https://pusher.com/docs/channels/library_auth_reference/rest-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "http://api-{cluster}.pusher.com",
      "description": "Pusher API server",
      "variables": {
        "cluster": {
          "default": "mt1",
          "description": "Your app's cluster identifier"
        }
      }
    }
  ],
  "security": [
    {
      "PusherAuth": []
    }
  ],
  "paths": {
    "/apps/{app_id}/events": {
      "post": {
        "summary": "Trigger single event",
        "description": "Triggers a single event on one or more channels",
        "operationId": "triggerEvent",
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "description": "Application ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "auth_key",
            "in": "query",
            "description": "Application key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "auth_timestamp",
            "in": "query",
            "description": "Seconds since January 1, 1970 (must be within 600s of server time)",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "auth_version",
            "in": "query",
            "description": "Authentication version (currently 1.0)",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "1.0"
              ]
            }
          },
          {
            "name": "body_md5",
            "in": "query",
            "description": "Hexadecimal MD5 hash of the request body",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "auth_signature",
            "in": "query",
            "description": "HMAC SHA256 hex digest of the signed string",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "data"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Event name"
                  },
                  "data": {
                    "type": "string",
                    "description": "JSON-encoded event data (max 10KB)"
                  },
                  "channels": {
                    "type": "array",
                    "description": "Array of channel names (max 100)",
                    "items": {
                      "type": "string"
                    },
                    "maxItems": 100
                  },
                  "channel": {
                    "type": "string",
                    "description": "Single channel name (alternative to channels)"
                  },
                  "socket_id": {
                    "type": "string",
                    "description": "Excludes specific connection from receiving the event"
                  },
                  "info": {
                    "type": "string",
                    "description": "Comma-separated channel attributes to return (user_count, subscription_count)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication error"
          },
          "403": {
            "description": "Forbidden - app disabled or quota exceeded"
          },
          "413": {
            "description": "Payload too large"
          }
        },
        "tags": [
          "apps"
        ]
      }
    },
    "/apps/{app_id}/batch_events": {
      "post": {
        "summary": "Trigger multiple events",
        "description": "Triggers multiple events in a single request (up to 10 events)",
        "operationId": "triggerBatchEvents",
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "description": "Application ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "auth_key",
            "in": "query",
            "description": "Application key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "auth_timestamp",
            "in": "query",
            "description": "Seconds since January 1, 1970 (must be within 600s of server time)",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "auth_version",
            "in": "query",
            "description": "Authentication version (currently 1.0)",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "1.0"
              ]
            }
          },
          {
            "name": "body_md5",
            "in": "query",
            "description": "Hexadecimal MD5 hash of the request body",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "auth_signature",
            "in": "query",
            "description": "HMAC SHA256 hex digest of the signed string",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "batch"
                ],
                "properties": {
                  "batch": {
                    "type": "array",
                    "description": "Array of events to trigger (max 10)",
                    "maxItems": 10,
                    "items": {
                      "type": "object",
                      "required": [
                        "name",
                        "data",
                        "channel"
                      ],
                      "properties": {
                        "name": {
                          "type": "string",
                          "description": "Event name"
                        },
                        "data": {
                          "type": "string",
                          "description": "JSON-encoded event data (max 10KB)"
                        },
                        "channel": {
                          "type": "string",
                          "description": "Channel name"
                        },
                        "socket_id": {
                          "type": "string",
                          "description": "Excludes specific connection from receiving the event"
                        },
                        "info": {
                          "type": "string",
                          "description": "Comma-separated channel attributes to return"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "batch": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication error"
          },
          "403": {
            "description": "Forbidden - app disabled or quota exceeded"
          },
          "413": {
            "description": "Payload too large"
          }
        },
        "tags": [
          "apps"
        ]
      }
    },
    "/apps/{app_id}/channels": {
      "get": {
        "summary": "Fetch multiple channels",
        "description": "Returns information about multiple channels",
        "operationId": "getChannels",
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "description": "Application ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "auth_key",
            "in": "query",
            "description": "Application key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "auth_timestamp",
            "in": "query",
            "description": "Seconds since January 1, 1970",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "auth_version",
            "in": "query",
            "description": "Authentication version",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "1.0"
              ]
            }
          },
          {
            "name": "auth_signature",
            "in": "query",
            "description": "HMAC SHA256 hex digest",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter_by_prefix",
            "in": "query",
            "description": "Filter channels by prefix (e.g., presence-)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "info",
            "in": "query",
            "description": "Comma-separated channel attributes to return",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "channels": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication error"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "tags": [
          "apps"
        ]
      }
    },
    "/apps/{app_id}/channels/{channel_name}": {
      "get": {
        "summary": "Fetch single channel",
        "description": "Returns information about a specific channel",
        "operationId": "getChannel",
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "description": "Application ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "channel_name",
            "in": "path",
            "description": "Channel name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "auth_key",
            "in": "query",
            "description": "Application key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "auth_timestamp",
            "in": "query",
            "description": "Seconds since January 1, 1970",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "auth_version",
            "in": "query",
            "description": "Authentication version",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "1.0"
              ]
            }
          },
          {
            "name": "auth_signature",
            "in": "query",
            "description": "HMAC SHA256 hex digest",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "info",
            "in": "query",
            "description": "Comma-separated attributes: user_count, subscription_count, or cache",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "occupied": {
                      "type": "boolean"
                    },
                    "user_count": {
                      "type": "integer",
                      "nullable": true
                    },
                    "subscription_count": {
                      "type": "integer",
                      "nullable": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication error"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "tags": [
          "apps"
        ]
      }
    },
