{
  "openapi": "3.0.0",
  "info": {
    "title": "Pusher Beams API",
    "description": "Pusher Beams is a hosted service that makes it easy to send push notifications to iOS, Android, and Web users via their devices' native notification platform.",
    "version": "1.0.0",
    "contact": {
      "name": "Pusher",
      "url": "https://pusher.com/beams"
    }
  },
  "servers": [
    {
      "url": "https://{instanceId}.pushnotifications.pusher.com",
      "description": "Pusher Beams API Server",
      "variables": {
        "instanceId": {
          "default": "YOUR_INSTANCE_ID",
          "description": "Your Pusher Beams instance ID"
        }
      }
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Secret key for server-side authentication"
      },
      "BeamsUserJWT": {
        "type": "http",
        "scheme": "bearer",
        "description": "JWT token for user authentication"
      }
    },
    "schemas": {
      "PublishToInterestsRequest": {
        "type": "object",
        "required": [
          "interests"
        ],
        "properties": {
          "interests": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "maxItems": 100,
            "description": "Array of interest names (1-100 interests per request)",
            "example": [
              "hello",
              "world"
            ]
          },
          "webhookUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL for publishing lifecycle webhooks"
          },
          "apns": {
            "type": "object",
            "description": "Apple Push Notification payload"
          },
          "fcm": {
            "type": "object",
            "description": "Firebase Cloud Messaging payload"
          },
          "web": {
            "type": "object",
            "description": "Web push gateway payload"
          }
        }
      },
      "PublishToUsersRequest": {
        "type": "object",
        "required": [
          "users"
        ],
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "maxItems": 1000,
            "description": "Array of user IDs (1-1000 users per request, max 164 bytes each)",
            "example": [
              "user-001",
              "user-002"
            ]
          },
          "apns": {
            "type": "object",
            "description": "Apple Push Notification payload"
          },
          "fcm": {
            "type": "object",
            "description": "Firebase Cloud Messaging payload"
          },
          "web": {
            "type": "object",
            "description": "Web push gateway payload"
          }
        }
      },
      "PublishResponse": {
        "type": "object",
        "properties": {
          "publishId": {
            "type": "string",
            "description": "Unique identifier for the publish request"
          }
        }
      },
      "DeviceRegistrationApns": {
        "type": "object",
        "required": [
          "token",
          "bundleIdentifier"
        ],
        "properties": {
          "token": {
            "type": "string",
            "description": "APNs device token"
          },
          "bundleIdentifier": {
            "type": "string",
            "description": "iOS app bundle identifier"
          }
        }
      },
      "DeviceRegistrationFcm": {
        "type": "object",
        "required": [
          "token",
          "bundleIdentifier"
        ],
        "properties": {
          "token": {
            "type": "string",
            "description": "FCM device token"
          },
          "bundleIdentifier": {
            "type": "string",
            "description": "Android app bundle identifier"
          }
        }
      },
      "DeviceResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Device ID"
          },
          "userId": {
            "type": "string",
            "description": "User ID associated with the device"
          },
          "initialInterestSet": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Initial set of interests for the device"
          }
        }
      },
      "DeviceMetadataApns": {
        "type": "object",
        "properties": {
          "sdkVersion": {
            "type": "string",
            "description": "SDK version"
          },
          "iosVersion": {
            "type": "string",
            "description": "iOS version"
          },
          "macosVersion": {
            "type": "string",
            "description": "macOS version"
          }
        }
      },
      "DeviceMetadataFcm": {
        "type": "object",
        "properties": {
          "sdkVersion": {
            "type": "string",
            "description": "SDK version"
          },
          "androidVersion": {
            "type": "string",
            "description": "Android version"
          }
        }
      },
      "InterestsResponse": {
        "type": "object",
        "properties": {
          "interests": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of interests"
          }
        }
      },
      "InterestsUpdate": {
        "type": "object",
        "required": [
          "interests"
        ],
        "properties": {
          "interests": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 5000,
            "description": "Array of interests (max 5000)"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "description": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      }
    }
  },
  "paths": {
    "/publish_api/v1/instances/{instanceId}/publishes/interests": {
      "post": {
        "operationId": "publishToInterests",
        "summary": "Publish to interests",
        "description": "Send push notifications to devices subscribed to specific interests",
        "parameters": [
          {
            "name": "instanceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your Pusher Beams instance ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PublishToInterestsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublishResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Instance not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limited (max 100 requests per second)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "publish_api"
        ]
      }
    },
    "/publish_api/v1/instances/{instanceId}/publishes/users": {
      "post": {
        "operationId": "publishToUsers",
        "summary": "Publish to users",
        "description": "Send push notifications to specific users",
        "parameters": [
          {
            "name": "instanceId",
            "in": "path",
