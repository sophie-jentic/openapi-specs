        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublishResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Instance not found"
          },
          "429": {
            "description": "Rate limited"
          }
        },
        "tags": [
          "publish_api"
        ]
      }
    },
