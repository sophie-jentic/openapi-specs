{
  "openapi": "3.0.3",
  "info": {
    "title": "WorldCoinIndex API",
    "description": "WorldCoinIndex cryptocurrency market data API providing ticker information, market prices, and volume data for various cryptocurrency pairs across multiple fiat currencies.",
    "version": "2.0.0",
    "contact": {
      "name": "WorldCoinIndex",
      "url": "https://www.worldcoinindex.com"
    }
  },
  "servers": [
    {
      "url": "https://www.worldcoinindex.com/apiservice",
      "description": "Production"
    }
  ],
  "security": [
    {
      "ApiKeyParam": []
    }
  ],
  "paths": {
    "/ticker": {
      "get": {
        "operationId": "getTicker",
        "summary": "Get ticker data",
        "description": "Retrieve ticker data for one or more specific cryptocurrency pairs.",
        "tags": [
          "Market Data"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "label",
            "in": "query",
            "required": true,
            "description": "Comma-separated cryptocurrency pair labels (e.g., ethbtc-ltcbtc)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fiat",
            "in": "query",
            "required": true,
            "description": "Target fiat or crypto currency for price conversion (e.g., btc, usd, eur)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TickerResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "429": {
            "description": "Rate limit exceeded (maximum 70 requests per hour)"
          }
        }
      }
    },
    "/v2getmarkets": {
      "get": {
        "operationId": "getMarketsV2",
        "summary": "Get all markets (v2)",
        "description": "Retrieve market data for all available cryptocurrencies. Returns labels with fiat currency placeholder.",
        "tags": [
          "Market Data"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fiat",
            "in": "query",
            "required": true,
            "description": "Target fiat currency for price conversion (e.g., usd, eur, gbp)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/getmarkets": {
      "get": {
        "operationId": "getMarkets",
        "summary": "Get all markets (deprecated)",
        "description": "Retrieve market data for all available cryptocurrencies. Deprecated in favor of v2getmarkets.",
        "tags": [
          "Market Data"
        ],
        "deprecated": true,
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fiat",
            "in": "query",
            "required": true,
            "description": "Target fiat currency",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          }
        }
      }
    },
    "/json": {
      "get": {
        "operationId": "getAllData",
        "summary": "Get all data (deprecated)",
        "description": "Retrieve all cryptocurrency data with prices in multiple fiat currencies. Deprecated.",
        "tags": [
          "Market Data"
        ],
        "deprecated": true,
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AllDataResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyParam": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key provided upon registration"
      }
    },
    "schemas": {
      "TickerResponse": {
        "type": "object",
        "properties": {
          "Markets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MarketTicker"
            }
          }
        }
      },
      "MarketsResponse": {
        "type": "object",
        "properties": {
          "Markets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MarketTicker"
            }
          }
        }
      },
      "MarketTicker": {
        "type": "object",
        "properties": {
          "Label": {
            "type": "string",
            "description": "Trading pair label (e.g., ETH/BTC)"
          },
          "Name": {
            "type": "string",
            "description": "Cryptocurrency name"
          },
          "Price": {
            "type": "number",
            "format": "double",
            "description": "Current price in the specified fiat currency"
          },
          "Volume_24h": {
            "type": "number",
            "format": "double",
            "description": "24-hour trading volume"
          },
          "Timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp of the data"
          }
        }
      },
      "AllDataResponse": {
        "type": "object",
        "properties": {
          "Markets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AllDataMarket"
            }
          }
        }
      },
      "AllDataMarket": {
        "type": "object",
        "properties": {
          "Label": {
            "type": "string"
          },
          "Name": {
            "type": "string"
          },
          "Price_btc": {
            "type": "number",
            "format": "double"
          },
          "Price_usd": {
            "type": "number",
            "format": "double"
          },
          "Price_cny": {
            "type": "number",
            "format": "double"
          },
          "Price_eur": {
            "type": "number",
            "format": "double"
          },
          "Price_gbp": {
            "type": "number",
            "format": "double"
          },
          "Price_rur": {
            "type": "number",
            "format": "double"
          },
          "Volume_24h": {
            "type": "number",
            "format": "double"
          },
          "Timestamp": {
            "type": "integer",
            "format": "int64"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Market Data"
    }
  ]
}
