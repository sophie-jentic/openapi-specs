{
  "openapi": "3.0.3",
  "info": {
    "title": "NATS Server Monitoring API",
    "version": "2.0.0",
    "description": "NATS server monitoring HTTP endpoints provide runtime info about the server state, connections, routes, subscriptions, accounts, and JetStream.",
    "contact": {
      "name": "NATS.io",
      "url": "https://nats.io"
    },
    "x-jentic-source-url": "https://docs.nats.io/running-a-nats-service/nats_admin/monitoring"
  },
  "servers": [
    {
      "url": "http://localhost:8222",
      "description": "NATS server monitoring port (default 8222)"
    }
  ],
  "tags": [
    {
      "name": "General",
      "description": "General server information"
    },
    {
      "name": "Connections",
      "description": "Connection information"
    },
    {
      "name": "Routes",
      "description": "Routing information"
    },
    {
      "name": "Gateways",
      "description": "Gateway information"
    },
    {
      "name": "Leafnodes",
      "description": "Leafnode information"
    },
    {
      "name": "Subscriptions",
      "description": "Subscription information"
    },
    {
      "name": "Accounts",
      "description": "Account information"
    },
    {
      "name": "JetStream",
      "description": "JetStream information"
    },
    {
      "name": "Health",
      "description": "Health check"
    }
  ],
  "paths": {
    "/varz": {
      "get": {
        "operationId": "getVarz",
        "summary": "Server general information",
        "description": "Returns general server stats: uptime, connections, messages, bytes, slow consumers, etc.",
        "tags": [
          "General"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "server_id": {
                      "type": "string"
                    },
                    "server_name": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    },
                    "proto": {
                      "type": "integer"
                    },
                    "go": {
                      "type": "string"
                    },
                    "host": {
                      "type": "string"
                    },
                    "port": {
                      "type": "integer"
                    },
                    "max_connections": {
                      "type": "integer"
                    },
                    "connections": {
                      "type": "integer"
                    },
                    "total_connections": {
                      "type": "integer"
                    },
                    "routes": {
                      "type": "integer"
                    },
                    "remotes": {
                      "type": "integer"
                    },
                    "leafnodes": {
                      "type": "integer"
                    },
                    "in_msgs": {
                      "type": "integer"
                    },
                    "out_msgs": {
                      "type": "integer"
                    },
                    "in_bytes": {
                      "type": "integer"
                    },
                    "out_bytes": {
                      "type": "integer"
                    },
                    "slow_consumers": {
                      "type": "integer"
                    },
                    "subscriptions": {
                      "type": "integer"
                    },
                    "mem": {
                      "type": "integer"
                    },
                    "cores": {
                      "type": "integer"
                    },
                    "cpu": {
                      "type": "number"
                    },
                    "uptime": {
                      "type": "string"
                    },
                    "start": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "now": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/connz": {
      "get": {
        "operationId": "getConnz",
        "summary": "Connection information",
        "description": "Returns detailed info about current client connections",
        "tags": [
          "Connections"
        ],
        "parameters": [
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "cid",
                "start",
                "subs",
                "pending",
                "msgs_to",
                "msgs_from",
                "bytes_to",
                "bytes_from",
                "last",
                "idle",
                "uptime",
                "stop",
                "reason"
              ]
            }
          },
          {
            "name": "auth",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include username"
          },
          {
            "name": "subs",
            "in": "query",
            "schema": {
              "type": "boolean",
              "enum": [
                true,
                false
              ]
            },
            "description": "Include subscriptions"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1024
            }
          },
          {
            "name": "cid",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by connection ID"
          },
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "closed",
                "any"
              ]
            }
          },
          {
            "name": "mqtt_client",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "server_id": {
                      "type": "string"
                    },
                    "now": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "num_connections": {
                      "type": "integer"
                    },
                    "total": {
                      "type": "integer"
                    },
                    "offset": {
                      "type": "integer"
                    },
                    "limit": {
                      "type": "integer"
                    },
                    "connections": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "cid": {
                            "type": "integer"
                          },
                          "kind": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string"
                          },
                          "ip": {
                            "type": "string"
                          },
                          "port": {
                            "type": "integer"
                          },
                          "start": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "last_activity": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "rtt": {
                            "type": "string"
                          },
                          "uptime": {
                            "type": "string"
                          },
                          "idle": {
                            "type": "string"
                          },
                          "pending_bytes": {
                            "type": "integer"
                          },
                          "in_msgs": {
                            "type": "integer"
                          },
                          "out_msgs": {
                            "type": "integer"
                          },
                          "in_bytes": {
                            "type": "integer"
                          },
                          "out_bytes": {
                            "type": "integer"
                          },
                          "subscriptions": {
                            "type": "integer"
                          },
                          "name": {
                            "type": "string"
                          },
                          "lang": {
                            "type": "string"
                          },
                          "version": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/routez": {
      "get": {
        "operationId": "getRoutez",
        "summary": "Route information",
        "description": "Returns info about active routes to other cluster members",
        "tags": [
          "Routes"
        ],
        "parameters": [
          {
            "name": "subs",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "server_id": {
                      "type": "string"
                    },
                    "now": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "num_routes": {
                      "type": "integer"
                    },
                    "routes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "rid": {
                            "type": "integer"
                          },
                          "remote_id": {
                            "type": "string"
                          },
                          "did_solicit": {
                            "type": "boolean"
                          },
                          "is_configured": {
                            "type": "boolean"
                          },
                          "ip": {
                            "type": "string"
                          },
                          "port": {
                            "type": "integer"
                          },
                          "pending_size": {
                            "type": "integer"
                          },
                          "in_msgs": {
                            "type": "integer"
                          },
                          "out_msgs": {
                            "type": "integer"
                          },
                          "in_bytes": {
                            "type": "integer"
                          },
                          "out_bytes": {
                            "type": "integer"
                          },
                          "subscriptions": {
                            "type": "integer"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/gatewayz": {
      "get": {
        "operationId": "getGatewayz",
        "summary": "Gateway information",
        "description": "Returns info about gateways in a super-cluster",
        "tags": [
          "Gateways"
        ],
        "parameters": [
          {
            "name": "accs",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "gw_name",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "acc_name",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/leafz": {
      "get": {
        "operationId": "getLeafz",
        "summary": "Leafnode information",
        "description": "Returns info about leafnode connections",
        "tags": [
          "Leafnodes"
        ],
        "parameters": [
          {
            "name": "subs",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "server_id": {
                      "type": "string"
                    },
                    "now": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "leafnodes": {
                      "type": "integer"
                    },
                    "leafs": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/subsz": {
      "get": {
        "operationId": "getSubsz",
        "summary": "Subscription information",
        "description": "Returns details about current subscriptions and subscription cache",
        "tags": [
          "Subscriptions"
        ],
        "parameters": [
          {
            "name": "subs",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "test",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Test a subject for matching subscriptions"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "num_subscriptions": {
                      "type": "integer"
                    },
                    "num_cache": {
                      "type": "integer"
                    },
                    "num_inserts": {
                      "type": "integer"
                    },
                    "num_removes": {
                      "type": "integer"
                    },
                    "num_matches": {
                      "type": "integer"
                    },
                    "cache_hit_rate": {
                      "type": "number"
                    },
                    "max_fanout": {
                      "type": "integer"
                    },
                    "avg_fanout": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accountz": {
      "get": {
        "operationId": "getAccountz",
        "summary": "Account information",
        "description": "Returns info about active accounts",
        "tags": [
          "Accounts"
        ],
        "parameters": [
          {
            "name": "acc",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by account name"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "server_id": {
                      "type": "string"
                    },
                    "now": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "system_account": {
                      "type": "string"
                    },
                    "accounts": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/jsz": {
      "get": {
        "operationId": "getJsz",
        "summary": "JetStream information",
        "description": "Returns JetStream config, stats, streams, and consumer info",
        "tags": [
          "JetStream"
        ],
        "parameters": [
          {
            "name": "acc",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "streams",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "consumers",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "config",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "leader_only",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "server_id": {
                      "type": "string"
                    },
                    "now": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "config": {
                      "type": "object"
                    },
                    "memory": {
                      "type": "integer"
                    },
                    "storage": {
                      "type": "integer"
                    },
                    "reserved_memory": {
                      "type": "integer"
                    },
                    "reserved_storage": {
                      "type": "integer"
                    },
                    "accounts": {
                      "type": "integer"
                    },
                    "ha_assets": {
                      "type": "integer"
                    },
                    "api": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "errors": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/healthz": {
      "get": {
        "operationId": "getHealthz",
        "summary": "Health check",
        "description": "Returns server health status",
        "tags": [
          "Health"
        ],
        "parameters": [
          {
            "name": "js-enabled-only",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "js-server-only",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ]
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Unhealthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "errors": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ipqueuesz": {
      "get": {
        "operationId": "getIpQueuesz",
        "summary": "Internal process queues info",
        "description": "Shows internal queues and their depths",
        "tags": [
          "General"
        ],
        "parameters": [
          {
            "name": "all",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {}
}