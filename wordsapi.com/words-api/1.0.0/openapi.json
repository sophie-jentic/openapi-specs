          },
          "hasUsages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inRegion": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "regionOf": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "pertainsTo": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "derivation": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Pronunciation": {
        "type": "object",
        "properties": {
          "all": {
            "type": "string",
            "description": "General IPA pronunciation"
          }
        },
        "additionalProperties": {
          "type": "string",
