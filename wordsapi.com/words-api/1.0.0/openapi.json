    "/words/": {
      "get": {
        "operationId": "getRandomWord",
        "summary": "Get a random word",
        "description": "Returns a random word. Can be filtered by various criteria such as having specific details available, letter patterns, word frequency, etc.",
        "tags": [
          "Words"
        ],
        "parameters": [
          {
            "name": "letterPattern",
            "in": "query",
            "description": "Regular expression pattern the word must match",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "letters",
            "in": "query",
            "description": "Number of letters in the word",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "lettersMin",
            "in": "query",
            "description": "Minimum number of letters",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "lettersMax",
            "in": "query",
            "description": "Maximum number of letters",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pronunciationPattern",
            "in": "query",
            "description": "IPA pronunciation pattern to match",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "frequencyMin",
            "in": "query",
            "description": "Minimum Zipf frequency score",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "frequencyMax",
            "in": "query",
            "description": "Maximum Zipf frequency score",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "hasDetails",
            "in": "query",
            "description": "Comma-separated list of detail types the random word must have (e.g., 'definitions,synonyms')",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "partOfSpeech",
            "in": "query",
            "description": "Part of speech to filter by (e.g., 'noun', 'verb', 'adjective')",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "random",
            "in": "query",
            "description": "Set to true to get a random word",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with a random word",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WordResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
