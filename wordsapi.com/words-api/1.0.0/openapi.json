{
  "openapi": "3.0.3",
  "info": {
    "title": "Words API",
    "version": "1.0.0",
    "description": "Words API provides comprehensive word data including definitions, synonyms, antonyms, examples, pronunciation, syllables, frequency, rhymes, and various semantic relationships. Accessed via RapidAPI. Returns JSON for all responses.",
    "x-jentic-source-url": "https://www.wordsapi.com/docs/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://wordsapiv1.p.mashape.com"
    }
  ],
  "paths": {
    "/words/{word}": {
      "get": {
        "operationId": "getWord",
        "summary": "Get complete word information",
        "description": "Returns everything known about a word — definitions, synonyms, antonyms, examples, pronunciation, syllables, frequency, and all semantic relationships, grouped by definition.",
        "tags": [
          "Words"
        ],
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "description": "The word to look up",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with complete word data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WordResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Word not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
