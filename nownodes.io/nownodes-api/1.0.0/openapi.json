{
  "openapi": "3.0.3",
  "info": {
    "title": "NOWNodes API",
    "description": "NOWNodes provides Blockchain-as-a-Service (BaaS) solution with instant access to full node RPC endpoints, block explorers, and WebSocket connections for 100+ blockchain networks. Use your API key to send JSON-RPC requests to any supported blockchain node.",
    "version": "1.0.0",
    "contact": {
      "name": "NOWNodes Support",
      "url": "https://nownodes.io/",
      "email": "sales@nownodes.io"
    },
    "termsOfService": "https://nownodes.io/terms"
  },
  "servers": [
    {
      "url": "https://{network}.nownodes.io",
      "description": "NOWNodes blockchain RPC endpoint",
      "variables": {
        "network": {
          "default": "btc",
          "description": "Blockchain network identifier",
          "enum": [
            "btc",
            "eth",
            "eth-archive",
            "bsc",
            "sol",
            "ltc",
            "doge",
            "matic",
            "arb",
            "op",
            "avax",
            "ada",
            "xrp",
            "dot",
            "trx",
            "atom",
            "xlm",
            "algo",
            "near",
            "ftm",
            "celo",
            "one",
            "klay",
            "zec",
            "dash",
            "bch",
            "etc",
            "bnb"
          ]
        }
      }
    },
    {
      "url": "https://{network}book.nownodes.io",
      "description": "NOWNodes BlockBook explorer endpoint",
      "variables": {
        "network": {
          "default": "btc",
          "description": "Blockchain network identifier for BlockBook explorer",
          "enum": [
            "btc",
            "eth",
            "ltc",
            "doge",
            "bch",
            "dash",
            "zec"
          ]
        }
      }
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/": {
      "post": {
        "operationId": "sendJsonRpcRequest",
        "summary": "Send JSON-RPC request",
        "description": "Send a JSON-RPC 2.0 request to the blockchain node. The available methods depend on the specific blockchain network being accessed (e.g., Bitcoin, Ethereum, Solana, etc.).",
        "tags": [
          "JSON-RPC"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JsonRpcRequest"
              },
              "examples": {
                "bitcoinGetBlockCount": {
                  "summary": "Bitcoin - Get block count",
                  "value": {
                    "jsonrpc": "2.0",
                    "method": "getblockcount",
                    "params": [],
                    "id": 1
                  }
                },
                "bitcoinGetBlockHash": {
                  "summary": "Bitcoin - Get block hash",
                  "value": {
                    "jsonrpc": "2.0",
                    "method": "getblockhash",
                    "params": [
                      100000
                    ],
                    "id": 1
                  }
                },
                "ethereumGetBlockNumber": {
                  "summary": "Ethereum - Get block number (eth_blockNumber)",
                  "value": {
                    "jsonrpc": "2.0",
                    "method": "eth_blockNumber",
                    "params": [],
                    "id": 1
                  }
                },
                "ethereumGetBalance": {
                  "summary": "Ethereum - Get balance (eth_getBalance)",
                  "value": {
                    "jsonrpc": "2.0",
                    "method": "eth_getBalance",
                    "params": [
                      "0x742d35Cc6634C0532925a3b844Bc9e7595f2bD1e",
                      "latest"
                    ],
                    "id": 1
                  }
                },
                "ethereumGetTransactionByHash": {
                  "summary": "Ethereum - Get transaction by hash",
                  "value": {
                    "jsonrpc": "2.0",
                    "method": "eth_getTransactionByHash",
                    "params": [
                      "0x88df016429689c079f3b2f6ad39fa052532c56795b733da78a91ebe6a713944b"
                    ],
                    "id": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful JSON-RPC response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JsonRpcResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "403": {
            "description": "Forbidden - API key does not have access to the requested network"
          },
          "429": {
            "description": "Too Many Requests - Rate limit exceeded"
          }
        }
      },
      "get": {
        "operationId": "getNodeStatus",
        "summary": "Get node status",
        "description": "Check the status and availability of the blockchain node.",
        "tags": [
          "Status"
        ],
        "responses": {
          "200": {
            "description": "Node is available and responding"
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      }
    },
    "/api/v2": {
      "get": {
        "operationId": "getBlockBookStatus",
        "summary": "Get BlockBook API status",
        "description": "Get the status of the BlockBook explorer API including current block height, best block hash, and backend info.",
        "tags": [
          "BlockBook"
        ],
        "responses": {
          "200": {
            "description": "BlockBook status information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlockBookStatus"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/v2/block/{blockHashOrHeight}": {
      "get": {
        "operationId": "getBlock",
        "summary": "Get block by hash or height",
        "description": "Returns information about a block, including transactions.",
        "tags": [
          "BlockBook"
        ],
        "parameters": [
          {
            "name": "blockHashOrHeight",
            "in": "path",
            "required": true,
            "description": "Block hash or block height",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for paginated results",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "description": "Number of transactions per page",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Block information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Block"
                }
              }
            }
          },
          "404": {
            "description": "Block not found"
          }
        }
      }
    },
    "/api/v2/tx/{txid}": {
      "get": {
        "operationId": "getTransaction",
        "summary": "Get transaction details",
        "description": "Returns detailed information about a transaction.",
        "tags": [
          "BlockBook"
        ],
        "parameters": [
          {
            "name": "txid",
            "in": "path",
            "required": true,
            "description": "Transaction ID (hash)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transaction"
                }
              }
            }
          },
          "404": {
            "description": "Transaction not found"
          }
        }
      }
    },
    "/api/v2/tx-specific/{txid}": {
      "get": {
        "operationId": "getTransactionSpecific",
        "summary": "Get backend-specific transaction details",
        "description": "Returns backend-specific (raw) transaction data from the node.",
        "tags": [
          "BlockBook"
        ],
        "parameters": [
          {
            "name": "txid",
            "in": "path",
            "required": true,
            "description": "Transaction ID (hash)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Backend-specific transaction data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Transaction not found"
          }
        }
      }
    },
    "/api/v2/address/{address}": {
      "get": {
        "operationId": "getAddress",
        "summary": "Get address details",
        "description": "Returns balances and transactions for a given address.",
        "tags": [
          "BlockBook"
        ],
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "Blockchain address",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "description": "Number of transactions per page",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "details",
            "in": "query",
            "required": false,
            "description": "Level of detail: basic, tokens, tokenBalances, txids, txs",
            "schema": {
              "type": "string",
              "enum": [
                "basic",
                "tokens",
                "tokenBalances",
                "txids",
                "txs"
              ]
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "description": "Filter from block height",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "description": "Filter to block height",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Address information with balance and transactions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Address"
                }
              }
            }
          },
          "404": {
            "description": "Address not found"
          }
        }
      }
    },
    "/api/v2/xpub/{xpub}": {
      "get": {
        "operationId": "getXpub",
        "summary": "Get xpub details",
        "description": "Returns balances and transactions associated with an xpub (extended public key).",
        "tags": [
          "BlockBook"
        ],
        "parameters": [
          {
            "name": "xpub",
            "in": "path",
            "required": true,
            "description": "Extended public key (xpub)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "description": "Number of transactions per page",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "details",
            "in": "query",
            "required": false,
            "description": "Level of detail",
            "schema": {
              "type": "string",
              "enum": [
                "basic",
                "tokens",
                "tokenBalances",
                "txids",
                "txs"
              ]
            }
          },
          {
            "name": "tokens",
            "in": "query",
            "required": false,
            "description": "Token filter: used, nonzero, derived",
            "schema": {
              "type": "string",
              "enum": [
                "used",
                "nonzero",
                "derived"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Xpub information with balance and transactions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Xpub"
                }
              }
            }
          },
          "404": {
            "description": "Xpub not found"
          }
        }
      }
    },
    "/api/v2/utxo/{addressOrXpub}": {
      "get": {
        "operationId": "getUtxo",
        "summary": "Get UTXOs for address or xpub",
        "description": "Returns a list of unspent transaction outputs (UTXOs) for a given address or xpub.",
        "tags": [
          "BlockBook"
        ],
        "parameters": [
          {
            "name": "addressOrXpub",
            "in": "path",
            "required": true,
            "description": "Address or extended public key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "confirmed",
            "in": "query",
            "required": false,
            "description": "If true, return only confirmed UTXOs",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of UTXOs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Utxo"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/balancehistory/{addressOrXpub}": {
      "get": {
        "operationId": "getBalanceHistory",
        "summary": "Get balance history",
        "description": "Returns the history of balance changes for an address or xpub.",
        "tags": [
          "BlockBook"
        ],
        "parameters": [
          {
            "name": "addressOrXpub",
            "in": "path",
            "required": true,
            "description": "Address or extended public key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "description": "Start timestamp (Unix)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "description": "End timestamp (Unix)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "groupBy",
            "in": "query",
            "required": false,
            "description": "Group results by time period",
            "schema": {
              "type": "integer",
              "description": "Interval in seconds"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Balance history data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BalanceHistory"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/sendtx/{hex}": {
      "get": {
        "operationId": "sendTransaction",
        "summary": "Send transaction",
        "description": "Broadcast a signed raw transaction to the blockchain network.",
        "tags": [
          "BlockBook"
        ],
        "parameters": [
          {
            "name": "hex",
            "in": "path",
            "required": true,
            "description": "Signed raw transaction hex",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction broadcast result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "string",
                      "description": "Transaction hash if successful"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid transaction"
          }
        }
      }
    },
    "/api/v2/estimatefee/{confirmationTarget}": {
      "get": {
        "operationId": "estimateFee",
        "summary": "Estimate transaction fee",
        "description": "Returns estimated fee per kilobyte for a transaction to be included within the specified number of blocks.",
        "tags": [
          "BlockBook"
        ],
        "parameters": [
          {
            "name": "confirmationTarget",
            "in": "path",
            "required": true,
            "description": "Number of blocks within which the transaction should be confirmed",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Estimated fee",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "string",
                      "description": "Estimated fee per kilobyte"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "api-key",
        "description": "NOWNodes API key obtained from the dashboard at https://nownodes.io/"
      }
    },
    "schemas": {
      "JsonRpcRequest": {
        "type": "object",
        "required": [
          "jsonrpc",
          "method",
          "id"
        ],
        "properties": {
          "jsonrpc": {
            "type": "string",
            "description": "JSON-RPC protocol version",
            "enum": [
              "2.0"
            ]
          },
          "method": {
            "type": "string",
            "description": "The RPC method to call. Available methods depend on the blockchain network."
          },
          "params": {
            "description": "Parameters for the RPC method",
            "oneOf": [
              {
                "type": "array",
                "items": {}
              },
              {
                "type": "object"
              }
            ]
          },
          "id": {
            "description": "Request identifier",
            "oneOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ]
          }
        }
      },
      "JsonRpcResponse": {
        "type": "object",
        "properties": {
          "jsonrpc": {
            "type": "string",
            "description": "JSON-RPC protocol version"
          },
          "result": {
            "description": "The result of the RPC call (type depends on the method called)"
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "integer",
                "description": "Error code"
              },
              "message": {
                "type": "string",
                "description": "Error message"
              }
            }
          },
          "id": {
            "description": "Request identifier matching the request"
          }
        }
      },
      "BlockBookStatus": {
        "type": "object",
        "properties": {
          "blockbook": {
            "type": "object",
            "properties": {
              "coin": {
                "type": "string",
                "description": "Cryptocurrency name"
              },
              "host": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "bestHeight": {
                "type": "integer",
                "description": "Current best block height"
              },
              "bestBlockHash": {
                "type": "string",
                "description": "Hash of the best block"
              },
              "decimals": {
                "type": "integer"
              },
              "inSync": {
                "type": "boolean",
                "description": "Whether the blockbook is in sync with the backend"
              },
              "lastBlockTime": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "backend": {
            "type": "object",
            "properties": {
              "chain": {
                "type": "string"
              },
              "blocks": {
                "type": "integer"
              },
              "headers": {
                "type": "integer"
              },
              "bestBlockHash": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "subversion": {
                "type": "string"
              },
              "protocolVersion": {
                "type": "string"
              }
            }
          }
        }
      },
      "Block": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          },
          "itemsOnPage": {
            "type": "integer"
          },
          "hash": {
            "type": "string"
          },
          "height": {
            "type": "integer"
          },
          "confirmations": {
            "type": "integer"
          },
          "size": {
            "type": "integer"
          },
          "time": {
            "type": "integer",
            "description": "Unix timestamp"
          },
          "version": {
            "type": "integer"
          },
          "merkleRoot": {
            "type": "string"
          },
          "nonce": {
            "type": "string"
          },
          "bits": {
            "type": "string"
          },
          "difficulty": {
            "type": "string"
          },
          "txCount": {
            "type": "integer"
          },
          "txs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            }
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "txid": {
            "type": "string"
          },
          "version": {
            "type": "integer"
          },
          "blockHash": {
            "type": "string"
          },
          "blockHeight": {
            "type": "integer"
          },
          "confirmations": {
            "type": "integer"
          },
          "blockTime": {
            "type": "integer"
          },
          "value": {
            "type": "string"
          },
          "valueIn": {
            "type": "string"
          },
          "fees": {
            "type": "string"
          },
          "vin": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "txid": {
                  "type": "string"
                },
                "vout": {
                  "type": "integer"
                },
                "value": {
                  "type": "string"
                },
                "addresses": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "vout": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string"
                },
                "n": {
                  "type": "integer"
                },
                "addresses": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          },
          "itemsOnPage": {
            "type": "integer"
          },
          "address": {
            "type": "string"
          },
          "balance": {
            "type": "string"
          },
          "totalReceived": {
            "type": "string"
          },
          "totalSent": {
            "type": "string"
          },
          "unconfirmedBalance": {
            "type": "string"
          },
          "unconfirmedTxs": {
            "type": "integer"
          },
          "txs": {
            "type": "integer"
          },
          "txids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "transactions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            }
          }
        }
      },
      "Xpub": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          },
          "itemsOnPage": {
            "type": "integer"
          },
          "address": {
            "type": "string"
          },
          "balance": {
            "type": "string"
          },
          "totalReceived": {
            "type": "string"
          },
          "totalSent": {
            "type": "string"
          },
          "unconfirmedBalance": {
            "type": "string"
          },
          "unconfirmedTxs": {
            "type": "integer"
          },
          "txs": {
            "type": "integer"
          },
