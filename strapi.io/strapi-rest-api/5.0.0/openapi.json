{
  "openapi": "3.0.3",
  "info": {
    "title": "Strapi REST API",
    "version": "5.0.0",
    "description": "Strapi headless CMS REST API for managing and delivering content. Strapi generates REST API endpoints for each content type.",
    "x-jentic-source-url": "https://docs.strapi.io/cms/api/rest"
  },
  "servers": [
    {
      "url": "https://api.example.com/api",
      "description": "Strapi instance base URL (varies per deployment)"
    }
  ],
  "paths": {
    "/{pluralApiId}": {
      "get": {
        "operationId": "listEntries",
        "summary": "List entries for a content type",
        "tags": [
          "Content"
        ],
        "parameters": [
          {
            "name": "pluralApiId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Plural API ID of the content type"
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filters",
            "in": "query",
            "required": false,
            "schema": {
              "type": "object"
            },
            "style": "deepObject"
          },
          {
            "name": "populate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pagination[page]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pagination[pageSize]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 25,
              "maximum": 100
            }
          },
          {
            "name": "locale",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "draft",
                "published"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of entries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntryListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createEntry",
        "summary": "Create a new entry",
        "tags": [
          "Content"
        ],
        "parameters": [
          {
            "name": "pluralApiId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EntryInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created entry",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{pluralApiId}/{documentId}": {
      "get": {
        "operationId": "getEntry",
        "summary": "Get a single entry",
        "tags": [
