{
  "openapi": "3.0.3",
  "info": {
    "title": "Glean.ly API",
    "version": "1.0.0",
    "description": "Glean.ly API for managing experiments, facts, insights, conclusions, themes, labels, and tags.",
    "x-jentic-source-url": "https://docs.google.com/document/d/e/2PACX-1vRu8Ec7tDXv3GjKz7B9tFpiDRkJnylJapjMNZhp5qlAz-PlEQFNZtAHovNJDgneSEbTikv1WAeC0CE8/pub",
