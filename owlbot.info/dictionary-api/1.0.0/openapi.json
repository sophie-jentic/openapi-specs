{
  "openapi": "3.0.3",
  "info": {
    "title": "OwlBot Dictionary API",
    "description": "Simple dictionary API providing definitions, types (part of speech), examples, and pronunciation information for English words.",
    "version": "1.0.0",
    "contact": {
      "url": "https://owlbot.info/"
    }
  },
  "servers": [
    {
      "url": "https://owlbot.info/api/v4"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/dictionary/{word}": {
      "get": {
        "summary": "Get dictionary definition for a word",
        "description": "Retrieve dictionary information including definitions, part of speech, example usage, and pronunciation for the specified word.",
        "operationId": "getDictionaryEntry",
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "description": "The word to look up",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "example"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with dictionary entry",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DictionaryEntry"
                }
              }
            }
          },
          "404": {
            "description": "Word not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "dictionary"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key for authentication. Format: 'Token your-api-key'. Free tier available."
      }
    },
    "schemas": {
      "DictionaryEntry": {
        "type": "object",
        "properties": {
          "word": {
            "type": "string",
            "description": "The word being defined"
          },
          "pronunciation": {
            "type": "string",
            "description": "Pronunciation of the word"
          },
          "definitions": {
            "type": "array",
            "description": "Array of definitions for different senses",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Part of speech (e.g., noun, verb, adjective)"
                },
                "definition": {
                  "type": "string",
                  "description": "The definition text"
                },
                "example": {
                  "type": "string",
                  "description": "Example usage of the word in context"
                },
                "image_url": {
                  "type": "string",
                  "description": "URL to an illustrative image (if available)"
                },
                "emoji": {
                  "type": "string",
                  "description": "Related emoji (if available)"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "dictionary"
    }
  ]
}
