  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token obtained from the /auth endpoint"
      }
    },
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "JWT access token for authenticating subsequent requests"
          },
          "organizations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Organization"
            },
            "description": "List of organizations the authenticated user belongs to"
          }
        }
      },
      "Organization": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the organization"
          },
          "name": {
            "type": "string",
            "description": "Organization name"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Permission scopes for the authenticated user in this organization"
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the project"
          },
          "organization_uuid": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "description": "Project name"
          },
          "type": {
            "type": "string",
            "enum": [
              "basic",
              "pro"
            ],
            "description": "Project type (Codeship Basic or Codeship Pro)"
          },
          "repository_url": {
            "type": "string",
            "description": "URL of the connected repository"
          },
          "repository_provider": {
            "type": "string",
            "description": "Source code repository provider (e.g., github, bitbucket, gitlab)"
          },
          "authentication_user": {
            "type": "string",
            "description": "Username used for repository authentication"
          },
          "notification_rules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NotificationRule"
            }
          },
          "aes_key": {
            "type": "string",
            "description": "AES encryption key for encrypting environment variables"
          },
          "ssh_key": {
            "type": "string",
            "description": "SSH public key for the project"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "setup_commands": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Setup commands (Codeship Basic only)"
          },
          "test_pipelines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TestPipeline"
            },
            "description": "Test pipelines (Codeship Basic only)"
          },
          "deploy_pipelines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeployPipeline"
            },
            "description": "Deploy pipelines (Codeship Basic only)"
          },
          "team_ids": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "IDs of teams with access to this project"
          }
        }
      },
      "ProjectCreateRequest": {
        "type": "object",
        "required": [
          "type",
          "repository_url"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "basic",
              "pro"
            ],
            "description": "Project type"
          },
          "repository_url": {
            "type": "string",
            "description": "URL of the repository to connect"
          },
          "setup_commands": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Setup commands (Codeship Basic only)"
          },
          "test_pipelines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TestPipeline"
            }
          },
          "team_ids": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        }
      },
      "ProjectUpdateRequest": {
        "type": "object",
        "properties": {
