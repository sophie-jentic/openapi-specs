      "post": {
        "operationId": "createBuild",
        "summary": "Create a build",
        "description": "Triggers a new build for the specified project.",
        "tags": [
          "Builds"
        ],
        "parameters": [
          {
            "name": "organization_uuid",
            "in": "path",
            "required": true,
            "description": "UUID of the organization",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "project_uuid",
            "in": "path",
            "required": true,
            "description": "UUID of the project",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "ref",
                  "commit_sha"
                ],
                "properties": {
                  "ref": {
                    "type": "string",
                    "description": "Git reference (branch name)"
                  },
                  "commit_sha": {
                    "type": "string",
                    "description": "Git commit SHA to build"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Build created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Build"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          }
        }
      }
    },
