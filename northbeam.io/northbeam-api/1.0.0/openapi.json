{
  "openapi": "3.0.3",
  "info": {
    "title": "Northbeam API",
    "version": "1.0.0",
    "description": "Northbeam API for managing advertising spend data, orders, and data exports. Provides endpoints for spend tracking at daily and hourly granularity.",
    "x-jentic-source-url": "https://docs.northbeam.io/docs/using-the-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.northbeam.io/v1"
    }
  ],
  "paths": {
    "/spend": {
      "get": {
        "operationId": "listSpendRecords",
        "summary": "List spend records",
        "tags": [
          "Spend"
        ],
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "description": "Single date filter",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date_start",
            "in": "query",
            "description": "Date range start",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date_end",
            "in": "query",
            "description": "Date range end",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "platform_account_id",
            "in": "query",
            "required": true,
            "description": "Platform account ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "campaign_id",
            "in": "query",
            "description": "Filter by campaign",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "adset_id",
            "in": "query",
            "description": "Filter by adset",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ad_id",
            "in": "query",
            "description": "Filter by ad",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "Results per page",
            "schema": {
              "type": "integer",
              "default": 1000,
              "maximum": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpendListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List spend records"
      },
      "post": {
        "operationId": "upsertSpendRecords",
        "summary": "Upsert one or multiple spend records",
        "tags": [
          "Spend"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/SpendEntry"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SpendEntry"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Invalid request body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Upsert one or multiple spend records"
      },
      "delete": {
        "operationId": "deleteSpendRecord",
        "summary": "Delete a spend record",
        "tags": [
          "Spend"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SpendDeleteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SpendEntry"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete a spend record"
      }
    },
    "/spend_hourly": {
      "get": {
        "operationId": "listHourlySpendRecords",
        "summary": "List hourly spend records",
        "tags": [
          "Spend"
        ],
        "parameters": [
          {
            "name": "hour_start_iso_begin",
            "in": "query",
            "description": "Hour range start (ISO datetime)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "hour_start_iso_end",
            "in": "query",
            "description": "Hour range end (ISO datetime)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "platform_account_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "campaign_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1000,
              "maximum": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpendListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List hourly spend records"
      },
      "post": {
        "operationId": "upsertHourlySpendRecords",
        "summary": "Upsert hourly spend records",
        "tags": [
          "Spend"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/HourlySpendEntry"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HourlySpendEntry"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Upsert hourly spend records"
      },
      "delete": {
        "operationId": "deleteHourlySpendRecord",
        "summary": "Delete a hourly spend record",
        "tags": [
          "Spend"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "hour_start_iso",
                  "campaign_id"
                ],
                "properties": {
                  "hour_start_iso": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "campaign_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HourlySpendEntry"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete a hourly spend record"
      }
    }
  },
  "components": {
    "schemas": {
      "SpendEntry": {
        "type": "object",
        "required": [
          "date",
          "platform_name",
          "campaign_id",
          "campaign_name",
          "spend",
          "spend_currency"
        ],
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "platform_name": {
            "type": "string"
          },
          "platform_account_id": {
            "type": "string"
          },
          "campaign_id": {
            "type": "string"
          },
          "campaign_name": {
            "type": "string"
          },
          "adset_id": {
            "type": "string"
          },
          "adset_name": {
            "type": "string"
          },
          "ad_id": {
            "type": "string"
          },
          "ad_name": {
            "type": "string"
          },
          "spend": {
            "type": "number"
          },
          "spend_currency": {
            "type": "string"
          },
          "impressions": {
            "type": "integer"
          },
          "clicks": {
            "type": "integer"
          }
        }
      },
      "HourlySpendEntry": {
        "type": "object",
        "required": [
          "hour_start_iso",
          "platform_name",
          "campaign_id",
          "campaign_name",
          "spend",
          "spend_currency"
        ],
        "properties": {
          "hour_start_iso": {
            "type": "string",
            "format": "date-time"
          },
          "platform_name": {
            "type": "string"
          },
          "campaign_id": {
            "type": "string"
          },
          "campaign_name": {
            "type": "string"
          },
          "spend": {
            "type": "number"
          },
          "spend_currency": {
            "type": "string"
          }
        }
      },
      "SpendDeleteRequest": {
        "type": "object",
        "required": [
          "date",
          "campaign_id"
        ],
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "campaign_id": {
            "type": "string"
          },
          "platform_account_id": {
            "type": "string"
          },
          "adset_id": {
            "type": "string"
          },
          "ad_id": {
            "type": "string"
          }
        }
      },
      "SpendListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SpendEntry"
            }
          },
          "page": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "request_id": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      },
      "clientId": {
        "type": "apiKey",
        "in": "header",
        "name": "Data-Client-ID"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": [],
      "clientId": []
    }
  ],
  "tags": [
    {
      "name": "Spend"
    }
  ]
}
