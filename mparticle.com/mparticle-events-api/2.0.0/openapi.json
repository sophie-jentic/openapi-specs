  "components": {
    "schemas": {
      "EventBatch": {
        "type": "object",
        "required": [
          "events",
          "environment"
        ],
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          },
          "source_request_id": {
            "type": "string"
          },
          "environment": {
            "type": "string",
            "enum": [
              "development",
              "production"
            ]
          },
          "user_identities": {
            "type": "object",
            "properties": {
              "customer_id": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "other": {
                "type": "string"
              }
            }
          },
          "user_attributes": {
            "type": "object"
          },
          "device_info": {
            "type": "object",
            "properties": {
              "brand": {
                "type": "string"
              },
              "product": {
                "type": "string"
              },
              "device": {
                "type": "string"
              },
              "os_version": {
                "type": "string"
              },
              "platform": {
                "type": "string"
              }
            }
          },
          "application_info": {
            "type": "object",
            "properties": {
              "application_name": {
                "type": "string"
              },
              "application_version": {
                "type": "string"
              },
              "package": {
                "type": "string"
              }
            }
          },
          "ip": {
            "type": "string"
          },
          "schema_version": {
            "type": "integer",
            "default": 2
          },
          "mpid": {
            "type": "string"
          }
        }
      },
      "Event": {
        "type": "object",
        "required": [
          "data",
          "event_type"
        ],
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "event_name": {
                "type": "string"
              },
              "custom_event_type": {
                "type": "string",
                "enum": [
                  "navigation",
                  "location",
                  "search",
                  "transaction",
                  "user_content",
                  "user_preference",
                  "social",
                  "other"
                ]
              },
              "custom_attributes": {
                "type": "object"
              },
              "timestamp_unixtime_ms": {
                "type": "integer"
              }
            }
          },
          "event_type": {
            "type": "string",
            "enum": [
              "custom_event",
              "screen_view",
              "commerce_event",
              "session_start",
              "session_end",
              "crash_report",
              "opt_out",
              "first_run",
              "application_state_transition",
              "push_registration",
              "push_message",
              "user_attribute_change",
              "user_identity_change",
              "breadcrumb"
            ]
          }
        }
      },
      "IdentityRequest": {
        "type": "object",
        "properties": {
          "client_sdk": {
            "type": "object"
          },
          "known_identities": {
            "type": "object",
            "properties": {
              "customer_id": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "device_application_stamp": {
                "type": "string"
              }
            }
          },
          "environment": {
            "type": "string",
            "enum": [
              "development",
              "production"
            ]
          },
          "previous_mpid": {
            "type": "string"
          }
        }
      },
      "IdentityModifyRequest": {
        "type": "object",
        "properties": {
          "identity_changes": {
