{
  "openapi": "3.0.3",
  "info": {
    "title": "mParticle Events API",
    "version": "2.0.0",
    "description": "mParticle Events API for ingesting customer data events. Send custom events, screen views, commerce events, user identity changes, and more. Also includes the Platform API for managing inputs, outputs, and configuration.",
    "x-jentic-source-url": "https://docs.mparticle.com/developers/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://s2s.mparticle.com/v2",
      "description": "Events API"
    },
    {
      "url": "https://api.mparticle.com/v1",
      "description": "Platform API"
    }
  ],
  "tags": [
    {
      "name": "Events",
      "description": "Event ingestion endpoints"
    },
    {
      "name": "Bulk",
      "description": "Bulk event processing"
    },
    {
      "name": "Data Planning",
      "description": "Data plan management"
    },
    {
      "name": "Platform",
      "description": "Platform configuration API"
    },
    {
      "name": "Audiences",
      "description": "Audience management"
    },
    {
      "name": "Profile",
      "description": "User profile access"
    }
  ],
  "paths": {
    "/events": {
      "post": {
        "operationId": "sendEvents",
        "summary": "Send events",
        "description": "Send a batch of events to mParticle. Supports custom events, screen views, commerce events, and more.",
        "tags": [
          "Events"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EventBatch"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Events accepted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
