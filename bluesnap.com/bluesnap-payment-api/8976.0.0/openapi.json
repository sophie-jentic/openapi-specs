            "type": "string"
          }
        }
      },
      "TransactionInput": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "cardTransactionType": {
            "type": "string",
            "enum": [
              "AUTH_CAPTURE",
              "AUTH_ONLY"
            ]
          }
        }
      },
      "TransactionUpdate": {
        "type": "object",
        "properties": {
          "cardTransactionType": {
            "type": "string",
            "enum": [
