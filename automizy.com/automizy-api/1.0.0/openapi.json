{
  "openapi": "3.0.3",
  "info": {
    "title": "Automizy API",
    "version": "1.0.0",
    "description": "Automizy is an email marketing automation platform. The API provides access to contacts, lists, campaigns, automations, and email sending.",
    "x-jentic-source-url": "https://automizy.com",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://gateway.automizy.com/v2",
      "description": "Automizy API v2"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Contacts",
      "description": "Contact management"
    },
    {
      "name": "Lists",
      "description": "Contact list management"
    },
    {
      "name": "Campaigns",
      "description": "Email campaign management"
    },
    {
      "name": "Automations",
      "description": "Email automation management"
    },
    {
      "name": "Custom Fields",
      "description": "Custom field management"
    },
    {
      "name": "Tags",
      "description": "Tag management"
    },
    {
      "name": "Forms",
      "description": "Signup form management"
    }
