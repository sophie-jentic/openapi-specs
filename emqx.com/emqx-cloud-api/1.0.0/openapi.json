{
  "openapi": "3.0.3",
  "info": {
    "title": "EMQX Cloud API",
    "version": "1.0.0",
    "description": "EMQX Cloud Platform and Deployment REST API for managing MQTT broker deployments, projects, TLS certificates, clients, subscriptions, and message publishing.",
    "x-jentic-source-url": "https://docs.emqx.com/en/cloud/latest/api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://cloud-api.emqx.com/api/v1",
      "description": "EMQX Cloud Platform API"
    },
    {
      "url": "https://{deployment_host}:8443/api",
      "description": "EMQX Cloud Deployment API",
      "variables": {
        "deployment_host": {
          "default": "deployment_host"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Deployments",
      "description": "Manage EMQX Cloud deployments"
    },
    {
      "name": "Projects",
      "description": "Manage projects"
    },
    {
      "name": "TLS Certificates",
      "description": "Manage TLS certificates for deployments"
    },
    {
      "name": "Clients",
      "description": "View MQTT client connections"
    },
    {
      "name": "Subscriptions",
      "description": "View MQTT subscriptions"
    },
    {
      "name": "Messages",
      "description": "Publish MQTT messages"
    }
  ],
