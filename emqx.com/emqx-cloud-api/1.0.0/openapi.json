    "/clients": {
      "get": {
        "operationId": "listClients",
        "summary": "Get all client connections",
        "description": "Retrieve all client connection information within the deployment, with support for pagination.",
        "tags": [
          "Clients"
        ],
        "parameters": [
          {
            "name": "_page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Page number"
          },
          {
            "name": "_limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of data entries per page"
          },
          {
            "name": "clientid",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Client identifier"
          },
          {
            "name": "username",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Client username"
          },
          {
            "name": "ip_address",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Client IP address"
          },
          {
            "name": "conn_state",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "connected",
                "disconnected"
              ]
            },
            "description": "Connection state"
          },
          {
            "name": "clean_start",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Whether the client uses a new session"
          },
          {
            "name": "proto_ver",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Protocol version"
          },
          {
            "name": "_like_clientid",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Fuzzy search by client ID"
          },
          {
            "name": "_like_username",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Fuzzy search by username"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientListResponse"
                }
              }
