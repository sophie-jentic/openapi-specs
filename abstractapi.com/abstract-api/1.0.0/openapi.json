  "paths": {
    "/v1/": {
      "get": {
        "operationId": "ipGeolocation",
        "summary": "IP Geolocation lookup",
        "description": "Get geolocation data for an IP address including city, region, country, timezone, currency, and security info",
        "tags": [
          "IP Geolocation"
        ],
        "servers": [
          {
            "url": "https://ipgeolocation.abstractapi.com"
          }
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key"
          },
          {
            "name": "ip_address",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "IP address to look up (omit for caller's IP)"
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of fields to return"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ip_address": {
                      "type": "string"
                    },
                    "city": {
                      "type": "string",
                      "nullable": true
                    },
                    "region": {
                      "type": "string"
                    },
                    "country": {
                      "type": "string"
                    },
                    "country_code": {
                      "type": "string"
                    },
                    "continent": {
                      "type": "string"
                    },
                    "latitude": {
                      "type": "number"
                    },
                    "longitude": {
                      "type": "number"
                    },
                    "timezone": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "abbreviation": {
                          "type": "string"
                        },
                        "utc_offset": {
                          "type": "number"
                        }
                      }
                    },
                    "flag": {
                      "type": "object",
                      "properties": {
                        "emoji": {
                          "type": "string"
                        },
                        "png": {
                          "type": "string"
                        },
                        "svg": {
                          "type": "string"
                        }
                      }
                    },
                    "currency": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "code": {
                          "type": "string"
                        },
                        "symbol": {
                          "type": "string"
                        }
                      }
                    },
                    "security": {
                      "type": "object",
                      "properties": {
                        "is_vpn": {
                          "type": "boolean"
                        },
                        "is_proxy": {
                          "type": "boolean"
                        },
                        "is_tor": {
                          "type": "boolean"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/email-validation": {
      "get": {
        "operationId": "emailValidation",
        "summary": "Validate email address",
        "description": "Validate an email address checking format, MX records, SMTP, and disposable status",
        "tags": [
          "Email Validation"
        ],
        "servers": [
          {
            "url": "https://emailvalidation.abstractapi.com"
          }
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Email to validate"
          },
          {
            "name": "auto_correct",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Attempt auto-correction"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "type": "string"
                    },
                    "autocorrect": {
                      "type": "string"
                    },
                    "deliverability": {
                      "type": "string",
                      "enum": [
                        "DELIVERABLE",
                        "UNDELIVERABLE",
                        "UNKNOWN"
                      ]
                    },
                    "quality_score": {
                      "type": "number"
                    },
                    "is_valid_format": {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "boolean"
                        },
                        "text": {
                          "type": "string"
                        }
                      }
                    },
                    "is_free_email": {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "boolean"
                        },
                        "text": {
                          "type": "string"
                        }
                      }
                    },
                    "is_disposable_email": {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "boolean"
                        },
                        "text": {
                          "type": "string"
                        }
                      }
                    },
                    "is_role_email": {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "boolean"
                        },
                        "text": {
                          "type": "string"
                        }
                      }
                    },
                    "is_catchall_email": {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "boolean"
                        },
                        "text": {
                          "type": "string"
                        }
                      }
                    },
                    "is_mx_found": {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "boolean"
                        },
                        "text": {
                          "type": "string"
                        }
                      }
                    },
                    "is_smtp_valid": {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "boolean"
                        },
                        "text": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/phone-validation": {
      "get": {
        "operationId": "phoneValidation",
        "summary": "Validate phone number",
        "description": "Validate and parse a phone number",
        "tags": [
          "Phone Validation"
        ],
        "servers": [
          {
            "url": "https://phonevalidation.abstractapi.com"
          }
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "phone",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Phone number to validate"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "2-letter country code"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phone": {
                      "type": "string"
                    },
                    "valid": {
                      "type": "boolean"
                    },
                    "format": {
                      "type": "object",
                      "properties": {
                        "international": {
                          "type": "string"
                        },
                        "local": {
                          "type": "string"
                        }
                      }
                    },
                    "country": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        },
                        "prefix": {
                          "type": "string"
                        }
                      }
                    },
                    "location": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    },
                    "carrier": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/exchange-rates": {
      "get": {
        "operationId": "liveExchangeRates",
        "summary": "Get live exchange rates",
        "description": "Get the latest exchange rates for a base currency",
        "tags": [
          "Exchange Rates"
        ],
        "servers": [
          {
            "url": "https://exchangeratesapi.abstractapi.com"
          }
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "base",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Base currency code (e.g. USD)"
          },
          {
            "name": "target",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Target currency code(s), comma-separated"
          },
          {
            "name": "date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Historical date (YYYY-MM-DD)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "base": {
                      "type": "string"
                    },
                    "last_updated": {
                      "type": "integer"
                    },
                    "exchange_rates": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/convert": {
      "get": {
        "operationId": "convertCurrency",
        "summary": "Convert currency amount",
        "description": "Convert an amount from one currency to another",
        "tags": [
          "Exchange Rates"
        ],
        "servers": [
          {
            "url": "https://exchangeratesapi.abstractapi.com"
          }
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "base",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "target",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "base_amount",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/v1/vat-validate": {
      "get": {
        "operationId": "validateVat",
        "summary": "Validate a VAT number",
        "tags": [
          "VAT"
        ],
        "servers": [
          {
            "url": "https://vat.abstractapi.com"
          }
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "vat_number",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "vat_number": {
                      "type": "string"
                    },
                    "valid": {
                      "type": "boolean"
                    },
                    "company": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "address": {
                          "type": "string"
                        }
                      }
                    },
                    "country": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Validate a VAT number"
      }
    },
    "/v1/vat-rates": {
      "get": {
        "operationId": "getVatRates",
        "summary": "Get VAT rates for a country",
        "tags": [
          "VAT"
        ],
        "servers": [
          {
            "url": "https://vat.abstractapi.com"
          }
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "country_code",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "description": "Get VAT rates for a country"
      }
    },
    "/v1/holidays": {
      "get": {
        "operationId": "getHolidays",
        "summary": "Get public holidays",
