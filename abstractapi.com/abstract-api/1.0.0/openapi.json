            "description": "2-letter country code"
          },
          {
            "name": "year",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "month",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "day",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "name_local": {
                        "type": "string"
                      },
                      "language": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      },
                      "country": {
                        "type": "string"
                      },
                      "location": {
                        "type": "string"
                      },
                      "type": {
                        "type": "string"
                      },
                      "date": {
                        "type": "string"
                      },
                      "date_year": {
                        "type": "string"
                      },
                      "date_month": {
                        "type": "string"
                      },
                      "date_day": {
                        "type": "string"
                      },
                      "week_day": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
