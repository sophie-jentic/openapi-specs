{
  "openapi": "3.0.3",
  "info": {
    "title": "La Banque Postale PSD2 API",
    "description": "La Banque Postale Open Banking API providing account information (AISP), payment initiation (PISP), and card-based payment instruments (CBPII)",
    "version": "2.0.0",
    "x-jentic-source-url": "https://developer.labanquepostale.com/home",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.labanquepostale.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/v2/accounts": {
      "get": {
        "summary": "Retrieve accounts",
        "description": "Retrieve account information with corrected idResource valuation",
        "operationId": "getAccounts",
        "tags": [
          "AISP"
        ],
        "security": [
          {
            "oauth2": [
              "aisp"
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "Accounts retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accounts": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Account identifier"
                          },
                          "iban": {
                            "type": "string",
                            "description": "Account IBAN"
                          },
                          "currency": {
                            "type": "string",
                            "description": "Account currency"
                          },
                          "name": {
                            "type": "string",
                            "description": "Account name"
                          },
                          "type": {
                            "type": "string",
                            "description": "Account type"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/accounts/{id}/owners": {
      "get": {
        "summary": "Retrieve account owners",
        "description": "Retrieve account owners information",
        "operationId": "getAccountOwners",
        "tags": [
          "AISP"
        ],
        "security": [
          {
            "oauth2": [
              "aisp"
            ]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Account owners retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "owners": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string",
                            "description": "Owner name"
                          },
                          "type": {
                            "type": "string",
                            "description": "Owner type"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/accounts/{id}/overdrafts": {
      "get": {
        "summary": "Retrieve account overdrafts",
        "description": "Retrieve overdraft details for an account",
        "operationId": "getAccountOverdrafts",
        "tags": [
          "AISP"
        ],
        "security": [
          {
            "oauth2": [
              "aisp"
            ]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Overdraft details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "overdraftLimit": {
                      "type": "number",
                      "description": "Overdraft limit"
                    },
                    "availableOverdraft": {
                      "type": "number",
                      "description": "Available overdraft amount"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/transactions": {
      "get": {
        "summary": "Retrieve transactions",
        "description": "Retrieve transaction history (90 days available)",
        "operationId": "getTransactions",
        "tags": [
          "AISP"
        ],
        "security": [
          {
            "oauth2": [
              "aisp"
            ]
          }
        ],
        "parameters": [
          {
            "name": "accountId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account identifier"
          },
          {
            "name": "fromDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date for transactions"
          },
          {
            "name": "toDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date for transactions"
          }
        ],
        "responses": {
          "200": {
            "description": "Transactions retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transactions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Transaction identifier"
                          },
                          "amount": {
                            "type": "number",
                            "description": "Transaction amount"
                          },
                          "currency": {
                            "type": "string",
                            "description": "Transaction currency"
                          },
                          "date": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Transaction date"
                          },
                          "description": {
                            "type": "string",
                            "description": "Transaction description"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/balances": {
      "get": {
        "summary": "Retrieve balances",
        "description": "Retrieve account balances with corrected amount format",
        "operationId": "getBalances",
        "tags": [
          "AISP"
        ],
        "security": [
          {
            "oauth2": [
              "aisp"
            ]
          }
        ],
        "parameters": [
          {
            "name": "accountId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Balances retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "balances": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "description": "Balance type"
                          },
                          "amount": {
                            "type": "number",
                            "description": "Balance amount"
                          },
                          "currency": {
                            "type": "string",
                            "description": "Balance currency"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/payment-requests": {
      "post": {
        "summary": "Initiate payment request",
        "description": "Initiate a payment request",
        "operationId": "createPaymentRequest",
        "tags": [
          "PISP"
        ],
        "security": [
          {
            "oauth2": [
              "pisp"
            ]
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "debtorAccount",
                  "creditorAccount",
                  "amount",
                  "currency"
                ],
                "properties": {
                  "debtorAccount": {
                    "type": "object",
                    "properties": {
                      "iban": {
                        "type": "string",
                        "description": "Debtor IBAN"
                      }
                    }
                  },
                  "creditorAccount": {
                    "type": "object",
                    "properties": {
                      "iban": {
                        "type": "string",
                        "description": "Creditor IBAN"
                      }
                    }
                  },
                  "amount": {
                    "type": "number",
                    "description": "Payment amount"
                  },
                  "currency": {
                    "type": "string",
                    "description": "Payment currency"
                  },
                  "reference": {
                    "type": "string",
                    "description": "Payment reference"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Payment request created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Payment request identifier"
                    },
                    "status": {
                      "type": "string",
                      "description": "Payment status"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/payment-requests/{id}": {
      "get": {
        "summary": "Retrieve payment request",
        "description": "Retrieve payment request status",
        "operationId": "getPaymentRequest",
        "tags": [
          "PISP"
        ],
        "security": [
          {
            "oauth2": [
              "pisp"
            ]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Payment request identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Payment request retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Payment request identifier"
                    },
                    "status": {
                      "type": "string",
                      "description": "Payment status"
                    },
                    "amount": {
                      "type": "number",
                      "description": "Payment amount"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Payment request not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/payment-requests/{id}/confirmation": {
      "post": {
        "summary": "Confirm payment request",
        "description": "Confirm payment authorization",
        "operationId": "confirmPaymentRequest",
        "tags": [
          "PISP"
        ],
        "security": [
          {
            "oauth2": [
              "pisp"
            ]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Payment request identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Payment confirmed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Payment request identifier"
                    },
                    "status": {
                      "type": "string",
                      "description": "Payment status"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Payment request not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://api.labanquepostale.com/authorize",
            "tokenUrl": "https://api.labanquepostale.com/token",
            "scopes": {
              "aisp": "Account information access",
              "pisp": "Payment initiation access",
              "cbpii": "Card-based payment instrument access"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "AISP",
      "description": "Account Information Service Provider operations"
    },
    {
      "name": "PISP",
      "description": "Payment Initiation Service Provider operations"
    }
  ]
}
