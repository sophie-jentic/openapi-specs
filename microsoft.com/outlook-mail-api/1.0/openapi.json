            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "string", "description": "Error code." },
                    "message": { "type": "string", "description": "Error message." },
                    "innerError": {
                      "type": "object",
                      "properties": {
                        "request-id": { "type": "string" },
                        "date": { "type": "string", "format": "date-time" }
                      }
                    }
                  },
                  "required": ["code", "message"]
                }
              }
            }
          }
        }
      }
    },
    "schemas": {
      "Message": {
        "type": "object",
        "description": "An email message in a user's mailbox.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the message.",
            "readOnly": true
          },
          "subject": {
            "type": "string",
            "description": "The subject of the message."
          },
          "body": {
            "$ref": "#/components/schemas/ItemBody"
          },
          "bodyPreview": {
            "type": "string",
            "description": "The first 255 characters of the message body in text format.",
            "readOnly": true
          },
          "from": {
            "$ref": "#/components/schemas/Recipient",
            "description": "The mailbox owner and sender of the message."
          },
          "sender": {
            "$ref": "#/components/schemas/Recipient",
            "description": "The account used to generate the message."
          },
          "toRecipients": {
            "type": "array",
