{
  "openapi": "3.0.3",
  "info": {
    "title": "Microsoft Graph Mail API (Outlook Mail)",
    "description": "The Microsoft Graph Mail API provides access to Outlook mail data including messages, mail folders, and attachments. This is the successor to the Hotmail/Outlook.com mail APIs, now unified under the Microsoft Graph v1.0 endpoint. Supports reading, sending, replying, forwarding, and organizing email in user mailboxes on Exchange Online (Microsoft 365) and hybrid deployments.",
    "version": "1.0",
    "contact": {
      "name": "Microsoft Graph Support",
      "url": "https://developer.microsoft.com/graph/support"
    },
    "license": {
      "name": "Microsoft API License",
      "url": "https://learn.microsoft.com/en-us/legal/microsoft-apis/terms-of-use"
    }
  },
  "externalDocs": {
    "description": "Microsoft Graph Mail API Overview",
    "url": "https://learn.microsoft.com/en-us/graph/api/resources/mail-api-overview"
  },
  "servers": [
    {
      "url": "https://graph.microsoft.com/v1.0",
      "description": "Microsoft Graph v1.0 endpoint"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "Messages",
      "description": "Operations on email messages"
    },
    {
      "name": "Mail Folders",
      "description": "Operations on mail folders"
    },
    {
      "name": "Attachments",
      "description": "Operations on message attachments"
    },
    {
      "name": "Send Mail",
      "description": "Sending email messages"
    }
  ],
  "paths": {
    "/me/messages": {
      "get": {
        "tags": ["Messages"],
        "operationId": "listMessages",
        "summary": "List messages",
        "description": "Get all the messages in the signed-in user's mailbox (including the Deleted Items and Clutter folders).",
        "parameters": [
          { "$ref": "#/components/parameters/top" },
          { "$ref": "#/components/parameters/skip" },
          { "$ref": "#/components/parameters/filter" },
          { "$ref": "#/components/parameters/select" },
          { "$ref": "#/components/parameters/orderby" },
          { "$ref": "#/components/parameters/search" },
          { "$ref": "#/components/parameters/count" }
        ],
        "responses": {
          "200": {
            "description": "A collection of messages.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "@odata.context": { "type": "string" },
                    "@odata.nextLink": { "type": "string" },
                    "@odata.count": { "type": "integer" },
                    "value": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Message" }
                    }
                  }
                }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "post": {
        "tags": ["Messages"],
        "operationId": "createDraftMessage",
        "summary": "Create draft message",
        "description": "Create a draft of a new message in the signed-in user's mailbox.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Message" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created draft message.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" }
      ],
      "get": {
        "tags": ["Messages"],
        "operationId": "getMessage",
        "summary": "Get message",
        "description": "Read properties and relationships of a message object.",
        "parameters": [
          { "$ref": "#/components/parameters/select" }
        ],
        "responses": {
          "200": {
            "description": "The requested message.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "patch": {
        "tags": ["Messages"],
        "operationId": "updateMessage",
        "summary": "Update message",
        "description": "Update the properties of a message object.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Message" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated message.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "delete": {
        "tags": ["Messages"],
        "operationId": "deleteMessage",
        "summary": "Delete message",
        "description": "Delete a message in the specified user's mailbox, or delete a relationship of the message.",
        "responses": {
          "204": {
            "description": "Message deleted successfully."
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}/copy": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" }
      ],
      "post": {
        "tags": ["Messages"],
        "operationId": "copyMessage",
        "summary": "Copy message",
        "description": "Copy a message to a folder.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "destinationId": {
                    "type": "string",
                    "description": "The destination folder ID, or a well-known folder name."
                  }
                },
                "required": ["destinationId"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The copied message.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}/move": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" }
      ],
      "post": {
        "tags": ["Messages"],
        "operationId": "moveMessage",
        "summary": "Move message",
        "description": "Move the message to a folder. This creates a new copy of the message in the destination folder.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "destinationId": {
                    "type": "string",
                    "description": "The destination folder ID, or a well-known folder name."
                  }
                },
                "required": ["destinationId"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The moved message.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}/reply": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" }
      ],
      "post": {
        "tags": ["Messages"],
        "operationId": "replyToMessage",
        "summary": "Reply to message",
        "description": "Reply to the sender of a message. The message is then saved in the Sent Items folder.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": { "$ref": "#/components/schemas/Message" },
                  "comment": {
                    "type": "string",
                    "description": "A comment to include with the reply."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Reply sent successfully."
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}/replyAll": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" }
      ],
      "post": {
        "tags": ["Messages"],
        "operationId": "replyAllToMessage",
        "summary": "Reply all to message",
        "description": "Reply to all recipients of a message. The message is then saved in the Sent Items folder.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": { "$ref": "#/components/schemas/Message" },
                  "comment": {
                    "type": "string",
                    "description": "A comment to include with the reply."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Reply all sent successfully."
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}/forward": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" }
      ],
      "post": {
        "tags": ["Messages"],
        "operationId": "forwardMessage",
        "summary": "Forward message",
        "description": "Forward a message. The message is then saved in the Sent Items folder.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "toRecipients": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Recipient" },
                    "description": "The recipients to forward the message to."
                  },
                  "message": { "$ref": "#/components/schemas/Message" },
                  "comment": {
                    "type": "string",
                    "description": "A comment to include with the forwarded message."
                  }
                },
                "required": ["toRecipients"]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Message forwarded successfully."
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}/createReply": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" }
      ],
      "post": {
        "tags": ["Messages"],
        "operationId": "createReplyDraft",
        "summary": "Create draft reply",
        "description": "Create a draft of a reply message. You can then update or send the draft.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": { "$ref": "#/components/schemas/Message" },
                  "comment": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created draft reply message.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}/createReplyAll": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" }
      ],
      "post": {
        "tags": ["Messages"],
        "operationId": "createReplyAllDraft",
        "summary": "Create draft reply-all",
        "description": "Create a draft of a reply-all message. You can then update or send the draft.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": { "$ref": "#/components/schemas/Message" },
                  "comment": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created draft reply-all message.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}/createForward": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" }
      ],
      "post": {
        "tags": ["Messages"],
        "operationId": "createForwardDraft",
        "summary": "Create draft forward",
        "description": "Create a draft of a forward message. You can then update or send the draft.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": { "$ref": "#/components/schemas/Message" },
                  "toRecipients": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Recipient" }
                  },
                  "comment": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created draft forward message.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}/send": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" }
      ],
      "post": {
        "tags": ["Send Mail"],
        "operationId": "sendDraftMessage",
        "summary": "Send a draft message",
        "description": "Send a previously created message draft. The message is then saved in the Sent Items folder.",
        "responses": {
          "202": {
            "description": "Draft message sent successfully."
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/sendMail": {
      "post": {
        "tags": ["Send Mail"],
        "operationId": "sendMail",
        "summary": "Send mail",
        "description": "Send the message specified in the request body. The message is saved in the Sent Items folder by default.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "$ref": "#/components/schemas/Message",
                    "description": "The message to send."
                  },
                  "saveToSentItems": {
                    "type": "boolean",
                    "description": "Indicates whether to save the message in Sent Items. Default is true.",
                    "default": true
                  }
                },
                "required": ["message"]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Mail accepted for delivery."
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/mailFolders": {
      "get": {
        "tags": ["Mail Folders"],
        "operationId": "listMailFolders",
        "summary": "List mail folders",
        "description": "Get all the mail folders in the signed-in user's mailbox, including any mail search folders.",
        "parameters": [
          { "$ref": "#/components/parameters/top" },
          { "$ref": "#/components/parameters/skip" },
          { "$ref": "#/components/parameters/filter" },
          { "$ref": "#/components/parameters/select" },
          {
            "name": "includeHiddenFolders",
            "in": "query",
            "description": "Include hidden mail folders in the response.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A collection of mail folders.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "@odata.context": { "type": "string" },
                    "@odata.nextLink": { "type": "string" },
                    "value": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/MailFolder" }
                    }
                  }
                }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "post": {
        "tags": ["Mail Folders"],
        "operationId": "createMailFolder",
        "summary": "Create mail folder",
        "description": "Create a new mail folder in the root folder of the user's mailbox.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MailFolder" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created mail folder.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MailFolder" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/mailFolders/{mailFolder-id}": {
      "parameters": [
        { "$ref": "#/components/parameters/mailFolderId" }
      ],
      "get": {
        "tags": ["Mail Folders"],
        "operationId": "getMailFolder",
        "summary": "Get mail folder",
        "description": "Read properties and relationships of a mailFolder object.",
        "parameters": [
          { "$ref": "#/components/parameters/select" }
        ],
        "responses": {
          "200": {
            "description": "The requested mail folder.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MailFolder" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "patch": {
        "tags": ["Mail Folders"],
        "operationId": "updateMailFolder",
        "summary": "Update mail folder",
        "description": "Update the properties of a mailFolder object.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MailFolder" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated mail folder.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MailFolder" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "delete": {
        "tags": ["Mail Folders"],
        "operationId": "deleteMailFolder",
        "summary": "Delete mail folder",
        "description": "Delete the specified mailFolder. The folder can be a mailSearchFolder.",
        "responses": {
          "204": {
            "description": "Mail folder deleted successfully."
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/mailFolders/{mailFolder-id}/copy": {
      "parameters": [
        { "$ref": "#/components/parameters/mailFolderId" }
      ],
      "post": {
        "tags": ["Mail Folders"],
        "operationId": "copyMailFolder",
        "summary": "Copy mail folder",
        "description": "Copy a mailFolder and its contents to another mailFolder.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "destinationId": {
                    "type": "string",
                    "description": "The folder ID or well-known folder name of the destination."
                  }
                },
                "required": ["destinationId"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The copied mail folder.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MailFolder" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/mailFolders/{mailFolder-id}/move": {
      "parameters": [
        { "$ref": "#/components/parameters/mailFolderId" }
      ],
      "post": {
        "tags": ["Mail Folders"],
        "operationId": "moveMailFolder",
        "summary": "Move mail folder",
        "description": "Move a mailFolder and its contents to another mailFolder.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "destinationId": {
                    "type": "string",
                    "description": "The folder ID or well-known folder name of the destination."
                  }
                },
                "required": ["destinationId"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The moved mail folder.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MailFolder" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/mailFolders/{mailFolder-id}/childFolders": {
      "parameters": [
        { "$ref": "#/components/parameters/mailFolderId" }
      ],
      "get": {
        "tags": ["Mail Folders"],
        "operationId": "listChildFolders",
        "summary": "List child folders",
        "description": "Get the folder collection under the specified folder.",
        "parameters": [
          { "$ref": "#/components/parameters/top" },
          { "$ref": "#/components/parameters/skip" },
          { "$ref": "#/components/parameters/filter" },
          { "$ref": "#/components/parameters/select" }
        ],
        "responses": {
          "200": {
            "description": "A collection of child mail folders.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "@odata.context": { "type": "string" },
                    "@odata.nextLink": { "type": "string" },
                    "value": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/MailFolder" }
                    }
                  }
                }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "post": {
        "tags": ["Mail Folders"],
        "operationId": "createChildFolder",
        "summary": "Create child folder",
        "description": "Create a new child mailFolder under the current one.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MailFolder" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created child mail folder.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MailFolder" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/mailFolders/{mailFolder-id}/messages": {
      "parameters": [
        { "$ref": "#/components/parameters/mailFolderId" }
      ],
      "get": {
        "tags": ["Messages", "Mail Folders"],
        "operationId": "listMessagesInFolder",
        "summary": "List messages in folder",
        "description": "Get all the messages in the specified mail folder.",
        "parameters": [
          { "$ref": "#/components/parameters/top" },
          { "$ref": "#/components/parameters/skip" },
          { "$ref": "#/components/parameters/filter" },
          { "$ref": "#/components/parameters/select" },
          { "$ref": "#/components/parameters/orderby" },
          { "$ref": "#/components/parameters/search" },
          { "$ref": "#/components/parameters/count" }
        ],
        "responses": {
          "200": {
            "description": "A collection of messages in the folder.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "@odata.context": { "type": "string" },
                    "@odata.nextLink": { "type": "string" },
                    "@odata.count": { "type": "integer" },
                    "value": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Message" }
                    }
                  }
                }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "post": {
        "tags": ["Messages", "Mail Folders"],
        "operationId": "createMessageInFolder",
        "summary": "Create message in folder",
        "description": "Create a new message in the specified mail folder.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Message" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created message.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}/attachments": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" }
      ],
      "get": {
        "tags": ["Attachments"],
        "operationId": "listAttachments",
        "summary": "List attachments",
        "description": "Retrieve a list of attachment objects attached to a message.",
        "parameters": [
          { "$ref": "#/components/parameters/select" },
          { "$ref": "#/components/parameters/filter" }
        ],
        "responses": {
          "200": {
            "description": "A collection of attachments.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "@odata.context": { "type": "string" },
                    "value": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Attachment" }
                    }
                  }
                }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "post": {
        "tags": ["Attachments"],
        "operationId": "addAttachment",
        "summary": "Add attachment",
        "description": "Add a file, item, or link attachment to a message. This operation limits the size of the attachment to under 3 MB. For larger files, use the upload session API.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FileAttachment" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created attachment.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Attachment" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/me/messages/{message-id}/attachments/{attachment-id}": {
      "parameters": [
        { "$ref": "#/components/parameters/messageId" },
        { "$ref": "#/components/parameters/attachmentId" }
      ],
      "get": {
        "tags": ["Attachments"],
        "operationId": "getAttachment",
        "summary": "Get attachment",
        "description": "Read the properties, relationships, or raw contents of an attachment attached to a message.",
        "parameters": [
          { "$ref": "#/components/parameters/select" }
        ],
        "responses": {
          "200": {
            "description": "The requested attachment.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Attachment" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "delete": {
        "tags": ["Attachments"],
        "operationId": "deleteAttachment",
        "summary": "Delete attachment",
        "description": "Delete an attachment from a message.",
