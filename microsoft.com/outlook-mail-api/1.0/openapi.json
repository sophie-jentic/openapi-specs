        "schema": { "type": "string" }
      },
      "attachmentId": {
        "name": "attachment-id",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the attachment.",
        "schema": { "type": "string" }
      },
      "top": {
        "name": "$top",
        "in": "query",
        "description": "Sets the page size of results.",
        "schema": { "type": "integer", "minimum": 0 }
