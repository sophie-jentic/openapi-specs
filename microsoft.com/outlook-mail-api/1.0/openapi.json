            "type": "array",
            "items": { "$ref": "#/components/schemas/Recipient" },
            "description": "The Cc: recipients for the message."
          },
          "bccRecipients": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Recipient" },
            "description": "The Bcc: recipients for the message."
          },
          "replyTo": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Recipient" },
            "description": "The email addresses to use when replying."
          },
          "conversationId": {
            "type": "string",
            "description": "The ID of the conversation the email belongs to.",
            "nullable": true
          },
          "conversationIndex": {
            "type": "string",
            "format": "byte",
            "description": "Indicates the position of the message within the conversation."
          },
          "receivedDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the message was received (UTC ISO 8601)."
          },
          "sentDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the message was sent (UTC ISO 8601)."
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the message was created (UTC ISO 8601).",
            "readOnly": true
          },
          "lastModifiedDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the message was last changed (UTC ISO 8601).",
            "readOnly": true
          },
          "hasAttachments": {
            "type": "boolean",
            "description": "Indicates whether the message has attachments (excludes inline attachments)."
          },
          "importance": {
            "type": "string",
            "enum": ["low", "normal", "high"],
            "description": "The importance of the message."
          },
          "isRead": {
            "type": "boolean",
            "description": "Indicates whether the message has been read."
          },
          "isDraft": {
            "type": "boolean",
            "description": "Indicates whether the message is a draft."
          },
          "isDeliveryReceiptRequested": {
            "type": "boolean",
            "description": "Indicates whether a delivery receipt is requested.",
            "nullable": true
          },
          "isReadReceiptRequested": {
            "type": "boolean",
            "description": "Indicates whether a read receipt is requested."
          },
          "parentFolderId": {
            "type": "string",
            "description": "The unique identifier for the message's parent mailFolder."
          },
          "internetMessageId": {
            "type": "string",
            "description": "The message ID in the format specified by RFC 2822."
          },
          "internetMessageHeaders": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/InternetMessageHeader" },
            "description": "A collection of message headers defined by RFC 5322. Returned only on $select."
          },
          "categories": {
            "type": "array",
            "items": { "type": "string" },
            "description": "The categories associated with the message."
          },
          "flag": {
            "$ref": "#/components/schemas/FollowupFlag"
          },
          "inferenceClassification": {
            "type": "string",
            "enum": ["focused", "other"],
            "description": "The classification of the message for the user based on inferred relevance."
