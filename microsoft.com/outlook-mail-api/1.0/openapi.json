          "changeKey": {
            "type": "string",
            "description": "The version of the message.",
            "readOnly": true
          },
          "webLink": {
            "type": "string",
            "description": "The URL to open the message in Outlook on the web.",
            "readOnly": true
          },
          "uniqueBody": {
            "$ref": "#/components/schemas/ItemBody",
            "description": "The part of the body unique to the current message. Returned only on $select."
          },
          "attachments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Attachment" },
            "description": "The file and item attachments for the message."
          }
        }
      },
      "MailFolder": {
        "type": "object",
