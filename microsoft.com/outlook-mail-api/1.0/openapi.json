        "in": "query",
        "description": "Orders results.",
        "schema": { "type": "string" }
      },
      "search": {
        "name": "$search",
        "in": "query",
        "description": "Searches for specific content.",
        "schema": { "type": "string" }
      },
      "count": {
        "name": "$count",
        "in": "query",
        "description": "Includes a count of the total number of items in a collection.",
        "schema": { "type": "boolean" }
