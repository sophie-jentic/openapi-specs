        },
        "targetId": {
          "type": "string",
          "description": "the id of the source object"
        },
        "accountType": {
          "type": "string",
          "description": "Recharge, Sundry, Master, etc"
        },
        "rentGroupType": {
          "type": "string",
          "description": "Major Works, etc"
        },
        "agreementType": {
          "type": "string",
          "description": "M, R, S, X"
        },
        "accountBalance": {
          "type": "number",
          "format": "double",
          "multipleOf": 0.01,
