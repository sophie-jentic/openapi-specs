  "paths": {
    "/accounts": {
      "get": {
        "description": "Gets a collection of accounts for a person or organisation",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "in": "query",
            "name": "type",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved a collection of accounts",
            "schema": {
              "$ref": "#/definitions/getAccounts"
            }
          },
          "400": {
            "description": "Invalid query parameters supplied"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "tags": [
          "accounts"
        ],
        "operationId": "get-accounts"
      },
      "post": {
        "description": "Creates a new account for a person",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "createAccountDetails",
            "schema": {
              "$ref": "#/definitions/createAccountDetails"
            },
            "required": true
          }
        ],
        "responses": {
          "201": {
            "description": "Successfully created account"
          },
          "400": {
            "description": "Invalid account object provided"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "tags": [
          "accounts"
        ],
        "operationId": "post-accounts"
      }
    },
    "/accounts/arrears": {
      "get": {
        "description": "Gets a collection of accounts that are in arrears",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "type",
            "type": "string"
          },
          {
            "in": "query",
            "name": "sort",
            "type": "string"
          },
          {
            "in": "query",
            "name": "direction",
            "type": "string"
          },
          {
            "in": "query",
            "name": "resultsCount",
            "type": "number"
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved a collection of accounts",
            "schema": {
              "$ref": "#/definitions/getAccounts"
            }
          },
          "400": {
            "description": "Invalid query parameters supplied"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "tags": [
          "accounts"
        ],
        "operationId": "get-accounts-arrears"
      }
    },
    "/accounts/{id}": {
      "get": {
        "description": "Gets a single account record from the supplied id",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved details for a particular account",
            "schema": {
              "$ref": "#/definitions/getAccountDetails"
            }
          },
          "400": {
            "description": "Invalid account id provided"
          },
          "404": {
            "description": "Account not found for id requested"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "tags": [
          "accounts"
        ],
        "operationId": "get-accounts-by-id"
      },
      "put": {
        "description": "Creates a new account for a person",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "updateAccountDetails",
            "schema": {
              "$ref": "#/definitions/updateAccountDetails"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Account has been updated"
          },
          "400": {
            "description": "Invalid account object provided"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "tags": [
          "accounts"
        ],
        "operationId": "put-accounts-by-id"
      }
    }
  },
  "host": "virtserver.swaggerhub.com",
  "basePath": "/Hackney/accountsApi/1.0.0",
  "definitions": {
    "createAccountDetails": {
      "type": "object",
      "properties": {
        "targetType": {
          "type": "string"
        },
        "targetId": {
          "type": "string",
          "description": "id for an account"
        },
        "accountType": {
          "type": "string",
          "description": "Recharge, Master, etc"
        },
        "rentGroupType": {
          "type": "string",
          "description": "Major Works, etc"
        },
        "agreementType": {
          "type": "string"
        },
        "startDate": {
          "type": "string",
          "format": "date-time"
        },
        "accountStatus": {
          "type": "string",
          "enum": [
            "active",
            "suspended",
            "ended"
          ]
        }
      }
    },
    "updateAccountDetails": {
      "type": "object",
      "properties": {
        "accountBalance": {
          "type": "number",
          "format": "double",
          "multipleOf": 0.01
        },
        "startDate": {
          "type": "string",
          "format": "date-time"
        },
        "endDate": {
          "type": "string",
          "format": "date-time"
        },
        "accountStatus": {
          "type": "string",
          "enum": [
            "active",
            "suspended",
            "ended"
          ]
        },
        "accountType": {
          "type": "string",
          "description": "Recharge, Master, etc"
        },
        "rentGroupType": {
          "type": "string",
          "description": "Major Works, etc"
        },
        "agreementType": {
          "type": "string"
        },
        "consolidatedCharges": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/consolidatedCharge"
          }
        },
        "tenure": {
          "type": "object",
          "description": "basic information on the tenure associated with this account",
          "properties": {
            "tenancyId": {
              "type": "string",
              "format": "GUID",
              "description": "the id of the tenancy"
            },
            "tenancyType": {
              "type": "string",
              "description": "the type of tenancy"
            },
            "primaryTenants": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/primaryTenant"
              }
            },
            "fullAddress": {
              "type": "string",
              "description": "the full address of the tenancy",
              "example": "1 Hillman Street, Hackney, E8 1DY"
            }
          }
        }
      }
    },
    "getAccountDetails": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "GUID",
