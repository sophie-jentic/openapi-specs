{
  "openapi": "3.0.3",
  "info": {
    "title": "Skyscanner Travel API",
    "version": "2.0",
    "description": "Skyscanner Travel APIs providing access to flights live and indicative prices, car hire prices, hotels live prices, culture data (markets, locales, currencies), and geo data (airports, cities, countries). Supports over 52 markets, 30 languages, and 1,300+ supply partners.",
    "x-jentic-source-url": "https://developers.skyscanner.net/docs/intro"
  },
  "servers": [
    {
      "url": "https://partners.api.skyscanner.net/apiservices/v3"
    }
  ],
  "paths": {
    "/flights/live/search/create": {
      "post": {
        "operationId": "createFlightLiveSearch",
        "summary": "Create a flights live price search",
        "description": "Initiates a live price search for flights. Returns a session token to poll for results.",
        "tags": [
          "Flights Live Prices"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FlightSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search session created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/flights/live/search/poll/{sessionToken}": {
      "post": {
        "operationId": "pollFlightLiveSearch",
        "summary": "Poll flight live search results",
        "description": "Polls for updated results from a live flight price search session.",
        "tags": [
          "Flights Live Prices"
        ],
        "parameters": [
          {
            "name": "sessionToken",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/flights/indicative/search": {
      "post": {
        "operationId": "searchFlightIndicativePrices",
        "summary": "Search indicative flight prices",
        "description": "Returns indicative (cached) flight prices for route/date combinations. Useful for inspiration and calendar views.",
        "tags": [
          "Flights Indicative Prices"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IndicativeSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Indicative prices",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndicativeSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
