    "/culture/markets": {
      "get": {
        "operationId": "listMarkets",
        "summary": "List supported markets",
        "description": "Returns all markets (countries) supported by Skyscanner.",
        "tags": [
          "Culture"
        ],
        "parameters": [
          {
            "name": "locale",
            "in": "query",
            "description": "Locale code",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en-US"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Markets list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
