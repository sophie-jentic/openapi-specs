    "/geo/hierarchy/flights/{locale}": {
      "get": {
        "operationId": "getGeoHierarchy",
        "summary": "Get geo hierarchy for flights",
        "description": "Returns full catalogue of supported locations (airports, cities, countries, continents).",
        "tags": [
