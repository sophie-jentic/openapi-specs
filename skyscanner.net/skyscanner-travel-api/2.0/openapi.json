  },
  "components": {
    "schemas": {
      "FlightSearchRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "object",
            "properties": {
              "market": {
                "type": "string"
              },
              "locale": {
                "type": "string"
              },
              "currency": {
                "type": "string"
              },
              "queryLegs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "originPlaceId": {
                      "type": "object",
                      "properties": {
                        "iata": {
                          "type": "string"
                        }
                      }
                    },
                    "destinationPlaceId": {
                      "type": "object",
                      "properties": {
                        "iata": {
                          "type": "string"
                        }
                      }
                    },
                    "date": {
                      "type": "object",
                      "properties": {
                        "year": {
                          "type": "integer"
                        },
                        "month": {
                          "type": "integer"
                        },
                        "day": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              },
              "cabinClass": {
                "type": "string",
                "enum": [
                  "CABIN_CLASS_ECONOMY",
                  "CABIN_CLASS_PREMIUM_ECONOMY",
                  "CABIN_CLASS_BUSINESS",
                  "CABIN_CLASS_FIRST"
                ]
              },
              "adults": {
                "type": "integer"
              }
            }
          }
        }
      },
      "FlightSearchResponse": {
        "type": "object",
        "properties": {
          "sessionToken": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "content": {
            "type": "object",
            "properties": {
              "results": {
                "type": "object"
              },
              "sortingOptions": {
                "type": "object"
              }
            }
          }
        }
      },
      "IndicativeSearchRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "object"
          }
        }
      },
      "IndicativeSearchResponse": {
        "type": "object",
        "properties": {
          "content": {
            "type": "object"
          }
        }
      },
      "CarHireSearchRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "object"
          }
        }
      },
      "CarHireSearchResponse": {
        "type": "object",
        "properties": {
          "sessionToken": {
            "type": "string"
          },
          "results": {
            "type": "object"
          }
        }
      },
      "HotelSearchRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "object"
          }
        }
      },
      "MarketsResponse": {
        "type": "object",
        "properties": {
          "markets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Skyscanner partner API key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}