{
  "openapi": "3.0.0",
  "info": {
    "title": "Host.io API",
    "description": "Domain name data API providing DNS details, scraped website content, outbound links, backlinks, and hosting details for any domain.",
    "version": "1.0.0",
    "contact": {
      "name": "Host.io",
      "url": "https://host.io"
    }
  },
  "servers": [
    {
      "url": "https://host.io/api",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "httpBasic": []
    },
    {
      "bearerAuth": []
    },
    {
      "apiKeyQuery": []
    }
  ],
  "paths": {
    "/web/{domain}": {
      "get": {
        "summary": "Get domain metadata",
        "description": "Returns metadata scraped from a domain homepage including rank, title, links, copyright, and IP address",
        "operationId": "getDomainMetadata",
        "tags": [
          "Domain Info"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "description": "Domain name",
            "schema": {
              "type": "string",
              "example": "facebook.com"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebMetadata"
                }
              }
            }
          },
          "404": {
            "description": "Domain not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/dns/{domain}": {
      "get": {
        "summary": "Get DNS records",
        "description": "Returns DNS records (A, AAAA, MX, NS) for a specified domain",
        "operationId": "getDNSRecords",
        "tags": [
          "Domain Info"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "description": "Domain name",
            "schema": {
              "type": "string",
              "example": "facebook.com"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DNSRecords"
                }
              }
            }
          },
          "404": {
            "description": "Domain not found"
          }
        }
      }
    },
    "/related/{domain}": {
      "get": {
        "summary": "Get related domains count",
        "description": "Returns count of related domains across all supported lookup fields",
        "operationId": "getRelatedDomains",
        "tags": [
          "Domain Info"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "description": "Domain name",
            "schema": {
              "type": "string",
              "example": "facebook.com"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RelatedDomains"
                }
              }
            }
          }
        }
      }
    },
    "/full/{domain}": {
      "get": {
        "summary": "Get full domain information",
        "description": "Returns combined data from web, DNS, related endpoints plus IPinfo geolocation",
        "operationId": "getFullDomainInfo",
        "tags": [
          "Domain Info"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "description": "Domain name",
            "schema": {
              "type": "string",
              "example": "facebook.com"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FullDomainInfo"
                }
              }
            }
          },
          "401": {
            "description": "API Access Token Required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/domains/{field}/{value}": {
      "get": {
        "summary": "List domains by field",
        "description": "Lists all domains matching a specific field-value pair",
        "operationId": "listDomainsByField",
        "tags": [
          "Domain Search"
        ],
        "parameters": [
          {
            "name": "field",
            "in": "path",
            "required": true,
            "description": "Field name to search",
            "schema": {
              "type": "string",
              "enum": [
                "ip",
                "ns",
                "mx",
                "asn",
                "backlinks",
                "redirects",
                "adsense",
                "facebook",
                "twitter",
                "instagram",
                "gtm",
                "googleanalytics",
                "email"
              ]
            }
          },
          {
            "name": "value",
            "in": "path",
            "required": true,
            "description": "Value to search for",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Results per page",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1,
                5,
                10,
                25,
                100,
                250,
                1000
              ],
              "default": 25
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number (zero-indexed)",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DomainList"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "httpBasic": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      },
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "API token as query parameter"
      }
    },
    "schemas": {
      "WebMetadata": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "Domain name"
          },
          "rank": {
            "type": "integer",
            "description": "Domain rank"
          },
          "title": {
            "type": "string",
            "description": "Page title"
          },
          "description": {
            "type": "string",
            "description": "Meta description"
          },
          "links": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Links found on the homepage"
          },
          "copyright": {
            "type": "string",
            "description": "Copyright information"
          },
          "ip": {
            "type": "string",
            "description": "IP address"
          },
          "adsense": {
            "type": "string",
            "description": "Google AdSense ID"
          },
          "facebook": {
            "type": "string",
            "description": "Facebook page ID"
          },
          "twitter": {
            "type": "string",
            "description": "Twitter handle"
          },
          "instagram": {
            "type": "string",
            "description": "Instagram handle"
          },
          "gtm": {
            "type": "string",
            "description": "Google Tag Manager ID"
          },
          "googleanalytics": {
            "type": "string",
            "description": "Google Analytics ID"
          }
        }
      },
      "DNSRecords": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "Domain name"
          },
          "a": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "A records"
          },
          "aaaa": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "AAAA records"
          },
          "mx": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "MX records"
          },
          "ns": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "NS records"
          }
        }
      },
      "RelatedDomains": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "Domain name"
          },
          "ip": {
            "type": "integer",
            "description": "Count of domains with same IP"
          },
          "ns": {
            "type": "integer",
            "description": "Count of domains with same nameserver"
          },
          "mx": {
            "type": "integer",
            "description": "Count of domains with same mail server"
          },
          "asn": {
            "type": "integer",
            "description": "Count of domains in same ASN"
          },
          "backlinks": {
            "type": "integer",
            "description": "Count of domains linking to this domain"
          },
          "redirects": {
            "type": "integer",
            "description": "Count of domains redirecting to this domain"
          }
        }
      },
      "FullDomainInfo": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "Domain name"
          },
          "rank": {
            "type": "integer",
            "description": "Domain rank"
          },
          "title": {
            "type": "string",
            "description": "Page title"
          },
          "description": {
            "type": "string",
            "description": "Meta description"
          },
          "links": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Links found on homepage"
          },
          "ip": {
            "type": "string",
            "description": "IP address"
          },
          "dns": {
            "$ref": "#/components/schemas/DNSRecords"
          },
          "ipinfo": {
            "type": "object",
            "properties": {
              "city": {
                "type": "string"
              },
              "region": {
                "type": "string"
              },
              "country": {
                "type": "string"
              },
              "loc": {
                "type": "string"
              },
              "org": {
                "type": "string"
              },
              "postal": {
                "type": "string"
              },
              "timezone": {
                "type": "string"
              }
            }
          },
          "related": {
            "$ref": "#/components/schemas/RelatedDomains"
          }
        }
      },
      "DomainList": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "description": "Total number of results"
          },
          "page": {
            "type": "integer",
            "description": "Current page"
          },
          "limit": {
            "type": "integer",
            "description": "Results per page"
          },
          "domains": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "domain": {
                  "type": "string"
                },
                "rank": {
                  "type": "integer"
                }
              }
            },
            "description": "List of domains"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Domain Info"
    },
    {
      "name": "Domain Search"
    }
  ]
}
