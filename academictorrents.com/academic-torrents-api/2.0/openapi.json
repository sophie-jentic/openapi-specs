{
  "openapi": "3.0.3",
  "info": {
    "title": "Academic Torrents API",
    "version": "2.0",
    "description": "API for Academic Torrents, a community-maintained distributed repository for sharing enormous research datasets using BitTorrent. Allows creating, retrieving, and modifying torrent entries and managing collections.",
    "x-jentic-source-url": "https://academictorrents.com/docs/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://academictorrents.com/apiv2"
    }
  ],
  "paths": {
    "/entry/{infoHash}": {
      "get": {
        "operationId": "getEntry",
        "summary": "Get entry by info hash",
        "description": "Retrieve data about a specific torrent entry using its info hash.",
        "tags": [
          "Entries"
        ],
        "parameters": [
          {
            "name": "infoHash",
            "in": "path",
            "required": true,
            "description": "The info hash of the torrent entry",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Entry"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Entry not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "updateEntry",
        "summary": "Modify an entry",
        "description": "Modify an existing torrent entry. Requires authentication via API key.",
        "tags": [
          "Entries"
        ],
        "parameters": [
          {
            "name": "infoHash",
            "in": "path",
            "required": true,
            "description": "The info hash of the torrent entry to modify",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/EntryInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Entry"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/entry": {
      "post": {
        "operationId": "createEntry",
        "summary": "Upload a new entry",
        "description": "Upload a new torrent entry to Academic Torrents. Requires authentication via API key (uid and pass).",
        "tags": [
          "Entries"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/EntryCreateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Entry"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/collection": {
      "post": {
        "operationId": "createCollection",
        "summary": "Create a collection",
        "description": "Create a new collection. Requires authentication.",
        "tags": [
          "Collections"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CollectionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Collection created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Collection"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/collection/{collectionName}": {
      "post": {
        "operationId": "updateCollection",
        "summary": "Update a collection",
        "description": "Update an existing collection. Requires authentication.",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "collectionName",
            "in": "path",
            "required": true,
            "description": "Name of the collection to update",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CollectionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Collection updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Collection"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/collection/{collectionName}/delete": {
      "post": {
        "operationId": "deleteCollection",
        "summary": "Delete a collection",
        "description": "Delete an existing collection. Requires authentication.",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "collectionName",
            "in": "path",
            "required": true,
            "description": "Name of the collection to delete",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/collection/{collectionName}/add": {
      "post": {
        "operationId": "addItemToCollection",
        "summary": "Add an item to a collection",
        "description": "Add a torrent entry to an existing collection. Requires authentication.",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "collectionName",
            "in": "path",
            "required": true,
            "description": "Name of the collection",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "infoHash": {
                    "type": "string",
                    "description": "Info hash of the entry to add"
                  }
                },
                "required": [
                  "infoHash"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item added to collection successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/collection/{collectionName}/remove": {
      "post": {
        "operationId": "removeItemFromCollection",
        "summary": "Remove an item from a collection",
        "description": "Remove a torrent entry from an existing collection. Requires authentication.",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "collectionName",
            "in": "path",
            "required": true,
            "description": "Name of the collection",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "infoHash": {
                    "type": "string",
                    "description": "Info hash of the entry to remove"
                  }
                },
                "required": [
                  "infoHash"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item removed from collection successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/test": {
      "get": {
        "operationId": "testApiAccess",
        "summary": "Test API access",
        "description": "Test that your API key is valid and you have access rights. Can be used with GET or POST.",
        "tags": [
          "Testing"
        ],
        "parameters": [
          {
            "name": "uid",
            "in": "query",
            "description": "User ID for authentication",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pass",
            "in": "query",
            "description": "API key/password hash",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "API test result",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "testApiAccessPost",
        "summary": "Test API access (POST)",
        "description": "Test that your API key is valid and you have access rights using POST method.",
        "tags": [
          "Testing"
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "uid": {
                    "type": "integer",
                    "description": "User ID for authentication"
                  },
                  "pass": {
                    "type": "string",
                    "description": "API key/password hash"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "API test result",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Entry": {
        "type": "object",
        "properties": {
          "infoHash": {
            "type": "string",
            "description": "Unique info hash of the torrent"
          },
          "name": {
            "type": "string",
            "description": "Title of the publication or dataset"
          },
          "authors": {
            "type": "string",
            "description": "Authors of the publication"
          },
          "descr": {
            "type": "string",
            "description": "Description in BibTeX format"
          },
          "category": {
            "type": "integer",
            "description": "Category ID"
          },
          "tags": {
            "type": "string",
            "description": "Comma-separated tags"
          },
          "urllist": {
            "type": "string",
            "description": "Comma-separated list of backup URLs"
          },
          "size": {
            "type": "integer",
            "description": "Total size in bytes"
          },
          "numFiles": {
            "type": "integer",
            "description": "Number of files in the torrent"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          }
        }
      },
      "EntryInput": {
        "type": "object",
        "properties": {
          "uid": {
            "type": "integer",
            "description": "User ID for authentication"
          },
          "pass": {
            "type": "string",
            "description": "API key/password hash"
          },
          "name": {
            "type": "string",
            "description": "The title of the publication"
          },
          "authors": {
            "type": "string",
            "description": "Authors (e.g., 'Author1 and Author2')"
          },
          "descr": {
            "type": "string",
            "description": "Description in BibTeX format"
          },
          "category": {
            "type": "integer",
            "description": "Category ID (e.g., 6)"
          },
          "tags": {
            "type": "string",
            "description": "Comma-separated tags"
          },
          "urllist": {
            "type": "string",
            "description": "Comma-separated backup file URLs"
          }
        }
      },
      "EntryCreateInput": {
        "type": "object",
        "required": [
          "name",
          "uid",
          "pass"
        ],
        "properties": {
          "uid": {
            "type": "integer",
            "description": "User ID for authentication"
          },
          "pass": {
            "type": "string",
            "description": "API key/password hash"
          },
          "name": {
            "type": "string",
            "description": "The title of the publication"
          },
          "authors": {
            "type": "string",
            "description": "Authors (e.g., 'Author1 and Author2')"
          },
          "descr": {
            "type": "string",
            "description": "Description in BibTeX format"
          },
          "category": {
            "type": "integer",
            "description": "Category ID"
          },
          "tags": {
            "type": "string",
            "description": "Comma-separated tags"
          },
          "urllist": {
            "type": "string",
            "description": "Comma-separated backup file URLs"
          },
          "file": {
            "type": "string",
            "format": "byte",
            "description": "Base64-encoded torrent file (data:application/x-bittorrent;base64,...)"
          }
        }
      },
      "Collection": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Collection name"
          },
          "entries": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of info hashes in the collection"
          }
        }
      },
      "CollectionInput": {
        "type": "object",
        "properties": {
          "uid": {
            "type": "integer",
            "description": "User ID for authentication"
          },
          "pass": {
            "type": "string",
            "description": "API key/password hash"
          },
          "name": {
            "type": "string",
            "description": "Collection name"
          },
          "description": {
            "type": "string",
            "description": "Collection description"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "uid;pass",
        "description": "Authentication via uid and pass cookies. Set cookies: uid={user_id};pass={api_key_hash}"
      },
      "queryAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "uid",
        "description": "Authentication via uid and pass query parameters"
      }
    }
  },
  "security": [
    {
      "cookieAuth": []
    }
  ],
  "tags": [
    {
      "name": "Collections"
    },
    {
      "name": "Entries"
    },
    {
      "name": "Testing"
    }
  ]
}
