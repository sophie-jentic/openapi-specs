{
  "openapi": "3.0.3",
  "info": {
    "title": "Liaison API",
    "version": "1.2.0",
    "description": "Liaison (Spectrum EMP) API for managing student enrollment forms, field rules, and student sources. Supports form submission, field requirement retrieval, and source management.",
    "x-jentic-source-url": "http://api-docs.spectrumemp.com",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.spectrumemp.com/api"
    }
  ],
  "paths": {
    "/forms/requirements": {
      "get": {
        "operationId": "getFormRequirements",
        "summary": "Get form field requirements",
        "description": "Find all fields and field options for form submission.",
        "tags": [
          "Forms"
        ],
        "parameters": [
          {
            "name": "IQS-API-KEY",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client API key"
          },
          {
            "name": "formID",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Form identifier; defaults to Inquiry Form"
          }
        ],
        "responses": {
          "200": {
            "description": "Form field requirements",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FormRequirements"
                }
              }
            }
          },
          "404": {
            "description": "Form not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/forms/submit": {
      "post": {
        "operationId": "submitForm",
        "summary": "Submit a form",
        "description": "Submit form data with field values.",
        "tags": [
          "Forms"
        ],
        "parameters": [
          {
            "name": "IQS-API-KEY",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client API key"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "formID": {
                    "type": "integer",
                    "description": "Form identifier"
                  },
                  "SOURCE": {
                    "type": "integer",
                    "description": "Supplemental source ID"
                  },
                  "UPDATE-EXISTING-PROSPECTS": {
                    "type": "boolean",
                    "description": "Legacy flag for updating prospect info"
                  }
                },
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Form submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Form not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/forms/submittable": {
      "get": {
        "operationId": "getSubmittableForms",
        "summary": "Get submittable forms",
        "description": "Find all non-event SEM forms with their identifiers.",
        "tags": [
          "Forms"
        ],
        "parameters": [
          {
            "name": "IQS-API-KEY",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client API key"
          }
        ],
        "responses": {
          "200": {
            "description": "List of submittable forms",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SubmittableForm"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Forms not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/field_rules/all_client_rules": {
      "get": {
        "operationId": "getAllFieldRules",
        "summary": "Get all field rule dependencies",
        "description": "Find all field rule dependencies between fields.",
        "tags": [
          "Field Rules"
        ],
        "parameters": [
          {
            "name": "CLIENT-ID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Client ID provided with API access"
          }
        ],
        "responses": {
          "200": {
            "description": "Field rule dependencies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/field_rules/field_options": {
      "post": {
        "operationId": "getFieldOptions",
        "summary": "Get dependent field options (deprecated)",
        "description": "Find all fields and options dependent on submitted values. This endpoint is deprecated.",
        "tags": [
          "Field Rules"
        ],
        "deprecated": true,
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "field_id": {
                    "type": "integer"
                  },
                  "option_id": {
                    "type": "string"
                  },
                  "CLIENT-ID": {
                    "type": "integer"
                  }
                },
                "required": [
                  "field_id",
                  "option_id",
                  "CLIENT-ID"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dependent field options",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sources/list": {
      "get": {
        "operationId": "listSources",
        "summary": "List student sources",
        "description": "Retrieve all available student sources.",
        "tags": [
          "Sources"
        ],
        "parameters": [
          {
            "name": "IQS-API-KEY",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client API key"
          }
        ],
        "responses": {
          "200": {
            "description": "Student sources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StudentSource"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Sources not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FormRequirements": {
        "type": "object",
        "properties": {
          "formId": {
            "type": "integer"
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FormField"
            }
          }
        }
      },
      "FormField": {
        "type": "object",
        "properties": {
          "fieldId": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "type": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "SubmittableForm": {
        "type": "object",
        "properties": {
          "formId": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "StudentSource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "IQS-API-KEY",
        "description": "Client API key for authentication"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Field Rules"
    },
    {
      "name": "Forms"
    },
    {
      "name": "Sources"
    }
  ]
}
