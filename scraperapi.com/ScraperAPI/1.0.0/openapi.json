{
  "openapi": "3.1.0",
  "info": {
    "title": "ScraperAPI",
    "version": "1.0.0",
    "description": "ScraperAPI handles proxies, browsers, and CAPTCHAs so you can scrape any web page with a simple API call. Supports web pages, API endpoints, images, documents, PDFs, and other files with a 50MB maximum request size limit.",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.scraperapi.com",
      "description": "Primary API endpoint"
    },
    {
      "url": "https://async.scraperapi.com",
      "description": "Asynchronous requests endpoint"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Scrape Web Page",
        "description": "Scrape any web page by providing the target URL and your API key. Recommended timeout: 70 seconds.",
        "operationId": "scrapeGet",
        "parameters": [
          {
            "$ref": "#/components/parameters/api_key"
          },
          {
            "$ref": "#/components/parameters/url"
          },
          {
            "$ref": "#/components/parameters/render"
          },
          {
            "$ref": "#/components/parameters/country_code"
          },
          {
            "$ref": "#/components/parameters/premium"
          },
          {
            "$ref": "#/components/parameters/session_number"
          },
          {
            "$ref": "#/components/parameters/keep_headers"
          },
          {
            "$ref": "#/components/parameters/device_type"
          },
          {
            "$ref": "#/components/parameters/wait_for_selector"
          },
          {
            "$ref": "#/components/parameters/autoparse"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response containing the scraped content",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                },
                "example": "<!DOCTYPE html><html>...</html>"
              },
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "data": "..."
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        },
        "tags": [
          "default"
        ]
      },
      "post": {
        "summary": "Scrape Web Page (POST)",
        "description": "Same as GET but using POST method. Useful for sending form data to the target URL.",
        "operationId": "scrapePost",
        "parameters": [
          {
            "$ref": "#/components/parameters/api_key"
          },
          {
            "$ref": "#/components/parameters/url"
          },
          {
            "$ref": "#/components/parameters/render"
          },
          {
            "$ref": "#/components/parameters/country_code"
          },
          {
            "$ref": "#/components/parameters/premium"
          },
          {
            "$ref": "#/components/parameters/session_number"
          },
          {
            "$ref": "#/components/parameters/keep_headers"
          },
          {
            "$ref": "#/components/parameters/device_type"
          },
          {
            "$ref": "#/components/parameters/wait_for_selector"
          },
          {
            "$ref": "#/components/parameters/autoparse"
          }
        ],
        "requestBody": {
          "description": "Request body to forward to the target URL",
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response containing the scraped content",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        },
        "tags": [
          "default"
        ]
      }
    },
    "/account": {
      "get": {
        "summary": "Get Account Information",
        "description": "Retrieve account information including remaining API credits and usage statistics.",
        "operationId": "getAccount",
        "parameters": [
          {
            "$ref": "#/components/parameters/api_key"
          }
        ],
        "responses": {
          "200": {
            "description": "Account information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "requestLimit": {
                      "type": "integer",
                      "description": "Total request limit for the account"
                    },
                    "requestCount": {
                      "type": "integer",
                      "description": "Number of requests used"
                    },
                    "remainingRequests": {
                      "type": "integer",
                      "description": "Number of remaining requests"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "tags": [
          "account"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Your ScraperAPI key. Sign up to get 5,000 free API credits."
      }
    },
    "parameters": {
      "api_key": {
        "name": "api_key",
        "in": "query",
        "required": true,
        "description": "Your ScraperAPI key (required for all requests)",
        "schema": {
          "type": "string"
        },
        "example": "your_api_key_here"
      },
      "url": {
        "name": "url",
        "in": "query",
        "required": true,
        "description": "The URL of the page to scrape",
        "schema": {
          "type": "string",
          "format": "uri"
        },
        "example": "https://example.com"
      },
      "render": {
        "name": "render",
        "in": "query",
        "required": false,
        "description": "Enable JavaScript rendering. Set to 'true' for dynamic pages. Default: false",
        "schema": {
          "type": "boolean",
          "default": false
        },
        "example": true
      },
      "country_code": {
        "name": "country_code",
        "in": "query",
        "required": false,
        "description": "2-letter ISO country code for geolocation (e.g., 'us', 'gb', 'de')",
        "schema": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2
        },
        "example": "us"
      },
      "premium": {
        "name": "premium",
        "in": "query",
        "required": false,
        "description": "Use premium residential proxies. Set to 'true' for better success rates. Default: false",
        "schema": {
          "type": "boolean",
          "default": false
        },
        "example": true
      },
      "session_number": {
        "name": "session_number",
        "in": "query",
        "required": false,
        "description": "Session number for maintaining the same IP across multiple requests",
        "schema": {
          "type": "integer"
        },
        "example": 123
      },
      "keep_headers": {
        "name": "keep_headers",
        "in": "query",
        "required": false,
        "description": "Keep custom headers in the request. Set to 'true' to forward headers. Default: false",
        "schema": {
          "type": "boolean",
          "default": false
        },
        "example": true
      },
      "device_type": {
        "name": "device_type",
        "in": "query",
        "required": false,
        "description": "Device type for the request (desktop or mobile)",
        "schema": {
          "type": "string",
          "enum": [
            "desktop",
            "mobile"
          ],
          "default": "desktop"
        },
        "example": "desktop"
      },
      "wait_for_selector": {
        "name": "wait_for_selector",
        "in": "query",
        "required": false,
        "description": "CSS selector to wait for before returning the page. Only works with render=true",
        "schema": {
          "type": "string"
        },
        "example": ".content-loaded"
      },
      "autoparse": {
        "name": "autoparse",
        "in": "query",
        "required": false,
        "description": "Automatically parse structured data from the page. Set to 'true' to enable. Default: false",
        "schema": {
          "type": "boolean",
          "default": false
        },
        "example": true
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - missing or invalid parameters",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Missing required parameter: url"
                }
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid API key",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Invalid API key"
                }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden - insufficient credits or account suspended",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Insufficient API credits"
                }
              }
            }
          }
        }
      },
      "RateLimitExceeded": {
        "description": "Rate limit exceeded",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Rate limit exceeded. Please try again later."
                }
              }
            }
          }
        }
      },
      "ServerError": {
        "description": "Server error or scraping failure",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Failed to scrape the target URL"
                }
              }
            }
          }
        }
      }
    }
  },
  "externalDocs": {
    "description": "Official ScraperAPI documentation",
    "url": "https://docs.scraperapi.com"
  },
  "tags": [
    {
      "name": "account"
    },
    {
      "name": "default"
    }
  ]
}
