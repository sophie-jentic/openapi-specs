{
  "openapi": "3.0.3",
  "info": {
    "title": "PCP PMWEBAPI",
    "version": "3.0",
    "description": "Performance Co-Pilot (PCP) Web Application Programming Interface. Provides REST API access to PCP performance metrics, time series, full-text search, and live PMAPI host services via pmproxy.",
    "x-jentic-source-url": "https://man7.org/linux/man-pages/man3/pmwebapi.3.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://{pmproxy-host}:44322"
    }
  ],
  "paths": {
    "/metrics": {
      "get": {
        "operationId": "getMetrics",
        "summary": "Export metrics in OpenMetrics/OpenTelemetry format",
        "description": "Fetches current values and metadata for all metrics or specified metrics. Output format is selected via Accept header: text/plain for OpenMetrics, application/json for OpenTelemetry.",
        "tags": [
          "OpenMetrics"
        ],
        "parameters": [
          {
            "name": "names",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of metric name prefixes"
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of excluded metric names"
          },
          {
            "name": "match",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "exact",
                "glob",
                "regex"
              ]
            },
            "description": "Pattern matching style"
          },
          {
            "name": "times",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Append sample times (ms since epoch)"
          },
          {
            "name": "hostspec",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Host specification"
          }
        ],
        "responses": {
          "200": {
            "description": "Metrics in requested format",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/series/ping": {
      "get": {
        "operationId": "seriesPing",
        "summary": "Liveness test for series API",
        "tags": [
          "Series"
        ],
        "responses": {
          "200": {
            "description": "Server is up"
          }
        },
        "description": "Liveness test for series API"
      }
    },
    "/series/query": {
      "get": {
        "operationId": "seriesQuery",
        "summary": "Query time series",
        "description": "Performs a time series query for matching identifiers or identifiers with time-stamped values using pmseries query language.",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "expr",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Query string in pmseries format"
          },
          {
            "name": "client",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Request identifier echoed in response"
          }
        ],
        "responses": {
          "200": {
            "description": "Query results (series IDs or time-stamped values)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/series/values": {
      "get": {
        "operationId": "seriesValues",
        "summary": "Retrieve time series values",
        "description": "Retrieves values for one or more time series identifiers with optional time window parameters.",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "series",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of series identifiers"
          },
          {
            "name": "samples",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Count of samples to return"
          },
          {
            "name": "interval",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Time between successive samples"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sample window start time"
          },
          {
            "name": "finish",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sample window end time"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sample window offset"
          },
          {
            "name": "align",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sample time alignment"
          },
          {
            "name": "zone",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Time window timezone"
          },
          {
            "name": "client",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Series values",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SeriesValue"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/series/descs": {
      "get": {
        "operationId": "seriesDescs",
        "summary": "Lookup series descriptors",
        "description": "Performs a descriptor lookup for one or more time series identifiers including PMID, InDom, semantics, type, and units.",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "series",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated series identifiers"
          },
          {
            "name": "client",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Series descriptors",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SeriesDescriptor"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/series/labels": {
      "get": {
        "operationId": "seriesLabels",
        "summary": "Lookup series labels",
        "description": "Performs label set lookup for series identifiers, lists all known label names, or finds all values for given label names.",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "series",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated series identifiers"
          },
          {
            "name": "match",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Glob pattern to match on labels"
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Find all values for this label name"
          },
          {
            "name": "names",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of label names"
          },
          {
            "name": "client",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Labels data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/series/metrics": {
      "get": {
        "operationId": "seriesMetrics",
        "summary": "Lookup series metric names",
        "description": "Performs metric name lookup for series identifiers, or returns all known metric names.",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "series",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "match",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Glob pattern to match names"
          },
          {
            "name": "client",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Metric names",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/series/sources": {
      "get": {
        "operationId": "seriesSources",
        "summary": "Lookup series sources",
        "description": "Returns PMAPI context names for given source identifiers.",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "series",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "match",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "client",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Source data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SeriesSource"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/series/instances": {
      "get": {
        "operationId": "seriesInstances",
        "summary": "Lookup series instances",
        "description": "Returns instance identifiers and names for series identifiers, or all known instance names.",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "series",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "match",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "client",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Instance data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SeriesInstance"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/series/load": {
      "get": {
        "operationId": "seriesLoad",
        "summary": "Load time series data from source",
        "description": "Loads time series data from a specified source into the key-value server cache.",
        "tags": [
          "Series"
        ],
        "parameters": [
          {
            "name": "expr",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Source load string in pmseries format"
          },
          {
            "name": "client",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Load result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/search/text": {
      "get": {
        "operationId": "searchText",
        "summary": "Full-text search across metrics",
        "description": "Performs text search query across metrics, instance domains, and instances - all forms of names and help texts.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query string"
          },
          {
            "name": "highlight",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Include matching markup in response fields (name, oneline, helptext)"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Result offset for pagination"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Max results"
          },
          {
            "name": "field",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Queried fields (name, oneline, helptext)"
          },
          {
            "name": "return",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Fields to return (name, type, oneline, helptext, indom)"
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "metric",
                "indom",
                "instance"
              ]
            },
            "description": "Entity type filter"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchTextResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/search/suggest": {
      "get": {
        "operationId": "searchSuggest",
        "summary": "Search suggestions",
        "description": "Provides search query suggestions (metric and instance names).",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/search/indom": {
      "get": {
        "operationId": "searchIndom",
        "summary": "Search by instance domain",
        "description": "Returns all entities (instances, metrics) related to the given indom.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Target indom"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "InDom entities"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/search/info": {
      "get": {
        "operationId": "searchInfo",
        "summary": "Search engine statistics",
        "description": "Returns metrics about the search engine operation including document and text record counts.",
        "tags": [
          "Search"
        ],
        "responses": {
          "200": {
            "description": "Search engine stats",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchInfo"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/pmapi/context": {
      "get": {
        "operationId": "createContext",
        "summary": "Create a PMAPI context",
        "description": "Creates a PMAPI context for live sampling and returns a context identifier for subsequent requests.",
        "tags": [
          "PMAPI"
        ],
        "parameters": [
          {
            "name": "hostspec",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Host specification"
          },
          {
            "name": "polltimeout",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 5
            },
            "description": "Seconds of inactivity before closing context"
          },
          {
            "name": "client",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Context created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContextResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/pmapi/metric": {
      "get": {
        "operationId": "getMetricMetadata",
        "summary": "Get metric metadata",
        "description": "Returns detailed PMAPI metric metadata for one or more metrics including descriptors, labels, and help text.",
        "tags": [
          "PMAPI"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Individual metric name"
          },
          {
            "name": "names",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated metric names"
          },
          {
            "name": "pmid",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Numeric or string metric identifier"
          },
          {
            "name": "pmids",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated pmIDs"
          },
          {
            "name": "prefix",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "PMNS subtree prefix"
          },
          {
            "name": "hostspec",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "context",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Web context number"
          },
          {
            "name": "polltimeout",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "client",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Metric metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetricResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/pmapi/fetch": {
      "get": {
        "operationId": "fetchMetrics",
        "summary": "Fetch (sample) metric values",
        "description": "Fetches current values for given metrics. Returns values for all instances unless an InDom profile has been set.",
        "tags": [
          "PMAPI"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "names",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pmid",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pmids",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "delta",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sampling interval"
          },
          {
            "name": "hostspec",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "context",
