    "/v1/papago/n2mt": {
      "post": {
        "operationId": "translateText",
        "summary": "Translate text (Papago NMT)",
        "description": "Translate text between languages using NAVER Papago Neural Machine Translation. Supports Korean, English, Japanese, Chinese (Simplified/Traditional), Vietnamese, Thai, Indonesian, French, Spanish, Russian, German, Italian.",
        "tags": [
          "Translation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "source",
                  "target",
                  "text"
                ],
                "properties": {
                  "source": {
                    "type": "string",
                    "description": "Source language code (ko, en, ja, zh-CN, zh-TW, vi, th, id, fr, es, ru, de, it)",
                    "example": "ko"
                  },
                  "target": {
                    "type": "string",
                    "description": "Target language code",
                    "example": "en"
                  },
                  "text": {
                    "type": "string",
                    "description": "Text to translate (max 5000 characters)",
                    "maxLength": 5000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful translation response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - unsupported language pair or text too long"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/papago/detectLangs": {
      "post": {
        "operationId": "detectLanguage",
        "summary": "Detect language of text",
        "description": "Detect the language of the given text using Papago language detection.",
        "tags": [
          "Translation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "query"
                ],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Text to detect language for"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful language detection",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "langCode": {
                      "type": "string",
                      "description": "Detected language code (ko, en, ja, zh-CN, zh-TW, etc.)"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/papago/romanization": {
      "get": {
        "operationId": "romanizeKorean",
        "summary": "Romanize Korean text",
        "description": "Convert Korean text to romanized (Latin alphabet) representation.",
        "tags": [
          "Translation"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "Korean text to romanize",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful romanization",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "aResult": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "sFirstName": {
                            "type": "string"
                          },
                          "aItems": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "name": {
                                  "type": "string",
                                  "description": "Romanized text"
                                },
                                "score": {
                                  "type": "string",
                                  "description": "Confidence score"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/util/shorturl": {
