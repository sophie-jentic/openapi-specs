    "/oauth2.0/authorize": {
      "get": {
        "operationId": "naverLoginAuthorize",
        "summary": "NAVER Login OAuth2 authorization",
        "description": "Redirect users to NAVER Login page for OAuth2 authorization. Uses the nid.naver.com server.",
        "tags": [
          "Login"
        ],
        "servers": [
          {
            "url": "https://nid.naver.com",
            "description": "NAVER Login Server"
          }
        ],
        "security": [],
        "parameters": [
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "description": "Must be 'code'",
            "schema": {
              "type": "string",
              "enum": [
                "code"
              ]
            }
          },
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "description": "Application client ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": true,
            "description": "Callback URL registered with the application",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "description": "CSRF protection token",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to NAVER Login page"
          }
        }
      }
    },
    "/oauth2.0/token": {
      "get": {
        "operationId": "naverLoginToken",
        "summary": "Exchange code for access token",
        "description": "Exchange authorization code for an access token via NAVER Login OAuth2. Uses the nid.naver.com server.",
        "tags": [
          "Login"
        ],
        "servers": [
          {
            "url": "https://nid.naver.com",
            "description": "NAVER Login Server"
          }
        ],
        "security": [],
        "parameters": [
          {
            "name": "grant_type",
            "in": "query",
            "required": true,
            "description": "Grant type: authorization_code, refresh_token, or delete",
            "schema": {
              "type": "string",
              "enum": [
                "authorization_code",
                "refresh_token",
                "delete"
              ]
            }
          },
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "description": "Application client ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "client_secret",
            "in": "query",
            "required": true,
            "description": "Application client secret",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code",
            "in": "query",
            "required": false,
            "description": "Authorization code (required when grant_type is authorization_code)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "description": "CSRF state token (required when grant_type is authorization_code)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "refresh_token",
            "in": "query",
            "required": false,
            "description": "Refresh token (required when grant_type is refresh_token)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "access_token",
            "in": "query",
            "required": false,
            "description": "Access token to delete (required when grant_type is delete)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Token response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NaverTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
