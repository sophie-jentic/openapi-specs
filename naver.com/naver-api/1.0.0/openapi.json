{
  "openapi": "3.0.3",
  "info": {
    "title": "NAVER Open API",
    "description": "NAVER Open API provides access to NAVER platform services including Search, Login (OAuth), Papago Translation, URL Shortener, Map/Geocoding, and more. Authentication uses Client ID and Client Secret passed via request headers.",
    "version": "1.0.0",
    "contact": {
      "name": "NAVER Developers",
      "url": "https://developers.naver.com"
    }
  },
  "servers": [
    {
      "url": "https://openapi.naver.com",
      "description": "NAVER Open API Server"
    },
    {
      "url": "https://nid.naver.com",
      "description": "NAVER Login (OAuth) Server"
    }
  ],
  "security": [
    {
      "clientId": [],
      "clientSecret": []
    }
  ],
  "paths": {
    "/v1/search/blog.json": {
      "get": {
        "operationId": "searchBlog",
        "summary": "Search blogs",
        "description": "Search NAVER blog posts by keyword.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "Search keyword",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "display",
            "in": "query",
            "required": false,
            "description": "Number of results to display (default 10, max 100)",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "Start position of search results (default 1, max 1000)",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1,
              "maximum": 1000
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "Sort order: sim (similarity) or date",
            "schema": {
              "type": "string",
              "enum": [
                "sim",
                "date"
              ],
              "default": "sim"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid client credentials"
          }
        }
      }
    },
