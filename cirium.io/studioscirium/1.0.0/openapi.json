{
  "openapi": "3.0.3",
  "info": {
    "title": "Cirium FlightStats FIDS API",
    "version": "1.0.0",
    "description": "Flight Information Display System (FIDS) API for airport arrivals and departures data",
    "x-jentic-source-url": "https://developer.studios.cirium.io/apis/flightstats-apis/fids",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.flightstats.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "appIdQuery": [],
      "appKeyQuery": []
    },
    {
      "appIdHeader": [],
      "appKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Arrivals",
      "description": "Airport arrival information"
    },
    {
      "name": "Departures",
      "description": "Airport departure information"
    }
  ],
  "paths": {
    "/flex/fids/rest/v1/{format}/{airport}/arrivals": {
      "get": {
        "tags": [
          "Arrivals"
        ],
        "summary": "Retrieve FIDS display data for flights arriving at a given airport",
        "operationId": "byArrivalAirport",
        "parameters": [
          {
            "name": "format",
            "in": "path",
            "required": true,
            "description": "Response format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "jsonp",
                "xml"
              ]
            }
          },
          {
            "name": "airport",
            "in": "path",
            "required": true,
            "description": "Airport code (e.g., PDX)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "codeType",
            "in": "query",
            "description": "Airport code type",
            "schema": {
              "type": "string",
              "enum": [
                "IATA",
                "ICAO",
                "FS"
              ]
            }
          },
          {
            "name": "requestedFields",
            "in": "query",
            "description": "Comma-separated list of fields to include",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortFields",
            "in": "query",
            "description": "Sort precedence fields",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "excludeAirlines",
            "in": "query",
            "description": "Airlines to exclude",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeAirlines",
            "in": "query",
            "description": "Airlines to include",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeCodeshares",
            "in": "query",
            "description": "Include codeshare flights",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "terminal",
            "in": "query",
            "description": "Terminal filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timeFormat",
            "in": "query",
            "description": "12 or 24-hour format",
            "schema": {
              "type": "integer",
              "enum": [
                12,
                24
              ],
              "default": 12
            }
          },
          {
            "name": "timeWindowBegin",
            "in": "query",
            "description": "Minutes before now (0-1440)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1440
            }
          },
          {
            "name": "timeWindowEnd",
            "in": "query",
            "description": "Minutes after now (0-4320)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 4320
            }
          },
          {
            "name": "maxFlights",
            "in": "query",
            "description": "Maximum results returned",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "lateMinutes",
            "in": "query",
            "description": "Delay threshold (1-240)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 240,
              "default": 15
            }
          },
          {
            "name": "boardingMinutes",
            "in": "query",
            "description": "Boarding window (0-120)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 120
            }
          },
          {
            "name": "useRunwayTimes",
            "in": "query",
            "description": "Use runway times instead of gate times",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "excludeCargoOnlyFlights",
            "in": "query",
            "description": "Exclude cargo-only flights",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "extendedOptions",
            "in": "query",
            "description": "Array for special behavior",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "FIDS arrival data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FidsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        },
        "description": "Retrieve FIDS display data for flights arriving at a given airport"
      }
    },
    "/flex/fids/rest/v1/{format}/{airport}/departures": {
      "get": {
        "tags": [
          "Departures"
        ],
        "summary": "Retrieve FIDS display data for flights departing from a given airport",
        "operationId": "byDepartureAirport",
        "parameters": [
          {
            "name": "format",
            "in": "path",
            "required": true,
            "description": "Response format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "jsonp",
                "xml"
              ]
            }
          },
          {
            "name": "airport",
            "in": "path",
            "required": true,
            "description": "Airport code (e.g., PDX)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "codeType",
            "in": "query",
            "description": "Airport code type",
            "schema": {
              "type": "string",
              "enum": [
                "IATA",
                "ICAO",
                "FS"
              ]
            }
          },
          {
            "name": "requestedFields",
            "in": "query",
            "description": "Comma-separated list of fields to include",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortFields",
            "in": "query",
            "description": "Sort precedence fields",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "excludeAirlines",
            "in": "query",
            "description": "Airlines to exclude",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeAirlines",
            "in": "query",
            "description": "Airlines to include",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeCodeshares",
            "in": "query",
            "description": "Include codeshare flights",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "terminal",
            "in": "query",
            "description": "Terminal filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timeFormat",
            "in": "query",
            "description": "12 or 24-hour format",
            "schema": {
              "type": "integer",
              "enum": [
                12,
                24
              ],
              "default": 12
            }
          },
          {
            "name": "timeWindowBegin",
            "in": "query",
            "description": "Minutes before now (0-1440)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1440
            }
          },
          {
            "name": "timeWindowEnd",
            "in": "query",
            "description": "Minutes after now (0-4320)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 4320
            }
          },
          {
            "name": "maxFlights",
            "in": "query",
            "description": "Maximum results returned",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "lateMinutes",
            "in": "query",
            "description": "Delay threshold (1-240)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 240,
              "default": 15
            }
          },
          {
            "name": "boardingMinutes",
            "in": "query",
            "description": "Boarding window (0-120)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 120
            }
          },
          {
            "name": "useRunwayTimes",
            "in": "query",
            "description": "Use runway times instead of gate times",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "excludeCargoOnlyFlights",
            "in": "query",
            "description": "Exclude cargo-only flights",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "extendedOptions",
            "in": "query",
            "description": "Array for special behavior",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "FIDS departure data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FidsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        },
        "description": "Retrieve FIDS display data for flights departing from a given airport"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "appIdQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "appId"
      },
      "appKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "appKey"
      },
      "appIdHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "appId"
      },
      "appKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "appKey"
      }
    },
    "schemas": {
      "FidsResponse": {
        "type": "object",
        "properties": {
          "fidsData": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FlightInfo"
            }
          }
        }
      },
      "FlightInfo": {
        "type": "object",
        "properties": {
          "flightId": {
            "type": "string"
          },
          "carrierFsCode": {
            "type": "string"
          },
          "flightNumber": {
            "type": "string"
          },
          "departureAirportFsCode": {
            "type": "string"
          },
          "arrivalAirportFsCode": {
            "type": "string"
          },
          "departureDate": {
            "type": "object",
            "properties": {
              "dateUtc": {
                "type": "string",
                "format": "date-time"
              },
              "dateLocal": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "arrivalDate": {
            "type": "object",
            "properties": {
              "dateUtc": {
                "type": "string",
                "format": "date-time"
              },
              "dateLocal": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "status": {
            "type": "string"
          },
          "operationalTimes": {
            "type": "object"
          },
          "delays": {
            "type": "object"
          },
          "flightDurations": {
            "type": "object"
          },
          "airportResources": {
            "type": "object"
          },
          "flightEquipment": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Authentication credentials are missing or invalid",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFoundError": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}
