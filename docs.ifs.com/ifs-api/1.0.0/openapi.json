{
  "openapi": "3.0.3",
  "info": {
    "title": "IFS Applications API",
    "version": "1.0.0",
    "description": "IFS Applications integration API providing access to projections (integration endpoints) via OData-compatible REST services. Each projection generates its own OpenAPI documentation.",
    "x-jentic-source-url": "https://docs.ifs.com/techdocs/foundation1/045_administration_aurena/240_integration/010_api_doc/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{server}:{port}",
      "variables": {
        "server": {
          "default": "ifs-server",
          "description": "IFS server hostname"
        },
        "port": {
          "default": "443",
          "description": "Server port"
        }
      }
    }
  ],
  "paths": {
    "/int/ifsapplications/projection/v1/{projectionName}.svc/$openapi": {
      "get": {
        "operationId": "getProjectionOpenApi",
        "summary": "Get OpenAPI documentation for a projection",
        "description": "Outputs API documentation per OpenAPI standards in JSON format for a specific projection",
        "tags": [
          "Documentation"
        ],
        "parameters": [
          {
            "name": "projectionName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Projection name"
          },
          {
            "name": "V2",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Return OAS 2.0 format"
          },
          {
            "name": "V3",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Return OAS 3.0 format"
          }
        ],
        "responses": {
          "200": {
            "description": "OpenAPI specification JSON",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/main/ifsapplications/projection/v1/AllProjections.svc/Projections": {
      "get": {
        "operationId": "listProjections",
        "summary": "List all available integration projections",
        "description": "Retrieves all available integration projections that can be used as API endpoints",
        "tags": [
          "Projections"
        ],
        "parameters": [
          {
            "name": "$format",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "default": "json"
            }
          },
          {
            "name": "$filter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "OData filter expression"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectionListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProjectionListResponse": {
        "type": "object",
        "properties": {
          "value": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "Name": {
                  "type": "string"
                },
                "Description": {
                  "type": "string"
                },
                "Categories": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "IFS Authentication"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Documentation"
    },
    {
      "name": "Projections"
    }
  ]
}
