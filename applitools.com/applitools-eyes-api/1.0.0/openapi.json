{
  "openapi": "3.0.3",
  "info": {
    "title": "Applitools Eyes API",
    "version": "1.0.0",
    "description": "Applitools Eyes Server REST API for visual testing management. Provides programmatic access to batch results, batch statistics, batch properties, discussion comments, SCM integration status, and API key validation.",
    "x-jentic-source-url": "https://applitools.com/docs/eyes/reference/server-api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://eyes.applitools.com/api/v1"
    }
  ],
  "paths": {
    "/batches/{batchId}": {
      "get": {
        "operationId": "listBatchResults",
        "summary": "List batch results",
        "description": "Lists the results of all the tests (sessions) in a batch. Results can be filtered by start and end date.",
        "tags": [
          "Batches"
        ],
        "parameters": [
          {
            "name": "batchId",
            "in": "path",
            "required": true,
            "description": "The Batch ID or Pointer ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "Filter results starting from this date (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "description": "Filter results ending at this date (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "statsOnly",
            "in": "query",
            "required": false,
            "description": "If true, return only statistics without test details",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "steps",
            "in": "query",
            "required": false,
            "description": "If true, include step details in test results",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with batch results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchResultsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteBatch",
        "summary": "Delete batch",
        "description": "Deletes the entire batch and all its sessions.",
        "tags": [
          "Batches"
        ],
        "parameters": [
          {
            "name": "batchId",
            "in": "path",
            "required": true,
            "description": "The Batch ID or Pointer ID of the batch to delete",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted - batch deletion initiated"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Batch not found"
          }
        }
      }
    },
    "/batches": {
      "get": {
        "operationId": "listBatchStatistics",
        "summary": "List batch statistics",
        "description": "Lists statistics for all batches, optionally filtered by date range.",
        "tags": [
          "Batches"
        ],
        "parameters": [
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "Filter batches starting from this date",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "description": "Filter batches ending at this date",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "skipTo",
            "in": "query",
            "required": false,
            "description": "Skip to a specific batch ID for pagination",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with batch statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchStatisticsListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/batches/{batchId}/properties": {
      "get": {
        "operationId": "listBatchProperties",
        "summary": "List batch properties",
        "description": "Lists the property names and values of all (or by name) the properties in a batch.",
        "tags": [
          "Batches"
        ],
        "parameters": [
          {
            "name": "batchId",
            "in": "path",
            "required": true,
            "description": "The Batch's ID or Pointer ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "description": "Optional property name to filter by",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with batch properties",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchPropertiesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateBatchProperties",
        "summary": "Update batch properties",
        "description": "Patches the property names and values in a batch. This allows you to update batch properties after the batchInfo object has been passed to Eyes.",
        "tags": [
          "Batches"
        ],
        "parameters": [
          {
            "name": "batchId",
            "in": "path",
            "required": true,
            "description": "The Batch's ID or Pointer ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchPropertiesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Properties updated successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/discuss/{discussionId}": {
      "get": {
        "operationId": "listDiscussionComments",
        "summary": "List discussion comments",
        "description": "Lists all comments in a discussion thread identified by the discussion ID from batch results steps issues or remarks.",
        "tags": [
          "Discussions"
        ],
        "parameters": [
          {
            "name": "discussionId",
            "in": "path",
            "required": true,
            "description": "The discussion ID taken from the batch results steps issues or remarks",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with discussion comments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DiscussionComment"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/scm/commits/{sha}/set-status": {
      "post": {
        "operationId": "setScmStatus",
        "summary": "Set SCM commit status",
        "description": "Sets the tests/applitools and/or scm/applitools status, depending if the SHA is push or PR.",
        "tags": [
          "SCM Integrations"
        ],
        "parameters": [
          {
            "name": "sha",
            "in": "path",
            "required": true,
            "description": "The Git commit SHA",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetStatusRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status set successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Commit context for SHA not found"
          }
        }
      }
    },
    "/auth/api-key-validation": {
      "get": {
        "operationId": "validateApiKey",
        "summary": "Validate API key",
        "description": "Returns information associated with the API key. This allows you to confirm that the API key used in your tests is valid.",
        "tags": [
          "Authentication"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response with API key details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKeyValidationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BatchStatistics": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Batch internal ID"
          },
          "pointerId": {
            "type": "string",
            "description": "Batch pointer ID"
          },
          "passed": {
            "type": "integer",
            "description": "Number of passed tests"
          },
          "failed": {
            "type": "integer",
            "description": "Number of failed tests"
          },
          "unresolved": {
            "type": "integer",
            "description": "Number of unresolved tests"
          },
          "new": {
            "type": "integer",
            "description": "Number of new tests"
          },
          "aborted": {
            "type": "integer",
            "description": "Number of aborted tests"
          },
          "empty": {
            "type": "integer",
            "description": "Number of empty tests"
          },
          "total": {
            "type": "integer",
            "description": "Total number of tests"
          },
          "status": {
            "type": "string",
            "description": "Overall batch status",
            "enum": [
              "Passed",
              "Failed",
              "Unresolved"
            ]
          }
        }
      },
      "TestEnvironment": {
        "type": "object",
        "properties": {
          "device": {
            "type": "string"
          },
          "os": {
            "type": "string"
          },
          "app": {
            "type": "string"
          },
          "viewport": {
            "type": "object",
            "properties": {
              "width": {
                "type": "integer"
              },
              "height": {
                "type": "integer"
              }
            }
          }
        }
      },
      "AccessibilityStatus": {
        "type": "object",
        "properties": {
          "guidelines": {
            "type": "string",
            "enum": [
              "WCAG_2_0",
              "WCAG_2_1"
            ]
          },
          "level": {
            "type": "string",
            "enum": [
              "A",
              "AA",
              "AAA"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "Passed",
              "Failed"
            ]
          },
          "violations": {
            "type": "integer"
          }
        }
      },
      "StepRemark": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "discussionId": {
            "type": "string"
          }
        }
      },
      "StepIssue": {
        "type": "object",
        "properties": {
          "failTests": {
            "type": "boolean"
          },
          "snoozeUntil": {
            "type": "string",
            "format": "date-time"
          },
          "title": {
            "type": "string"
          },
          "discussionId": {
            "type": "string"
          }
        }
      },
      "TestStep": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "isMatching": {
            "type": "boolean"
          },
          "remarks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StepRemark"
            }
          },
          "issues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StepIssue"
            }
          },
          "accessibilitySettings": {
            "type": "object",
            "properties": {
              "guidelines": {
                "type": "string"
              },
              "level": {
                "type": "string"
              }
            }
          }
        }
      },
      "Property": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Property name"
          },
          "value": {
            "type": "string",
            "description": "Property value"
          }
        }
      },
      "TestResult": {
        "type": "object",
        "properties": {
          "testId": {
            "type": "string"
          },
          "testName": {
            "type": "string"
          },
          "branchName": {
            "type": "string"
          },
          "runBy": {
            "type": "string"
          },
          "assignedTo": {
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "env": {
            "$ref": "#/components/schemas/TestEnvironment"
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "unresolved",
              "new",
              "aborted"
            ]
          },
          "properties": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Property"
            }
          },
          "accessibilityStatus": {
            "$ref": "#/components/schemas/AccessibilityStatus"
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TestStep"
            }
          }
        }
      },
      "BatchResultsResponse": {
        "type": "object",
        "properties": {
          "statistics": {
            "$ref": "#/components/schemas/BatchStatistics"
          },
          "tests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TestResult"
            }
          }
        }
      },
      "BatchStatisticsListResponse": {
        "type": "object",
        "properties": {
          "batches": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BatchStatistics"
            }
          }
        }
      },
      "BatchPropertiesResponse": {
        "type": "object",
        "properties": {
          "properties": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Property"
            }
          }
        }
      },
      "BatchPropertiesRequest": {
        "type": "object",
        "properties": {
          "properties": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Property"
            }
          }
        }
      },
      "DiscussionComment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Comment ID"
          },
          "at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the comment"
          },
          "by": {
            "type": "string",
            "description": "Email of the commenter"
          },
          "content": {
            "type": "string",
            "description": "JSON-encoded comment content"
          }
        }
      },
      "SetStatusRequest": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "description": "The status to set for the commit",
            "enum": [
              "Pending",
              "Passed",
              "Failed"
            ]
          }
        }
      },
      "ApiKeyValidationResponse": {
        "type": "object",
        "properties": {
          "teamId": {
            "type": "string",
            "description": "Team identifier"
          },
          "user": {
            "type": "string",
            "description": "Email of the API key owner"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "read",
                "write",
                "execute",
                "merge"
              ]
            },
            "description": "Permissions associated with the API key"
          },
          "createdBy": {
            "type": "string",
            "description": "Email of who created the key"
          },
          "purpose": {
            "type": "string",
            "description": "Purpose of the API key"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "Expiration date of the API key"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Eyes-Api-Key",
        "description": "Applitools API key for authentication"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication"
    },
    {
      "name": "Batches"
    },
    {
      "name": "Discussions"
    },
    {
      "name": "SCM Integrations"
    }
  ]
}
