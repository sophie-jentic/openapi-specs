{
  "openapi": "3.0.3",
  "info": {
    "title": "Claim.MD API",
    "version": "1.0.0",
    "description": "Claim.MD provides healthcare claims clearinghouse services including electronic claims submission, eligibility verification, ERA (Electronic Remittance Advice) retrieval, and related billing operations.",
    "x-jentic-source-url": "https://api.claim.md/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.claim.md"
    }
  ],
  "paths": {
    "/services/upload": {
      "post": {
        "operationId": "uploadBatchFile",
        "summary": "Upload batch files",
        "description": "Submit claims, eligibility, ERA or attachment files as batch uploads.",
        "tags": [
          "Claims"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "AccountKey",
                  "File"
                ],
                "properties": {
                  "AccountKey": {
                    "type": "string",
                    "description": "API account key for authentication"
                  },
                  "File": {
                    "type": "string",
                    "format": "binary",
                    "description": "The batch file to upload"
                  },
                  "Filename": {
                    "type": "string",
                    "description": "Optional filename for the uploaded file"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful upload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
