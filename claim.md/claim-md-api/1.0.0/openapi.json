    "/services/eralist": {
      "post": {
        "operationId": "listERAs",
        "summary": "List Electronic Remittance Advice",
        "description": "Returns list of received ERA with filtering options.",
        "tags": [
          "ERA"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "AccountKey"
                ],
                "properties": {
                  "AccountKey": {
                    "type": "string",
                    "description": "API account key for authentication"
                  },
                  "CheckDate": {
                    "type": "string",
                    "format": "date",
                    "description": "Filter by check date"
                  },
                  "ReceivedDate": {
                    "type": "string",
                    "format": "date",
                    "description": "Filter by received date"
                  },
                  "ReceivedAfterDate": {
                    "type": "string",
                    "format": "date",
                    "description": "Filter for ERA received after this date"
                  },
                  "CheckNumber": {
                    "type": "string",
                    "description": "Filter by check number"
                  },
                  "CheckAmount": {
                    "type": "number",
                    "description": "Filter by check amount"
                  },
                  "PayerID": {
                    "type": "string",
                    "description": "Filter by payer ID"
                  },
                  "NPI": {
                    "type": "string",
                    "description": "Filter by provider NPI"
                  },
                  "TaxID": {
                    "type": "string",
                    "description": "Filter by tax ID"
                  },
                  "NewOnly": {
                    "type": "boolean",
                    "description": "Return only new/unread ERAs"
                  },
                  "ERAID": {
                    "type": "string",
                    "description": "Filter by specific ERA ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ERAListResponse"
