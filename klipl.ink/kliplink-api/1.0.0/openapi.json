{
  "openapi": "3.0.3",
  "info": {
    "title": "KlipLink API",
    "version": "1.0.0",
    "description": "KlipLink URL shortener API for creating, managing, and tracking short links. Available to paid plan users only (experimental).",
    "x-jentic-source-url": "https://klipl.ink/pages/docs/api/v1/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.klipl.ink"
    }
  ],
  "paths": {
    "/v1/links": {
      "get": {
        "operationId": "listLinks",
        "summary": "List all links",
        "description": "Retrieve all links for the authenticated user.",
        "tags": [
          "Links"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Link"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createLink",
        "summary": "Create a short link",
        "description": "Create a new shortened link.",
        "tags": [
          "Links"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLinkRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Link created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Link"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/links/{short_url}": {
      "get": {
        "operationId": "getLink",
        "summary": "Get a link",
        "description": "Retrieve a single link by its short URL identifier.",
        "tags": [
          "Links"
        ],
        "parameters": [
          {
            "name": "short_url",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Short URL identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Link"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateLink",
        "summary": "Update a link",
        "description": "Update an existing short link. At least one field is required.",
        "tags": [
          "Links"
        ],
        "parameters": [
          {
            "name": "short_url",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Short URL identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateLinkRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Link updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Link"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteLink",
        "summary": "Delete a link",
        "description": "Permanently delete a link.",
        "tags": [
          "Links"
        ],
        "parameters": [
          {
            "name": "short_url",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Short URL identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Link deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/domains": {
      "get": {
        "operationId": "listDomains",
        "summary": "List domains",
        "description": "Get list of user's current domains.",
        "tags": [
          "Domains"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Domain"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Link": {
        "type": "object",
        "properties": {
          "short_url": {
            "type": "string",
            "description": "Short URL identifier"
          },
          "destination_url": {
            "type": "string",
            "description": "Target destination URL"
          },
          "title": {
            "type": "string",
            "description": "Link title"
          },
          "domain": {
            "type": "string",
            "description": "Custom domain used"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "clicks": {
            "type": "integer",
            "description": "Number of clicks"
          }
        }
      },
      "CreateLinkRequest": {
        "type": "object",
        "required": [
          "destination_url"
        ],
        "properties": {
          "destination_url": {
            "type": "string",
            "description": "Target URL"
          },
          "back_half": {
            "type": "string",
            "description": "Custom short link identifier"
          },
          "title": {
            "type": "string",
            "description": "Link title"
          },
          "domain": {
            "type": "string",
            "description": "Custom domain for the short link"
          }
        }
      },
      "UpdateLinkRequest": {
        "type": "object",
        "properties": {
          "destination_url": {
            "type": "string",
            "description": "New destination URL"
          },
          "title": {
            "type": "string",
            "description": "Updated title"
          }
        }
      },
      "Domain": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string"
          },
          "verified": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key as Bearer token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Domains"
    },
    {
      "name": "Links"
    }
  ]
}
