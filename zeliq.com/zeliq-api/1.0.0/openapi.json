{
  "openapi": "3.0.3",
  "info": {
    "title": "Zeliq API",
    "version": "1.0.0",
    "description": "Zeliq is a sales intelligence and data enrichment API providing email and phone number waterfall enrichment and credit balance management.",
    "x-jentic-source-url": "https://docs.zeliq.com/docs/api-overview",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.zeliq.com/api"
    }
  ],
  "paths": {
    "/credits/balance": {
      "get": {
        "operationId": "getCreditBalance",
        "summary": "Get credit balance",
        "tags": [
          "Credits"
        ],
        "responses": {
          "200": {
            "description": "Credit balance",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "credit_balance": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get credit balance"
      }
    },
    "/contact/enrich/phone": {
      "post": {
        "operationId": "enrichPhone",
        "summary": "Enrich contact with phone number",
        "tags": [
          "Enrichment"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "callback_url"
                ],
                "properties": {
                  "linkedin_url": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "callback_url": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Enrichment initiated"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Enrich contact with phone number"
      }
    },
    "/contact/enrich/email": {
      "post": {
        "operationId": "enrichEmail",
        "summary": "Enrich contact with email",
        "tags": [
          "Enrichment"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "callback_url"
                ],
                "properties": {
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "company": {
                    "type": "string"
                  },
                  "linkedin_url": {
                    "type": "string"
                  },
                  "callback_url": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Enrichment initiated"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Enrich contact with email"
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Credits"
    },
    {
      "name": "Enrichment"
    }
  ]
}
