{
  "openapi": "3.0.3",
  "info": {
    "title": "BingX Spot API",
    "version": "1.0.0",
    "description": "BingX cryptocurrency exchange Spot trading API. Provides market data, spot trading, account management, and wallet operations. All authenticated endpoints require HMAC SHA256 signature. Base domain .com is primary; .pro is fallback for network errors only.",
    "x-jentic-source-url": "https://bingx-api.github.io/docs/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://open-api.bingx.com",
      "description": "Production (primary)"
    },
    {
      "url": "https://open-api.bingx.pro",
      "description": "Production (fallback for network errors)"
    },
    {
      "url": "https://open-api-vst.bingx.com",
      "description": "Virtual Simulated Trading (VST)"
    }
  ],
  "security": [
    {
      "apiKeyAuth": [],
      "signatureAuth": []
    }
  ],
  "tags": [
    {
      "name": "Market",
      "description": "Market data endpoints (public, no auth required)"
    },
    {
      "name": "Trade",
      "description": "Spot trading endpoints (authenticated)"
    },
    {
      "name": "Account",
      "description": "Account balance and asset management (authenticated)"
    },
    {
      "name": "Wallet",
      "description": "Deposits, withdrawals, and coin config (authenticated)"
    }
  ],
  "paths": {
    "/openApi/spot/v1/market/trades": {
      "get": {
        "operationId": "getRecentTrades",
        "summary": "Query recent trades",
        "tags": [
          "Market"
        ],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[A-Z0-9]+-[A-Z]+$"
            },
            "description": "Trading pair (e.g. BTC-USDT)."
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent trades.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BingXResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          }
        },
        "description": "Query recent trades"
      }
    },
