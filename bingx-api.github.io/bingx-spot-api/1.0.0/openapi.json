    "/openApi/spot/v1/trade/order": {
      "post": {
        "operationId": "createOrder",
        "summary": "Place a new order",
        "tags": [
          "Trade"
        ],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "side",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "BUY",
                "SELL"
              ]
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "MARKET",
                "LIMIT",
                "TAKE_STOP_LIMIT",
                "TAKE_STOP_MARKET",
                "TRIGGER_LIMIT",
                "TRIGGER_MARKET"
              ]
            }
          },
          {
            "name": "quantity",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Order quantity in base asset."
          },
          {
            "name": "quoteOrderQty",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Order amount in quote asset."
          },
          {
            "name": "price",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Limit price (required for LIMIT orders)."
          },
          {
            "name": "stopPrice",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Trigger price for stop orders."
          },
          {
            "name": "timeInForce",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "GTC",
                "IOC",
                "FOK",
                "PostOnly"
              ],
              "default": "GTC"
            }
          },
          {
            "name": "newClientOrderId",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 40
            }
          },
          {
            "name": "recvWindow",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 60000
            }
          },
          {
            "name": "timestamp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order placed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BingXResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          }
        },
        "description": "Place a new order"
      }
    },
