    "/openApi/api/v3/capital/deposit/hisrec": {
      "get": {
        "operationId": "getDepositHistory",
        "summary": "Query deposit history",
        "tags": [
          "Wallet"
        ],
        "parameters": [
          {
            "name": "coin",
            "in": "query",
            "schema": {
              "type": "string",
              "pattern": "^[A-Z0-9]{1,20}$"
            },
            "description": "Coin name (e.g. USDT). Omit for all."
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1,
                2,
                6
              ]
            },
            "description": "0=in progress, 1=not credited, 2=wrong amount, 6=completed."
          },
          {
            "name": "startTime",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
