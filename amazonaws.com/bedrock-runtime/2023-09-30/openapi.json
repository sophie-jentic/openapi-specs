{
  "openapi": "3.0.3",
  "info": {
    "title": "Amazon Bedrock Runtime API",
    "version": "2023-09-30",
    "description": "The Amazon Bedrock Runtime API provides operations for invoking foundation models, using guardrails, and managing conversational AI interactions.",
    "contact": {
      "name": "AWS Support",
      "url": "https://aws.amazon.com/bedrock/"
    }
  },
  "servers": [
    {
      "url": "https://bedrock-runtime.{region}.amazonaws.com",
      "description": "Amazon Bedrock Runtime regional endpoint",
      "variables": {
        "region": {
          "default": "us-east-1",
          "description": "AWS Region"
        }
      }
    }
  ],
  "security": [
    {
      "awsSignatureV4": []
    }
  ],
  "paths": {
    "/model/{modelId}/invoke": {
      "post": {
        "summary": "Invoke a foundation model",
        "operationId": "InvokeModel",
        "tags": [
          "Model Invocation"
        ],
        "parameters": [
          {
            "name": "modelId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the foundation model to invoke"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Model-specific request payload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful model invocation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Model-specific response payload"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Model not found"
          },
          "429": {
            "description": "Too many requests"
          }
        },
        "description": "Invoke a foundation model"
      }
    },
    "/model/{modelId}/invoke-with-response-stream": {
      "post": {
        "summary": "Invoke a foundation model with streaming response",
        "operationId": "InvokeModelWithResponseStream",
        "tags": [
          "Model Invocation"
        ],
        "parameters": [
          {
            "name": "modelId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the foundation model to invoke"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Model-specific request payload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful streaming response",
            "content": {
              "application/vnd.amazon.eventstream": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Model not found"
          }
        },
        "description": "Invoke a foundation model with streaming response"
      }
    },
    "/model/{modelId}/converse": {
      "post": {
        "summary": "Converse with a foundation model",
        "operationId": "Converse",
        "tags": [
          "Conversation"
        ],
        "parameters": [
          {
            "name": "modelId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the foundation model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConverseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful conversation response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConverseResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "description": "Converse with a foundation model"
      }
    },
    "/model/{modelId}/converse-stream": {
      "post": {
        "summary": "Converse with streaming response",
        "operationId": "ConverseStream",
        "tags": [
          "Conversation"
        ],
        "parameters": [
          {
            "name": "modelId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the foundation model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConverseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful streaming conversation",
            "content": {
              "application/vnd.amazon.eventstream": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "description": "Converse with streaming response"
      }
    },
    "/guardrail/{guardrailIdentifier}/version/{guardrailVersion}/apply": {
      "post": {
        "summary": "Apply a guardrail to content",
        "operationId": "ApplyGuardrail",
        "tags": [
          "Guardrails"
        ],
        "parameters": [
          {
            "name": "guardrailIdentifier",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The guardrail identifier"
          },
          {
            "name": "guardrailVersion",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The guardrail version"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "enum": [
                      "INPUT",
                      "OUTPUT"
                    ]
                  },
                  "content": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "text": {
                          "type": "object",
                          "properties": {
                            "text": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Guardrail applied successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "action": {
                      "type": "string"
                    },
                    "outputs": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Apply a guardrail to content"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "awsSignatureV4": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "AWS Signature Version 4 authentication"
      }
    },
    "schemas": {
      "ConverseRequest": {
        "type": "object",
        "required": [
          "messages"
        ],
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string",
                  "enum": [
                    "user",
                    "assistant"
                  ]
                },
                "content": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "system": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "inferenceConfig": {
            "type": "object",
            "properties": {
              "maxTokens": {
                "type": "integer"
              },
              "temperature": {
                "type": "number",
                "format": "float"
              },
              "topP": {
                "type": "number",
                "format": "float"
              }
            }
          }
        }
      },
      "ConverseResponse": {
        "type": "object",
        "properties": {
          "output": {
            "type": "object",
            "properties": {
              "message": {
                "type": "object",
                "properties": {
                  "role": {
                    "type": "string"
                  },
                  "content": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "stopReason": {
            "type": "string"
          },
          "usage": {
            "type": "object",
            "properties": {
              "inputTokens": {
                "type": "integer"
              },
              "outputTokens": {
                "type": "integer"
              },
              "totalTokens": {
                "type": "integer"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Model Invocation",
      "description": "Operations for invoking foundation models"
    },
    {
      "name": "Conversation",
      "description": "Conversational AI operations"
    },
    {
      "name": "Guardrails",
      "description": "Content safety and guardrail operations"
    }
  ]
}
