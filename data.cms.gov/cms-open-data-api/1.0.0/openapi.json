            }
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Dataset": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "modified": {
            "type": "string",
            "format": "date"
          },
          "publisher": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          },
          "contactPoint": {
            "type": "object",
            "properties": {
              "fn": {
                "type": "string"
              },
              "hasEmail": {
                "type": "string"
              }
            }
          },
          "keyword": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "theme": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "distribution": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Distribution"
            }
          },
          "temporal": {
            "type": "string"
          },
          "spatial": {
            "type": "string"
          },
          "accessLevel": {
            "type": "string"
          }
        }
      },
      "Distribution": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "format": {
            "type": "string",
            "enum": [
              "csv",
              "json",
              "xml"
            ]
          },
          "downloadURL": {
            "type": "string",
            "format": "uri"
          },
          "mediaType": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "DatastoreQueryResult": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "integer"
          },
          "schema": {
            "type": "object"
          },
          "query": {
            "type": "object"
          }
        }
      },
      "SqlQueryResult": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "integer"
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Dataset"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": [],
  "tags": [
    {
      "name": "Datastore"
    },
    {
      "name": "Harvest"
    },
    {
      "name": "Metastore"
    },
    {
      "name": "Search"
    }
  ]
}
