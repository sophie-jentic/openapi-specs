              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/1/metastore/schemas/{schema_id}/items": {
      "get": {
        "operationId": "listSchemaItems",
        "summary": "List schema items",
        "description": "Returns all items for a given schema.",
        "tags": [
          "Metastore"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "schema_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Schema ID (e.g., dataset, distribution, theme, keyword)"
          }
        ]
      }
    },
    "/api/1/harvest": {
      "get": {
        "operationId": "listHarvests",
        "summary": "List harvests",
        "description": "Returns harvest source information.",
        "tags": [
          "Harvest"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
