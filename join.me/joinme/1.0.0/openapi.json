{
  "openapi": "3.0.3",
  "info": {
    "title": "join.me API",
    "version": "1.0.0",
    "description": "The join.me API enables developers to integrate join.me meeting capabilities into their applications. Start meetings, manage scheduled meetings, and retrieve user information programmatically.",
    "x-jentic-source-url": "https://developer.join.me",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.join.me/v1"
    }
  ],
  "security": [
    {
      "OAuth2": []
    },
    {
      "ApiKey": []
    }
  ],
  "components": {
    "schemas": {
      "StartNewMeetingRequest": {
        "type": "object",
        "required": [
          "startWithPersonalUrl"
        ],
        "properties": {
          "startWithPersonalUrl": {
            "type": "boolean",
            "description": "Whether to start meeting with personal URL"
          }
        }
      },
      "ScheduleNewMeetingRequest": {
        "type": "object",
        "properties": {
          "meetingName": {
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "participants": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "email"
            }
          }
        }
      },
      "UpdateMeetingRequest": {
        "type": "object",
        "properties": {
          "meetingName": {
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MeetingResponse": {
        "type": "object",
        "properties": {
          "meetingId": {
            "type": "integer"
          },
          "meetingName": {
            "type": "string"
          },
          "meetingUrl": {
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      },
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "implicit": {
            "authorizationUrl": "https://example.com/oauth/authorize",
            "scopes": {}
          }
        }
      }
    }
  },
  "paths": {
    "/meetings/start": {
      "post": {
        "summary": "Start a new meeting",
        "description": "Start a new join.me meeting immediately",
        "operationId": "startNewMeeting",
        "tags": [
          "Meetings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartNewMeetingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Meeting started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeetingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/meetings/{meetingId}/start": {
      "post": {
        "summary": "Start a scheduled meeting",
        "description": "Start an existing scheduled meeting by its ID",
        "operationId": "startScheduledMeeting",
        "tags": [
          "Meetings"
        ],
        "parameters": [
          {
            "name": "meetingId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Meeting started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeetingResponse"
                }
              }
            }
          },
          "404": {
            "description": "Meeting not found"
          }
        }
      }
    },
    "/meetings/{meetingId}": {
      "get": {
        "summary": "Get a scheduled meeting",
        "description": "Retrieve details of a scheduled meeting by its ID",
        "operationId": "getMeeting",
        "tags": [
          "Meetings"
        ],
        "parameters": [
          {
            "name": "meetingId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Meeting details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeetingResponse"
                }
              }
            }
          },
          "404": {
            "description": "Meeting not found"
          }
        }
      },
      "patch": {
        "summary": "Update a meeting",
        "description": "Update details of a scheduled meeting",
        "operationId": "updateMeeting",
        "tags": [
          "Meetings"
        ],
        "parameters": [
          {
            "name": "meetingId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateMeetingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Meeting updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeetingResponse"
                }
              }
            }
          },
          "404": {
            "description": "Meeting not found"
          }
        }
      },
      "delete": {
        "summary": "Delete a meeting",
        "description": "Delete a scheduled meeting",
        "operationId": "deleteMeeting",
        "tags": [
          "Meetings"
        ],
        "parameters": [
          {
            "name": "meetingId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Meeting deleted"
          },
          "404": {
            "description": "Meeting not found"
          }
        }
      }
    },
    "/meetings": {
      "get": {
        "summary": "Get scheduled meetings",
        "description": "Retrieve a list of scheduled meetings",
        "operationId": "getMeetings",
        "tags": [
          "Meetings"
        ],
        "parameters": [
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of meetings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MeetingResponse"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Schedule a new meeting",
        "description": "Create a new scheduled meeting",
        "operationId": "scheduleMeeting",
        "tags": [
          "Meetings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScheduleNewMeetingRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Meeting scheduled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeetingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/user": {
      "get": {
        "summary": "Get user information",
        "description": "Retrieve information about the authenticated user",
        "operationId": "getUser",
        "tags": [
          "User"
        ],
        "responses": {
          "200": {
            "description": "User information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Meetings",
      "description": "Meeting management endpoints"
    },
    {
      "name": "User",
      "description": "User information endpoints"
    }
  ]
}
