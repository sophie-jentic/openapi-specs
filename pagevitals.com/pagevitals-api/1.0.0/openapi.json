{
  "openapi": "3.0.3",
  "info": {
    "title": "PageVitals API",
    "version": "1.0.0",
    "description": "PageVitals provides website performance monitoring. The REST API allows accessing websites, pages, tests, multistep tests, budgets, field testing data, opportunities, and settings.",
    "x-jentic-source-url": "https://pagevitals.com/docs/rest-api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.pagevitals.com"
    }
  ],
  "paths": {
    "/websites": {
      "get": {
        "operationId": "listWebsites",
        "summary": "List all websites",
        "tags": [
          "Websites"
        ],
        "responses": {
          "200": {
            "description": "Website list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebsiteListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all websites"
      }
    },
    "/account/websites": {
      "post": {
        "operationId": "addWebsite",
        "summary": "Add website",
        "tags": [
          "Websites"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "domain"
                ],
                "properties": {
                  "domain": {
                    "type": "string"
                  },
                  "displayName": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Website added",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Website"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Add website"
      }
    },
    "/{websiteId}": {
      "delete": {
        "operationId": "deleteWebsite",
        "summary": "Delete website",
        "tags": [
          "Websites"
        ],
        "parameters": [
          {
            "name": "websiteId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete website"
      }
    },
    "/{websiteId}/pages": {
      "get": {
        "operationId": "listPages",
        "summary": "List pages",
        "tags": [
          "Pages"
        ],
        "parameters": [
          {
            "name": "websiteId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pages list"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List pages"
      }
    },
    "/{websiteId}/pages/{pageId}": {
      "get": {
        "operationId": "getPage",
        "summary": "Get page detail",
        "tags": [
          "Pages"
        ],
        "parameters": [
          {
            "name": "websiteId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Page details"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get page detail"
      }
    },
    "/{websiteId}/testseries": {
      "get": {
        "operationId": "listTestSeries",
        "summary": "List test series",
        "tags": [
          "Tests"
        ],
        "parameters": [
          {
            "name": "websiteId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Test series"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List test series"
      }
    },
    "/{websiteId}/tests": {
      "get": {
        "operationId": "listTests",
        "summary": "List tests",
        "tags": [
          "Tests"
        ],
        "parameters": [
          {
            "name": "websiteId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tests"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List tests"
      }
    }
  },
  "components": {
    "schemas": {
      "Website": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          }
        }
      },
      "WebsiteListResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "list": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Website"
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Pages"
    },
    {
      "name": "Tests"
    },
    {
      "name": "Websites"
    }
  ]
}
