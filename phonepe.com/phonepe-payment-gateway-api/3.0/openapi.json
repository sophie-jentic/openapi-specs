{
  "openapi": "3.0.3",
  "info": {
    "title": "PhonePe Payment Gateway API",
    "version": "3.0",
    "description": "PhonePe digital payments API (India). Supports payment initiation, status check, refunds, and callbacks for UPI and other payment methods via the PhonePe payment gateway.",
    "x-jentic-source-url": "https://developer.phonepe.com/v4/reference/check-status-api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.phonepe.com/apis/hermes",
      "description": "Production"
    },
    {
      "url": "https://api-preprod.phonepe.com/apis/pg-sandbox",
      "description": "Sandbox/UAT"
    }
  ],
  "paths": {
    "/pg/v1/pay": {
      "post": {
        "operationId": "initiatePayment",
        "summary": "Initiate payment",
        "description": "Initiate a payment transaction. The request body must be Base64 encoded.",
        "tags": [
          "Payments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentInitRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentInitResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/pg/v1/status/{merchantId}/{merchantTransactionId}": {
      "get": {
        "operationId": "checkPaymentStatus",
        "summary": "Check payment status",
        "description": "Check the status of a payment transaction. X-VERIFY header required.",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "merchantId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique Merchant ID assigned by PhonePe"
          },
          {
            "name": "merchantTransactionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Merchant transaction ID"
          },
          {
            "name": "X-VERIFY",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "SHA256(\"/pg/v1/status/{merchantId}/{merchantTransactionId}\" + saltKey) + \"###\" + saltIndex"
          },
          {
            "name": "X-MERCHANT-ID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Merchant ID (default: same as path)"
          }
        ],
        "responses": {
          "200": {
            "description": "Payment status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authorization failed"
          }
        }
      }
    },
    "/pg/v1/refund": {
      "post": {
        "operationId": "initiateRefund",
        "summary": "Initiate refund",
        "description": "Initiate a refund for a completed payment",
        "tags": [
          "Refunds"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefundRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refund initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefundResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/pg/v1/refund/{merchantId}/{merchantTransactionId}": {
      "get": {
        "operationId": "checkRefundStatus",
        "summary": "Check refund status",
        "tags": [
          "Refunds"
        ],
        "parameters": [
          {
            "name": "merchantId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "merchantTransactionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-VERIFY",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-MERCHANT-ID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Refund status"
          }
        },
        "description": "Check refund status"
      }
    },
    "/v3/transaction/{merchantId}/{transactionId}/status": {
      "get": {
        "operationId": "checkTransactionStatusV3",
        "summary": "Check transaction status (v3)",
        "description": "Legacy v3 status check endpoint",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "merchantId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "transactionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-VERIFY",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "description": "SHA256(\"/v3/transaction/{merchantId}/{transactionId}/status\" + saltKey) + \"###\" + saltIndex"
            }
          },
          {
            "name": "X-CLIENT-ID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V3StatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/pg/v1/validate/vpa": {
      "post": {
        "operationId": "validateVPA",
        "summary": "Validate VPA (UPI ID)",
        "description": "Validate a UPI Virtual Payment Address",
        "tags": [
          "Validation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "merchantId",
                  "vpa"
                ],
                "properties": {
                  "merchantId": {
                    "type": "string"
                  },
                  "vpa": {
                    "type": "string",
                    "description": "UPI VPA to validate"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "VPA validation result"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PaymentInitRequest": {
        "type": "object",
        "required": [
          "request"
        ],
        "properties": {
          "request": {
            "type": "string",
            "description": "Base64 encoded payment request JSON"
          },
          "X-VERIFY": {
            "type": "string",
            "description": "SHA256(base64Body + \"/pg/v1/pay\" + saltKey) + \"###\" + saltIndex"
          }
        },
        "description": "The actual payload (before encoding) contains: merchantId, merchantTransactionId, merchantUserId, amount (in paise), redirectUrl, redirectMode, callbackUrl, paymentInstrument"
      },
      "PaymentInitResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "merchantId": {
                "type": "string"
              },
              "merchantTransactionId": {
                "type": "string"
              },
              "instrumentResponse": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "redirectInfo": {
                    "type": "object",
                    "properties": {
                      "url": {
                        "type": "string"
                      },
                      "method": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "PaymentStatusResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "code": {
            "type": "string",
            "description": "Response code (PAYMENT_SUCCESS, PAYMENT_ERROR, PAYMENT_PENDING, etc.)"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "merchantId": {
                "type": "string"
              },
              "merchantTransactionId": {
                "type": "string"
              },
              "transactionId": {
                "type": "string"
              },
              "amount": {
                "type": "integer",
                "description": "Amount in paise"
              },
              "state": {
                "type": "string",
                "enum": [
                  "COMPLETED",
                  "PENDING",
                  "FAILED"
                ]
              },
              "responseCode": {
                "type": "string"
              },
              "paymentInstrument": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "utr": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "RefundRequest": {
        "type": "object",
        "required": [
          "request"
        ],
        "properties": {
          "request": {
            "type": "string",
            "description": "Base64 encoded refund request"
          },
          "X-VERIFY": {
            "type": "string"
          }
        },
        "description": "Payload contains: merchantId, merchantUserId, originalTransactionId, merchantTransactionId, amount (in paise), callbackUrl"
      },
      "RefundResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "merchantId": {
                "type": "string"
              },
              "merchantTransactionId": {
                "type": "string"
              },
              "transactionId": {
                "type": "string"
              },
              "amount": {
                "type": "integer"
              },
              "state": {
                "type": "string"
              }
            }
          }
        }
      },
      "V3StatusResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "code": {
            "type": "string",
            "enum": [
              "PAYMENT_SUCCESS",
              "PAYMENT_ERROR",
              "PAYMENT_PENDING",
              "PAYMENT_DECLINED",
              "PAYMENT_CANCELLED",
              "TRANSACTION_NOT_FOUND",
              "BAD_REQUEST",
              "AUTHORIZATION_FAILED",
              "INTERNAL_SERVER_ERROR"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "transactionId": {
                "type": "string"
              },
              "merchantId": {
                "type": "string"
              },
              "amount": {
                "type": "integer"
              },
              "providerReferenceId": {
                "type": "string"
              },
              "paymentState": {
                "type": "string"
              },
              "payResponseCode": {
                "type": "string"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "verifyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-VERIFY",
        "description": "SHA256-based verification header. Computed as SHA256(payload + endpoint + saltKey) + '###' + saltIndex"
      }
    }
  },
  "security": [
    {
      "verifyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Payments"
    },
    {
      "name": "Refunds"
    },
    {
      "name": "Validation"
    }
  ]
}
