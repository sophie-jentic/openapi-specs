{
  "openapi": "3.0.3",
  "info": {
    "title": "EDluminate Institution API",
    "description": "EDluminate API for managing contact student enrollment",
    "version": "1.0.0",
    "contact": {
      "url": "https://docs.edluminate.com"
    }
  },
  "servers": [
    {
      "url": "https://{subdomain}.edluminate.com/api/v1",
      "variables": {
        "subdomain": {
          "default": "your-institution",
          "description": "Your institution subdomain"
        }
      }
    }
  ],
  "paths": {
    "/contact_student_enrollment": {
      "post": {
        "summary": "Create contact student enrollment",
        "description": "Create a new lead for student enrollment",
        "operationId": "createContactStudentEnrollment",
        "tags": [
          "Enrollment"
        ],
        "parameters": [
          {
            "name": "api_access_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Institution API Access Key"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ContactStudentEnrollment"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          },
          "405": {
            "description": "Method Not Allowed"
          },
          "406": {
            "description": "Not Acceptable"
          },
          "410": {
            "description": "Gone"
          },
          "418": {
            "description": "I'm a teapot"
          },
          "429": {
            "description": "Too Many Requests"
          },
          "500": {
            "description": "Internal Server Error"
          },
          "503": {
            "description": "Service Unavailable"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContactStudentEnrollment": {
        "type": "object",
        "required": [
          "email",
          "first_name",
          "last_name",
          "phone_number",
          "campus_id",
          "program_id"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "New Lead's Email"
          },
          "first_name": {
            "type": "string",
            "description": "New Lead's First Name"
          },
          "last_name": {
            "type": "string",
            "description": "New Lead's Last Name"
          },
          "phone_number": {
            "type": "string",
            "description": "Phone Number (with area code)"
          },
          "campus_id": {
            "type": "string",
            "description": "Campus ID from EDluminate"
          },
          "program_id": {
            "type": "string",
            "description": "Program ID from EDluminate"
          },
          "general_comments": {
            "type": "string",
            "nullable": true
          },
          "preferred_contact_method": {
            "type": "string",
            "nullable": true
          },
          "mailing_address": {
            "type": "string",
            "nullable": true
          },
          "second_mailing_address": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "state": {
            "type": "string",
            "nullable": true
          },
          "zipcode": {
            "type": "string",
            "nullable": true
          },
          "best_contact_time": {
            "type": "string",
            "nullable": true
          },
          "source": {
            "type": "string",
            "nullable": true
          },
          "vendor_source": {
            "type": "string",
            "nullable": true
          },
          "notify": {
            "type": "string",
            "nullable": true
          },
          "high_school": {
            "type": "string",
            "nullable": true
          },
          "high_school_graduation_year": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Enrollment"
    }
  ]
}
