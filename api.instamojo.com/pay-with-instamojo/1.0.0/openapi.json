{
  "openapi": "3.0.1",
  "info": {
    "title": "Pay with Instamojo",
    "description": "API to initiate payments with Instamojo",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/saich/pay-with-instamojo/1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.instamojo.com/v2"
    }
  ],
  "paths": {
    "/gateway/orders/": {
      "get": {
        "summary": "Get all your payment orders",
        "description": "This endpoint returns paginated results of all your payment orders. This endpoint also supports filtering by some parameters.\n",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "Search for payment orders by id.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "transaction_id",
            "in": "query",
            "description": "Search for payment orders by your transaction_id.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number of the results to retrieve from.",
            "schema": {
              "minimum": 1,
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Limit the number of results returned per page. Defaults to `50` results per page. Max limit allowed is `500`.",
            "schema": {
              "maximum": 500,
              "minimum": 1,
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "integer",
                      "description": "Total number of results available, based on the filters applied."
                    },
                    "next": {
                      "type": "string",
                      "description": "URL to get next set of results on next page. This will be `null` if this is the last page.",
                      "format": "url"
                    },
                    "previous": {
                      "type": "string",
                      "description": "URL to get previous set of results on previous page. This will be `null` if this is the first page.",
                      "format": "url"
                    },
                    "orders": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Order"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "oauth2": [
              "all"
            ]
          }
        ],
        "operationId": "get_gateway_orders",
        "tags": [
          "gateway"
        ]
      },
      "post": {
        "summary": "Create a Payment Order",
        "description": "Initiates a payment order with Instamojo.\n\nThere can only be one Instamojo payment order for a transaction in your system (transaction in your system being identified by `transaction_id`)\n",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "required": [
                  "amount",
                  "currency",
                  "email",
                  "name",
                  "phone",
                  "redirect_url",
                  "transaction_id"
                ],
                "type": "object",
                "properties": {
                  "name": {
                    "maxLength": 100,
                    "type": "string",
                    "description": "Name of the customer (max 100 characters)."
                  },
                  "email": {
                    "maxLength": 75,
                    "type": "string",
                    "description": "Email address of the customer (max 75 characters).",
                    "format": "email"
                  },
                  "phone": {
                    "maxLength": 75,
                    "type": "string",
                    "description": "Phone number of the customer. It is recommended to use [E.164 number formatting](https://en.wikipedia.org/wiki/E.164) for all phone numbers.",
                    "format": "phone"
                  },
                  "currency": {
                    "type": "string",
                    "description": "String identifier for the currency. Currenly, only `INR` (for Indian Rupee) is supported.",
                    "enum": [
                      "INR"
                    ]
                  },
                  "amount": {
                    "minimum": 10.0,
                    "type": "number",
                    "description": "Amount the customer has to pay. Numbers upto 2 decimal places are supported.",
                    "format": "money"
                  },
                  "description": {
                    "maxLength": 255,
                    "type": "string",
                    "description": "Short description of the order (max 255 characters). If provided, this information is sent to backend gateways, wherever possible."
                  },
                  "transaction_id": {
                    "maxLength": 64,
                    "type": "string",
                    "description": "Unique identifier for the order (max 64 characters). Identifier can contain alphanumeric characters, hyphens and underscores only. This is generally the unique order id (or primary key) in your system."
                  },
                  "redirect_url": {
                    "maxLength": 2000,
                    "type": "string",
                    "description": "Full URL to which the customer is redirected after payment. Redirection happens even if payment wasn't successful. This URL shouldn't contain any query parameters.",
                    "format": "url"
                  }
                }
              }
            },
            "application/json": {
              "schema": {
                "required": [
                  "amount",
                  "currency",
                  "email",
                  "name",
                  "phone",
                  "redirect_url",
                  "transaction_id"
                ],
                "type": "object",
                "properties": {
                  "name": {
                    "maxLength": 100,
                    "type": "string",
                    "description": "Name of the customer (max 100 characters)."
                  },
                  "email": {
                    "maxLength": 75,
                    "type": "string",
                    "description": "Email address of the customer (max 75 characters).",
                    "format": "email"
                  },
                  "phone": {
                    "maxLength": 75,
                    "type": "string",
                    "description": "Phone number of the customer. It is recommended to use [E.164 number formatting](https://en.wikipedia.org/wiki/E.164) for all phone numbers.",
                    "format": "phone"
                  },
                  "currency": {
                    "type": "string",
                    "description": "String identifier for the currency. Currenly, only `INR` (for Indian Rupee) is supported.",
                    "enum": [
                      "INR"
                    ]
                  },
                  "amount": {
                    "minimum": 10.0,
                    "type": "number",
                    "description": "Amount the customer has to pay. Numbers upto 2 decimal places are supported.",
                    "format": "money"
                  },
                  "description": {
                    "maxLength": 255,
                    "type": "string",
                    "description": "Short description of the order (max 255 characters). If provided, this information is sent to backend gateways, wherever possible."
                  },
                  "transaction_id": {
                    "maxLength": 64,
                    "type": "string",
                    "description": "Unique identifier for the order (max 64 characters). Identifier can contain alphanumeric characters, hyphens and underscores only. This is generally the unique order id (or primary key) in your system."
                  },
                  "redirect_url": {
                    "maxLength": 2000,
                    "type": "string",
                    "description": "Full URL to which the customer is redirected after payment. Redirection happens even if payment wasn't successful. This URL shouldn't contain any query parameters.",
                    "format": "url"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Order Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order": {
                      "$ref": "#/components/schemas/Order"
                    },
                    "payment_options": {
                      "$ref": "#/components/schemas/PaymentOptions"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "oauth2": [
              "all"
            ]
          }
        ],
        "operationId": "post_gateway_orders",
        "tags": [
          "gateway"
        ]
      }
    },
    "/gateway/orders/id:{id}/": {
      "get": {
        "summary": "Get details of this payment order",
        "description": "Get the details of the specified order (identified by `id`).\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Id of the order.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          }
        },
        "security": [
          {
            "oauth2": [
              "all"
            ]
          }
        ],
        "operationId": "get_gateway_orders_id:id",
        "tags": [
          "gateway"
        ]
      }
    },
    "/gateway/orders/transaction_id:{transaction_id}/": {
      "get": {
        "summary": "Get details of this payment order",
        "description": "Get the details of the specified order (identified by `id`).\n",
        "parameters": [
          {
            "name": "transaction_id",
            "in": "path",
            "description": "transaction_id of the order.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          }
        },
        "security": [
          {
            "oauth2": [
              "all"
            ]
          }
        ],
        "operationId": "get_gateway_orders_transaction_id:transaction_id",
        "tags": [
          "gateway"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "transaction_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "complete"
            ]
          },
          "currency": {
            "type": "string",
            "enum": [
              "INR"
            ]
          },
          "amount": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "redirect_url": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "resource_uri": {
            "type": "string",
            "format": "url"
          }
        },
        "description": "Order Object"
      },
      "PaymentOptions": {
        "type": "object",
        "properties": {
          "payment_url": {
            "type": "string",
            "format": "url"
          }
        },
        "description": "Payment Options"
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "description": "Standard oauth2 authorization using `client_credentials` flow. This authorization scheme expects an access token in the `Authorization` header.\n",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://www.instamojo.com/oauth2/token/",
            "scopes": {
              "all": "Complete Access"
            }
          }
        }
      }
    }
  },
  "x-original-swagger-version": "2.0",
  "tags": [
    {
      "name": "gateway"
    }
  ]
}
