{
  "openapi": "3.0.3",
  "info": {
    "title": "RocketReach API",
    "version": "1.0.0",
    "description": "The RocketReach API provides access to people and company data for email and contact lookup.",
    "x-jentic-source-url": "https://rocketreach.co/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.rocketreach.co/api/v2",
      "description": "RocketReach API v2"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/api/v2/account": {
      "get": {
        "operationId": "getAccount",
        "tags": [
          "Account"
        ],
        "summary": "Get RocketReach API Account",
        "description": "Returns account information for the authenticated user.",
        "responses": {
          "200": {
            "description": "Account information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/person/lookup": {
      "get": {
        "operationId": "lookupPerson",
        "tags": [
          "People"
        ],
        "summary": "People Lookup API",
        "description": "Look up a person by LinkedIn URL, name, or other identifiers.",
        "parameters": [
          {
            "name": "linkedin_url",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "LinkedIn profile URL"
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Full name of the person"
          },
          {
            "name": "current_employer",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Current employer name"
          },
          {
            "name": "email",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Email address"
          }
        ],
        "responses": {
          "200": {
            "description": "Person lookup result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersonLookupResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/person/search": {
      "post": {
        "operationId": "searchPeople",
        "tags": [
          "People"
        ],
        "summary": "People Search API",
        "description": "Search for people using various filters.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PeopleSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PeopleSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/person/bulk_lookup": {
      "post": {
        "operationId": "bulkLookupPeople",
        "tags": [
          "People"
        ],
        "summary": "Bulk People Lookup API",
        "description": "Look up multiple people in a single request.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkLookupRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk lookup results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkLookupResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/company/search": {
      "post": {
        "operationId": "searchCompanies",
        "tags": [
          "Companies"
        ],
        "summary": "Company Search API",
        "description": "Search for companies using various filters.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompanySearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Company search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanySearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/company/lookup": {
      "get": {
        "operationId": "lookupCompany",
        "tags": [
          "Companies"
        ],
        "summary": "Company Lookup API",
        "description": "Look up a company by name, domain, or LinkedIn URL.",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Company name"
          },
          {
            "name": "domain",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Company domain"
          },
          {
            "name": "linkedin_url",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "LinkedIn company URL"
          }
        ],
        "responses": {
          "200": {
            "description": "Company lookup result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Company"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Api-Key",
        "description": "RocketReach API key"
      }
    },
    "schemas": {
      "Account": {
        "type": "object",
        "description": "RocketReach account information",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "plan": {
            "type": "string"
          },
          "credits": {
            "type": "integer"
          },
          "lookups": {
            "type": "integer"
          }
        }
      },
      "PersonLookupResult": {
        "type": "object",
        "description": "Person lookup result with contact info",
        "properties": {
          "id": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "complete",
              "progress",
              "failed"
            ]
          },
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "current_employer": {
            "type": "string"
          },
          "linkedin_url": {
            "type": "string"
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "phones": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "location": {
            "type": "string"
          }
        }
      },
      "PeopleSearchRequest": {
        "type": "object",
        "description": "People search request filters",
        "properties": {
          "name": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "current_employer": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "title": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "location": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "start": {
            "type": "integer",
            "default": 1
          },
          "page_size": {
            "type": "integer",
            "default": 10
          }
        }
      },
      "PeopleSearchResponse": {
        "type": "object",
        "description": "People search response",
        "properties": {
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          },
          "profiles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PersonLookupResult"
            }
          }
        }
      },
      "BulkLookupRequest": {
        "type": "object",
        "description": "Bulk lookup request",
        "properties": {
          "lookups": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PersonLookupRequest"
            }
          }
        }
      },
      "PersonLookupRequest": {
        "type": "object",
        "description": "Single person lookup request",
        "properties": {
          "linkedin_url": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "current_employer": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        }
      },
      "BulkLookupResponse": {
        "type": "object",
        "description": "Bulk lookup response",
        "properties": {
          "profiles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PersonLookupResult"
            }
          }
        }
      },
      "CompanySearchRequest": {
        "type": "object",
        "description": "Company search filters",
        "properties": {
          "name": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "domain": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "industry": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "location": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "start": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          }
        }
      },
      "CompanySearchResponse": {
        "type": "object",
        "description": "Company search response",
        "properties": {
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          },
          "companies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Company"
            }
          }
        }
      },
      "Company": {
        "type": "object",
        "description": "Company information",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "linkedin_url": {
            "type": "string"
          },
          "industry": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "employee_count": {
            "type": "integer"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "description": "Pagination info",
        "properties": {
          "start": {
            "type": "integer"
          },
          "next": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Error response",
        "properties": {
          "message": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Account"
    },
    {
      "name": "Companies"
    },
    {
      "name": "People"
    }
  ]
}
