{
  "openapi": "3.0.3",
  "info": {
    "title": "Plausible API",
    "version": "1.0.0",
    "description": "Plausible is a privacy-friendly, open-source web analytics platform. The API provides programmatic access to website statistics (Stats API) and site management (Sites API). Stats API allows querying aggregate metrics, timeseries data, and breakdowns by various dimensions. Sites API allows creating, updating, and deleting sites, managing shared links, and goals.",
    "x-jentic-source-url": "https://plausible.io/docs/stats-api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://plausible.io"
    }
  ],
  "paths": {
    "/api/v1/stats/realtime/visitors": {
      "get": {
        "operationId": "getRealtimeVisitors",
        "summary": "Get realtime visitor count",
        "description": "Returns the number of current visitors on the given site. A current visitor is defined as a visitor who triggered a pageview on the site in the last 5 minutes.",
        "tags": [
          "Stats"
        ],
        "parameters": [
          {
            "name": "site_id",
            "in": "query",
            "description": "Domain of the site to query (e.g. example.com)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Current number of visitors",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "integer"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stats/aggregate": {
      "get": {
        "operationId": "getAggregateStats",
        "summary": "Get aggregate stats",
        "description": "Aggregates metrics over a certain time period. If you are familiar with the Plausible dashboard, this endpoint corresponds to the top row of stats that includes unique visitors, pageviews, bounce rate, and visit duration. You can retrieve any number and combination of these metrics in one request.",
        "tags": [
          "Stats"
        ],
        "parameters": [
          {
            "name": "site_id",
            "in": "query",
            "description": "Domain of the site to query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "period",
            "in": "query",
            "description": "Time period",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "12mo",
                "6mo",
                "month",
                "30d",
                "7d",
                "day",
                "custom"
              ],
              "default": "30d"
            }
          },
          {
            "name": "metrics",
            "in": "query",
            "description": "Comma-separated list of metrics to aggregate. Available: visitors, visits, pageviews, views_per_visit, bounce_rate, visit_duration, events, conversion_rate",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "compare",
            "in": "query",
            "description": "Enables comparison with a previous period",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "previous_period"
              ]
            }
          },
          {
            "name": "filters",
            "in": "query",
            "description": "Filters for the query, semicolon-separated (e.g. visit:source==Google;visit:country==US)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "description": "Date to query. For period=custom, use format YYYY-MM-DD,YYYY-MM-DD.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aggregated statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AggregateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stats/timeseries": {
      "get": {
        "operationId": "getTimeseries",
        "summary": "Get timeseries stats",
        "description": "Returns a time series of data over a given time period. Each data point contains the metrics for that date.",
        "tags": [
          "Stats"
        ],
        "parameters": [
          {
            "name": "site_id",
            "in": "query",
            "description": "Domain of the site to query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "period",
            "in": "query",
            "description": "Time period",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "12mo",
                "6mo",
                "month",
                "30d",
                "7d",
                "day",
                "custom"
              ],
              "default": "30d"
            }
          },
          {
            "name": "metrics",
            "in": "query",
            "description": "Comma-separated list of metrics (visitors, visits, pageviews, views_per_visit, bounce_rate, visit_duration, events)",
            "required": false,
            "schema": {
              "type": "string",
              "default": "visitors"
            }
          },
          {
            "name": "interval",
            "in": "query",
            "description": "Time interval for the data points",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "date",
                "month"
              ]
            }
          },
          {
            "name": "filters",
            "in": "query",
            "description": "Filters for the query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "description": "Date or date range",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Timeseries data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TimeseriesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stats/breakdown": {
      "get": {
        "operationId": "getBreakdown",
        "summary": "Get breakdown stats",
        "description": "Returns a breakdown of stats by the specified property. Think of it as a filtered, ordered list of items with their associated metrics.",
        "tags": [
          "Stats"
        ],
        "parameters": [
          {
            "name": "site_id",
            "in": "query",
            "description": "Domain of the site to query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "property",
            "in": "query",
            "description": "Property to break down by (e.g. event:page, visit:source, visit:country, visit:browser, visit:os, visit:device, visit:utm_source, visit:utm_medium, visit:utm_campaign, visit:utm_content, visit:utm_term, event:name)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "period",
            "in": "query",
            "description": "Time period",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "12mo",
                "6mo",
                "month",
                "30d",
                "7d",
                "day",
                "custom"
              ],
              "default": "30d"
            }
          },
          {
            "name": "metrics",
            "in": "query",
            "description": "Comma-separated list of metrics",
            "required": false,
            "schema": {
              "type": "string",
              "default": "visitors"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "filters",
            "in": "query",
            "description": "Filters for the query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "description": "Date or date range",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Breakdown data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BreakdownResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sites": {
      "get": {
        "operationId": "listSites",
        "summary": "List all sites",
        "description": "Returns a list of all sites the authenticated user has access to.",
        "tags": [
          "Sites"
        ],
        "responses": {
          "200": {
            "description": "List of sites",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SiteListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createSite",
        "summary": "Create a site",
        "description": "Creates a new site in your Plausible account.",
        "tags": [
          "Sites"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSiteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Site created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Site"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sites/{site_id}": {
      "get": {
        "operationId": "getSite",
        "summary": "Get a site",
        "description": "Returns details of a specific site.",
        "tags": [
          "Sites"
        ],
        "parameters": [
          {
            "name": "site_id",
            "in": "path",
            "description": "Domain of the site",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Site details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Site"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Site not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateSite",
        "summary": "Update a site",
        "description": "Updates a site's domain.",
        "tags": [
          "Sites"
        ],
        "parameters": [
          {
            "name": "site_id",
            "in": "path",
            "description": "Domain of the site",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSiteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Site updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Site"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteSite",
        "summary": "Delete a site",
        "description": "Deletes a site and all associated data.",
        "tags": [
          "Sites"
        ],
        "parameters": [
          {
            "name": "site_id",
            "in": "path",
            "description": "Domain of the site",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Site deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deleted": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Site not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sites/shared-links": {
      "put": {
        "operationId": "createSharedLink",
        "summary": "Create a shared link",
        "description": "Creates a shared link for a site.",
        "tags": [
          "Sites"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSharedLinkRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shared link created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SharedLink"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sites/goals": {
      "put": {
        "operationId": "createGoal",
        "summary": "Create a goal",
        "description": "Creates a goal for a site. Goals can be page visit goals or custom event goals.",
        "tags": [
          "Sites"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateGoalRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Goal created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Goal"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sites/goals/{goal_id}": {
      "delete": {
        "operationId": "deleteGoal",
        "summary": "Delete a goal",
        "description": "Deletes a goal from a site.",
        "tags": [
          "Sites"
        ],
        "parameters": [
          {
            "name": "goal_id",
            "in": "path",
            "description": "ID of the goal to delete",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "site_id"
                ],
                "properties": {
                  "site_id": {
                    "type": "string",
                    "description": "Domain of the site"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Goal deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deleted": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Goal not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/event": {
      "post": {
        "operationId": "sendEvent",
        "summary": "Send a pageview or custom event",
        "description": "Records a pageview or custom event. This is the endpoint used by the Plausible tracking script.",
        "tags": [
          "Events"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EventRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Event accepted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Site": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "Domain name of the site"
          },
          "timezone": {
            "type": "string",
            "description": "Timezone of the site"
          }
        }
      },
      "SiteListResponse": {
        "type": "object",
        "properties": {
          "sites": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Site"
            }
          }
        }
      },
      "CreateSiteRequest": {
        "type": "object",
        "required": [
          "domain"
        ],
        "properties": {
          "domain": {
            "type": "string",
            "description": "Domain name of the new site"
          },
          "timezone": {
            "type": "string",
            "description": "Timezone for the site (e.g. Europe/London)"
          }
        }
      },
      "UpdateSiteRequest": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "New domain name for the site"
          }
        }
      },
      "CreateSharedLinkRequest": {
        "type": "object",
        "required": [
          "site_id",
          "name"
        ],
        "properties": {
          "site_id": {
            "type": "string",
            "description": "Domain of the site"
          },
          "name": {
            "type": "string",
            "description": "Name of the shared link"
          }
        }
      },
      "SharedLink": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "description": "The URL of the shared dashboard link"
          }
        }
      },
      "CreateGoalRequest": {
        "type": "object",
        "required": [
          "site_id"
        ],
        "properties": {
          "site_id": {
            "type": "string",
            "description": "Domain of the site"
          },
          "goal_type": {
            "type": "string",
            "enum": [
              "event",
              "page"
            ],
            "description": "Type of goal"
          },
          "event_name": {
            "type": "string",
            "description": "Name of the custom event (for event goals)"
          },
          "page_path": {
            "type": "string",
            "description": "Page path (for page goals)"
          }
        }
      },
      "Goal": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Goal ID"
          },
          "domain": {
            "type": "string"
          },
          "goal_type": {
            "type": "string"
          },
          "event_name": {
            "type": "string"
          },
          "page_path": {
            "type": "string"
          }
        }
      },
      "EventRequest": {
        "type": "object",
        "required": [
          "name",
          "url",
          "domain"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the event (use 'pageview' for page views)"
          },
          "url": {
            "type": "string",
            "description": "URL of the page where the event was triggered"
          },
          "domain": {
            "type": "string",
            "description": "Domain of the site in Plausible"
          },
          "referrer": {
            "type": "string",
            "description": "Referrer URL"
          },
          "props": {
            "type": "object",
