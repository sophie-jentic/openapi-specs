            "type": "integer"
          }
        }
      },
      "DivisionList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "TagList": {
        "type": "object",
        "properties": {
