{
  "openapi": "3.0.3",
  "info": {
    "title": "Cruisen API",
    "version": "1.0.0",
    "description": "Public API for cruise travel advisors to manage users, profiles, bookings, and trips.",
    "x-jentic-source-url": "https://cruisen-preview.firebaseapp.com/public-api-docs.html",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://cruisen-production.web.app"
    }
  ],
  "paths": {
    "/get-user": {
      "get": {
        "operationId": "getUser",
        "summary": "Get current user",
        "description": "Retrieves public information about the currently authenticated user",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "User info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/get-profile": {
      "get": {
        "operationId": "getProfile",
        "summary": "Get a profile",
        "description": "Retrieves detailed information about a specific profile",
        "tags": [
          "Profiles"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Profile details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/get-profiles": {
      "get": {
        "operationId": "getProfiles",
        "summary": "Get all profiles",
        "description": "Retrieves profiles based on trip membership or ownership",
        "tags": [
          "Profiles"
        ],
        "responses": {
          "200": {
            "description": "Profiles list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/get-booking": {
      "get": {
        "operationId": "getBooking",
        "summary": "Get a booking",
        "description": "Retrieves detailed information about a specific booking",
        "tags": [
          "Bookings"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/get-bookings": {
      "get": {
        "operationId": "getBookings",
        "summary": "Get all bookings",
        "description": "Retrieves all bookings associated with the authenticated advisor",
        "tags": [
          "Bookings"
        ],
        "responses": {
          "200": {
            "description": "Bookings list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/get-trip": {
      "get": {
        "operationId": "getTrip",
        "summary": "Get a trip",
        "description": "Retrieves detailed information about a specific trip",
        "tags": [
          "Trips"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trip details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/get-trips": {
      "get": {
        "operationId": "getTrips",
        "summary": "Get all trips",
        "description": "Retrieves all trips accessible to the authenticated user",
        "tags": [
          "Trips"
        ],
        "responses": {
          "200": {
            "description": "Trips list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "code": {
            "type": "string"
          },
          "result": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Bookings"
    },
    {
      "name": "Profiles"
    },
    {
      "name": "Trips"
    },
    {
      "name": "Users"
    }
  ]
}
