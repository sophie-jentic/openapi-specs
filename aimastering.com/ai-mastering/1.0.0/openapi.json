{
  "openapi": "3.0.3",
  "info": {
    "title": "AI Mastering API",
    "version": "1.0.0",
    "description": "API for AI Mastering, an automated audio mastering service that uses machine learning to master music tracks.",
    "x-jentic-source-url": "https://aimastering.com/api_docs/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.bakuage.com"
    }
  ],
  "paths": {
    "/masterings": {
      "get": {
        "operationId": "listMasterings",
        "summary": "List mastering jobs",
        "description": "Retrieve a list of mastering jobs for the authenticated user",
        "tags": [
          "Masterings"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of mastering jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Mastering"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createMastering",
        "summary": "Create a mastering job",
        "description": "Submit an audio file for automated mastering",
        "tags": [
          "Masterings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMasteringRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Mastering job created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Mastering"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/masterings/{id}": {
      "get": {
        "operationId": "getMastering",
        "summary": "Get mastering job details",
        "description": "Retrieve details and status of a specific mastering job",
        "tags": [
          "Masterings"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Mastering job ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Mastering job details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Mastering"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Mastering job not found"
          }
        }
      }
    },
    "/audios": {
      "post": {
        "operationId": "uploadAudio",
        "summary": "Upload audio file",
        "description": "Upload an audio file to be used for mastering",
        "tags": [
          "Audio"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Audio file (WAV, MP3, FLAC, etc.)"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Audio uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Audio"
                }
              }
            }
          },
          "400": {
            "description": "Invalid file format"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/audios/{id}": {
      "get": {
        "operationId": "getAudio",
        "summary": "Get audio details",
        "description": "Retrieve details of an uploaded audio file",
        "tags": [
          "Audio"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Audio ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Audio details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Audio"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Audio not found"
          }
        }
      }
    },
    "/audios/{id}/download": {
      "get": {
        "operationId": "downloadAudio",
        "summary": "Download audio file",
        "description": "Download the mastered audio file",
        "tags": [
          "Audio"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Audio ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Audio file binary",
            "content": {
              "audio/*": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Audio not found"
          }
        }
      }
    },
    "/plans": {
      "get": {
        "operationId": "listPlans",
        "summary": "List available plans",
        "description": "Retrieve available subscription plans",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "List of plans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Plan"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Mastering": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "waiting",
              "processing",
              "done",
              "failed"
            ]
          },
          "input_audio_id": {
            "type": "integer"
          },
          "output_audio_id": {
            "type": "integer"
          },
          "target_loudness": {
            "type": "number",
            "description": "Target loudness in LUFS"
          },
          "master_type": {
            "type": "string",
            "enum": [
              "default",
              "custom"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateMasteringRequest": {
        "type": "object",
        "properties": {
          "input_audio_id": {
            "type": "integer",
            "description": "ID of the uploaded audio to master"
          },
          "target_loudness": {
            "type": "number",
            "description": "Target loudness in LUFS (e.g., -14)"
          },
          "mode": {
            "type": "string",
            "enum": [
              "default",
              "custom"
            ],
            "default": "default"
          }
        },
        "required": [
          "input_audio_id"
        ]
      },
      "Audio": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "duration": {
            "type": "number",
            "description": "Duration in seconds"
          },
          "sample_rate": {
            "type": "integer"
          },
          "channels": {
            "type": "integer"
          },
          "loudness": {
            "type": "number",
            "description": "Loudness in LUFS"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Plan": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "max_tracks_per_month": {
            "type": "integer"
          },
          "price": {
            "type": "number"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "API key passed as Bearer token"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Masterings",
      "description": "Manage mastering jobs"
    },
    {
      "name": "Audio",
      "description": "Upload and download audio files"
    },
    {
      "name": "Account",
      "description": "Account and plan management"
    }
  ]
}
