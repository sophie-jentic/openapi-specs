{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "Affico AscendingBull API",
    "description": "baseURL: https://affico.ascendingbull.com:4448/",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/luis.lopez3/AfficoAscendingBull/1.0.0/swagger.json",
    "contact": {}
  },
  "paths": {
    "/auth": {
      "post": {
        "description": "Endpoint to get authoritation token",
        "parameters": [
          {
            "name": "Affiliate",
            "in": "body",
            "description": "affiliate information provided by us",
            "schema": {
              "type": "object",
              "required": [
                "PartnerId",
                "SecretKey",
                "Time",
                "Sign"
              ],
              "properties": {
                "PartnerId": {
                  "type": "integer",
                  "description": "Id provided by us"
                },
                "SecretKey": {
                  "type": "string",
                  "description": "Token provided by us"
                },
                "Time": {
                  "type": "string",
                  "description": "Unix timeStamp"
                },
                "Sign": {
                  "type": "string",
                  "description": "SHA256(PartnerId + Time + Secret_Key)"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully created an auth token",
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    }
                  }
                },
                "error": {
                  "type": "string",
                  "default": ""
                },
                "result": {
                  "type": "integer",
                  "default": 1
                }
              }
            }
          }
        },
        "tags": [
          "auth"
        ],
        "operationId": "post-auth"
      }
    },
    "/create": {
      "post": {
        "description": "Endpoint to create a client",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "a bearer authorization header",
            "required": true,
            "type": "string",
            "default": "Bearer + token"
          },
          {
            "name": "Customer",
            "in": "body",
            "description": "Client information to create a client",
            "schema": {
              "type": "object",
              "required": [
                "firstName",
                "lastName",
                "email",
                "country",
                "phoneNumber",
                "phoneCountryCode",
                "referral",
                "password"
              ],
              "properties": {
                "firstName": {
                  "type": "string"
                },
                "lastName": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "password": {
                  "type": "string",
                  "description": "minlength 8, maxlength 15, at least one number, lowercase and capital letter"
                },
                "country": {
                  "type": "string",
                  "description": "ISO alpha-2 code"
                },
                "phoneNumber": {
                  "type": "string",
                  "description": "max lenght 10"
                },
                "phoneCountryCode": {
                  "type": "string",
                  "description": "phone country code with + included"
                },
                "referral": {
                  "type": "string",
                  "description": "campaign where customer came from"
                },
                "source": {
                  "type": "string",
                  "description": "page where customer came from"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Customer successfully created",
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "object",
                  "properties": {
                    "crmId": {
                      "type": "string"
                    },
                    "tpId": {
                      "type": "string"
                    },
                    "autologinUrl": {
                      "type": "string"
                    }
                  }
                },
                "error": {
                  "type": "string",
                  "default": ""
                },
                "result": {
                  "type": "integer",
                  "default": 1
                }
              }
            }
          }
        },
        "tags": [
          "create"
        ],
        "operationId": "post-create"
      }
    },
    "/get/Multiple": {
      "get": {
        "description": "Shows all customers inserted in a range of dates",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "an bearer authorization header",
            "required": true,
            "type": "string",
            "default": "Bearer + token"
          },
          {
            "name": "page",
            "in": "query",
            "type": "integer",
            "description": "pagination number",
            "default": 1
          },
          {
            "name": "startDate",
            "in": "query",
            "type": "string",
            "description": "start date for range in format YYYY-MM-DD"
          },
          {
            "name": "endDate",
            "in": "query",
            "type": "string",
            "description": "end date for range in format YYYY-MM-DD"
          },
          {
            "name": "rows",
            "in": "query",
            "type": "integer",
            "description": "number of records you want to read",
            "default": 500
          },
          {
            "name": "onlyFtd",
            "in": "query",
            "type": "boolean",
            "description": "boolean to get only ftds or get every lead"
          }
        ],
        "responses": {
          "200": {
            "description": "shows customers",
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "country": {
                        "type": "string"
                      },
                      "crmId": {
                        "type": "string"
                      },
                      "email": {
                        "type": "string"
                      },
                      "firstName": {
                        "type": "string"
                      },
                      "ftd": {
                        "type": "integer"
                      },
                      "ftdDate": {
                        "type": "string",
                        "description": "date in format YYYY-MM-DD HH:mm:SS"
                      },
                      "insertDate": {
                        "type": "string",
                        "description": "date in format YYYY-MM-DD HH:mm:SS"
                      },
                      "lastName": {
                        "type": "string"
                      },
                      "referral": {
                        "type": "string"
                      },
                      "source": {
                        "type": "string"
                      },
                      "status": {
                        "type": "string"
                      },
                      "tpId": {
                        "type": "string"
                      }
                    }
                  }
                },
                "error": {
                  "type": "string",
                  "default": ""
                },
                "result": {
                  "type": "integer",
                  "default": 1
                }
              }
            }
          }
        },
        "tags": [
          "get"
        ],
        "operationId": "get-get-multiple"
      }
    },
    "/get/Single": {
      "get": {
        "description": "Show customer information",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "an bearer authorization header",
            "required": true,
            "type": "string",
            "default": "Bearer + token"
          },
          {
            "name": "email",
            "in": "query",
            "type": "string",
            "description": "Customer's email"
          }
        ],
        "responses": {
          "200": {
            "description": "customer information",
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "object",
                  "properties": {
                    "country": {
                      "type": "string"
                    },
                    "crmId": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string"
                    },
                    "firstName": {
                      "type": "string"
                    },
                    "ftd": {
                      "type": "integer"
                    },
                    "ftdDate": {
                      "type": "string",
                      "description": "date in format YYYY-MM-DD HH:mm:SS"
                    },
                    "insertDate": {
                      "type": "string",
                      "description": "date in format YYYY-MM-DD HH:mm:SS"
                    },
                    "lastName": {
                      "type": "string"
                    },
                    "referral": {
                      "type": "string"
                    },
                    "source": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "tpId": {
                      "type": "string"
                    }
                  }
                },
                "error": {
                  "type": "string",
                  "default": ""
                },
                "result": {
                  "type": "integer",
                  "default": 1
                }
              }
            }
          }
        },
        "tags": [
          "get"
        ],
        "operationId": "get-get-single"
      }
    }
  },
  "schemes": [
    "https"
  ],
  "host": "affico.ascendingbull.com:4448",
  "basePath": "/",
  "tags": [
    {
      "name": "auth"
    },
    {
      "name": "create"
    },
