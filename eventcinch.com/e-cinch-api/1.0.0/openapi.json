{
  "openapi": "3.0.3",
  "info": {
    "title": "E-cinch API",
    "description": "Event management API for E-cinch platform providing cart and user validation functionality for Zapier integrations",
    "version": "1.0.0",
    "x-jentic-source-url": "https://eventcinch.com/zap/apidocs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://eventcinch.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/zap/user": {
      "get": {
        "summary": "Validate User",
        "description": "Validates a user's credentials and returns user information",
        "operationId": "validateUser",
        "parameters": [
          {
            "name": "user_email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            },
            "description": "User email address"
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful validation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ID": {
                      "type": "string"
                    },
                    "username": {
                      "type": "string",
                      "format": "email"
                    },
                    "companyName": {
                      "type": "string"
                    },
                    "contactFirstName": {
                      "type": "string"
                    },
                    "contactLastName": {
                      "type": "string"
                    },
                    "phone": {
                      "type": "string"
                    },
                    "address": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "ID": "497",
                  "username": "central773@gmail.com",
                  "companyName": "Some Company",
                  "contactFirstName": "John",
                  "contactLastName": "Doe",
                  "phone": "555-123-1234",
                  "address": "1234 Main st."
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "zap"
        ]
      }
    },
    "/zap/newcart": {
      "post": {
        "summary": "Subscribe to New Cart Trigger",
        "description": "Subscribes a webhook URL to receive notifications when new carts are created",
        "operationId": "subscribeNewCart",
        "parameters": [
          {
            "name": "user_email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hook_url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "description": "Webhook URL to receive notifications"
          }
        ],
        "responses": {
          "200": {
            "description": "Subscription successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "zap"
        ]
      },
      "delete": {
        "summary": "Unsubscribe from New Cart Trigger",
        "description": "Removes webhook subscription for new cart notifications",
        "operationId": "unsubscribeNewCart",
        "parameters": [
          {
            "name": "user_email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hook_url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Unsubscription successful"
          },
          "404": {
            "description": "Subscription not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "zap"
        ]
      }
    },
    "/zap/updatecart": {
      "post": {
        "summary": "Subscribe to Update Cart Trigger",
        "description": "Subscribes a webhook URL to receive notifications when carts are updated",
        "operationId": "subscribeUpdateCart",
        "parameters": [
          {
            "name": "user_email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hook_url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Subscription successful"
          }
        },
        "tags": [
          "zap"
        ]
      },
      "delete": {
        "summary": "Unsubscribe from Update Cart Trigger",
        "description": "Removes webhook subscription for cart update notifications",
        "operationId": "unsubscribeUpdateCart",
        "parameters": [
          {
            "name": "user_email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hook_url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Unsubscription successful"
          }
        },
        "tags": [
          "zap"
        ]
      }
    },
    "/zap/carts/new": {
      "get": {
        "summary": "List New Carts",
        "description": "Returns a list of newly created carts",
        "operationId": "listNewCarts",
        "parameters": [
          {
            "name": "user_email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of new carts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Cart"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "zap"
        ]
      }
    },
    "/zap/carts/fresh": {
      "get": {
        "summary": "List Fresh Carts",
        "description": "Returns a list of recently modified carts",
        "operationId": "listFreshCarts",
        "parameters": [
          {
            "name": "user_email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of fresh carts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Cart"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "zap"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key authentication"
      }
    },
    "schemas": {
      "Cart": {
        "type": "object",
        "properties": {
          "client_first_name": {
            "type": "string"
          },
          "client_last_name": {
            "type": "string"
          },
          "client_email": {
            "type": "string",
            "format": "email"
          },
          "company_name": {
            "type": "string"
          },
          "event_address": {
            "type": "string"
          },
          "event_title": {
            "type": "string"
          },
          "event_guest_count": {
            "type": "integer"
          },
          "event_date": {
            "type": "string",
            "format": "date"
          },
          "event_start": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "message": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "zap"
    }
  ]
}
