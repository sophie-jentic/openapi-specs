{
  "openapi": "3.0.1",
  "info": {
    "title": "Asynchronous tour delete",
    "description": "Documentation for AM1 homework [https://courses.fit.cvut.cz/NI-AM1/hw/06/index.html](https://courses.fit.cvut.cz/NI-AM1/hw/06/index.html).\n\nWhen user requests to delete a tour, the API responds with status code 303 and gives user URL to monitor the tour removal state in Location header. The confirmation is simulated by a delay. Before the remove is confirmed the tour is still available. After the tour is removed, the monitoring page updates the content to \"Tour deleted\".\n",
    "version": "1.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/letomas/asynchronous-delete/1.0/swagger.json",
    "contact": {}
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/tour/{id}": {
      "get": {
        "tags": [
          "Tour"
        ],
        "operationId": "getTour",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Tour"
                }
              }
            }
          },
          "404": {
            "description": "Tour not found"
          }
        },
        "description": "Gettour"
      },
      "delete": {
        "tags": [
          "Tour"
        ],
        "operationId": "deleteTour",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "303": {
            "description": "Gives URL to monitor tour removal state in Location header",
            "headers": {
              "location": {
                "description": "URL to monitor the process of tour removal",
                "schema": {
                  "type": "string",
                  "format": "uri",
                  "example": "http://localhost:8080/confirmation/0"
                }
              }
            }
          },
          "400": {
            "description": "Bad request (already queued to delete, waiting for confirmation)"
          },
          "404": {
            "description": "Tour not found"
          }
        },
        "description": "Deletetour"
      }
    },
    "/tour": {
      "get": {
        "tags": [
          "Tour"
        ],
        "operationId": "getTours",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Tour"
                  }
                }
              }
            }
          }
        },
        "description": "Gettours"
      }
    },
    "/confirmation/{id}": {
      "get": {
        "tags": [
          "Removal Status"
        ],
        "operationId": "getConfirmation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "enum": [
                    "Waiting for confirmation to remove the tour",
                    "Tour deleted"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Page not found"
          }
        },
        "description": "Getconfirmation"
      }
    }
  },
  "components": {
    "schemas": {
      "Tour": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          },
          "startsOn": {
            "type": "string",
            "format": "date"
          },
          "endsOn": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Removal Status"
    },
    {
      "name": "Tour"
    }
  ]
}
