{
  "openapi": "3.0.0",
  "info": {
    "title": "What's On The Menu API",
    "version": "1.0.0",
    "description": "The New York Public Library's What's On The Menu API provides access to historical menu data, including menus and dishes from restaurants dating back to the 1850s.",
    "contact": {
      "email": "menus@nypl.org",
      "url": "http://nypl.github.io/menus-api/"
    }
  },
  "servers": [
    {
      "url": "http://api.menus.nypl.org",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiTokenQuery": []
    }
  ],
  "paths": {
    "/menus": {
      "get": {
        "summary": "List menus",
        "description": "Returns a paginated list of menus with optional filtering",
        "operationId": "listMenus",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API access token"
          },
          {
            "name": "min_year",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Minimum year for date range (inclusive)"
          },
          {
            "name": "max_year",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Maximum year for date range (exclusive)"
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["date", "name", "dish_count"]
            },
            "description": "Sort order (defaults to date, most recent to oldest)"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["under_review", "complete", "to_transcribe"]
            },
            "description": "Filter by transcription status"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 50
            },
            "description": "Number of results per page (max 50)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stats": {
                      "type": "object",
                      "properties": {
                        "count": {
                          "type": "integer"
                        },
                        "earliest_menu": {
                          "type": "integer"
                        },
                        "latest_menu": {
                          "type": "integer"
                        },
                        "to_transcribe": {
                          "type": "integer"
                        },
                        "under_review": {
                          "type": "integer"
                        },
                        "complete": {
                          "type": "integer"
                        }
                      }
                    },
                    "menus": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Menu"
                      }
                    }
                  }
                }
              },
              "application/xml": {
                "schema": {
                  "type": "object"
                }
              }
            },
            "headers": {
              "X-Ratelimit-Limit": {
                "schema": {
                  "type": "integer"
                },
                "description": "Rate limit per day"
              },
              "X-Ratelimit-Remaining": {
                "schema": {
                  "type": "integer"
                },
                "description": "Remaining requests"
              },
              "Link": {
                "schema": {
                  "type": "string"
                },
                "description": "Pagination links (first, prev, next, last)"
              }
            }
          }
        }
      }
    },
    "/menus/{id}": {
      "get": {
        "summary": "Get menu by ID",
        "description": "Returns detailed information about a specific menu",
        "operationId": "getMenu",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Menu ID"
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API access token"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Menu"
                }
              },
              "application/xml": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/menus/{id}/pages": {
      "get": {
        "summary": "Get menu pages",
        "description": "Returns all pages for a specific menu",
        "operationId": "getMenuPages",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Menu ID"
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API access token"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "links": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "href": {
                            "type": "string"
                          },
                          "rel": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "pages": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Page"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/menus/{id}/dishes": {
      "get": {
        "summary": "Get menu dishes",
        "description": "Returns all dishes for a specific menu",
        "operationId": "getMenuDishes",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Menu ID"
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API access token"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "links": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "dishes": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Dish"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/menus/search": {
      "get": {
        "summary": "Search menus",
        "description": "Search for menus by various criteria",
        "operationId": "searchMenus",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API access token"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/dishes": {
      "get": {
        "summary": "List dishes",
        "description": "Returns a paginated list of dishes",
        "operationId": "listDishes",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API access token"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100
            },
            "description": "Number of results per page (max 100)"
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["date"]
            },
            "description": "Sort order"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "dishes": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Dish"
                      }
                    }
                  }
                }
              }
            },
            "headers": {
              "Link": {
                "schema": {
                  "type": "string"
                },
                "description": "Pagination links"
              }
            }
          }
        }
      }
    },
    "/dishes/{id}": {
      "get": {
        "summary": "Get dish by ID",
        "description": "Returns detailed information about a specific dish",
        "operationId": "getDish",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Dish ID"
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API access token"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Dish"
                }
              }
            }
          }
        }
      }
    },
    "/dishes/{id}/menus": {
      "get": {
        "summary": "Get menus containing dish",
        "description": "Returns all menus that contain a specific dish",
        "operationId": "getDishMenus",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Dish ID"
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API access token"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/dishes/search": {
      "get": {
        "summary": "Search dishes",
        "description": "Search for dishes by name or other criteria",
        "operationId": "searchDishes",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API access token"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiTokenQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "API token obtained by emailing menus@nypl.org with subject 'API ACCESS'"
      }
    },
    "schemas": {
      "Menu": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "sponsor": {
            "type": "string"
          },
          "venue": {
            "type": "string",
            "nullable": true
          },
          "event": {
            "type": "string",
            "nullable": true
          },
          "place": {
            "type": "string",
            "nullable": true
          },
          "occasion": {
            "type": "string",
            "nullable": true
          },
          "physical_description": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "call_number": {
            "type": "string"
          },
          "keywords": {
            "type": "string",
            "nullable": true
          },
          "language": {
            "type": "string",
            "nullable": true
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string",
            "enum": ["complete", "under review", "to_transcribe"]
          },
          "currency": {
            "type": "string",
            "nullable": true
          },
          "currency_symbol": {
            "type": "string",
            "nullable": true
          },
          "location": {
            "type": "string"
          },
          "location_type": {
            "type": "string",
            "nullable": true
          },
          "page_count": {
            "type": "integer"
          },
          "dish_count": {
            "type": "integer"
          },
          "thumbnail_src": {
            "type": "string",
            "format": "uri"
          },
          "large_src": {
            "type": "string",
            "format": "uri"
          },
          "first_page_aspect": {
            "type": "string",
            "enum": ["portrait", "landscape"]
          },
          "first_page_full_width": {
            "type": "integer",
            "description": "Width in pixels"
          },
          "first_page_full_height": {
            "type": "integer",
            "description": "Height in pixels"
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "rel": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Page": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "page_number": {
            "type": "integer"
          },
          "image_id": {
            "type": "string"
          },
          "full_height": {
            "type": "integer",
            "description": "Height in pixels"
          },
          "full_width": {
            "type": "integer",
            "description": "Width in pixels"
          },
          "uuid": {
            "type": "string",
            "description": "NYPL Image Repository UUID"
          }
        }
      },
      "Dish": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "price": {
            "type": "string",
            "nullable": true,
            "description": "String representation of float value"
          },
          "high_price": {
            "type": "string",
            "nullable": true,
            "description": "String representation of float value"
          },
          "xpos": {
            "type": "number"
          },
          "ypos": {
            "type": "number"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
