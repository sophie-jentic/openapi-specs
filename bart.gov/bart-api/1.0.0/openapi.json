    "/etd.aspx": {
      "get": {
        "tags": [
          "RealTime"
        ],
        "summary": "Get Real-Time Estimated Departures",
        "operationId": "getEstimatedDepartures",
        "description": "Requests current departure information for a station. Returns estimated time of departure, platform, direction, line color, bike flags, and delay information.",
        "parameters": [
          {
            "name": "cmd",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "etd"
              ]
            },
            "description": "Command: etd"
          },
          {
            "name": "orig",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Station abbreviation (e.g. RICH, 12TH) or 'ALL' for all stations"
          },
          {
            "name": "plat",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4
            },
            "description": "Limit results to a specific platform (1-4). Cannot be used with 'dir'."
          },
          {
            "name": "dir",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "n",
                "s"
              ]
            },
            "description": "Limit results to direction: 'n' (Northbound) or 's' (Southbound). Cannot be used with 'plat'."
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API registration key"
          },
          {
            "name": "json",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "y"
              ]
            },
            "description": "Set to 'y' to return JSON instead of XML"
          }
        ],
        "responses": {
          "200": {
            "description": "Estimated departure information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EtdResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
