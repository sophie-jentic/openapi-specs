{
  "openapi": "3.0.3",
  "info": {
    "title": "BART API",
    "version": "1.0.0",
    "description": "Bay Area Rapid Transit (BART) API provides access to real-time estimates, station information, route details, schedule information, and service advisories for the BART transit system.",
    "x-jentic-source-url": "https://api.bart.gov/docs/overview/index.aspx",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.bart.gov/api",
      "description": "BART API"
    }
  ],
  "tags": [
    {
      "name": "Advisories",
      "description": "BART service advisories (BSA)"
    },
    {
      "name": "RealTime",
      "description": "Real-time estimated departure information"
    },
    {
      "name": "Stations",
      "description": "Station information"
    },
    {
      "name": "Routes",
      "description": "Route/line information"
    },
    {
      "name": "Schedules",
      "description": "Schedule information including fares and trip planning"
    }
  ],
  "paths": {
    "/bsa.aspx": {
      "get": {
        "tags": [
          "Advisories"
        ],
        "summary": "Get Service Advisories",
        "operationId": "getServiceAdvisories",
        "description": "Requests current BART service advisory (BSA) information. Messages are tagged system-wide with station code 'BART'. Type will be DELAY or EMERGENCY.",
        "parameters": [
          {
            "name": "cmd",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "bsa"
              ]
            },
            "description": "Command: bsa"
          },
          {
            "name": "orig",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "all"
            },
            "description": "Station abbreviation or 'all'. Currently only 'all' is supported."
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API registration key"
          },
          {
            "name": "json",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "y"
              ]
            },
            "description": "Set to 'y' to return JSON instead of XML"
          }
        ],
        "responses": {
          "200": {
            "description": "Advisory information returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdvisoryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
