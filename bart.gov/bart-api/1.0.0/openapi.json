    "/sched.aspx#depart": {
      "get": {
        "tags": [
          "Schedules"
        ],
        "summary": "Get Trip Plan (Depart)",
        "operationId": "getTripPlanDepart",
        "description": "Returns scheduled trips between two stations based on departure time. Includes fare, trip time, and transfer details.",
        "parameters": [
          {
            "name": "cmd",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "depart"
              ]
            },
            "description": "Command: depart"
          },
          {
            "name": "orig",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Origin station abbreviation"
          },
          {
            "name": "dest",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Destination station abbreviation"
          },
          {
            "name": "date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Date (mm/dd/yyyy), 'today', or 'now'"
          },
          {
            "name": "time",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Time (h:mm+am/pm) or 'now'"
          },
          {
            "name": "b",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 2
            },
            "description": "Number of trips before the specified time"
          },
          {
            "name": "a",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 2
            },
            "description": "Number of trips after the specified time"
          },
          {
            "name": "l",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "description": "Set to 1 to return legend information"
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API registration key"
          },
          {
            "name": "json",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "y"
              ]
            },
            "description": "Set to 'y' to return JSON instead of XML"
          }
        ],
        "responses": {
          "200": {
            "description": "Trip plan results"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
