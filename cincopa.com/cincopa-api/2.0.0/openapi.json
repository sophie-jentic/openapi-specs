{
  "openapi": "3.0.3",
  "info": {
    "title": "Cincopa REST API V2",
    "version": "1.0.0",
    "description": "Cincopa REST API V2 provides methods to access and manipulate galleries and assets. Authentication uses an api_token. Designed for server-to-server (read/write) and client-to-server (read-only) scenarios.",
    "x-jentic-source-url": "https://developer.cincopa.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.cincopa.com/v2",
      "description": "Cincopa API V2 server"
    }
  ],
  "security": [
    {
      "apiToken": []
    }
  ],
  "tags": [
    {
      "name": "General",
      "description": "Validate connection and get temporary tokens"
    },
    {
      "name": "Gallery",
      "description": "Manage media galleries"
    },
    {
      "name": "Assets",
      "description": "Manage media assets"
    }
  ],
  "paths": {
    "/ping.json": {
      "get": {
        "operationId": "ping",
        "summary": "Validate API connection",
        "description": "Confirm the validity and responsiveness of your API connection.",
        "tags": [
          "General"
        ],
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your API token"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful ping",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BasicResponse"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/token.get_temp.json": {
      "get": {
        "operationId": "getTempToken",
        "summary": "Obtain a temporary token",
        "description": "Generate a temporary token for frontend client-to-server communications.",
        "tags": [
          "General"
        ],
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Temporary token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "runtime": {
                      "type": "integer"
                    },
                    "temp_token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized"
          }
        }
      }
    },
