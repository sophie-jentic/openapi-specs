    "/asset.list.json": {
      "get": {
        "operationId": "listAssets",
        "summary": "List assets",
        "description": "Get a list of assets in the account. Use search to locate specific assets or reference_id.",
        "tags": [
          "Assets"
        ],
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Text search for assets"
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "video,image,audio,other"
            },
            "description": "Asset types to return"
          },
          {
            "name": "rid",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Resource ID to locate specific asset"
          },
          {
            "name": "reference_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "External reference ID"
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by tag (use 'no-tag' or 'any-tag')"
          },
          {
            "name": "details",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Extra metadata fields to return"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "items_per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
