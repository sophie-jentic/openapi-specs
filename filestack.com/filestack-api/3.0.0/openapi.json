{
  "openapi": "3.0.3",
  "info": {
    "title": "Filestack API",
    "description": "Filestack is a file handling service that provides APIs for uploading, storing, transforming, and delivering files. The API supports file uploads, metadata retrieval, file deletion, URL-based ingestion, and image/document processing transformations.",
    "version": "3.0.0",
    "contact": {
      "name": "Filestack",
      "url": "https://www.filestack.com"
    }
  },
  "servers": [
    {
      "url": "https://www.filestackapi.com/api",
      "description": "Filestack File API server"
    },
    {
      "url": "https://upload.filestackapi.com",
      "description": "Filestack Upload API server"
    },
    {
      "url": "https://cdn.filestackcontent.com",
      "description": "Filestack CDN for file delivery"
    },
    {
      "url": "https://process.filestackapi.com",
      "description": "Filestack Processing API server"
    },
    {
      "url": "https://cloud.filestackapi.com",
      "description": "Filestack Cloud API server"
    }
  ],
  "paths": {
    "/file/{handle}": {
      "get": {
        "summary": "Retrieve a file",
        "description": "Download or retrieve a file by its Filestack handle. Returns the file content.",
        "operationId": "getFile",
        "servers": [
          {
            "url": "https://cdn.filestackcontent.com",
            "description": "Filestack CDN"
          }
        ],
        "parameters": [
          {
            "name": "handle",
            "in": "path",
            "required": true,
            "description": "The Filestack file handle",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dl",
            "in": "query",
            "description": "Set to true to force download (Content-Disposition: attachment)",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "cache",
            "in": "query",
            "description": "Set to false to disable caching",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File content returned",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "File not found"
          }
        },
        "tags": [
          "file"
        ]
      },
      "head": {
        "summary": "Get file headers",
        "description": "Retrieve HTTP headers for a file without downloading it.",
        "operationId": "headFile",
        "servers": [
          {
            "url": "https://cdn.filestackcontent.com",
            "description": "Filestack CDN"
          }
        ],
        "parameters": [
          {
            "name": "handle",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File headers returned"
          }
        },
        "tags": [
          "file"
        ]
      },
      "delete": {
        "summary": "Delete a file",
        "description": "Delete a file from Filestack. Requires security policy and signature.",
        "operationId": "deleteFile",
        "servers": [
          {
            "url": "https://www.filestackapi.com/api",
            "description": "Filestack File API"
          }
        ],
        "parameters": [
          {
            "name": "handle",
            "in": "path",
            "required": true,
            "description": "The Filestack file handle to delete",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Your Filestack API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "policy",
            "in": "query",
            "required": true,
            "description": "Security policy (base64 encoded JSON)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "signature",
            "in": "query",
            "required": true,
            "description": "HMAC-SHA256 signature of the policy",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "skip_storage",
            "in": "query",
            "description": "Skip removing from cloud storage, only remove from Filestack",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File deleted successfully"
          },
          "403": {
            "description": "Security policy or signature invalid"
          }
        },
        "tags": [
          "file"
        ]
      }
    },
    "/file/{handle}/metadata": {
      "get": {
        "summary": "Get file metadata",
        "description": "Retrieve metadata about a file, including size, mimetype, filename, dimensions (for images), checksums, and more.",
        "operationId": "getFileMetadata",
        "servers": [
          {
            "url": "https://www.filestackapi.com/api",
            "description": "Filestack File API"
          }
        ],
        "parameters": [
          {
            "name": "handle",
            "in": "path",
            "required": true,
            "description": "The Filestack file handle",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Include file size in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "mimetype",
            "in": "query",
            "description": "Include MIME type in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "filename",
            "in": "query",
            "description": "Include filename in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "width",
            "in": "query",
            "description": "Include image width in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "height",
            "in": "query",
            "description": "Include image height in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "uploaded",
            "in": "query",
            "description": "Include upload timestamp in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "writeable",
            "in": "query",
            "description": "Include writeable status in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "cloud",
            "in": "query",
            "description": "Include cloud storage info in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "source_url",
            "in": "query",
            "description": "Include source URL in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "md5",
            "in": "query",
            "description": "Include MD5 hash in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sha1",
            "in": "query",
            "description": "Include SHA-1 hash in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sha224",
            "in": "query",
            "description": "Include SHA-224 hash in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sha256",
            "in": "query",
            "description": "Include SHA-256 hash in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sha384",
            "in": "query",
            "description": "Include SHA-384 hash in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sha512",
            "in": "query",
            "description": "Include SHA-512 hash in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Include storage location in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "path",
            "in": "query",
            "description": "Include storage path in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "container",
            "in": "query",
            "description": "Include storage container in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "exif",
            "in": "query",
            "description": "Include EXIF data in response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "policy",
            "in": "query",
            "description": "Security policy (if security is enabled)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "signature",
            "in": "query",
            "description": "Security signature (if security is enabled)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileMetadata"
                }
              }
            }
          }
        },
        "tags": [
          "file"
        ]
      }
    },
    "/store/{storeLocation}": {
      "post": {
        "summary": "Store a file from URL",
        "description": "Store a file from a URL into cloud storage. Supports S3, Google Cloud Storage, Azure, Dropbox, and Rackspace.",
        "operationId": "storeFromUrl",
        "servers": [
          {
            "url": "https://www.filestackapi.com/api",
            "description": "Filestack File API"
          }
        ],
        "parameters": [
          {
            "name": "storeLocation",
            "in": "path",
            "required": true,
            "description": "Storage location (s3, gcs, azure, dropbox, rackspace)",
            "schema": {
              "type": "string",
              "enum": [
                "s3",
                "gcs",
                "azure",
                "dropbox",
                "rackspace"
              ]
            }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Your Filestack API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "URL of the file to store",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "filename",
            "in": "query",
            "description": "Custom filename for the stored file",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mimetype",
            "in": "query",
            "description": "MIME type override",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "path",
            "in": "query",
            "description": "Custom storage path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "container",
            "in": "query",
            "description": "Storage container/bucket name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "access",
            "in": "query",
            "description": "File access level",
            "schema": {
              "type": "string",
              "enum": [
                "public",
                "private"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File stored successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StoreResponse"
                }
              }
            }
          }
        },
        "tags": [
          "store"
        ]
      }
    },
    "/process": {
      "post": {
        "summary": "Process files",
        "description": "Process files through Filestack's transformation pipeline. Supports storing from URL with transformation tasks.",
        "operationId": "processFiles",
        "servers": [
          {
            "url": "https://process.filestackapi.com",
            "description": "Filestack Processing API"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "apikey",
                  "sources",
                  "tasks"
                ],
                "properties": {
                  "apikey": {
                    "type": "string",
                    "description": "Your Filestack API key"
                  },
                  "sources": {
                    "type": "array",
                    "description": "Source URLs or objects with source and headers",
                    "items": {
                      "oneOf": [
                        {
                          "type": "string",
                          "format": "uri"
                        },
                        {
                          "type": "object",
                          "properties": {
                            "source": {
                              "type": "string",
                              "format": "uri"
                            },
                            "headers": {
                              "type": "object",
                              "additionalProperties": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      ]
                    }
                  },
                  "tasks": {
                    "type": "array",
                    "description": "Array of transformation tasks to apply",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string",
                          "description": "Task name (e.g., resize, crop, rotate, store)"
                        },
                        "params": {
                          "type": "object",
                          "description": "Task-specific parameters"
                        }
                      }
                    }
                  },
                  "upload_tags": {
                    "type": "object",
                    "description": "Custom tags for the upload",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Processing result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessResponse"
                }
              }
            }
          }
        },
        "tags": [
          "process"
        ]
      }
    },
    "/{apikey}/{transforms}/{handle}": {
      "get": {
        "summary": "Transform a file via URL",
        "description": "Apply transformations to a file using URL-based parameters. Transformations include resize, crop, rotate, watermark, convert, and many more.",
        "operationId": "transformFile",
        "servers": [
          {
            "url": "https://cdn.filestackcontent.com",
            "description": "Filestack CDN"
          }
        ],
        "parameters": [
          {
            "name": "apikey",
            "in": "path",
            "required": true,
            "description": "Your Filestack API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "transforms",
            "in": "path",
            "required": true,
            "description": "Transformation string (e.g., resize=width:200,height:200/crop=dim:[0,0,200,200])",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "handle",
            "in": "path",
            "required": true,
            "description": "Filestack file handle or external URL",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transformed file content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        },
        "tags": [
          "default"
        ]
      }
    },
    "/multipart/start": {
      "post": {
        "summary": "Start multipart upload",
        "description": "Initiate a multipart upload session for large files.",
        "operationId": "startMultipartUpload",
        "servers": [
          {
            "url": "https://upload.filestackapi.com",
            "description": "Filestack Upload API"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "apikey",
                  "filename",
                  "mimetype",
                  "size"
                ],
                "properties": {
                  "apikey": {
                    "type": "string",
                    "description": "Your Filestack API key"
                  },
                  "filename": {
                    "type": "string"
                  },
                  "mimetype": {
                    "type": "string"
                  },
                  "size": {
                    "type": "integer",
                    "description": "Total file size in bytes"
                  },
                  "policy": {
                    "type": "string"
                  },
                  "signature": {
                    "type": "string"
                  },
                  "store": {
                    "type": "object",
                    "properties": {
                      "location": {
                        "type": "string"
                      },
                      "path": {
                        "type": "string"
                      },
                      "container": {
                        "type": "string"
                      },
                      "region": {
                        "type": "string"
                      },
                      "access": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Multipart upload initiated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "uri": {
                      "type": "string"
                    },
                    "region": {
                      "type": "string"
                    },
                    "upload_id": {
                      "type": "string"
                    },
                    "location_url": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "multipart"
        ]
      }
    },
    "/multipart/upload": {
      "post": {
        "summary": "Upload a part",
        "description": "Upload a single part of a multipart upload.",
        "operationId": "uploadPart",
        "servers": [
          {
            "url": "https://upload.filestackapi.com",
            "description": "Filestack Upload API"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "apikey": {
                    "type": "string"
                  },
                  "uri": {
                    "type": "string"
                  },
                  "region": {
                    "type": "string"
                  },
                  "upload_id": {
                    "type": "string"
                  },
                  "part": {
                    "type": "integer"
                  },
                  "size": {
                    "type": "integer"
                  },
                  "md5": {
                    "type": "string"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Part uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    },
                    "headers": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "multipart"
        ]
      }
    },
    "/multipart/complete": {
      "post": {
        "summary": "Complete multipart upload",
        "description": "Complete a multipart upload session after all parts have been uploaded.",
        "operationId": "completeMultipartUpload",
        "servers": [
          {
            "url": "https://upload.filestackapi.com",
            "description": "Filestack Upload API"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "apikey",
                  "uri",
                  "region",
                  "upload_id",
                  "filename",
                  "mimetype",
                  "size"
                ],
                "properties": {
                  "apikey": {
                    "type": "string"
                  },
                  "uri": {
                    "type": "string"
                  },
                  "region": {
                    "type": "string"
                  },
                  "upload_id": {
                    "type": "string"
                  },
                  "filename": {
                    "type": "string"
                  },
                  "mimetype": {
                    "type": "string"
                  },
                  "size": {
                    "type": "integer"
                  },
                  "parts": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "part_number": {
                          "type": "integer"
                        },
                        "etag": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "store": {
                    "type": "object",
                    "properties": {
                      "location": {
                        "type": "string"
                      },
                      "path": {
                        "type": "string"
                      },
                      "container": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StoreResponse"
                }
              }
            }
          }
        },
        "tags": [
          "multipart"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "key",
        "in": "query",
        "description": "Filestack API key"
      },
      "securityPolicy": {
        "type": "apiKey",
        "name": "policy",
        "in": "query",
        "description": "Base64-encoded security policy JSON"
      },
      "securitySignature": {
        "type": "apiKey",
        "name": "signature",
        "in": "query",
        "description": "HMAC-SHA256 signature of the policy"
      }
    },
    "schemas": {
      "FileMetadata": {
        "type": "object",
        "properties": {
          "handle": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "description": "File size in bytes"
          },
          "mimetype": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "width": {
            "type": "integer",
            "description": "Image width in pixels"
          },
          "height": {
            "type": "integer",
            "description": "Image height in pixels"
          },
          "uploaded": {
            "type": "number",
            "description": "Upload timestamp"
          },
          "writeable": {
            "type": "boolean"
          },
          "cloud": {
            "type": "object"
          },
          "source_url": {
            "type": "string"
          },
          "md5": {
            "type": "string"
          },
          "sha1": {
            "type": "string"
          },
          "sha224": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "sha384": {
            "type": "string"
          },
          "sha512": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "container": {
            "type": "string"
          },
          "exif": {
            "type": "object",
            "description": "EXIF data for images",
            "additionalProperties": true
          }
        }
      },
      "StoreResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "handle": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "description": "MIME type"
          },
          "mimetype": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "upload_tags": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "ProcessResponse": {
        "type": "object",
        "properties": {
          "handle": {
            "type": "string"
          },
