    "/image/wallpaper": {
      "post": {
        "operationId": "getWallpaper",
        "summary": "Get a random wallpaper",
        "description": "Retrieve a random wallpaper image URL.",
        "requestBody": {
          "required": false,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "nsfw": {
                    "type": "string",
                    "description": "Whether to include NSFW content",
                    "enum": [
                      "true",
                      "false"
                    ],
                    "default": "false"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Wallpaper URL response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "example": 200
                    },
                    "url": {
                      "type": "string",
                      "format": "uri",
                      "description": "URL of the random wallpaper image"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "tags": [
          "Images"
        ]
      }
    }
  },
  "components": {
    "requestBodies": {
      "ImageUrlBody": {
        "required": true,
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "type": "object",
              "required": [
                "url"
              ],
              "properties": {
                "url": {
                  "type": "string",
                  "format": "uri",
                  "description": "URL of the image to process"
                }
              }
            }
          }
        }
      }
    },
    "responses": {
      "ImageResponse": {
        "description": "Generated image returned as binary data",
        "content": {
          "image/png": {
            "schema": {
              "type": "string",
              "format": "binary"
            }
          }
        }
      },
      "UnauthorizedError": {
        "description": "Unauthorized - invalid or missing API token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "BadRequestError": {
        "description": "Bad request - missing or invalid parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "tags": [
    {
      "name": "Image Generation",
      "description": "Generate images with various effects and overlays"
    },
    {
      "name": "Images",
      "description": "Retrieve random images"
    }
  ]
}
