{
  "openapi": "3.0.3",
  "info": {
    "title": "Amethyste API",
    "description": "Amethyste is an image generation and manipulation API. It provides endpoints to apply various effects and overlays to images (such as glitch, blur, sepia, pixelize, etc.) and to retrieve random images (wallpapers). The API is associated with the Amethyste Discord bot.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.amethyste.moe/",
    "contact": {
      "name": "Amethyste",
      "url": "https://api.amethyste.moe"
    }
  },
  "servers": [
    {
      "url": "https://v1.api.amethyste.moe",
      "description": "Amethyste API v1"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/generate/circle": {
      "post": {
        "operationId": "generateCircle",
        "summary": "Circle crop an image",
        "description": "Crop an image into a circle shape.",
        "requestBody": {
          "$ref": "#/components/requestBodies/ImageUrlBody"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/ImageResponse"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          }
        },
        "tags": [
          "Image Generation"
        ]
      }
    },
