    "/generate/pixelize": {
      "post": {
        "operationId": "generatePixelize",
        "summary": "Apply pixelization effect",
        "description": "Apply a pixelization effect to an image.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of the image to process"
                  },
                  "pixelize": {
                    "type": "integer",
                    "description": "Pixelization level (1-50, default: 8)",
                    "minimum": 1,
                    "maximum": 50,
                    "default": 8
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/ImageResponse"
          },
          "401": {
