{
  "openapi": "3.0.3",
  "info": {
    "title": "BounCA API",
    "version": "1.0.0",
    "description": "BounCA is a PKI (Public Key Infrastructure) certificate authority management tool. Built on Django REST Framework, it provides a web interface and REST API for creating and managing Root CAs, Intermediate CAs, and end-entity certificates (server, client, code signing).",
    "x-jentic-source-url": "https://bounca.org/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{bounca-host}/api"
    }
  ],
  "paths": {
    "/auth/login/": {
      "post": {
        "operationId": "login",
        "summary": "Authenticate user",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "key": {
                      "type": "string",
                      "description": "Auth token"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Authenticate user"
      }
    },
    "/auth/logout/": {
      "post": {
        "operationId": "logout",
        "summary": "Logout user",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Logged out"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Logout user"
      }
    },
    "/auth/user/": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current user details",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "User details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get current user details"
      }
    },
    "/certificates/": {
      "get": {
        "operationId": "listCertificates",
        "summary": "List all certificates",
        "description": "Returns all certificates including Root CAs, Intermediate CAs, and end-entity certificates.",
        "tags": [
          "Certificates"
        ],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "R",
                "I",
                "S",
                "C",
                "O"
              ]
            },
            "description": "Filter by type: R=Root CA, I=Intermediate CA, S=Server, C=Client, O=Code Signing"
          },
          {
            "name": "parent",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Filter by parent certificate ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Certificate list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Certificate"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createCertificate",
        "summary": "Create a new certificate",
        "tags": [
          "Certificates"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CertificateCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Certificate created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Certificate"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a new certificate"
      }
    },
    "/certificates/{id}/": {
      "get": {
        "operationId": "getCertificate",
        "summary": "Get certificate details",
        "tags": [
          "Certificates"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Certificate details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Certificate"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get certificate details"
      },
      "patch": {
        "operationId": "updateCertificate",
        "summary": "Update certificate",
        "tags": [
          "Certificates"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CertificateUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update certificate"
      },
      "delete": {
        "operationId": "deleteCertificate",
        "summary": "Delete certificate",
        "tags": [
          "Certificates"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Delete certificate"
      }
    },
    "/certificates/{id}/revoke/": {
      "post": {
        "operationId": "revokeCertificate",
        "summary": "Revoke a certificate",
        "tags": [
          "Certificates"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reason": {
                    "type": "string",
                    "enum": [
                      "unspecified",
                      "keyCompromise",
                      "cACompromise",
                      "affiliationChanged",
                      "superseded",
                      "cessationOfOperation"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Certificate revoked"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Revoke a certificate"
      }
    },
    "/certificates/{id}/crl/": {
      "get": {
        "operationId": "getCRL",
        "summary": "Download Certificate Revocation List",
        "tags": [
          "Certificates"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CRL file",
            "content": {
              "application/x-pem-file": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Download Certificate Revocation List"
      },
      "post": {
        "operationId": "generateCRL",
        "summary": "Generate new CRL",
        "tags": [
          "Certificates"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CRL generated"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Generate new CRL"
      }
    },
    "/certificates/{id}/download/": {
      "get": {
        "operationId": "downloadCertificate",
        "summary": "Download certificate files",
        "description": "Download certificate, key, and chain files in various formats.",
        "tags": [
          "Certificates"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "pem",
                "der",
                "pkcs12"
              ]
            },
            "description": "Output format"
          }
        ],
        "responses": {
          "200": {
            "description": "Certificate file",
            "content": {
              "application/x-pem-file": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/certificates/{id}/renew/": {
      "post": {
        "operationId": "renewCertificate",
        "summary": "Renew a certificate",
        "tags": [
          "Certificates"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "days": {
                    "type": "integer",
                    "description": "Validity period in days"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Certificate renewed"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Renew a certificate"
      }
    },
    "/certificates/{id}/info/": {
      "get": {
        "operationId": "getCertificateInfo",
        "summary": "Get parsed certificate information",
        "description": "Returns detailed X.509 certificate information including subject, issuer, validity dates, extensions, etc.",
        "tags": [
          "Certificates"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Certificate info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CertificateInfo"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "pk": {
            "type": "integer"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          }
        }
      },
      "Certificate": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "enum": [
              "R",
              "I",
              "S",
              "C",
              "O"
            ]
          },
          "name": {
            "type": "string"
          },
          "dn": {
            "type": "object",
            "properties": {
              "commonName": {
                "type": "string"
              },
              "organizationName": {
                "type": "string"
              },
              "countryName": {
                "type": "string"
              },
              "stateOrProvinceName": {
                "type": "string"
              },
              "localityName": {
                "type": "string"
              },
              "emailAddress": {
                "type": "string"
              }
            }
          },
          "parent": {
            "type": "integer"
          },
          "serial": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "revoked_at": {
            "type": "string",
            "format": "date-time"
          },
          "days_valid": {
            "type": "integer"
          },
          "expired": {
            "type": "boolean"
          },
          "revoked": {
            "type": "boolean"
          },
          "passphrase_issuer": {
            "type": "boolean"
          },
          "passphrase_out": {
            "type": "boolean"
          },
          "crl_distribution_url": {
            "type": "string"
          },
          "ocsp_distribution_host": {
            "type": "string"
          }
        }
      },
      "CertificateCreate": {
        "type": "object",
        "required": [
          "type",
          "name",
          "dn"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "R",
              "I",
              "S",
              "C",
              "O"
            ]
          },
          "name": {
            "type": "string"
          },
          "parent": {
            "type": "integer"
          },
          "dn": {
            "type": "object",
            "required": [
              "commonName"
            ],
            "properties": {
              "commonName": {
                "type": "string"
              },
              "organizationName": {
                "type": "string"
              },
              "countryName": {
                "type": "string"
              },
              "stateOrProvinceName": {
                "type": "string"
              },
              "localityName": {
                "type": "string"
              },
              "emailAddress": {
                "type": "string"
              }
            }
          },
          "days_valid": {
            "type": "integer"
          },
          "passphrase_issuer": {
            "type": "string"
          },
          "passphrase_out": {
            "type": "string"
          },
          "crl_distribution_url": {
            "type": "string"
          },
          "ocsp_distribution_host": {
            "type": "string"
          },
          "subject_alt_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CertificateUpdate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "crl_distribution_url": {
            "type": "string"
          },
          "ocsp_distribution_host": {
            "type": "string"
          }
        }
      },
      "CertificateInfo": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "object"
          },
          "issuer": {
            "type": "object"
          },
          "serial_number": {
            "type": "string"
          },
          "not_before": {
            "type": "string",
            "format": "date-time"
          },
          "not_after": {
            "type": "string",
            "format": "date-time"
          },
          "key_usage": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extended_key_usage": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "subject_alt_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "signature_algorithm": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "tokenAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Token authentication (from /auth/login/)"
      },
      "sessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "sessionid",
        "description": "Django session cookie"
      }
    }
  },
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication"
    },
    {
      "name": "Certificates"
    }
  ]
}
