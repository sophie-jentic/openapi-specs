{
  "openapi": "3.0.3",
  "info": {
    "title": "Azure Blob Storage REST API",
    "description": "Azure Blob Storage provides massively scalable object storage for unstructured data. This API covers core Blob Storage operations including container management, blob upload/download, and metadata operations. Uses Azure Shared Key or Azure AD (OAuth 2.0) authentication.",
    "version": "2024-11-04",
    "contact": {
      "name": "Microsoft Azure Support",
      "url": "https://learn.microsoft.com/en-us/rest/api/storageservices/"
    },
    "x-categories": [
      "Cloud Storage"
    ],
    "x-logo": {
      "url": "https://learn.microsoft.com/favicon.ico"
    }
  },
  "servers": [
    {
      "url": "https://{accountName}.blob.core.windows.net",
      "description": "Azure Blob Storage endpoint",
      "variables": {
        "accountName": {
          "default": "myaccount",
          "description": "Your Azure storage account name"
        }
      }
    }
  ],
  "security": [
    {
      "SharedKeyAuth": []
    },
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "listContainers",
        "summary": "List containers",
        "description": "Returns a list of the containers under the specified storage account. Supports filtering by prefix, pagination with marker, and optional inclusion of metadata, deleted containers, and system containers.",
        "parameters": [
          {
            "name": "comp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "list"
              ]
            }
          },
          {
            "name": "prefix",
            "in": "query",
            "description": "Filter results to containers whose names begin with this prefix",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marker",
            "in": "query",
            "description": "Continuation token for paginated results",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "maxresults",
            "in": "query",
            "description": "Maximum number of containers to return (up to 5000)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5000
            }
          },
          {
            "name": "include",
            "in": "query",
            "description": "Datasets to include: metadata, deleted, system (comma-separated)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timeout",
            "in": "query",
            "description": "Server timeout in seconds",
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "#/components/parameters/XMsVersion"
          }
        ],
        "responses": {
          "200": {
            "description": "List of containers returned as XML",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/ContainerListResult"
                }
              }
            }
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StorageError"
                }
              }
            }
          }
        },
        "tags": [
          "Containers"
        ]
      }
    },
    "/{containerName}": {
      "put": {
        "operationId": "createContainer",
        "summary": "Create a container",
        "description": "Creates a new container under the specified account.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContainerName"
          },
          {
            "name": "restype",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "container"
              ]
            }
          },
          {
            "$ref": "#/components/parameters/XMsVersion"
          },
          {
            "name": "x-ms-blob-public-access",
            "in": "header",
            "description": "Public access level: container, blob, or omit for private",
            "schema": {
              "type": "string",
              "enum": [
                "container",
                "blob"
              ]
            }
          },
          {
            "name": "containerName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Container created"
          },
          "409": {
            "description": "Container already exists"
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StorageError"
                }
              }
            }
          }
        },
        "tags": [
          "Containers"
        ]
      },
      "delete": {
        "operationId": "deleteContainer",
        "summary": "Delete a container",
        "description": "Marks the specified container for deletion.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContainerName"
          },
          {
            "name": "restype",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "container"
              ]
            }
          },
          {
            "$ref": "#/components/parameters/XMsVersion"
          },
          {
            "name": "containerName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Container marked for deletion"
          },
          "404": {
            "description": "Container not found"
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StorageError"
                }
              }
            }
          }
        },
        "tags": [
          "Containers"
        ]
      },
      "get": {
        "operationId": "getContainerProperties",
        "summary": "Get container properties",
        "description": "Returns all system properties and user-defined metadata for the container.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContainerName"
          },
          {
            "name": "restype",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "container"
              ]
            }
          },
          {
            "$ref": "#/components/parameters/XMsVersion"
          },
          {
            "name": "containerName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Container properties returned in headers",
            "headers": {
              "x-ms-lease-status": {
                "schema": {
                  "type": "string",
                  "enum": [
                    "locked",
                    "unlocked"
                  ]
                }
              },
              "x-ms-lease-state": {
                "schema": {
                  "type": "string",
                  "enum": [
                    "available",
                    "leased",
                    "expired",
                    "breaking",
                    "broken"
                  ]
                }
              },
              "ETag": {
                "schema": {
                  "type": "string"
                }
              },
              "Last-Modified": {
                "schema": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StorageError"
                }
              }
            }
          }
        },
        "tags": [
          "Containers"
        ]
      }
    },
    "/{containerName}/{blobName}": {
      "put": {
        "operationId": "putBlob",
        "summary": "Upload a blob",
        "description": "Creates a new block blob or updates the content of an existing block blob. For block blobs up to 5000 MiB (256 MiB for older versions).",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContainerName"
          },
          {
            "$ref": "#/components/parameters/BlobName"
          },
          {
            "$ref": "#/components/parameters/XMsVersion"
          },
          {
            "name": "x-ms-blob-type",
            "in": "header",
            "required": true,
            "description": "Type of blob",
            "schema": {
              "type": "string",
              "enum": [
                "BlockBlob",
                "PageBlob",
                "AppendBlob"
              ]
            }
          },
          {
            "name": "Content-Type",
            "in": "header",
            "description": "MIME type of the blob content",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Content-Length",
            "in": "header",
            "required": true,
            "description": "Size of the request body in bytes",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "x-ms-blob-content-type",
            "in": "header",
            "description": "Content type to store for the blob",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "containerName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "blobName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Blob created or updated",
            "headers": {
              "ETag": {
                "schema": {
                  "type": "string"
                }
              },
              "Content-MD5": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StorageError"
                }
              }
            }
          }
        },
        "tags": [
          "Blobs"
        ]
      },
      "get": {
        "operationId": "getBlob",
        "summary": "Download a blob",
        "description": "Reads or downloads a blob including its metadata and properties.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContainerName"
          },
          {
            "$ref": "#/components/parameters/BlobName"
          },
          {
            "$ref": "#/components/parameters/XMsVersion"
          },
          {
            "name": "Range",
            "in": "header",
            "description": "Byte range to return (e.g., bytes=0-1023)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-ms-range-get-content-md5",
            "in": "header",
            "description": "Return MD5 hash for the range",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "containerName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "blobName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Blob content returned",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            },
            "headers": {
              "Content-Type": {
                "schema": {
                  "type": "string"
                }
              },
              "Content-Length": {
                "schema": {
                  "type": "integer"
                }
              },
              "ETag": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "206": {
            "description": "Partial content (range request)",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StorageError"
                }
              }
            }
          }
        },
        "tags": [
          "Blobs"
        ]
      },
      "head": {
        "operationId": "getBlobProperties",
        "summary": "Get blob properties",
        "description": "Returns all system properties and user-defined metadata for the blob.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContainerName"
          },
          {
            "$ref": "#/components/parameters/BlobName"
          },
          {
            "$ref": "#/components/parameters/XMsVersion"
          },
          {
            "name": "containerName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "blobName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Blob properties returned in headers",
            "headers": {
              "Content-Type": {
                "schema": {
                  "type": "string"
                }
              },
              "Content-Length": {
                "schema": {
                  "type": "integer",
                  "format": "int64"
                }
              },
              "ETag": {
                "schema": {
                  "type": "string"
                }
              },
              "Last-Modified": {
                "schema": {
                  "type": "string"
                }
              },
              "x-ms-blob-type": {
                "schema": {
                  "type": "string",
                  "enum": [
                    "BlockBlob",
                    "PageBlob",
                    "AppendBlob"
                  ]
                }
              }
            }
          },
          "default": {
            "description": "Error response"
          }
        },
        "tags": [
          "Blobs"
        ]
      },
      "delete": {
        "operationId": "deleteBlob",
        "summary": "Delete a blob",
        "description": "Marks the specified blob or snapshot for deletion.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContainerName"
          },
          {
            "$ref": "#/components/parameters/BlobName"
          },
          {
            "$ref": "#/components/parameters/XMsVersion"
          },
          {
            "name": "x-ms-delete-snapshots",
            "in": "header",
            "description": "How to handle snapshots",
            "schema": {
              "type": "string",
              "enum": [
                "include",
                "only"
              ]
            }
          },
          {
            "name": "containerName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "blobName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Blob marked for deletion"
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StorageError"
                }
              }
            }
          }
        },
        "tags": [
          "Blobs"
        ]
      }
    },
    "/{containerName}?restype=container&comp=list": {
      "get": {
        "operationId": "listBlobs",
        "summary": "List blobs in a container",
        "description": "Returns a list of the blobs under the specified container.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContainerName"
          },
          {
            "name": "restype",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "container"
              ]
            }
          },
          {
            "name": "comp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "list"
              ]
            }
          },
          {
            "name": "prefix",
            "in": "query",
            "description": "Filter results to blobs whose names begin with this prefix",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "delimiter",
            "in": "query",
            "description": "Delimiter for virtual hierarchy (usually /)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marker",
            "in": "query",
            "description": "Continuation token for paginated results",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "maxresults",
            "in": "query",
            "description": "Maximum number of blobs to return",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5000
            }
          },
          {
            "name": "include",
            "in": "query",
            "description": "Datasets to include: snapshots, metadata, uncommittedblobs, copy, deleted, tags, versions, deletedwithversions, immutabilitypolicy, legalhold, permissions",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/XMsVersion"
          },
          {
            "name": "containerName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of blobs returned as XML",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StorageError"
                }
              }
            }
          }
        },
        "tags": [
          "Blobs"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "SharedKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Azure Storage Shared Key authorization. Format: SharedKey {accountName}:{signature}"
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Azure AD OAuth 2.0 bearer token"
      }
    },
    "parameters": {
      "ContainerName": {
        "name": "containerName",
        "in": "path",
        "required": true,
        "description": "Name of the container",
        "schema": {
          "type": "string"
        }
      },
      "BlobName": {
        "name": "blobName",
        "in": "path",
        "required": true,
        "description": "Name of the blob",
        "schema": {
          "type": "string"
        }
      },
      "XMsVersion": {
        "name": "x-ms-version",
        "in": "header",
        "required": true,
        "description": "Azure Storage API version",
        "schema": {
          "type": "string",
          "default": "2024-11-04"
        }
      }
    },
    "schemas": {
      "ContainerListResult": {
        "type": "object",
        "properties": {
          "ServiceEndpoint": {
            "type": "string"
          },
          "Prefix": {
            "type": "string"
          },
          "Marker": {
            "type": "string"
          },
          "MaxResults": {
            "type": "integer"
          },
          "Containers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Container"
            }
          },
          "NextMarker": {
            "type": "string"
          }
        }
      },
      "Container": {
        "type": "object",
        "properties": {
          "Name": {
            "type": "string"
          },
          "Properties": {
            "type": "object",
            "properties": {
              "Last-Modified": {
                "type": "string",
                "format": "date-time"
              },
              "Etag": {
                "type": "string"
              },
              "LeaseStatus": {
                "type": "string",
                "enum": [
                  "locked",
                  "unlocked"
                ]
              },
              "LeaseState": {
                "type": "string",
                "enum": [
                  "available",
                  "leased",
                  "expired",
                  "breaking",
                  "broken"
                ]
              },
              "LeaseDuration": {
                "type": "string",
                "enum": [
                  "infinite",
                  "fixed"
                ]
              },
              "PublicAccess": {
                "type": "string",
                "enum": [
                  "container",
                  "blob"
                ]
              },
              "HasImmutabilityPolicy": {
                "type": "boolean"
              },
              "HasLegalHold": {
                "type": "boolean"
              }
            }
          },
          "Metadata": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "StorageError": {
        "type": "object",
        "properties": {
          "Code": {
            "type": "string"
          },
          "Message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Containers",
      "description": "Blob Storage container operations"
    },
    {
      "name": "Blobs",
      "description": "Blob upload, download, and management operations"
    }
  ]
}
