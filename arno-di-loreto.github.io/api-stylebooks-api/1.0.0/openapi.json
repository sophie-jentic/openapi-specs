{
  "openapi": "3.0.1",
  "info": {
    "title": "API Stylebook's API",
    "description": "All informations available at apistylebook.com",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/apihandyman/apistylebook/1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://arno-di-loreto.github.io/asb-web-test"
    }
  ],
  "tags": [
    {
      "name": "API Design Topics"
    },
    {
      "name": "API Design Guidelines"
    }
  ],
  "paths": {
    "/design/guidelines.{format}": {
      "get": {
        "tags": [
          "API Design Guidelines"
        ],
        "summary": "Gets the list of API design guidelines",
        "description": "Returns all guidelines referenced by apistylebook.com",
        "parameters": [
          {
            "name": "format",
            "in": "path",
            "description": "Data format",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "yaml"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Guidelines list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Guidelines"
                }
              },
              "application/yaml": {
                "schema": {
                  "$ref": "#/components/schemas/Guidelines"
                }
              }
            }
          },
          "404": {
            "description": "Unavailable resource or format.",
            "content": {}
          }
        },
        "operationId": "get_design_guidelines_format"
      }
    },
    "/design/guidelines/{guidelineId}.{format}": {
      "get": {
        "tags": [
          "API Design Guidelines"
        ],
        "summary": "Gets an API design guidelines",
        "description": "Return informations about a specific API design guidelines",
        "parameters": [
          {
            "name": "guidelineId",
            "in": "path",
            "description": "Guideline's id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "path",
            "description": "Data format",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "yaml"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An API design guidelines",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Guideline"
                }
              },
              "application/yaml": {
                "schema": {
                  "$ref": "#/components/schemas/Guideline"
                }
              }
            }
          },
          "404": {
            "description": "Unavailable resource or format.",
            "content": {}
          }
        },
        "operationId": "get_design_guidelines_guidelineId_format"
      }
    },
    "/design/guidelines/{guidelineId}/topics.{format}": {
      "get": {
        "tags": [
          "API Design Guidelines"
        ],
        "summary": "Gets the topics covered",
        "description": "Returns the list of topics covered by a specific guideline including a detail list of references",
        "parameters": [
          {
            "name": "guidelineId",
            "in": "path",
            "description": "Guideline's id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "path",
            "description": "Data format",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "yaml"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of referenced topics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GuidelineTopics"
                }
              },
              "application/yaml": {
                "schema": {
                  "$ref": "#/components/schemas/GuidelineTopics"
                }
              }
            }
          },
          "404": {
            "description": "Unavailable resource or format.",
            "content": {}
          }
        },
        "operationId": "get_design_guidelines_guidelineId_topics_format"
      }
    },
    "/design/topics.{format}": {
      "get": {
        "tags": [
          "API Design Topics"
        ],
        "summary": "Gets the list of API design topics",
        "description": "Returns all API design topics covered in referenced guidelines",
        "parameters": [
          {
            "name": "format",
            "in": "path",
            "description": "Data format",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "yaml"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Topics list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Topics"
                }
              },
              "application/yaml": {
                "schema": {
                  "$ref": "#/components/schemas/Topics"
                }
              }
            }
          },
          "404": {
            "description": "Unavailable resource or format.",
            "content": {}
          }
        },
        "operationId": "get_design_topics_format"
      }
    },
    "/design/topics/{topicId}.{format}": {
      "get": {
        "tags": [
          "API Design Topics"
        ],
        "summary": "Gets a topic",
        "description": "Returns topic's informations",
        "parameters": [
          {
            "name": "topicId",
            "in": "path",
            "description": "Topic's id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "path",
            "description": "Data format",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "yaml"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A topic",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Topic"
                }
              },
              "application/yaml": {
                "schema": {
                  "$ref": "#/components/schemas/Topic"
                }
              }
            }
          },
          "404": {
            "description": "Unavailable resource or format.",
            "content": {}
          }
        },
        "operationId": "get_design_topics_topicId_format"
      }
    },
    "/design/topics/{topicId}/guidelines.{format}": {
      "get": {
        "tags": [
          "API Design Topics"
        ],
        "summary": "Gets all guidelines referencing a topic",
        "description": "Returns a detailed list of guidelines covering a specific topic",
        "parameters": [
          {
            "name": "topicId",
            "in": "path",
            "description": "Topic's id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "path",
            "description": "Data format",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "yaml"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "References list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TopicGuidelines"
                }
              },
              "application/yaml": {
                "schema": {
                  "$ref": "#/components/schemas/TopicGuidelines"
                }
              }
            }
          },
          "404": {
            "description": "Unavailable resource or format.",
            "content": {}
          }
        },
        "operationId": "get_design_topics_topicId_guidelines_format"
      }
    }
  },
  "components": {
    "schemas": {
      "GuidelineId": {
        "pattern": "[a-z0-9\\-]+",
        "type": "string",
        "description": "Guidelines' ID"
      },
      "GuidelineLink": {
        "required": [
          "href"
        ],
        "type": "object",
        "properties": {
          "href": {
            "pattern": "http://localhost:4010/design/guidelines/[a-z0-9\\-]+\\.json",
            "type": "string",
            "description": "Link's URL"
          }
        },
        "description": "Link to a guideline"
      },
      "GuidelinesLink": {
        "required": [
          "href"
        ],
        "type": "object",
        "properties": {
          "href": {
            "pattern": "http://localhost:4010/design/guidelines\\.json",
            "type": "string",
            "description": "Link's URL"
          }
        },
        "description": "Link to a guidelines list"
      },
      "GuidelineTopicsLink": {
        "required": [
          "href"
        ],
        "type": "object",
        "properties": {
          "href": {
            "pattern": "http://localhost:4010/design/guidelines/[a-z\\-]{20}/topics\\.json",
            "type": "string",
            "description": "Link's URL"
          }
        },
        "description": "Link to the detail list of topics covered by a guideline"
      },
      "TopicId": {
        "pattern": "[a-z0-9\\-]+",
        "type": "string",
        "description": "Topic's ID"
      },
      "TopicLink": {
        "title": "TopicLink",
        "required": [
          "href"
        ],
        "type": "object",
        "properties": {
          "href": {
            "pattern": "http://localhost:4010/design/topics/[a-z\\-]{20}\\.json",
            "type": "string",
            "description": "Link's URL"
          }
        },
        "description": "Link to a topic"
      },
      "TopicsLink": {
        "required": [
          "href"
        ],
        "type": "object",
        "properties": {
          "href": {
            "pattern": "http://localhost:4010/design/topics\\.json",
            "type": "string",
            "description": "Link's URL"
          }
        },
        "description": "Link to the list of topics"
      },
      "TopicGuidelinesLink": {
        "required": [
          "href"
        ],
        "type": "object",
        "properties": {
          "href": {
            "pattern": "http://localhost:4010/design/topics/[a-z\\-]{20}/guidelines\\.json",
            "type": "string",
            "description": "Link's URL"
          }
        },
        "description": "Link to the guidelines list covering a topic"
      },
      "Guideline": {
        "required": [
          "_links",
          "company",
          "date",
          "documents",
          "id",
          "reviewed",
          "title",
          "topicsIds"
        ],
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/GuidelineId"
          },
          "title": {
            "type": "string",
            "description": "Guidelines title"
          },
          "company": {
            "type": "string",
            "description": "Company providing these guidelines"
          },
          "date": {
            "type": "string",
            "description": "When the document was published or updated"
          },
          "reviewed": {
            "type": "boolean",
            "description": "Does these guidelines have been reviewed"
          },
          "reviewDate": {
            "type": "string",
            "description": "When these guidelines where reviewed (information provide if these guidelines have been reviewed)"
          },
          "companyLogoUrl": {
            "type": "string",
            "description": "Link to company's logo"
          },
          "companyUrl": {
            "type": "string",
            "description": "Link to company's web site"
          },
          "authors": {
            "minItems": 1,
            "type": "array",
            "description": "A list of author",
            "items": {
              "title": "Author",
              "required": [
                "firstname",
                "lastname"
              ],
              "type": "object",
              "properties": {
                "firstname": {
                  "type": "string",
                  "description": "Author's firstname"
                },
                "lastname": {
                  "type": "string",
                  "description": "Author's lastname"
                },
                "twitter": {
                  "type": "string",
                  "description": "Author's twitter handle"
                },
                "github": {
                  "type": "string",
                  "description": "Author's github username"
                },
                "websiteUrl": {
                  "type": "string",
                  "description": "Author's website's URL"
                }
              }
            }
          },
          "documents": {
            "minItems": 1,
            "type": "array",
            "description": "A list of document composing these guidelines",
            "items": {
              "title": "Document",
              "required": [
                "main",
                "name",
                "type",
                "url"
              ],
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Document's name"
                },
                "type": {
                  "type": "string",
                  "description": "Document's type",
                  "enum": [
                    "website",
                    "github"
                  ]
                },
                "url": {
                  "type": "string",
                  "description": "Document's URL"
                },
                "main": {
                  "type": "boolean",
                  "description": "Indicate if this document is the main one in the documents set."
                }
              }
            }
          },
          "topicsIds": {
            "type": "object",
            "description": "The list of topics ids covered by these guidelines"
          },
          "_links": {
            "title": "GuidelineLinks",
            "required": [
              "parent",
              "self",
              "topics"
            ],
            "type": "object",
            "properties": {
              "self": {
                "$ref": "#/components/schemas/GuidelineLink"
              },
              "parent": {
                "$ref": "#/components/schemas/GuidelinesLink"
              },
              "topics": {
                "$ref": "#/components/schemas/GuidelineTopicsLink"
              }
            },
            "description": "List of links"
          }
        }
      },
      "Guidelines": {
        "required": [
          "_links",
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "minItems": 1,
            "type": "array",
            "description": "An array of guidelines items",
            "items": {
              "$ref": "#/components/schemas/Guideline"
            }
          },
          "_links": {
            "title": "GuidelinesLinks",
            "required": [
              "self"
            ],
            "type": "object",
            "properties": {
              "self": {
                "$ref": "#/components/schemas/GuidelinesLink"
              }
            },
            "description": "List of links"
          }
        }
      },
      "Topic": {
        "required": [
          "_links",
          "description",
          "id",
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/TopicId"
          },
          "name": {
            "type": "string",
            "description": "Topic's name"
          },
          "description": {
            "type": "string",
            "description": "Topic's description (can contain HTML and GFM)"
          },
          "_links": {
            "title": "TopicLinks",
            "required": [
              "guidelines",
              "parent",
              "self"
            ],
            "type": "object",
            "properties": {
              "self": {
                "$ref": "#/components/schemas/TopicLink"
              },
              "parent": {
                "$ref": "#/components/schemas/TopicsLink"
              },
              "guidelines": {
                "$ref": "#/components/schemas/TopicGuidelinesLink"
              }
            },
            "description": "List of links"
          }
        },
        "description": "An API design topic"
      },
      "Topics": {
        "required": [
          "_links",
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "description": "A list of topics",
            "items": {
              "$ref": "#/components/schemas/Topic"
            }
          },
          "_links": {
            "title": "TopicsLinks",
            "required": [
              "self"
            ],
            "type": "object",
            "properties": {
              "self": {
                "$ref": "#/components/schemas/TopicsLink"
              }
            },
            "description": "List of links"
          }
        },
        "description": "A list of topics"
      },
      "ReferencesToTopicWithinGuideline": {
        "required": [
          "_links",
          "guidelineId",
          "references",
          "topicId"
        ],
        "type": "object",
        "properties": {
          "topicId": {
            "$ref": "#/components/schemas/TopicId"
          },
          "guidelineId": {
            "$ref": "#/components/schemas/GuidelineId"
          },
          "references": {
            "minItems": 1,
            "type": "array",
            "description": "List of references to a topic within a guideline",
            "items": {
              "title": "Reference",
              "required": [
                "name",
                "url"
              ],
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "A readable reference name"
                },
                "url": {
                  "type": "string",
                  "description": "Direct access to URL (when possible)"
                },
                "quote": {
                  "type": "string",
                  "description": "A guideline's quote to explain the reference"
                }
              },
              "description": "A reference within a guideline"
            }
          },
          "_links": {
            "title": "ReferencesToTopicWithinGuidelineLinks",
            "required": [
              "guideline",
              "topic"
            ],
            "type": "object",
            "properties": {
              "topic": {
                "$ref": "#/components/schemas/TopicLink"
              },
              "guideline": {
                "$ref": "#/components/schemas/GuidelineLink"
              }
            }
          }
        },
        "description": "List of references to a topic within a guideline"
      },
      "GuidelineTopics": {
        "required": [
          "_links",
          "guidelineId",
          "items"
        ],
        "type": "object",
        "properties": {
          "guidelineId": {
            "$ref": "#/components/schemas/GuidelineId"
          },
          "items": {
            "minItems": 1,
            "type": "array",
            "description": "Array of topics and their references within the guideline",
            "items": {
              "$ref": "#/components/schemas/ReferencesToTopicWithinGuideline"
            }
          },
          "_links": {
            "title": "GuidelineReferencedTopicsLink",
            "required": [
              "guideline",
              "self"
            ],
            "type": "object",
            "properties": {
              "self": {
                "$ref": "#/components/schemas/GuidelineTopicsLink"
              },
              "guideline": {
                "$ref": "#/components/schemas/GuidelineLink"
              }
            }
          }
        },
        "description": "A list of topics referenced by a guideline. Each topic has also the list of all references to this topic within the guideline."
      },
      "TopicGuidelines": {
        "required": [
          "_links",
          "items"
        ],
        "type": "object",
        "properties": {
          "topicId": {
            "$ref": "#/components/schemas/TopicId"
          },
          "items": {
            "minItems": 1,
            "type": "array",
            "description": "An array of guidelines and their references to the topic",
            "items": {
              "$ref": "#/components/schemas/ReferencesToTopicWithinGuideline"
            }
          },
          "_links": {
            "title": "GuidelinesTopicReferencesLinks",
            "required": [
              "self",
              "topic"
            ],
            "type": "object",
            "properties": {
              "self": {
                "$ref": "#/components/schemas/TopicGuidelinesLink"
              },
              "topic": {
                "$ref": "#/components/schemas/TopicLink"
              }
            },
            "description": "List of links"
          }
        },
        "description": "A list of guidelines referencing a specific topic. Each guideline has also the list of all references to this topic within itself."
      }
    },
    "responses": {
      "unavailable": {
        "description": "Unavailable resource or format.",
        "content": {}
      }
    },
    "parameters": {
      "format": {
        "name": "format",
        "in": "path",
        "description": "Data format",
        "required": true,
        "schema": {
          "type": "string",
          "enum": [
            "json",
            "yaml"
          ]
        }
      },
      "guidelineId": {
        "name": "guidelineId",
        "in": "path",
        "description": "Guideline's id",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "topicId": {
        "name": "topicId",
        "in": "path",
        "description": "Topic's id",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    }
  },
  "x-original-swagger-version": "2.0"
}
