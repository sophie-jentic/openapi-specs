{
  "openapi": "3.0.3",
  "info": {
    "title": "Code Climate Quality API",
    "version": "1.0.0",
    "description": "Code Climate (now Qlty) provides a REST API for managing code quality projects, issues, metrics, workspaces, and user information. Uses Bearer token authentication.",
    "x-jentic-source-url": "https://api.codeclimate.com/v1/",
    "contact": {}
  },
  "paths": {
    "/gh/{ownerKeyOrId}/projects/{projectKeyOrId}/issues": {
      "get": {
        "operationId": "list-issues",
        "summary": "List Issues",
        "description": "Retrieves a list of Projects associated with a Workspace",
        "tags": [
          "subpackage_issues"
        ],
        "parameters": [
          {
            "name": "ownerKeyOrId",
            "in": "path",
            "description": "The key or ID of the Workspace that owns the Project",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "projectKeyOrId",
            "in": "path",
            "description": "The key or ID of the Project to retrieve issues for",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "description": "Filter issues by category",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/type_common:MiniIssueCategory"
              }
            }
          },
          {
            "name": "level",
            "in": "query",
            "description": "Filter issues by severity level",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/type_common:MiniLevel"
              }
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter issues by status (defaults to open only)",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/type_common:MiniIssueStatus"
              }
            }
          },
          {
            "name": "tool",
            "in": "query",
            "description": "Filter issues by the tool that detected them (e.g., eslint, typescript)",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "page[limit]",
            "in": "query",
            "description": "Maximum number of items to return",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page[offset]",
            "in": "query",
            "description": "Number of items to skip",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response with status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/type_issues:ListIssuesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error response with status 400",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/type_common:ErrorBody"
                }
              }
            }
          },
          "401": {
            "description": "Error response with status 401",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/type_common:ErrorBody"
                }
              }
            }
          },
          "403": {
            "description": "Error response with status 403",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/type_common:ErrorBody"
                }
              }
            }
          },
          "404": {
            "description": "Error response with status 404",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/type_common:ErrorBody"
                }
              }
            }
          },
          "429": {
            "description": "Error response with status 429",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/type_common:ErrorBody"
                }
              }
            }
          }
        }
      }
    },
