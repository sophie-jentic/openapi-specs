  "components": {
    "schemas": {
      "type_common:MiniIssueCategory": {
        "type": "string",
        "enum": [
          "bug",
          "vulnerability",
          "structure",
          "duplication",
          "security_hotspot",
          "performance",
          "documentation",
          "type_check",
          "style",
          "anti_pattern",
          "accessibility",
          "dead_code",
          "lint",
          "secret",
          "dependency_alert"
        ],
        "title": "MiniIssueCategory"
      },
      "type_common:MiniLevel": {
        "type": "string",
        "enum": [
          "note",
          "fmt",
          "low",
          "medium",
          "high"
        ],
        "title": "MiniLevel"
      },
      "type_common:MiniIssueStatus": {
        "type": "string",
        "enum": [
          "open",
          "ignored"
        ],
        "title": "MiniIssueStatus"
      },
      "type_issues:MiniLocation": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "The file path where the issue was detected"
          },
          "startLine": {
            "type": "integer",
            "description": "The line number where the issue begins"
          },
          "endLine": {
            "type": "integer",
            "description": "The line number where the issue ends"
          }
        },
        "required": [
          "path"
        ],
        "title": "MiniLocation"
      },
      "type_issues:MiniIssue": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The UUID of the Issue"
          },
          "fingerprint": {
            "type": "string",
            "description": "A unique hash that identifies this specific issue instance"
          },
          "tool": {
            "type": "string",
            "description": "The name of the tool that detected the issue (e.g., eslint, rubocop)"
          },
          "ruleKey": {
            "type": "string",
            "description": "The specific rule or check that was violated"
          },
          "message": {
            "type": "string",
            "description": "Human-readable description of the issue"
          },
          "category": {
            "$ref": "#/components/schemas/type_common:MiniIssueCategory"
          },
          "level": {
            "$ref": "#/components/schemas/type_common:MiniLevel"
          },
          "status": {
            "$ref": "#/components/schemas/type_common:MiniIssueStatus"
          },
          "documentationUrl": {
            "type": "string",
            "description": "URL to documentation about this issue type or rule"
          },
          "location": {
            "$ref": "#/components/schemas/type_issues:MiniLocation"
          }
        },
        "required": [
          "id",
          "fingerprint",
          "tool",
          "ruleKey",
          "message",
          "category",
          "level",
          "status",
          "location"
        ],
        "title": "MiniIssue"
      },
      "type_common:PaginationMeta": {
        "type": "object",
        "properties": {
          "hasMore": {
            "type": "boolean",
            "description": "Indicates if there are more items available for pagination"
          }
        },
        "required": [
          "hasMore"
        ],
        "title": "PaginationMeta"
      },
      "type_issues:ListIssuesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/type_issues:MiniIssue"
            },
            "description": "List of Issue items returned in the response"
          },
          "meta": {
            "$ref": "#/components/schemas/type_common:PaginationMeta"
          }
        },
        "required": [
          "data",
          "meta"
        ],
        "title": "ListIssuesResponse"
      },
      "type_common:ErrorBody": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "The HTTP status code of the error"
          },
          "title": {
            "type": "string",
            "description": "A short, human-readable summary of the error"
          },
          "detail": {
            "type": "string",
            "description": "A detailed explanation of the error"
          }
        },
        "required": [
          "status"
        ],
        "title": "ErrorBody"
      },
      "type_metrics:MeasureValue": {
        "description": "The metric value which can be a number, T-shirt size (XS-XL), or letter rating (A-F)",
        "oneOf": [
          {
            "type": "number",
            "format": "double"
          },
          {
            "type": "string",
            "enum": [
              "XS",
              "S",
              "M",
              "L",
              "XL"
            ]
          },
          {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C",
              "D",
              "F"
            ]
          }
        ]
