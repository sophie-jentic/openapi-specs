{
  "openapi": "3.0.3",
  "info": {
    "title": "Ideogram API",
    "version": "1.0.0",
    "description": "AI image generation API. Generate, edit, remix, reframe, upscale, and describe images.",
    "x-jentic-source-url": "https://developer.ideogram.ai/openapi.json",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.ideogram.ai"
    }
  ],
  "paths": {
    "/v1/ideogram-v3/generate": {
      "post": {
        "operationId": "generateV3",
        "summary": "Generate images with Ideogram 3.0",
        "tags": [
          "Generation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "prompt"
                ],
                "properties": {
                  "prompt": {
                    "type": "string"
                  },
                  "aspect_ratio": {
                    "type": "string"
                  },
                  "model": {
                    "type": "string"
                  },
                  "magic_prompt_option": {
                    "type": "string"
                  },
                  "num_images": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Images generated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Generate images with Ideogram 3.0"
      }
    },
    "/v1/ideogram-v3/generate-transparent": {
