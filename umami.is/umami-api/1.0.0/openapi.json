    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.umami.is",
      "description": "Umami Cloud"
    },
    {
      "url": "http://localhost:3000",
      "description": "Self-hosted"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication"
    },
    {
      "name": "Websites",
      "description": "Website management"
    },
    {
      "name": "Statistics",
      "description": "Analytics data retrieval"
    },
    {
      "name": "Events",
      "description": "Event tracking and data"
    },
    {
      "name": "Sessions",
      "description": "Session data"
    },
    {
      "name": "Collect",
      "description": "Data collection"
    }
