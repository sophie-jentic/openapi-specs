{
  "openapi": "3.0.3",
  "info": {
    "title": "Umami API",
    "version": "1.0.0",
    "description": "Umami is an open-source, privacy-focused web analytics platform. This API provides endpoints for authentication, website management, session tracking, event tracking, and retrieving analytics statistics.",
