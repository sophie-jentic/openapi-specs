{
  "openapi": "3.0.3",
  "info": {
    "title": "Bittrex API v3",
    "description": "Bittrex cryptocurrency exchange REST API v3. Provides access to market data, trading, and account management. Note: Bittrex ceased operations in December 2023.",
    "version": "3.0.0",
    "contact": {
      "name": "Bittrex",
      "url": "https://bittrex.github.io/api/v3"
    }
  },
  "servers": [
    {
      "url": "https://api.bittrex.com/v3",
      "description": "Bittrex API v3"
    }
  ],
  "paths": {
    "/markets": {
      "get": {
        "summary": "List markets",
        "description": "Returns a list of all available markets.",
        "operationId": "getMarkets",
        "tags": [
          "Markets"
        ],
        "responses": {
          "200": {
            "description": "List of markets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Market"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/markets/{marketSymbol}": {
      "get": {
        "summary": "Get market",
        "description": "Returns a specific market by symbol.",
        "operationId": "getMarket",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "marketSymbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Market symbol (e.g. BTC-USD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Market details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Market"
                }
              }
            }
          }
        }
      }
    },
    "/markets/summaries": {
      "get": {
        "summary": "List market summaries",
        "description": "Returns summary data for all markets.",
        "operationId": "getMarketSummaries",
        "tags": [
          "Markets"
        ],
        "responses": {
          "200": {
            "description": "Market summaries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MarketSummary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/markets/{marketSymbol}/summary": {
      "get": {
        "summary": "Get market summary",
        "description": "Returns summary data for a specific market.",
        "operationId": "getMarketSummary",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "marketSymbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Market summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketSummary"
                }
              }
            }
          }
        }
      }
    },
    "/markets/tickers": {
      "get": {
        "summary": "List tickers",
        "description": "Returns ticker data for all markets.",
        "operationId": "getTickers",
        "tags": [
          "Markets"
        ],
        "responses": {
          "200": {
            "description": "Tickers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Ticker"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/markets/{marketSymbol}/ticker": {
      "get": {
        "summary": "Get market ticker",
        "description": "Returns ticker data for a specific market.",
        "operationId": "getMarketTicker",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "marketSymbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ticker",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ticker"
                }
              }
            }
          }
        }
      }
    },
    "/markets/{marketSymbol}/orderbook": {
      "get": {
        "summary": "Get order book",
        "description": "Returns the order book for a market.",
        "operationId": "getOrderBook",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "marketSymbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "depth",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25,
              "enum": [
                1,
                25,
                500
              ]
            },
            "description": "Order book depth (1, 25, or 500)"
          }
        ],
        "responses": {
          "200": {
            "description": "Order book",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderBook"
                }
              }
            }
          }
        }
      }
    },
    "/markets/{marketSymbol}/trades": {
      "get": {
        "summary": "Get recent trades",
        "description": "Returns recent trades for a market.",
        "operationId": "getMarketTrades",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "marketSymbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent trades",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Trade"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/markets/{marketSymbol}/candles/{candleType}/{candleInterval}/recent": {
      "get": {
        "summary": "Get recent candles",
        "description": "Returns recent candle (OHLCV) data for a market.",
        "operationId": "getRecentCandles",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "marketSymbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "candleType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "TRADE",
                "MIDPOINT"
              ]
            }
          },
          {
            "name": "candleInterval",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "MINUTE_1",
                "MINUTE_5",
                "HOUR_1",
                "DAY_1"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Candle data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Candle"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/currencies": {
      "get": {
        "summary": "List currencies",
        "description": "Returns a list of all supported currencies.",
        "operationId": "getCurrencies",
        "tags": [
          "Currencies"
        ],
        "responses": {
          "200": {
