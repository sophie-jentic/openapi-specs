{
  "openapi": "3.0.1",
  "info": {
    "title": "Partner Content API",
    "version": "0.1.17",
    "description": "Epidemic Sound Partner Content API - provides access to music catalog including collections, tracks, moods, genres, and sound effects.",
    "x-jentic-source-url": "https://partner-content-api.epidemicsound.com/docs/spec.json",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://partner-content-api.epidemicsound.com",
      "description": "Epidemic Sound Content API"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Endpoints for user authentication."
    },
    {
      "name": "Browse & search",
      "description": "Explore the Epidemic Sound library."
    },
    {
      "name": "Tracks",
      "description": "Track specific information endpoints."
    },
    {
      "name": "Sound effects",
      "description": "Sound effect specific information endpoints."
    },
    {
      "name": "Reporting",
      "description": "Report how tracks are used in your application."
    },
    {
      "name": "Users",
      "description": "Get user specific information."
    },
    {
      "name": "Assets",
      "description": "Upload assets such as images or audio."
    },
    {
      "name": "Beta",
      "description": "Beta endpoints."
    }
  ],
  "paths": {
    "/v0/collections": {
      "get": {
        "tags": [
          "Browse & search"
        ],
        "summary": "List collections",
        "description": "Returns playlists curated by in-house experts.",
        "operationId": "GET_Collections",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Max number of entries, default 10 max 20",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectionsPaginatedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "UserAuth": []
          },
          {
            "EpidemicSoundConnectAuth": []
          }
        ]
      }
    },
    "/v0/collections/{collectionId}": {
      "get": {
        "tags": [
          "Browse & search"
        ],
        "summary": "Collection details",
        "description": "List all tracks in a specific collection.",
        "operationId": "GET_Collection",
        "parameters": [
          {
            "name": "collectionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectionPaginatedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Collection not found"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "UserAuth": []
          },
          {
            "EpidemicSoundConnectAuth": []
          }
        ]
      }
    },
    "/v0/tracks": {
      "get": {
        "tags": [
          "Tracks"
        ],
        "summary": "List tracks based on mood, genre or BPM",
        "description": "List all tracks based on a specified mood, genre or BPM.",
        "operationId": "GET_Tracks",
        "parameters": [
          {
            "name": "genre",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mood",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bpmMin",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "bpmMax",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tracks response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TracksResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "UserAuth": []
          },
          {
            "EpidemicSoundConnectAuth": []
          }
        ]
      }
    },
    "/v0/tracks/search": {
      "get": {
        "tags": [
          "Browse & search"
        ],
        "summary": "Search music",
        "description": "Search the entire Epidemic Sound library.",
        "operationId": "GET_Tracks_Search",
        "parameters": [
          {
            "name": "term",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "genre",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mood",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "Title",
                "Relevance",
                "Date",
                "Popularity",
                "Duration",
                "BPM"
              ]
            }
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tracks response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TracksResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "UserAuth": []
          },
          {
            "EpidemicSoundConnectAuth": []
          }
        ]
      }
    },
    "/v0/tracks/search/suggestions": {
      "get": {
        "tags": [
          "Browse & search"
        ],
        "summary": "Search autosuggest",
        "description": "Get autocomplete suggestions for music search.",
        "operationId": "GET_Tracks_Search_suggestions",
        "parameters": [
          {
            "name": "term",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search suggestions response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchSuggestionsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "UserAuth": []
          },
          {
            "EpidemicSoundConnectAuth": []
          }
        ]
      }
    },
    "/v0/tracks/parameters": {
      "get": {
        "tags": [
          "Tracks"
        ],
        "summary": "List track parameters",
        "description": "Get a list of possible track query parameters (genres, moods).",
        "operationId": "GET_Track_Parameters",
        "responses": {
          "200": {
            "description": "Track parameters response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackParametersResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "UserAuth": []
          },
          {
            "EpidemicSoundConnectAuth": []
          }
        ]
      }
    },
    "/v0/moods": {
      "get": {
        "tags": [
          "Browse & search"
        ],
        "summary": "List moods",
        "description": "Browse the music catalog based on moods.",
        "operationId": "GET_All_Moods",
        "parameters": [
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Moods response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MoodsPaginatedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "UserAuth": []
          },
          {
            "EpidemicSoundConnectAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "UserAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "EpidemicSoundConnectAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Track": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "mainArtists": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "featuredArtists": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "bpm": {
            "type": "integer"
          },
          "length": {
            "type": "integer"
          },
          "hasVocals": {
            "type": "boolean"
          },
          "isExplicit": {
            "type": "boolean"
          },
          "isPreviewOnly": {
            "type": "boolean"
          },
          "added": {
            "type": "string",
            "format": "date"
          },
          "waveformUrl": {
            "type": "string"
          },
          "moods": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagItem"
            }
          },
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GenreItem"
            }
          },
          "images": {
            "$ref": "#/components/schemas/Images"
          }
        }
      },
      "TagItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "GenreItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "parent": {
            "$ref": "#/components/schemas/TagItem"
          }
        }
      },
      "Images": {
        "type": "object",
        "properties": {
          "default": {
            "type": "string"
          },
          "XS": {
            "type": "string"
          },
          "S": {
            "type": "string"
          },
          "M": {
            "type": "string"
          },
          "L": {
            "type": "string"
          }
        }
      },
      "TracksResponse": {
        "type": "object",
        "properties": {
          "tracks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Track"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          },
          "links": {
            "$ref": "#/components/schemas/Links"
          }
        }
      },
      "CollectionsPaginatedResponse": {
        "type": "object",
        "properties": {
          "collections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Collection"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          },
          "links": {
            "$ref": "#/components/schemas/Links"
          }
        }
      },
      "CollectionPaginatedResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "tracks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Track"
            }
          },
          "availableTracks": {
            "type": "integer"
          },
          "images": {
            "$ref": "#/components/schemas/Images"
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          },
          "links": {
            "$ref": "#/components/schemas/Links"
          }
        }
      },
      "Collection": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "tracks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Track"
            }
          },
          "availableTracks": {
            "type": "integer"
          },
          "images": {
            "$ref": "#/components/schemas/Images"
          }
        }
      },
      "MoodsPaginatedResponse": {
        "type": "object",
        "properties": {
          "moods": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagItem"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "SearchSuggestionsResponse": {
        "type": "object",
        "properties": {
          "suggestions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "TEXT",
                    "EXTERNAL_SPOTIFY"
                  ]
                }
              }
            }
          }
        }
      },
      "TrackParametersResponse": {
        "type": "object",
        "properties": {
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GenreItem"
            }
          },
          "moods": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagItem"
            }
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          }
        }
      },
      "Links": {
        "type": "object",
        "properties": {
          "next": {
            "type": "string"
          },
          "prev": {
            "type": "string"
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
