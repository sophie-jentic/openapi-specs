{
  "openapi": "3.0.3",
  "info": {
    "title": "Telegraph API",
    "description": "Telegraph is a publishing tool by Telegram that lets you create richly formatted posts and share them instantly. The API allows creating accounts, publishing and editing pages, and retrieving page statistics.",
    "version": "1.0.0",
    "contact": {
      "name": "Telegraph",
      "url": "https://telegra.ph"
    }
  },
  "servers": [
    {
      "url": "https://api.telegra.ph",
      "description": "Telegraph API server"
    }
  ],
  "security": [
    {
      "accessToken": []
    }
  ],
  "paths": {
    "/createAccount": {
      "post": {
        "operationId": "createAccount",
        "summary": "Create a new Telegraph account",
        "description": "Creates a new Telegraph account. Most users only need one account, but this can be useful for channel administrators who want to keep a consistent author name and link across all posts.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "short_name"
                ],
                "properties": {
                  "short_name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 32,
                    "description": "Account name, helps users with several accounts remember which they are currently using. Displayed to the user above the \"Edit/Publish\" button on Telegra.ph."
                  },
                  "author_name": {
                    "type": "string",
                    "maxLength": 128,
                    "description": "Default author name used when creating new articles."
                  },
                  "author_url": {
                    "type": "string",
                    "maxLength": 512,
                    "description": "Default profile link, opened when users click on the author's name below the title. Can be any link, not necessarily to a Telegram profile or channel."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_Account"
                }
              }
            }
          }
        },
        "tags": [
          "createAccount"
        ]
      }
    },
    "/editAccountInfo": {
      "post": {
        "operationId": "editAccountInfo",
        "summary": "Edit account information",
        "description": "Updates information about a Telegraph account. Pass only the parameters that you want to edit.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "access_token"
                ],
                "properties": {
                  "access_token": {
                    "type": "string",
                    "description": "Access token of the Telegraph account."
                  },
                  "short_name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 32,
                    "description": "New account name."
                  },
                  "author_name": {
                    "type": "string",
                    "maxLength": 128,
                    "description": "New default author name used when creating new articles."
                  },
                  "author_url": {
                    "type": "string",
                    "maxLength": 512,
                    "description": "New default profile link."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_Account"
                }
              }
            }
          }
        },
        "tags": [
          "editAccountInfo"
        ]
      }
    },
    "/getAccountInfo": {
      "post": {
        "operationId": "getAccountInfo",
        "summary": "Get account information",
        "description": "Returns information about a Telegraph account.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "access_token"
                ],
                "properties": {
                  "access_token": {
                    "type": "string",
                    "description": "Access token of the Telegraph account."
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "short_name",
                        "author_name",
                        "author_url",
                        "auth_url",
                        "page_count"
                      ]
                    },
                    "default": [
                      "short_name",
                      "author_name",
                      "author_url"
                    ],
                    "description": "List of account fields to return."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_Account"
                }
              }
            }
          }
        },
        "tags": [
          "getAccountInfo"
        ]
      }
    },
    "/revokeAccessToken": {
      "post": {
        "operationId": "revokeAccessToken",
        "summary": "Revoke access token",
        "description": "Revokes the access token and returns a new one.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "access_token"
                ],
                "properties": {
                  "access_token": {
                    "type": "string",
                    "description": "Access token of the Telegraph account."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with new access token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_Account"
                }
              }
            }
          }
        },
        "tags": [
          "revokeAccessToken"
        ]
      }
    },
    "/createPage": {
      "post": {
        "operationId": "createPage",
        "summary": "Create a new Telegraph page",
        "description": "Creates a new Telegraph page (article).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "access_token",
                  "title",
                  "content"
                ],
                "properties": {
                  "access_token": {
                    "type": "string",
                    "description": "Access token of the Telegraph account."
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "description": "Page title."
                  },
                  "author_name": {
                    "type": "string",
                    "maxLength": 128,
                    "description": "Author name, displayed below the article's title."
                  },
                  "author_url": {
                    "type": "string",
                    "maxLength": 512,
                    "description": "Profile link, opened when users click on the author's name."
                  },
                  "content": {
                    "type": "array",
                    "description": "Content of the page as an array of Node objects. Each node can be a string or a DOM element object with tag, attrs, and children.",
                    "items": {
                      "$ref": "#/components/schemas/Node"
                    }
                  },
                  "return_content": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, the content field will be returned in the Page object."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_Page"
                }
              }
            }
          }
        },
        "tags": [
          "createPage"
        ]
      }
    },
    "/editPage/{path}": {
      "post": {
        "operationId": "editPage",
        "summary": "Edit a Telegraph page",
        "description": "Edits an existing Telegraph page.",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "description": "Path to the page (e.g., 'Sample-Page-12-15').",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "access_token",
                  "title",
                  "content"
                ],
                "properties": {
                  "access_token": {
                    "type": "string",
                    "description": "Access token of the Telegraph account."
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "description": "Page title."
                  },
                  "content": {
                    "type": "array",
                    "description": "Content of the page.",
                    "items": {
                      "$ref": "#/components/schemas/Node"
                    }
                  },
                  "author_name": {
                    "type": "string",
                    "maxLength": 128,
                    "description": "Author name, displayed below the article's title."
                  },
                  "author_url": {
                    "type": "string",
                    "maxLength": 512,
                    "description": "Profile link."
                  },
                  "return_content": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, the content field will be returned in the Page object."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_Page"
                }
              }
            }
          }
        },
        "tags": [
          "editPage"
        ]
      }
    },
    "/getPage/{path}": {
      "get": {
        "operationId": "getPage",
        "summary": "Get a Telegraph page",
        "description": "Returns a Telegraph page.",
        "security": [],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "description": "Path to the page (e.g., 'Sample-Page-12-15').",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "return_content",
            "in": "query",
            "required": false,
            "description": "If true, the content field will be returned in the Page object.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_Page"
                }
              }
            }
          }
        },
        "tags": [
          "getPage"
        ]
      }
    },
    "/getPageList": {
      "post": {
        "operationId": "getPageList",
        "summary": "Get a list of pages belonging to a Telegraph account",
        "description": "Returns a list of pages belonging to a Telegraph account, sorted by most recently created pages first.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "access_token"
                ],
                "properties": {
                  "access_token": {
                    "type": "string",
                    "description": "Access token of the Telegraph account."
                  },
                  "offset": {
                    "type": "integer",
                    "default": 0,
                    "description": "Sequential number of the first page to be returned."
                  },
                  "limit": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 200,
                    "default": 50,
                    "description": "Limits the number of pages to be retrieved."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_PageList"
                }
              }
            }
          }
        },
        "tags": [
          "getPageList"
        ]
      }
    },
    "/getViews/{path}": {
      "get": {
        "operationId": "getViews",
        "summary": "Get views for a Telegraph page",
        "description": "Returns the number of views for a Telegraph article. By default, the total number of page views will be returned.",
        "security": [],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "description": "Path to the page (e.g., 'Sample-Page-12-15').",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "year",
            "in": "query",
            "required": false,
            "description": "Required if month is passed. If passed, the number of page views for the requested year will be returned.",
            "schema": {
              "type": "integer",
              "minimum": 2000,
              "maximum": 2100
            }
          },
          {
            "name": "month",
            "in": "query",
            "required": false,
            "description": "Required if day is passed. If passed, the number of page views for the requested month will be returned.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12
            }
          },
          {
            "name": "day",
            "in": "query",
            "required": false,
            "description": "Required if hour is passed. If passed, the number of page views for the requested day will be returned.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 31
            }
          },
          {
            "name": "hour",
            "in": "query",
            "required": false,
            "description": "If passed, the number of page views for the requested hour will be returned.",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 24
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_PageViews"
                }
              }
            }
          }
        },
        "tags": [
          "getViews"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "accessToken": {
        "type": "apiKey",
        "in": "query",
        "name": "access_token",
        "description": "Telegraph access token obtained via createAccount or revokeAccessToken."
      }
    },
    "schemas": {
      "ApiResponse_Account": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "True if the request was successful."
          },
          "result": {
            "$ref": "#/components/schemas/Account"
          },
          "error": {
            "type": "string",
            "description": "Error message if the request was not successful."
          }
        }
      },
      "ApiResponse_Page": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "result": {
            "$ref": "#/components/schemas/Page"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "ApiResponse_PageList": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "result": {
            "$ref": "#/components/schemas/PageList"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "ApiResponse_PageViews": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "result": {
            "$ref": "#/components/schemas/PageViews"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "short_name": {
            "type": "string",
            "description": "Account name."
          },
          "author_name": {
            "type": "string",
            "description": "Default author name."
          },
          "author_url": {
            "type": "string",
            "description": "Default profile link."
          },
          "access_token": {
            "type": "string",
            "description": "Access token of the account."
          },
          "auth_url": {
            "type": "string",
            "description": "URL to authorize a browser on telegra.ph."
          },
          "page_count": {
            "type": "integer",
            "description": "Number of pages belonging to the account."
          }
        }
      },
      "Page": {
        "type": "object",
        "required": [
          "path",
          "url",
          "title",
          "description",
          "views"
        ],
        "properties": {
          "path": {
            "type": "string",
            "description": "Path to the page."
          },
          "url": {
            "type": "string",
            "description": "URL of the page."
          },
          "title": {
            "type": "string",
            "description": "Title of the page."
          },
          "description": {
            "type": "string",
            "description": "Description of the page."
          },
          "author_name": {
            "type": "string",
            "description": "Name of the author."
          },
          "author_url": {
            "type": "string",
            "description": "Profile link of the author."
          },
          "image_url": {
            "type": "string",
            "description": "Image URL of the page."
          },
          "content": {
            "type": "array",
            "description": "Content of the page (only returned if requested).",
            "items": {
              "$ref": "#/components/schemas/Node"
            }
          },
          "views": {
            "type": "integer",
            "description": "Number of page views."
          },
          "can_edit": {
            "type": "boolean",
            "description": "True if the target Telegraph account can edit the page."
          }
        }
      },
      "PageList": {
        "type": "object",
        "required": [
          "total_count",
          "pages"
        ],
        "properties": {
          "total_count": {
            "type": "integer",
            "description": "Total number of pages belonging to the account."
          },
          "pages": {
            "type": "array",
            "description": "Requested pages.",
            "items": {
              "$ref": "#/components/schemas/Page"
            }
          }
        }
      },
      "PageViews": {
        "type": "object",
        "required": [
          "views"
        ],
        "properties": {
          "views": {
            "type": "integer",
            "description": "Number of page views."
          }
        }
      },
      "Node": {
        "oneOf": [
          {
            "type": "string",
            "description": "A text node (plain text content)."
          },
          {
            "type": "object",
            "description": "A DOM element node.",
            "required": [
              "tag"
            ],
            "properties": {
              "tag": {
                "type": "string",
                "description": "Name of the DOM element. Allowed tags: a, aside, b, blockquote, br, code, em, figcaption, figure, h3, h4, hr, i, img, li, ol, p, pre, s, strong, u, ul, video.",
                "enum": [
                  "a",
                  "aside",
                  "b",
                  "blockquote",
                  "br",
                  "code",
                  "em",
                  "figcaption",
                  "figure",
                  "h3",
                  "h4",
                  "hr",
                  "i",
                  "img",
                  "li",
                  "ol",
                  "p",
                  "pre",
                  "s",
                  "strong",
                  "u",
                  "ul",
                  "video"
                ]
              },
              "attrs": {
                "type": "object",
                "description": "Optional attributes of the DOM element. Key-value mapping of attribute names and values.",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "children": {
                "type": "array",
                "description": "Optional list of child nodes.",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        ]
      }
    }
  },
  "tags": [
    {
      "name": "createAccount"
    },
    {
      "name": "createPage"
    },
    {
      "name": "editAccountInfo"
    },
    {
      "name": "editPage"
    },
    {
      "name": "getAccountInfo"
    },
    {
      "name": "getPage"
    },
    {
      "name": "getPageList"
    },
    {
      "name": "getViews"
    },
    {
      "name": "revokeAccessToken"
    }
  ]
}
