{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenRefine API",
    "version": "3.0",
    "description": "OpenRefine is a tool for working with messy data. This API provides HTTP endpoints for project management, data manipulation, column operations, reconciliation, and import/export.",
    "x-jentic-source-url": "https://openrefine.org/docs/technical-reference/openrefine-api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3333",
      "description": "Local OpenRefine instance"
    }
  ],
  "tags": [
