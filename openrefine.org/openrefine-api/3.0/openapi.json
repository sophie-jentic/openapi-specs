      "name": "Projects",
      "description": "Project management"
    },
    {
      "name": "Columns",
      "description": "Column operations"
    },
    {
      "name": "Rows",
      "description": "Row operations"
    },
    {
      "name": "Reconciliation",
      "description": "Reconciliation service"
    },
    {
      "name": "Import/Export",
      "description": "Data import and export"
    },
    {
      "name": "System",
      "description": "System operations"
    }
  ],
