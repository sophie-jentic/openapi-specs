    "/command/core/add-column": {
      "post": {
        "operationId": "addColumn",
        "summary": "Add a column based on expression",
        "tags": [
          "Columns"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "project",
                  "baseColumnName",
                  "newColumnName",
                  "expression"
                ],
                "properties": {
                  "project": {
                    "type": "string"
                  },
                  "baseColumnName": {
                    "type": "string"
                  },
                  "newColumnName": {
                    "type": "string"
                  },
                  "expression": {
                    "type": "string",
                    "description": "GREL or Jython expression"
                  },
                  "columnInsertIndex": {
                    "type": "integer"
                  },
                  "onError": {
                    "type": "string",
                    "enum": [
                      "set-to-blank",
                      "store-error",
                      "keep-original"
                    ]
