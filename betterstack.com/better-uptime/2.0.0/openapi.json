{
  "openapi": "3.0.3",
  "info": {
    "title": "Better Stack Uptime API",
    "version": "2.0.0",
    "description": "Better Stack Uptime API for managing monitors, heartbeats, incidents, monitor groups, status pages, and on-call calendars. Provides full CRUD operations for uptime monitoring infrastructure.",
    "x-jentic-source-url": "https://betterstack.com/docs/uptime/api/getting-started-with-uptime-api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://uptime.betterstack.com/api/v2",
      "description": "Better Stack Uptime API v2"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Monitors",
      "description": "Manage uptime monitors"
    },
    {
      "name": "Monitor Groups",
      "description": "Manage monitor groups"
    },
    {
      "name": "Heartbeats",
      "description": "Manage heartbeat monitors"
    },
    {
      "name": "Incidents",
      "description": "Manage incidents"
    },
    {
      "name": "Status Pages",
      "description": "Manage status pages"
    },
    {
      "name": "On-Call Calendars",
      "description": "Manage on-call calendars"
    }
  ],
  "paths": {
    "/monitors": {
      "get": {
        "operationId": "listMonitors",
        "summary": "List all monitors",
        "description": "Returns a list of all existing monitors. The status attribute can be: paused, pending, maintenance, up, validating, or down.",
        "tags": [
          "Monitors"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of items per page (max 50)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of monitors",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Monitor"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createMonitor",
        "summary": "Create a monitor",
        "description": "Creates a new monitor. If an escalation policy is set (policy_id) then the simple escalation settings (call, sms, email, push) are ignored.",
        "tags": [
          "Monitors"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMonitorRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Monitor created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Monitor"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Unprocessable entity"
          }
        }
      }
    },
    "/monitors/{monitorId}": {
      "get": {
        "operationId": "getMonitor",
        "summary": "Get a monitor",
        "description": "Returns a single monitor by ID.",
        "tags": [
          "Monitors"
        ],
        "parameters": [
          {
            "name": "monitorId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Monitor details",
