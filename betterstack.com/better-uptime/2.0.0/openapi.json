  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Use your Better Stack API token as a Bearer token."
      }
    },
    "schemas": {
      "Monitor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "attributes": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              },
              "pronounceable_name": {
                "type": "string"
              },
              "monitor_type": {
                "type": "string",
                "enum": [
                  "status",
                  "expected_status_code",
                  "keyword",
                  "keyword_absence",
                  "ping",
                  "tcp",
                  "udp",
                  "smtp",
                  "pop",
                  "imap"
                ]
              },
              "monitor_group_id": {
                "type": "string",
                "nullable": true
              },
              "last_checked_at": {
                "type": "string",
                "format": "date-time"
              },
              "status": {
                "type": "string",
                "enum": [
                  "paused",
                  "pending",
                  "maintenance",
                  "up",
                  "validating",
                  "down"
                ]
              },
              "check_frequency": {
                "type": "integer",
                "description": "Check frequency in seconds"
              },
              "call": {
                "type": "boolean"
              },
              "sms": {
                "type": "boolean"
              },
              "email": {
                "type": "boolean"
              },
              "push": {
                "type": "boolean"
              },
              "team_wait": {
                "type": "integer",
                "nullable": true
              },
              "http_method": {
                "type": "string",
                "enum": [
                  "get",
                  "head",
                  "post",
                  "put",
                  "patch"
                ]
              },
              "request_timeout": {
                "type": "integer"
              },
              "recovery_period": {
                "type": "integer"
              },
              "request_headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "request_body": {
                "type": "string"
              },
              "paused_at": {
                "type": "string",
                "format": "date-time",
                "nullable": true
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              },
              "updated_at": {
                "type": "string",
                "format": "date-time"
              },
              "ssl_expiration": {
                "type": "integer",
                "nullable": true
              },
              "domain_expiration": {
                "type": "integer",
                "nullable": true
              },
              "regions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "policy_id": {
                "type": "string",
                "nullable": true
              },
              "follow_redirects": {
                "type": "boolean"
              },
              "expected_status_codes": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              },
              "confirmation_period": {
                "type": "integer"
              }
            }
          }
        }
      },
      "CreateMonitorRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "description": "URL to monitor"
          },
          "pronounceable_name": {
            "type": "string"
          },
          "monitor_type": {
            "type": "string",
            "enum": [
              "status",
              "expected_status_code",
              "keyword",
              "keyword_absence",
              "ping",
              "tcp",
              "udp",
              "smtp",
              "pop",
              "imap"
            ]
          },
          "monitor_group_id": {
            "type": "string"
          },
          "check_frequency": {
            "type": "integer",
            "description": "Check frequency in seconds (30-86400)"
          },
          "call": {
            "type": "boolean"
          },
          "sms": {
            "type": "boolean"
          },
          "email": {
            "type": "boolean"
          },
          "push": {
            "type": "boolean"
          },
          "http_method": {
            "type": "string",
            "enum": [
              "get",
              "head",
              "post",
              "put",
              "patch"
            ]
          },
          "request_timeout": {
            "type": "integer"
          },
          "recovery_period": {
            "type": "integer"
          },
          "request_headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "request_body": {
            "type": "string"
          },
          "regions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "policy_id": {
            "type": "string"
          },
          "follow_redirects": {
            "type": "boolean"
          },
          "expected_status_codes": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "confirmation_period": {
            "type": "integer"
          }
        }
      },
      "UpdateMonitorRequest": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "pronounceable_name": {
            "type": "string"
          },
          "monitor_type": {
            "type": "string"
          },
          "check_frequency": {
            "type": "integer"
          },
          "call": {
            "type": "boolean"
          },
          "sms": {
            "type": "boolean"
          },
          "email": {
            "type": "boolean"
          },
          "push": {
            "type": "boolean"
          },
          "paused": {
            "type": "boolean"
          }
        }
      },
      "MonitorGroup": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "attributes": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "sort_index": {
                "type": "integer"
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              },
              "updated_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
