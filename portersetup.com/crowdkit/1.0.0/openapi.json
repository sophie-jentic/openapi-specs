{
  "openapi": "3.0.3",
  "info": {
    "title": "Porter Setup API",
    "version": "1.0.0",
    "description": "Porter Setup API for hospitality and event management. Manage bookings, guest information, and venue operations.",
    "x-jentic-source-url": "https://portersetup.com/docs/api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.portersetup.com/v1"
    }
  ],
  "security": [
    {
      "ApiKey": []
    }
  ],
  "components": {
    "schemas": {
      "BookingRequest": {
        "type": "object",
        "required": [
          "guest_name",
          "check_in",
          "check_out"
        ],
        "properties": {
          "guest_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "check_in": {
            "type": "string",
            "format": "date"
          },
          "check_out": {
            "type": "string",
            "format": "date"
          },
          "guests": {
            "type": "integer"
          },
          "room_type": {
            "type": "string"
          }
        }
      },
      "BookingResponse": {
        "type": "object",
        "properties": {
          "booking_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "guest_name": {
            "type": "string"
          },
          "check_in": {
            "type": "string",
            "format": "date"
          },
          "check_out": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "GuestResponse": {
        "type": "object",
        "properties": {
          "guest_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/bookings": {
      "post": {
        "summary": "Create booking",
        "description": "Create a new booking for a guest",
        "operationId": "createBooking",
        "tags": [
          "Bookings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BookingRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Booking created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookingResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List bookings",
        "description": "Get a list of all bookings",
        "operationId": "listBookings",
        "tags": [
          "Bookings"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date_from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of bookings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BookingResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/bookings/{booking_id}": {
      "get": {
        "summary": "Get booking",
        "description": "Retrieve details of a specific booking",
        "operationId": "getBooking",
        "tags": [
          "Bookings"
        ],
        "parameters": [
          {
            "name": "booking_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookingResponse"
                }
              }
            }
          }
        }
      }
    },
    "/guests/{guest_id}": {
      "get": {
        "summary": "Get guest",
        "description": "Retrieve guest information",
        "operationId": "getGuest",
        "tags": [
          "Guests"
        ],
        "parameters": [
          {
            "name": "guest_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Guest details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GuestResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Bookings",
      "description": "Booking management"
    },
    {
      "name": "Guests",
      "description": "Guest management"
    }
  ]
}
