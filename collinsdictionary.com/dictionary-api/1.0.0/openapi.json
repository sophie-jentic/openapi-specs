{
  "openapi": "3.0.3",
  "info": {
    "title": "Collins Dictionary API",
    "description": "Access Collins Dictionary data including word definitions, translations, examples, and related content. Provides comprehensive dictionary and thesaurus information from Collins, one of the leading English language dictionaries.",
    "version": "1.0.0",
    "contact": {
      "url": "https://api.collinsdictionary.com/"
    }
  },
  "servers": [
    {
      "url": "https://api.collinsdictionary.com/api/v1"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/dictionaries/{dictionary}/search": {
      "get": {
        "summary": "Search dictionary entries",
        "description": "Search for word entries in the specified Collins dictionary.",
        "operationId": "searchDictionary",
        "parameters": [
          {
            "name": "dictionary",
            "in": "path",
            "description": "The dictionary to search (e.g., english, french-english, spanish-english, german-english, italian-english)",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "english",
                "french-english",
                "spanish-english",
                "german-english",
                "italian-english"
              ]
            },
            "example": "english"
          },
          {
            "name": "q",
            "in": "query",
            "description": "The search query (word or phrase to look up)",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "example"
          },
          {
            "name": "format",
            "in": "query",
            "description": "Response format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "html"
              ],
              "default": "json"
            }
          },
          {
            "name": "pagesize",
            "in": "query",
            "description": "Number of results per page",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "pageindex",
            "in": "query",
            "description": "Page number (0-indexed)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          },
          "404": {
            "description": "No results found"
          }
        },
        "tags": [
          "dictionaries"
        ]
      }
    },
    "/dictionaries/{dictionary}/entries/{entryId}": {
      "get": {
        "summary": "Get dictionary entry by ID",
        "description": "Retrieve a specific dictionary entry with full details including definitions, examples, pronunciation, and related information.",
        "operationId": "getDictionaryEntry",
        "parameters": [
          {
            "name": "dictionary",
            "in": "path",
            "description": "The dictionary to query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entryId",
            "in": "path",
            "description": "The entry ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Response format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "html"
              ],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with entry details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DictionaryEntry"
                }
              }
            }
          },
          "404": {
            "description": "Entry not found"
          }
        },
        "tags": [
          "dictionaries"
        ]
      }
    },
    "/dictionaries/{dictionary}/nearby": {
      "get": {
        "summary": "Get nearby dictionary entries",
        "description": "Retrieve dictionary entries that are alphabetically near the specified word.",
        "operationId": "getNearbyEntries",
        "parameters": [
          {
            "name": "dictionary",
            "in": "path",
            "description": "The dictionary to query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "The reference word",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Nearby entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/EntryReference"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "dictionaries"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "accesskey",
        "description": "API access key required for authentication. Register at api.collinsdictionary.com to obtain a key."
      }
    },
    "schemas": {
      "SearchResults": {
        "type": "object",
        "properties": {
          "dictionaryCode": {
            "type": "string",
            "description": "Dictionary identifier"
          },
          "entryLabel": {
            "type": "string",
            "description": "Search query"
          },
          "totalResults": {
            "type": "integer",
            "description": "Total number of results"
          },
          "currentPageIndex": {
            "type": "integer",
            "description": "Current page number"
          },
          "pageSize": {
            "type": "integer",
            "description": "Results per page"
          },
          "results": {
            "type": "array",
            "description": "Search results",
            "items": {
              "$ref": "#/components/schemas/EntryReference"
            }
          }
        }
      },
      "EntryReference": {
        "type": "object",
        "properties": {
          "entryId": {
            "type": "string",
            "description": "Unique entry identifier"
          },
          "entryLabel": {
            "type": "string",
            "description": "The headword"
          },
          "entryUrl": {
            "type": "string",
            "description": "URL to full entry"
          }
        }
      },
      "DictionaryEntry": {
        "type": "object",
        "properties": {
          "entryId": {
            "type": "string",
            "description": "Entry identifier"
          },
          "entryLabel": {
            "type": "string",
            "description": "The headword"
          },
          "entryContent": {
            "type": "string",
            "description": "Full entry content (format depends on format parameter)"
          },
          "topics": {
            "type": "array",
            "description": "Related topics",
            "items": {
              "type": "string"
            }
          },
          "pronunciations": {
            "type": "array",
            "description": "Pronunciation information",
            "items": {
              "type": "object",
              "properties": {
                "phoneticSpelling": {
                  "type": "string"
                },
                "audio": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "url": {
                        "type": "string"
                      },
                      "type": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "dictionaries"
    }
  ]
}
