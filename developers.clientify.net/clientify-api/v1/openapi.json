          },
          "task_stage": {
            "type": "string",
            "description": "URL of the task stage"
          },
          "message": {
            "type": "string",
            "description": "Message text shown in contact wall"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
