{
  "openapi": "3.0.3",
  "info": {
    "title": "Finstar API",
    "version": "1.0.0",
    "description": "Finstar open banking APIs for PSD2 payment initiation, account access (XS2A), card management, and digital onboarding.",
    "x-jentic-source-url": "https://www.finstar.ch/en/products/api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.finstar.ch"
    }
  ],
