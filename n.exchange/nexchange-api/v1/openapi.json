{
  "openapi": "3.0.3",
  "info": {
    "title": "Nexchange API",
    "description": "N.exchange (Nexchange) is a non-custodial cryptocurrency exchange API. Provides access to currency pairs, price quotes, and order management for instant crypto-to-crypto and fiat-to-crypto exchanges.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://nexchange2.docs.apiary.io/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.n.exchange/en/api/v1",
      "description": "Production"
    }
  ],
  "tags": [
    {
      "name": "Currencies",
      "description": "Available currencies"
    },
    {
      "name": "Pairs",
      "description": "Trading pair information"
    },
    {
      "name": "Prices",
      "description": "Price and quote data"
    },
    {
      "name": "Orders",
      "description": "Order management"
    },
    {
      "name": "Referrals",
      "description": "Referral system"
    },
    {
      "name": "KYC",
      "description": "Know Your Customer verification"
    }
  ],
