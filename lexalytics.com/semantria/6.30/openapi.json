  "components": {
    "securitySchemes": {
      "Api_Auth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API authentication token obtained from the Create Session endpoint."
      }
    },
    "schemas": {
      "UserSession": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The token passed as a header to authenticate other calls to the Semantria API."
          },
          "account_id": {
            "type": "string",
            "description": "Account identifier."
          },
          "authenticated": {
            "type": "string",
            "format": "date-time",
            "description": "UTC time and date the session was created."
          },
          "expiration": {
            "type": "string",
            "format": "date-time",
            "description": "UTC time and date the session will expire."
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs of the groups the authenticated user is a member of."
          },
          "notes": {
            "type": "string",
            "description": "Optional notes about the session purpose."
          },
          "permissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Permission"
            },
            "description": "List of permissions for the user."
          },
          "renewal_type": {
            "type": "string",
            "enum": [
              "AUTO",
              "MANUAL",
              "NONE"
            ],
            "description": "How the session expiration is renewed."
          },
          "user_id": {
            "type": "string",
            "description": "User identifier."
          },
          "user_login": {
