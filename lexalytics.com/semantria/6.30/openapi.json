{
  "openapi": "3.0.3",
  "info": {
    "title": "Semantria API",
    "description": "Text Analytics API with sentiment analysis, categorization, and named entity extraction. Semantria is a SaaS text analytics service from Lexalytics that provides natural language processing capabilities including sentiment analysis, entity recognition, theme extraction, categorization, and more.",
    "version": "6.30",
    "contact": {
      "name": "Lexalytics",
      "url": "https://www.lexalytics.com"
    }
  },
  "servers": [
    {
      "url": "https://api5.semantria.com",
      "description": "Semantria API (North America)"
    }
  ],
  "security": [
    {
      "Api_Auth": []
    }
  ],
  "paths": {
    "/auth/sessions": {
      "get": {
        "operationId": "getAllSessions",
        "summary": "Get All User Sessions",
        "description": "Retrieve all active sessions for the authenticated user.",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "List of sessions retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserSession"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createSession",
        "summary": "Create Semantria Session",
        "description": "Authenticate and create a new Semantria session. Returns an access token used for authenticating subsequent API calls.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "x-api-version",
            "in": "header",
            "description": "API version specification.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "login",
                  "password"
                ],
                "properties": {
                  "login": {
                    "type": "string",
                    "description": "Account login name or email."
                  },
                  "password": {
                    "type": "string",
                    "description": "Account password."
                  },
                  "expiration": {
                    "type": "string",
                    "description": "Type of expiration.",
                    "enum": [
                      "default",
                      "custom",
                      "forever"
                    ],
                    "default": "default"
                  },
                  "expire_after_minutes": {
                    "type": "string",
                    "description": "Minutes until token expires. Requires expiration=custom."
                  },
                  "notes": {
                    "type": "string",
                    "description": "Purpose or use of this token."
                  },
                  "renewal_type": {
                    "type": "string",
                    "description": "How expiration time is updated.",
                    "enum": [
                      "auto",
                      "manual"
                    ],
                    "default": "auto"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserSession"
                }
              }
            }
          },
          "404": {
            "description": "Not found."
          }
        }
      }
    },
    "/auth/sessions/{sessionId}": {
      "get": {
        "operationId": "getSession",
        "summary": "Get Semantria Session",
        "description": "Retrieve details of an existing Semantria session.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "description": "The id of the session. Same as the auth token received when the session was created.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Session details retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserSession"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteSession",
        "summary": "Delete Semantria Session",
        "description": "Remove an active Semantria session, effectively logging out the user.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "description": "The id of the session. Same as the auth token received when the session was created.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Session deleted successfully."
          }
        }
      }
    },
