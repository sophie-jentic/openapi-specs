{
  "openapi": "3.0.3",
  "info": {
    "title": "AskYourPDF API",
    "version": "0.1.0",
    "description": "AskYourPDF API enables developers to programmatically upload documents, extract information from PDF files, and create interactive chatbots. Supports PDF, TXT, PPT, PPTX, CSV, EPUB, and RTF formats.",
    "x-jentic-source-url": "https://docs.askyourpdf.com",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.askyourpdf.com",
      "description": "AskYourPDF API Server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Document",
      "description": "Document upload and management operations"
    },
    {
      "name": "Chat",
      "description": "Chat with documents"
    },
    {
      "name": "Knowledge Base",
      "description": "Knowledge base management"
    }
  ],
  "paths": {
    "/v1/api/download_pdf": {
      "get": {
        "tags": [
          "Document"
        ],
        "summary": "Download PDF from URL",
        "description": "Download a PDF file from a URL and save it to the database. Supports PDF links and website/blog post URLs.",
        "operationId": "downloadPdf",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "The URL of the PDF file or web page to download.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Document successfully downloaded and saved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/api/upload": {
      "post": {
        "tags": [
          "Document"
        ],
        "summary": "Upload PDF file",
        "description": "Upload a PDF file and save it to the database. Supports .pdf, .txt, .ppt, .pptx, .csv, .epub, and .rtf formats.",
        "operationId": "uploadPdf",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UploadPdfRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document successfully uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/{doc_id}": {
      "post": {
        "tags": [
          "Chat"
        ],
        "summary": "Chat with document",
        "description": "Chat with a single document. Supports multiple AI models, streaming, source citation, and multi-turn conversations.",
        "operationId": "chatWithDocument",
        "parameters": [
          {
            "name": "doc_id",
            "in": "path",
            "required": true,
            "description": "The ID of the document to chat with.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "model_name",
            "in": "query",
            "required": false,
            "description": "The AI model to use for the chat.",
            "schema": {
              "type": "string",
              "enum": [
                "CLAUDE1",
                "CLAUDE2",
                "GPT3",
                "GPT4",
                "GPT4O_MINI",
                "GEMINI_FLASH",
                "GEMINI_PRO",
                "GPT5_MINI",
                "GPT5_2",
                "GPT5_NANO",
                "GPT5"
              ],
              "default": "GPT5_2"
            }
          },
          {
            "name": "stream",
            "in": "query",
            "required": false,
            "description": "Whether to stream the response as tokens.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "cite_source",
            "in": "query",
            "required": false,
            "description": "Whether to cite the source in the response.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "temperature",
            "in": "query",
            "required": false,
            "description": "The model temperature. Min 0.1, max 1.5.",
            "schema": {
              "type": "number",
              "default": 0.7,
              "minimum": 0.1,
              "maximum": 1.5
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "description": "The language to respond in.",
            "schema": {
              "type": "string",
              "enum": [
                "DEFAULT",
                "ENGLISH",
                "FRENCH",
                "GERMAN",
                "SPANISH",
                "CHINESE",
                "JAPANESE",
                "KOREAN",
                "PORTUGUESE",
                "ARABIC",
                "ITALIAN",
                "TURKISH",
                "HEBREW",
                "DUTCH"
              ],
              "default": "DEFAULT"
            }
          },
          {
            "name": "length",
            "in": "query",
            "required": false,
            "description": "The desired length of the response.",
            "schema": {
              "type": "string",
              "enum": [
                "SHORT",
                "LONG"
              ],
              "default": "LONG"
            }
          },
          {
            "name": "agent_mode",
            "in": "query",
            "required": false,
            "description": "Whether to use agent mode for more accurate responses.",
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ChatRequest"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful chat response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatSerializer"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/api/knowledge_base_chat": {
      "post": {
        "tags": [
          "Chat"
        ],
        "summary": "Chat with multiple documents",
        "description": "Chat with multiple documents by providing a list of document IDs. Deprecated in favor of /api/knowledge/{knowledge_base_id}/chat.",
        "operationId": "chatWithMultipleDocuments",
        "deprecated": true,
        "parameters": [
          {
            "name": "model_name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "CLAUDE1",
                "CLAUDE2",
                "GPT3",
                "GPT4",
                "GPT4O_MINI",
                "GEMINI_FLASH",
                "GEMINI_PRO",
                "GPT5_MINI",
                "GPT5_2",
                "GPT5_NANO",
                "GPT5"
              ],
              "default": "GPT5_MINI"
            }
          },
          {
            "name": "stream",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "cite_source",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "temperature",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 0.7
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "DEFAULT",
                "ENGLISH",
                "FRENCH",
                "GERMAN",
                "SPANISH",
                "CHINESE",
                "JAPANESE",
                "KOREAN",
                "PORTUGUESE",
                "ARABIC",
                "ITALIAN",
                "TURKISH",
                "HEBREW",
                "DUTCH"
              ],
              "default": "DEFAULT"
            }
          },
          {
            "name": "length",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "SHORT",
                "LONG"
              ],
              "default": "LONG"
            }
          },
          {
            "name": "agent_mode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KnowledgeChatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful chat response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatSerializer"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/api/documents": {
      "get": {
        "tags": [
          "Document"
        ],
        "summary": "Fetch documents",
        "description": "Fetch a paginated list of all documents for the current user.",
        "operationId": "fetchDocuments",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "The page number to return.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "description": "Number of documents per page.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with document list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserDocumentsMetaSerializer"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/api/documents/{doc_id}": {
      "get": {
        "tags": [
          "Document"
        ],
        "summary": "Fetch single document",
        "description": "Fetch a single document's metadata by its document ID.",
        "operationId": "fetchDocument",
        "parameters": [
          {
            "name": "doc_id",
            "in": "path",
            "required": true,
            "description": "The document ID.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with document metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserDocumentMeta"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Document"
        ],
        "summary": "Delete document",
        "description": "Delete a document belonging to the authenticated user.",
        "operationId": "deleteDocument",
        "parameters": [
          {
            "name": "doc_id",
            "in": "path",
            "required": true,
            "description": "The document ID to delete.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document successfully deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/api/knowledge/{knowledge_base_id}/chat": {
      "post": {
        "tags": [
          "Knowledge Base"
        ],
        "summary": "Chat with knowledge base",
        "description": "Chat with a knowledge base by its ID. This is the recommended endpoint for multi-document chat.",
        "operationId": "chatWithKnowledgeBase",
        "parameters": [
          {
            "name": "knowledge_base_id",
            "in": "path",
            "required": true,
            "description": "The knowledge base ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "model_name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "CLAUDE1",
                "CLAUDE2",
                "GPT3",
                "GPT4",
                "GPT4O_MINI",
                "GEMINI_FLASH",
                "GEMINI_PRO",
                "GPT5_MINI",
                "GPT5_2",
                "GPT5_NANO",
                "GPT5"
              ],
              "default": "GPT5_2"
            }
          },
          {
            "name": "stream",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "cite_source",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "temperature",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 0.7
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "DEFAULT",
                "ENGLISH",
                "FRENCH",
                "GERMAN",
                "SPANISH",
                "CHINESE",
                "JAPANESE",
                "KOREAN",
                "PORTUGUESE",
                "ARABIC",
                "ITALIAN",
                "TURKISH",
                "HEBREW",
                "DUTCH"
              ],
              "default": "DEFAULT"
            }
          },
          {
            "name": "length",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "SHORT",
                "LONG"
              ],
              "default": "LONG"
            }
          },
          {
            "name": "agent_mode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ChatRequest"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful chat response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatSerializer"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key generated from your AskYourPDF account at https://askyourpdf.com/developers/apiKeys"
      }
    },
    "schemas": {
      "DocumentUploadResponse": {
        "type": "object",
        "required": [
          "docId"
        ],
        "properties": {
          "docId": {
            "type": "string",
            "description": "The document ID of the uploaded/downloaded document."
          }
        }
      },
      "UploadPdfRequest": {
        "type": "object",
        "required": [
          "file"
        ],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "The file to upload."
          }
        }
      },
      "ChatRequest": {
        "type": "object",
        "required": [
          "sender",
          "message"
        ],
        "properties": {
          "sender": {
            "type": "string",
            "description": "The sender: 'user', 'bot', or 'system'."
          },
          "message": {
            "type": "string",
            "description": "The chat message content."
          }
        }
      },
      "ChatSerializer": {
        "type": "object",
        "required": [
          "question",
          "answer"
        ],
        "properties": {
          "question": {
            "$ref": "#/components/schemas/ChatResponse"
          },
          "answer": {
            "$ref": "#/components/schemas/ChatResponse"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "The time the chat was created."
          }
        }
      },
      "ChatResponse": {
        "type": "object",
        "required": [
          "sender",
          "message",
          "type"
        ],
        "properties": {
          "sender": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "description": "Either 'question' or 'response'."
          }
        }
      },
      "KnowledgeChatRequest": {
        "type": "object",
        "required": [
          "documents",
          "messages"
        ],
        "properties": {
          "documents": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of document IDs to chat with."
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatRequest"
            }
          }
        }
      },
      "UserDocumentsMetaSerializer": {
        "type": "object",
        "required": [
          "documents"
        ],
        "properties": {
          "total_pages": {
            "type": "integer",
            "default": 0
          },
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserDocumentMeta"
            }
          }
        }
      },
      "UserDocumentMeta": {
        "type": "object",
        "required": [
          "name",
          "doc_id"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "doc_id": {
            "type": "string"
          },
          "summary": {
            "type": "string",
            "nullable": true
          },
          "language": {
            "type": "string",
            "default": "en"
          },
          "pages": {
            "type": "integer",
            "default": 0
          },
          "shareable": {
            "type": "boolean",
            "default": true
          },
          "date_time": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "HTTPValidationError": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            }
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "properties": {
          "loc": {
