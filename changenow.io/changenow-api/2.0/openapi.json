{
  "openapi": "3.0.3",
  "info": {
    "title": "ChangeNOW API",
    "version": "2.0",
    "description": "ChangeNOW cryptocurrency exchange API v2. Provides endpoints for instant cryptocurrency exchanges without registration, including currency listings, exchange rate estimation, transaction creation, and transaction status tracking.",
    "x-jentic-source-url": "https://changenow.io/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.changenow.io/v2"
    }
  ],
  "paths": {
    "/exchange/currencies": {
      "get": {
        "operationId": "listCurrencies",
        "summary": "List available currencies",
        "description": "Returns a list of available currencies for exchange",
        "tags": [
          "Currencies"
        ],
        "parameters": [
          {
            "name": "active",
            "in": "query",
            "description": "Show only active currencies",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "fixedRate",
            "in": "query",
            "description": "Filter currencies supporting fixed rate",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "buy",
            "in": "query",
            "description": "Filter currencies available for purchase",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sell",
            "in": "query",
            "description": "Filter currencies available for selling",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Currency"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/exchange/estimated-amount": {
      "get": {
        "operationId": "getEstimatedAmount",
        "summary": "Get estimated exchange amount",
        "description": "Returns the estimated amount of cryptocurrency you will receive for a standard-rate exchange",
        "tags": [
          "Exchange"
        ],
        "parameters": [
          {
            "name": "fromCurrency",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Ticker of the currency to send"
          },
          {
            "name": "toCurrency",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Ticker of the currency to receive"
          },
          {
            "name": "fromAmount",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Amount to exchange"
          },
          {
            "name": "fromNetwork",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Network of the currency to send"
          },
          {
            "name": "toNetwork",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Network of the currency to receive"
          },
          {
            "name": "flow",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "standard",
                "fixed-rate"
              ],
              "default": "standard"
            },
            "description": "Exchange flow type"
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "direct",
                "reverse"
              ],
              "default": "direct"
            },
            "description": "Whether fromAmount is the send or receive amount"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EstimatedAmount"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/exchange/min-amount": {
      "get": {
        "operationId": "getMinAmount",
        "summary": "Get minimum exchange amount",
        "description": "Returns the minimum amount required to create an exchange",
        "tags": [
          "Exchange"
        ],
        "parameters": [
          {
            "name": "fromCurrency",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "toCurrency",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromNetwork",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "toNetwork",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flow",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "standard",
                "fixed-rate"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MinAmount"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/exchange/range": {
      "get": {
        "operationId": "getExchangeRange",
        "summary": "Get exchange range",
        "description": "Returns the minimum and maximum amounts for an exchange pair",
        "tags": [
          "Exchange"
        ],
        "parameters": [
          {
            "name": "fromCurrency",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "toCurrency",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromNetwork",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "toNetwork",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flow",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "standard",
                "fixed-rate"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExchangeRange"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/exchange": {
      "post": {
        "operationId": "createExchange",
        "summary": "Create exchange transaction",
        "description": "Creates a new cryptocurrency exchange transaction",
        "tags": [
          "Exchange"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateExchangeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Exchange created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transaction"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/exchange/by-id": {
      "get": {
        "operationId": "getTransactionStatus",
        "summary": "Get transaction status",
        "description": "Returns the current status of an exchange transaction",
        "tags": [
          "Transactions"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Transaction ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionStatus"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/exchange/market-info/available-pairs": {
      "get": {
        "operationId": "getAvailablePairs",
        "summary": "Get available exchange pairs",
        "description": "Returns a list of all available exchange pairs",
        "tags": [
          "Market Info"
        ],
        "parameters": [
          {
            "name": "includePartners",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/fiat-currencies/fiat": {
      "get": {
        "operationId": "listFiatCurrencies",
        "summary": "List fiat currencies",
        "description": "Returns a list of supported fiat currencies",
        "tags": [
          "Fiat"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FiatCurrency"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Currency": {
        "type": "object",
        "properties": {
          "ticker": {
            "type": "string",
            "description": "Currency ticker"
          },
          "name": {
            "type": "string",
            "description": "Currency full name"
          },
          "image": {
            "type": "string",
            "description": "Currency icon URL"
          },
          "hasExternalId": {
            "type": "boolean"
          },
          "isFiat": {
            "type": "boolean"
          },
          "featured": {
            "type": "boolean"
          },
          "isStable": {
            "type": "boolean"
          },
          "supportsFixedRate": {
            "type": "boolean"
          },
          "network": {
            "type": "string"
          },
          "tokenContract": {
            "type": "string"
          },
          "buy": {
            "type": "boolean"
          },
          "sell": {
            "type": "boolean"
          }
        }
      },
      "EstimatedAmount": {
        "type": "object",
        "properties": {
          "fromCurrency": {
            "type": "string"
          },
          "fromNetwork": {
            "type": "string"
          },
          "toCurrency": {
            "type": "string"
          },
          "toNetwork": {
            "type": "string"
          },
          "flow": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "rateId": {
            "type": "string"
          },
          "validUntil": {
            "type": "string"
          },
          "transactionSpeedForecast": {
            "type": "string"
          },
          "warningMessage": {
            "type": "string"
          },
          "fromAmount": {
            "type": "number"
          },
          "toAmount": {
            "type": "number"
          }
        }
      },
      "MinAmount": {
        "type": "object",
        "properties": {
          "fromCurrency": {
            "type": "string"
          },
          "fromNetwork": {
            "type": "string"
          },
          "toCurrency": {
            "type": "string"
          },
          "toNetwork": {
            "type": "string"
          },
          "flow": {
            "type": "string"
          },
          "minAmount": {
            "type": "number"
          }
        }
      },
      "ExchangeRange": {
        "type": "object",
        "properties": {
          "fromCurrency": {
            "type": "string"
          },
          "fromNetwork": {
            "type": "string"
          },
          "toCurrency": {
            "type": "string"
          },
          "toNetwork": {
            "type": "string"
          },
          "flow": {
            "type": "string"
          },
          "minAmount": {
            "type": "number"
          },
          "maxAmount": {
            "type": "number"
          }
        }
      },
      "CreateExchangeRequest": {
        "type": "object",
        "properties": {
          "fromCurrency": {
            "type": "string"
          },
          "toCurrency": {
            "type": "string"
          },
          "fromAmount": {
            "type": "number"
          },
          "address": {
            "type": "string",
            "description": "Destination wallet address"
          },
          "fromNetwork": {
            "type": "string"
          },
          "toNetwork": {
            "type": "string"
          },
          "flow": {
            "type": "string",
            "enum": [
              "standard",
              "fixed-rate"
            ],
            "default": "standard"
          },
          "type": {
            "type": "string",
            "enum": [
              "direct",
              "reverse"
            ],
            "default": "direct"
          },
          "rateId": {
            "type": "string",
            "description": "Rate ID for fixed-rate exchanges"
          },
          "extraId": {
            "type": "string",
            "description": "Extra ID (memo/tag) if required by destination"
          },
          "refundAddress": {
            "type": "string",
            "description": "Refund address in case of issues"
          },
          "refundExtraId": {
            "type": "string"
          },
          "contactEmail": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          }
        },
        "required": [
          "fromCurrency",
          "toCurrency",
          "fromAmount",
          "address"
        ]
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "fromCurrency": {
            "type": "string"
          },
          "fromNetwork": {
            "type": "string"
          },
          "toCurrency": {
            "type": "string"
          },
          "toNetwork": {
            "type": "string"
          },
          "fromAmount": {
            "type": "number"
          },
          "toAmount": {
            "type": "number"
          },
          "flow": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "payinAddress": {
            "type": "string",
            "description": "Address to send funds to"
          },
          "payoutAddress": {
            "type": "string"
          },
          "payinExtraId": {
            "type": "string"
          },
          "refundAddress": {
            "type": "string"
          },
          "refundExtraId": {
            "type": "string"
          }
        }
      },
      "TransactionStatus": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "waiting",
              "confirming",
              "exchanging",
              "sending",
              "finished",
              "failed",
              "refunded",
              "verifying"
            ]
          },
          "fromCurrency": {
            "type": "string"
          },
          "toCurrency": {
            "type": "string"
          },
          "expectedSendAmount": {
            "type": "number"
          },
          "expectedReceiveAmount": {
            "type": "number"
          },
          "amountFrom": {
            "type": "number"
          },
          "amountTo": {
            "type": "number"
          },
          "payinAddress": {
            "type": "string"
          },
          "payoutAddress": {
            "type": "string"
          },
          "payinHash": {
            "type": "string"
          },
          "payoutHash": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FiatCurrency": {
        "type": "object",
        "properties": {
          "ticker": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "image": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-changenow-api-key",
        "description": "ChangeNOW API key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Currencies"
    },
    {
      "name": "Exchange"
    },
    {
      "name": "Fiat"
    },
    {
      "name": "Market Info"
    },
    {
      "name": "Transactions"
    }
  ]
}
