{
  "openapi": "3.0.3",
  "info": {
    "title": "Terros API",
    "description": "Terros API for managing accounts, calendars, contacts, dispositions, evaluations, locations, reports, tasks, teams, users, imports, and exports",
    "version": "1.0.0",
    "contact": {
      "url": "https://docs.terros.com"
    }
  },
  "servers": [
    {
      "url": "https://api.terros.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/user/get": {
      "post": {
        "summary": "Get user profile",
        "description": "Retrieve the current user's profile information",
        "operationId": "getUserProfile",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          },
          "403": {
            "description": "Forbidden - Insufficient permissions"
          }
        },
        "tags": [
          "user"
        ]
      }
    },
    "/account": {
      "get": {
        "summary": "Get accounts",
        "description": "Retrieve account information",
        "operationId": "getAccounts",
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "account"
        ]
      }
    },
