{
  "openapi": "3.0.3",
  "info": {
    "title": "Threat Jammer API",
    "description": "Threat Jammer provides a risk scoring and threat assessment API for IP addresses, user agents, and other network indicators. It aggregates data from multiple threat intelligence sources to deliver real-time risk scores and threat categorization for security applications, WAFs, and fraud prevention systems.",
    "version": "1.0.0",
    "contact": {
      "name": "Threat Jammer",
      "url": "https://threatjammer.com"
    },
    "x-jentic-source-url": "https://threatjammer.com/docs/index"
  },
  "servers": [
    {
      "url": "https://dublin.api.threatjammer.com",
      "description": "Threat Jammer API - Dublin region"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Risk Assessment",
      "description": "IP address and network risk scoring endpoints"
    },
    {
      "name": "IP Intelligence",
      "description": "IP address reputation and threat intelligence"
    },
    {
      "name": "Blocklists",
      "description": "Custom blocklist and allowlist management"
    },
    {
      "name": "User Agent",
      "description": "User agent risk assessment"
    },
    {
      "name": "Account",
      "description": "Account and usage information"
    }
  ],
  "paths": {
    "/v1/assess/ip/{ip}": {
      "get": {
        "operationId": "assessIP",
        "summary": "Assess risk for an IP address",
        "description": "Returns a comprehensive risk assessment for the specified IP address, including risk score, threat categories, and source intelligence data.",
        "tags": [
          "Risk Assessment"
        ],
        "parameters": [
          {
            "name": "ip",
            "in": "path",
            "required": true,
            "description": "The IPv4 or IPv6 address to assess",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Risk assessment result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IPAssessment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid IP address format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing token"
          },
          "403": {
            "description": "Forbidden - insufficient permissions"
          },
          "429": {
            "description": "Too many requests - rate limit exceeded"
          }
        }
      }
    },
    "/v1/assess/ip": {
      "post": {
        "operationId": "assessIPBatch",
        "summary": "Batch assess risk for multiple IP addresses",
        "description": "Returns risk assessments for multiple IP addresses in a single request.",
        "tags": [
          "Risk Assessment"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "ips"
                ],
                "properties": {
                  "ips": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of IP addresses to assess",
                    "maxItems": 100
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch assessment results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IPAssessment"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/report/ip/{ip}": {
      "get": {
        "operationId": "getIPReport",
        "summary": "Get detailed IP report",
        "description": "Returns a detailed intelligence report for an IP address, including ASN information, geolocation, associated threats, and historical data.",
        "tags": [
          "IP Intelligence"
        ],
        "parameters": [
          {
            "name": "ip",
            "in": "path",
            "required": true,
            "description": "The IPv4 or IPv6 address",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detailed IP report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IPReport"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "No data found for this IP"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/report/network/{cidr}": {
      "get": {
        "operationId": "getNetworkReport",
        "summary": "Get network CIDR report",
        "description": "Returns threat intelligence data for a CIDR network range.",
        "tags": [
          "IP Intelligence"
        ],
        "parameters": [
          {
            "name": "cidr",
            "in": "path",
            "required": true,
            "description": "CIDR notation (e.g. 192.168.1.0/24)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Network report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NetworkReport"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid CIDR format"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/report/asn/{asn}": {
      "get": {
        "operationId": "getASNReport",
        "summary": "Get ASN report",
        "description": "Returns threat intelligence data for an autonomous system number.",
        "tags": [
          "IP Intelligence"
        ],
        "parameters": [
          {
            "name": "asn",
            "in": "path",
            "required": true,
            "description": "Autonomous system number",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ASN report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ASNReport"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "ASN not found"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/assess/useragent": {
      "post": {
        "operationId": "assessUserAgent",
        "summary": "Assess user agent risk",
        "description": "Analyzes a user agent string for risk indicators such as known bot signatures, outdated browsers, and suspicious patterns.",
        "tags": [
          "User Agent"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user_agent"
                ],
                "properties": {
                  "user_agent": {
                    "type": "string",
                    "description": "The user agent string to analyze"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User agent assessment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserAgentAssessment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/blocklist/ip": {
      "get": {
        "operationId": "getIPBlocklist",
        "summary": "Get IP blocklist",
        "description": "Returns all IP addresses and CIDR ranges in the custom blocklist.",
        "tags": [
          "Blocklists"
        ],
        "responses": {
          "200": {
            "description": "Blocklist entries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlocklistResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "addToIPBlocklist",
        "summary": "Add IP to blocklist",
        "description": "Adds an IP address or CIDR range to the custom blocklist.",
        "tags": [
          "Blocklists"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "ip"
                ],
                "properties": {
                  "ip": {
                    "type": "string",
                    "description": "IP address or CIDR range to block"
                  },
                  "ttl": {
                    "type": "integer",
                    "description": "Time to live in seconds (0 for permanent)",
                    "default": 0
                  },
                  "reason": {
                    "type": "string",
                    "description": "Reason for blocking"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Added to blocklist"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "409": {
            "description": "Conflict - entry already exists"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      },
      "delete": {
        "operationId": "removeFromIPBlocklist",
        "summary": "Remove IP from blocklist",
        "description": "Removes an IP address or CIDR range from the custom blocklist.",
        "tags": [
          "Blocklists"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "ip"
                ],
                "properties": {
                  "ip": {
                    "type": "string",
                    "description": "IP address or CIDR range to unblock"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Removed from blocklist"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Entry not found in blocklist"
          }
        }
      }
    },
    "/v1/allowlist/ip": {
      "get": {
        "operationId": "getIPAllowlist",
        "summary": "Get IP allowlist",
        "description": "Returns all IP addresses and CIDR ranges in the custom allowlist.",
        "tags": [
          "Blocklists"
        ],
        "responses": {
          "200": {
            "description": "Allowlist entries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlocklistResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "addToIPAllowlist",
        "summary": "Add IP to allowlist",
        "description": "Adds an IP address or CIDR range to the custom allowlist.",
        "tags": [
          "Blocklists"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "ip"
                ],
                "properties": {
                  "ip": {
                    "type": "string",
                    "description": "IP address or CIDR range to allow"
                  },
                  "ttl": {
                    "type": "integer",
                    "description": "Time to live in seconds (0 for permanent)",
                    "default": 0
                  },
                  "reason": {
                    "type": "string",
                    "description": "Reason for allowing"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Added to allowlist"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "409": {
            "description": "Conflict - entry already exists"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      },
      "delete": {
        "operationId": "removeFromIPAllowlist",
        "summary": "Remove IP from allowlist",
        "tags": [
          "Blocklists"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "ip"
                ],
                "properties": {
                  "ip": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Removed from allowlist"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Entry not found"
          }
        },
        "description": "Remove IP from allowlist"
      }
    },
    "/v1/account/usage": {
      "get": {
        "operationId": "getAccountUsage",
        "summary": "Get account usage",
        "description": "Returns the current account's API usage statistics and remaining quota.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Usage statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountUsage"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/account/plan": {
      "get": {
        "operationId": "getAccountPlan",
        "summary": "Get account plan",
        "description": "Returns the current account's subscription plan details.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Plan details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountPlan"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token authentication. Obtain your API token from the Threat Jammer dashboard."
      }
    },
    "schemas": {
      "IPAssessment": {
        "type": "object",
        "properties": {
          "ip": {
            "type": "string",
            "description": "The assessed IP address"
          },
          "score": {
            "type": "integer",
            "description": "Risk score from 0 (safe) to 100 (maximum risk)",
            "minimum": 0,
            "maximum": 100
          },
          "risk": {
            "type": "string",
            "description": "Risk level classification",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Threat categories (e.g. 'spam', 'botnet', 'tor_exit', 'vpn', 'proxy', 'scanner')"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Intelligence sources that flagged this IP"
          },
          "blocklist_match": {
            "type": "boolean",
            "description": "Whether the IP matches a custom blocklist entry"
          },
          "allowlist_match": {
            "type": "boolean",
            "description": "Whether the IP matches a custom allowlist entry"
          }
        }
      },
      "IPReport": {
        "type": "object",
        "properties": {
          "ip": {
            "type": "string"
          },
          "score": {
            "type": "integer"
          },
          "risk": {
            "type": "string"
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "asn": {
            "type": "object",
            "properties": {
              "number": {
                "type": "integer"
              },
              "organization": {
                "type": "string"
              },
              "country": {
                "type": "string"
              }
            }
          },
          "geolocation": {
            "type": "object",
            "properties": {
              "country": {
                "type": "string"
              },
              "country_code": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "latitude": {
                "type": "number"
              },
              "longitude": {
                "type": "number"
              }
            }
          },
          "network": {
            "type": "object",
            "properties": {
              "cidr": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "category": {
                  "type": "string"
                },
                "first_seen": {
                  "type": "string",
                  "format": "date-time"
                },
                "last_seen": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      },
      "NetworkReport": {
        "type": "object",
        "properties": {
          "cidr": {
            "type": "string"
          },
          "total_ips": {
            "type": "integer"
          },
          "malicious_ips": {
            "type": "integer"
          },
          "risk_score": {
            "type": "integer"
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ASNReport": {
        "type": "object",
        "properties": {
          "asn": {
            "type": "integer"
          },
          "organization": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "total_ips": {
            "type": "integer"
          },
          "malicious_ips": {
            "type": "integer"
          },
          "risk_score": {
            "type": "integer"
          },
          "prefixes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "UserAgentAssessment": {
        "type": "object",
        "properties": {
          "user_agent": {
            "type": "string"
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "is_bot": {
            "type": "boolean"
          },
          "bot_category": {
            "type": "string",
            "nullable": true
          },
          "browser": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "version": {
                "type": "string"
              }
            }
          },
          "os": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "version": {
                "type": "string"
              }
            }
          }
        }
      },
      "BlocklistResponse": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ip": {
                  "type": "string"
                },
                "ttl": {
                  "type": "integer"
                },
                "reason": {
                  "type": "string",
                  "nullable": true
                },
                "created_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "AccountUsage": {
        "type": "object",
        "properties": {
          "requests_today": {
            "type": "integer"
          },
          "requests_this_month": {
            "type": "integer"
          },
          "requests_limit": {
            "type": "integer"
          },
          "requests_remaining": {
            "type": "integer"
          }
        }
      },
      "AccountPlan": {
        "type": "object",
        "properties": {
          "plan_name": {
            "type": "string"
          },
          "requests_per_month": {
            "type": "integer"
          },
          "rate_limit_per_second": {
            "type": "integer"
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          },
          "detail": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      }
    }
  }
}
