{
  "openapi": "3.0.3",
  "info": {
    "title": "SiPay Wallet API",
    "version": "1.0.0",
    "description": "STS API for SiPay wallet payment transactions.",
    "x-jentic-source-url": "https://walletapi.sipay.com.tr/tr/transaction/payment",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://walletapi.sipay.com.tr"
    }
  ],
  "paths": {
    "/v1/Transaction/Payment": {
      "post": {
        "operationId": "createPayment",
        "summary": "Create payment",
        "description": "Process payment from individual user account to institution account.",
        "tags": [
          "Transactions"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PaymentRequest": {
        "type": "object",
        "required": [
          "sender_account_number",
          "sender_wallet_number",
          "ext_transaction_id",
          "currency_code",
          "amount",
          "receiver_wallet_number"
        ],
        "properties": {
          "sender_account_number": {
            "type": "string"
          },
          "sender_wallet_number": {
            "type": "string"
          },
          "ext_transaction_id": {
            "type": "string"
          },
          "business_code": {
            "type": "string"
          },
          "currency_code": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "description": {
            "type": "string"
          },
          "receiver_wallet_number": {
            "type": "string"
          },
          "source_type": {
            "type": "string"
          },
          "channel_type": {
            "type": "string"
          },
          "hash_key": {
            "type": "string"
          }
        }
      },
      "PaymentResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Transactions"
    }
  ]
}
