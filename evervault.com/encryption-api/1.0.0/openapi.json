{
  "openapi": "3.0.3",
  "info": {
    "title": "Evervault Encryption API",
    "version": "1.0.0",
    "description": "Evervault provides encryption-as-a-service. The API allows encrypting data, decrypting data, running Evervault Functions (serverless encryption), creating tokens for client-side decryption, and managing cages/functions.",
    "x-jentic-source-url": "https://docs.evervault.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.evervault.com",
      "description": "Evervault API"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Encryption",
      "description": "Encrypt and decrypt data"
    },
    {
      "name": "Functions",
      "description": "Run Evervault Functions"
    },
    {
      "name": "Tokens",
      "description": "Create client tokens"
    }
  ],
  "paths": {
    "/encrypt": {
      "post": {
        "operationId": "encryptData",
        "summary": "Encrypt data",
        "description": "Encrypts the provided data using Evervault's encryption. Returns encrypted strings that can only be decrypted by Evervault.",
        "tags": [
          "Encryption"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "description": "Data to encrypt. Can be a string, number, boolean, array, or object."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Encrypted data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "description": "The encrypted data"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/decrypt": {
      "post": {
        "operationId": "decryptData",
        "summary": "Decrypt data",
        "description": "Decrypts previously encrypted data. Requires an API key with decrypt permissions.",
        "tags": [
          "Encryption"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "description": "Encrypted data to decrypt. Can be a string, array, or object containing encrypted values."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Decrypted data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "description": "The decrypted data"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - API key lacks decrypt permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/functions/{functionName}/runs": {
      "post": {
        "operationId": "runFunction",
        "summary": "Run an Evervault Function",
        "description": "Executes an Evervault Function (serverless function that can process encrypted data). The function runs in a secure enclave and can decrypt data passed to it.",
        "tags": [
          "Functions"
        ],
        "parameters": [
          {
            "name": "functionName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the Function to run"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "payload": {
                    "type": "object",
                    "description": "Data payload to send to the function",
                    "additionalProperties": true
                  },
                  "async": {
                    "type": "boolean",
                    "description": "Whether to run the function asynchronously",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Function result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FunctionRunResult"
                }
              }
            }
          },
          "202": {
            "description": "Function queued (async mode)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FunctionRunQueued"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Function not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/client-tokens": {
      "post": {
        "operationId": "createClientToken",
        "summary": "Create a client token",
        "description": "Creates a short-lived token that can be used client-side to decrypt specific data. Useful for displaying decrypted data in browsers or mobile apps.",
        "tags": [
          "Tokens"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "action",
                  "payload"
                ],
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "api:decrypt"
                    ],
                    "description": "The action the token grants"
                  },
                  "payload": {
                    "description": "The encrypted data the token will be authorized to decrypt"
                  },
                  "expiry": {
                    "type": "integer",
                    "description": "Token expiry in minutes (default: 5, max: 10)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Client token created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientToken"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use your Evervault App UUID as username and API key as password for Basic auth"
      }
    },
    "schemas": {
      "FunctionRunResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Run ID"
          },
          "result": {
            "description": "The function's return value"
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failure"
            ]
          }
        }
      },
      "FunctionRunQueued": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Run ID"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued"
            ]
          }
        }
      },
      "ClientToken": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "The client-side token"
          },
          "expiry": {
            "type": "integer",
            "description": "Unix timestamp when the token expires"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "code": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    }
  }
}
