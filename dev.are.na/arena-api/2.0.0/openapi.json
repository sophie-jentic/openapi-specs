    "/channels/{slug}/blocks": {
      "post": {
        "operationId": "createBlock",
        "summary": "Create a block in a channel",
        "description": "Creates a new block and adds it to the specified channel. Either source or content is required, not both.",
        "tags": [
          "Blocks"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
