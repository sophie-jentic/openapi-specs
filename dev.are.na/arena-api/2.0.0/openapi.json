            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "description": "URL of content. Can be an Image, Embed, or Link."
                  },
                  "content": {
                    "type": "string",
                    "description": "Textual content rendered with Github Flavored Markdown."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Block created",
            "content": {
