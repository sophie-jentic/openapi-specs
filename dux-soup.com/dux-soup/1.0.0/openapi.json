{
  "openapi": "3.0.3",
  "info": {
    "title": "Dux-Soup LinkedIn Activity API",
    "version": "1.0.0",
    "description": "The Dux-Soup LinkedIn Activity API allows you to trigger automated LinkedIn actions from outside the browser. Queue LinkedIn commands like visit, connect, message, enroll, tag, and more. Available for Turbo and Cloud users.",
    "x-jentic-source-url": "https://support.dux-soup.com/article/115-remote-control-by-example",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://app.dux-soup.com/xapi",
      "description": "Dux-Soup API"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "paths": {
    "/remote/control/{userId}/queue": {
      "post": {
        "operationId": "queueLinkedInCommand",
        "tags": [
          "LinkedIn Activity"
        ],
        "summary": "Queue a LinkedIn activity command",
        "description": "Queue a LinkedIn activity command for remote execution. Commands are queued and executed when the Dux-Soup extension picks them up (up to 365 days). Supported commands: visit, enroll, connect, message, inmail, tag, untag, savetopdf, follow, disconnect, endorse, saveaslead, likepost.",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your Dux-Soup user ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LinkedInCommandRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Command queued successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandQueueResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Dux-Soup API key"
      }
    },
    "schemas": {
      "LinkedInCommandRequest": {
        "type": "object",
        "required": [
          "command",
          "params"
        ],
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "visit",
              "enroll",
              "connect",
              "message",
              "inmail",
              "tag",
              "untag",
              "savetopdf",
              "follow",
              "disconnect",
              "endorse",
              "saveaslead",
              "likepost"
            ],
            "description": "The LinkedIn activity command to queue"
          },
          "params": {
            "$ref": "#/components/schemas/CommandParams"
          },
          "runafter": {
            "type": "string",
            "format": "date-time",
            "description": "Schedule the command to run after a set time (ISO date-string, optional)"
          }
        }
      },
      "CommandParams": {
        "type": "object",
        "properties": {
          "profile": {
            "type": "string",
            "description": "Target LinkedIn profile URL (mandatory for most commands)"
          },
          "campaignid": {
            "type": "string",
            "description": "Campaign ID to assign to this command (optional)"
          },
          "force": {
            "type": "boolean",
            "description": "Force the action, ignoring all exclusion rules (optional)"
          },
          "messagetext": {
            "type": "string",
            "description": "Message text for connect/message/inmail commands. Can contain placeholders like _FN_"
          },
          "messagesubject": {
            "type": "string",
            "description": "Subject for InMail messages"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of tags to add or remove (for tag/untag commands)"
          },
          "count": {
            "type": "integer",
            "description": "Number of skills to endorse (for endorse command, e.g. 3 for top 3 or -1 for bottom 1)"
          }
        }
      },
      "CommandQueueResponse": {
        "type": "object",
        "properties": {
          "messageid": {
            "type": "string",
            "description": "The ID of the queued message. Repeated identical calls return the existing message ID."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "LinkedIn Activity"
    }
  ]
}
