{
  "openapi": "3.0.3",
  "info": {
    "title": "E-goi API",
    "version": "3.0.0",
    "description": "E-goi provides marketing automation APIs for email marketing, SMS, push notifications, and voice campaigns. The API allows you to send campaigns, manage contacts, access reports data, and perform a variety of marketing automation tasks.",
    "x-jentic-source-url": "http://api-docs.e-goi.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.egoiapp.com",
      "description": "E-goi API server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/lists": {
      "get": {
        "summary": "Get All Lists",
        "description": "Retrieve all contact lists in your account.",
        "operationId": "getLists",
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset for pagination"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 1000
            },
            "description": "Number of results to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of contact lists",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "list_id": {
                            "type": "integer"
                          },
                          "internal_name": {
                            "type": "string"
                          },
                          "public_name": {
                            "type": "string"
                          },
                          "created": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      }
                    },
                    "total_items": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "lists"
        ]
      },
      "post": {
        "summary": "Create List",
        "description": "Create a new contact list.",
        "operationId": "createList",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "internal_name"
                ],
                "properties": {
                  "internal_name": {
                    "type": "string",
                    "description": "Internal name for the list"
                  },
                  "public_name": {
                    "type": "string",
                    "description": "Public name for the list"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "List created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "list_id": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "lists"
        ]
      }
    },
    "/lists/{list_id}": {
      "get": {
        "summary": "Get List",
        "description": "Retrieve a specific contact list.",
        "operationId": "getList",
        "parameters": [
          {
            "name": "list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List details"
          },
          "404": {
            "description": "List not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "lists"
        ]
      },
      "patch": {
        "summary": "Update List",
        "description": "Update an existing contact list.",
        "operationId": "updateList",
        "parameters": [
          {
            "name": "list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "internal_name": {
                    "type": "string"
                  },
                  "public_name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List updated successfully"
          },
          "404": {
            "description": "List not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "lists"
        ]
      },
      "delete": {
        "summary": "Delete List",
        "description": "Delete a contact list.",
        "operationId": "deleteList",
        "parameters": [
          {
            "name": "list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "List deleted successfully"
          },
          "404": {
            "description": "List not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "lists"
        ]
      }
    },
    "/lists/{list_id}/contacts": {
      "get": {
        "summary": "Get Contacts",
        "description": "Retrieve contacts from a specific list.",
        "operationId": "getContacts",
        "parameters": [
          {
            "name": "list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "contact_id": {
                            "type": "string"
                          },
                          "email": {
                            "type": "string",
                            "format": "email"
                          },
                          "status": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "lists"
        ]
      },
      "post": {
        "summary": "Add Contact",
        "description": "Add a new contact to a list.",
        "operationId": "addContact",
        "parameters": [
          {
            "name": "list_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "mobile_phone": {
                    "type": "string"
                  },
                  "extra_fields": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Contact added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "contact_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "lists"
        ]
      }
    },
    "/campaigns/email": {
      "post": {
        "summary": "Send Email Campaign",
        "description": "Create and send an email campaign.",
        "operationId": "sendEmailCampaign",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "list_id",
                  "subject",
                  "content"
                ],
                "properties": {
                  "list_id": {
                    "type": "integer"
                  },
                  "subject": {
                    "type": "string"
                  },
                  "content": {
                    "type": "string",
                    "description": "HTML email content"
                  },
                  "from_name": {
                    "type": "string"
                  },
                  "from_email": {
                    "type": "string",
                    "format": "email"
                  },
                  "schedule_date": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Optional schedule date, leave empty to send immediately"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Campaign created and sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "campaign_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "campaigns"
        ]
      }
    },
    "/reports/campaigns/{campaign_id}": {
      "get": {
        "summary": "Get Campaign Report",
        "description": "Retrieve campaign statistics and performance data.",
        "operationId": "getCampaignReport",
        "parameters": [
          {
            "name": "campaign_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign report data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "campaign_id": {
                      "type": "string"
                    },
                    "sent": {
                      "type": "integer"
                    },
                    "opens": {
                      "type": "integer"
                    },
                    "clicks": {
                      "type": "integer"
                    },
                    "bounces": {
                      "type": "integer"
                    },
                    "unsubscribes": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Campaign not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "reports"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Apikey",
        "description": "API key for authentication. Obtain from your E-goi account settings."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "campaigns"
    },
    {
      "name": "lists"
    },
    {
      "name": "reports"
    }
  ]
}
