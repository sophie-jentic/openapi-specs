    "/main/api/v2/hashpower/order/{orderId}/updatePriceAndLimit/": {
      "post": {
        "operationId": "updateHashpowerOrderPriceAndLimit",
        "summary": "Update hashpower order price and limit",
        "description": "Updates the price and speed limit of an existing hashpower order.",
        "tags": ["Hashpower"],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "description": "The ID of the hashpower order to update.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["price", "limit"],
                "properties": {
                  "price": {
                    "type": "number",
                    "format": "double",
                    "description": "New price per unit of hashing speed."
                  },
                  "limit": {
                    "type": "number",
                    "format": "double",
                    "description": "New speed limit."
                  },
                  "marketFactor": {
                    "type": "number",
                    "format": "double",
                    "description": "Market factor for price calculation."
                  },
                  "displayMarketFactor": {
                    "type": "string",
                    "description": "Display market factor unit."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order updated successfully"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/main/api/v2/pool/": {
      "post": {
        "operationId": "createPool",
        "summary": "Create a mining pool",
        "description": "Creates a new mining pool configuration for directing hashpower.",
        "tags": ["Pools"],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "algorithm", "stratumHostname", "stratumPort", "username", "password"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Display name for the pool."
                  },
                  "algorithm": {
                    "type": "string",
                    "description": "Mining algorithm."
                  },
                  "stratumHostname": {
                    "type": "string",
                    "description": "Stratum server hostname."
                  },
