    "/main/api/v2/hashpower/myOrders": {
      "get": {
        "operationId": "getMyHashpowerOrders",
        "summary": "Get my hashpower orders",
        "description": "Returns a list of your hashpower orders, optionally filtered by algorithm and market.",
        "tags": ["Hashpower"],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "algorithm",
            "in": "query",
            "required": false,
            "description": "Algorithm name (e.g., SHA256, SCRYPT, X11).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "market",
            "in": "query",
            "required": false,
            "description": "Market location (e.g., EU, USA).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ts",
            "in": "query",
            "required": false,
            "description": "Timestamp for pagination.",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of results to return.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "op",
            "in": "query",
            "required": false,
            "description": "Comparison operator for timestamp-based pagination (GT or LT).",
            "schema": {
              "type": "string",
              "enum": ["GT", "LT"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "list": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/HashpowerOrder"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
