    "/main/api/v2/hashpower/order/": {
      "post": {
        "operationId": "createHashpowerOrder",
        "summary": "Create a hashpower order",
        "description": "Creates a new hashpower order to buy mining power on the marketplace.",
        "tags": ["Hashpower"],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["market", "algorithm", "amount", "price", "limit", "poolId", "type"],
                "properties": {
                  "market": {
                    "type": "string",
                    "description": "Market location (e.g., EU, USA)."
                  },
                  "algorithm": {
                    "type": "string",
                    "description": "Mining algorithm name."
                  },
                  "amount": {
                    "type": "number",
                    "format": "double",
                    "description": "Order amount in BTC."
                  },
                  "price": {
                    "type": "number",
                    "format": "double",
                    "description": "Price per unit of hashing speed."
                  },
                  "limit": {
                    "type": "number",
                    "format": "double",
                    "description": "Speed limit."
                  },
                  "poolId": {
                    "type": "string",
                    "description": "ID of the mining pool to direct hashpower to."
                  },
                  "type": {
                    "type": "string",
                    "description": "Order type (STANDARD or FIXED).",
                    "enum": ["STANDARD", "FIXED"]
                  },
                  "marketFactor": {
                    "type": "number",
                    "format": "double",
                    "description": "Market factor for price calculation."
                  },
                  "displayMarketFactor": {
                    "type": "string",
                    "description": "Display market factor unit."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hashpower order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HashpowerOrder"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/main/api/v2/hashpower/order/{orderId}": {
      "delete": {
        "operationId": "cancelHashpowerOrder",
        "summary": "Cancel a hashpower order",
        "description": "Cancels an existing hashpower order.",
        "tags": ["Hashpower"],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "description": "The ID of the hashpower order to cancel.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order cancelled successfully"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
