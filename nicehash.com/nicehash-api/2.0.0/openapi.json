                "properties": {
                  "withdrawalAddressId": {
                    "type": "string",
                    "description": "ID of the pre-configured withdrawal address."
                  },
                  "amount": {
                    "type": "number",
                    "format": "double",
                    "description": "Amount to withdraw."
                  },
                  "currency": {
                    "type": "string",
                    "description": "Currency code (e.g., BTC)."
