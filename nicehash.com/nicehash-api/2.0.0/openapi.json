{
  "openapi": "3.0.3",
  "info": {
    "title": "NiceHash API",
    "description": "NiceHash is a crypto mining marketplace that connects sellers of hashing power (miners) with buyers. This API provides access to public market data, hashpower marketplace management, mining pool configuration, exchange trading, and account/wallet operations.",
    "version": "2.0.0",
    "contact": {
      "name": "NiceHash",
      "url": "https://www.nicehash.com"
    },
    "x-logo": {
      "url": "https://www.nicehash.com/static/media/logo.svg"
    }
  },
  "servers": [
    {
      "url": "https://api2.nicehash.com",
      "description": "Production"
    },
    {
      "url": "https://api-test.nicehash.com",
      "description": "Test / Sandbox (testnet)"
    }
  ],
  "security": [],
  "paths": {
    "/main/api/v2/public/stats/global/current/": {
      "get": {
        "operationId": "getGlobalStatsCurrent",
        "summary": "Get current global stats",
        "description": "Returns current global profitability and hashrate statistics for all algorithms.",
        "tags": ["Public"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "algorithms": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AlgorithmStats"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
