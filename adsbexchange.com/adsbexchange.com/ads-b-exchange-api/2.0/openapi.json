{
  "openapi": "3.0.3",
  "info": {
    "title": "ADS-B Exchange API",
    "description": "ADS-B Exchange provides real-time aircraft tracking data from a global network of ADS-B receivers. Access aircraft positions, flight data, military aircraft tracking, and historical flight information. The world's largest source of unfiltered flight data.",
    "version": "2.0",
    "contact": {
      "name": "ADS-B Exchange",
      "url": "https://www.adsbexchange.com/"
    },
    "license": {
      "name": "ADS-B Exchange Terms",
      "url": "https://www.adsbexchange.com/legal-and-privacy/"
    }
  },
  "externalDocs": {
    "description": "ADS-B Exchange Data",
    "url": "https://www.adsbexchange.com/data/"
  },
  "servers": [
    {
      "url": "https://adsbexchange.com/api",
      "description": "ADS-B Exchange Direct API"
    },
    {
      "url": "https://adsbexchange-com1.p.rapidapi.com",
      "description": "ADS-B Exchange via RapidAPI"
    }
  ],
  "security": [
    {
      "rapidApiKey": []
    },
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/aircraft/json/lat/{lat}/lon/{lon}/dist/{dist}/": {
      "get": {
        "operationId": "getAircraftByLocation",
        "summary": "Get aircraft near a location",
        "description": "Returns all aircraft within the specified radius of the given latitude/longitude coordinates.",
        "parameters": [
          {
            "name": "lat",
            "in": "path",
            "required": true,
            "description": "Latitude in decimal degrees",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "lon",
            "in": "path",
            "required": true,
            "description": "Longitude in decimal degrees",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "dist",
            "in": "path",
            "required": true,
            "description": "Radius in nautical miles (max 250)",
            "schema": {
              "type": "number",
              "maximum": 250
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aircraft within range",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "tags": [
          "aircraft"
        ]
      }
    },
    "/aircraft/icao/{icao}/": {
      "get": {
        "operationId": "getAircraftByIcao",
        "summary": "Get aircraft by ICAO hex code",
        "description": "Returns current position and data for a specific aircraft by ICAO 24-bit address.",
        "parameters": [
          {
            "name": "icao",
            "in": "path",
            "required": true,
            "description": "ICAO 24-bit hex code (e.g. A12345)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aircraft data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponse"
                }
              }
            }
          },
          "404": {
            "description": "Aircraft not found"
          }
        },
        "tags": [
          "aircraft"
        ]
      }
    },
    "/aircraft/callsign/{callsign}/": {
      "get": {
        "operationId": "getAircraftByCallsign",
        "summary": "Get aircraft by callsign",
        "description": "Returns data for aircraft matching a specific callsign.",
        "parameters": [
          {
            "name": "callsign",
            "in": "path",
            "required": true,
            "description": "Flight callsign (e.g. UAL123)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aircraft data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponse"
                }
              }
            }
          },
          "404": {
            "description": "Aircraft not found"
          }
        },
        "tags": [
          "aircraft"
        ]
      }
    },
    "/aircraft/registration/{reg}/": {
      "get": {
        "operationId": "getAircraftByRegistration",
        "summary": "Get aircraft by registration",
        "description": "Returns data for an aircraft by its registration number (tail number).",
        "parameters": [
          {
            "name": "reg",
            "in": "path",
            "required": true,
            "description": "Aircraft registration/tail number (e.g. N12345)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aircraft data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponse"
                }
              }
            }
          },
          "404": {
            "description": "Aircraft not found"
          }
        },
        "tags": [
          "aircraft"
        ]
      }
    },
    "/aircraft/type/{type}/": {
      "get": {
        "operationId": "getAircraftByType",
        "summary": "Get aircraft by type designator",
        "description": "Returns all currently tracked aircraft of a specific ICAO type designator.",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "description": "ICAO aircraft type designator (e.g. B738, A320)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aircraft data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponse"
                }
              }
            }
          }
        },
        "tags": [
          "aircraft"
        ]
      }
    },
    "/aircraft/mil/": {
      "get": {
        "operationId": "getMilitaryAircraft",
        "summary": "Get all military aircraft",
        "description": "Returns all currently tracked military aircraft worldwide.",
        "responses": {
          "200": {
            "description": "Military aircraft",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponse"
                }
              }
            }
          }
        },
        "tags": [
          "aircraft"
        ]
      }
    },
    "/aircraft/ladd/": {
      "get": {
        "operationId": "getLaddAircraft",
        "summary": "Get LADD-filtered aircraft",
        "description": "Returns aircraft subject to FAA Limiting Aircraft Data Displayed program.",
        "responses": {
          "200": {
            "description": "LADD aircraft",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponse"
                }
              }
            }
          }
        },
        "tags": [
          "aircraft"
        ]
      }
    },
    "/aircraft/pia/": {
      "get": {
        "operationId": "getPiaAircraft",
        "summary": "Get PIA aircraft",
        "description": "Returns aircraft using FAA Privacy ICAO Address program.",
        "responses": {
          "200": {
            "description": "PIA aircraft",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponse"
                }
              }
            }
          }
        },
        "tags": [
          "aircraft"
        ]
      }
    },
    "/aircraft/sqk/{squawk}/": {
      "get": {
        "operationId": "getAircraftBySquawk",
        "summary": "Get aircraft by squawk code",
        "description": "Returns aircraft broadcasting a specific squawk/transponder code.",
        "parameters": [
          {
            "name": "squawk",
            "in": "path",
            "required": true,
            "description": "Squawk code (e.g. 7700, 7600, 7500)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aircraft with matching squawk",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponse"
                }
              }
            }
          }
        },
        "tags": [
          "aircraft"
        ]
      }
    },
    "/v2/lat/{lat}/lon/{lon}/dist/{dist}/": {
      "get": {
        "operationId": "getAircraftByLocationV2",
        "summary": "Get aircraft near a location (v2)",
        "description": "V2 endpoint returning aircraft within the specified distance.",
        "parameters": [
          {
            "name": "lat",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "lon",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "dist",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number",
              "maximum": 250
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aircraft data (v2 format)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponseV2"
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ]
      }
    },
    "/v2/icao/{icao}/": {
      "get": {
        "operationId": "getAircraftByIcaoV2",
        "summary": "Get aircraft by ICAO (v2)",
        "parameters": [
          {
            "name": "icao",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aircraft data (v2 format)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponseV2"
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ],
        "description": "Get aircraft by ICAO (v2)"
      }
    },
    "/v2/callsign/{callsign}/": {
      "get": {
        "operationId": "getAircraftByCallsignV2",
        "summary": "Get aircraft by callsign (v2)",
        "parameters": [
          {
            "name": "callsign",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aircraft data (v2 format)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponseV2"
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ],
        "description": "Get aircraft by callsign (v2)"
      }
    },
    "/v2/mil/": {
      "get": {
        "operationId": "getMilitaryAircraftV2",
        "summary": "Get all military aircraft (v2)",
        "responses": {
          "200": {
            "description": "Military aircraft (v2 format)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponseV2"
                }
              }
            }
          }
        },
        "tags": [
          "v2"
        ],
        "description": "Get all military aircraft (v2)"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "rapidApiKey": {
        "type": "apiKey",
        "name": "X-RapidAPI-Key",
        "in": "header",
        "description": "RapidAPI key for ADS-B Exchange"
      },
      "apiKey": {
        "type": "apiKey",
        "name": "api-auth",
        "in": "query",
        "description": "Direct ADS-B Exchange API key"
      }
    },
    "schemas": {
      "AircraftResponse": {
        "type": "object",
        "properties": {
          "ac": {
            "type": "array",
            "description": "Array of aircraft",
            "items": {
              "$ref": "#/components/schemas/Aircraft"
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of aircraft in response"
          },
          "ctime": {
            "type": "integer",
            "description": "Current timestamp"
          },
          "ptime": {
            "type": "integer",
            "description": "Processing time in ms"
          }
        }
      },
      "Aircraft": {
        "type": "object",
        "properties": {
          "icao": {
            "type": "string",
            "description": "ICAO 24-bit hex address"
          },
          "type": {
            "type": "string",
            "description": "Aircraft type (e.g. adsb_icao, mlat, tisb)"
          },
          "flight": {
            "type": "string",
            "description": "Callsign/flight number"
          },
          "r": {
            "type": "string",
            "description": "Registration/tail number"
          },
          "t": {
            "type": "string",
            "description": "ICAO aircraft type designator"
          },
          "dbFlags": {
            "type": "integer",
            "description": "Database flags (1=military, 2=interesting, 4=PIA, 8=LADD)"
          },
          "alt_baro": {
            "type": "integer",
            "description": "Barometric altitude in feet",
            "nullable": true
          },
          "alt_geom": {
            "type": "integer",
            "description": "Geometric altitude in feet",
            "nullable": true
          },
          "gs": {
            "type": "number",
            "description": "Ground speed in knots",
            "nullable": true
          },
          "ias": {
            "type": "integer",
            "description": "Indicated airspeed in knots",
            "nullable": true
          },
          "tas": {
            "type": "integer",
            "description": "True airspeed in knots",
            "nullable": true
          },
          "mach": {
            "type": "number",
            "description": "Mach number",
            "nullable": true
          },
          "track": {
            "type": "number",
            "description": "Track angle in degrees (0=north)",
            "nullable": true
          },
          "baro_rate": {
            "type": "integer",
            "description": "Barometric rate of change in ft/min",
            "nullable": true
          },
          "geom_rate": {
            "type": "integer",
            "description": "Geometric rate of change in ft/min",
            "nullable": true
          },
          "squawk": {
            "type": "string",
            "description": "Transponder squawk code",
            "nullable": true
          },
          "emergency": {
            "type": "string",
            "description": "Emergency/priority status",
            "nullable": true
          },
          "category": {
            "type": "string",
            "description": "Emitter category",
            "nullable": true
          },
          "nav_qnh": {
            "type": "number",
            "description": "Altimeter setting in hPa",
            "nullable": true
          },
          "nav_altitude_mcp": {
            "type": "integer",
            "description": "Selected altitude from MCP/FCU",
            "nullable": true
          },
          "nav_heading": {
            "type": "number",
            "description": "Selected heading",
            "nullable": true
          },
          "lat": {
            "type": "number",
            "format": "double",
            "description": "Latitude in decimal degrees",
            "nullable": true
          },
          "lon": {
            "type": "number",
            "format": "double",
            "description": "Longitude in decimal degrees",
            "nullable": true
          },
          "nic": {
            "type": "integer",
            "description": "Navigation Integrity Category"
          },
          "rc": {
            "type": "integer",
            "description": "Radius of containment in meters"
          },
          "seen_pos": {
            "type": "number",
            "description": "Seconds since last position update",
            "nullable": true
          },
          "seen": {
            "type": "number",
            "description": "Seconds since last message"
          },
          "rssi": {
            "type": "number",
            "description": "Signal strength in dBFS"
          },
          "alert": {
            "type": "integer",
            "description": "Alert flag"
          },
          "spi": {
            "type": "integer",
            "description": "Special Position Identification flag"
          },
          "messages": {
            "type": "integer",
            "description": "Total messages received"
          },
          "dst": {
            "type": "number",
            "description": "Distance from reference point in nautical miles",
            "nullable": true
          }
        }
      },
      "AircraftResponseV2": {
        "type": "object",
        "properties": {
          "ac": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AircraftV2"
            }
          },
          "msg": {
            "type": "string"
          },
          "now": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          },
          "ctime": {
            "type": "integer"
          },
          "ptime": {
            "type": "integer"
          }
        }
      },
      "AircraftV2": {
        "type": "object",
        "description": "V2 aircraft format with condensed field names",
        "properties": {
          "hex": {
            "type": "string",
            "description": "ICAO hex code"
          },
          "type": {
            "type": "string"
          },
          "flight": {
            "type": "string"
          },
          "r": {
            "type": "string",
            "description": "Registration"
          },
          "t": {
            "type": "string",
            "description": "Aircraft type"
          },
          "alt_baro": {
            "type": "integer",
            "nullable": true
          },
          "alt_geom": {
            "type": "integer",
            "nullable": true
          },
          "gs": {
            "type": "number",
            "nullable": true
          },
          "track": {
            "type": "number",
            "nullable": true
          },
          "baro_rate": {
            "type": "integer",
            "nullable": true
          },
          "squawk": {
            "type": "string",
            "nullable": true
          },
          "emergency": {
            "type": "string",
            "nullable": true
          },
          "lat": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "lon": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "seen": {
            "type": "number"
          },
          "rssi": {
            "type": "number"
          },
          "dst": {
            "type": "number",
            "nullable": true
          },
          "dbFlags": {
            "type": "integer"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "aircraft"
    },
    {
      "name": "v2"
    }
  ]
}
