    "/jurisdictions": {
      "get": {
        "operationId": "listJurisdictions",
        "summary": "List tax jurisdictions",
        "tags": [
          "Jurisdictions"
        ],
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
