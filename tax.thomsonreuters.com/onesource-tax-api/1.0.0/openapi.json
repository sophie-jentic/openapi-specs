  "components": {
    "schemas": {
      "TaxRequest": {
        "type": "object",
        "properties": {
          "companyId": {
            "type": "string"
          },
          "transactionType": {
            "type": "string",
            "enum": [
              "sale",
              "purchase",
              "return"
            ]
          },
          "transactionDate": {
            "type": "string",
            "format": "date"
          },
          "currency": {
            "type": "string"
          },
          "lines": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "lineNumber": {
                  "type": "integer"
                },
                "productCode": {
                  "type": "string"
                },
                "quantity": {
                  "type": "number"
                },
                "amount": {
                  "type": "number"
                },
                "shipFrom": {
                  "$ref": "#/components/schemas/Address"
                },
                "shipTo": {
                  "$ref": "#/components/schemas/Address"
                }
              }
            }
          }
        }
      },
      "TaxResponse": {
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string"
          },
          "totalTax": {
            "type": "number"
          },
          "totalAmount": {
            "type": "number"
          },
          "lines": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "lineNumber": {
                  "type": "integer"
                },
                "tax": {
                  "type": "number"
                },
                "taxableAmount": {
                  "type": "number"
                },
                "taxDetails": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "jurisdiction": {
                        "type": "string"
                      },
                      "rate": {
                        "type": "number"
                      },
                      "tax": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ExemptionCertificate": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string"
          },
          "jurisdiction": {
            "type": "string"
          },
          "exemptionType": {
            "type": "string"
          },
          "exemptionNumber": {
            "type": "string"
          },
          "effectiveDate": {
            "type": "string",
            "format": "date"
          },
          "expirationDate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "line1": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "postalCode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://auth.tax.thomsonreuters.com/oauth/token",
            "scopes": {
              "tax:read": "Read tax data",
              "tax:write": "Write tax data"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "oauth2": []
    }
  ]
}