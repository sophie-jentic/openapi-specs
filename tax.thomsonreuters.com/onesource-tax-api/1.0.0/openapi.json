{
  "openapi": "3.0.3",
  "info": {
    "title": "Thomson Reuters ONESOURCE Tax API",
    "version": "1.0.0",
    "description": "Thomson Reuters ONESOURCE indirect tax determination API. Provides tax calculation, exemption certificate management, and tax reporting capabilities for enterprise tax compliance.",
    "x-jentic-source-url": "https://tax.thomsonreuters.com/en/onesource/apis"
  },
  "servers": [
    {
      "url": "https://api.tax.thomsonreuters.com/v1"
    }
  ],
  "paths": {
    "/tax/determination": {
      "post": {
        "operationId": "calculateTax",
        "summary": "Calculate tax",
        "description": "Calculate tax for a transaction",
        "tags": [
          "Tax Determination"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaxRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tax calculation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaxResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tax/determination/batch": {
      "post": {
        "operationId": "batchCalculateTax",
        "summary": "Batch tax calculation",
        "tags": [
          "Tax Determination"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "transactions": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/TaxRequest"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch results"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tax/determination/reverse": {
      "post": {
        "operationId": "reverseTax",
        "summary": "Reverse tax calculation",
        "tags": [
          "Tax Determination"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
