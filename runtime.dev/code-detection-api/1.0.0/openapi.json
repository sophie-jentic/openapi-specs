{
  "openapi": "3.0.3",
  "info": {
    "title": "Code Detection API",
    "description": "Detect, label, format and enrich code in your app or data pipeline. The Code Detection API can identify whether content is code or text, detect the programming language, and format/enrich code snippets.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://codedetectionapi.runtime.dev",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.runtime.dev/v1",
      "description": "Code Detection API Server"
    }
  ],
  "security": [
    {
      "oauth2": [
        "read",
        "write"
      ]
    }
  ],
  "tags": [
    {
      "name": "Detection",
      "description": "Detect whether content is code and identify the language"
    },
    {
      "name": "Formatting",
      "description": "Format and enrich code snippets"
    },
    {
      "name": "Analysis",
      "description": "Analyze code content"
    }
  ],
  "paths": {
    "/detect": {
      "post": {
        "operationId": "detectCode",
        "summary": "Detect if content is code",
        "description": "Analyze the provided content to determine if it contains code, and if so, identify the programming language.",
        "tags": [
          "Detection"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DetectRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Detection result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetectResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/detect/batch": {
      "post": {
        "operationId": "detectCodeBatch",
        "summary": "Detect code in multiple content items",
        "description": "Analyze multiple content items in a single request to determine if they contain code.",
        "tags": [
          "Detection"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchDetectRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch detection results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchDetectResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/label": {
      "post": {
        "operationId": "labelCode",
        "summary": "Label code with language and metadata",
        "description": "Identify the programming language and add metadata labels to the provided code snippet.",
        "tags": [
          "Detection"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LabelRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Labeled code result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LabelResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/format": {
      "post": {
        "operationId": "formatCode",
        "summary": "Format a code snippet",
        "description": "Format and beautify the provided code snippet according to language-specific conventions.",
        "tags": [
          "Formatting"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FormatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Formatted code",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FormatResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/enrich": {
      "post": {
        "operationId": "enrichCode",
        "summary": "Enrich a code snippet with metadata",
        "description": "Enrich the provided code snippet with syntax highlighting tokens, language detection, and structural metadata.",
        "tags": [
          "Formatting"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EnrichRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Enriched code result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnrichResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/languages": {
      "get": {
        "operationId": "listLanguages",
        "summary": "List supported programming languages",
        "description": "Get a list of all programming languages supported by the Code Detection API.",
        "tags": [
          "Analysis"
        ],
        "responses": {
          "200": {
            "description": "List of supported languages",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LanguagesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://auth.runtime.dev/oauth/token",
            "scopes": {
              "read": "Read access to detection and analysis endpoints",
              "write": "Write access for formatting and enrichment"
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid input or content",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - missing or invalid OAuth token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "DetectRequest": {
        "type": "object",
        "required": [
          "content"
        ],
        "properties": {
          "content": {
            "type": "string",
            "description": "The text or code content to analyze"
          },
          "threshold": {
            "type": "number",
            "format": "float",
            "description": "Confidence threshold for detection (0.0 to 1.0)",
            "minimum": 0,
            "maximum": 1,
            "default": 0.5
          }
        }
      },
      "DetectResponse": {
        "type": "object",
        "properties": {
          "isCode": {
            "type": "boolean",
            "description": "Whether the content is detected as code"
          },
          "confidence": {
            "type": "number",
            "format": "float",
            "description": "Confidence score (0.0 to 1.0)"
          },
          "language": {
            "type": "string",
            "description": "Detected programming language (if isCode is true)"
          },
          "languageConfidence": {
            "type": "number",
            "format": "float",
            "description": "Confidence of language detection"
          }
        }
      },
      "BatchDetectRequest": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DetectRequest"
            },
            "description": "Array of content items to analyze"
          }
        }
      },
      "BatchDetectResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DetectResponse"
            }
          }
        }
      },
      "LabelRequest": {
        "type": "object",
        "required": [
          "content"
        ],
        "properties": {
          "content": {
            "type": "string",
            "description": "Code content to label"
          }
        }
      },
      "LabelResponse": {
        "type": "object",
        "properties": {
          "language": {
            "type": "string",
            "description": "Detected programming language"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Metadata labels (e.g., 'function', 'class', 'script', 'config')"
          },
          "confidence": {
            "type": "number",
            "format": "float"
          },
          "framework": {
            "type": "string",
            "description": "Detected framework if applicable"
          }
        }
      },
      "FormatRequest": {
        "type": "object",
        "required": [
          "content"
        ],
        "properties": {
          "content": {
            "type": "string",
            "description": "Code content to format"
          },
          "language": {
            "type": "string",
            "description": "Programming language (auto-detected if not specified)"
          },
          "indentSize": {
            "type": "integer",
            "description": "Number of spaces for indentation",
            "default": 2
          },
          "useTabs": {
            "type": "boolean",
            "description": "Use tabs instead of spaces",
            "default": false
          }
        }
      },
      "FormatResponse": {
        "type": "object",
        "properties": {
          "formatted": {
            "type": "string",
            "description": "Formatted code"
          },
          "language": {
            "type": "string",
            "description": "Language used for formatting"
          }
        }
      },
      "EnrichRequest": {
        "type": "object",
        "required": [
          "content"
        ],
        "properties": {
          "content": {
            "type": "string",
            "description": "Code content to enrich"
          },
          "language": {
            "type": "string",
            "description": "Programming language (auto-detected if not specified)"
          },
          "includeTokens": {
            "type": "boolean",
            "description": "Include syntax highlighting tokens",
            "default": true
          }
        }
      },
      "EnrichResponse": {
        "type": "object",
        "properties": {
          "language": {
            "type": "string"
          },
          "formatted": {
            "type": "string",
            "description": "Formatted code"
          },
          "tokens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SyntaxToken"
            },
            "description": "Syntax tokens for highlighting"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "lineCount": {
                "type": "integer"
              },
              "complexity": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              "imports": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "functions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "classes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "SyntaxToken": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Token type (keyword, string, comment, etc.)"
          },
          "value": {
            "type": "string"
          },
          "line": {
            "type": "integer"
          },
          "column": {
            "type": "integer"
          }
        }
      },
      "LanguagesResponse": {
        "type": "object",
        "properties": {
          "languages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Language"
            }
          }
        }
      },
      "Language": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Language name"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Alternative names"
          },
          "extensions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Common file extensions"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error type"
          },
          "message": {
            "type": "string",
            "description": "Detailed error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  }
}
