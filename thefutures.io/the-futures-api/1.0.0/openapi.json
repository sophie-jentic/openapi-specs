{
  "openapi": "3.0.3",
  "info": {
    "title": "The Futures API",
    "version": "1.0.0",
    "description": "The Futures API provides endpoints for authentication, managing tickets (creative design requests), retrieving available features/wizards, and accessing ticket files.",
    "x-jentic-source-url": "https://app.swaggerhub.com/apis-docs/tech53/TheFuturesAPI/1.0.0",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://gwy.thefutures.io/public/webhooks"
    }
  ],
  "paths": {
    "/auth-webhook": {
      "post": {
        "operationId": "authWebhook",
        "summary": "Validate token credentials",
        "description": "Authenticate using a token in the authorization header.",
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Authorization Token"
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/features": {
      "get": {
        "operationId": "getFeatures",
        "summary": "Get available wizards",
        "description": "Retrieve the list of available wizards/features.",
        "tags": [
          "Features"
        ],
        "responses": {
          "200": {
            "description": "List of wizards",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Feature"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tickets": {
      "get": {
        "operationId": "getTickets",
        "summary": "Get tickets",
        "description": "Get tickets of the authenticated client, optionally filtered by status.",
        "tags": [
          "Tickets"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter tickets by status"
          }
        ],
        "responses": {
          "200": {
            "description": "List of tickets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TicketSummary"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createTicket",
        "summary": "Create a ticket",
        "description": "Create a new ticket with data received in the request body.",
        "tags": [
          "Tickets"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TicketCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ticket"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tickets/files": {
      "get": {
        "operationId": "getTicketFiles",
        "summary": "Get ticket files",
        "description": "Get files of tickets, optionally filtered by status.",
        "tags": [
          "Tickets"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter tickets by status"
          }
        ],
        "responses": {
          "200": {
            "description": "List of file URLs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/File"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {}
          }
        }
      },
      "Feature": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "feature_code": {
            "type": "string",
            "example": "BASIC"
          },
          "feature_title": {
            "type": "string",
            "example": "Standard Graphic Design"
          }
        }
      },
      "Ticket": {
        "type": "object",
        "required": [
          "title",
          "description",
          "featureCode",
          "formResponses"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 5065
          },
          "title": {
            "type": "string",
            "example": "Ticket test"
          },
          "description": {
            "type": "string",
            "example": "Description of my request"
          },
          "formResponses": {
            "type": "object"
          }
        }
      },
      "TicketCreateRequest": {
        "type": "object",
        "required": [
          "title",
          "description",
          "featureCode",
          "formResponses"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "featureCode": {
            "type": "string"
          },
          "formResponses": {
            "type": "object"
          }
        }
      },
      "TicketSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "10332-1635185191"
          },
          "ticketId": {
            "type": "integer",
            "example": 10332
          },
          "title": {
            "type": "string",
            "example": "testing"
          },
          "status": {
            "type": "string",
            "example": "under-way"
          },
          "wizard": {
            "type": "string",
            "example": "BOOKCOVERS"
          }
        }
      },
      "File": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 45346490
          },
          "ticketId": {
            "type": "integer",
            "example": 5065
          },
          "filename": {
            "type": "string",
            "example": "Learning techniques RF.pptx"
          },
          "revision": {
            "type": "integer",
            "example": 3
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Presigned AWS S3 URL for file access"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Features"
    },
    {
      "name": "Tickets"
    }
  ]
}
