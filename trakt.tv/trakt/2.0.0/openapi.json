{
  "openapi": "3.0.3",
  "info": {
    "title": "Trakt API",
    "version": "2.0.0",
    "description": "Trakt API for movie and TV show data, user watchlists, history, ratings, and recommendations.",
    "x-jentic-source-url": "https://trakt.docs.apiary.io/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.trakt.tv"
    }
  ],
  "paths": {
    "/search/{type}": {
      "get": {
        "operationId": "search",
        "summary": "Search",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "movie",
                "show",
                "episode",
                "person",
                "list"
              ]
            }
          },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SearchResult"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Search"
      }
    },
    "/movies/trending": {
      "get": {
        "operationId": "getTrendingMovies",
        "summary": "Trending movies",
        "tags": [
          "Movies"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trending",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TrendingMovie"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Trending movies"
      }
    },
    "/movies/popular": {
      "get": {
        "operationId": "getPopularMovies",
        "summary": "Popular movies",
        "tags": [
          "Movies"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Popular",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Movie"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Popular movies"
      }
    },
    "/movies/{id}": {
      "get": {
        "operationId": "getMovie",
        "summary": "Get movie",
        "tags": [
          "Movies"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Movie",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movie"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get movie"
      }
    },
    "/shows/trending": {
      "get": {
        "operationId": "getTrendingShows",
        "summary": "Trending shows",
        "tags": [
          "Shows"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trending",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TrendingShow"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Trending shows"
      }
    },
    "/shows/{id}": {
      "get": {
        "operationId": "getShow",
        "summary": "Get show",
        "tags": [
          "Shows"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Show",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Show"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get show"
      }
    },
    "/shows/{id}/seasons": {
      "get": {
        "operationId": "getSeasons",
        "summary": "Get seasons",
        "tags": [
          "Shows"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Seasons",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Season"
                  }
                }
              }
            }
          }
        },
        "description": "Get seasons"
      }
    },
    "/users/me/watchlist/movies": {
      "get": {
        "operationId": "getMovieWatchlist",
        "summary": "Get movie watchlist",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Watchlist",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "listed_at": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "movie": {
                        "$ref": "#/components/schemas/Movie"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get movie watchlist"
      }
    },
    "/users/me/history": {
      "get": {
        "operationId": "getHistory",
        "summary": "Get watch history",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "movies",
                "shows",
                "episodes"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "History"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get watch history"
      }
    },
    "/users/me/ratings": {
      "get": {
        "operationId": "getRatings",
        "summary": "Get user ratings",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "movies",
                "shows",
                "episodes"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ratings"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get user ratings"
      }
    },
    "/recommendations/movies": {
      "get": {
        "operationId": "getMovieRecommendations",
        "summary": "Movie recommendations",
        "tags": [
          "Recommendations"
        ],
        "responses": {
          "200": {
            "description": "Recommendations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Movie"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Movie recommendations"
      }
    }
  },
  "components": {
    "schemas": {
      "Movie": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          },
          "ids": {
            "$ref": "#/components/schemas/Ids"
          },
          "overview": {
            "type": "string"
          },
          "runtime": {
            "type": "integer"
          },
          "rating": {
            "type": "number"
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Show": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          },
          "ids": {
            "$ref": "#/components/schemas/Ids"
          },
          "overview": {
            "type": "string"
          },
          "runtime": {
            "type": "integer"
          },
          "rating": {
            "type": "number"
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Season": {
        "type": "object",
        "properties": {
          "number": {
            "type": "integer"
          },
          "ids": {
            "$ref": "#/components/schemas/Ids"
          },
          "episode_count": {
            "type": "integer"
          }
        }
      },
      "TrendingMovie": {
        "type": "object",
        "properties": {
          "watchers": {
            "type": "integer"
          },
          "movie": {
            "$ref": "#/components/schemas/Movie"
          }
        }
      },
      "TrendingShow": {
        "type": "object",
        "properties": {
          "watchers": {
            "type": "integer"
          },
          "show": {
            "$ref": "#/components/schemas/Show"
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "movie": {
            "$ref": "#/components/schemas/Movie"
          },
          "show": {
            "$ref": "#/components/schemas/Show"
          }
        }
      },
      "Ids": {
        "type": "object",
        "properties": {
          "trakt": {
            "type": "integer"
          },
          "slug": {
            "type": "string"
          },
          "imdb": {
            "type": "string"
          },
          "tmdb": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Search"
    },
    {
      "name": "Movies"
    },
    {
      "name": "Shows"
    },
    {
      "name": "Users"
    },
    {
      "name": "Recommendations"
    }
  ]
}
