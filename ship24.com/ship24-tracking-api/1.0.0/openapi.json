  "components": {
    "schemas": {
      "Tracker": {
        "type": "object",
        "properties": {
          "trackerId": {
            "type": "string"
          },
          "trackingNumber": {
            "type": "string"
          },
          "shipmentReference": {
            "type": "string",
            "nullable": true
          },
          "courierCode": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "clientTrackerId": {
            "type": "string",
            "nullable": true
          },
          "isSubscribed": {
            "type": "boolean"
          },
          "isTracked": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateTrackerInput": {
        "type": "object",
        "required": [
          "trackingNumber"
        ],
        "properties": {
          "trackingNumber": {
            "type": "string"
          },
          "shipmentReference": {
            "type": "string"
          },
          "courierCode": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 3
          },
          "clientTrackerId": {
            "type": "string"
          },
          "destinationPostCode": {
            "type": "string"
          },
          "shippingDate": {
            "type": "string",
            "format": "date"
          },
          "originCountryCode": {
            "type": "string"
          },
          "destinationCountryCode": {
            "type": "string"
          }
        }
      },
      "UpdateTrackerInput": {
        "type": "object",
        "properties": {
          "shipmentReference": {
            "type": "string"
          },
          "courierCode": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "TrackingResult": {
        "type": "object",
        "properties": {
          "trackings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tracking"
            }
          }
        }
      },
      "Tracking": {
        "type": "object",
        "properties": {
          "tracker": {
            "$ref": "#/components/schemas/Tracker"
          },
          "shipment": {
            "$ref": "#/components/schemas/Shipment"
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TrackingEvent"
            }
          }
        }
      },
      "Shipment": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "string"
          },
          "statusCategory": {
            "type": "string"
          },
          "statusMilestone": {
            "type": "string"
          },
          "originCountryCode": {
            "type": "string"
          },
          "destinationCountryCode": {
            "type": "string"
          }
        }
      },
      "TrackingEvent": {
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string"
          },
          "trackingNumber": {
            "type": "string"
          },
          "datetime": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string"
          },
          "statusCode": {
            "type": "string"
          },
          "statusCategory": {
            "type": "string"
          },
          "statusMilestone": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "courierCode": {
            "type": "string"
          }
        }
      },
      "Courier": {
        "type": "object",
        "properties": {
          "courierCode": {
            "type": "string"
          },
          "courierName": {
            "type": "string"
          }
        }
      },
      "BulkCreateResponse": {
        "type": "object",
        "properties": {
          "trackers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tracker"
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
