{
  "openapi": "3.0.3",
  "info": {
    "title": "Octopus Energy API",
    "version": "1.0.0",
    "description": "Octopus Energy provides REST and GraphQL APIs for managing energy accounts, tariffs, and consumption data in the UK energy market.",
    "x-jentic-source-url": "https://developer.octopus.energy/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.octopus.energy"
    }
  ],
  "paths": {
    "/v1/graphql": {
      "post": {
        "operationId": "graphqlQuery",
        "summary": "Execute GraphQL query",
        "tags": [
          "GraphQL"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "query"
                ],
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "variables": {
                    "type": "object"
                  },
                  "operationName": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Execute GraphQL query"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "GraphQL"
    }
  ],
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  }
}
