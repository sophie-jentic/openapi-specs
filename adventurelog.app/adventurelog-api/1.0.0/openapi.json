{
  "openapi": "3.0.3",
  "info": {
    "title": "AdventureLog API",
    "version": "1.0.0",
    "description": "AdventureLog is a self-hosted travel tracker. The API allows managing adventures, collections, trips, transportation, notes, checklists, and locations.",
    "x-jentic-source-url": "https://adventurelog.app/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/api"
    }
  ],
  "paths": {
    "/adventures/": {
      "get": {
        "operationId": "listAdventures",
        "summary": "List adventures",
        "tags": [
          "Adventures"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "collection",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by collection ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Adventure list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "integer"
                    },
                    "next": {
                      "type": "string",
                      "nullable": true
                    },
                    "previous": {
                      "type": "string",
                      "nullable": true
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Adventure"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List adventures"
      },
      "post": {
        "operationId": "createAdventure",
        "summary": "Create an adventure",
        "tags": [
          "Adventures"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdventureInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Adventure created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create an adventure"
      }
    },
    "/adventures/{id}/": {
      "get": {
        "operationId": "getAdventure",
        "summary": "Get an adventure",
        "tags": [
          "Adventures"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Adventure details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Adventure"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get an adventure"
      },
      "put": {
        "operationId": "updateAdventure",
        "summary": "Update an adventure",
        "tags": [
          "Adventures"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdventureInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update an adventure"
      },
      "delete": {
        "operationId": "deleteAdventure",
        "summary": "Delete an adventure",
        "tags": [
          "Adventures"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete an adventure"
      }
    },
    "/collections/": {
      "get": {
        "operationId": "listCollections",
        "summary": "List collections",
        "tags": [
          "Collections"
        ],
        "responses": {
          "200": {
            "description": "Collection list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List collections"
      },
      "post": {
        "operationId": "createCollection",
        "summary": "Create a collection",
        "tags": [
          "Collections"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CollectionInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a collection"
      }
    },
    "/collections/{id}/": {
      "get": {
        "operationId": "getCollection",
        "summary": "Get a collection",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection details"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get a collection"
      },
      "put": {
        "operationId": "updateCollection",
        "summary": "Update a collection",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CollectionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        },
        "description": "Update a collection"
      },
      "delete": {
        "operationId": "deleteCollection",
        "summary": "Delete a collection",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          }
        },
        "description": "Delete a collection"
      }
    },
    "/trips/": {
      "get": {
        "operationId": "listTrips",
        "summary": "List trips",
        "tags": [
          "Trips"
        ],
        "responses": {
          "200": {
            "description": "Trip list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List trips"
      },
      "post": {
        "operationId": "createTrip",
        "summary": "Create a trip",
        "tags": [
          "Trips"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TripInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a trip"
      }
    },
    "/trips/{id}/": {
      "get": {
        "operationId": "getTrip",
        "summary": "Get a trip",
        "tags": [
          "Trips"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trip details"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get a trip"
      }
    },
    "/notes/": {
      "get": {
        "operationId": "listNotes",
        "summary": "List notes",
        "tags": [
          "Notes"
        ],
        "responses": {
          "200": {
            "description": "Note list"
          }
        },
        "description": "List notes"
      },
      "post": {
        "operationId": "createNote",
        "summary": "Create a note",
        "tags": [
          "Notes"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NoteInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        },
        "description": "Create a note"
      }
    },
    "/checklists/": {
      "get": {
        "operationId": "listChecklists",
        "summary": "List checklists",
        "tags": [
          "Checklists"
        ],
        "responses": {
          "200": {
            "description": "Checklist list"
          }
        },
        "description": "List checklists"
      },
      "post": {
        "operationId": "createChecklist",
        "summary": "Create a checklist",
        "tags": [
          "Checklists"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChecklistInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        },
