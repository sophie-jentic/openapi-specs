    "/transportations/": {
      "get": {
        "operationId": "listTransportations",
        "summary": "List transportations",
        "tags": [
          "Transportations"
        ],
        "responses": {
          "200": {
            "description": "Transportation list"
          }
        },
        "description": "List transportations"
      },
      "post": {
        "operationId": "createTransportation",
        "summary": "Create a transportation",
        "tags": [
          "Transportations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransportationInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        },
        "description": "Create a transportation"
      }
    },
    "/stats/": {
      "get": {
        "operationId": "getStats",
        "summary": "Get adventure statistics",
        "tags": [
          "Stats"
        ],
        "responses": {
          "200": {
            "description": "Statistics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total_adventures": {
                      "type": "integer"
                    },
                    "total_countries": {
                      "type": "integer"
                    },
                    "total_visited_regions": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get adventure statistics"
      }
    }
  },
  "components": {
    "schemas": {
      "Adventure": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "latitude": {
            "type": "number",
            "nullable": true
          },
          "longitude": {
            "type": "number",
            "nullable": true
          },
          "location": {
            "type": "string"
          },
          "activity_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rating": {
            "type": "number",
            "nullable": true
          },
          "is_public": {
            "type": "boolean"
          },
          "collection": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "images": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AdventureInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "format": "date"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "location": {
            "type": "string"
          },
          "activity_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rating": {
            "type": "number"
          },
          "is_public": {
            "type": "boolean"
          },
          "collection": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "name",
          "type"
        ]
      },
      "CollectionInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "is_public": {
            "type": "boolean"
          }
        },
        "required": [
          "name"
        ]
      },
      "TripInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "format": "date"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "NoteInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "adventure": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "name"
        ]
      },
      "ChecklistInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "is_checked": {
                  "type": "boolean"
                }
              }
            }
          }
        },
        "required": [
          "name"
        ]
      },
      "TransportationInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "car",
              "plane",
              "train",
              "bus",
              "boat",
              "bike",
              "walk",
              "other"
            ]
          },
          "origin": {
            "type": "string"
          },
          "destination": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "name",
          "type"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "CookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "sessionid"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Adventures"
    },
    {
      "name": "Checklists"
    },
    {
      "name": "Collections"
    },
    {
      "name": "Notes"
    },
    {
      "name": "Stats"
    },
    {
      "name": "Transportations"
    },
    {
      "name": "Trips"
    }
  ]
}
