{
  "openapi": "3.0.3",
  "info": {
    "title": "Mendeley API",
    "version": "1.0",
    "description": "Mendeley is a reference manager and academic social network. The API provides access to documents, annotations, catalog search, folders, groups, files, profiles, and datasets.",
    "x-jentic-source-url": "https://dev.mendeley.com/methods/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.mendeley.com"
    }
  ],
  "paths": {
    "/annotations": {
      "get": {
        "operationId": "listAnnotations",
        "summary": "List annotations",
        "description": "Retrieve all your annotations, optionally filtered by group or document.",
        "tags": [
          "Annotations"
        ],
        "parameters": [
          {
            "name": "group_id",
            "in": "query",
            "description": "Filter by group UUID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "document_id",
            "in": "query",
            "description": "Filter by document UUID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "modified_since",
            "in": "query",
            "description": "Return only annotations modified since this ISO 8601 timestamp",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "deleted_since",
            "in": "query",
            "description": "Return only annotations deleted since this ISO 8601 timestamp",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Max items per page (default 20, max 500)",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "marker",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Annotation"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createAnnotation",
        "summary": "Create an annotation",
        "tags": [
          "Annotations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnnotationCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Annotation created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Annotation"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create an annotation"
      }
    },
    "/annotations/{id}": {
      "patch": {
        "operationId": "updateAnnotation",
        "summary": "Update an annotation",
        "tags": [
          "Annotations"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
