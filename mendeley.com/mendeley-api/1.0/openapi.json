            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a catalog document by ID"
      }
    },
    "/search/catalog": {
      "get": {
        "operationId": "searchCatalog",
        "summary": "Search catalog",
        "description": "Search the Mendeley catalog by query or specific fields.",
        "tags": [
          "Catalog"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "General search query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "title",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "author",
            "in": "query",
