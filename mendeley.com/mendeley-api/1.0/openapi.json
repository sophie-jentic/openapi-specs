    "/catalog": {
      "get": {
        "operationId": "getCatalogByIdentifier",
        "summary": "Search catalog by identifier",
        "description": "Retrieve catalog documents by identifier (DOI, ISBN, ISSN, PMID, etc.).",
        "tags": [
          "Catalog"
        ],
        "parameters": [
          {
            "name": "doi",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "isbn",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "issn",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pmid",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "arxiv",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scopus",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filehash",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "view",
            "in": "query",
            "description": "Additional fields to include",
            "schema": {
              "type": "string",
              "enum": [
                "bib",
                "client",
                "stats",
                "all"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CatalogDocument"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
