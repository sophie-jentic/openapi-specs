    },
    "/zones/{zone_id}/ds_records": {
      "get": {
        "operationId": "listDsRecords",
        "summary": "List DS records for a zone",
        "tags": [
          "DS Records"
        ],
        "parameters": [
          {
            "name": "zone_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "DS records",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DsRecord"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List DS records for a zone"
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string"
          },
          "repo_uri": {
            "type": "string"
          },
          "api_enabled": {
            "type": "boolean"
          },
          "tfa": {
            "type": "boolean"
          },
          "deploy_key": {
            "type": "string"
          },
          "ttl": {
            "type": "integer"
          },
          "package": {
            "type": "string"
          },
          "name_servers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Zone": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "synced": {
            "type": "boolean"
          },
          "queries_count": {
            "type": "integer"
          },
          "records_count": {
            "type": "integer"
          },
          "aliases_count": {
            "type": "integer"
          },
          "redirects_count": {
            "type": "integer"
          },
          "forwards_count": {
            "type": "integer"
          },
          "template_id": {
            "type": "integer"
          }
        }
      },
      "ZoneWithRecords": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Zone"
          },
          {
            "type": "object",
            "properties": {
              "records": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Record"
                }
              }
            }
          }
        ]
      },
      "Record": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "ttl": {
            "type": "integer"
          },
          "zone_id": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RecordInput": {
        "type": "object",
        "required": [
          "name",
          "type",
          "content"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "ttl": {
            "type": "integer"
          },
          "external_id": {
            "type": "string"
          }
        }
      },
      "DsRecord": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "key_tag": {
            "type": "integer"
          },
          "algorithm": {
            "type": "integer"
          },
          "digest_type": {
            "type": "integer"
          },
          "digest": {
            "type": "string"
          },
          "public_key": {
            "type": "string"
          },
          "zone_id": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Auth with email as username and API key as password"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "DS Records"
    },
    {
      "name": "Records"
    },
    {
      "name": "Users"
    },
    {
      "name": "Zones"
    }
  ]
}
