{
  "openapi": "3.0.3",
  "info": {
    "title": "Craft CMS API",
    "version": "5.0.0",
    "description": "Craft CMS controller actions and element API for managing entries, users, addresses, sessions, and more.",
    "x-jentic-source-url": "https://craftcms.com/docs/5.x/reference/controller-actions.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{site-domain}",
      "variables": {
        "site-domain": {
          "default": "example.com",
          "description": "Your Craft CMS site domain"
        }
      }
    }
  ],
  "paths": {
    "/actions/entries/save-entry": {
      "post": {
        "operationId": "saveEntry",
        "summary": "Create or update an entry",
        "description": "Creates or updates an entry the current user has appropriate permissions for.",
        "tags": [
          "Entries"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveEntryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry saved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Entry"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/actions/users/login": {
      "post": {
        "operationId": "login",
        "summary": "Log a user in",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "returnUrl": {
                      "type": "string"
                    },
                    "csrfTokenValue": {
                      "type": "string"
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Log a user in"
      }
    },
    "/actions/users/save-user": {
      "post": {
        "operationId": "saveUser",
        "summary": "Register or update a user",
        "description": "Registers a new user account or updates an existing one.",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User saved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "csrfTokenValue": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/actions/users/upload-user-photo": {
      "post": {
        "operationId": "uploadUserPhoto",
        "summary": "Upload a user photo",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "userId",
                  "photo"
                ],
                "properties": {
                  "userId": {
                    "type": "integer"
                  },
                  "photo": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Photo uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "html": {
                      "type": "string"
                    },
                    "photoId": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Upload a user photo"
      }
    },
    "/actions/users/send-password-reset-email": {
      "post": {
        "operationId": "sendPasswordResetEmail",
        "summary": "Send a password reset email",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "loginName": {
                    "type": "string",
                    "description": "Username or email"
                  },
                  "userId": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reset email sent"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Send a password reset email"
      }
    },
    "/actions/users/set-password": {
      "post": {
        "operationId": "setPassword",
        "summary": "Set a new password",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "code",
                  "newPassword"
                ],
                "properties": {
                  "code": {
                    "type": "string",
                    "description": "Verification code"
                  },
                  "id": {
                    "type": "string",
                    "description": "User UID"
                  },
                  "newPassword": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password set"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Set a new password"
      }
    },
    "/actions/users/save-address": {
      "post": {
        "operationId": "saveAddress",
        "summary": "Create or update an address",
        "tags": [
          "Addresses"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveAddressRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Address saved"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create or update an address"
      }
    },
    "/actions/users/delete-address": {
      "post": {
        "operationId": "deleteAddress",
        "summary": "Delete an address",
        "tags": [
          "Addresses"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "addressId"
                ],
                "properties": {
                  "addressId": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Address deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete an address"
      }
    },
    "/actions/users/session-info": {
      "get": {
        "operationId": "getSessionInfo",
        "summary": "Get current session info",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Session info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "isGuest": {
                      "type": "boolean"
                    },
                    "timeout": {
                      "type": "integer"
                    },
                    "csrfTokenName": {
                      "type": "string"
                    },
                    "csrfTokenValue": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get current session info"
      }
    },
    "/actions/app/health-check": {
      "get": {
        "operationId": "healthCheck",
        "summary": "Application health check",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Application is healthy",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Application health check"
      }
    }
  },
  "components": {
    "schemas": {
      "Entry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "sectionId": {
            "type": "integer"
          },
          "typeId": {
            "type": "integer"
          },
          "authorId": {
            "type": "integer"
          },
          "postDate": {
            "type": "string",
            "format": "date-time"
          },
          "expiryDate": {
            "type": "string",
            "format": "date-time"
          },
          "enabled": {
            "type": "boolean"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time"
          },
          "dateUpdated": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SaveEntryRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "sectionId": {
            "type": "integer"
          },
          "typeId": {
            "type": "integer"
          },
          "author": {
            "type": "integer"
          },
          "postDate": {
            "type": "string",
            "format": "date-time"
          },
          "expiryDate": {
            "type": "string",
            "format": "date-time"
          },
          "enabled": {
            "type": "boolean"
          },
          "parentId": {
            "type": "integer"
          },
          "canonicalId": {
            "type": "integer",
            "description": "Entry ID to update"
          },
          "siteId": {
            "type": "integer"
          },
          "fields": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "admin": {
            "type": "boolean"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "loginName",
          "password"
        ],
        "properties": {
          "loginName": {
            "type": "string",
            "description": "Username or email"
          },
          "password": {
            "type": "string"
          },
          "rememberMe": {
            "type": "boolean"
          }
        }
      },
      "SaveUserRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "newPassword": {
            "type": "string"
          },
          "currentPassword": {
            "type": "string"
          },
          "userId": {
            "type": "integer"
          },
          "admin": {
            "type": "boolean"
          },
          "fields": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "SaveAddressRequest": {
        "type": "object",
        "properties": {
          "addressId": {
            "type": "integer"
          },
          "ownerId": {
            "type": "integer"
          },
          "countryCode": {
            "type": "string"
          },
          "administrativeArea": {
            "type": "string"
          },
          "locality": {
            "type": "string"
          },
          "postalCode": {
            "type": "string"
          },
          "addressLine1": {
            "type": "string"
          },
          "addressLine2": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "organization": {
            "type": "string"
          },
          "fields": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "CookieSession": {
        "type": "apiKey",
        "name": "Cookie",
        "in": "header",
        "description": "Session cookie for authenticated requests"
      },
      "CSRFToken": {
        "type": "apiKey",
        "name": "X-CSRF-Token",
        "in": "header",
        "description": "CSRF token required for POST requests"
      }
    }
  },
  "security": [
    {
      "CookieSession": [],
      "CSRFToken": []
    }
  ],
  "tags": [
    {
      "name": "Addresses"
    },
    {
      "name": "Entries"
    },
    {
      "name": "System"
    },
    {
      "name": "Users"
    }
  ]
}
