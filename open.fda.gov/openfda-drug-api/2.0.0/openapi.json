  "components": {
    "schemas": {
      "OpenFDAResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/MetaData"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "DrugEventResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/MetaData"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdverseEvent"
            }
          }
        }
      },
      "MetaData": {
        "type": "object",
        "properties": {
          "disclaimer": {
            "type": "string"
          },
          "terms": {
            "type": "string"
          },
          "license": {
            "type": "string"
          },
          "last_updated": {
            "type": "string",
            "format": "date"
          },
          "results": {
            "type": "object",
            "properties": {
              "skip": {
                "type": "integer"
              },
              "limit": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              }
            }
          }
        }
      },
      "AdverseEvent": {
        "type": "object",
        "properties": {
          "safetyreportid": {
            "type": "string"
          },
          "serious": {
            "type": "string"
          },
          "seriousnessdeath": {
            "type": "string"
          },
          "receivedate": {
            "type": "string"
          },
          "receiptdate": {
            "type": "string"
          },
          "companynumb": {
            "type": "string"
          },
          "primarysource": {
            "type": "object",
            "properties": {
              "reportercountry": {
                "type": "string"
              },
              "qualification": {
                "type": "string"
              }
            }
          },
          "patient": {
            "type": "object",
            "properties": {
              "patientonsetage": {
                "type": "string"
              },
              "patientonsetageunit": {
                "type": "string"
              },
              "patientsex": {
                "type": "string"
              },
              "reaction": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "reactionmeddrapt": {
                      "type": "string"
                    }
                  }
                }
              },
              "drug": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "drugcharacterization": {
                      "type": "string"
                    },
                    "medicinalproduct": {
                      "type": "string"
                    },
                    "drugauthorizationnumb": {
                      "type": "string"
                    },
                    "drugadministrationroute": {
                      "type": "string"
                    },
                    "drugindication": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Optional API key for higher rate limits (240 requests/minute vs 40 without key)"
      }
    }
  },
  "security": [
