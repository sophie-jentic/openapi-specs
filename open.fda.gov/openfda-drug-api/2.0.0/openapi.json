{
  "openapi": "3.0.3",
  "info": {
    "title": "openFDA Drug API",
    "version": "2.0.0",
    "description": "The openFDA Drug API provides access to FDA drug data including adverse events reports (FAERS), product labeling, NDC directory, recall enforcement reports, Drugs@FDA approvals, and drug shortages information.",
    "x-jentic-source-url": "https://open.fda.gov/apis/drug/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.fda.gov"
    }
  ],
  "paths": {
    "/drug/event.json": {
      "get": {
        "operationId": "searchDrugAdverseEvents",
        "summary": "Search drug adverse events",
        "description": "Search reports of drug side effects, product use errors, product quality problems, and therapeutic failures from FAERS.",
        "tags": [
          "Adverse Events"
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Search query using openFDA query syntax (e.g., patient.drug.openfda.brand_name:\"aspirin\")",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "count",
            "in": "query",
            "description": "Field to count unique values of (returns counts instead of records)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of records to return (max 1000)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "maximum": 1000
            }
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Number of records to skip (max 25000)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 25000
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "description": "API key for higher rate limits",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DrugEventResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
