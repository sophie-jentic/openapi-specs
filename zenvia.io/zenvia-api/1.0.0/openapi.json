    {
      "name": "Facebook",
      "description": "The Facebook channel may be used after connection on Zenvia platform."
    },
    {
      "name": "Webhooks",
      "description": "Webhooks allow you to receive events in the configured URL."
    },
    {
      "name": "Templates",
      "description": "Message Templates are message formats for common reusable messages."
