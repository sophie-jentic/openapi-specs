    "/reports/flow/entries": {
      "get": {
        "operationId": "getFlowReportEntries",
        "description": "Retrieve all entries applying the given filters",
        "tags": [
          "Flow Report"
        ],
        "parameters": [
          {
            "name": "startDate",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "The start of the period to query entries"
          },
          {
            "name": "endDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "The end of the period to query entries"
          },
          {
            "name": "flowId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The flow identifier"
          },
          {
            "name": "dispatchId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The dispatch ID"
          },
          {
            "name": "sessionId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The session ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Flow report entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FlowReportEntry"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/reports/message/entries": {
      "get": {
        "operationId": "getMessageReportEntries",
        "description": "Retrieve all entries applying the given filters",
        "tags": [
          "Message Report"
        ],
        "parameters": [
          {
            "name": "startDate",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "The start of the period"
          },
          {
            "name": "endDate",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "The end of the period"
          },
          {
            "name": "channels",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of channels"
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "message",
                "notification"
              ]
            },
            "description": "The message type"
          }
        ],
        "responses": {
          "200": {
            "description": "Message report entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageReportEntry"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContentText": {
        "type": "object",
        "required": [
          "type",
          "text"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Content type"
          },
          "text": {
            "type": "string",
            "description": "Text to be sent"
          },
          "payload": {
            "type": "string",
            "description": "Payload of selected button"
          }
        }
      },
      "MessageBase": {
        "type": "object",
        "required": [
          "from",
          "to",
          "contents"
        ],
        "properties": {
          "id": {
            "type": "string",
            "readOnly": true,
            "description": "Message ID"
          },
          "from": {
            "type": "string",
            "description": "Sender identifier"
          },
          "to": {
            "type": "string",
            "description": "Recipient identifier"
          },
          "direction": {
            "type": "string",
            "enum": [
              "IN",
              "OUT"
            ],
            "readOnly": true,
            "description": "Message direction"
          },
          "channel": {
            "type": "string",
            "readOnly": true,
            "description": "Message channel"
          },
          "contents": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "minItems": 1,
            "description": "A list of content to be sent"
          }
        }
      },
      "MessageSms": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MessageBase"
          },
          {
            "type": "object",
            "properties": {
              "contents": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ContentText"
                },
                "minItems": 1
              }
            }
          }
        ]
      },
      "MessageFacebook": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MessageBase"
          }
        ]
      },
      "MessageWhatsapp": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MessageBase"
          }
        ]
      },
      "Error": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "readOnly": true,
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "readOnly": true,
            "description": "Error message"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "readOnly": true
          }
        }
      },
      "Subscription": {
        "type": "object",
        "required": [
          "eventType",
          "webhook"
        ],
        "properties": {
          "id": {
            "type": "string",
            "readOnly": true
          },
          "eventType": {
            "type": "string",
            "enum": [
              "MESSAGE",
              "MESSAGE_STATUS"
            ]
          },
          "webhook": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "description": "Webhook URL"
              },
              "headers": {
                "type": "object"
              }
            }
          }
        }
      },
      "SubscriptionUpdate": {
        "type": "object",
        "properties": {
          "webhook": {
            "type": "object"
          }
        }
      },
      "Template": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "description": "Template name"
          }
        }
      },
      "TemplateUpdate": {
        "type": "object",
        "properties": {}
      },
      "TemplateComment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "readOnly": true
          }
        }
      },
      "FlowReportEntry": {
        "type": "object",
        "properties": {
          "flowId": {
            "type": "string"
          }
        }
      },
      "MessageReportEntry": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "readOnly": true
          }
        }
      }
    },
    "securitySchemes": {
      "JWT": {
        "type": "apiKey",
        "in": "header",
        "name": "JWT"
      },
      "TOKEN": {
        "type": "apiKey",
        "in": "header",
        "name": "TOKEN"
      }
    }
  }
}
