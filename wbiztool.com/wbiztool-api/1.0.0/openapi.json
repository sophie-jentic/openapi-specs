{
  "openapi": "3.0.3",
  "info": {
    "title": "Wbiztool WhatsApp API",
    "description": "API for sending WhatsApp messages including text, images, and files through the Wbiztool platform.",
    "version": "1.0.0",
    "contact": {
      "name": "Wbiztool",
      "url": "https://wbiztool.com"
    },
    "x-jentic-source-url": "https://wbiztool.com/docs/send-message/"
  },
  "servers": [
    {
      "url": "https://wbiztool.com/api/v1",
      "description": "Wbiztool Production API"
    }
  ],
  "paths": {
    "/send_msg/": {
      "post": {
        "tags": [
          "Messages"
        ],
        "summary": "Send a WhatsApp message",
        "description": "Send a text, image, or file message to a WhatsApp number or group.",
        "operationId": "sendMessage",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "client_id",
                  "api_key",
                  "whatsapp_client",
                  "msg_type",
                  "msg"
                ],
                "properties": {
                  "client_id": {
                    "type": "integer",
                    "description": "User's client identifier"
                  },
                  "api_key": {
                    "type": "string",
                    "description": "User's authentication API key"
                  },
                  "whatsapp_client": {
                    "type": "integer",
                    "description": "WhatsApp client identifier"
                  },
                  "msg_type": {
                    "type": "integer",
                    "description": "Message type: 0 = text, 1 = image with text, 2 = file with text",
                    "enum": [
                      0,
                      1,
                      2
                    ]
                  },
                  "msg": {
                    "type": "string",
                    "description": "Message content"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Recipient's WhatsApp number with country code (e.g. 919632066772)"
                  },
                  "group_name": {
                    "type": "string",
                    "description": "WhatsApp group name for group messaging"
                  },
                  "country_code": {
                    "type": "string",
                    "description": "Country code, applies to phone messages only"
                  },
                  "img_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Image URL (required when msg_type=1). Must end with valid image extension."
                  },
                  "file_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "File URL (required when msg_type=2 and file not uploaded)"
                  },
                  "file_name": {
                    "type": "string",
                    "description": "File name (required when msg_type=2)"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "File upload (required when msg_type=2 and file_url absent)"
                  },
                  "expire_after_seconds": {
                    "type": "integer",
                    "description": "Message expiration timeout in seconds"
                  },
                  "webhook": {
                    "type": "string",
                    "format": "uri",
                    "description": "Callback URL for message status updates"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SendMessageResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "1 for success, 0 for failure",
            "enum": [
              0,
              1
            ]
          },
          "message": {
            "type": "string",
            "description": "Human-readable status description"
          },
          "msg_id": {
            "type": "integer",
            "description": "Unique message identifier for tracking"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "enum": [
              0
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Messages"
    }
  ]
}
