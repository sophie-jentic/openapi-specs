{
  "openapi": "3.0.3",
  "info": {
    "title": "Giftogram API",
    "description": "The Giftogram API allows you to programmatically send gift and prepaid cards to users, customers, and survey participants. Automate rewards, send gifts from multiple brands, and manage campaigns through the platform.",
    "version": "1.0",
    "contact": {
      "email": "api-support@giftogram.com",
      "url": "https://developers.giftogram.com"
    }
  },
  "servers": [
    {
      "url": "https://api.giftogram.com",
      "description": "Production API"
    },
    {
      "url": "https://sandbox.api.giftogram.com",
      "description": "Sandbox API"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/campaigns": {
      "get": {
        "summary": "List campaigns",
        "description": "Retrieve a list of available campaigns with their configurations, currencies, and denominations",
        "operationId": "getCampaigns",
        "tags": [
          "Campaigns"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "headers": {
              "Content-Type": {
                "schema": {
                  "type": "string",
                  "example": "application/json"
                }
              },
              "X-RateLimit-Limit": {
                "schema": {
                  "type": "integer",
                  "example": 120
                },
                "description": "Rate limit for API requests"
              },
              "X-RateLimit-Remaining": {
                "schema": {
                  "type": "integer",
                  "example": 120
                },
                "description": "Remaining requests in rate limit window"
              },
              "X-Giftogram-API-Key-Expires-At": {
                "schema": {
                  "type": "string",
                  "example": "2028-12-07"
                },
                "description": "API key expiration date"
              },
              "X-Giftogram-API-Key-Alias": {
                "schema": {
                  "type": "string",
                  "example": "Purple Team Key"
                },
                "description": "API key alias"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Campaign"
                      }
                    },
                    "links": {
                      "$ref": "#/components/schemas/PaginationLinks"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid, expired, or revoked API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token associated with a Giftogram account"
      }
    },
    "schemas": {
      "Campaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "UUID used during ordering to denote which campaign"
          },
          "name": {
            "type": "string",
            "description": "Campaign identifier"
          },
          "currencies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Available currency codes (e.g., USD, EUR)",
            "example": [
              "USD"
            ]
          },
          "denominations": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "Valid gift amounts; empty array means all amounts are allowed"
          },
          "active": {
            "type": "boolean",
            "description": "Campaign status - whether the campaign is currently active"
          }
        }
      },
      "PaginationLinks": {
        "type": "object",
        "properties": {
          "first": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "URL to first page"
          },
          "last": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "URL to last page"
          },
          "prev": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "URL to previous page"
          },
          "next": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "URL to next page"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Campaigns"
    }
  ]
}
