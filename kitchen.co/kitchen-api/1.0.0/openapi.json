{
  "openapi": "3.0.3",
  "info": {
    "title": "Kitchen.co API",
    "description": "The Kitchen.co API is organized around REST. It provides access to project management features including files, folders, tasks, boards, invoices, conversations, webhooks, and more. Accepts form-encoded request bodies and returns JSON-encoded responses.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://kitchen.co/apidocs/introduction",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{workspace}.kitchen.co/api",
      "description": "Kitchen.co API server",
      "variables": {
        "workspace": {
          "default": "your-workspace",
          "description": "Your Kitchen.co workspace subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/files/{id}": {
      "get": {
        "summary": "Retrieve a file",
        "operationId": "getFile",
        "tags": [
          "Files"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/File"
                }
              }
            }
          }
        },
        "description": "Retrieve a file"
      },
      "delete": {
        "summary": "Delete a file",
        "operationId": "deleteFile",
        "tags": [
          "Files"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File deleted"
          }
        },
        "description": "Delete a file"
      }
    },
    "/folders": {
      "get": {
        "summary": "List all folders",
        "operationId": "listFolders",
        "tags": [
          "Folders"
        ],
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "active",
                "archived"
              ],
              "default": "active"
            }
          },
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of folders",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                }
              }
            }
          }
        },
        "description": "List all folders"
      }
    },
    "/folders/{id}": {
      "get": {
        "summary": "Retrieve a folder",
        "operationId": "getFolder",
        "tags": [
          "Folders"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Folder"
                }
              }
            }
          }
        },
        "description": "Retrieve a folder"
      }
    },
    "/boards": {
      "get": {
        "summary": "List all boards",
        "operationId": "listBoards",
        "tags": [
          "Boards"
        ],
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "active",
                "archived"
              ],
              "default": "active"
            }
          },
          {
            "name": "title",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of boards",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Board"
                      }
                    },
                    "links": {
                      "$ref": "#/components/schemas/PaginationLinks"
                    },
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List all boards"
      }
    },
    "/boards/{id}/tasks": {
      "get": {
        "summary": "List all tasks in a board",
        "operationId": "listTasks",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "expand",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "assignee",
                  "author",
                  "board",
                  "completer",
                  "milestone",
                  "list"
                ]
              }
            }
          },
          {
            "name": "title",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "completed"
              ]
            }
          },
          {
            "name": "repeating",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "members",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "lists",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "labels",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "starts_at",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "due_at",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Task"
                      }
                    },
                    "links": {
                      "$ref": "#/components/schemas/PaginationLinks"
                    },
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List all tasks in a board"
      },
      "post": {
        "summary": "Create a task",
        "operationId": "createTask",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "list",
                  "title"
                ],
                "properties": {
                  "list": {
                    "type": "string",
                    "description": "ID of the list"
                  },
                  "title": {
                    "type": "string"
                  },
                  "assignee": {
                    "type": "string",
                    "description": "User ID"
                  },
                  "description": {
                    "type": "string",
                    "description": "Accepts HTML"
                  },
                  "due_at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "due_reminder": {
                    "type": "string"
                  },
                  "milestone": {
                    "type": "string"
                  },
                  "parent": {
                    "type": "string",
                    "description": "Parent task ID"
                  },
                  "remaining_minutes_estimate": {
                    "type": "integer"
                  },
                  "start_at": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        },
        "description": "Create a task"
      }
    },
    "/conversations": {
      "get": {
        "summary": "List all conversations",
        "operationId": "listConversations",
        "tags": [
          "Conversations"
        ],
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "active",
                "archived"
              ],
              "default": "active"
            }
          },
          {
            "name": "title",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of conversations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Conversation"
                      }
                    },
                    "links": {
                      "$ref": "#/components/schemas/PaginationLinks"
                    },
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List all conversations"
      }
    },
    "/invoices": {
      "get": {
        "summary": "List all invoices",
        "operationId": "listInvoices",
        "tags": [
          "Invoices"
        ],
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "active",
                "archived"
              ],
              "default": "active"
            }
          },
          {
            "name": "number",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "expand",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "billing_profile",
                  "client",
                  "creator"
                ]
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of invoices",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                }
              }
            }
          }
        },
        "description": "List all invoices"
      },
      "post": {
        "summary": "Create an invoice",
        "operationId": "createInvoice",
        "tags": [
          "Invoices"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "visibility"
                ],
                "properties": {
                  "client": {
                    "type": "string"
                  },
                  "currency": {
                    "type": "string",
                    "description": "Three-letter ISO currency code"
                  },
                  "discounts": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "due_date_in_days": {
                    "type": "number"
                  },
                  "due_reminder_message": {
                    "type": "string"
                  },
                  "due_reminder_send_days": {
                    "type": "number"
                  },
                  "folder": {
                    "type": "string"
                  },
                  "footer_notes": {
                    "type": "string"
                  },
                  "grand_total": {
                    "type": "string"
                  },
                  "issue_date": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "language": {
                    "type": "string"
                  },
                  "memo": {
                    "type": "string"
                  },
                  "number": {
                    "type": "string"
                  },
                  "payment_gateways": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "credit_card",
                        "stripe_ach",
                        "paypal",
                        "bank"
                      ]
                    }
                  },
                  "shipping_amount": {
                    "type": "number"
                  },
                  "tax_items": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "visibility": {
                    "type": "string",
                    "enum": [
                      "private",
                      "internal",
                      "shared"
                    ]
                  },
                  "role": {
                    "type": "string",
                    "enum": [
                      "invoice_admin",
                      "invoice_manager",
                      "invoice_viewer"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Invoice created"
          }
        },
        "description": "Create an invoice"
      }
    },
    "/webhooks": {
      "get": {
        "summary": "List all webhooks",
        "operationId": "listWebhooks",
        "tags": [
          "Webhooks"
        ],
        "responses": {
          "200": {
            "description": "Paginated list of webhooks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Webhook"
                      }
                    },
                    "links": {
                      "$ref": "#/components/schemas/PaginationLinks"
                    },
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List all webhooks"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token issued from workspace settings"
      }
    },
    "schemas": {
      "File": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "location_type": {
            "type": "string",
            "enum": [
              "folder",
              "conversation_message",
              "task_comment"
            ]
          },
          "location": {
            "type": "string"
          },
          "approver": {
            "type": "string",
            "nullable": true
          },
          "uploader": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "mime_type": {
            "type": "string"
          },
          "extension": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "thumbnail": {
            "type": "string",
            "nullable": true
          },
          "approved_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Folder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "visibility": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "archived_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "Board": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "visibility": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "archived_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "assignee": {
            "type": "string",
            "nullable": true
          },
          "author": {
            "type": "string"
          },
          "board": {
            "type": "string"
          },
          "list": {
            "type": "string"
          },
          "milestone": {
            "type": "string",
            "nullable": true
          },
          "completed": {
            "type": "boolean"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "completer": {
            "type": "string",
            "nullable": true
          },
          "start_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "due_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "due_reminder": {
            "type": "string",
            "nullable": true
          },
          "due_reminder_sent_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "remaining_minutes_estimate": {
            "type": "integer",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Conversation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string"
          },
          "visibility": {
            "type": "string"
          },
          "messages_count": {
            "type": "integer"
          },
          "latest_message_created_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "archived_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "events_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "attempts_count": {
            "type": "integer"
          },
          "failed_attempts_count": {
            "type": "integer"
          },
          "enabled": {
            "type": "boolean"
          },
          "secret": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "links": {
            "$ref": "#/components/schemas/PaginationLinks"
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "PaginationLinks": {
        "type": "object",
        "properties": {
          "first": {
            "type": "string",
            "nullable": true
          },
          "last": {
            "type": "string",
            "nullable": true
          },
          "prev": {
            "type": "string",
            "nullable": true
          },
          "next": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "current_page": {
            "type": "integer"
          },
          "last_page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer",
            "default": 20
          },
          "total": {
            "type": "integer"
          }
        }
      }
    }
