  "tags": [
    {
      "name": "Boards"
    },
    {
      "name": "Conversations"
    },
    {
      "name": "Files"
    },
    {
      "name": "Folders"
    },
    {
      "name": "Invoices"
    },
    {
      "name": "Tasks"
    },
    {
      "name": "Webhooks"
    }
  ]
}
