{
  "openapi": "3.0.0",
  "info": {
    "title": "OneLogin API",
    "version": "2",
    "description": "OneLogin API for managing users, apps, roles, events, and authentication flows in your OneLogin account.",
    "contact": {
      "url": "https://developers.onelogin.com"
    },
    "x-jentic-source-url": "https://developers.onelogin.com/api-docs/2"
  },
  "servers": [
    {
      "url": "https://{subdomain}/api/2",
      "variables": {
        "subdomain": {
          "default": "api.us.onelogin.com",
          "description": "Your OneLogin API subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List Users",
        "description": "Get a paginated list of users in a OneLogin account. Supports filtering by date range, name, email, username, and custom attributes. Returns up to 50 users per page.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "created_since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "ISO8601 timestamp - returns all users created after this date"
          },
          {
            "name": "created_until",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "ISO8601 timestamp - returns all users created before this date"
          },
          {
            "name": "updated_since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "ISO8601 timestamp - returns all users updated after this date"
          },
          {
            "name": "updated_until",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "ISO8601 timestamp - returns all users updated before this date"
          },
          {
            "name": "last_login_since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "ISO8601 timestamp - returns all users that logged in after this date"
          },
          {
            "name": "last_login_until",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "ISO8601 timestamp - returns all users that logged in before this date"
          },
          {
            "name": "firstname",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "The first name of the user"
          },
          {
            "name": "lastname",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "The last name of the user"
          },
          {
            "name": "email",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "The email address of the user"
          },
          {
            "name": "username",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "The username for the user"
          },
          {
            "name": "directory_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "The ID in OneLogin of the Directory that the user belongs to"
          },
          {
            "name": "external_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "An external identifier that has been set on the user"
          },
          {
            "name": "app_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "The ID of a OneLogin Application"
          },
          {
            "name": "user_ids",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "A comma separated list of OneLogin User IDs"
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "A comma separated list of user attributes to return"
          }
        ],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - invalid query parameter"
          },
          "401": {
            "description": "Unauthorized - invalid access token"
          },
          "422": {
            "description": "Unprocessable Entity"
          }
        }
      }
    },
    "/apps": {
      "get": {
        "operationId": "listApps",
        "summary": "List Apps",
        "description": "Return a list of all Apps in a OneLogin account.",
        "tags": [
          "Apps"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "The name or partial name of the app to search for. When using partial name append wildcard *"
          },
          {
            "name": "connector_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Returns all apps based off a specific connector."
          },
          {
            "name": "auth_method",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1,
                2,
                3,
                4,
                6,
                7,
                8
              ]
            },
            "description": "Returns all apps based on type: 0=Password, 1=OpenId, 2=SAML, 3=API, 4=Google, 6=Forms, 7=WSFED, 8=OpenId Connect"
          }
        ],
        "responses": {
          "200": {
            "description": "List of apps",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/App"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Unprocessable Entity"
          }
        }
      }
    },
    "/auth/token": {
      "post": {
        "operationId": "generateToken",
        "summary": "Generate Token",
        "description": "Generate an access token using client credentials (client_id and client_secret).",
        "tags": [
          "Auth Tokens"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "client_credentials"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Set to 'bearer <access_token>'. Access token generated using the Generate Token API."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "firstname": {
            "type": "string"
          },
          "lastname": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer"
          },
          "state": {
            "type": "integer"
          },
          "external_id": {
            "type": "string",
            "nullable": true
          },
          "directory_id": {
            "type": "integer",
            "nullable": true
          },
          "distinguished_name": {
            "type": "string",
            "nullable": true
          },
          "samaccountname": {
            "type": "string",
            "nullable": true
          },
          "member_of": {
            "type": "string",
            "nullable": true
          },
          "group_id": {
            "type": "integer",
            "nullable": true
          },
          "invalid_login_attempts": {
            "type": "integer"
          },
          "locked_until": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "activated_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "invitation_sent_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "last_login": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "password_changed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "App": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "connector_id": {
            "type": "integer"
          },
          "auth_method": {
            "type": "integer"
          },
          "auth_method_description": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "visible": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_in": {
            "type": "integer"
          },
          "refresh_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string"
          },
          "account_id": {
            "type": "integer"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Apps"
    },
    {
      "name": "Auth Tokens"
    },
    {
      "name": "Users"
    }
  ]
}
