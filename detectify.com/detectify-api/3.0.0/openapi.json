{
  "openapi": "3.0.3",
  "info": {
    "title": "Detectify API",
    "version": "3.0.0",
    "description": "Detectify is a web application security scanner. The API provides programmatic access to surface monitoring data including IP addresses, technologies, ports, breaches, and connector management.",
    "x-jentic-source-url": "https://developer.detectify.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.detectify.com/rest/v3"
    }
  ],
  "paths": {
    "/ips": {
      "get": {
        "operationId": "listIpAddresses",
        "summary": "Get all IP addresses",
        "description": "Returns all the IP addresses which have been discovered on your attack surface",
        "tags": [
          "Surface Monitoring"
        ],
        "parameters": [
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Pagination cursor"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Max results to return"
          },
          {
            "name": "first_seen_before",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter by first seen before date"
          },
          {
            "name": "first_seen_after",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter by first seen after date"
          },
          {
            "name": "disappeared_before",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter by disappeared before date"
          },
          {
            "name": "disappeared_after",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter by disappeared after date"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IpListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
