                    "enum": [
                      "any",
                      "index",
                      "login",
                      "account",
                      "product",
                      "search",
                      "category",
                      "order",
                      "payment"
                    ]
                  },
                  "regex": {
                    "type": "string",
                    "description": "Regex expression to match a page in URL"
                  }
                },
                "description": "Page where snippet need to be placed"
              },
              "location": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Type of location",
                    "enum": [
                      "header",
                      "content_top",
                      "content_bottom",
                      "content_left",
                      "content_right"
                    ]
                  },
                  "regex": {
                    "type": "string",
                    "description": "Regex expression to match element in source page"
                  }
                },
                "description": "Location on selected page"
              }
            },
            "description": "Set of pages and locations inside the page where snippet needs to \nbe placed\n"
