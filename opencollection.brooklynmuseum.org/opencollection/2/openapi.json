{
  "openapi": "3.0.1",
  "info": {
    "title": "Opencollection",
    "description": "The new opencollection api",
    "version": "2",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/amychengbkm/opencollection-dev/2",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://opencollection.brooklynmuseum.org/v2"
    }
  ],
  "paths": {
    "/object/{object_id}": {
      "get": {
        "tags": [
          "Object"
        ],
        "summary": "Get information on an object",
        "description": "Nothing special to note\n",
        "parameters": [
          {
            "name": "object_id",
            "in": "path",
            "description": "ID of the opencollection object to be fetched",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An array of products",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Object"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_object_object_id"
      }
    },
    "/search/{term}": {
      "get": {
        "summary": "Search objects",
        "parameters": [
          {
            "name": "term",
            "in": "path",
            "description": "search objects by this term",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "description": "Search objects",
        "operationId": "get_search_term",
        "tags": [
          "search"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Object": {
        "title": "Object",
        "required": [
          "accession_date",
          "accession_number",
          "approvals_mask",
          "artists",
          "classification",
          "collections",
          "completeness",
          "copyright",
          "copyright_restricted",
          "credit_line",
          "date_added",
          "description",
          "dimensions",
          "dynasty",
          "edition",
          "exhibitions",
          "id",
          "images",
          "inscribed",
          "labels",
          "markings",
          "medium",
          "museum_location",
          "museum_location_id",
          "object_date",
          "period",
          "portfolio",
          "primary_image",
          "public_access",
          "rights_statement",
          "signed",
          "state",
          "title",
          "visible"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "ID of the object"
          },
          "title": {
            "type": "string",
            "description": "Title of the object"
          },
          "accession_number": {
            "type": "string",
            "description": "The object's accession number"
          },
          "accession_date": {
            "type": "string",
            "description": "The date the object was accessioned",
            "format": "date-time"
          },
          "object_date": {
            "type": "string",
            "description": "Date of the object",
            "format": "date-time"
          },
          "object_date_begin": {
            "type": "string",
            "description": "The start date of the object",
            "format": "date-time"
          },
          "object_date_end": {
            "type": "string",
            "description": "The end date of the object",
            "format": "date-time"
          },
          "period": {
            "type": "string",
            "description": "The period of the object if known"
          },
          "dynasty": {
            "type": "string",
            "description": "The dynasty of the object if known or applicable"
          },
          "description": {
            "type": "string",
            "description": "The catalogue desciption of the object.  This description is a concise explanation of what the object is"
          },
          "medium": {
            "type": "string",
            "description": "The medium of the object (e.g. materials object is made of)"
          },
          "dimensions": {
            "type": "string",
            "description": "The dimenions of the object"
          },
          "edition": {
            "type": "string",
            "description": "??"
          },
          "portfolio": {
            "type": "string",
            "description": "??"
          },
          "state": {
            "type": "string",
            "description": "??"
          },
          "markings": {
            "type": "string",
            "description": "??"
          },
          "signed": {
            "type": "string",
            "description": "??"
          },
          "inscribed": {
            "type": "string",
            "description": "??"
          },
          "credit_line": {
            "type": "string",
            "description": "??"
          },
          "copyright": {
            "type": "string",
            "description": "copyright"
          },
          "rights_statement": {
            "type": "string",
            "description": "??"
          },
          "classification": {
            "type": "string",
            "description": "E.g. Photograph"
          },
          "public_access": {
            "type": "integer",
            "description": "1 if the object is publicly accessible, 0 if not"
          },
          "approvals_mask": {
            "type": "integer",
            "description": "??"
          },
          "copyright_restricted": {
            "type": "integer",
            "description": "1 if copyright restricted.  0 if not"
          },
          "visible": {
            "type": "integer",
            "description": "1 if visible.  0 if not"
          },
          "completeness": {
            "type": "integer",
            "description": "On a scale of 0-100%, how complete is data regarding this object"
          },
          "date_added": {
            "type": "string",
            "description": "??? Might be date the object was added to our collection",
            "format": "date-time"
          },
          "museum_location": {
            "type": "string",
            "description": "The location in the museum where the object is located"
          },
          "museum_location_id": {
            "type": "integer",
            "description": "The id of the location where the object is located"
          },
          "primary_image": {
            "type": "string",
            "description": "The highest ranked (highest quality) image available for this object"
          },
          "labels": {
            "uniqueItems": true,
            "type": "array",
            "description": "An array of text labels (such as more in depth object descriptions detailing the object's background, importance, and other historical information) associated with an object",
            "items": {
              "$ref": "#/components/schemas/Label"
            }
          },
          "artists": {
            "uniqueItems": true,
            "type": "array",
            "description": "An array of artists who made the object",
            "items": {
              "$ref": "#/components/schemas/Artist"
            }
          },
          "collections": {
            "uniqueItems": true,
            "type": "array",
            "description": "An array of collections the object is a part of",
            "items": {
              "$ref": "#/components/schemas/Collection"
            }
          },
          "exhibitions": {
            "uniqueItems": true,
            "type": "array",
            "description": "An array of exhibitions the object has been, and currently is a part of",
            "items": {
              "$ref": "#/components/schemas/Exhibition"
            }
          },
          "images": {
            "uniqueItems": true,
            "type": "array",
            "description": "An array of images of the object, grouped by rank. Rank determines the relative importance of the images i.e. a lower rank corresponds with better image.",
            "items": {
              "$ref": "#/components/schemas/Image"
            }
          }
        }
      },
      "Artist": {
        "title": "Artist",
        "required": [
          "id",
          "name",
          "nationality"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The id of the exhibition"
          },
          "name": {
            "type": "string",
            "description": "Name of the artist"
          },
          "nationality": {
            "type": "string",
            "description": "The nationality of the artist"
          }
        }
      },
      "Exhibition": {
        "title": "Exhibition",
        "required": [
          "id",
          "title"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The id of the exhibition"
          },
          "title": {
            "type": "string",
            "description": "The title of the exhibition"
          }
        }
      },
      "Image": {
        "title": "Image",
        "required": [
          "filename"
        ],
        "type": "object",
        "properties": {
          "filename": {
            "type": "string",
            "description": "The filename of the image. To get the complete url of the image use the open collection CDN url format i.e. http://cdn2.brooklynmuseum.org/images/opencollection/objects/size{NUMBER}/{FILENAME}. NUMBER corresponds with the size of the image to be returned between 0 and 4, greater number is used for a larger image. FILENAME is the image filename."
          }
        }
      },
      "Collection": {
        "title": "Collection",
        "required": [
          "id",
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The id of the collection"
          },
          "name": {
            "type": "string",
            "description": "The name of the collection"
          }
        }
      },
      "GeographicalLocation": {
        "title": "GeographicalLocation",
        "required": [
          "id",
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The id of the collection"
          },
          "name": {
            "type": "string",
            "description": "The name of the collection"
          },
          "type": {
            "type": "string",
            "description": "Will give more context on the relationship between the geographical location and the object"
          }
        }
      },
      "Label": {
        "title": "Label",
        "required": [
          "content",
          "id",
          "summary",
          "title"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "ID of the label"
          },
          "title": {
            "type": "string",
            "description": "?? Probably don't use"
          },
          "content": {
            "type": "string",
            "description": "The important label text"
          },
          "summary": {
            "type": "string",
            "description": "Probably not used"
          }
        }
      },
      "Error": {
        "title": "Error",
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "fields": {
            "type": "string"
          }
        }
      }
    }
  },
  "x-original-swagger-version": "2.0",
  "tags": [
    {
      "name": "Object"
    },
    {
      "name": "search"
    }
  ]
}
