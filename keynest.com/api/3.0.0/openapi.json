    "/MyOffices": {
      "get": {
        "summary": "List of my offices",
        "description": "<p>This endpoint return the list of all of your offices.</p>\n<div class=\"click-to-expand-wrapper is-table-wrapper\"><table>\n<thead>\n<tr>\n<th>Name</th>\n<th>Type</th>\n<th>Required</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>ApiKey</td>\n<td>String</td>\n<td>Yes</td>\n</tr>\n</tbody>\n</table>\n</div>",
