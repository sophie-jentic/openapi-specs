{
  "openapi": "3.0.3",
  "info": {
    "title": "Node-RED Admin API",
    "version": "1.0.0",
    "description": "Node-RED Admin HTTP API for managing flows, nodes, and the runtime. The Admin API provides endpoints for authentication, flow configuration, node management, settings, and diagnostics.",
    "x-jentic-source-url": "https://nodered.org/docs/api/admin/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://{node-red-host}:{port}",
      "description": "Node-RED instance",
      "variables": {
        "port": {
          "default": "port"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Authentication and token management"
    },
    {
      "name": "Flows",
      "description": "Flow configuration management"
    },
    {
      "name": "Nodes",
      "description": "Node module management"
    },
    {
      "name": "Runtime",
      "description": "Runtime settings and diagnostics"
    }
  ],
  "paths": {
    "/auth/login": {
      "get": {
        "operationId": "getAuthScheme",
        "summary": "Get the active authentication scheme",
        "description": "Returns the authentication scheme in use. If no authentication is active, returns an empty object. If credential-based, returns the required prompts.",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Active authentication scheme",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthScheme"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/token": {
      "post": {
        "operationId": "exchangeToken",
        "summary": "Exchange credentials for access token",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Not authorized"
          }
        },
        "description": "Exchange credentials for access token"
      }
    },
    "/auth/revoke": {
      "post": {
        "operationId": "revokeToken",
        "summary": "Revoke an access token",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "Token to revoke"
                  }
                },
                "required": [
                  "token"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token revoked"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Revoke an access token"
      }
    },
