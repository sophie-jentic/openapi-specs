    "/diagnostics": {
      "get": {
        "operationId": "getDiagnostics",
        "summary": "Get the runtime diagnostics",
        "tags": [
          "Runtime"
        ],
        "responses": {
          "200": {
            "description": "Diagnostics information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
