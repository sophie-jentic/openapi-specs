{
  "openapi": "3.0.3",
  "info": {
    "title": "Ometria Data API",
    "description": "The Ometria Data API allows you to push and retrieve customer data, products, orders, and events. It supports batch operations and provides comprehensive endpoints for managing your customer data platform.",
    "version": "2.0",
    "contact": {
      "url": "http://docs.ometria.com/"
    }
  },
  "servers": [
    {
      "url": "https://api.ometria.com/v2"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/push": {
      "post": {
        "summary": "Push data records",
        "description": "Accepts a list of up to 100 records of any accepted types: contact, custom event, product, profile, or order",
        "operationId": "pushData",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "maxItems": 100,
                "items": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/Contact"
                    },
                    {
                      "$ref": "#/components/schemas/Order"
                    },
                    {
                      "$ref": "#/components/schemas/Product"
                    },
                    {
                      "$ref": "#/components/schemas/CustomEvent"
                    }
                  ]
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Push object accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PushResponse"
                }
              }
            }
          },
          "403": {
            "description": "API key unauthorized"
          }
        },
        "tags": [
          "push"
        ]
      }
    },
    "/push-errors": {
      "get": {
        "summary": "List push errors",
        "description": "Get a list of errors from push operations",
        "operationId": "listPushErrors",
        "responses": {
          "200": {
            "description": "List of push errors"
          }
        },
        "tags": [
          "push-errors"
        ]
      }
    },
    "/products": {
      "get": {
        "summary": "List products",
        "description": "Get a list of products with optional filtering",
        "operationId": "listProducts",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 250
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "active",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "includeVariants",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "products"
        ]
      }
    },
