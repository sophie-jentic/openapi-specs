  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Ometria-Auth"
      }
    },
    "schemas": {
      "PushResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "OK",
              "ERROR"
            ]
          },
          "request_id": {
            "type": "string"
          },
          "accepted": {
            "type": "integer"
          },
          "rejected": {
            "type": "integer"
          },
          "skipped": {
            "type": "integer"
          }
        }
      },
      "Contact": {
        "type": "object",
        "required": [
          "@type",
          "id"
        ],
        "properties": {
          "@type": {
            "type": "string",
            "enum": [
              "contact"
            ]
          },
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "maxLength": 255
          },
          "phone_number": {
            "type": "string"
          },
          "customer_id": {
            "type": "string",
            "maxLength": 255
          },
          "firstname": {
            "type": "string",
            "maxLength": 64
          },
          "lastname": {
            "type": "string",
            "maxLength": 64
          },
          "middlename": {
            "type": "string",
            "maxLength": 64
          },
          "marketing_optin": {
            "type": "string",
            "enum": [
              "EXPLICITLY_OPTEDOUT",
              "NOT_SPECIFIED",
              "EXPLICITLY_OPTEDIN"
            ]
          },
          "country_id": {
            "type": "string",
            "maxLength": 2
          },
          "date_of_birth": {
            "type": "string",
            "format": "date"
          },
          "@add_to_lists": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "string"
            }
          },
          "@remove_from_lists": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "string"
            }
          },
          "channels": {
            "type": "object",
            "properties": {
              "sms": {
                "type": "object",
                "properties": {
                  "marketing_optin": {
                    "type": "string",
                    "enum": [
                      "EXPLICITLY_OPTEDOUT",
                      "NOT_SPECIFIED",
                      "EXPLICITLY_OPTEDIN"
                    ]
                  },
                  "transactional_optin": {
                    "type": "string",
                    "enum": [
                      "EXPLICITLY_OPTEDOUT",
                      "NOT_SPECIFIED",
                      "EXPLICITLY_OPTEDIN"
                    ]
                  }
                }
              }
            }
          },
          "properties": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "Order": {
        "type": "object",
        "required": [
          "@type",
          "id",
          "timestamp",
          "grand_total",
          "subtotal",
          "currency"
        ],
        "properties": {
          "@type": {
            "type": "string",
            "enum": [
              "order"
            ]
          },
          "id": {
            "type": "string",
            "maxLength": 36
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "currency": {
            "type": "string",
            "maxLength": 3
          },
          "grand_total": {
            "type": "number",
            "format": "float"
          },
          "subtotal": {
            "type": "number",
            "format": "float"
          },
          "discount": {
            "type": "number",
            "format": "float"
          },
          "shipping": {
            "type": "number",
