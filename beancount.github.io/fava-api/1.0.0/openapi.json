{
  "openapi": "3.0.3",
  "info": {
    "title": "Fava API",
    "version": "1.0.0",
    "description": "Fava is a web interface for the Beancount plain-text accounting tool. This JSON API provides endpoints for querying ledger data, managing entries, uploading documents, and running Beancount queries.",
    "x-jentic-source-url": "https://beancount.github.io/fava/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:5000/{bfile}/api",
      "variables": {
        "bfile": {
          "default": "default",
          "description": "Beancount file slug"
        }
      }
    }
  ],
  "paths": {
    "/changed": {
      "get": {
        "operationId": "getChanged",
        "summary": "Check for file changes",
        "tags": [
          "Ledger"
        ],
        "responses": {
          "200": {
            "description": "Changed status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "boolean"
                    },
                    "mtime": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Check for file changes"
      }
    },
    "/errors": {
      "get": {
        "operationId": "getErrors",
        "summary": "Get ledger errors",
        "tags": [
          "Ledger"
        ],
        "responses": {
          "200": {
            "description": "Error list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "mtime": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get ledger errors"
      }
    },
    "/ledger_data": {
      "get": {
        "operationId": "getLedgerData",
        "summary": "Get ledger metadata",
        "tags": [
          "Ledger"
        ],
        "responses": {
          "200": {
            "description": "Ledger data"
          }
        },
        "description": "Get ledger metadata"
      }
    },
    "/payee_accounts": {
      "get": {
        "operationId": "getPayeeAccounts",
        "summary": "Rank accounts for a payee",
        "tags": [
          "Ledger"
        ],
        "parameters": [
          {
            "name": "payee",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ranked account list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Rank accounts for a payee"
      }
    },
    "/query": {
      "get": {
        "operationId": "getQuery",
        "summary": "Run a Beancount query",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "query_string",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "BQL query string"
          }
        ],
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Run a Beancount query"
      }
    },
    "/extract": {
      "get": {
        "operationId": "getExtract",
        "summary": "Extract entries using ingest framework",
        "tags": [
          "Import"
        ],
        "parameters": [
          {
            "name": "filename",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "importer",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Extracted entries"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Extract entries using ingest framework"
      }
    },
    "/context": {
      "get": {
        "operationId": "getContext",
        "summary": "Get context for an entry",
        "tags": [
          "Entries"
        ],
        "parameters": [
          {
            "name": "entry_hash",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Entry context with balances",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Context"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Entry not found"
          }
        },
        "description": "Get context for an entry"
      }
    },
    "/source_slice": {
      "put": {
        "operationId": "putSourceSlice",
        "summary": "Update an entry source slice",
        "tags": [
          "Source Files"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "entry_hash": {
                    "type": "string"
                  },
                  "source": {
                    "type": "string"
                  },
                  "sha256sum": {
                    "type": "string"
                  }
                },
                "required": [
                  "entry_hash",
                  "source",
                  "sha256sum"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Source slice updated"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Update an entry source slice"
      },
      "delete": {
        "operationId": "deleteSourceSlice",
        "summary": "Delete an entry",
        "tags": [
          "Entries"
        ],
        "parameters": [
          {
            "name": "entry_hash",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sha256sum",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Entry deleted"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Delete an entry"
      }
    },
    "/source": {
      "get": {
        "operationId": "getSource",
        "summary": "Load a source file",
        "tags": [
          "Source Files"
        ],
        "parameters": [
          {
            "name": "filename",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Source file content",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/SourceFile"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Load a source file"
      }
    },
    "/payee_transaction": {
      "get": {
        "operationId": "getPayeeTransaction",
        "summary": "Get last transaction for a payee",
        "tags": [
          "Ledger"
        ],
        "parameters": [
          {
            "name": "payee",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Last transaction"
          }
        },
        "description": "Get last transaction for a payee"
      }
    },
    "/narration_transaction": {
      "get": {
        "operationId": "getNarrationTransaction",
        "summary": "Get last transaction by narration",
        "tags": [
          "Ledger"
        ],
        "parameters": [
          {
            "name": "narration",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Last transaction"
          }
        },
        "description": "Get last transaction by narration"
      }
    },
    "/narrations": {
      "get": {
        "operationId": "getNarrations",
        "summary": "List all narrations",
        "tags": [
          "Ledger"
        ],
        "responses": {
          "200": {
            "description": "Narration list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List all narrations"
      }
    },
    "/journal": {
      "get": {
        "operationId": "getJournal",
        "summary": "Get all filtered entries",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "Journal entries"
          }
        },
        "description": "Get all filtered entries"
      }
    },
    "/journal_page": {
      "get": {
        "operationId": "getJournalPage",
        "summary": "Get paginated journal",
        "tags": [
          "Reports"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Journal page",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/JournalPage"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Page not found"
          }
        },
        "description": "Get paginated journal"
      }
    },
    "/events": {
      "get": {
        "operationId": "getEvents",
        "summary": "Get all events",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "Event list"
          }
        },
        "description": "Get all events"
      }
    },
    "/imports": {
      "get": {
        "operationId": "getImports",
        "summary": "Get importable files",
        "tags": [
          "Import"
        ],
        "responses": {
          "200": {
            "description": "Import file list"
          }
        },
        "description": "Get importable files"
      }
    },
    "/documents": {
      "get": {
        "operationId": "getDocuments",
        "summary": "Get all documents",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "Document list"
          }
        },
        "description": "Get all documents"
      }
    },
    "/options": {
      "get": {
        "operationId": "getOptions",
        "summary": "Get Fava and Beancount options",
        "tags": [
          "Configuration"
        ],
        "responses": {
          "200": {
            "description": "Options"
          }
        },
        "description": "Get Fava and Beancount options"
      }
    },
    "/commodities": {
      "get": {
        "operationId": "getCommodities",
        "summary": "Get prices for commodity pairs",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "Commodity prices"
          }
        },
        "description": "Get prices for commodity pairs"
      }
    },
    "/income_statement": {
      "get": {
        "operationId": "getIncomeStatement",
        "summary": "Get income statement data",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "Income statement"
          }
        },
        "description": "Get income statement data"
      }
    },
    "/balance_sheet": {
      "get": {
        "operationId": "getBalanceSheet",
        "summary": "Get balance sheet data",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "Balance sheet"
          }
        },
        "description": "Get balance sheet data"
      }
    },
    "/trial_balance": {
      "get": {
        "operationId": "getTrialBalance",
        "summary": "Get trial balance data",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "Trial balance"
          }
        },
        "description": "Get trial balance data"
      }
    },
    "/move": {
      "put": {
        "operationId": "moveDocument",
        "summary": "Move a document file",
        "tags": [
          "Documents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "account": {
                    "type": "string"
                  },
                  "new_name": {
                    "type": "string"
                  },
                  "filename": {
                    "type": "string"
                  }
                },
                "required": [
                  "account",
                  "new_name",
                  "filename"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document moved"
          },
          "400": {
            "description": "Bad request"
          },
          "409": {
            "description": "Target exists"
          }
        },
        "description": "Move a document file"
      }
    },
    "/add_entries": {
      "put": {
        "operationId": "addEntries",
        "summary": "Add multiple entries",
        "tags": [
          "Entries"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "entries": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  }
                },
                "required": [
                  "entries"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entries stored"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Add multiple entries"
      }
    },
    "/format_source": {
      "put": {
        "operationId": "formatSource",
        "summary": "Format beancount source",
        "tags": [
          "Source Files"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string"
                  }
                },
                "required": [
                  "source"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Formatted source"
          }
        },
        "description": "Format beancount source"
      }
    },
    "/add_document": {
      "put": {
        "operationId": "uploadDocument",
        "summary": "Upload a document",
        "tags": [
          "Documents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "folder": {
                    "type": "string"
                  },
                  "account": {
                    "type": "string"
                  },
                  "hash": {
                    "type": "string"
                  }
                },
                "required": [
                  "file",
                  "folder",
                  "account"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document uploaded"
          },
          "400": {
            "description": "Bad request"
          },
          "409": {
            "description": "File already exists"
          }
        },
        "description": "Upload a document"
      }
    },
    "/attach_document": {
      "put": {
        "operationId": "attachDocument",
        "summary": "Attach a document to an entry",
        "tags": [
          "Documents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "filename": {
                    "type": "string"
                  },
                  "entry_hash": {
                    "type": "string"
                  }
                },
                "required": [
                  "filename",
                  "entry_hash"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document attached"
          }
        },
        "description": "Attach a document to an entry"
      }
    },
    "/upload_import_file": {
      "put": {
        "operationId": "uploadImportFile",
        "summary": "Upload a file for importing",
        "tags": [
          "Import"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Upload a file for importing"
      }
    },
    "/document": {
      "delete": {
        "operationId": "deleteDocument",
        "summary": "Delete a document",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "name": "filename",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document deleted"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Delete a document"
      }
    }
  },
  "components": {
    "schemas": {
      "Context": {
        "type": "object",
        "properties": {
          "entry": {
            "type": "object"
          },
          "balances_before": {
            "type": "object",
            "nullable": true
          },
          "balances_after": {
            "type": "object",
            "nullable": true
          }
        }
      },
      "SourceSlice": {
        "type": "object",
        "properties": {
          "sha256sum": {
            "type": "string"
          },
          "slice": {
            "type": "string"
          }
        }
      },
      "SourceFile": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string"
          },
          "sha256sum": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        }
      },
      "JournalPage": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "total_pages": {
            "type": "integer"
          },
          "journal": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "SessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session",
        "description": "Flask session cookie"
      }
    }
  },
  "security": [
    {
      "SessionAuth": []
    }
  ],
  "tags": [
    {
      "name": "Configuration"
    },
    {
      "name": "Documents"
    },
    {
      "name": "Entries"
    },
    {
      "name": "Import"
    },
    {
      "name": "Ledger"
    },
    {
      "name": "Query"
    },
    {
      "name": "Reports"
    },
    {
      "name": "Source Files"
    }
  ]
}
