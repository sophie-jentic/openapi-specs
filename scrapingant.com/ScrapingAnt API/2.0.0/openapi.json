{
  "openapi": "3.1.0",
  "info": {
    "title": "ScrapingAnt API",
    "version": "2.0.0",
    "description": "ScrapingAnt provides a web scraping API that runs a cluster of hundreds of Chrome browsers under the hood. The API handles JavaScript rendering, proxy rotation, CAPTCHA solving, and more.",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.scrapingant.com/v2"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/general": {
      "get": {
        "summary": "General Web Scraping",
        "description": "Scrapes any website and returns the HTML content. Supports headless browser rendering, proxy rotation, and various customization options.",
        "operationId": "generalScrape",
        "parameters": [
          {
            "$ref": "#/components/parameters/x-api-key"
          },
          {
            "$ref": "#/components/parameters/url"
          },
          {
            "$ref": "#/components/parameters/browser"
          },
          {
            "$ref": "#/components/parameters/timeout"
          },
          {
            "$ref": "#/components/parameters/return_page_source"
          },
          {
            "$ref": "#/components/parameters/cookies"
          },
          {
            "$ref": "#/components/parameters/js_snippet"
          },
          {
            "$ref": "#/components/parameters/proxy_type"
          },
          {
            "$ref": "#/components/parameters/proxy_country"
          },
          {
            "$ref": "#/components/parameters/wait_for_selector"
          },
          {
            "$ref": "#/components/parameters/block_resource"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response containing the HTML content of the target page",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                },
                "example": "<!DOCTYPE html><html>...</html>"
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        },
        "tags": [
          "general"
        ]
      },
