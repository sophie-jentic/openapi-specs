    "/markdown": {
      "get": {
        "summary": "Markdown Extraction",
        "description": "Converts HTML to Markdown format for LLM compatibility.",
        "operationId": "markdownExtract",
        "parameters": [
          {
            "$ref": "#/components/parameters/x-api-key"
          },
          {
            "$ref": "#/components/parameters/url"
          },
          {
            "$ref": "#/components/parameters/browser"
          },
          {
            "$ref": "#/components/parameters/timeout"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response containing markdown content",
            "content": {
              "text/markdown": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
