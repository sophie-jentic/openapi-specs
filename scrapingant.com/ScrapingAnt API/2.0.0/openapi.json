    "/extract": {
      "get": {
        "summary": "AI Data Extraction",
        "description": "Extracts structured data using AI models.",
        "operationId": "aiExtract",
        "parameters": [
          {
            "$ref": "#/components/parameters/x-api-key"
          },
          {
            "$ref": "#/components/parameters/url"
          },
          {
            "$ref": "#/components/parameters/browser"
          },
          {
            "$ref": "#/components/parameters/timeout"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response containing extracted structured data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
