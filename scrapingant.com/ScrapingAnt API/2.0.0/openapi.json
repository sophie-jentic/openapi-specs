  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "x-api-key",
        "description": "API key for authentication. Get it from your dashboard."
      }
    },
    "parameters": {
      "x-api-key": {
        "name": "x-api-key",
        "in": "query",
        "required": true,
        "description": "Your ScrapingAnt API key from the dashboard",
        "schema": {
          "type": "string"
        },
        "example": "your_api_key_here"
      },
      "url": {
        "name": "url",
        "in": "query",
        "required": true,
        "description": "Target website URL to scrape",
        "schema": {
          "type": "string",
          "format": "uri"
        },
        "example": "https://example.com"
      },
      "browser": {
        "name": "browser",
        "in": "query",
        "required": false,
        "description": "Activates headless browser functionality. Default: true",
        "schema": {
          "type": "boolean",
          "default": true
        },
        "example": true
      },
      "timeout": {
        "name": "timeout",
        "in": "query",
        "required": false,
        "description": "Processing duration limit in seconds (5-60 range). Default: 60",
        "schema": {
          "type": "integer",
          "minimum": 5,
          "maximum": 60,
          "default": 60
        },
        "example": 30
      },
      "return_page_source": {
        "name": "return_page_source",
        "in": "query",
        "required": false,
        "description": "Returns unaltered server data without JS rendering. Default: false",
        "schema": {
          "type": "boolean",
          "default": false
        },
        "example": false
      },
      "cookies": {
        "name": "cookies",
        "in": "query",
        "required": false,
        "description": "Custom cookies for the target request",
        "schema": {
          "type": "string"
        },
        "example": "sessionid=abc123; token=xyz789"
      },
      "js_snippet": {
        "name": "js_snippet",
        "in": "query",
        "required": false,
        "description": "Base64-encoded JavaScript code executed after page loads",
        "schema": {
          "type": "string"
        },
        "example": "Y29uc29sZS5sb2coJ0hlbGxvJyk="
      },
      "proxy_type": {
        "name": "proxy_type",
        "in": "query",
        "required": false,
        "description": "Proxy classification selection. Default: datacenter",
        "schema": {
          "type": "string",
          "enum": [
            "datacenter",
            "residential"
          ],
          "default": "datacenter"
        },
        "example": "datacenter"
      },
      "proxy_country": {
        "name": "proxy_country",
        "in": "query",
        "required": false,
        "description": "Geographic proxy location specification (2-letter country code)",
        "schema": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2
        },
        "example": "US"
      },
      "wait_for_selector": {
        "name": "wait_for_selector",
        "in": "query",
        "required": false,
        "description": "CSS selector element to await before returning results",
        "schema": {
          "type": "string"
        },
        "example": ".content-loaded"
      },
      "block_resource": {
        "name": "block_resource",
        "in": "query",
        "required": false,
        "description": "Resource types to prevent loading (repeatable parameter)",
        "schema": {
          "type": "string",
          "enum": [
            "image",
            "stylesheet",
            "font",
            "script",
            "media"
          ]
        },
        "example": "image"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "detail": {
                  "type": "string",
                  "example": "Invalid URL parameter"
                }
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "detail": {
                  "type": "string",
                  "example": "Invalid API key"
                }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden - insufficient credits or plan restrictions",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "detail": {
                  "type": "string",
                  "example": "Insufficient API credits"
                }
              }
            }
          }
        }
      },
      "RateLimitExceeded": {
        "description": "Rate limit exceeded",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "detail": {
                  "type": "string",
                  "example": "Rate limit exceeded"
                }
              }
            }
          }
        }
      },
      "ServerError": {
        "description": "Server error",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "detail": {
                  "type": "string",
                  "example": "Internal server error"
                }
              }
            }
          }
        }
      }
    }
  },
  "externalDocs": {
    "description": "Official ScrapingAnt documentation",
    "url": "https://docs.scrapingant.com"
  },
