    "/extended": {
      "get": {
        "summary": "Extended JSON Output",
        "description": "Returns JSON with metadata including cookies, headers, and XHRs.",
        "operationId": "extendedScrape",
        "parameters": [
          {
            "$ref": "#/components/parameters/x-api-key"
          },
          {
            "$ref": "#/components/parameters/url"
          },
          {
            "$ref": "#/components/parameters/browser"
          },
          {
            "$ref": "#/components/parameters/timeout"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response containing HTML and metadata",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "content": {
                      "type": "string",
                      "description": "HTML content of the page"
                    },
                    "cookies": {
                      "type": "array",
                      "description": "Cookies from the response"
                    },
                    "headers": {
                      "type": "object",
                      "description": "Response headers"
                    },
                    "xhr": {
                      "type": "array",
                      "description": "XHR requests made by the page"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        },
        "tags": [
          "extended"
        ]
      }
    }
