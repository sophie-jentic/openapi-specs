{
  "openapi": "3.0.3",
  "info": {
    "title": "ChartMogul API",
    "description": "ChartMogul provides subscription analytics and revenue reporting. The API allows you to manage data sources, customers, plans, invoices, subscriptions, and retrieve key SaaS metrics like MRR, ARR, churn rate, LTV, ARPA, and customer count.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://dev.chartmogul.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.chartmogul.com/v1"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/account": {
      "get": {
        "summary": "Retrieve Account",
        "description": "Retrieves details of the current ChartMogul account.",
        "operationId": "retrieveAccount",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Account details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          }
        }
      }
    },
    "/data_sources": {
      "get": {
        "summary": "List Data Sources",
        "description": "Lists all data sources for the account.",
        "operationId": "listDataSources",
        "tags": [
          "Data Sources"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Filter by data source name.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "system",
            "in": "query",
            "description": "Filter by system type (e.g., Stripe, Recurly, Custom).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "with_auto_churn_subscription_setting",
            "in": "query",
            "description": "Include auto-churn subscription configuration.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "with_invoice_handling_setting",
            "in": "query",
            "description": "Include invoice handling configuration.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of data sources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data_sources": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DataSource"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/data_sources/{data_source_uuid}": {
      "get": {
        "summary": "Retrieve a Data Source",
        "description": "Retrieves a single data source by UUID.",
        "operationId": "retrieveDataSource",
        "tags": [
          "Data Sources"
        ],
        "parameters": [
          {
            "name": "data_source_uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "with_auto_churn_subscription_setting",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "with_invoice_handling_setting",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Data source details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataSource"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a Data Source",
        "description": "Permanently deletes a data source and all associated data.",
        "operationId": "deleteDataSource",
        "tags": [
          "Data Sources"
        ],
        "parameters": [
          {
            "name": "data_source_uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Data source deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/customers": {
      "get": {
        "summary": "List Customers",
        "description": "Lists all customers with optional filtering and pagination.",
        "operationId": "listCustomers",
        "tags": [
          "Customers"
        ],
        "parameters": [
          {
            "name": "data_source_uuid",
            "in": "query",
            "description": "Filter by data source UUID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "external_id",
            "in": "query",
            "description": "Filter by external identifier.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "email",
            "in": "query",
            "description": "Filter by email address.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by customer status.",
            "schema": {
              "type": "string",
              "enum": [
                "New_Lead",
                "Working_Lead",
                "Qualified_Lead",
                "Unqualified_Lead",
                "Active",
                "Past_Due",
                "Cancelled"
              ]
            }
          },
          {
            "name": "system",
            "in": "query",
            "description": "Filter by billing system (case-sensitive).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Pagination cursor.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of results per page (max 200).",
            "schema": {
              "type": "integer",
              "default": 200,
              "maximum": 200
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of customers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Customer"
                      }
                    },
                    "cursor": {
                      "type": "string"
                    },
                    "has_more": {
                      "type": "boolean"
                    },
                    "per_page": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/plans": {
      "get": {
        "summary": "List Plans",
        "description": "Lists all plans with optional filtering.",
        "operationId": "listPlans",
        "tags": [
          "Plans"
        ],
        "parameters": [
          {
            "name": "data_source_uuid",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "external_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "system",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 200,
              "maximum": 200
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of plans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "plans": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Plan"
                      }
                    },
                    "cursor": {
                      "type": "string"
                    },
                    "has_more": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/invoices": {
      "get": {
        "summary": "List Invoices",
        "description": "Lists all invoices with optional filtering.",
        "operationId": "listInvoices",
        "tags": [
          "Invoices"
        ],
        "parameters": [
          {
            "name": "data_source_uuid",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "customer_uuid",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "external_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 200,
              "maximum": 200
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "validation_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "valid",
                "invalid",
                "all"
              ],
              "default": "valid"
            }
          },
          {
            "name": "include_edit_histories",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "with_disabled",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of invoices",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "invoices": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Invoice"
                      }
                    },
                    "cursor": {
                      "type": "string"
                    },
                    "has_more": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/metrics/mrr": {
      "get": {
        "summary": "Retrieve MRR",
        "description": "Retrieves Monthly Recurring Revenue metrics.",
        "operationId": "retrieveMRR",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/startDate"
          },
          {
            "$ref": "#/components/parameters/endDate"
          },
          {
            "$ref": "#/components/parameters/interval"
          },
          {
            "$ref": "#/components/parameters/geo"
          },
          {
            "$ref": "#/components/parameters/plans"
          },
          {
            "$ref": "#/components/parameters/filters"
          }
        ],
        "responses": {
          "200": {
            "description": "MRR metrics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "date": {
                            "type": "string",
                            "format": "date"
                          },
                          "mrr": {
                            "type": "integer",
                            "description": "MRR in cents"
                          },
                          "percentage-change": {
                            "type": "number"
                          },
                          "mrr-new-business": {
                            "type": "integer"
                          },
                          "mrr-expansion": {
                            "type": "integer"
                          },
                          "mrr-contraction": {
                            "type": "integer"
                          },
                          "mrr-churn": {
                            "type": "integer"
                          },
                          "mrr-reactivation": {
                            "type": "integer"
                          }
                        }
                      }
                    },
                    "summary": {
                      "$ref": "#/components/schemas/MetricSummary"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/metrics/arr": {
      "get": {
        "summary": "Retrieve ARR",
        "description": "Retrieves Annual Run Rate metrics.",
        "operationId": "retrieveARR",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/startDate"
          },
          {
            "$ref": "#/components/parameters/endDate"
          },
          {
            "$ref": "#/components/parameters/interval"
          },
          {
            "$ref": "#/components/parameters/geo"
          },
          {
            "$ref": "#/components/parameters/plans"
          },
          {
            "$ref": "#/components/parameters/filters"
          }
        ],
        "responses": {
          "200": {
            "description": "ARR metrics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "date": {
                            "type": "string",
                            "format": "date"
                          },
                          "arr": {
                            "type": "integer",
                            "description": "ARR in cents"
                          },
                          "percentage-change": {
                            "type": "number"
                          }
                        }
                      }
                    },
                    "summary": {
                      "$ref": "#/components/schemas/MetricSummary"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/metrics/arpa": {
      "get": {
        "summary": "Retrieve ARPA",
        "description": "Retrieves Average Revenue Per Account metrics.",
        "operationId": "retrieveARPA",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/startDate"
          },
          {
            "$ref": "#/components/parameters/endDate"
          },
          {
            "$ref": "#/components/parameters/interval"
          },
          {
            "$ref": "#/components/parameters/geo"
          },
          {
            "$ref": "#/components/parameters/plans"
          },
          {
            "$ref": "#/components/parameters/filters"
          }
        ],
        "responses": {
          "200": {
            "description": "ARPA metrics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "date": {
                            "type": "string",
                            "format": "date"
                          },
                          "arpa": {
                            "type": "integer",
                            "description": "ARPA in cents"
                          },
                          "percentage-change": {
