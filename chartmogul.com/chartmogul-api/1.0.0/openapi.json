        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication using API key as username with empty password."
      }
    },
    "parameters": {
      "startDate": {
        "name": "start-date",
        "in": "query",
        "required": true,
        "description": "Start date in ISO-8601 format (e.g., 2015-05-12).",
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "endDate": {
        "name": "end-date",
        "in": "query",
        "required": true,
        "description": "End date in ISO-8601 format.",
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "interval": {
        "name": "interval",
        "in": "query",
        "description": "Aggregation interval.",
        "schema": {
          "type": "string",
          "enum": [
            "day",
            "week",
            "month",
            "quarter",
            "year"
          ],
          "default": "month"
        }
      },
      "geo": {
        "name": "geo",
        "in": "query",
        "description": "Comma-separated ISO 3166-1 Alpha-2 country codes.",
        "schema": {
          "type": "string"
        }
      },
      "plans": {
        "name": "plans",
        "in": "query",
        "description": "Comma-separated plan UUIDs, external IDs, or names.",
        "schema": {
          "type": "string"
        }
      },
      "filters": {
        "name": "filters",
        "in": "query",
        "description": "ChartMogul Filter Language (CFL) expression.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Account UUID with acc_ prefix."
          },
          "name": {
            "type": "string"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code."
          },
          "time_zone": {
            "type": "string",
            "description": "TZ identifier."
          },
          "week_start_on": {
            "type": "string",
            "enum": [
              "monday",
              "sunday"
            ]
          }
        }
      },
      "DataSource": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "system": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": [
              "working",
              "idle",
              "never_imported",
              "importing",
              "import_complete"
            ]
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "uuid": {
            "type": "string"
          },
          "external_id": {
            "type": "string"
          },
          "external_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "data_source_uuid": {
            "type": "string"
          },
          "data_source_uuids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "lead_created_at": {
            "type": "string",
            "format": "date-time"
          },
          "free_trial_started_at": {
            "type": "string",
            "format": "date-time"
          },
          "customer-since": {
            "type": "string",
            "format": "date-time"
          },
          "country": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "zip": {
            "type": "string"
          },
          "mrr": {
            "type": "integer",
            "description": "MRR in cents."
          },
          "arr": {
            "type": "integer",
            "description": "ARR in cents."
          },
          "currency": {
            "type": "string"
          },
          "currency-sign": {
