                          },
                          "customer-churn-rate": {
                            "type": "number"
                          },
                          "percentage-change": {
                            "type": "number"
                          }
                        }
                      }
                    },
                    "summary": {
                      "$ref": "#/components/schemas/MetricSummary"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/metrics/customer-count": {
      "get": {
        "summary": "Retrieve Customer Count",
        "description": "Retrieves customer count metrics over time.",
        "operationId": "retrieveCustomerCount",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/startDate"
          },
          {
            "$ref": "#/components/parameters/endDate"
          },
          {
            "$ref": "#/components/parameters/interval"
          },
          {
            "$ref": "#/components/parameters/geo"
          },
          {
            "$ref": "#/components/parameters/plans"
          },
          {
            "$ref": "#/components/parameters/filters"
          }
        ],
        "responses": {
          "200": {
            "description": "Customer count metrics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "date": {
                            "type": "string",
                            "format": "date"
                          },
                          "customers": {
                            "type": "integer"
                          },
                          "percentage-change": {
                            "type": "number"
                          }
                        }
                      }
                    },
                    "summary": {
                      "$ref": "#/components/schemas/MetricSummary"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/metrics/ltv": {
      "get": {
        "summary": "Retrieve LTV",
        "description": "Retrieves Customer Lifetime Value metrics.",
        "operationId": "retrieveLTV",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/startDate"
          },
          {
            "$ref": "#/components/parameters/endDate"
