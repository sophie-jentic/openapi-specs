                        }
                      }
                    },
                    "summary": {
                      "$ref": "#/components/schemas/MetricSummary"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/metrics/customer-churn-rate": {
      "get": {
        "summary": "Retrieve Customer Churn Rate",
        "description": "Retrieves customer churn rate metrics.",
        "operationId": "retrieveCustomerChurnRate",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/startDate"
          },
          {
            "$ref": "#/components/parameters/endDate"
