{
  "openapi": "3.0.3",
  "info": {
    "title": "Brave Search API",
    "description": "The Brave Search API provides access to Brave's independent search index. It offers web search, image search, news search, video search, and AI-powered summarized answers. Powered by an independent index of over 30 billion pages.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://brave.com/search/api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.search.brave.com"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Web Search",
      "description": "Web search endpoints"
    },
    {
      "name": "Summarizer",
      "description": "AI-powered answer summarization"
    },
    {
      "name": "Image Search",
      "description": "Image search endpoints"
    },
    {
      "name": "Video Search",
      "description": "Video search endpoints"
    },
    {
      "name": "News Search",
      "description": "News search endpoints"
    },
    {
      "name": "Suggest",
      "description": "Search suggestions"
    },
    {
      "name": "Spellcheck",
      "description": "Spellcheck endpoints"
    }
  ],
  "paths": {
    "/res/v1/web/search": {
      "get": {
        "operationId": "webSearch",
        "summary": "Web Search",
        "description": "Get web search results including URLs, snippets, and metadata. Supports Goggles for custom reranking and extra snippets for enhanced context.",
        "tags": [
          "Web Search"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The search query string"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Country code for search results localization (e.g., US, GB)"
          },
          {
            "name": "search_lang",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Language code for search results"
          },
          {
            "name": "ui_lang",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "UI language for the response"
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20,
              "default": 10
            },
            "description": "Number of results to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset for pagination"
          },
          {
            "name": "safesearch",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "off",
                "moderate",
                "strict"
              ]
            },
            "description": "SafeSearch filter level"
          },
          {
            "name": "freshness",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Freshness filter (e.g., pd for past day, pw for past week, pm for past month)"
          },
          {
            "name": "text_decorations",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Whether to include text decorations like bold in snippets"
          },
          {
            "name": "spellcheck",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Whether to include spellcheck suggestions"
          },
          {
            "name": "goggles_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Goggles ID for custom reranking and filtering"
          },
          {
            "name": "units",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "metric",
                "imperial"
              ]
            },
            "description": "Units for measurement results"
          },
          {
            "name": "extra_snippets",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Whether to return extra alternate snippets (up to 5)"
          },
          {
            "name": "summary",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Whether to include a summarizer key in the response"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful web search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid query parameters"
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key"
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
