{
  "openapi": "3.0.3",
  "info": {
    "title": "MTA Developer API",
    "version": "1.0.0",
    "description": "MTA (Metropolitan Transportation Authority) developer API providing real-time GTFS-RT feeds for NYC subway, LIRR, Metro-North, and bus services, as well as static GTFS schedule data.",
    "x-jentic-source-url": "https://api.mta.info/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.mta.info",
      "description": "Real-time feeds"
    },
    {
      "url": "https://rrgtfsfeeds.s3.amazonaws.com",
      "description": "Static GTFS feeds"
    }
  ],
  "paths": {
    "/gtfs_subway.zip": {
      "get": {
        "operationId": "getSubwaySchedule",
        "summary": "Download subway GTFS schedule",
        "tags": [
          "Static GTFS"
        ],
        "responses": {
          "200": {
            "description": "GTFS ZIP file",
            "content": {
              "application/zip": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        },
        "description": "Download subway GTFS schedule"
      }
    },
    "/gtfs_supplemented.zip": {
