    },
    "/messageheaders": {
      "get": {
        "summary": "List Message Headers",
        "operationId": "listMessageHeaders",
        "description": "Retrieve message headers with filtering options",
        "servers": [
          {
            "url": "https://api.esendex.com/v1.0"
          }
        ],
        "parameters": [
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by recipient phone number"
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by sender"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "Sent",
                "Delivered",
                "Failed",
                "Pending"
              ]
            },
            "description": "Filter by message status"
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start date for filtering"
          },
          {
            "name": "finish",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End date for filtering"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageHeader"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "messageheaders"
        ]
      }
    },
    "/messageheaders/{id}": {
      "get": {
        "summary": "Get Message Header",
        "operationId": "getMessageHeader",
        "description": "Retrieve a single message header by ID",
        "servers": [
