  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Base64-encoded username:password"
      },
      "primaryKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Primary Key from developer profile"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      },
      "MessageDispatchRequest": {
        "type": "object",
        "required": [
          "accountreference",
          "messages"
        ],
        "properties": {
          "accountreference": {
            "type": "string"
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "to": {
                  "type": "string",
                  "description": "E.164 format phone number"
                },
                "body": {
                  "type": "string"
                },
                "from": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "SMS",
                    "Voice"
                  ]
                },
                "sendAt": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      },
      "MessageDispatchResponse": {
        "type": "object",
        "properties": {
          "batchid": {
            "type": "string"
          },
          "messageids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "MessageInformationRequest": {
        "type": "object",
        "properties": {
          "body": {
            "type": "string"
          }
        }
      },
      "MessageInformationResponse": {
        "type": "object",
        "properties": {
          "charactercount": {
            "type": "integer"
          },
          "messagecount": {
            "type": "integer"
          },
          "encoding": {
            "type": "string"
          }
        }
      },
      "MessageHeader": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "sentat": {
            "type": "string",
            "format": "date-time"
          },
          "deliveredat": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "InboxMessage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "receivedat": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ConversationMessage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "direction": {
            "type": "string",
            "enum": [
              "Inbound",
              "Outbound"
            ]
          },
          "body": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MessageBatch": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "createdat": {
            "type": "string",
            "format": "date-time"
          },
          "messagecount": {
            "type": "integer"
          }
        }
      },
      "RichContentRequest": {
        "type": "object",
        "required": [
          "accountReference",
          "channels",
          "recipient",
          "content"
        ],
        "properties": {
          "accountReference": {
            "type": "string"
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "SMS",
                "RCS",
                "WhatsApp"
              ]
            }
          },
          "recipient": {
            "type": "object",
            "properties": {
              "address": {
                "type": "string"
              },
              "variables": {
                "type": "object"
              }
            }
          },
          "content": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "templateId": {
                "type": "string"
              }
            }
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "RichContentResponse": {
        "type": "object",
        "properties": {
          "gatewayId": {
            "type": "string"
          }
        }
      },
      "RichContentMessageStatus": {
        "type": "object",
        "properties": {
          "status": {
