{
  "openapi": "3.0.3",
  "info": {
    "title": "Linear API",
    "version": "1.0",
    "description": "Linear project management GraphQL API",
    "x-jentic-source-url": "https://developers.linear.app/docs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.linear.app"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "paths": {
    "/graphql": {
      "post": {
        "summary": "Execute GraphQL query",
        "operationId": "ExecuteGraphQLquery",
        "tags": [
          "GraphQL"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Execute GraphQL query"
      }
    }
  },
  "tags": [
    {
      "name": "GraphQL"
    }
  ]
}
