{
  "openapi": "3.0.3",
  "info": {
    "title": "NoiseAware API",
    "version": "1.1.0",
    "description": "NoiseAware API for property noise monitoring, event management, user management, and threshold configuration.",
    "x-jentic-source-url": "https://noiseaware.readme.io/reference",
    "contact": {}
