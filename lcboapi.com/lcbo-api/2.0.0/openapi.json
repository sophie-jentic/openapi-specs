  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API access key. Pass as 'Token <your_key>' in the Authorization header."
      }
    },
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "LCBO product number"
          },
          "is_dead": {
            "type": "boolean",
            "description": "Whether the product has been removed from the catalog"
          },
          "name": {
            "type": "string"
          },
          "tags": {
            "type": "string",
            "description": "Space-separated tags"
          },
          "is_discontinued": {
            "type": "boolean"
          },
          "price_in_cents": {
            "type": "integer"
          },
          "regular_price_in_cents": {
            "type": "integer"
          },
          "limited_time_offer_savings_in_cents": {
            "type": "integer"
          },
          "limited_time_offer_ends_on": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "bonus_reward_miles": {
            "type": "integer"
          },
          "bonus_reward_miles_ends_on": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "stock_type": {
            "type": "string"
          },
          "primary_category": {
            "type": "string"
          },
          "secondary_category": {
            "type": "string"
          },
          "tertiary_category": {
            "type": "string"
          },
          "origin": {
            "type": "string"
          },
          "package": {
            "type": "string"
          },
          "package_unit_type": {
            "type": "string"
          },
          "package_unit_volume_in_milliliters": {
            "type": "integer"
          },
          "total_package_units": {
            "type": "integer"
          },
          "total_package_volume_in_milliliters": {
            "type": "integer"
          },
          "volume_in_milliliters": {
            "type": "integer"
          },
          "alcohol_content": {
            "type": "integer",
            "description": "Alcohol content in tenths of a percent (e.g., 1250 = 12.5%)"
          },
          "price_per_liter_of_alcohol_in_cents": {
            "type": "integer"
          },
          "price_per_liter_in_cents": {
            "type": "integer"
          },
          "inventory_count": {
