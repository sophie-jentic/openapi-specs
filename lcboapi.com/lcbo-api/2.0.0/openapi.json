{
  "openapi": "3.0.3",
  "info": {
    "title": "LCBO API",
    "description": "API providing access to the Liquor Control Board of Ontario (LCBO) product catalog, store locations, inventory levels, producer information, category data, and dataset snapshots.",
    "version": "2.0.0",
    "contact": {
      "name": "LCBO API",
      "url": "https://lcboapi.com"
    },
    "x-jentic-source-url": "https://lcboapi.com/"
  },
  "servers": [
    {
      "url": "https://lcboapi.com",
      "description": "LCBO API Production"
    }
  ],
  "tags": [
    {
      "name": "Products",
      "description": "Browse and search LCBO product catalog"
    },
    {
      "name": "Stores",
      "description": "Browse and search LCBO store locations"
    },
    {
      "name": "Inventories",
      "description": "Product inventory at specific store locations"
    },
    {
      "name": "Producers",
      "description": "Product producers and wineries"
    },
    {
      "name": "Categories",
      "description": "Product categories"
    },
    {
      "name": "Datasets",
      "description": "Periodic data snapshots"
    }
  ],
  "paths": {
    "/products": {
      "get": {
        "tags": ["Products"],
        "summary": "List or search products",
        "description": "Returns a paginated list of LCBO products. Supports full-text search, filtering, and sorting.",
        "operationId": "listProducts",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Full-text search query for product name, keywords, or tags",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 50
            }
          },
          {
            "name": "where",
            "in": "query",
            "description": "Filter expression (e.g., is_dead, is_discontinued, is_kosher, is_vqa, is_ocb, has_value_added_promotion, has_limited_time_offer, has_bonus_reward_miles, has_clearance_sale, is_seasonal)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "where_not",
            "in": "query",
            "description": "Negative filter expression",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort order (e.g., price_in_cents.asc, price_in_cents.desc, name.asc, inventory_count.desc)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "store_id",
            "in": "query",
            "description": "Filter products available at a specific store",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer"
                    },
                    "message": {
                      "type": "string",
                      "nullable": true
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Product"
                      }
                    },
                    "pager": {
                      "$ref": "#/components/schemas/Pager"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get product by ID",
        "description": "Retrieve detailed information about a specific product.",
        "operationId": "getProduct",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Product ID (LCBO product number)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer"
                    },
                    "message": {
                      "type": "string",
                      "nullable": true
                    },
                    "result": {
                      "$ref": "#/components/schemas/Product"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/stores": {
      "get": {
        "tags": ["Stores"],
        "summary": "List or search stores",
        "description": "Returns a paginated list of LCBO retail stores. Supports geographic and text search.",
