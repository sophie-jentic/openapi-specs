{
  "openapi": "3.0.3",
  "info": {
    "title": "Spiky API V2",
    "description": "Spiky API V2 provides programmatic access to Spiky's meeting analysis platform.\n\nHow to use:\n  1. Open a Spiky account\n  2. Get authentication tokens\n  3. Send POST /platform/meeting-reports for fetching upload URLs. The integration name must be given \"MANUALTIMELINE\" for manual timeline upload flow.\n  4. Upload timeline file to S3 via given signed URL (if manual timeline flow is selected)\n  5. Upload a video or audio file to the given URL\n  6. Analysis will start by itself\n  7. GET /platform/meeting-reports/<analysis-id> can be used for getting the latest status of the meeting. \"analysisStatus\" will be set as \"ANALYSIS_READY\" if analysis is finished.\n  8. GET /platform/ml-data/<analysis-id> can be used for getting the ML data\n  9. POST /platform/public/token/refresh can be used for refreshing the token.",
    "version": "2.0.0",
    "termsOfService": "https://spiky.ai/terms-of-service",
    "contact": {
      "email": "info@spiky.ai"
    },
    "x-jentic-source-url": "https://api-docs.spiky.ai/openapi3_1.yaml"
  },
  "servers": [
    {
      "url": "https://apiv2.spiky.ai"
    }
  ],
  "tags": [
    {
      "name": "authorization",
      "description": "Authorization operations"
    },
    {
      "name": "meeting-reports",
      "description": "Meeting Report Endpoints"
    },
    {
      "name": "ml-data",
      "description": "Machine learning model outputs"
    }
  ],
  "paths": {
    "/public/token": {
      "post": {
        "tags": [
          "authorization"
        ],
        "summary": "Get an authorization token",
        "operationId": "getToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CredentialInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CredentialOutput"
                }
              }
            }
          }
        },
        "security": [],
        "description": "Get an authorization token"
      }
    },
    "/public/token/refresh": {
      "post": {
        "tags": [
          "authorization"
        ],
        "summary": "Refresh an authorization token",
        "operationId": "refreshToken",
        "responses": {
          "200": {
            "description": "Token refreshed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CredentialOutput"
                }
              }
            }
          }
        },
        "description": "Refresh an authorization token"
      }
    },
    "/platform/meeting-reports": {
      "post": {
        "tags": [
          "meeting-reports"
        ],
        "summary": "Create a new analysis",
        "operationId": "createAnalysis",
        "requestBody": {
          "description": "Create a new analysis",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalysisInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Analysis"
                }
              }
            }
          }
        },
        "description": "Create a new analysis"
      },
      "get": {
        "tags": [
          "meeting-reports"
        ],
        "summary": "List analyses",
        "operationId": "listAnalyses",
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Analysis"
                  }
                }
              }
            }
          }
        },
        "description": "List analyses"
      }
    },
    "/platform/meeting-reports/{analysisId}": {
      "get": {
        "tags": [
          "meeting-reports"
        ],
        "summary": "Get an analysis by ID",
        "operationId": "getAnalysis",
        "parameters": [
          {
            "name": "analysisId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "The unique identifier of the analysis"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Analysis"
                }
              }
            }
          }
        },
        "description": "Get an analysis by ID"
      }
    },
    "/platform/ml-data/{analysisId}": {
      "get": {
        "tags": [
          "ml-data"
        ],
        "summary": "Get ML data for an analysis",
        "operationId": "getMLData",
        "parameters": [
          {
            "name": "analysisId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "The unique identifier of the analysis"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArrayOfMLData"
                }
              }
            }
          }
        },
        "description": "Get ML data for an analysis"
      }
    }
  },
  "components": {
    "schemas": {
      "AnalysisInput": {
        "type": "object",
        "properties": {
          "meetingName": {
            "type": "string"
          },
          "meetingDate": {
            "type": "string"
          },
          "integrationName": {
            "type": "string",
            "description": "Use 'MANUALTIMELINE' for manual timeline upload flow"
          }
        }
      },
      "Analysis": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "meetingName": {
            "type": "string"
          },
          "meetingDate": {
            "type": "string"
          },
          "ownerID": {
            "type": "string"
          },
          "analysisStatus": {
            "type": "string",
            "enum": [
              "UPLOAD_IN_PROGRESS",
              "UPLOAD_ERROR",
              "ANALYSIS_IN_PROGRESS",
              "ANALYSIS_ERROR",
              "ANALYSIS_READY",
              "CANCELLED"
            ]
          },
          "timelineUploadURL": {
            "type": "string",
            "format": "uri"
          },
          "s3UploadURL": {
            "type": "string",
            "format": "uri"
          },
          "isSample": {
            "type": "boolean"
          },
          "failureMessage": {
            "type": "string"
          }
        }
      },
      "MLData": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "mlDataID": {
            "type": "string",
            "enum": [
              "faceAttention",
              "faceEmotion",
              "generalSummary",
              "languageAveragePatience",
              "languageControlLevel",
              "languageEmotion",
              "languageFillerWords",
              "languageHedgingWords",
              "languageInteraction",
              "languageLongestPatience",
              "languageNextStep",
              "languagePerceivedStatus",
              "languagePositivity",
              "languageQuestionRatio",
              "languageQuestionStats",
              "languageTalkRatio",
              "languageTalkingInteraction",
              "languageTalkingSpeed",
              "meetingFeedback",
              "meetingSpeakIntervals",
              "meetingTranscript",
              "moments",
              "momentsPeopleOverview",
              "participants",
              "questionInsight",
              "spikyScore",
              "transcriptLanguage",
              "voiceEmotion",
              "voiceEnergy"
            ]
          },
          "mlData": {
            "type": "object"
          }
        }
      },
      "ArrayOfMLData": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/MLData"
        }
      },
      "CredentialInput": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "CredentialOutput": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "AccessToken": {
                "type": "string"
              },
              "ExpiresIn": {
                "type": "integer"
              },
              "TokenType": {
                "type": "string"
              },
              "RefreshToken": {
                "type": "string"
              },
              "IDToken": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearer_auth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearer_auth": []
    }
  ]
}
