{
  "openapi": "3.0.3",
  "info": {
    "title": "Arize Phoenix API",
    "version": "1.0.0",
    "description": "Arize Phoenix (AX) is an AI observability and evaluation platform. Provides REST API for managing traces, spans, datasets, experiments, evaluations, and annotations for LLM applications.",
    "x-jentic-source-url": "https://docs.arize.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://app.phoenix.arize.com"
    }
