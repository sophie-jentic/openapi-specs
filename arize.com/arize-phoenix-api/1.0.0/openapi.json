  "components": {
    "schemas": {
      "Dataset": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "example_count": {
            "type": "integer"
          }
        }
      },
      "CreateDatasetRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "DatasetListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Dataset"
            }
          }
        }
      },
      "DatasetExample": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "input": {
            "type": "object"
          },
          "output": {
            "type": "object"
          },
          "metadata": {
            "type": "object"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ExampleListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DatasetExample"
            }
          }
        }
      },
      "DatasetVersion": {
        "type": "object",
        "properties": {
          "version_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Experiment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "dataset_id": {
            "type": "string"
          },
          "dataset_version_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "repetitions": {
            "type": "integer"
          },
          "metadata": {
            "type": "object"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateExperimentRequest": {
        "type": "object",
        "required": [
          "dataset_id"
        ],
        "properties": {
          "dataset_id": {
            "type": "string"
          },
          "dataset_version_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "repetitions": {
            "type": "integer",
            "default": 1
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "ExperimentListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Experiment"
            }
          }
        }
      },
      "SpanAnnotation": {
        "type": "object",
        "properties": {
          "span_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "annotator_kind": {
            "type": "string",
            "enum": [
              "LLM",
              "HUMAN"
            ]
          },
          "result": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "score": {
                "type": "number"
              },
              "explanation": {
                "type": "string"
              }
            }
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "TraceAnnotation": {
        "type": "object",
        "properties": {
          "trace_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "annotator_kind": {
            "type": "string",
            "enum": [
              "LLM",
              "HUMAN"
            ]
          },
          "result": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "score": {
                "type": "number"
              },
              "explanation": {
                "type": "string"
              }
            }
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Phoenix API key"
      }
    }
  },
