{
  "openapi": "3.0.3",
  "info": {
    "title": "Detect Language API",
    "description": "Language detection API that detects the language of a given text. Supports 216 languages with confidence scores and reliability indicators. Handles long texts, short phrases, and single words.",
    "version": "0.2",
    "contact": {
      "name": "Detect Language",
      "url": "https://detectlanguage.com/"
    }
  },
  "servers": [
    {
      "url": "https://ws.detectlanguage.com/0.2"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/detect": {
      "post": {
        "operationId": "detectLanguage",
        "summary": "Detect language of text",
        "description": "Detects the language of the provided text. Returns language code, confidence score, and reliability flag.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "q"
                ],
                "properties": {
                  "q": {
                    "type": "string",
                    "description": "Text to detect language for. Must be UTF-8 encoded."
                  }
                }
              },
              "example": {
                "q": "Hello, how are you?"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "q"
                ],
                "properties": {
                  "q": {
                    "type": "string",
                    "description": "Text to detect language for. Must be UTF-8 encoded."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful detection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetectionResponse"
                },
                "example": {
                  "data": {
                    "detections": [
                      {
                        "language": "en",
                        "isReliable": true,
                        "confidence": 11.94
                      }
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "403": {
            "description": "Forbidden - Account suspended or daily limit exceeded"
          }
        },
        "tags": [
          "detect"
        ]
      }
    },
    "/detect/batch": {
      "post": {
        "operationId": "detectLanguageBatch",
        "summary": "Detect language of multiple texts",
        "description": "Detects the language of multiple texts in a single request. Each text in the batch is counted as a separate request.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "q"
                ],
                "properties": {
                  "q": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of texts to detect language for."
                  }
                }
              },
              "example": {
                "q": [
                  "Hello, how are you?",
                  "Bonjour, comment allez-vous?"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful batch detection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchDetectionResponse"
                },
                "example": {
                  "data": {
                    "detections": [
                      [
                        {
                          "language": "en",
                          "isReliable": true,
                          "confidence": 11.94
                        }
                      ],
                      [
                        {
                          "language": "fr",
                          "isReliable": true,
                          "confidence": 17.85
                        }
                      ]
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "403": {
            "description": "Forbidden - Account suspended or daily limit exceeded"
          }
        },
        "tags": [
          "detect"
        ]
      }
    },
    "/user/status": {
      "get": {
        "operationId": "getUserStatus",
        "summary": "Get account status",
        "description": "Returns information about the current account including usage statistics, plan details, and limits.",
        "responses": {
          "200": {
            "description": "Successful response with account status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserStatusResponse"
                },
                "example": {
                  "date": "2024-01-15",
                  "requests": 1250,
                  "bytes": 54321,
                  "plan": "free",
                  "plan_expires": null,
                  "daily_requests_limit": 1000,
                  "daily_bytes_limit": 1048576,
                  "status": "ACTIVE"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        },
        "tags": [
          "user"
        ]
      }
    },
    "/languages": {
      "get": {
        "operationId": "listLanguages",
        "summary": "List supported languages",
        "description": "Returns a list of all supported languages with their codes and names.",
        "responses": {
          "200": {
            "description": "List of supported languages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Language"
                  }
                },
                "example": [
                  {
                    "code": "en",
                    "name": "ENGLISH"
                  },
                  {
                    "code": "fr",
                    "name": "FRENCH"
                  }
                ]
              }
            }
          }
        },
        "tags": [
          "languages"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key passed as a Bearer token in the Authorization header."
      }
    },
    "schemas": {
      "Detection": {
        "type": "object",
        "properties": {
          "language": {
            "type": "string",
            "description": "ISO 639-1 language code."
          },
          "isReliable": {
            "type": "boolean",
            "description": "Whether the detection is considered reliable."
          },
          "confidence": {
            "type": "number",
            "format": "double",
            "description": "Confidence score for the detection. Values can exceed 100."
          }
        }
      },
      "DetectionResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "detections": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Detection"
                }
              }
            }
          }
        }
      },
      "BatchDetectionResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "detections": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Detection"
                  }
                }
              }
            }
          }
        }
      },
      "UserStatusResponse": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "description": "Current date."
          },
          "requests": {
            "type": "integer",
            "description": "Number of requests made today."
          },
          "bytes": {
            "type": "integer",
            "description": "Number of bytes processed today."
          },
          "plan": {
            "type": "string",
            "description": "Current plan name."
          },
          "plan_expires": {
            "type": "string",
            "nullable": true,
            "description": "Plan expiration date, if applicable."
          },
          "daily_requests_limit": {
            "type": "integer",
            "description": "Daily request limit."
          },
          "daily_bytes_limit": {
            "type": "integer",
            "description": "Daily byte limit."
          },
          "status": {
            "type": "string",
            "description": "Account status (e.g., ACTIVE, SUSPENDED)."
          }
        }
      },
      "Language": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "ISO 639-1 language code."
          },
          "name": {
            "type": "string",
            "description": "Language name."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "detect"
    },
    {
      "name": "languages"
    },
    {
      "name": "user"
    }
  ]
}
