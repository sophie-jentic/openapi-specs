{
  "openapi": "3.0.3",
  "info": {
    "title": "Lexamica API",
    "version": "1.0.0",
    "description": "Lexamica API for legal document automation and case management",
    "x-jentic-source-url": "https://docs.lexamica.com",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.lexamica.com/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "OAuth2": []
    }
  ],
  "paths": {
    "/version": {
      "get": {
        "summary": "Get API version",
        "description": "Retrieve the current API version information",
        "operationId": "getVersion",
        "tags": [
          "General"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Version information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "version": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/cases": {
      "get": {
        "summary": "List cases",
        "description": "Retrieve a list of legal cases",
        "operationId": "listCases",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "List of cases"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create case",
        "description": "Create a new legal case",
        "operationId": "createCase",
        "tags": [
          "Cases"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Case created"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cases/{id}": {
      "get": {
        "summary": "Get case",
        "description": "Retrieve a specific case by ID",
        "operationId": "getCase",
        "tags": [
          "Cases"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Case details"
          },
          "404": {
            "description": "Case not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update case",
        "description": "Update an existing case",
        "operationId": "updateCase",
        "tags": [
          "Cases"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Case updated"
          }
        }
      }
    },
    "/referrals": {
      "get": {
        "summary": "List referrals",
        "description": "Retrieve a list of case referrals",
        "operationId": "listReferrals",
        "tags": [
          "Referrals"
        ],
        "responses": {
          "200": {
            "description": "List of referrals"
          }
        }
      },
      "post": {
        "summary": "Create referral",
        "description": "Create a new case referral",
        "operationId": "createReferral",
        "tags": [
          "Referrals"
        ],
        "responses": {
          "201": {
            "description": "Referral created"
          }
        }
      }
    },
    "/documents": {
      "get": {
        "summary": "List documents",
        "description": "Retrieve a list of legal documents",
        "operationId": "listDocuments",
        "tags": [
          "Documents"
        ],
        "responses": {
          "200": {
            "description": "List of documents"
          }
        }
      },
      "post": {
        "summary": "Create document",
        "description": "Create a new legal document",
        "operationId": "createDocument",
        "tags": [
          "Documents"
        ],
        "responses": {
          "201": {
            "description": "Document created"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "description": "OAuth 2.0 authentication with granular scopes and IP filtering",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://api.lexamica.com/oauth/authorize",
            "tokenUrl": "https://api.lexamica.com/oauth/token",
            "scopes": {
              "read": "Read access",
              "write": "Write access"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Cases"
    },
    {
      "name": "Documents"
    },
    {
      "name": "General"
    },
    {
      "name": "Referrals"
    }
  ]
}
