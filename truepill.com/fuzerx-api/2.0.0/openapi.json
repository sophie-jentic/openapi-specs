{
  "openapi": "3.0.3",
  "info": {
    "title": "FuzeRx API",
    "version": "2.0.0",
    "description": "FuzeRx (formerly Truepill) provides pharmacy fulfillment APIs for patient management, prescriptions, transfers, and webhook events.",
    "x-jentic-source-url": "https://rxdocs.fuzehealth.com/index.html",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.truepill.com"
    }
  ],
  "paths": {
    "/v1/patient": {
      "put": {
        "operationId": "createPatient",
        "summary": "Create a patient",
        "tags": [
          "Patients"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePatientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Patient created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatientResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create a patient"
      },
      "get": {
        "operationId": "findPatient",
        "summary": "Find a patient by demographics",
        "tags": [
          "Patients"
        ],
        "parameters": [
          {
            "name": "first_name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "last_name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dob",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "gender",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "zip",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Patient found"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Find a patient by demographics"
      }
    },
    "/v1/patient/{patient_token}": {
      "get": {
        "operationId": "getPatient",
        "summary": "Get a patient",
        "tags": [
          "Patients"
        ],
        "parameters": [
          {
            "name": "patient_token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get a patient"
      },
      "post": {
        "operationId": "updatePatient",
        "summary": "Update a patient",
        "tags": [
          "Patients"
        ],
        "parameters": [
          {
            "name": "patient_token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePatientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update a patient"
      }
    },
    "/v1/patient/{patient_token}/prescriptions": {
      "get": {
        "operationId": "getPatientPrescriptions",
        "summary": "Get patient prescriptions",
        "tags": [
          "Prescriptions"
        ],
        "parameters": [
          {
            "name": "patient_token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get patient prescriptions"
      }
    },
    "/v1/prescription/{prescription_token}": {
      "get": {
        "operationId": "getPrescription",
        "summary": "Get a prescription",
        "tags": [
          "Prescriptions"
        ],
        "parameters": [
          {
            "name": "prescription_token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get a prescription"
      }
    },
    "/v1/transfer_request": {
      "post": {
        "operationId": "createTransfer",
        "summary": "Create a transfer request",
        "tags": [
          "Transfers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTransferRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a transfer request"
      },
      "get": {
        "operationId": "listTransfers",
        "summary": "List transfer requests",
        "tags": [
          "Transfers"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List transfer requests"
      }
    },
    "/v1/transfer_request/{transfer_token}": {
      "get": {
        "operationId": "getTransfer",
        "summary": "Get a transfer",
        "tags": [
          "Transfers"
        ],
        "parameters": [
          {
            "name": "transfer_token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get a transfer"
      }
    },
    "/v1/direct_transfer": {
      "post": {
        "operationId": "createDirectTransfer",
        "summary": "Create a direct transfer",
        "tags": [
          "Transfers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a direct transfer"
      }
    },
    "/v2/direct_transfer": {
      "post": {
        "operationId": "createDirectTransferV2",
        "summary": "Create a direct transfer v2",
        "tags": [
          "Transfers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a direct transfer v2"
      }
    },
    "/v1/webhook_events/{webhook_type}": {
      "get": {
        "operationId": "getWebhookEvents",
        "summary": "Get webhook events",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "webhook_type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "notify_rx"
              ]
            }
          },
          {
            "name": "next",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get webhook events"
      }
    }
  },
  "components": {
    "schemas": {
      "CreatePatientRequest": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "dob",
          "gender"
        ],
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "dob": {
            "type": "string",
            "format": "date"
          },
          "gender": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "zip": {
            "type": "string"
          },
          "street1": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          }
        }
      },
      "UpdatePatientRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "zip": {
            "type": "string"
          },
          "street1": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          }
        }
      },
      "PatientResponse": {
        "type": "object",
        "properties": {
          "patient_token": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "CreateTransferRequest": {
        "type": "object",
        "required": [
          "patient_token"
        ],
        "properties": {
          "patient_token": {
            "type": "string"
          },
          "pharmacy_name": {
            "type": "string"
          },
          "pharmacy_phone": {
            "type": "string"
          },
          "prescriber_name": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "ApiKey YOUR_API_KEY"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Patients"
    },
    {
      "name": "Prescriptions"
    },
    {
      "name": "Transfers"
    },
    {
      "name": "Webhooks"
    }
  ]
}
