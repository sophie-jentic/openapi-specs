{
  "openapi": "3.1.0",
  "info": {
    "title": "Text-to-Speech (TTS)",
    "version": "1.0.0",
    "description": "Hume AI Text-to-Speech API powered by Octave. Synthesize speech, manage voices, and convert voice audio.",
    "x-jentic-source-url": "https://dev.hume.ai/openapi.json?api=9416cf4b-0067-49e4-aca6-076148299f53",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.hume.ai"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v0/tts": {
      "post": {
        "operationId": "synthesize-json",
        "summary": "Text-to-Speech (Json)",
        "description": "Synthesizes one or more input texts into speech using the specified voice. If no voice is provided, a novel voice will be generated dynamically.",
        "tags": [
          "TTS"
        ],
        "parameters": [
          {
            "name": "X-Hume-Api-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OctaveBodyArgs"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OctaveResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v0/tts/file": {
      "post": {
        "operationId": "synthesize-file",
        "summary": "Text-to-Speech (File)",
        "description": "Synthesizes one or more input texts into speech. The response contains the generated audio file in the requested format.",
        "tags": [
          "TTS"
        ],
        "parameters": [
          {
            "name": "X-Hume-Api-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OctaveBodyArgs"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v0/tts/stream/json": {
      "post": {
        "operationId": "synthesize-json-streaming",
        "summary": "Text-to-Speech (Streamed JSON)",
        "description": "Streams synthesized speech using the specified voice. The response is a stream of JSON objects including audio encoded in base64.",
        "tags": [
          "TTS"
        ],
        "parameters": [
          {
            "name": "X-Hume-Api-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OctaveBodyArgs"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response - streamed audio",
            "content": {
              "text/event-stream": {
                "schema": {
                  "$ref": "#/components/schemas/TtsOutput"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v0/tts/stream/file": {
      "post": {
        "operationId": "synthesize-file-streaming",
        "summary": "Text-to-Speech (Streamed File)",
        "description": "Streams synthesized speech using the specified voice as a binary file stream.",
        "tags": [
          "TTS"
        ],
        "parameters": [
          {
            "name": "X-Hume-Api-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OctaveBodyArgs"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK - streaming audio",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v0/tts/voices": {
      "post": {
        "operationId": "create-voice",
        "summary": "Create voice",
        "description": "Saves a new custom voice to your account using the specified TTS generation ID.",
        "tags": [
          "Voices"
        ],
        "parameters": [
          {
            "name": "X-Hume-Api-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OctaveVoiceDesignSaveArgs"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Voice created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OctaveVoiceDesignSaveResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "list-voices",
        "summary": "List voices",
        "description": "Lists voices you have saved in your account, or voices from the Voice Library.",
        "tags": [
          "Voices"
        ],
        "parameters": [
          {
            "name": "provider",
            "in": "query",
            "description": "Specify the voice provider: HUME_AI or CUSTOM_VOICE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "HUME_AI",
                "CUSTOM_VOICE"
              ]
            }
          },
          {
            "name": "page_number",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "X-Hume-Api-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of voices",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedVoices"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "delete-voice",
        "summary": "Delete voice",
        "description": "Deletes a previously generated custom voice.",
        "tags": [
          "Voices"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Name of the voice to delete",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Hume-Api-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Voice deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v0/tts/voice_conversion/file": {
      "post": {
        "operationId": "convert-voice-file",
        "summary": "Voice Conversion (Streamed File)",
        "description": "Converts uploaded audio to the target voice, returning a streamed file.",
        "tags": [
          "Voice Conversion"
        ],
        "parameters": [
          {
            "name": "X-Hume-Api-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "audio"
                ],
                "properties": {
                  "audio": {
                    "type": "string",
                    "format": "binary",
                    "description": "Audio file to convert. Supported: MP3, WAV, M4A, OGG."
                  },
                  "voice": {
                    "$ref": "#/components/schemas/VoiceRef"
                  },
                  "format": {
                    "$ref": "#/components/schemas/Format"
                  },
                  "strip_headers": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Converted audio file",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Hume-Api-Key"
      }
    },
    "schemas": {
      "Utterance": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "description": "The input text to be synthesized."
          },
          "description": {
            "type": "string",
            "description": "Natural language instructions for how speech should sound."
          },
          "speed": {
            "type": "number",
            "default": 1,
            "description": "Speed multiplier for synthesized speech."
          },
          "trailing_silence": {
            "type": "number",
            "default": 0,
            "description": "Duration of trailing silence in seconds."
          },
          "voice": {
            "$ref": "#/components/schemas/VoiceRef"
          }
        }
      },
      "VoiceProvider": {
        "type": "string",
        "enum": [
          "HUME_AI",
          "CUSTOM_VOICE"
        ]
      },
      "VoiceId": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "provider": {
            "$ref": "#/components/schemas/VoiceProvider"
          }
        }
      },
      "VoiceName": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "provider": {
            "$ref": "#/components/schemas/VoiceProvider"
          }
        }
      },
      "VoiceRef": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/VoiceId"
          },
          {
            "$ref": "#/components/schemas/VoiceName"
          }
        ]
      },
      "Format": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "mp3"
                ]
              }
            },
            "required": [
              "type"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "pcm"
                ]
              }
            },
            "required": [
              "type"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "wav"
                ]
              }
            },
            "required": [
              "type"
            ]
          }
        ]
      },
      "OctaveBodyArgs": {
        "type": "object",
        "required": [
          "utterances"
        ],
        "properties": {
          "utterances": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Utterance"
            },
            "description": "A list of utterances to be converted to speech."
          },
          "format": {
            "$ref": "#/components/schemas/Format"
          },
          "num_generations": {
            "type": "integer",
            "default": 1
          },
          "split_utterances": {
            "type": "boolean",
            "default": true
          },
          "strip_headers": {
            "type": "boolean",
            "default": false
          },
          "version": {
            "type": "string",
            "enum": [
              "1",
              "2"
            ]
          },
          "instant_mode": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "OctaveResponse": {
        "type": "object",
        "required": [
          "generations",
          "request_id"
        ],
        "properties": {
          "generations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Generation"
            }
          },
          "request_id": {
            "type": "string"
          }
        }
      },
      "Generation": {
        "type": "object",
        "properties": {
          "audio": {
            "type": "string",
            "description": "Base64-encoded audio output."
          },
          "duration": {
            "type": "number"
          },
          "generation_id": {
            "type": "string"
          },
          "file_size": {
            "type": "integer"
          },
          "snippets": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Snippet"
              }
            }
          }
        }
      },
      "Snippet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "generation_id": {
            "type": "string"
          },
          "audio": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "utterance_index": {
            "type": "integer"
          }
        }
      },
      "TtsOutput": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "audio",
              "timestamp"
            ]
          },
          "audio": {
            "type": "string"
          },
          "generation_id": {
            "type": "string"
          },
          "snippet_id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      },
      "OctaveVoiceDesignSaveArgs": {
        "type": "object",
        "required": [
          "generation_id",
          "name"
        ],
        "properties": {
          "generation_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "OctaveVoiceDesignSaveResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "provider": {
            "$ref": "#/components/schemas/VoiceProvider"
          }
        }
      },
      "PagedVoices": {
        "type": "object",
        "properties": {
          "page_number": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          },
          "total_pages": {
            "type": "integer"
          },
          "voices_page": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "provider": {
                  "$ref": "#/components/schemas/VoiceProvider"
                }
              }
            }
          }
        }
      },
      "HTTPValidationError": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "loc": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "msg": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "TTS"
    },
    {
      "name": "Voice Conversion"
    },
    {
      "name": "Voices"
    }
  ]
}
