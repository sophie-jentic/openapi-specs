{
  "openapi": "3.0.3",
  "info": {
    "title": "Census Data API",
    "version": "1.0.0",
    "description": "The U.S. Census Bureau Data API provides access to over 1,700 datasets of Census data including the American Community Survey, Decennial Census, Economic Census, Population Estimates, and more. Data is queried by specifying a dataset, variables (columns), and geographic filters.",
    "x-jentic-source-url": "https://www.census.gov/data/developers/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.census.gov/data"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "listDatasets",
        "summary": "List Available Datasets",
        "description": "Returns a catalog of all available Census API datasets with their metadata, vintage years, and access URLs.",
        "tags": [
          "Discovery"
        ],
        "responses": {
          "200": {
            "description": "Dataset catalog",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetCatalog"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{year}/acs/acs5": {
      "get": {
        "operationId": "queryAcs5Year",
        "summary": "Query ACS 5-Year Estimates",
        "description": "Query the American Community Survey 5-Year Data. Returns detailed demographic, social, economic, and housing data down to the block-group level.",
        "tags": [
          "American Community Survey"
        ],
        "parameters": [
          {
            "name": "year",
            "in": "path",
            "required": true,
            "description": "Data vintage year (e.g. 2022)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "get",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of variable names to retrieve (e.g. NAME,B01001_001E)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "for",
            "in": "query",
            "required": true,
            "description": "Geography level to retrieve (e.g. state:*, county:*, tract:*)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "in",
            "in": "query",
            "required": false,
            "description": "Parent geography filter (e.g. state:06 for California)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "required": false,
            "description": "Your Census API key",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of arrays - first row is headers, subsequent rows are data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CensusDataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid variable or geography",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
