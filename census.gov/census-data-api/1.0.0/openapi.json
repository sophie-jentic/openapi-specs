              "type": "string"
            }
          },
          {
            "name": "for",
            "in": "query",
            "required": false,
            "description": "Country FIPS code filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "YR",
            "in": "query",
            "required": false,
            "description": "Reference year",
            "schema": {
              "type": "string"
