  },
  "components": {
    "schemas": {
      "CensusDataResponse": {
        "type": "array",
        "description": "Array of arrays. First element is the header row with variable/geography names. Subsequent elements are data rows.",
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "DatasetCatalog": {
        "type": "object",
        "properties": {
          "dataset": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "c_vintage": {
                  "type": "integer",
                  "description": "Data vintage year"
                },
                "c_dataset": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "title": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "c_isAvailable": {
                  "type": "boolean"
                },
                "distribution": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      },
      "VariablesResponse": {
        "type": "object",
        "properties": {
          "variables": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string"
                },
                "concept": {
                  "type": "string"
                },
                "predicateType": {
                  "type": "string"
                },
                "group": {
                  "type": "string"
                },
                "limit": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "key",
        "in": "query",
        "description": "Census API key (optional for low-volume requests, required for higher rate limits)"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "American Community Survey"
    },
    {
      "name": "Decennial Census"
    },
    {
      "name": "Discovery"
    },
    {
      "name": "Economic Census"
    },
    {
      "name": "International"
    },
    {
      "name": "Population Estimates"
    }
  ]
}
