      "get": {
        "operationId": "listAcs5Variables",
        "summary": "List ACS 5-Year Variables",
        "description": "Returns metadata for all available variables in the ACS 5-Year dataset for a given year.",
        "tags": [
          "Discovery"
        ],
        "parameters": [
          {
            "name": "year",
            "in": "path",
