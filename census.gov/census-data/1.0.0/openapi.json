    "/data/{year}/acs/acs5/variables.json": {
      "get": {
        "operationId": "listAcs5Variables",
        "summary": "List ACS 5-Year variables",
        "description": "Returns the list of all available variables for the ACS 5-Year Estimates dataset.",
        "tags": [
