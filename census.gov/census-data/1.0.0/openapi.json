  "components": {
    "schemas": {
      "DatasetList": {
        "type": "object",
        "properties": {
          "dataset": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Dataset"
            }
          }
        }
      },
      "Dataset": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "vintage": {
            "type": "string"
          },
          "dataset_name": {
            "type": "string"
          },
          "dataset_type": {
            "type": "string"
          },
          "c_geographyLink": {
            "type": "string"
          },
          "c_variablesLink": {
            "type": "string"
          },
          "c_groupsLink": {
            "type": "string"
          },
          "distribution": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "accessURL": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Variable": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "concept": {
            "type": "string"
          },
          "predicateType": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
