            "description": "Geography level and filter"
          },
          {
            "name": "in",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Parent geography filter"
          },
          {
            "name": "key",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Census API key"
          }
        ],
        "responses": {
          "200": {
            "description": "Census data array",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
