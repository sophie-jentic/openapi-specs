          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/data/{year}/cbp": {
      "get": {
        "operationId": "queryCountyBusinessPatterns",
        "summary": "Query County Business Patterns",
        "description": "Query the County Business Patterns dataset providing economic data by industry at various geographic levels.",
        "tags": [
          "CBP"
        ],
        "parameters": [
          {
            "name": "year",
            "in": "path",
