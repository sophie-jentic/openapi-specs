  "paths": {
    "/articles": {
      "get": {
        "operationId": "listArticles",
        "summary": "List published articles",
        "description": "Retrieve a list of published articles with optional filtering by tag, username, or state.",
        "tags": [
          "articles"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page (max 1000)",
            "schema": {
              "type": "integer",
              "default": 30,
              "maximum": 1000
            }
          },
          {
            "name": "tag",
            "in": "query",
            "description": "Filter by tag",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tags",
            "in": "query",
            "description": "Filter by multiple tags (comma-separated)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tags_exclude",
            "in": "query",
            "description": "Exclude articles with these tags",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "query",
            "description": "Filter by author username",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "Filter by state",
            "schema": {
              "type": "string",
              "enum": [
                "fresh",
                "rising",
                "all"
              ]
            }
          },
          {
            "name": "top",
            "in": "query",
            "description": "Return top articles from the last N days",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "collection_id",
            "in": "query",
            "description": "Filter by collection/series ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of articles",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Article"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createArticle",
        "summary": "Create a new article",
        "description": "Publish or draft a new article.",
        "tags": [
          "articles"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ArticleCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Article created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Article"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          }
        },
        "security": [
          {
            "apiKey": []
          }
        ]
      }
    },
