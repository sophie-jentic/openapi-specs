    "version": "1.0.0",
    "contact": {
      "name": "Forem",
      "url": "https://developers.forem.com/api"
    },
    "license": {
      "name": "AGPL-3.0",
      "url": "https://github.com/forem/forem/blob/main/LICENSE.md"
    },
    "x-jentic-source-url": "https://developers.forem.com/api"
  },
  "servers": [
    {
      "url": "https://dev.to/api",
      "description": "Dev.to production API"
    }
  ],
  "tags": [
    {
      "name": "articles",
      "description": "Published articles and blog posts"
    },
    {
      "name": "comments",
      "description": "Article and podcast comments"
    },
    {
      "name": "users",
      "description": "User profiles and management"
    },
    {
      "name": "tags",
      "description": "Content tags"
    },
    {
      "name": "organizations",
      "description": "Organization profiles"
    },
    {
      "name": "followers",
      "description": "Follower relationships"
    },
    {
      "name": "follows",
      "description": "Follow relationships for tags"
    },
    {
      "name": "readinglist",
      "description": "User reading list"
    },
    {
      "name": "reactions",
      "description": "Reactions on content"
    },
    {
      "name": "podcasts",
      "description": "Podcast episodes"
    },
    {
      "name": "profile_images",
      "description": "User profile images"
    },
    {
      "name": "videos",
      "description": "Video articles"
    },
    {
      "name": "pages",
      "description": "Static pages (admin)"
    },
    {
      "name": "billboards",
      "description": "Billboard/ad management (admin)"
    },
    {
      "name": "segments",
      "description": "Audience segments (admin)"
    }
