{
  "openapi": "3.0.3",
  "info": {
    "title": "Bubble Data API",
    "description": "Bubble.io Data API for CRUD operations on database records (Things). The API base URL is per-app: https://{appname}.bubbleapps.io/api/1.1. The 'typename' path parameter represents the data type name. Also includes the Workflow API for triggering backend workflows.",
    "version": "1.1",
    "x-jentic-source-url": "https://manual.bubble.io/core-resources/api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{appname}.bubbleapps.io/api/1.1",
      "description": "Per-app Bubble API endpoint",
      "variables": {
        "appname": {
          "default": "myapp",
          "description": "Your Bubble application name."
        }
      }
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Data",
      "description": "CRUD operations on database records (Things)."
    },
    {
      "name": "Workflow",
      "description": "Trigger backend API workflows."
    }
  ],
  "paths": {
    "/obj/{typename}": {
      "get": {
        "tags": [
          "Data"
        ],
        "summary": "Search for Things",
        "description": "Returns a list of Things of the specified type, optionally filtered by constraints.",
        "operationId": "searchThings",
        "parameters": [
          {
            "name": "typename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The data type name."
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Starting index for pagination."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            },
            "description": "Maximum number of records to return (max 100)."
          },
          {
            "name": "sort_field",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Field to sort by."
          },
          {
            "name": "descending",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Sort in descending order."
          },
          {
            "name": "constraints",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "JSON array of constraint objects. Each constraint has 'key', 'constraint_type', and 'value'."
          }
        ],
        "responses": {
          "200": {
            "description": "Search results.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "object",
                      "properties": {
                        "cursor": {
                          "type": "integer"
                        },
                        "results": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Thing"
                          }
                        },
                        "count": {
                          "type": "integer"
                        },
                        "remaining": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "tags": [
          "Data"
        ],
        "summary": "Create a Thing",
        "description": "Creates a new record (Thing) of the specified data type.",
        "operationId": "createThing",
        "parameters": [
          {
            "name": "typename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Key-value pairs for the fields to set on the new Thing. Keys must match field names.",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Thing created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "id": {
                      "type": "string",
                      "description": "Unique ID of the created Thing."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - unrecognized field or invalid value."
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/obj/{typename}/bulk": {
      "post": {
        "tags": [
          "Data"
        ],
        "summary": "Bulk create Things",
        "description": "Creates multiple Things in bulk. Body should be plain text with one JSON object per line.",
        "operationId": "bulkCreateThings",
        "parameters": [
          {
            "name": "typename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "text/plain": {
              "schema": {
                "type": "string",
                "description": "One JSON object per line, each representing a Thing to create."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk creation result.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/obj/{typename}/{uid}": {
      "get": {
        "tags": [
          "Data"
        ],
        "summary": "Retrieve a Thing by ID",
        "description": "Returns a single Thing by its unique ID.",
        "operationId": "getThing",
        "parameters": [
          {
            "name": "typename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique ID of the Thing."
          }
        ],
        "responses": {
          "200": {
            "description": "Thing details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "$ref": "#/components/schemas/Thing"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Thing not found."
          }
        }
      },
      "patch": {
        "tags": [
          "Data"
        ],
        "summary": "Update a Thing",
        "description": "Updates specific fields on a Thing by its unique ID. Only the provided fields are changed.",
        "operationId": "updateThing",
        "parameters": [
          {
            "name": "typename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Key-value pairs of fields to update.",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Thing updated successfully."
          },
          "400": {
            "description": "Bad Request - unrecognized field."
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Thing not found."
          }
        }
      },
      "put": {
        "tags": [
          "Data"
        ],
        "summary": "Replace a Thing",
        "description": "Replaces all editable fields on a Thing. Fields not included will be reset to defaults.",
        "operationId": "replaceThing",
        "parameters": [
          {
            "name": "typename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Key-value pairs for all fields. Unspecified fields will be reset.",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Thing replaced successfully."
          },
          "400": {
            "description": "Bad Request - unrecognized field."
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Thing not found."
          }
        }
      },
      "delete": {
        "tags": [
          "Data"
        ],
        "summary": "Delete a Thing",
        "description": "Deletes a Thing by its unique ID.",
        "operationId": "deleteThing",
        "parameters": [
          {
            "name": "typename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Thing deleted successfully."
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Thing not found."
          }
        }
      }
    },
    "/wf/{workflow_name}": {
      "post": {
        "tags": [
          "Workflow"
        ],
        "summary": "Trigger an API Workflow",
        "description": "Triggers a backend API workflow by name. Parameters are passed in the request body.",
        "operationId": "triggerWorkflow",
        "parameters": [
          {
            "name": "workflow_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The name of the API workflow to trigger."
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Parameters defined in the API workflow.",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow executed and returned data.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Return data from the workflow.",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - invalid parameters or condition not met."
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Thing": {
        "type": "object",
        "description": "A database record (Thing) in Bubble. Fields vary per data type.",
        "properties": {
          "_id": {
            "type": "string",
            "description": "Unique ID of the Thing."
          },
          "Created By": {
            "type": "string"
          },
          "Created Date": {
            "type": "string",
            "format": "date-time"
          },
          "Modified Date": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": true
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bubble API token passed as a Bearer token."
      }
    }
  }
}
