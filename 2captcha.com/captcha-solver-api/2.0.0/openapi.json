{
  "openapi": "3.0.3",
  "info": {
    "title": "2Captcha API",
    "version": "2.0.0",
    "description": "2Captcha API v2 for solving captchas programmatically. Submit captcha tasks, retrieve results, check balance, and report solutions.",
    "x-jentic-source-url": "https://2captcha.com/api-docs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.2captcha.com"
    }
  ],
  "tags": [
    {
      "name": "Tasks",
      "description": "Create and retrieve captcha solving tasks"
    },
    {
      "name": "Account",
      "description": "Account-related operations"
    },
    {
      "name": "Reporting",
      "description": "Report task results as correct or incorrect"
    }
  ],
  "paths": {
    "/createTask": {
      "post": {
        "operationId": "createTask",
        "summary": "Create a captcha solving task",
        "description": "Submits a new captcha solving task. The task type determines what kind of captcha will be solved.",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getTaskResult": {
      "post": {
        "operationId": "getTaskResult",
        "summary": "Get the result of a task",
        "description": "Returns the result for a task. The result format depends on the task type. Poll this endpoint at least 5 seconds apart until the status is 'ready'.",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetTaskResultRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task result returned (may be processing or ready)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetTaskResultResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getBalance": {
      "post": {
        "operationId": "getBalance",
        "summary": "Get account balance",
        "description": "Returns the current account balance.",
        "tags": [
          "Account"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientKeyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Balance returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetBalanceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reportCorrect": {
      "post": {
        "operationId": "reportCorrect",
        "summary": "Report a correctly solved task",
        "description": "Report that a task was solved correctly. This helps improve the quality of the solving service.",
        "tags": [
          "Reporting"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Report submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reportIncorrect": {
      "post": {
        "operationId": "reportIncorrect",
        "summary": "Report an incorrectly solved task",
        "description": "Report that a task was solved incorrectly. May result in a refund depending on the task type.",
        "tags": [
          "Reporting"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Report submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ClientKeyRequest": {
        "type": "object",
        "required": [
          "clientKey"
        ],
        "properties": {
          "clientKey": {
            "type": "string",
            "description": "Your 2Captcha API key"
          }
        }
      },
      "CreateTaskRequest": {
        "type": "object",
        "required": [
          "clientKey",
          "task"
        ],
        "properties": {
          "clientKey": {
            "type": "string",
            "description": "Your 2Captcha API key"
          },
          "task": {
            "type": "object",
            "description": "Task object. The structure depends on the task type.",
            "properties": {
              "type": {
                "type": "string",
                "description": "The task type (e.g., ImageToTextTask, RecaptchaV2TaskProxyless, TurnstileTaskProxyless, etc.)"
              }
            },
            "additionalProperties": true
          },
          "softId": {
            "type": "integer",
            "description": "Optional software ID for developer rewards"
          },
          "callbackUrl": {
            "type": "string",
            "description": "Optional webhook URL to receive the result"
          }
        }
      },
      "CreateTaskResponse": {
        "type": "object",
        "properties": {
          "errorId": {
            "type": "integer",
            "description": "Error identifier. 0 means no error."
          },
          "taskId": {
            "type": "integer",
            "description": "Unique task identifier for retrieving results"
          }
        }
      },
      "GetTaskResultRequest": {
        "type": "object",
        "required": [
          "clientKey",
          "taskId"
        ],
        "properties": {
          "clientKey": {
            "type": "string",
            "description": "Your 2Captcha API key"
          },
          "taskId": {
            "type": "integer",
            "description": "The ID of the task to retrieve results for"
          }
        }
      },
      "GetTaskResultResponse": {
        "type": "object",
        "properties": {
          "errorId": {
            "type": "integer",
            "description": "Error identifier. 0 means no error."
          },
          "errorCode": {
            "type": "string",
            "description": "Error code string (e.g., ERROR_CAPTCHA_UNSOLVABLE)"
          },
          "errorDescription": {
            "type": "string",
            "description": "Human-readable error description"
          },
          "status": {
            "type": "string",
            "enum": [
              "processing",
              "ready"
            ],
            "description": "Task status. 'processing' means still working, 'ready' means complete."
          },
          "solution": {
            "type": "object",
            "description": "Solution object. Format depends on task type.",
            "additionalProperties": true
          },
          "cost": {
            "type": "string",
            "description": "Price charged for this task"
          },
          "ip": {
            "type": "string",
            "description": "IP address that submitted the task"
          },
          "createTime": {
            "type": "integer",
            "description": "Unix timestamp when task was created"
          },
          "endTime": {
            "type": "integer",
            "description": "Unix timestamp when task was completed"
          },
          "solveCount": {
            "type": "integer",
            "description": "Number of workers who attempted the task"
          }
        }
      },
      "GetBalanceResponse": {
        "type": "object",
        "properties": {
          "errorId": {
            "type": "integer",
            "description": "Error identifier. 0 means no error."
          },
          "balance": {
            "type": "number",
            "format": "double",
            "description": "Current account balance in USD"
          }
        }
      },
      "ReportTaskRequest": {
        "type": "object",
        "required": [
          "clientKey",
          "taskId"
        ],
        "properties": {
          "clientKey": {
            "type": "string",
            "description": "Your 2Captcha API key"
          },
          "taskId": {
            "type": "integer",
            "description": "The ID of the task to report on"
          }
        }
      },
      "ReportTaskResponse": {
        "type": "object",
        "properties": {
          "errorId": {
            "type": "integer",
            "description": "Error identifier. 0 means no error."
          },
          "status": {
            "type": "string",
            "description": "Status of the report"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errorId": {
            "type": "integer",
            "description": "Error identifier"
          },
          "errorCode": {
            "type": "string",
            "description": "Error code string"
          },
          "errorDescription": {
            "type": "string",
            "description": "Human-readable error description"
          }
        }
      }
    }
  }
}
