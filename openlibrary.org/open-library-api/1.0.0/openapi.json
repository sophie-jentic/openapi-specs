    "/api/books": {
      "get": {
        "operationId": "getBooksByBibkeys",
        "summary": "Books API (by bibkeys)",
        "description": "Get book data using bibliographic keys (ISBN, LCCN, OCLC, OLID). Returns data in specified format.",
        "tags": [
          "Books"
        ],
        "parameters": [
          {
            "name": "bibkeys",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of bibliographic keys (e.g., ISBN:0451526538)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Response format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "javascript"
              ],
              "default": "json"
            }
          },
          {
            "name": "callback",
            "in": "query",
            "description": "JSONP callback function name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "jscmd",
            "in": "query",
            "description": "What data to return",
            "schema": {
              "type": "string",
              "enum": [
                "viewapi",
                "data",
                "details"
              ],
              "default": "viewapi"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
