{
  "openapi": "3.0.3",
  "info": {
    "title": "Beekeeper API",
    "version": "2.0.0",
    "description": "Beekeeper is an operational communication platform. This API provides access to manage posts, streams, chats, messages, users, and profiles within a Beekeeper tenant.",
    "x-jentic-source-url": "https://developers.beekeeper.io/reference",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{subdomain}.beekeeper.io/api/2",
      "description": "Beekeeper tenant API",
      "variables": {
        "subdomain": {
          "description": "Your Beekeeper tenant subdomain",
          "default": "your-tenant"
        }
      }
    }
  ],
  "security": [
    {
      "bearerToken": []
    }
  ],
  "tags": [
    {
      "name": "Posts",
      "description": "Create and manage posts in streams"
    },
    {
      "name": "Streams",
      "description": "List available streams"
    },
    {
      "name": "Chats",
      "description": "Manage group chats and messages"
    },
    {
      "name": "Users",
      "description": "List and manage users"
    },
    {
      "name": "Profiles",
      "description": "Get user profile details"
    },
    {
      "name": "Webhooks",
      "description": "Manage webhooks"
    }
  ],
  "paths": {
    "/posts": {
      "post": {
        "operationId": "createPost",
        "summary": "Create a new post",
        "description": "Create a new text or multimedia post in a defined stream.",
        "tags": [
          "Posts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePostRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Post created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Post"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/streams": {
      "get": {
        "operationId": "listStreams",
        "summary": "List all streams",
        "description": "Returns a list of all available streams in the tenant.",
        "tags": [
          "Streams"
        ],
        "responses": {
          "200": {
            "description": "List of streams",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Stream"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chats/groups": {
      "get": {
        "operationId": "listGroupChats",
        "summary": "List group chats",
        "description": "Returns a list of all group chats.",
        "tags": [
          "Chats"
        ],
        "responses": {
          "200": {
            "description": "List of group chats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "chats": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Chat"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chats/groups/{chatId}/messages": {
      "post": {
        "operationId": "sendChatMessage",
        "summary": "Send a message to a group chat",
        "description": "Send a new message to the specified group chat.",
        "tags": [
          "Chats"
        ],
        "parameters": [
          {
            "name": "chatId",
            "in": "path",
            "required": true,
            "description": "The ID of the group chat",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chats/groups/{chatId}/members": {
      "get": {
        "operationId": "listChatMembers",
        "summary": "List chat members",
        "description": "Returns a list of members in the specified group chat.",
        "tags": [
          "Chats"
        ],
        "parameters": [
          {
            "name": "chatId",
            "in": "path",
            "required": true,
            "description": "The ID of the group chat",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of chat members",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "members": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ChatMember"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List users",
        "description": "Returns a paginated list of users in the tenant.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of users to return",
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of users to skip for pagination",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/profiles": {
      "get": {
        "operationId": "listProfiles",
        "summary": "List user profiles",
        "description": "Returns profiles for the specified user IDs.",
        "tags": [
          "Profiles"
        ],
        "parameters": [
          {
            "name": "user_ids",
            "in": "query",
            "description": "Comma-separated list of user IDs",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of user profiles",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserProfile"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/profiles/{userId}": {
      "get": {
        "operationId": "getUserProfile",
        "summary": "Get a user profile",
        "description": "Returns the profile for the specified user.",
        "tags": [
          "Profiles"
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "description": "The user ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfile"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/webhooks": {
      "post": {
        "operationId": "createWebhook",
        "summary": "Create a webhook",
        "description": "Register a new webhook for receiving event notifications.",
        "tags": [
          "Webhooks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWebhookRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/webhooks/{webhookId}": {
      "delete": {
        "operationId": "deleteWebhook",
        "summary": "Delete a webhook",
        "description": "Delete an existing webhook.",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "webhookId",
            "in": "path",
            "required": true,
            "description": "The webhook ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook deleted"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerToken": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "Token-based authentication. Use 'Token {access_token}' as the Authorization header value."
      }
    },
    "schemas": {
      "CreatePostRequest": {
        "type": "object",
        "required": [
          "streamid",
          "text"
        ],
        "properties": {
          "streamid": {
            "type": "string",
            "description": "The ID of the stream to post to"
          },
          "text": {
            "type": "string",
            "description": "The text content of the post"
          },
          "title": {
            "type": "string",
            "description": "The title of the post"
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FileAttachment"
            },
            "description": "List of file objects to be attached"
          },
          "media": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MediaAttachment"
            },
            "description": "List of photo or video objects"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of labels attached to the post"
          },
          "locked": {
            "type": "boolean",
            "description": "Disables adding comments on the post"
          },
          "sticky": {
            "type": "boolean",
            "description": "Pins post to top of stream"
          },
          "reactions_disabled": {
            "type": "boolean",
            "description": "Disables reactions on the post"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                }
              }
            },
            "description": "List of poll options"
          },
          "scheduled_at": {
            "type": "string",
            "format": "date-time",
            "description": "UTC datetime when the post is scheduled to be published (yyyy-mm-ddTHH:MM:SS)"
          }
        }
      },
      "SendMessageRequest": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "description": "Message text content"
          },
          "mentions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs of mentioned users, or 'all' for all members"
          }
        }
      },
      "CreateWebhookRequest": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "The URL to send webhook events to"
          },
          "event_types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Event types to subscribe to"
          }
        }
      },
      "Post": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "Unique identifier of the post"
          },
          "text": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "streamid": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "locked": {
            "type": "boolean"
          },
          "sticky": {
            "type": "boolean"
          }
        }
      },
      "Stream": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Chat": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      },
      "ChatMember": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string"
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "avatar_url": {
            "type": "string"
          }
        }
      },
      "FileAttachment": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "userid": {
            "type": "string"
          },
          "height": {
            "type": "integer"
          },
          "width": {
            "type": "integer"
          },
          "key": {
            "type": "string"
          },
          "media_type": {
            "type": "string"
          },
          "usage_type": {
            "type": "string"
          }
        }
      },
      "MediaAttachment": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "userid": {
            "type": "string"
          },
          "height": {
            "type": "integer"
          },
          "width": {
            "type": "integer"
          },
          "key": {
            "type": "string"
          },
          "media_type": {
            "type": "string"
          },
          "usage_type": {
            "type": "string"
          }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "event_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "status_code": {
            "type": "integer"
          }
        }
      }
    }
  }
}
