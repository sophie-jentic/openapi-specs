{
  "openapi": "3.0.3",
  "info": {
    "title": "Web3.Storage API",
    "description": "Web3.Storage is a service that makes it easy to store and retrieve data on IPFS and Filecoin. Upload files, get content-addressed CIDs, and retrieve data through IPFS gateways. Note: web3.storage has been rebranded to Storacha, but the HTTP API at api.web3.storage remains operational.",
    "version": "1.0.0",
    "contact": {
      "name": "Web3.Storage (Storacha)",
      "url": "https://storacha.network/"
    },
    "license": {
      "name": "Apache-2.0 OR MIT"
    }
  },
  "servers": [
    {
      "url": "https://api.web3.storage",
      "description": "Web3.Storage Production API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/upload": {
      "post": {
        "tags": [
          "Upload"
        ],
        "summary": "Upload a file",
        "description": "Upload a single file (up to 100MB). For files larger than 100MB, use the CAR upload endpoint. The uploaded file is stored on IPFS and Filecoin, and a CID is returned.",
        "operationId": "uploadFile",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The file to upload (max 100MB)"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/car": {
      "post": {
        "tags": [
          "Upload"
        ],
        "summary": "Upload a CAR file",
        "description": "Upload a Content Addressable aRchive (CAR) file. CAR files can contain arbitrary IPLD DAGs. This is the recommended method for uploading large files or complex data structures.",
        "operationId": "uploadCar",
        "requestBody": {
          "required": true,
          "content": {
            "application/car": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            },
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "CAR file uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/car/{cid}": {
      "get": {
        "tags": [
          "Retrieve"
        ],
        "summary": "Retrieve a CAR file",
        "description": "Retrieve a CAR file for the given CID. The CAR file contains the content-addressed data.",
        "operationId": "getCar",
        "parameters": [
          {
            "name": "cid",
            "in": "path",
            "required": true,
            "description": "The CID of the content to retrieve",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CAR file data",
            "content": {
              "application/car": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "Content not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "head": {
        "tags": [
          "Retrieve"
        ],
        "summary": "Check CAR file availability",
        "description": "Check if a CAR file is available for the given CID without downloading it.",
        "operationId": "headCar",
        "parameters": [
          {
            "name": "cid",
            "in": "path",
            "required": true,
            "description": "The CID to check",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CAR file exists"
          },
          "404": {
            "description": "Content not found"
          }
        }
      }
    },
    "/status/{cid}": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Get storage status for a CID",
        "description": "Retrieve the storage status of a CID, including pin status and Filecoin deal information.",
        "operationId": "getStatus",
        "parameters": [
          {
            "name": "cid",
            "in": "path",
            "required": true,
            "description": "The CID to check status for",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Storage status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          },
          "404": {
            "description": "CID not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/user/uploads": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "List user uploads",
        "description": "Retrieve a list of uploads for the authenticated user. Results are paginated.",
        "operationId": "listUploads",
        "parameters": [
          {
            "name": "before",
            "in": "query",
            "description": "Return results created before this ISO 8601 date string",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "after",
            "in": "query",
            "description": "Return results created after this ISO 8601 date string",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "Sort results by a field",
            "schema": {
              "type": "string",
              "enum": [
                "Date",
                "Name"
              ],
              "default": "Date"
            }
          },
          {
            "name": "sortOrder",
            "in": "query",
            "description": "Sort order",
            "schema": {
              "type": "string",
              "enum": [
                "Asc",
                "Desc"
              ],
              "default": "Asc"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of uploads",
            "headers": {
              "Count": {
                "description": "Total number of uploads",
                "schema": {
                  "type": "integer"
                }
              },
              "Page": {
                "description": "Current page number",
                "schema": {
                  "type": "integer"
                }
              },
              "Size": {
                "description": "Page size",
                "schema": {
                  "type": "integer"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Upload"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/user/uploads/{cid}": {
      "delete": {
        "tags": [
          "User"
        ],
        "summary": "Delete an upload",
        "description": "Delete an upload by its CID. This will remove the upload record and unpin the content.",
        "operationId": "deleteUpload",
        "parameters": [
          {
            "name": "cid",
            "in": "path",
            "required": true,
            "description": "The CID of the upload to delete",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Upload deletion accepted"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Upload not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/user/account": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Get account information",
        "description": "Retrieve account information for the authenticated user, including storage usage.",
        "operationId": "getAccount",
        "responses": {
          "200": {
            "description": "Account information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/pins": {
      "get": {
        "tags": [
          "Pinning"
        ],
        "summary": "List pin requests",
        "description": "List all pin requests for the authenticated user. Implements the IPFS Pinning Service API.",
        "operationId": "listPins",
        "parameters": [
          {
            "name": "cid",
            "in": "query",
            "description": "Filter by exact CID match",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "Filter by pin name (exact match)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "match",
            "in": "query",
            "description": "Text matching strategy for name filter",
            "schema": {
              "type": "string",
              "enum": [
                "exact",
                "iexact",
                "partial",
                "ipartial"
              ],
              "default": "exact"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by pin status",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "queued",
                  "pinning",
                  "pinned",
                  "failed"
                ]
              }
            }
          },
          {
            "name": "before",
            "in": "query",
            "description": "Return results created before this ISO 8601 date",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "after",
            "in": "query",
            "description": "Return results created after this ISO 8601 date",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Max records to return",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pin results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PinResults"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Pinning"
        ],
        "summary": "Add a pin",
        "description": "Request that the service pin a CID. Implements the IPFS Pinning Service API.",
        "operationId": "addPin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PinRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Pin request accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PinStatus"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/pins/{requestId}": {
      "get": {
        "tags": [
          "Pinning"
        ],
        "summary": "Get pin status",
        "description": "Get the status of a pin request by its ID.",
        "operationId": "getPin",
        "parameters": [
          {
            "name": "requestId",
            "in": "path",
            "required": true,
            "description": "The ID of the pin request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pin status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PinStatus"
                }
              }
            }
          },
          "404": {
            "description": "Pin request not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Pinning"
        ],
        "summary": "Replace a pin",
        "description": "Replace an existing pin request with a new one.",
        "operationId": "replacePin",
        "parameters": [
          {
            "name": "requestId",
            "in": "path",
            "required": true,
            "description": "The ID of the pin request to replace",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PinRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Pin replaced",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PinStatus"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Pin request not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Pinning"
        ],
        "summary": "Remove a pin",
        "description": "Remove a pin request by its ID.",
        "operationId": "removePin",
        "parameters": [
          {
            "name": "requestId",
            "in": "path",
            "required": true,
            "description": "The ID of the pin request to remove",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Pin removed"
          },
          "404": {
            "description": "Pin request not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Web3.Storage API token. Create one at https://web3.storage/tokens/"
      }
    },
    "schemas": {
      "UploadResponse": {
        "type": "object",
        "properties": {
          "cid": {
            "type": "string",
            "description": "Content Identifier (CID) for the uploaded content"
          },
          "carCid": {
            "type": "string",
            "description": "CID of the CAR file that contains the uploaded content"
          }
        }
      },
      "Upload": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the upload"
          },
          "cid": {
            "type": "string",
            "description": "Content Identifier"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Upload creation timestamp"
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          },
          "dagSize": {
            "type": "integer",
            "description": "Total size of the DAG in bytes"
          },
          "pins": {
            "type": "array",
            "description": "Pin status information",
            "items": {
              "$ref": "#/components/schemas/Pin"
            }
          },
          "deals": {
            "type": "array",
            "description": "Filecoin storage deal information",
            "items": {
              "$ref": "#/components/schemas/Deal"
            }
          }
        }
      },
      "Status": {
        "type": "object",
        "properties": {
          "cid": {
            "type": "string",
            "description": "Content Identifier"
          },
          "dagSize": {
            "type": "integer",
            "description": "Total size of the DAG in bytes"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "pins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Pin"
            }
          },
          "deals": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Deal"
            }
          }
        }
      },
      "Pin": {
        "type": "object",
        "properties": {
          "peerId": {
            "type": "string",
            "description": "Peer ID of the IPFS node pinning the content"
          },
          "peerName": {
            "type": "string",
            "description": "Name of the pinning peer"
          },
          "region": {
            "type": "string",
            "description": "Geographic region of the pinning node"
          },
          "status": {
            "type": "string",
            "enum": [
              "Pinned",
              "Pinning",
              "PinQueued",
              "Unpinned"
            ],
            "description": "Current pin status"
          },
          "updated": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Deal": {
        "type": "object",
        "properties": {
          "dealId": {
            "type": "integer",
            "description": "Filecoin deal ID"
          },
          "storageProvider": {
            "type": "string",
            "description": "Filecoin storage provider address"
          },
          "status": {
            "type": "string",
            "enum": [
              "Queued",
              "Published",
              "Active"
            ],
            "description": "Deal status"
          },
          "pieceCid": {
            "type": "string",
            "description": "Piece CID for the Filecoin deal"
          },
          "dataCid": {
            "type": "string",
            "description": "Data CID stored in the deal"
          },
          "dataModelSelector": {
            "type": "string",
            "description": "Selector for the data within the deal"
          },
          "activation": {
            "type": "string",
            "format": "date-time",
            "description": "Deal activation time"
          },
          "expiration": {
            "type": "string",
            "format": "date-time",
            "description": "Deal expiration time"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "updated": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "usedStorage": {
            "type": "object",
            "properties": {
              "uploaded": {
                "type": "integer",
                "description": "Total bytes uploaded"
              },
              "psaPinned": {
                "type": "integer",
                "description": "Total bytes pinned via PSA"
              }
            }
          }
        }
      },
      "PinRequest": {
        "type": "object",
        "required": [
          "cid"
        ],
        "properties": {
          "cid": {
            "type": "string",
            "description": "CID to be pinned"
          },
          "name": {
            "type": "string",
            "description": "Optional name for the pin"
          },
          "origins": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Multiaddrs of known providers for the content"
          },
          "meta": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Optional metadata"
          }
        }
      },
      "PinStatus": {
        "type": "object",
        "properties": {
          "requestid": {
            "type": "string",
            "description": "Unique ID for the pin request"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "pinning",
              "pinned",
              "failed"
            ],
            "description": "Current status of the pin request"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "pin": {
            "type": "object",
            "properties": {
              "cid": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "origins": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "meta": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          },
          "delegates": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Multiaddrs of peers pinning the content"
          },
          "info": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "PinResults": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "description": "Total number of pin requests matching the query"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PinStatus"
            }
          }
        }
      },
      "Error": {
