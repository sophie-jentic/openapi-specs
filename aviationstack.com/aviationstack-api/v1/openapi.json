{
  "openapi": "3.0.3",
  "info": {
    "title": "Aviationstack API",
    "description": "Real-time flight status and aviation data API. Provides access to global flight tracking, airport schedules, airline routes, aircraft data, and more.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://aviationstack.com/documentation",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.aviationstack.com/v1",
      "description": "Production"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Flights",
      "description": "Real-time and historical flight data"
    },
    {
      "name": "Airports",
      "description": "Airport information"
    },
    {
      "name": "Airlines",
      "description": "Airline information"
    },
    {
      "name": "Aircraft",
      "description": "Aircraft type information"
    },
    {
      "name": "Routes",
      "description": "Flight route data"
    },
    {
      "name": "Reference",
      "description": "Cities, countries and aviation reference data"
    }
  ],
  "paths": {
    "/flights": {
      "get": {
        "operationId": "getFlights",
        "summary": "Get real-time flight data",
        "description": "Returns real-time flight data for flights worldwide.",
        "tags": [
          "Flights"
        ],
        "parameters": [
          {
            "name": "access_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API access key"
          },
          {
            "name": "flight_status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "scheduled",
                "active",
                "landed",
                "cancelled",
                "incident",
                "diverted"
              ]
            },
            "description": "Filter by flight status"
          },
          {
            "name": "flight_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Filter by flight date"
          },
          {
            "name": "dep_iata",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by departure airport IATA code"
          },
          {
            "name": "arr_iata",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by arrival airport IATA code"
          },
          {
            "name": "dep_icao",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by departure airport ICAO code"
          },
          {
            "name": "arr_icao",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by arrival airport ICAO code"
          },
          {
            "name": "airline_name",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by airline name"
          },
          {
            "name": "airline_iata",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by airline IATA code"
          },
          {
            "name": "airline_icao",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by airline ICAO code"
          },
          {
            "name": "flight_number",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by flight number"
          },
          {
            "name": "flight_iata",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by flight IATA code"
          },
          {
            "name": "flight_icao",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by flight ICAO code"
          },
          {
            "name": "min_delay_dep",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Min departure delay in minutes"
          },
          {
            "name": "min_delay_arr",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Min arrival delay in minutes"
          },
          {
            "name": "max_delay_dep",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Max departure delay in minutes"
          },
          {
            "name": "max_delay_arr",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Max arrival delay in minutes"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            },
            "description": "Pagination limit"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Pagination offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Flight data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
