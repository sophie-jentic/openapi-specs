  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "access_key",
        "in": "query"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "context": {
                "type": "object"
              }
            }
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "count": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "Flight": {
        "type": "object",
        "properties": {
          "flight_date": {
            "type": "string",
            "format": "date"
          },
          "flight_status": {
            "type": "string"
          },
          "departure": {
            "$ref": "#/components/schemas/FlightEndpoint"
          },
          "arrival": {
            "$ref": "#/components/schemas/FlightEndpoint"
          },
          "airline": {
            "type": "object",
