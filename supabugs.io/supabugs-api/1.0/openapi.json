  "components": {
    "schemas": {
      "CreateIssueRequest": {
        "type": "object",
        "required": [
          "title",
          "description",
          "type",
          "severity",
          "priority"
        ],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 50
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "environment": {
            "$ref": "#/components/schemas/Environment"
          },
          "user": {
            "$ref": "#/components/schemas/UserRequest"
          }
        }
      },
      "UpdateIssueRequest": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "environment": {
            "$ref": "#/components/schemas/Environment"
          },
          "user": {
            "$ref": "#/components/schemas/UserRequest"
          }
        }
      },
      "IssueSearchRequest": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "status": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "type": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "severity": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "priority": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdById": {
            "type": "string"
          },
          "isFinal": {
            "type": "boolean"
          },
          "page": {
            "type": "integer",
            "default": 1
          },
          "limit": {
            "type": "integer",
            "default": 20
          },
          "sort": {
            "type": "string"
          }
        }
      },
      "CreateCommentRequest": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserRequest"
          }
        }
      },
      "Issue": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "closed": {
            "type": "boolean"
          },
          "dueDate": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "$ref": "#/components/schemas/LovReference"
          },
          "type": {
            "$ref": "#/components/schemas/LovReference"
          },
          "severity": {
            "$ref": "#/components/schemas/LovReference"
          },
          "priority": {
            "$ref": "#/components/schemas/LovReference"
          }
        }
      },
      "ZapierIssue": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "closed": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "IssueListResponse": {
        "type": "object",
        "properties": {
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Issue"
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "count": {
                "type": "integer"
              },
              "limit": {
                "type": "integer"
              },
              "page": {
                "type": "integer"
              }
            }
          }
        }
      },
      "LovItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "order": {
            "type": "string"
          },
          "isFinal": {
            "type": "boolean"
          },
          "isInitial": {
            "type": "boolean"
          }
        }
      },
      "LovReference": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "isFinal": {
            "type": "boolean"
          },
          "isInitial": {
            "type": "boolean"
          }
        }
      },
      "Environment": {
        "type": "object",
        "properties": {
          "browserName": {
            "type": "string"
          },
          "browserVersion": {
            "type": "string"
          },
          "osName": {
            "type": "string"
          },
          "osVersion": {
            "type": "string"
          },
          "deviceName": {
            "type": "string"
          },
          "resolution": {
            "type": "string"
          },
          "ip": {
            "type": "string"
          },
          "networkName": {
            "type": "string"
          }
        }
      },
      "UserRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "surname": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "externalIdentifier": {
            "type": "string"
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "archived": {
            "type": "boolean"
          },
          "issuesCount": {
            "type": "integer"
          },
          "openIssuesCount": {
            "type": "integer"
          },
          "closedIssuesCount": {
            "type": "integer"
          },
          "startDate": {
            "type": "string"
          },
          "endDate": {
            "type": "string"
          },
          "contractNumber": {
            "type": "string"
          },
          "clientCompanyName": {
            "type": "string"
          }
        }
