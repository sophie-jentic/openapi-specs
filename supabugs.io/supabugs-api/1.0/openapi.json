        "operationId": "downloadAttachment",
        "summary": "Download Attachment",
        "description": "Download an attachment from an issue",
        "tags": [
          "Attachments"
        ],
        "parameters": [
          {
            "name": "issueId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Issue ID"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Attachment ID"
