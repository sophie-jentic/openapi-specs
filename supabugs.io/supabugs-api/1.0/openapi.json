                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/issues/{issueId}/attachments/{id}": {
      "delete": {
        "operationId": "deleteAttachment",
        "summary": "Delete Attachment",
        "description": "Delete an attachment from an issue",
        "tags": [
          "Attachments"
        ],
        "parameters": [
          {
            "name": "issueId",
            "in": "path",
