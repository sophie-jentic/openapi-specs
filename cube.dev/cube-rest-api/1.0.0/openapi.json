{
  "openapi": "3.0.3",
  "info": {
    "title": "Cube.js REST API",
    "version": "1.0.0",
    "description": "Cube.js REST API provides endpoints for loading data via Cube JSON queries and retrieving metadata about the data model. The API uses JWT bearer authentication.",
    "x-jentic-source-url": "https://cube.dev/docs/product/apis-integrations/rest-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{host}",
      "description": "Cube.js API server",
      "variables": {
        "host": {
          "default": "localhost:4000/cubejs-api",
          "description": "Cube.js deployment host"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Metadata",
      "description": "Cube metadata endpoints"
    },
    {
      "name": "Data",
      "description": "Data loading endpoints"
    }
  ],
  "paths": {
    "/v1/meta": {
      "get": {
        "operationId": "getMetadata",
        "summary": "Load Metadata",
        "description": "Returns metadata about the available cubes, including their measures, dimensions, segments, and joins.",
        "tags": [
          "Metadata"
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V1MetaResponse"
                }
              }
            }
          },
          "400": {
            "description": "Request could not be completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V1Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing JWT token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V1Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/load": {
      "post": {
        "operationId": "loadData",
        "summary": "Load data via Cube JSON Query",
        "description": "Executes a Cube JSON query and returns the result data with annotations.",
        "tags": [
          "Data"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/V1LoadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V1LoadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Request could not be completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V1Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V1Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "V1MetaResponse": {
        "type": "object",
        "properties": {
          "cubes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/V1CubeMeta"
            }
          },
          "compilerId": {
            "type": "string"
          }
        }
      },
      "V1CubeMeta": {
        "type": "object",
        "required": [
          "name",
          "type",
          "measures",
          "dimensions",
          "segments"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "cube",
              "view"
            ],
            "description": "Type of cube"
          },
          "meta": {
            "type": "object"
          },
          "description": {
            "type": "string"
          },
          "measures": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/V1CubeMetaMeasure"
            }
          },
          "dimensions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/V1CubeMetaDimension"
            }
          },
          "segments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/V1CubeMetaSegment"
            }
          },
          "joins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/V1CubeMetaJoin"
            }
          }
        }
      },
      "V1CubeMetaMeasure": {
        "type": "object",
        "required": [
          "name",
          "type"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "shortTitle": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "aggType": {
            "type": "string"
          },
          "meta": {
            "type": "object"
          }
        }
      },
      "V1CubeMetaDimension": {
        "type": "object",
        "required": [
          "name",
          "type"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "shortTitle": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "meta": {
            "type": "object"
          }
        }
      },
      "V1CubeMetaSegment": {
        "type": "object",
        "required": [
          "name",
          "title",
          "shortTitle"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "shortTitle": {
            "type": "string"
          },
          "meta": {
            "type": "object"
          }
        }
      },
      "V1CubeMetaJoin": {
        "type": "object",
        "required": [
          "name",
          "relationship"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "relationship": {
            "type": "string"
          }
        }
      },
      "V1LoadRequest": {
        "type": "object",
        "properties": {
          "queryType": {
            "type": "string"
          },
          "cache": {
            "type": "string",
            "enum": [
              "stale-if-slow",
              "stale-while-revalidate",
              "must-revalidate",
              "no-cache"
            ]
          },
          "query": {
            "$ref": "#/components/schemas/V1LoadRequestQuery"
          }
        }
      },
      "V1LoadRequestQuery": {
        "type": "object",
        "properties": {
          "measures": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dimensions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "segments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "timeDimensions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/V1TimeDimension"
            }
          },
          "order": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "limit": {
            "type": "integer",
            "format": "int32"
          },
          "offset": {
            "type": "integer",
            "format": "int32"
          },
          "filters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/V1Filter"
            }
          },
          "ungrouped": {
            "type": "boolean"
          },
          "timezone": {
            "type": "string"
          }
        }
      },
      "V1TimeDimension": {
        "type": "object",
        "required": [
          "dimension"
        ],
        "properties": {
          "dimension": {
            "type": "string"
          },
          "granularity": {
            "type": "string"
          },
          "dateRange": {
            "type": "object"
          }
        }
      },
      "V1Filter": {
        "type": "object",
        "properties": {
          "member": {
            "type": "string"
          },
          "operator": {
            "type": "string"
          },
          "values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "and": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "or": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "V1LoadResponse": {
        "type": "object",
        "required": [
          "results"
        ],
        "properties": {
          "pivotQuery": {
            "type": "object"
          },
          "slowQuery": {
            "type": "boolean"
          },
          "queryType": {
            "type": "string"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/V1LoadResult"
            }
          }
        }
      },
      "V1LoadResult": {
        "type": "object",
        "required": [
          "annotation",
          "data"
        ],
        "properties": {
          "dataSource": {
            "type": "string"
          },
          "annotation": {
            "type": "object",
            "properties": {
              "measures": {
                "type": "object"
              },
              "dimensions": {
                "type": "object"
              },
              "segments": {
                "type": "object"
              },
              "timeDimensions": {
                "type": "object"
              }
            }
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "lastRefreshTime": {
            "type": "string"
          }
        }
      },
      "V1Error": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}
