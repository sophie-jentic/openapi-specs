{
  "openapi": "3.0.3",
  "info": {
    "title": "AISTA API",
    "description": "AI chatbot creation and management platform API for training ChatGPT-style bots with custom data",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.aista.ai/swagger",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.aista.ai/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Chatbots",
      "description": "Chatbot management"
    },
    {
      "name": "Training",
      "description": "Training data management"
    }
  ],
  "paths": {
    "/chatbots": {
      "get": {
        "tags": [
          "Chatbots"
        ],
        "summary": "List chatbots",
        "description": "Retrieve all chatbots",
        "operationId": "listChatbots",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of chatbots",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "chatbots": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Chatbot"
                      }
                    },
                    "total": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Chatbots"
        ],
        "summary": "Create chatbot",
        "description": "Create a new chatbot",
        "operationId": "createChatbot",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "type"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "support",
                      "lead_generation",
                      "qa",
                      "personality"
                    ]
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Chatbot created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Chatbot"
                }
              }
            }
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chatbots/{id}": {
      "get": {
        "tags": [
          "Chatbots"
        ],
        "summary": "Get chatbot",
        "description": "Retrieve a specific chatbot by ID",
        "operationId": "getChatbot",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chatbot details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Chatbot"
                }
              }
            }
          },
          "404": {
            "description": "Chatbot not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Chatbots"
        ],
        "summary": "Delete chatbot",
        "description": "Delete a chatbot",
        "operationId": "deleteChatbot",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Chatbot deleted"
          }
        }
      }
    },
    "/chatbots/{id}/training": {
      "post": {
        "tags": [
          "Training"
        ],
        "summary": "Upload training data",
        "description": "Upload training data for a chatbot",
        "operationId": "uploadTrainingData",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Training data file (XML, JSON, YAML, CSV)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Training data uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "records_processed": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/chatbots/{id}/scrape": {
      "post": {
        "tags": [
          "Training"
        ],
        "summary": "Scrape website for training",
        "description": "Scrape website content to train chatbot",
        "operationId": "scrapeWebsite",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "max_pages": {
                    "type": "integer",
                    "default": 100
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scraping started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "job_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "Chatbot": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "support",
              "lead_generation",
              "qa",
              "personality"
            ]
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "training",
              "inactive"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
