{
  "openapi": "3.1.0",
  "info": {
    "title": "Loader.io API",
    "description": "Loader.io is a cloud-based load testing service. The API allows you to register and verify testing domains, create and run load tests, view test results, and access loader.io server IPs for firewall whitelisting.",
    "version": "2.0",
    "contact": {
      "name": "Loader.io (SendGrid Labs)",
      "url": "https://loader.io"
    },
    "x-jentic-source-url": "http://docs.loader.io/api/intro.html"
  },
  "servers": [
    {
      "url": "https://api.loader.io/v2",
      "description": "Loader.io API v2"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Apps",
      "description": "Target host/application management"
    },
    {
      "name": "Tests",
      "description": "Load test management"
    },
    {
      "name": "Results",
      "description": "Test results"
    },
    {
      "name": "Servers",
      "description": "Loader.io server IPs"
    }
  ],
  "paths": {
    "/apps": {
      "get": {
        "operationId": "listApps",
        "summary": "List registered applications",
        "description": "Returns a list of all registered target hosts.",
        "tags": [
          "Apps"
        ],
        "responses": {
          "200": {
            "description": "Application list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/App"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "registerApp",
        "summary": "Register a new application",
        "description": "Registers a new domain/host for testing. The domain must be verified before tests can be run.",
        "tags": [
          "Apps"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "app"
                ],
                "properties": {
                  "app": {
                    "type": "string",
                    "description": "Domain name or IP to register (e.g. gonnacrushya.com)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "App registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/App"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/apps/{app_id}": {
      "get": {
        "operationId": "getApp",
        "summary": "Get application details",
        "tags": [
          "Apps"
        ],
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "App details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/App"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get application details"
      },
      "delete": {
        "operationId": "deleteApp",
        "summary": "Delete an application",
        "tags": [
          "Apps"
        ],
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "App deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete an application"
      }
    },
    "/apps/{app_id}/verify": {
      "post": {
        "operationId": "verifyApp",
        "summary": "Verify an application",
        "description": "Verifies domain ownership using DNS, HTTP, or token method.",
        "tags": [
          "Apps"
        ],
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "method": {
                    "type": "string",
                    "enum": [
                      "dns",
                      "http",
                      "token"
                    ],
                    "description": "Verification method"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/App"
                }
              }
            }
          },
          "400": {
            "description": "Verification failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tests": {
      "get": {
        "operationId": "listTests",
        "summary": "List tests",
        "description": "Returns a list of all configured tests.",
        "tags": [
          "Tests"
        ],
        "responses": {
          "200": {
            "description": "Test list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Test"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createTest",
        "summary": "Create a new test",
        "description": "Creates a new load test configuration.",
        "tags": [
          "Tests"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "test_type",
                  "urls",
                  "duration",
                  "total"
                ],
                "properties": {
                  "test_type": {
                    "type": "string",
                    "enum": [
                      "cycling",
                      "non-cycling"
                    ],
                    "description": "cycling ramps from initial to total connections; non-cycling maintains constant total connections"
                  },
                  "urls": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/TestUrl"
                    },
                    "description": "URLs to test"
                  },
                  "duration": {
                    "type": "integer",
                    "description": "Duration of test in seconds"
                  },
                  "initial": {
                    "type": "integer",
                    "default": 0,
                    "description": "Number of connections to start with (cycling only)"
                  },
                  "total": {
                    "type": "integer",
                    "description": "Number of connections to end with (cycling) or total connections (non-cycling)"
                  },
                  "timeout": {
                    "type": "integer",
                    "default": 10000,
                    "description": "Request timeout in milliseconds"
                  },
                  "error_threshold": {
                    "type": "integer",
                    "default": 50,
                    "description": "Error percentage threshold"
                  },
                  "callback": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to POST results to when test finishes"
                  },
                  "callback_email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email to send results to"
                  },
                  "scheduled_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Schedule the test for future execution"
                  },
                  "name": {
                    "type": "string"
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Test created and started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "enum": [
                        "success"
                      ]
                    },
                    "result_id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "running",
                        "pending"
                      ]
                    },
                    "test_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tests/{test_id}": {
      "get": {
        "operationId": "getTest",
        "summary": "Get test details",
        "tags": [
          "Tests"
        ],
        "parameters": [
          {
            "name": "test_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Test details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Test"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get test details"
      }
    },
    "/tests/{test_id}/run": {
      "put": {
        "operationId": "runTest",
        "summary": "Run a test",
        "description": "Starts execution of a previously created test.",
        "tags": [
          "Tests"
        ],
        "parameters": [
          {
            "name": "test_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Test started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "result_id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tests/{test_id}/stop": {
      "put": {
        "operationId": "stopTest",
        "summary": "Stop a running test",
        "tags": [
          "Tests"
        ],
        "parameters": [
          {
            "name": "test_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Test stopped",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Stop a running test"
      }
    },
    "/tests/{test_id}/results": {
      "get": {
        "operationId": "listTestResults",
        "summary": "List test results",
        "description": "Returns all results for a test.",
        "tags": [
          "Results"
        ],
        "parameters": [
          {
            "name": "test_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Test results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TestResult"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tests/{test_id}/results/{result_id}": {
      "get": {
        "operationId": "getTestResult",
        "summary": "Get specific test result",
        "tags": [
          "Results"
        ],
        "parameters": [
          {
            "name": "test_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "result_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Test result details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TestResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get specific test result"
      }
    },
    "/servers": {
      "get": {
        "operationId": "listServers",
        "summary": "List loader.io server IPs",
        "description": "Returns a list of IP addresses that loader.io may use to send requests during tests. Useful for firewall whitelisting.",
        "tags": [
          "Servers"
        ],
        "responses": {
          "200": {
            "description": "Server IP list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ip": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "description": "IP address"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "loaderio-auth",
        "description": "Loader.io API key from your account settings page"
      }
    },
    "schemas": {
      "App": {
        "type": "object",
        "properties": {
          "app": {
            "type": "string",
            "description": "Domain or IP"
          },
          "app_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "verified",
              "unverified"
            ]
          },
          "verification_method": {
            "type": "string",
            "enum": [
              "dns",
              "http",
              "token"
            ]
          }
        }
      },
      "Test": {
        "type": "object",
        "properties": {
          "test_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "test_type": {
            "type": "string",
            "enum": [
              "cycling",
              "non-cycling"
            ]
          },
          "duration": {
            "type": "integer"
          },
          "initial": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          },
          "timeout": {
            "type": "integer"
          },
          "error_threshold": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "running",
              "complete",
              "pending"
            ]
          },
          "urls": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TestUrl"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "TestUrl": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "request_type": {
            "type": "string",
            "enum": [
              "GET",
              "POST"
            ],
            "default": "GET"
          },
          "credentials": {
            "type": "object",
            "properties": {
              "login": {
                "type": "string"
              },
              "password": {
                "type": "string"
              }
            },
            "description": "HTTP Basic Auth credentials"
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "request_params": {
            "type": "object",
            "additionalProperties": true,
            "description": "Query params (GET) or body data (POST)"
          },
          "raw_post_body": {
            "type": "string",
            "description": "Raw POST body"
          },
          "payload_file_url": {
            "type": "string",
            "format": "uri"
          },
          "variables": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "property": {
                  "type": "string"
                },
                "source": {
                  "type": "string",
                  "enum": [
                    "header"
                  ]
                }
              }
            }
          }
        }
      },
      "TestResult": {
        "type": "object",
        "properties": {
          "result_id": {
            "type": "string"
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string"
          },
          "public_results_url": {
            "type": "string"
          },
          "success": {
            "type": "integer"
          },
          "error": {
            "type": "integer"
          },
          "timeout_count": {
            "type": "integer"
          },
          "data_sent": {
            "type": "integer",
            "description": "Bytes sent"
          },
          "data_received": {
            "type": "integer",
            "description": "Bytes received"
          },
          "avg_response_time": {
            "type": "integer",
            "description": "Average response time in ms"
          },
          "avg_error_rate": {
            "type": "number"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
