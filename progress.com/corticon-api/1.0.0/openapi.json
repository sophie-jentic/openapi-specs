{
  "openapi": "3.0.3",
  "info": {
    "title": "Progress Corticon Decision Service API",
    "version": "1.0.0",
    "description": "Progress Corticon exposes business rules as RESTful decision services. The API allows execution of decision services, management of rule assets, and monitoring of decision service deployments. Corticon Server provides a REST endpoint for invoking decision services deployed as web services.",
    "x-jentic-source-url": "https://www.progress.com/corticon",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}:{port}/axis/corticon",
      "variables": {
        "host": {
          "default": "localhost"
        },
        "port": {
          "default": "8850"
        }
      }
    }
  ],
  "paths": {
    "/execute": {
      "post": {
        "operationId": "executeDecisionService",
        "summary": "Execute a decision service",
        "description": "Invokes a Corticon decision service with the provided input payload. The decision service applies business rules and returns the results.",
        "tags": [
          "Decision Execution"
        ],
        "parameters": [
          {
            "name": "decisionServiceName",
            "in": "query",
            "required": true,
            "description": "Name of the decision service to execute",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DecisionRequest"
              }
            },
            "application/xml": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Decision executed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DecisionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Decision service not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/batch": {
      "post": {
        "operationId": "executeBatchDecision",
        "summary": "Execute batch decision service",
        "description": "Processes multiple decision requests in a single batch call.",
        "tags": [
          "Decision Execution"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchDecisionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch processed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchDecisionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/server/decisionservices": {
      "get": {
        "operationId": "listDecisionServices",
        "summary": "List deployed decision services",
        "description": "Returns a list of all decision services currently deployed on the server.",
        "tags": [
          "Server Management"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DecisionServiceList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/server/decisionservices/{serviceName}": {
      "get": {
        "operationId": "getDecisionService",
        "summary": "Get decision service details",
        "tags": [
          "Server Management"
        ],
        "parameters": [
          {
            "name": "serviceName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get decision service details"
      },
      "delete": {
        "operationId": "undeployDecisionService",
        "summary": "Undeploy a decision service",
        "tags": [
          "Server Management"
        ],
        "parameters": [
          {
            "name": "serviceName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Undeployed"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Undeploy a decision service"
      }
    },
    "/server/deploy": {
      "post": {
        "operationId": "deployDecisionService",
        "summary": "Deploy a decision service",
        "tags": [
          "Server Management"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deployed"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Deploy a decision service"
      }
    },
    "/server/status": {
      "get": {
        "operationId": "getServerStatus",
        "summary": "Get server status",
        "tags": [
          "Server Management"
        ],
        "responses": {
          "200": {
            "description": "Server status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerStatus"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get server status"
      }
    },
    "/server/ruleflows": {
      "get": {
        "operationId": "listRuleflows",
        "summary": "List available ruleflows",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List available ruleflows"
      }
    },
    "/server/rulesheets": {
      "get": {
        "operationId": "listRulesheets",
        "summary": "List available rulesheets",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List available rulesheets"
      }
    },
    "/server/vocabularies": {
      "get": {
        "operationId": "listVocabularies",
        "summary": "List vocabularies",
        "tags": [
          "Rules"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List vocabularies"
      }
    },
    "/server/logs": {
      "get": {
        "operationId": "getServerLogs",
        "summary": "Get server execution logs",
        "tags": [
          "Monitoring"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "level",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "INFO",
                "WARN",
                "ERROR"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Logs retrieved"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get server execution logs"
      }
    },
    "/server/metrics": {
      "get": {
        "operationId": "getServerMetrics",
        "summary": "Get server metrics",
        "tags": [
          "Monitoring"
        ],
        "responses": {
          "200": {
            "description": "Metrics retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerMetrics"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get server metrics"
      }
    }
  },
  "components": {
    "schemas": {
      "DecisionRequest": {
        "type": "object",
        "properties": {
          "Objects": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Array of business objects to process"
          }
        }
      },
      "DecisionResponse": {
        "type": "object",
        "properties": {
          "Objects": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "Messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RuleMessage"
            }
          }
        }
      },
      "BatchDecisionRequest": {
        "type": "object",
        "properties": {
          "requests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DecisionRequest"
            }
          }
        }
      },
      "BatchDecisionResponse": {
        "type": "object",
        "properties": {
          "responses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DecisionResponse"
            }
          }
        }
      },
      "RuleMessage": {
        "type": "object",
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "Info",
              "Warning",
              "Violation"
            ]
          },
          "message": {
            "type": "string"
          },
          "entityName": {
            "type": "string"
          }
        }
      },
      "DecisionServiceList": {
        "type": "object",
        "properties": {
          "services": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "version": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ServerStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "uptime": {
            "type": "integer"
          },
          "deployedServices": {
            "type": "integer"
          }
        }
      },
      "ServerMetrics": {
        "type": "object",
        "properties": {
          "totalRequests": {
            "type": "integer"
          },
          "averageResponseTime": {
            "type": "number"
          },
          "activeThreads": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Decision Execution"
    },
    {
      "name": "Monitoring"
    },
    {
      "name": "Rules"
    },
    {
      "name": "Server Management"
    }
  ]
}
