{
  "openapi": "3.0.3",
  "info": {
    "title": "Sonix API",
    "version": "1.0.0",
    "description": "API for automated transcription, translation, and subtitle creation for audio and video files.",
    "x-jentic-source-url": "https://sonix.ai/docs/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.sonix.ai/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/media": {
      "get": {
        "summary": "List media files",
        "description": "Retrieve a paginated list of media files with optional filtering",
        "operationId": "listMedia",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number (100 files per page)"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "completed",
                "transcribing",
                "aligning",
                "failed"
              ]
            },
            "description": "Filter by transcription status"
          },
          {
            "name": "folder_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by folder ID"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search files by name"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "media": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "page": {
                      "type": "integer"
                    },
                    "total_pages": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "tags": [
          "media"
        ]
      },
      "post": {
        "summary": "Submit new media",
        "description": "Upload media file for transcription or alignment",
        "operationId": "createMedia",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "language"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Audio/video file (100MB limit)"
                  },
                  "file_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to remote media file (for files >100MB)"
                  },
                  "language": {
                    "type": "string",
                    "description": "Language code for transcription"
                  },
                  "name": {
                    "type": "string",
                    "description": "Custom name for the media"
                  },
                  "transcript_text": {
                    "type": "string",
                    "description": "Existing transcript for alignment"
                  },
                  "folder_id": {
                    "type": "string",
                    "description": "Target folder ID"
                  },
                  "keywords": {
                    "type": "string",
                    "description": "Comma-separated keywords for transcription hints"
                  },
                  "custom_data": {
                    "type": "object",
                    "description": "Custom metadata key-value pairs"
                  },
                  "callback_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Webhook URL for status updates"
                  },
                  "multitrack": {
                    "type": "boolean",
                    "description": "Enable multitrack processing"
                  },
                  "speaker_labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Speaker identifiers for multitrack"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Media uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "tags": [
          "media"
        ]
      }
    },
    "/media/{id}": {
      "get": {
        "summary": "Get media status",
        "description": "Retrieve details and status of a specific media file",
        "operationId": "getMedia",
        "parameters": [
          {
