{
  "openapi": "3.0.3",
  "info": {
    "title": "DHL eCommerce API",
    "version": "1.0.0",
    "description": "DHL eCommerce API for creating shipment labels, tracking parcels, and retrieving shipment options in the Netherlands.",
    "x-jentic-source-url": "https://api-gw.dhlparcel.nl/docs/guide",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api-gw.dhlparcel.nl"
    }
  ],
  "paths": {
    "/track-trace": {
      "get": {
        "operationId": "trackTrace",
        "summary": "Track a shipment",
        "tags": [
          "Tracking"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Tracker code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pc",
            "in": "query",
            "required": true,
            "description": "Postal code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tracking information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Track a shipment"
      }
    },
    "/labels": {
      "get": {
        "operationId": "listLabels",
        "summary": "List labels",
        "tags": [
          "Labels"
        ],
        "parameters": [
          {
            "name": "trackerCodeFilter",
            "in": "query",
            "description": "Filter by tracker code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Labels list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Label"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List labels"
      },
      "post": {
        "operationId": "createLabel",
        "summary": "Create a label",
        "tags": [
          "Labels"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LabelRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Label created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Label"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create a label"
      }
    },
    "/shipmentOptions": {
      "get": {
        "operationId": "getShipmentOptions",
        "summary": "Get available shipment options",
        "tags": [
          "Shipments"
        ],
        "responses": {
          "200": {
            "description": "Shipment options",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ShipmentOption"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get available shipment options"
      }
    }
  },
  "components": {
    "schemas": {
      "TrackingResponse": {
        "type": "object",
        "properties": {
          "trackerCode": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "timestamp": {
                  "type": "string",
                  "format": "date-time"
                },
                "description": {
                  "type": "string"
                },
                "location": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Label": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "trackerCode": {
            "type": "string"
          },
          "labelType": {
            "type": "string"
          },
          "pdf": {
            "type": "string"
          }
        }
      },
      "LabelRequest": {
        "type": "object",
        "properties": {
          "shipmentId": {
            "type": "string"
          },
          "receiver": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "address": {
                "type": "object"
              }
            }
          },
          "shipper": {
            "type": "object"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ShipmentOption": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "JWT bearer token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Labels"
    },
    {
      "name": "Shipments"
    },
    {
      "name": "Tracking"
    }
  ]
}
