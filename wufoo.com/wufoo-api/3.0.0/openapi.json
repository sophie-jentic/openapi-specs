    "/forms/{formHash}/entries.json": {
      "get": {
        "operationId": "listFormEntries",
        "summary": "List form entries",
        "tags": [
          "Entries"
        ],
        "parameters": [
          {
            "name": "formHash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Form identifier hash"
          },
          {
            "name": "pageStart",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25,
              "maximum": 100
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortDirection",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "ASC",
                "DESC"
              ]
            }
          },
          {
            "name": "Filter1",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Entries": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "EntryCount": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List form entries"
      },
      "post": {
        "operationId": "submitFormEntry",
        "summary": "Submit form entry",
        "tags": [
          "Entries"
        ],
        "parameters": [
          {
            "name": "formHash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Form identifier hash"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Success": {
                      "type": "integer"
                    },
                    "EntryId": {
                      "type": "string"
                    },
                    "EntryLink": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Submit form entry"
      }
