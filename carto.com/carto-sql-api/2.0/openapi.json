{
  "openapi": "3.0.3",
  "info": {
    "title": "CARTO SQL API",
    "version": "2.0",
    "description": "The CARTO SQL API allows you to interact with your CARTO tables and data via SQL queries. Run arbitrary SQL to read, write, and modify data in your CARTO account. Also includes Import API for uploading data, Maps API for map tile generation, and Named Maps API for managing map templates.",
    "x-jentic-source-url": "https://carto.com/developers/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{username}.carto.com",
      "variables": {
        "username": {
          "default": "your-username",
          "description": "Your CARTO username"
        }
      }
    }
  ],
  "paths": {
    "/api/v2/sql": {
      "get": {
        "operationId": "executeSqlGet",
        "summary": "Execute SQL query (GET)",
        "description": "Execute a SQL query against your CARTO tables. Returns results in JSON format.",
        "tags": [
          "SQL"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "SQL query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Response format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "geojson",
                "csv",
                "shp",
                "svg",
                "kml",
                "spatialite"
              ]
            }
          },
          {
            "name": "dp",
            "in": "query",
            "description": "Decimal places for floating point values",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "rows_per_page",
            "in": "query",
            "description": "Rows per page",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SqlResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "executeSqlPost",
        "summary": "Execute SQL query (POST)",
        "description": "Execute a SQL query via POST. Better for long queries.",
        "tags": [
          "SQL"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "q"
                ],
                "properties": {
                  "q": {
                    "type": "string",
                    "description": "SQL query"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "json",
                      "geojson",
                      "csv",
                      "shp",
                      "svg",
                      "kml",
                      "spatialite"
                    ]
                  },
                  "dp": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SqlResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/sql/job": {
      "post": {
        "operationId": "createBatchSqlJob",
        "summary": "Create a batch SQL job",
        "description": "Create a batch SQL job for long-running queries.",
        "tags": [
          "SQL"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "query"
                ],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "SQL query or array of SQL queries"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch job created"
          },
          "400": {
            "description": "Bad request",
