              }
            }
          }
        }
      },
      "post": {
        "operationId": "createImport",
        "summary": "Import data",
        "description": "Import data from a URL or file upload.",
        "tags": [
          "Import"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "File to upload"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to import from"
                  },
                  "type_guessing": {
                    "type": "boolean",
                    "default": true
                  },
                  "quoted_fields_guessing": {
                    "type": "boolean",
                    "default": true
                  },
                  "content_guessing": {
                    "type": "boolean"
                  },
                  "create_visualization": {
                    "type": "boolean"
                  },
                  "table_name": {
                    "type": "string"
                  },
                  "privacy": {
                    "type": "string",
                    "enum": [
                      "private",
                      "public",
                      "link"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportStatus"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
