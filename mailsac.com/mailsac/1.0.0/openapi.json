{
  "openapi": "3.0.3",
  "info": {
    "title": "Mailsac API",
    "description": "Mailsac is a disposable email service providing REST APIs for managing temporary email addresses, receiving and reading messages, and integrating email testing into development workflows. Supports WebSockets and Webhooks for real-time notifications.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://mailsac.com/docs/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://mailsac.com",
      "description": "Mailsac API Server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Email Addresses",
      "description": "Manage email addresses"
    },
    {
      "name": "Messages",
      "description": "Retrieve and manage email messages"
    },
    {
      "name": "Message Content",
      "description": "Retrieve message content in various formats"
    },
    {
      "name": "Validation",
      "description": "Email validation and verification"
    },
    {
      "name": "Webhooks",
      "description": "Manage webhook notifications"
    }
  ],
  "paths": {
    "/api/addresses/{email}/messages": {
      "get": {
        "operationId": "listMessages",
        "summary": "List messages for an email address",
        "description": "Retrieve a list of messages received at the specified email address.",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "description": "Email address to check for messages",
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of messages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageSummary"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteAllMessages",
        "summary": "Delete all messages for an email address",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Messages deleted successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "description": "Delete all messages for an email address"
      }
    },
    "/api/addresses/{email}/messages/{messageId}": {
      "get": {
        "operationId": "getMessage",
        "summary": "Get a specific message metadata",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Message metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageSummary"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "description": "Message not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get a specific message metadata"
      },
      "delete": {
        "operationId": "deleteMessage",
        "summary": "Delete a specific message",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Message deleted successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "description": "Delete a specific message"
      }
    },
    "/api/text/{email}/{messageId}": {
      "get": {
        "operationId": "getMessageText",
        "summary": "Get plain text content of a message",
        "tags": [
          "Message Content"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Plain text content of the message",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "description": "Get plain text content of a message"
      }
    },
    "/api/raw/{email}/{messageId}": {
      "get": {
        "operationId": "getMessageRaw",
        "summary": "Get raw SMTP message with headers, body, and attachments",
        "tags": [
          "Message Content"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Raw SMTP message",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "description": "Get raw SMTP message with headers, body, and attachments"
      }
    },
    "/api/body/{email}/{messageId}": {
      "get": {
        "operationId": "getMessageBody",
        "summary": "Get sanitized HTML body of a message",
        "description": "Returns HTML body with images, links, and scripts removed for safe rendering.",
        "tags": [
          "Message Content"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sanitized HTML body",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/dirty/{email}/{messageId}": {
      "get": {
        "operationId": "getMessageDirtyBody",
        "summary": "Get unfiltered HTML body with inlined images",
        "tags": [
          "Message Content"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Unfiltered HTML body",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "description": "Get unfiltered HTML body with inlined images"
      }
    },
    "/api/headers/{email}/{messageId}": {
      "get": {
        "operationId": "getMessageHeaders",
        "summary": "Get SMTP headers as JSON",
        "tags": [
          "Message Content"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SMTP headers as JSON object",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "description": "Get SMTP headers as JSON"
      }
    },
    "/api/addresses": {
      "get": {
        "operationId": "listAddresses",
        "summary": "List reserved email addresses",
        "description": "Get a list of email addresses reserved on your account.",
        "tags": [
          "Email Addresses"
        ],
        "responses": {
          "200": {
            "description": "List of reserved addresses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EmailAddress"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/addresses/{email}": {
      "get": {
        "operationId": "getAddress",
        "summary": "Get information about an email address",
        "tags": [
          "Email Addresses"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Email address details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmailAddress"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "description": "Get information about an email address"
      },
      "post": {
        "operationId": "reserveAddress",
        "summary": "Reserve an email address",
        "tags": [
          "Email Addresses"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Address reserved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmailAddress"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "description": "Reserve an email address"
      },
      "delete": {
        "operationId": "releaseAddress",
        "summary": "Release a reserved email address",
        "tags": [
          "Email Addresses"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Address released successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "description": "Release a reserved email address"
      }
    },
    "/api/validations/{email}": {
      "get": {
        "operationId": "validateEmail",
        "summary": "Validate an email address",
        "description": "Check if an email address is valid and deliverable.",
        "tags": [
          "Validation"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/addresses/{email}/webhooks": {
      "get": {
        "operationId": "listWebhooks",
        "summary": "List webhooks for an email address",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of webhooks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Webhook"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "description": "List webhooks for an email address"
      },
      "post": {
        "operationId": "createWebhook",
        "summary": "Create a webhook for an email address",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "description": "Create a webhook for an email address"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Mailsac-Key",
        "description": "Mailsac API key passed in the Mailsac-Key header"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - missing or invalid Mailsac-Key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "MessageSummary": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "description": "Unique message identifier"
          },
          "from": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EmailParticipant"
            }
          },
          "to": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EmailParticipant"
            }
          },
          "subject": {
            "type": "string"
          },
          "inbox": {
            "type": "string",
            "description": "The email address this message was sent to"
          },
          "received": {
            "type": "string",
            "format": "date-time"
          },
          "size": {
            "type": "integer",
            "description": "Message size in bytes"
          },
          "attachments": {
            "type": "integer",
            "description": "Number of attachments"
          },
          "ip": {
            "type": "string",
            "description": "Sender IP address"
          },
          "via": {
            "type": "string"
          },
          "folder": {
            "type": "string"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "read": {
            "type": "boolean"
          },
          "rtls": {
            "type": "boolean",
            "description": "Whether TLS was used"
          }
        }
      },
      "EmailParticipant": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "EmailAddress": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "description": "The email address"
          },
          "owner": {
            "type": "string",
            "description": "Account that owns this address"
          },
          "encryptedInbox": {
            "type": "string"
          },
          "forward": {
            "type": "string",
            "description": "Forwarding address"
          },
          "enablews": {
            "type": "boolean",
            "description": "Whether WebSocket notifications are enabled"
          },
          "webhook": {
            "type": "string",
            "description": "Webhook URL"
          },
          "info": {
            "type": "string"
          }
        }
      },
      "ValidationResult": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "validFormat": {
            "type": "boolean"
          },
          "local": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "isDisposable": {
            "type": "boolean"
          },
          "disposableDomains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "enabled": {
            "type": "boolean"
          }
        }
      },
      "WebhookCreate": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to receive webhook notifications"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "message": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      }
    }
  }
}
