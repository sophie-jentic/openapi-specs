{
  "openapi": "3.0.3",
  "info": {
    "title": "Ontraport API",
    "description": "Ontraport is a comprehensive business automation platform API that provides access to contacts, campaigns, products, orders, messages, and more. The API supports full CRUD operations on objects and includes specialized features for marketing automation.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.ontraport.com/doc/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.ontraport.com/1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKey": [],
      "ApiAppId": []
    }
  ],
  "paths": {
    "/objects": {
      "get": {
        "summary": "Retrieve objects",
        "description": "Retrieve multiple objects of a specified type",
        "operationId": "getObjects",
        "parameters": [
          {
            "name": "objectID",
            "in": "query",
            "required": true,
            "description": "Object type ID (0=Contacts, 7=Messages, 16=Products, etc.)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "range",
            "in": "query",
            "description": "Number of results to return (max 50)",
            "schema": {
              "type": "integer",
              "maximum": 50,
              "default": 50
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Starting position for pagination",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "condition",
            "in": "query",
            "description": "JSON-encoded filter conditions",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "listFields",
            "in": "query",
            "description": "Comma-separated list of fields to return",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObjectsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "tags": [
          "objects"
        ]
      },
      "post": {
        "summary": "Create object",
        "description": "Create a new object",
        "operationId": "createObject",
        "parameters": [
          {
            "name": "objectID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Object created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObjectResponse"
                }
              }
            }
          }
        },
        "tags": [
          "objects"
        ]
      },
      "put": {
        "summary": "Update object",
        "description": "Update an existing object",
        "operationId": "updateObject",
        "parameters": [
          {
            "name": "objectID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "ID of the object to update",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Object updated successfully"
          }
        },
        "tags": [
          "objects"
        ]
      },
      "delete": {
        "summary": "Delete object",
        "description": "Delete an object",
        "operationId": "deleteObject",
        "parameters": [
          {
            "name": "objectID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object deleted successfully"
          }
        },
        "tags": [
          "objects"
        ]
      }
    },
    "/object": {
      "post": {
        "summary": "Get single object",
        "description": "Retrieve a single object by ID",
        "operationId": "getObject",
        "parameters": [
          {
            "name": "objectID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObjectResponse"
                }
              }
            }
          }
        },
        "tags": [
          "object"
        ]
      }
    },
    "/objects/saveorupdate": {
      "post": {
        "summary": "Save or update object",
        "description": "Create or update an object based on a lookup field",
        "operationId": "saveOrUpdateObject",
        "parameters": [
          {
            "name": "objectID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Object saved or updated successfully"
          }
        },
        "tags": [
          "objects"
        ]
      }
    },
    "/objects/tag": {
      "put": {
        "summary": "Tag objects",
        "description": "Add tags to objects",
        "operationId": "tagObjects",
        "parameters": [
          {
            "name": "objectID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "add_list",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of tag IDs to add",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ids",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of object IDs",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Objects tagged successfully"
          }
        },
        "tags": [
          "objects"
        ]
      }
    },
    "/objects/subscribe": {
      "post": {
        "summary": "Subscribe to sequence",
        "description": "Subscribe objects to a sequence or campaign",
        "operationId": "subscribeToSequence",
        "parameters": [
          {
            "name": "objectID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "sequence_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ids",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Subscribed successfully"
          }
        },
        "tags": [
          "objects"
        ]
      }
    },
    "/objects/meta": {
      "get": {
        "summary": "Get object metadata",
        "description": "Retrieve metadata about an object type including available fields",
        "operationId": "getObjectMeta",
        "parameters": [
          {
            "name": "objectID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "objects"
        ]
      }
    },
    "/Contacts": {
      "get": {
        "summary": "Get contacts",
        "description": "Retrieve contacts (convenience endpoint for objectID=0)",
        "operationId": "getContacts",
        "parameters": [
          {
            "name": "range",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "tags": [
          "Contacts"
        ]
      }
    },
    "/CreditCard/collect": {
      "post": {
        "summary": "Collect credit card",
        "description": "Process a credit card collection",
        "operationId": "collectCreditCard",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "contact_id": {
                    "type": "string"
                  },
                  "chargeNow": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Card collected successfully"
          }
        },
        "tags": [
          "CreditCard"
        ]
      }
    },
    "/transaction/processManual": {
      "post": {
        "summary": "Process manual transaction",
        "description": "Process a manual transaction",
        "operationId": "processManualTransaction",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "contact_id": {
                    "type": "string"
                  },
                  "chargeNow": {
                    "type": "string"
                  },
                  "offer_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction processed"
          }
        },
        "tags": [
          "transaction"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Api-Key",
        "description": "Your unique API key from Ontraport account settings"
      },
      "ApiAppId": {
        "type": "apiKey",
        "in": "header",
        "name": "Api-Appid",
        "description": "Your unique App ID from Ontraport account settings"
      }
    },
    "schemas": {
      "ObjectsResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Response code (0 = success)"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          },
          "account_id": {
            "type": "string"
          }
        }
      },
      "ObjectResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          },
          "account_id": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "data": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Authentication failed - invalid API key or App ID",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Contacts"
    },
    {
      "name": "CreditCard"
    },
    {
      "name": "object"
    },
    {
      "name": "objects"
    },
    {
      "name": "transaction"
    }
  ]
}
