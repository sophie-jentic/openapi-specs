            "type": "integer"
          },
          "lifepoints": {
            "type": "integer"
          },
          "members": {
            "type": "boolean"
          },
          "weakness": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "xp": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "aggressive": {
            "type": "boolean"
          },
          "poisonous": {
            "type": "boolean"
          },
          "attackable": {
            "type": "boolean"
          },
          "areas": {
            "type": "array",
