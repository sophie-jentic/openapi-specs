                "rank": {
                  "type": "integer"
                },
                "id": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "Quest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "COMPLETED",
              "STARTED",
              "NOT_STARTED"
            ]
          },
          "difficulty": {
            "type": "integer"
          },
          "members": {
            "type": "boolean"
