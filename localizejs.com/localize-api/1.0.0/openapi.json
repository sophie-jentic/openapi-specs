{
  "openapi": "3.0.3",
  "info": {
    "title": "Localize API",
    "version": "1.0.0",
    "description": "Localize (localizejs.com) provides website and application translation. The API manages translation projects, phrases, glossary terms, and languages.",
    "x-jentic-source-url": "https://help.localizejs.com/docs/getting-started-with-the-localize-api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.localizejs.com"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Bearer API key"
      }
    },
    "schemas": {
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "sourceLanguage": {
            "type": "string"
          },
          "activeLanguages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Phrase": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "sourceValue": {
            "type": "string"
          },
          "translations": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "context": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "GlossaryTerm": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "term": {
            "type": "string"
          },
          "definition": {
            "type": "string"
          },
          "translations": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "doNotTranslate": {
            "type": "boolean"
          }
        }
      },
      "Language": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          },
          "progress": {
            "type": "number"
          }
        }
      },
      "ImportResult": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer"
          },
          "updated": {
            "type": "integer"
          },
          "skipped": {
            "type": "integer"
          }
        }
      }
    }
  },
  "paths": {
    "/v1/projects": {
      "get": {
        "summary": "List projects",
        "operationId": "projects_list",
        "tags": [
          "Projects"
        ],
        "responses": {
          "200": {
            "description": "Projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "": "#/components/schemas/Project"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List projects"
      }
    },
    "/v1/projects/{projectId}": {
      "get": {
        "summary": "Retrieve a project",
        "operationId": "projects_get",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project",
            "content": {
              "application/json": {
                "schema": {
                  "": "#/components/schemas/Project"
                }
              }
            }
          }
        },
        "description": "Retrieve a project"
      }
    },
    "/v1/projects/{projectId}/phrases": {
      "get": {
        "summary": "List phrases",
        "operationId": "phrases_list",
        "tags": [
          "Phrases"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "perPage",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "language",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "untranslated",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Phrases",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "": "#/components/schemas/Phrase"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List phrases"
      },
      "post": {
        "summary": "Create a phrase",
        "operationId": "phrases_create",
        "tags": [
          "Phrases"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "key": {
                    "type": "string"
                  },
                  "sourceValue": {
                    "type": "string"
                  },
                  "context": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "key",
                  "sourceValue"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "": "#/components/schemas/Phrase"
                }
              }
            }
          }
        },
        "description": "Create a phrase"
      }
    },
    "/v1/projects/{projectId}/phrases/{phraseId}": {
      "get": {
        "summary": "Retrieve a phrase",
        "operationId": "phrases_get",
        "tags": [
          "Phrases"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "phraseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Phrase",
            "content": {
              "application/json": {
                "schema": {
                  "": "#/components/schemas/Phrase"
                }
              }
            }
          }
        },
        "description": "Retrieve a phrase"
      },
      "put": {
        "summary": "Update a phrase",
        "operationId": "phrases_update",
        "tags": [
          "Phrases"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "phraseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "context": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        },
        "description": "Update a phrase"
      },
      "delete": {
        "summary": "Delete a phrase",
        "operationId": "phrases_delete",
        "tags": [
          "Phrases"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "phraseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          }
        },
        "description": "Delete a phrase"
      }
    },
    "/v1/projects/{projectId}/phrases/{phraseId}/translations/{languageCode}": {
      "put": {
        "summary": "Update translation",
        "operationId": "phrases_translate",
        "tags": [
          "Phrases"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "phraseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "languageCode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "string"
                  }
                },
                "required": [
                  "value"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Translation updated"
          }
        },
        "description": "Update translation"
      }
    },
    "/v1/projects/{projectId}/languages": {
      "get": {
        "summary": "List languages",
        "operationId": "languages_list",
        "tags": [
          "Languages"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Languages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "": "#/components/schemas/Language"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List languages"
      },
      "post": {
        "summary": "Add a language",
        "operationId": "languages_add",
        "tags": [
          "Languages"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string"
                  }
                },
                "required": [
                  "code"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Language added"
          }
        },
        "description": "Add a language"
      }
    },
    "/v1/projects/{projectId}/glossary": {
      "get": {
        "summary": "List glossary terms",
        "operationId": "glossary_list",
        "tags": [
          "Glossary"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Glossary terms",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "": "#/components/schemas/GlossaryTerm"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List glossary terms"
      },
      "post": {
        "summary": "Create a glossary term",
        "operationId": "glossary_create",
        "tags": [
          "Glossary"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "term": {
                    "type": "string"
                  },
                  "definition": {
                    "type": "string"
                  },
                  "doNotTranslate": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "term"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        },
        "description": "Create a glossary term"
      }
    },
    "/v1/projects/{projectId}/import": {
      "post": {
        "summary": "Import translations",
        "operationId": "import_translations",
        "tags": [
          "Import/Export"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import result",
            "content": {
              "application/json": {
                "schema": {
                  "": "#/components/schemas/ImportResult"
                }
              }
            }
          }
        },
        "description": "Import translations"
      }
    },
    "/v1/projects/{projectId}/export": {
      "get": {
        "summary": "Export translations",
        "operationId": "export_translations",
        "tags": [
          "Import/Export"
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv",
                "xliff",
                "po"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Export file",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        },
        "description": "Export translations"
      }
    }
  },
  "tags": [
    {
      "name": "Glossary"
    },
    {
      "name": "Import/Export"
    },
    {
      "name": "Languages"
    },
    {
      "name": "Phrases"
    },
    {
      "name": "Projects"
    }
  ]
}
