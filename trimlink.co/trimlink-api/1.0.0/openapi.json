{
  "openapi": "3.0.3",
  "info": {
    "title": "TrimLink API",
    "version": "1.0.0",
    "description": "URL shortener API for creating, managing, and tracking short links with custom domains, folders, QR codes, and analytics.",
    "x-jentic-source-url": "https://trimlink.co/developers",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://trimlink.co"
    }
  ],
  "paths": {
    "/api/v1/shorten": {
      "post": {
        "operationId": "createShortLink",
        "summary": "Create a short link",
        "tags": [
          "Links"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "Destination URL"
                  },
                  "customCode": {
                    "type": "string",
                    "description": "Custom short code (3-50 chars)"
                  },
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "expiresAt": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "folderId": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Link created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LinkResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create a short link"
      }
    },
