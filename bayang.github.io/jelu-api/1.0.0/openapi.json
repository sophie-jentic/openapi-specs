              "type": "string"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated book list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedBooks"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List books"
      },
      "post": {
        "operationId": "createBook",
        "summary": "Create a book",
        "tags": [
          "Books"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "book": {
                    "type": "string",
                    "description": "JSON book object"
                  },
                  "cover": {
                    "type": "string",
                    "format": "binary",
                    "description": "Cover image"
                  }
                },
                "required": [
                  "book"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Book created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Book"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a book"
      }
    },
