{
  "openapi": "3.0.0",
  "info": {
    "title": "ZenRows API",
    "version": "1.0.0",
    "description": "Web scraping API with anti-bot bypass, residential proxies, and headless browser support. Handles CAPTCHAs, JavaScript rendering, and advanced scraping scenarios.",
    "contact": {
      "name": "ZenRows Support",
      "url": "https://www.zenrows.com"
    }
  },
  "servers": [
    {
      "url": "https://api.zenrows.com/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Scrape URL",
        "description": "Scrape a web page with advanced anti-bot bypass and optional JavaScript rendering",
        "operationId": "scrapeUrl",
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "description": "Your ZenRows API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "The target URL to scrape (URL-encoded)",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "js_render",
            "in": "query",
            "description": "Enable JavaScript rendering",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "premium_proxy",
            "in": "query",
            "description": "Use premium residential proxies",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "proxy_country",
            "in": "query",
            "description": "ISO 3166-1 alpha-2 country code for proxy location",
            "schema": {
              "type": "string",
              "pattern": "^[A-Z]{2}$"
            }
          },
          {
            "name": "wait",
            "in": "query",
            "description": "Wait time in milliseconds for JavaScript rendering",
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "wait_for",
            "in": "query",
            "description": "CSS selector to wait for before returning content",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "css_extractor",
            "in": "query",
            "description": "JSON string defining CSS selectors to extract specific data",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "json_response",
            "in": "query",
            "description": "Return response in JSON format",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "original_status",
            "in": "query",
            "description": "Return the original HTTP status code from target",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "custom_headers",
            "in": "query",
            "description": "Enable custom headers (sent via request headers)",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "device",
            "in": "query",
            "description": "Device type for user agent",
            "schema": {
              "type": "string",
              "enum": [
                "desktop",
                "mobile"
              ],
              "default": "desktop"
            }
          },
          {
            "name": "screenshot",
            "in": "query",
            "description": "Return a screenshot (requires js_render=true)",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "screenshot_fullpage",
            "in": "query",
            "description": "Capture full page screenshot",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "window_width",
            "in": "query",
            "description": "Browser window width in pixels",
            "schema": {
              "type": "integer",
              "default": 1920
            }
          },
          {
            "name": "window_height",
            "in": "query",
            "description": "Browser window height in pixels",
            "schema": {
              "type": "integer",
              "default": 1080
            }
          },
          {
            "name": "autoparse",
            "in": "query",
            "description": "Automatically parse structured data from supported sites",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully scraped content",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string",
                  "description": "HTML content of the scraped page"
                }
              },
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "JSON response when json_response=true or css_extractor is used"
                }
              },
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary",
                  "description": "Screenshot image when screenshot=true"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          },
          "422": {
            "description": "Unprocessable entity - scraping failed"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "tags": [
          "default"
        ]
      },
      "post": {
        "summary": "Scrape URL with POST data",
        "description": "Scrape a web page using POST method with request body",
        "operationId": "scrapeUrlPost",
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "description": "Your ZenRows API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "The target URL to scrape",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "js_render",
            "in": "query",
            "description": "Enable JavaScript rendering",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "premium_proxy",
            "in": "query",
            "description": "Use premium residential proxies",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "requestBody": {
          "description": "POST data to send to the target URL",
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully scraped content",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "default"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "apikey",
        "description": "API key obtained from ZenRows dashboard"
      }
    }
  },
  "tags": [
    {
      "name": "default"
    }
  ]
}
