            "type": "string"
          },
          "location_id": {
            "type": "string"
          }
        }
      },
      "Access": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "key_id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "access_code": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "cancelled",
              "expired"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AccessRequest": {
        "type": "object",
        "required": [
          "key_id",
          "email",
          "start_time",
          "end_time"
        ],
        "properties": {
          "key_id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "SmartBox": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "serial_number": {
            "type": "string"
          },
          "location_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "online",
              "offline"
            ]
          },
          "bins": {
            "type": "array",
