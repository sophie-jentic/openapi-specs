              "type": "object",
              "properties": {
                "bin_number": {
                  "type": "integer"
                },
                "occupied": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "postal_code": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "event_type": {
            "type": "string",
            "enum": [
              "pickup",
              "dropoff",
              "access_granted",
              "access_denied"
            ]
          },
          "key_id": {
            "type": "string"
          },
          "access_id": {
            "type": "string"
          },
          "smartbox_id": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "user_email": {
            "type": "string"
