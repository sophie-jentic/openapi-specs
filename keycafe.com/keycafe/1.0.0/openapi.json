              "type": "string"
            }
          },
          "active": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
