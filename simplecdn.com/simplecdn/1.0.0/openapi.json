{
  "openapi": "3.0.0",
  "info": {
    "title": "SimpleCDN API (formerly PageCDN)",
    "version": "1.0.0",
    "description": "SimpleCDN (formerly PageCDN) provides CDN services for accelerating web content delivery. Note: Public API documentation is not readily available; this specification is based on typical CDN API patterns.",
    "contact": {
      "url": "https://simplecdn.com"
    }
  },
  "servers": [
    {
      "url": "https://api.simplecdn.com/v1"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/zones": {
      "get": {
        "summary": "List CDN zones",
        "description": "Retrieve a list of all CDN zones in your account",
        "operationId": "listZones",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "description": "Number of zones per page",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of zones",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "zones": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "origin": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string",
                            "enum": [
                              "active",
                              "pending",
                              "inactive"
                            ]
                          },
                          "created_at": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "page": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "total": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "zones"
        ]
      },
      "post": {
        "summary": "Create CDN zone",
        "description": "Create a new CDN zone",
        "operationId": "createZone",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "origin"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Zone name or domain"
                  },
                  "origin": {
                    "type": "string",
                    "description": "Origin server URL"
                  },
                  "ssl": {
                    "type": "boolean",
                    "description": "Enable SSL/TLS",
                    "default": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Zone created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "zone": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        },
                        "origin": {
                          "type": "string"
                        },
                        "cdn_url": {
                          "type": "string",
                          "description": "CDN URL for the zone"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "zones"
        ]
      }
    },
    "/zones/{zone_id}": {
      "get": {
        "summary": "Get zone details",
        "description": "Retrieve details for a specific CDN zone",
        "operationId": "getZone",
        "parameters": [
          {
            "name": "zone_id",
            "in": "path",
            "required": true,
            "description": "Zone identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Zone details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "zone": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        },
                        "origin": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string"
                        },
                        "cdn_url": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Zone not found"
          }
        },
        "tags": [
          "zones"
        ]
      },
      "delete": {
        "summary": "Delete zone",
        "description": "Delete a CDN zone",
        "operationId": "deleteZone",
        "parameters": [
          {
            "name": "zone_id",
            "in": "path",
            "required": true,
            "description": "Zone identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Zone deleted successfully"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Zone not found"
          }
        },
        "tags": [
          "zones"
        ]
      }
    },
    "/zones/{zone_id}/purge": {
      "post": {
        "summary": "Purge cache",
        "description": "Purge cached content for a zone",
        "operationId": "purgeCache",
        "parameters": [
          {
            "name": "zone_id",
            "in": "path",
            "required": true,
            "description": "Zone identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Specific files to purge (empty for all)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cache purge initiated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Zone not found"
          }
        },
        "tags": [
          "zones"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication"
      }
    }
  },
  "tags": [
    {
      "name": "zones"
    }
  ]
}
