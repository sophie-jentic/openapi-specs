{
  "openapi": "3.0.3",
  "info": {
    "title": "Sailthru API",
    "description": "Sailthru (Marigold Engage) API for email marketing automation, user profile management, campaign scheduling, content management, purchase tracking, and analytics. Authentication uses a shared-secret hash scheme with api_key and sig parameters on every request.",
    "version": "1.0",
    "x-jentic-source-url": "https://getstarted.meetmarigold.com/engagebysailthru/Content/developers/api-basics/introduction.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.sailthru.com",
      "description": "Sailthru production API"
    }
  ],
  "security": [
    {
      "sailthruAuth": []
    }
  ],
  "paths": {
    "/user": {
      "get": {
        "operationId": "getUser",
        "summary": "Retrieve user profile data",
        "description": "Fetch user information by email, sid, extid, SMS number, or other identifier.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "User identifier value (email, sid, extid, etc.)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "description": "Identifier type: email (default), sid, extid, sms, cookie, fb, twitter",
            "schema": {
              "type": "string",
              "enum": [
                "email",
                "sid",
                "extid",
                "sms",
                "cookie",
                "fb",
                "twitter"
              ]
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "JSON object specifying additional fields to return (activity, device, lifetime, purchases, smart_lists, purchase_incomplete)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sig",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User profile data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfile"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      },
      "post": {
        "operationId": "createOrUpdateUser",
        "summary": "Create or update a user profile",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "sig"
                ],
                "properties": {
                  "api_key": {
                    "type": "string"
                  },
                  "sig": {
                    "type": "string"
                  },
                  "json": {
                    "type": "string",
                    "description": "JSON-encoded object with user data including id, key, keys, vars, lists, optout_email, fields"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "description": "Create or update a user profile"
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Permanently delete a user profile",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "email",
                "sid",
                "extid",
                "sms",
                "fb",
                "twitter"
              ]
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sig",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "description": "Permanently delete a user profile"
      }
    },
