      "delete": {
        "operationId": "cancelSend",
        "summary": "Cancel a scheduled send",
        "tags": [
          "Send"
        ],
        "parameters": [
          {
            "name": "send_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sig",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Send cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "description": "Cancel a scheduled send"
      }
    },
    "/blast": {
      "get": {
        "operationId": "getBlast",
        "summary": "Retrieve campaign data",
        "description": "Fetch information about a specific campaign by blast_id, or list campaigns by status.",
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "blast_id",
            "in": "query",
            "description": "Specific campaign ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by campaign status",
            "schema": {
              "type": "string",
              "enum": [
                "created",
                "scheduled",
                "sending",
                "sent"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Max blasts to return (default 20, use 0 for all)",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Pagination offset",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "list",
            "in": "query",
            "description": "Filter by list name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "vars",
            "in": "query",
            "description": "Set to 1 to return blast variables",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sig",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlastResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      },
      "post": {
        "operationId": "createOrUpdateBlast",
        "summary": "Create, update, or schedule a campaign",
        "tags": [
          "Campaigns"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "sig"
                ],
                "properties": {
                  "api_key": {
                    "type": "string"
                  },
                  "sig": {
                    "type": "string"
                  },
                  "json": {
                    "type": "string",
                    "description": "JSON-encoded object with name, list, schedule_time, from_name, from_email, subject, content_html, content_text, blast_id, suppress_list, vars, labels"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Campaign created or updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlastResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "description": "Create, update, or schedule a campaign"
      },
      "delete": {
        "operationId": "deleteBlast",
        "summary": "Delete a campaign",
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "blast_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sig",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "blast_id": {
                      "type": "integer"
                    },
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        },
        "description": "Delete a campaign"
      }
    },
