{
  "openapi": "3.0.3",
  "info": {
    "title": "Poof API",
    "version": "1.0.0",
    "description": "Poof background removal API. Remove backgrounds from images.",
    "x-jentic-source-url": "https://docs.poof.bg",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.poof.bg/v1"
    }
  ],
  "tags": [
    {
      "name": "Image Processing"
    }
  ],
  "paths": {
    "/remove": {
      "post": {
        "operationId": "removeBackground",
        "tags": [
          "Image Processing"
        ],
        "summary": "Remove background from image",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "image_file"
                ],
                "properties": {
                  "image_file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image file to process"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Processed image with background removed",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Remove background from image"
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}
