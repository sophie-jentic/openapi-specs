{
  "openapi": "3.0.3",
  "info": {
    "title": "Vtiger VTAP REST API",
    "version": "1.0.0",
    "description": "Vtiger CRM REST API for managing CRM records, modules, relationships, tags, and performing queries and sync operations.",
    "x-jentic-source-url": "https://vtap.vtiger.com/platform/rest-apis.html",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{instance}.odx.vtiger.com/restapi/v1/vtiger/default",
      "variables": {
        "instance": {
          "default": "your-instance",
          "description": "Your Vtiger instance name"
        }
      }
    }
