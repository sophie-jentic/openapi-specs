{
  "openapi": "3.0.3",
  "info": {
    "title": "GoPay REST API",
    "version": "1.0.0",
    "description": "GoPay payment gateway REST API for creating payments, managing refunds, recurring payments, and preauthorizations.",
    "x-jentic-source-url": "https://speca.io/gopaycz/gopay-rest-api-en",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://gate.gopay.cz/api"
    }
  ],
  "paths": {
    "/oauth2/token": {
      "post": {
        "operationId": "getAccessToken",
        "summary": "Get access token",
        "description": "Obtain access token using client credentials.",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "client_credentials"
                    ]
                  },
                  "scope": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    },
    "/payments/payment": {
      "post": {
        "operationId": "createPayment",
        "summary": "Create payment",
        "description": "Create a standard payment for an order.",
        "tags": [
          "Payments"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}": {
      "get": {
        "operationId": "getPaymentStatus",
        "summary": "Get payment status",
        "description": "Get the status of a payment.",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}/refund": {
      "post": {
        "operationId": "refundPayment",
        "summary": "Refund payment",
        "description": "Refund a completed payment, fully or partially.",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": {
                    "type": "integer",
                    "description": "Amount in cents for partial refund"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefundResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}/create-recurrence": {
      "post": {
        "operationId": "createRecurrence",
        "summary": "Create recurring payment",
        "description": "Create a recurring payment on demand based on a previously established recurring payment.",
        "tags": [
          "Recurring"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecurrenceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}/void-recurrence": {
      "post": {
        "operationId": "cancelRecurrence",
        "summary": "Cancel recurring payment",
        "description": "Cancel recurrence of a previously created payment.",
        "tags": [
          "Recurring"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VoidResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}/capture": {
      "post": {
        "operationId": "capturePayment",
        "summary": "Capture preauthorized payment",
        "description": "Capture preauthorized funds.",
        "tags": [
          "Preauthorization"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CaptureResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}/void-authorization": {
      "post": {
        "operationId": "voidAuthorization",
        "summary": "Void preauthorization",
        "description": "Release pre-authorization funds.",
        "tags": [
          "Preauthorization"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VoidResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/eshops/eshop/{goid}/payment-instruments/{currency}": {
      "get": {
        "operationId": "listPaymentInstruments",
        "summary": "List payment methods",
        "description": "Get allowed payment methods for an eshop.",
        "tags": [
          "Eshops"
        ],
        "parameters": [
          {
            "name": "goid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "currency",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentInstrumentsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/account-statement": {
      "post": {
        "operationId": "getAccountStatement",
        "summary": "Get account statement",
        "description": "Generate statements from GoPay business account.",
        "tags": [
          "Accounts"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountStatementRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Statement file",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "token_type": {
            "type": "string"
          },
          "access_token": {
            "type": "string"
          },
          "refresh_token": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer"
          }
        }
      },
      "CreatePaymentRequest": {
        "type": "object",
        "required": [
          "target",
          "amount",
          "currency",
          "order_number"
        ],
        "properties": {
          "payer": {
            "type": "object"
          },
          "target": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "goid": {
                "type": "integer"
              }
            }
          },
          "amount": {
            "type": "integer"
          },
          "currency": {
            "type": "string"
          },
          "order_number": {
            "type": "string",
            "maxLength": 128
          },
          "order_description": {
            "type": "string",
            "maxLength": 256
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "callback": {
            "type": "object",
            "properties": {
              "return_url": {
                "type": "string"
              },
              "notification_url": {
                "type": "string"
              }
            }
          },
          "lang": {
            "type": "string"
          },
          "preauthorization": {
            "type": "boolean"
          },
          "recurrence": {
            "type": "object"
          }
        }
      },
      "PaymentResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "order_number": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "CREATED",
              "PAYMENT_METHOD_CHOSEN",
              "PAID",
              "AUTHORIZED",
              "CANCELED",
              "TIMEOUTED",
              "REFUNDED",
              "PARTIALLY_REFUNDED"
            ]
          },
          "amount": {
            "type": "integer"
          },
          "currency": {
            "type": "string"
          },
          "payer": {
            "type": "object"
          },
          "target": {
            "type": "object"
          },
          "gw_url": {
            "type": "string"
          }
        }
      },
      "RefundResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "result": {
            "type": "string",
            "enum": [
              "FINISHED"
            ]
          }
        }
      },
      "VoidResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "result": {
            "type": "string",
            "enum": [
              "ACCEPTED",
              "FINISHED"
            ]
          }
        }
      },
      "CaptureResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "result": {
            "type": "string",
            "enum": [
              "FINISHED"
            ]
          }
        }
      },
      "RecurrenceRequest": {
        "type": "object",
        "required": [
          "amount",
          "currency",
          "order_number",
          "items"
        ],
        "properties": {
          "amount": {
            "type": "integer"
          },
          "currency": {
            "type": "string"
          },
          "order_number": {
            "type": "string",
            "maxLength": 128
          },
          "order_description": {
            "type": "string",
            "maxLength": 256
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "PaymentInstrumentsResponse": {
        "type": "object",
        "properties": {
          "groups": {
            "type": "object"
          },
          "enabledPaymentInstruments": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "AccountStatementRequest": {
        "type": "object",
        "required": [
          "date_from",
          "date_to",
          "goid",
          "currency",
          "format"
        ],
        "properties": {
          "date_from": {
            "type": "string",
            "format": "date"
          },
          "date_to": {
            "type": "string",
            "format": "date"
          },
          "goid": {
            "type": "integer"
          },
          "currency": {
            "type": "string"
          },
          "format": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Accounts"
    },
    {
      "name": "Authentication"
    },
    {
      "name": "Eshops"
    },
    {
      "name": "Payments"
    },
    {
      "name": "Preauthorization"
    },
    {
      "name": "Recurring"
    }
  ]
}
