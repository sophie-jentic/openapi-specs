{
  "openapi": "3.0.3",
  "info": {
    "title": "WebinarJam API",
    "description": "The WebinarJam API allows you to manage webinars, register participants, retrieve registrant and attendee data, and manage lead subscriptions on the WebinarJam platform. All requests use POST method with form-urlencoded body and require an API key passed in the request body.",
    "version": "1.0.0",
    "contact": {
      "name": "WebinarJam Support",
      "url": "https://support.webinarjam.com"
    }
  },
  "servers": [
    {
      "url": "https://api.webinarjam.com",
      "description": "WebinarJam API Server"
    }
  ],
  "paths": {
    "/webinarjam/webinars": {
      "post": {
        "operationId": "listWebinars",
        "summary": "List all webinars",
        "description": "Retrieves a list of all webinars in your WebinarJam account.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key"
                ],
                "properties": {
                  "api_key": {
                    "type": "string",
                    "description": "Your WebinarJam API key."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with list of webinars.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Status of the request.",
                      "example": "success"
                    },
                    "webinars": {
                      "type": "array",
                      "description": "Array of webinar summary objects.",
                      "items": {
                        "$ref": "#/components/schemas/WebinarSummary"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "webinarjam"
        ]
      }
    },
    "/webinarjam/webinar": {
      "post": {
        "operationId": "getWebinar",
        "summary": "Get webinar details",
        "description": "Retrieves detailed information about a specific webinar, including its schedules.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "webinar_id"
                ],
                "properties": {
                  "api_key": {
                    "type": "string",
                    "description": "Your WebinarJam API key."
                  },
                  "webinar_id": {
                    "type": "integer",
                    "description": "The unique identifier of the webinar."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with webinar details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Status of the request.",
                      "example": "success"
                    },
                    "webinar": {
                      "$ref": "#/components/schemas/WebinarDetail"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Webinar not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "webinarjam"
        ]
      }
    },
    "/webinarjam/register": {
      "post": {
        "operationId": "registerParticipant",
        "summary": "Register a participant",
        "description": "Registers a new participant to a specific webinar schedule. Returns the registrant details including their unique link to join the webinar.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "webinar_id",
                  "schedule",
                  "first_name",
                  "email"
                ],
                "properties": {
                  "api_key": {
                    "type": "string",
                    "description": "Your WebinarJam API key."
                  },
                  "webinar_id": {
                    "type": "integer",
                    "description": "The unique identifier of the webinar."
                  },
                  "schedule": {
                    "type": "integer",
                    "description": "The schedule number for the webinar (0 for the first schedule, 1 for the second, etc.)."
                  },
                  "first_name": {
                    "type": "string",
                    "description": "First name of the registrant."
                  },
                  "last_name": {
                    "type": "string",
                    "description": "Last name of the registrant."
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email address of the registrant."
                  },
                  "phone_country_code": {
                    "type": "string",
                    "description": "Country code for the registrant's phone number (e.g., '1' for US)."
                  },
                  "phone": {
                    "type": "string",
                    "description": "Phone number of the registrant."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful registration response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Status of the request.",
                      "example": "success"
                    },
                    "user": {
                      "$ref": "#/components/schemas/Registrant"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Missing required parameters or invalid data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "webinarjam"
        ]
      }
    },
    "/webinarjam/registrants": {
      "post": {
        "operationId": "listRegistrants",
        "summary": "List registrants for a webinar",
        "description": "Retrieves the list of all registrants for a specific webinar schedule.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "webinar_id",
                  "schedule"
                ],
                "properties": {
                  "api_key": {
                    "type": "string",
                    "description": "Your WebinarJam API key."
                  },
                  "webinar_id": {
                    "type": "integer",
                    "description": "The unique identifier of the webinar."
                  },
                  "schedule": {
                    "type": "integer",
                    "description": "The schedule number for the webinar (0 for the first schedule, 1 for the second, etc.)."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with list of registrants.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Status of the request.",
                      "example": "success"
                    },
                    "registrants": {
                      "type": "array",
                      "description": "Array of registrant objects.",
                      "items": {
                        "$ref": "#/components/schemas/Registrant"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "webinarjam"
        ]
      }
    },
    "/webinarjam/unsubscribe": {
      "post": {
        "operationId": "unsubscribeRegistrant",
        "summary": "Unsubscribe a registrant",
        "description": "Unsubscribes a lead from a specific webinar, removing them from future communications related to that webinar.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "webinar_id",
                  "email"
                ],
                "properties": {
                  "api_key": {
                    "type": "string",
                    "description": "Your WebinarJam API key."
                  },
                  "webinar_id": {
                    "type": "integer",
                    "description": "The unique identifier of the webinar."
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email address of the registrant to unsubscribe."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful unsubscription response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Status of the request.",
                      "example": "success"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "webinarjam"
        ]
      }
    },
    "/webinarjam/countries": {
      "post": {
        "operationId": "listCountries",
        "summary": "List supported countries",
        "description": "Retrieves the list of supported countries with their phone country codes. Useful for populating country/phone code dropdowns in registration forms.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key"
                ],
                "properties": {
                  "api_key": {
                    "type": "string",
                    "description": "Your WebinarJam API key."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with list of countries.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Status of the request.",
                      "example": "success"
                    },
                    "countries": {
                      "type": "array",
                      "description": "Array of country objects.",
                      "items": {
                        "$ref": "#/components/schemas/Country"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "webinarjam"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "WebinarSummary": {
        "type": "object",
        "properties": {
          "webinar_id": {
            "type": "integer",
            "description": "Unique identifier of the webinar."
          },
          "name": {
            "type": "string",
            "description": "Name/title of the webinar."
          },
          "description": {
            "type": "string",
            "description": "Description of the webinar."
          },
          "schedules": {
            "type": "array",
            "description": "Array of schedule objects for the webinar.",
            "items": {
              "$ref": "#/components/schemas/Schedule"
            }
          }
        }
      },
      "WebinarDetail": {
        "type": "object",
        "properties": {
          "webinar_id": {
            "type": "integer",
            "description": "Unique identifier of the webinar."
          },
          "name": {
            "type": "string",
            "description": "Name/title of the webinar."
          },
          "description": {
            "type": "string",
            "description": "Description of the webinar."
          },
          "timezone": {
            "type": "string",
            "description": "Timezone of the webinar."
          },
          "schedules": {
            "type": "array",
            "description": "Array of schedule objects for the webinar.",
            "items": {
              "$ref": "#/components/schemas/Schedule"
            }
          },
          "presenters": {
            "type": "array",
            "description": "Array of presenter objects.",
            "items": {
              "$ref": "#/components/schemas/Presenter"
            }
          },
          "registration_url": {
            "type": "string",
            "format": "uri",
            "description": "Public registration URL for the webinar."
          }
        }
      },
      "Schedule": {
        "type": "object",
        "properties": {
          "schedule": {
            "type": "integer",
            "description": "Schedule index number."
          },
          "date": {
            "type": "string",
            "description": "Date of the scheduled session."
          },
          "time": {
            "type": "string",
            "description": "Time of the scheduled session."
          },
          "comment": {
            "type": "string",
            "description": "Comment or label for the schedule."
          }
        }
      },
      "Presenter": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the presenter."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email of the presenter."
          },
          "role": {
            "type": "string",
            "description": "Role of the presenter (e.g., host, moderator, presenter)."
          }
        }
      },
      "Registrant": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string",
            "description": "First name of the registrant."
          },
          "last_name": {
            "type": "string",
            "description": "Last name of the registrant."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the registrant."
          },
          "phone_country_code": {
            "type": "string",
            "description": "Country code for the registrant's phone."
          },
          "phone": {
            "type": "string",
            "description": "Phone number of the registrant."
          },
          "thank_you_url": {
            "type": "string",
            "format": "uri",
            "description": "Unique thank-you/confirmation page URL for the registrant."
          },
          "live_room_url": {
            "type": "string",
            "format": "uri",
            "description": "Unique live room URL for the registrant to join the webinar."
          },
          "replay_room_url": {
            "type": "string",
            "format": "uri",
            "description": "Unique replay room URL for the registrant."
          }
        }
      },
      "Country": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the country."
          },
          "code": {
            "type": "string",
            "description": "ISO country code."
          },
          "phone_country_code": {
            "type": "string",
            "description": "Phone country code (e.g., '1' for US, '44' for UK)."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Status of the request.",
            "example": "error"
          },
          "message": {
            "type": "string",
            "description": "Error message describing what went wrong."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "webinarjam"
    }
  ]
}
