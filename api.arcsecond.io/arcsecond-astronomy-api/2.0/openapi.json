{
  "openapi": "3.0.3",
  "info": {
    "title": "Arcsecond Astronomy API",
    "description": "Unified REST APIs for world-wide astronomy data including exoplanets, observing sites, telescopes, instruments, observations, and astronomical objects.",
    "version": "2.0",
    "contact": {
      "name": "Arcsecond",
      "url": "https://www.arcsecond.io"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "externalDocs": {
    "description": "Arcsecond API Home",
    "url": "https://api.arcsecond.io"
  },
  "servers": [
    {
      "url": "https://api.arcsecond.io",
      "description": "Arcsecond Production"
    }
  ],
  "security": [
    {
      "tokenAuth": []
    },
    {}
  ],
  "paths": {
    "/auth/register/": {
      "post": {
        "operationId": "registerUser",
        "summary": "Register a new user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "email",
                  "password1",
                  "password2"
                ],
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password1": {
                    "type": "string"
                  },
                  "password2": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created"
          },
          "400": {
            "description": "Validation error"
          }
        },
        "description": "Register a new user",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/login/": {
      "post": {
        "operationId": "loginUser",
        "summary": "Log in and receive auth token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "key": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid credentials"
          }
        },
        "description": "Log in and receive auth token",
        "tags": [
          "auth"
        ]
      }
    },
    "/exoplanets/": {
      "get": {
        "operationId": "listExoplanets",
        "summary": "List all exoplanets",
        "security": [],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "api"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of exoplanets",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResult"
                }
              }
            }
          }
        },
        "description": "List all exoplanets",
        "tags": [
          "exoplanets"
        ]
      }
    },
    "/exoplanets/{name}/": {
      "get": {
        "operationId": "getExoplanet",
        "summary": "Get a specific exoplanet",
        "security": [],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Exoplanet details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Exoplanet"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a specific exoplanet",
        "tags": [
          "exoplanets"
        ]
      }
    },
    "/objects/{name}/": {
      "get": {
        "operationId": "getAstronomicalObject",
        "summary": "Get an astronomical object by name",
        "security": [],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Astronomical object details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get an astronomical object by name",
        "tags": [
          "objects"
        ]
      }
    },
    "/observingsites/": {
      "get": {
        "operationId": "listObservingSites",
        "summary": "List observing sites worldwide",
        "security": [],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of observing sites",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResult"
                }
              }
            }
          }
        },
        "description": "List observing sites worldwide",
        "tags": [
          "observingsites"
        ]
      }
    },
    "/observingsites/{uuid}/": {
      "get": {
        "operationId": "getObservingSite",
        "summary": "Get a specific observing site",
        "security": [],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Observing site details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a specific observing site",
        "tags": [
          "observingsites"
        ]
      }
    },
    "/telescopes/": {
      "get": {
        "operationId": "listTelescopes",
        "summary": "List telescopes",
        "security": [],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of telescopes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResult"
                }
              }
            }
          }
        },
        "description": "List telescopes",
        "tags": [
          "telescopes"
        ]
      }
    },
    "/telescopes/{uuid}/": {
      "get": {
        "operationId": "getTelescope",
        "summary": "Get a specific telescope",
        "security": [],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Telescope details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "description": "Get a specific telescope",
        "tags": [
          "telescopes"
        ]
      }
    },
    "/profiles/{username}/": {
      "get": {
        "operationId": "getUserProfile",
        "summary": "Get a user's public profile",
        "security": [],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a user's public profile",
        "tags": [
          "profiles"
        ]
      }
    },
    "/satellites/": {
      "get": {
        "operationId": "listSatellites",
        "summary": "List satellites and space debris",
        "security": [],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of satellites",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResult"
                }
              }
            }
          }
        },
        "description": "List satellites and space debris",
        "tags": [
          "satellites"
        ]
      }
    },
    "/observations/": {
      "get": {
        "operationId": "listObservations",
        "summary": "List observations",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of observations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResult"
                }
              }
            }
          }
        },
        "description": "List observations",
        "tags": [
          "observations"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "Token-based auth: Authorization: Token <api_key>"
      }
    },
    "schemas": {
      "PaginatedResult": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "next": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "previous": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Exoplanet": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "coordinates": {
            "type": "object",
            "properties": {
              "ra": {
                "type": "number"
              },
              "dec": {
                "type": "number"
              }
            }
          },
          "mass": {
            "type": "number",
            "nullable": true
          },
          "radius": {
            "type": "number",
            "nullable": true
          },
          "orbital_period": {
            "type": "number",
            "nullable": true
          },
          "semi_major_axis": {
            "type": "number",
            "nullable": true
          },
          "eccentricity": {
            "type": "number",
            "nullable": true
          },
          "inclination": {
            "type": "number",
            "nullable": true
          },
          "discovery_method": {
            "type": "string"
          },
          "discovery_year": {
            "type": "integer",
            "nullable": true
          },
          "star": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "auth"
    },
    {
      "name": "exoplanets"
    },
    {
      "name": "objects"
    },
    {
      "name": "observations"
    },
    {
      "name": "observingsites"
    },
    {
      "name": "profiles"
    },
    {
      "name": "satellites"
    },
    {
      "name": "telescopes"
    }
  ]
}
