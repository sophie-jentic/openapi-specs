                  "to",
                  "body"
                ],
                "properties": {
                  "to": {
                    "type": "string"
                  },
                  "from": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "callback": {
                    "type": "object",
                    "properties": {
                      "url": {
                        "type": "string"
                      },
                      "strategy": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SmsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
