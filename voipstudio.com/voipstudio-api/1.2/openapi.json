{
  "openapi": "3.0.3",
  "info": {
    "title": "VoIPstudio API",
    "description": "VoIPstudio REST API for managing VoIP communications, calls, customers, settings, and reports. The API provides access to authentication, call management, call-me-back, customer data, settings, storage, history, and reporting functionalities.",
    "version": "1.2",
    "contact": {
      "name": "VoIPstudio Support",
      "url": "https://voipstudio.com"
    }
  },
  "servers": [
    {
      "url": "https://l7api.com/v1.2/voipstudio",
      "description": "VoIPstudio API Server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "summary": "Login to obtain user token",
        "description": "Authenticate with email and password to receive a user_token that expires after 30 minutes of inactivity.",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user_token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          }
        },
        "security": [],
        "operationId": "post_login"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Auth-Token",
        "description": "API key obtained from dashboard or via login endpoint"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "parameters": {
      "PageParam": {
        "name": "page",
        "in": "query",
        "description": "Page number for pagination",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      },
      "LimitParam": {
        "name": "limit",
        "in": "query",
        "description": "Number of records per page (max 5000)",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5000,
          "default": 100
        }
      }
    }
  },
  "tags": [
    {
      "name": "Authentication"
    }
  ]
}
