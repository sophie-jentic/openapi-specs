{
  "openapi": "3.0.3",
  "info": {
    "title": "Linkly API",
    "version": "1.0.0",
    "description": "Linkly is a link shortening and analytics platform. The API allows programmatic creation, update, and management of links, as well as access to click data and traffic reports. Rate limit: 20 requests/second for link management, 50 requests/hour for analytics.",
    "x-jentic-source-url": "https://linklyhq.com/support/api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://app.linklyhq.com/api/v1",
      "description": "Linkly API v1"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "paths": {
    "/link": {
      "post": {
        "operationId": "createOrUpdateLink",
        "tags": [
          "Links"
        ],
        "summary": "Create or update a link",
        "description": "Create a new link or update an existing one. Include the 'id' field to update an existing link. Supports x-www-form-urlencoded or application/json encoding. Use JSON if submitting Rules.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LinkRequest"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/LinkRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Link created or updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Link"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/clicks": {
      "get": {
        "operationId": "getClickData",
        "tags": [
          "Analytics"
        ],
        "summary": "Get click data",
        "description": "Export raw click data with full parameters, timestamps and geolocation information. Rate limited to 50 requests/hour.",
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "link_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Filter by link ID"
          },
          {
            "name": "link_ids",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated link IDs"
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv",
                "tsv"
              ],
              "default": "json"
            }
          },
          {
            "name": "pivot",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Use 'link_id' to get pivot mode data"
          }
        ],
        "responses": {
          "200": {
            "description": "Click data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClickDataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/counters": {
      "get": {
        "operationId": "getCounters",
        "tags": [
          "Analytics"
        ],
        "summary": "Get traffic counters",
        "description": "Get aggregated click counts. Rate limited to 50 requests/hour.",
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "link_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "link_ids",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv",
                "tsv"
              ],
              "default": "json"
            }
          },
          {
            "name": "pivot",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Counter data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountersResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/export": {
      "get": {
        "operationId": "exportData",
        "tags": [
          "Analytics"
        ],
        "summary": "Export traffic data",
        "description": "Export traffic report data. Rate limited to 50 requests/hour.",
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "link_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv",
                "tsv"
              ],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Export data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClickDataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Your Linkly API key"
      }
    },
    "schemas": {
      "LinkRequest": {
        "type": "object",
        "required": [
          "api_key",
          "workspace_id",
          "url"
        ],
        "properties": {
          "api_key": {
            "type": "string",
            "description": "Account API Key"
          },
          "workspace_id": {
            "type": "integer",
            "description": "Workspace ID"
          },
          "id": {
            "type": "integer",
            "description": "Link ID (required if updating existing link)"
          },
          "url": {
            "type": "string",
            "description": "Destination URL"
          },
          "name": {
            "type": "string",
            "description": "Nickname"
          },
          "note": {
            "type": "string",
            "description": "Notes"
          },
          "head_tags": {
            "type": "string",
            "description": "Retargeting tags (head region)"
          },
          "body_tags": {
            "type": "string",
            "description": "Retargeting tags (body region)"
          },
          "forward_params": {
            "type": "boolean",
            "description": "Forward URL parameters"
          },
          "enabled": {
            "type": "boolean",
            "description": "Publishing status"
          },
          "utm_source": {
            "type": "string"
          },
          "utm_medium": {
            "type": "string"
          },
          "utm_campaign": {
            "type": "string"
          },
          "utm_term": {
            "type": "string"
          },
          "utm_content": {
            "type": "string"
          },
          "domain": {
            "type": "string",
            "description": "Custom domain (required if slug is provided)"
          },
          "slug": {
            "type": "string",
            "description": "Custom domain suffix"
          },
          "og_title": {
            "type": "string",
            "description": "Open Graph title"
          },
          "og_description": {
            "type": "string",
            "description": "Open Graph description"
          },
          "og_image": {
            "type": "string",
            "description": "Open Graph image URI"
          },
          "fb_pixel_id": {
            "type": "string",
            "description": "Meta Pixel ID"
          },
          "ga4_tag_id": {
            "type": "string",
            "description": "Google Analytics 4 ID"
          },
          "gtm_id": {
            "type": "string",
            "description": "Google Tag Manager container ID"
          },
          "expiry_datetime": {
            "type": "string",
            "format": "date-time",
            "description": "Expiry date/time (ISO8601)"
          },
          "expiry_destination": {
            "type": "string",
            "description": "Redirect URL after expiry"
          },
          "qr_styles": {
            "type": "object",
            "description": "QR code styles",
            "properties": {
              "fgColor": {
                "type": "string"
              },
              "bgColor": {
                "type": "string"
              },
              "qrStyle": {
                "type": "string"
              },
              "eyeStyle": {
                "type": "string"
              }
            }
          },
          "rules": {
            "type": "array",
            "description": "Rules for rotators, geo-redirects, and device redirects (requires JSON encoding)",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Link": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "short_url": {
            "type": "string"
          },
          "full_url": {
            "type": "string"
          },
          "workspace_id": {
            "type": "integer"
          },
          "enabled": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ClickDataResponse": {
        "type": "object",
        "properties": {
          "links": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LinkInfo"
            }
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ClickEntry"
            }
          }
        }
      },
      "ClickEntry": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "clicks": {
            "type": "object",
            "description": "Click counts keyed by link_id (in pivot mode)"
          },
          "link_id": {
            "type": "integer"
          },
          "country": {
            "type": "string"
          },
          "browser": {
            "type": "string"
          },
          "device": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CountersResponse": {
        "type": "object",
        "properties": {
          "links": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LinkInfo"
            }
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CounterEntry"
            }
          }
        }
      },
      "CounterEntry": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "clicks": {
            "type": "integer"
          }
        }
      },
      "LinkInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "full_url": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Analytics"
    },
    {
      "name": "Links"
    }
  ]
}
