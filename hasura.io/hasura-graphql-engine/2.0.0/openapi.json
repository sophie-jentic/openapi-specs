{
  "openapi": "3.0.0",
  "info": {
    "title": "Hasura GraphQL Engine API",
    "description": "Hasura GraphQL Engine provides instant GraphQL APIs on your databases and APIs. This spec covers the main GraphQL and Metadata APIs.",
    "version": "2.0.0",
    "contact": {
      "name": "Hasura",
      "url": "https://hasura.io"
    }
  },
  "servers": [
    {
      "url": "https://{project-name}.hasura.app",
      "description": "Hasura Cloud project endpoint",
      "variables": {
        "project-name": {
          "default": "your-project",
          "description": "Your Hasura project name"
        }
      }
    }
  ],
  "security": [
    {
      "adminSecret": []
    }
  ],
  "paths": {
    "/v1/graphql": {
      "post": {
        "summary": "Execute GraphQL query or mutation",
        "description": "Main GraphQL endpoint for queries, mutations, and subscriptions",
        "operationId": "executeGraphQL",
        "tags": [
          "GraphQL"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/GraphQLRequest"
                  },
                  {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/GraphQLRequest"
                    },
                    "description": "Batch request"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/GraphQLResponse"
                    },
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/GraphQLResponse"
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v1/metadata": {
      "post": {
        "summary": "Execute metadata operation",
        "description": "Metadata API for managing Hasura configuration",
        "operationId": "executeMetadata",
        "tags": [
          "Metadata"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MetadataRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/query": {
      "post": {
        "summary": "Execute query (deprecated)",
        "description": "Legacy query endpoint (use /v1/metadata instead)",
        "operationId": "executeQuery",
        "tags": [
          "Query"
        ],
        "deprecated": true,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "args": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/v1/version": {
      "get": {
        "summary": "Get Hasura version",
        "description": "Returns the version of the Hasura GraphQL Engine",
        "operationId": "getVersion",
        "tags": [
          "Utility"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "version": {
                      "type": "string",
                      "description": "Hasura version"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/healthz": {
      "get": {
        "summary": "Health check",
        "description": "Returns health status of the Hasura instance",
        "operationId": "healthCheck",
        "tags": [
          "Utility"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Healthy",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "OK"
                }
              }
            }
          },
          "500": {
            "description": "Unhealthy"
          }
        }
      }
    },
    "/v2/query": {
      "post": {
        "summary": "Execute query with database operations",
        "description": "Query endpoint for database operations like run_sql",
        "operationId": "executeQueryV2",
        "tags": [
          "Query"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "run_sql",
                      "bulk"
                    ]
                  },
                  "args": {
                    "type": "object",
                    "properties": {
                      "source": {
                        "type": "string",
                        "description": "Database source name"
                      },
                      "sql": {
                        "type": "string",
                        "description": "SQL query to execute"
                      },
                      "cascade": {
                        "type": "boolean",
                        "description": "Cascade operations"
                      },
                      "read_only": {
                        "type": "boolean",
                        "description": "Read-only query"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result_type": {
                      "type": "string"
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "type": "array"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "adminSecret": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Hasura-Admin-Secret",
        "description": "Admin secret for authentication"
      }
    },
    "schemas": {
      "GraphQLRequest": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "GraphQL query or mutation"
          },
          "operationName": {
            "type": "string",
            "description": "Operation name (for named queries)"
          },
          "variables": {
            "type": "object",
            "description": "Query variables",
            "additionalProperties": true
          }
        }
      },
      "GraphQLResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "description": "Query result data",
            "additionalProperties": true
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                },
                "extensions": {
                  "type": "object"
                }
              }
            },
            "description": "GraphQL errors"
          }
        }
      },
      "MetadataRequest": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Metadata operation type",
            "enum": [
              "export_metadata",
              "replace_metadata",
              "reload_metadata",
              "clear_metadata",
              "get_inconsistent_metadata",
              "drop_inconsistent_metadata",
              "track_table",
              "untrack_table",
              "set_table_customization",
              "create_object_relationship",
              "create_array_relationship",
              "drop_relationship",
              "create_insert_permission",
              "create_select_permission",
              "create_update_permission",
              "create_delete_permission",
              "drop_insert_permission",
              "drop_select_permission",
              "drop_update_permission",
              "drop_delete_permission",
              "create_action",
              "drop_action",
              "create_event_trigger",
              "delete_event_trigger",
              "add_remote_schema",
              "remove_remote_schema",
              "create_cron_trigger",
              "delete_cron_trigger"
            ]
          },
          "args": {
            "type": "object",
            "description": "Arguments for the operation",
            "additionalProperties": true
          },
          "version": {
            "type": "integer",
            "description": "Metadata version",
            "default": 3
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "path": {
            "type": "string",
            "description": "Error path"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "GraphQL"
    },
    {
      "name": "Metadata"
    },
    {
      "name": "Query"
    },
    {
      "name": "Utility"
    }
  ]
}
