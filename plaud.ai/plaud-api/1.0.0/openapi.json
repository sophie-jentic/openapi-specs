{
  "openapi": "3.0.3",
  "info": {
    "title": "Plaud Partner API",
    "description": "Plaud Partner API for authentication, user token management, and AI transcription services. Plaud is an AI voice recorder platform supporting offline and online conversational intelligence.",
    "version": "1.0.0",
    "contact": {
      "name": "Plaud",
      "url": "https://docs.plaud.ai"
    }
  },
  "servers": [
    {
      "url": "https://platform.plaud.ai/developer/api",
      "description": "US region"
    },
    {
      "url": "https://platform-jp.plaud.ai/developer/api",
      "description": "JP region"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/oauth/partner/access-token": {
      "post": {
        "operationId": "getPartnerAccessToken",
        "summary": "Get Partner Access Token",
        "description": "Obtain an access token and refresh token using HTTP Basic authentication with client_id and secret_key. Rate limited to 10 requests per minute per client_id.",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PartnerAccessTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - SECRET_KEY_INVALID or CLIENT_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/oauth/partner/access-token/refresh": {
      "post": {
        "operationId": "refreshPartnerAccessToken",
        "summary": "Refresh Partner Access Token",
        "description": "Refresh an expired partner access token using the refresh token.",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "refresh_token"
                ],
                "properties": {
                  "refresh_token": {
                    "type": "string",
                    "description": "The refresh token obtained from the initial access token request."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token refreshed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PartnerAccessTokenResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - REFRESH_TOKEN_INVALID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/open/partner/users/access-token": {
      "post": {
        "operationId": "getPartnerUserToken",
        "summary": "Get Partner User Access Token",
        "description": "Obtain a user-scoped access token for SDK use. Rate limited to 10 requests per minute per client_id + user_id combination.",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user_id"
                ],
                "properties": {
                  "user_id": {
                    "type": "string",
                    "maxLength": 120,
                    "description": "The unique identifier of the user."
                  },
                  "expires_in": {
                    "type": "integer",
                    "minimum": 300,
                    "maximum": 86400,
                    "description": "Token expiration time in seconds. Range: 300-86400."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User access token generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserAccessTokenResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - ACCESS_TOKEN_INVALID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/open/partner/ai/transcriptions": {
      "post": {
        "operationId": "submitTranscriptionTask",
        "summary": "Submit Transcription Task",
        "description": "Submit an audio file URL for transcription processing. This is a Beta endpoint. Rate limited based on client configuration (default: 60 requests per minute).",
        "tags": [
          "Transcription"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranscriptionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transcription task submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptionSubmitResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - ACCESS_TOKEN_INVALID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/open/partner/ai/transcriptions/{transcription_id}": {
      "get": {
        "operationId": "getTranscriptionResult",
        "summary": "Get Transcription Result",
        "description": "Retrieve the status and result of a previously submitted transcription task.",
        "tags": [
          "Transcription"
        ],
        "parameters": [
          {
            "name": "transcription_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the transcription task.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transcription result retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptionResultResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - ACCESS_TOKEN_INVALID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Transcription task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication using client_id as username and secret_key as password."
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication using the partner access token."
      }
    },
    "schemas": {
      "PartnerAccessTokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The partner access token for authenticating subsequent requests."
          },
          "refresh_token": {
            "type": "string",
            "description": "The refresh token for obtaining a new access token."
          },
          "token_type": {
            "type": "string",
            "enum": [
              "bearer"
            ],
            "description": "The type of token issued."
          },
          "expires_in": {
            "type": "integer",
            "description": "Token expiration time in seconds.",
            "example": 86400
          }
        }
      },
      "UserAccessTokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The user-scoped access token for SDK use."
          }
        }
      },
      "TranscriptionRequest": {
        "type": "object",
        "required": [
          "file_url"
        ],
        "properties": {
          "file_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the audio file to transcribe."
          },
          "params": {
            "type": "object",
            "description": "Optional transcription parameters.",
            "properties": {
              "transcribe": {
                "type": "object",
                "properties": {
                  "language": {
                    "type": "string",
                    "default": "auto",
                    "description": "Language for transcription. Use 'auto' for automatic detection."
                  },
                  "detection_level": {
                    "type": "string",
                    "default": "segment",
                    "description": "Language detection granularity level."
                  }
                }
              },
              "vad": {
                "type": "object",
                "properties": {
                  "decode_silence": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether to decode silent segments."
                  }
                }
              },
              "diarization": {
                "type": "object",
                "properties": {
                  "enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether to enable speaker diarization."
                  },
                  "return_embedding": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether to return speaker voice embeddings."
                  }
                }
              }
            }
          }
        }
      },
      "TranscriptionSubmitResponse": {
        "type": "object",
        "properties": {
          "transcription_id": {
            "type": "string",
            "description": "The unique identifier for the submitted transcription task."
          },
          "status": {
            "type": "string",
            "enum": [
              "RECEIVED"
            ],
            "description": "The initial status of the transcription task."
          },
          "data": {
            "type": "object",
            "description": "Additional data about the submitted task."
          }
        }
      },
      "TranscriptionResultResponse": {
        "type": "object",
        "properties": {
          "transcription_id": {
            "type": "string",
            "description": "The unique identifier of the transcription task."
          },
          "status": {
            "$ref": "#/components/schemas/TranscriptionStatus"
          },
          "data": {
            "type": "object",
            "description": "Transcription result data, populated when status is SUCCESS.",
            "properties": {
              "results": {
                "type": "array",
                "description": "Array of transcription segments.",
                "items": {
                  "$ref": "#/components/schemas/TranscriptionSegment"
                }
              },
              "embeddings": {
                "type": "object",
                "description": "Speaker voice embeddings, present if diarization with return_embedding was enabled.",
                "additionalProperties": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                }
              }
            }
          }
        }
      },
      "TranscriptionSegment": {
        "type": "object",
        "properties": {
          "speaker_id": {
            "type": "string",
            "description": "Identifier of the speaker for this segment."
          },
          "start": {
            "type": "number",
            "format": "float",
            "description": "Start time of the segment in seconds."
          },
          "end": {
            "type": "number",
            "format": "float",
            "description": "End time of the segment in seconds."
          },
          "text": {
            "type": "string",
            "description": "Transcribed text of the segment."
          },
          "language": {
            "type": "string",
            "description": "Detected language of the segment."
          }
        }
      },
      "TranscriptionStatus": {
        "type": "string",
        "enum": [
          "RECEIVED",
          "PROGRESS",
          "SUCCESS",
          "FAILURE",
          "REVOKED"
        ],
        "description": "Status of a transcription task."
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error code.",
            "enum": [
              "CLIENT_NOT_FOUND",
              "SECRET_KEY_INVALID",
              "ACCESS_TOKEN_INVALID",
              "REFRESH_TOKEN_INVALID",
              "SIGNATURE_INVALID"
            ]
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Authentication",
      "description": "Partner authentication and token management endpoints."
    },
    {
      "name": "Transcription",
      "description": "AI transcription task submission and result retrieval endpoints (Beta)."
    }
  ]
}
