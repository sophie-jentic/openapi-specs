          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "OPERATIONAL",
              "UNDERMAINTENANCE",
              "DEGRADEDPERFORMANCE",
              "PARTIALOUTAGE",
              "MAJOROUTAGE"
            ]
          },
          "description": {
            "type": "string"
          },
          "showUptime": {
            "type": "boolean"
          },
          "order": {
            "type": "integer"
          },
          "group": {
            "type": "string"
          }
        }
      },
      "ComponentInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "order": {
            "type": "integer"
          },
          "showUptime": {
            "type": "boolean"
          },
          "grouped": {
            "type": "boolean"
          },
          "group": {
            "type": "string"
          }
        }
      },
      "Incident": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "INVESTIGATING",
              "IDENTIFIED",
              "MONITORING",
              "RESOLVED"
            ]
          },
          "started": {
            "type": "string",
            "format": "date-time"
          },
          "resolved": {
            "type": "string",
            "format": "date-time"
          },
          "updates": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "components": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "IncidentInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "components": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "started": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string"
          },
          "notify": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
