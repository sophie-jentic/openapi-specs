{
  "openapi": "3.1.0",
  "info": {
    "title": "Brevo Email API",
    "version": "1.0.0",
    "description": "Brevo Email API for sending transactional emails, managing templates, and retrieving email statistics and activity.",
    "x-jentic-source-url": "https://developers.brevo.com/openapi.json?api=83b25a83-2183-4694-8eeb-a845da5a6490",
    "contact": {
      "url": "https://developers.brevo.com",
      "email": "contact@brevo.com"
    }
  },
  "servers": [
    {
      "url": "https://api.brevo.com/v3",
      "description": "Brevo API v3"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Transactional Emails",
      "description": "Send and manage transactional emails"
    },
    {
      "name": "Email Statistics",
      "description": "Retrieve email statistics and reports"
    },
    {
      "name": "Email Templates",
      "description": "Manage email templates"
    },
    {
      "name": "Blocked Contacts",
      "description": "Manage blocked email contacts"
    }
  ],
  "paths": {
    "/smtp/email": {
      "post": {
        "operationId": "send-transac-email",
        "tags": [
          "Transactional Emails"
        ],
        "summary": "Send a transactional email",
        "description": "Send a transactional email. Supports templates, HTML content, attachments, and message versioning for batch personalization.",
        "parameters": [
          {
            "name": "api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "requestBody": {
          "description": "Request body parameters for sending a transactional email",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "to": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "email": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        }
                      }
                    },
                    "description": "Array of recipient objects. Required when messageVersions is not provided."
                  },
                  "templateId": {
                    "type": "integer",
                    "format": "int64",
                    "description": "Template identifier"
                  },
                  "subject": {
                    "type": "string",
                    "description": "Email subject line. Required when templateId is not provided."
                  },
                  "htmlContent": {
                    "type": "string",
                    "description": "HTML body content of the email. Required when templateId is not provided."
                  },
                  "textContent": {
                    "type": "string",
                    "description": "Plain text body content of the email."
                  },
                  "sender": {
                    "type": "object",
                    "properties": {
                      "email": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "id": {
                        "type": "integer"
                      }
                    }
                  },
                  "cc": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "email": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "bcc": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "email": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "replyTo": {
                    "type": "object",
                    "properties": {
                      "email": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      }
                    }
                  },
                  "params": {
                    "type": "object",
                    "additionalProperties": {},
                    "description": "Key-value pairs for template variable substitution."
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "headers": {
                    "type": "object",
                    "additionalProperties": {}
                  },
                  "scheduledAt": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "batchId": {
                    "type": "string",
                    "description": "UUIDv4 identifier for scheduled batch of transactional emails."
                  },
                  "attachment": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "url": {
                          "type": "string"
                        },
                        "content": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "messageVersions": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    },
                    "description": "Array of message version objects for batch personalization. Max 2000 total recipients."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Transactional email sent successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/smtp/emails": {
      "get": {
        "operationId": "get-transac-emails-list",
        "tags": [
          "Transactional Emails"
        ],
        "summary": "Get the list of transactional emails on the basis of allowed filters",
