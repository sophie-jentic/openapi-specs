{
  "openapi": "3.0.1",
  "info": {
    "title": "ArtLedger API",
    "version": "0.1.1",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/ValenceAPI/ArtLedger/0.1.1/swagger.json",
    "contact": {},
    "description": "ArtLedger API"
  },
  "servers": [
    {
      "description": "ArtLedger Dev",
      "url": "https://2antv2o7ma.execute-api.us-east-1.amazonaws.com"
    }
  ],
  "tags": [
    {
      "name": "artwork",
      "description": "Artwork"
    }
  ],
  "paths": {
    "/artwork/import": {
      "post": {
        "tags": [
          "artwork"
        ],
        "summary": "Import artwork CSV file",
        "operationId": "createWallet",
        "requestBody": {
          "description": "Import CSV",
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "attachment": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import success",
            "content": {
              "application/json": {
                "example": {
                  "message": "File imported"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIError"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIError"
                }
              }
            }
          }
        },
        "description": "Import artwork CSV file"
      }
    },
    "/artwork": {
      "get": {
        "tags": [
          "artwork"
        ],
        "summary": "List imported artworks",
        "operationId": "getArtworks",
        "responses": {
          "200": {
            "description": "Artwork list",
            "content": {
              "application/json": {
                "example": {
                  "artworks": [
                    {
                      "edition_count": 100,
                      "price_override": "price on request",
                      "depth": "",
                      "mounting": "this is a multiline field",
                      "create_date": "1983",
                      "frame_width": "",
                      "import_key": "",
                      "medium": "oil on canvas",
                      "active": true,
                      "artist_last_name": "Warhol",
                      "consignment_cost_type": "percent",
                      "width": 48,
                      "notes": "this is a multiline field",
                      "units": "in",
                      "purchased_price": "",
                      "framer_name": "",
                      "frame_cost": "",
                      "tags": "abstract, bluechip",
                      "consignment_cost": 50,
                      "quantity": "",
                      "frame_height": "",
                      "location": "Gallery",
                      "mkt_opt": "",
                      "created": "",
                      "ownership": "consigned",
                      "order": "",
                      "framed": false,
                      "height": 48,
                      "edition_number": "1",
                      "acquisition_date": "2022-08-11",
                      "artist_first_name": "Andy",
                      "private_notes": "this is a multiline field",
                      "price": 320000,
                      "inventory_number": "1234",
                      "sku": "ABC123",
                      "title": "My favorite work",
                      "type": "Artwork"
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIError"
                }
              }
            }
          }
        },
        "description": "List imported artworks"
      }
    }
  },
  "components": {
    "schemas": {
      "APIError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Name of the error"
          },
          "message": {
            "type": "string",
            "description": "Information about the error, along with suggestions on how to fix the problem"
          }
        },
        "description": "Error information"
      }
    }
  }
}
