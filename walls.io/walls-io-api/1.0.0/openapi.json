  "components": {
    "schemas": {
      "Post": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "network": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "visible": {
            "type": "boolean"
          },
          "pinned": {
            "type": "boolean"
          },
          "spam": {
            "type": "boolean"
          },
          "language": {
            "type": "string"
          }
        }
      },
      "PostListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Post"
            }
          }
        }
      },
      "CreatePostRequest": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "mediaId": {
            "type": "string"
          }
        }
      },
      "UpdatePostRequest": {
        "type": "object",
        "properties": {
          "visible": {
            "type": "boolean"
          },
          "pinned": {
            "type": "boolean"
          },
          "language": {
            "type": "string"
          },
          "spam": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "accessToken": {
        "type": "apiKey",
        "in": "query",
        "name": "access_token",
        "description": "API access token"
      }
    }
  },
  "security": [
    {
      "accessToken": []
    }
  ],
  "tags": [
