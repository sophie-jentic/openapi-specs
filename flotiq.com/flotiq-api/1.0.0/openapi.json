    "/api/v1/open-api-schema.json": {
      "get": {
        "operationId": "getOpenApiSchema",
        "summary": "Get OpenAPI schema",
        "tags": [
          "Schema"
        ],
        "parameters": [
          {
            "name": "version",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "2",
                "3",
                "3.1"
              ]
            }
          },
          {
            "name": "hydrate",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          },
          {
            "name": "user_only",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OpenAPI schema"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get OpenAPI schema"
      }
    }
