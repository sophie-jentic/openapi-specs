{
  "openapi": "3.0.3",
  "info": {
    "title": "Flotiq API",
    "version": "1.0.0",
    "description": "Headless CMS API for managing content types, media, tags, and content objects with full CRUD operations.",
    "x-jentic-source-url": "https://flotiq.com/docs/API/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.flotiq.com"
    }
  ],
  "paths": {
    "/api/auth-context": {
      "get": {
        "operationId": "validateApiKey",
        "summary": "Validate API key",
        "tags": [
          "Auth"
        ],
        "responses": {
          "200": {
            "description": "Valid API key"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Validate API key"
      }
    },
