{
  "openapi": "3.0.3",
  "info": {
    "title": "Finage API",
    "description": "Real-time and historical financial market data API for stocks, forex, cryptocurrencies, and more",
    "version": "1.0.0",
    "contact": {
      "name": "Finage Support",
      "url": "https://finage.co.uk"
    }
  },
  "servers": [
    {
      "url": "https://api.finage.co.uk",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/last/stock/{symbol}": {
      "get": {
        "summary": "Last Stock Price",
        "description": "Get the last traded price for a stock",
        "operationId": "getLastStockPrice",
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Stock ticker symbol"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LastPrice"
                }
              }
            }
          }
        }
      }
    },
    "/agg/stock/{symbol}/{period}": {
      "get": {
        "summary": "Stock Aggregates",
        "description": "Get aggregated stock data for various time periods",
        "operationId": "getStockAggregates",
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "period",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["1min", "5min", "15min", "30min", "1hour", "4hour", "1day"]
            }
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Aggregates"
                }
              }
            }
          }
        }
      }
    },
    "/last/forex/{pair}": {
      "get": {
        "summary": "Last Forex Price",
        "description": "Get the last forex exchange rate",
        "operationId": "getLastForexPrice",
        "parameters": [
          {
            "name": "pair",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Currency pair (e.g., EURUSD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LastPrice"
                }
              }
            }
          }
        }
      }
    },
    "/last/crypto/{symbol}": {
      "get": {
        "summary": "Last Crypto Price",
        "description": "Get the last cryptocurrency price",
        "operationId": "getLastCryptoPrice",
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Crypto symbol (e.g., BTCUSD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LastPrice"
                }
              }
            }
          }
        }
      }
    },
    "/history/stock/{symbol}": {
      "get": {
        "summary": "Stock Historical Data",
        "description": "Get historical stock price data",
        "operationId": "getStockHistory",
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HistoricalData"
                }
              }
            }
          }
        }
      }
    },
    "/marketstatus": {
      "get": {
        "summary": "Market Status",
        "description": "Get current market status",
        "operationId": "getMarketStatus",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "market": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "apikey",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "LastPrice": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "ask": {
            "type": "number",
            "format": "double"
          },
          "bid": {
            "type": "number",
            "format": "double"
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "Aggregates": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AggregateBar"
            }
          }
        }
      },
      "AggregateBar": {
        "type": "object",
        "properties": {
          "o": {
            "type": "number",
            "format": "double",
            "description": "Open price"
          },
          "h": {
            "type": "number",
            "format": "double",
            "description": "High price"
          },
          "l": {
            "type": "number",
            "format": "double",
            "description": "Low price"
          },
          "c": {
            "type": "number",
            "format": "double",
            "description": "Close price"
          },
          "v": {
            "type": "number",
            "format": "double",
            "description": "Volume"
          },
          "t": {
            "type": "integer",
            "format": "int64",
            "description": "Timestamp"
          }
        }
      },
      "HistoricalData": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "historical": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string",
                  "format": "date"
                },
                "open": {
                  "type": "number",
                  "format": "double"
                },
                "high": {
                  "type": "number",
                  "format": "double"
                },
                "low": {
                  "type": "number",
                  "format": "double"
                },
                "close": {
                  "type": "number",
                  "format": "double"
                },
                "volume": {
                  "type": "number",
                  "format": "double"
                }
              }
            }
          }
        }
      }
    }
  }
}
