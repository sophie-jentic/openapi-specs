{
  "openapi": "3.0.3",
  "info": {
    "title": "Postmates Delivery API",
    "description": "The Postmates API enables programmatic access to Postmates' on-demand delivery platform. It allows you to get delivery quotes, create deliveries, track delivery status, and manage deliveries (cancel or return). Note: Postmates was acquired by Uber in 2020 and the API has been deprecated in favor of Uber Direct (https://developer.uber.com/docs/deliveries). This spec documents the original Postmates API (v1) as it existed before deprecation.",
    "version": "1.0.0",
    "contact": {
      "name": "Postmates Developer Support",
      "url": "https://developer.uber.com/docs/deliveries"
    },
    "x-deprecated": true,
    "x-deprecation-notice": "Postmates was acquired by Uber in December 2020. The Postmates API has been deprecated and replaced by the Uber Direct API. See https://developer.uber.com/docs/deliveries for the successor API."
  },
  "servers": [
    {
      "url": "https://api.postmates.com/v1",
      "description": "Postmates API v1 (deprecated)"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/customers/{customer_id}/delivery_quotes": {
      "post": {
        "operationId": "createDeliveryQuote",
        "summary": "Create a delivery quote",
        "description": "Retrieve a delivery quote for a given pickup and dropoff location. The quote provides estimated fee, duration, and dropoff ETA. Quotes expire after a short period.",
        "tags": [
          "Quotes"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/customerId"
          },
          {
            "name": "customer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "pickup_address",
                  "dropoff_address"
                ],
                "properties": {
                  "pickup_address": {
                    "type": "string",
                    "description": "The pickup street address.",
                    "example": "20 McAllister St, San Francisco, CA"
                  },
                  "pickup_latitude": {
                    "type": "number",
                    "format": "double",
                    "description": "The latitude of the pickup location."
                  },
                  "pickup_longitude": {
                    "type": "number",
                    "format": "double",
                    "description": "The longitude of the pickup location."
                  },
                  "dropoff_address": {
                    "type": "string",
                    "description": "The dropoff street address.",
                    "example": "101 Market St, San Francisco, CA"
                  },
                  "dropoff_latitude": {
                    "type": "number",
                    "format": "double",
                    "description": "The latitude of the dropoff location."
                  },
                  "dropoff_longitude": {
                    "type": "number",
                    "format": "double",
                    "description": "The longitude of the dropoff location."
                  },
                  "pickup_phone_number": {
                    "type": "string",
                    "description": "The phone number at the pickup location."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A delivery quote.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeliveryQuote"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/customers/{customer_id}/deliveries": {
      "post": {
        "operationId": "createDelivery",
        "summary": "Create a delivery",
        "description": "Create a new delivery between a pickup and dropoff location. A previously generated quote_id can be provided to lock in pricing.",
        "tags": [
          "Deliveries"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/customerId"
          },
          {
            "name": "customer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "manifest",
                  "pickup_name",
                  "pickup_address",
                  "pickup_phone_number",
                  "dropoff_name",
                  "dropoff_address",
                  "dropoff_phone_number"
                ],
                "properties": {
                  "quote_id": {
                    "type": "string",
                    "description": "The ID of a previously generated delivery quote. Optional but recommended to lock in pricing."
                  },
                  "manifest": {
                    "type": "string",
                    "description": "A description of what the courier will be delivering.",
                    "example": "A box of cookies"
                  },
                  "manifest_reference": {
                    "type": "string",
                    "description": "Optional reference that identifies the manifest. Can be used for order number or receipt number."
                  },
                  "pickup_name": {
                    "type": "string",
                    "description": "Name of the pickup location or business.",
                    "example": "Cookie Store"
                  },
                  "pickup_address": {
                    "type": "string",
                    "description": "The street address of the pickup location.",
                    "example": "20 McAllister St, San Francisco, CA"
                  },
                  "pickup_phone_number": {
                    "type": "string",
                    "description": "The phone number of the pickup location.",
                    "example": "+1-555-555-5555"
                  },
                  "pickup_business_name": {
                    "type": "string",
                    "description": "Optional business name at the pickup location."
                  },
                  "pickup_notes": {
                    "type": "string",
                    "description": "Additional instructions for the courier at the pickup location."
                  },
                  "dropoff_name": {
                    "type": "string",
                    "description": "Name of the person receiving the delivery.",
                    "example": "John Doe"
                  },
                  "dropoff_address": {
                    "type": "string",
                    "description": "The street address of the dropoff location.",
                    "example": "101 Market St, San Francisco, CA"
                  },
                  "dropoff_phone_number": {
                    "type": "string",
                    "description": "The phone number of the person receiving the delivery.",
                    "example": "+1-555-555-1234"
                  },
                  "dropoff_business_name": {
                    "type": "string",
                    "description": "Optional business name at the dropoff location."
                  },
                  "dropoff_notes": {
                    "type": "string",
                    "description": "Additional instructions for the courier at the dropoff location."
                  },
                  "requires_dropoff_signature": {
                    "type": "boolean",
                    "description": "Whether the delivery requires a signature upon dropoff."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The created delivery.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listDeliveries",
        "summary": "List deliveries",
        "description": "List all deliveries for a customer. Results can be filtered by status and paginated.",
        "tags": [
          "Deliveries"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/customerId"
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Filter deliveries by status (e.g., 'ongoing').",
            "schema": {
              "type": "string",
              "enum": [
                "ongoing"
              ]
            }
          },
          {
            "name": "customer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of deliveries.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total_count": {
                      "type": "integer",
                      "description": "Total number of deliveries matching the filter."
                    },
                    "next_href": {
                      "type": "string",
                      "format": "uri",
                      "description": "URL for the next page of results."
                    },
                    "previous_href": {
                      "type": "string",
                      "format": "uri",
                      "description": "URL for the previous page of results."
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Delivery"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/customers/{customer_id}/deliveries/{delivery_id}": {
      "get": {
        "operationId": "getDelivery",
        "summary": "Get a delivery",
        "description": "Retrieve the details of a specific delivery by its ID.",
        "tags": [
          "Deliveries"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/customerId"
          },
          {
            "$ref": "#/components/parameters/deliveryId"
          },
          {
            "name": "customer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "delivery_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The delivery details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Delivery not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/customers/{customer_id}/deliveries/{delivery_id}/cancel": {
      "post": {
        "operationId": "cancelDelivery",
        "summary": "Cancel a delivery",
        "description": "Cancel a delivery that has not yet been picked up. A delivery can only be canceled before the courier picks up the items.",
        "tags": [
          "Deliveries"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/customerId"
          },
          {
            "$ref": "#/components/parameters/deliveryId"
          },
          {
            "name": "customer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "delivery_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The canceled delivery.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Delivery cannot be canceled (already picked up or delivered).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Delivery not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/customers/{customer_id}/deliveries/{delivery_id}/return": {
      "post": {
        "operationId": "returnDelivery",
        "summary": "Return a delivery",
        "description": "Initiate a return of a delivery. This can be used after the courier has picked up the items to return them to the pickup location.",
        "tags": [
          "Deliveries"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/customerId"
          },
          {
            "$ref": "#/components/parameters/deliveryId"
          },
          {
            "name": "customer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "delivery_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The delivery with return status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Delivery cannot be returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Delivery not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication using your Postmates API key as the username and an empty password."
      }
    },
    "parameters": {
      "customerId": {
        "name": "customer_id",
        "in": "path",
        "required": true,
        "description": "The unique identifier for the customer account.",
        "schema": {
          "type": "string"
        }
      },
      "deliveryId": {
        "name": "delivery_id",
        "in": "path",
        "required": true,
        "description": "The unique identifier for the delivery.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "DeliveryQuote": {
        "type": "object",
        "description": "A delivery quote with estimated fee and timing.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the quote."
          },
          "kind": {
            "type": "string",
            "description": "The type of object.",
            "example": "delivery_quote"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the quote was created."
          },
          "expires": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the quote expires."
          },
          "fee": {
            "type": "integer",
            "description": "The estimated delivery fee in cents."
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the fee.",
            "example": "usd"
          },
          "dropoff_eta": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated time of arrival at the dropoff location."
          },
          "duration": {
            "type": "integer",
            "description": "Estimated delivery duration in minutes."
          }
        }
      },
      "Delivery": {
        "type": "object",
        "description": "A delivery object representing an on-demand delivery.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the delivery."
          },
          "kind": {
            "type": "string",
            "description": "The type of object.",
            "example": "delivery"
          },
          "status": {
            "type": "string",
            "description": "The current status of the delivery.",
            "enum": [
              "pending",
              "pickup",
              "pickup_complete",
              "dropoff",
              "delivered",
              "canceled",
              "returned"
            ]
          },
          "complete": {
            "type": "boolean",
            "description": "Whether the delivery has been completed."
          },
          "quote_id": {
            "type": "string",
            "description": "The ID of the quote used for this delivery, if any."
          },
          "fee": {
            "type": "integer",
            "description": "The delivery fee in cents."
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the fee.",
            "example": "usd"
          },
          "manifest": {
            "$ref": "#/components/schemas/Manifest"
          },
          "pickup": {
            "$ref": "#/components/schemas/Location"
          },
          "dropoff": {
            "$ref": "#/components/schemas/Location"
          },
          "courier": {
            "$ref": "#/components/schemas/Courier"
          },
          "image_href": {
            "type": "string",
            "format": "uri",
            "description": "URL of an image related to the delivery."
          },
          "customer_signature_img_href": {
            "type": "string",
            "format": "uri",
            "description": "URL of the customer's signature image, if signature was required."
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the delivery was created."
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the delivery was last updated."
          },
          "pickup_eta": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated time of arrival at the pickup location."
          },
          "dropoff_eta": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated time of arrival at the dropoff location."
          },
          "dropoff_deadline": {
            "type": "string",
            "format": "date-time",
            "description": "Deadline for the delivery to be completed."
          }
        }
      },
      "Manifest": {
        "type": "object",
        "description": "Describes what is being delivered.",
        "properties": {
          "description": {
            "type": "string",
            "description": "A text description of the delivery contents."
          },
          "reference": {
            "type": "string",
            "description": "An optional reference identifier (e.g., order number)."
          }
        }
      },
      "Location": {
        "type": "object",
        "description": "A pickup or dropoff location.",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the location or contact person."
          },
          "phone_number": {
            "type": "string",
            "description": "Phone number for the location."
          },
          "address": {
            "type": "string",
            "description": "The street address."
          },
          "detailed_address": {
            "type": "object",
            "description": "Parsed address components.",
            "properties": {
              "street_address_1": {
                "type": "string"
              },
              "street_address_2": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "state": {
                "type": "string"
              },
              "zip_code": {
                "type": "string"
              },
              "country": {
                "type": "string"
              }
            }
          },
          "notes": {
            "type": "string",
            "description": "Additional notes for the courier."
          },
          "location": {
            "type": "object",
            "description": "Geographic coordinates.",
            "properties": {
              "lat": {
                "type": "number",
                "format": "double",
                "description": "Latitude."
              },
              "lng": {
                "type": "number",
                "format": "double",
                "description": "Longitude."
              }
            }
          }
        }
      },
      "Courier": {
        "type": "object",
        "description": "Information about the assigned courier.",
        "properties": {
          "name": {
            "type": "string",
            "description": "The courier's name."
          },
          "phone_number": {
            "type": "string",
            "description": "The courier's phone number."
          },
          "img_href": {
            "type": "string",
            "format": "uri",
            "description": "URL of the courier's profile image."
          },
          "location": {
            "type": "object",
            "description": "The courier's current location.",
            "properties": {
              "lat": {
                "type": "number",
                "format": "double",
                "description": "Latitude."
              },
              "lng": {
                "type": "number",
                "format": "double",
                "description": "Longitude."
              }
            }
          },
          "vehicle": {
            "type": "object",
            "description": "The courier's vehicle information.",
            "properties": {
              "make": {
                "type": "string"
              },
              "model": {
                "type": "string"
              },
              "license_plate": {
                "type": "string"
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "description": "An error response.",
        "properties": {
          "kind": {
            "type": "string",
            "description": "The type of error.",
            "example": "error"
          },
          "code": {
            "type": "string",
            "description": "A machine-readable error code."
          },
          "message": {
            "type": "string",
            "description": "A human-readable error message."
          },
          "params": {
            "type": "object",
            "description": "Additional error parameters.",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Quotes",
      "description": "Get delivery cost estimates before creating a delivery."
    },
    {
      "name": "Deliveries",
      "description": "Create, track, cancel, and return deliveries."
    }
  ]
}
