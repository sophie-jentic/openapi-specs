{
  "openapi": "3.0.0",
  "info": {
    "title": "CurrencyScoop API (now CurrencyBeacon)",
    "version": "1.0.0",
    "description": "Real-time and historical foreign exchange rates API covering 168+ world currencies and 2,000+ cryptocurrencies. Updated every 60 seconds with 99.99% uptime SLA.",
    "contact": {
      "name": "CurrencyBeacon Support",
      "url": "https://currencybeacon.com"
    }
  },
  "servers": [
    {
      "url": "https://api.currencybeacon.com/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    },
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/latest": {
      "get": {
        "summary": "Get Latest Exchange Rates",
        "description": "Real-time exchange rates updated every 60 seconds",
        "operationId": "getLatestRates",
        "parameters": [
          {
            "name": "base",
            "in": "query",
            "description": "Base currency code (3-letter ISO code)",
            "required": false,
            "schema": {
              "type": "string",
              "default": "USD",
              "example": "USD"
            }
          },
          {
            "name": "symbols",
            "in": "query",
            "description": "Comma-separated list of currency codes to filter results",
            "required": false,
            "schema": {
              "type": "string",
              "example": "EUR,GBP,JPY"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer"
                        },
                        "disclaimer": {
                          "type": "string"
                        }
                      }
                    },
                    "response": {
                      "type": "object",
                      "properties": {
                        "date": {
                          "type": "string",
                          "format": "date"
                        },
                        "base": {
                          "type": "string"
                        },
                        "rates": {
                          "type": "object",
                          "additionalProperties": {
                            "type": "number"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "429": {
            "description": "Rate limit exceeded"
          },
          "500": {
            "description": "Server error"
          }
        },
        "tags": [
          "latest"
        ]
      }
    },
    "/historical": {
      "get": {
        "summary": "Get Historical Exchange Rates",
        "description": "Historical exchange rates from January 1, 1996 onwards",
        "operationId": "getHistoricalRates",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "description": "Date in YYYY-MM-DD format",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2023-01-15"
            }
          },
          {
            "name": "base",
            "in": "query",
            "description": "Base currency code",
            "required": false,
            "schema": {
              "type": "string",
              "default": "USD"
            }
          },
          {
            "name": "symbols",
            "in": "query",
            "description": "Comma-separated currency codes to filter",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "type": "object"
                    },
                    "response": {
                      "type": "object",
                      "properties": {
                        "date": {
                          "type": "string",
                          "format": "date"
                        },
                        "base": {
                          "type": "string"
                        },
                        "rates": {
                          "type": "object",
                          "additionalProperties": {
                            "type": "number"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "404": {
            "description": "Endpoint not found"
          },
          "500": {
            "description": "Server error"
          }
        },
        "tags": [
          "historical"
        ]
      }
    },
    "/convert": {
      "get": {
        "summary": "Convert Currency",
        "description": "Currency conversion with server-side calculation",
        "operationId": "convertCurrency",
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "Source currency code",
            "required": true,
            "schema": {
              "type": "string",
              "example": "USD"
            }
          },
          {
            "name": "to",
            "in": "query",
            "description": "Target currency code",
            "required": true,
            "schema": {
              "type": "string",
              "example": "EUR"
            }
          },
          {
            "name": "amount",
            "in": "query",
            "description": "Amount to convert",
            "required": true,
            "schema": {
              "type": "number",
              "example": 100
            }
          },
          {
            "name": "date",
            "in": "query",
            "description": "Optional date for historical conversion (YYYY-MM-DD)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful conversion",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "type": "object"
                    },
                    "response": {
                      "type": "object",
                      "properties": {
                        "timestamp": {
                          "type": "integer"
                        },
                        "date": {
                          "type": "string",
                          "format": "date"
                        },
                        "from": {
                          "type": "string"
                        },
                        "to": {
                          "type": "string"
                        },
                        "amount": {
                          "type": "number"
                        },
                        "value": {
                          "type": "number"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "500": {
            "description": "Server error"
          }
        },
        "tags": [
          "convert"
        ]
      }
    },
    "/timeseries": {
      "get": {
        "summary": "Get Time Series Data",
        "description": "Daily historical rates between date ranges (Startup/Pro plans only)",
        "operationId": "getTimeSeries",
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "description": "Start date (YYYY-MM-DD)",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "description": "End date (YYYY-MM-DD)",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "base",
            "in": "query",
            "description": "Base currency code",
            "required": false,
            "schema": {
              "type": "string",
              "default": "USD"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "type": "object"
                    },
                    "response": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "rates": {
                            "type": "object",
                            "additionalProperties": {
                              "type": "number"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Plan restriction - endpoint not available on current plan"
          },
          "500": {
            "description": "Server error"
          }
        },
        "tags": [
          "timeseries"
        ]
      }
    },
    "/currencies": {
      "get": {
        "summary": "List All Currencies",
        "description": "List all supported currencies with codes, names, and symbols",
        "operationId": "getCurrencies",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "type": "object"
                    },
                    "response": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "symbol": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "500": {
            "description": "Server error"
          }
        },
        "tags": [
          "currencies"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key passed as query parameter"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key passed in Authorization header (recommended for production)"
      }
    }
  },
  "tags": [
    {
      "name": "convert"
    },
    {
      "name": "currencies"
    },
    {
      "name": "historical"
    },
    {
      "name": "latest"
    },
    {
      "name": "timeseries"
    }
  ]
}
