{
  "openapi": "3.0.3",
  "info": {
    "title": "TrailBase API",
    "version": "1.0.0",
    "description": "TrailBase is a fast, single-executable Firebase alternative. Provides type-safe REST and realtime APIs for database records, authentication, OAuth, and file management, built on Rust/SQLite.",
    "x-jentic-source-url": "https://trailbase.io/api/",
    "license": {
      "name": "OSL-3.0"
    },
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "variables": {
        "host": {
          "default": "localhost:4000"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication endpoints"
    },
    {
      "name": "OAuth",
      "description": "OAuth provider endpoints"
    },
    {
      "name": "Records",
      "description": "Record CRUD and query endpoints"
    }
  ],
  "paths": {
    "/api/auth/v1/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "operationId": "login",
        "summary": "Login with email and password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "auth_token": {
                      "type": "string"
                    },
                    "refresh_token": {
                      "type": "string"
                    },
                    "csrf_token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [],
        "description": "Login with email and password"
      }
    },
