{
  "openapi": "3.0.3",
  "info": {
    "title": "BC Data Catalogue API",
    "version": "3.0.0",
    "description": "The British Columbia Data Catalogue API provides access to open data from the Government of British Columbia. It is based on CKAN and provides standard endpoints for searching packages (datasets), retrieving organizations, groups, tags, and performing datastore queries.",
    "x-jentic-source-url": "https://catalogue.data.gov.bc.ca/api/3",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://catalogue.data.gov.bc.ca/api/3",
      "description": "BC Data Catalogue (CKAN API v3)"
    }
  ],
  "tags": [
    {
      "name": "CKAN",
      "description": "CKAN standard API actions"
    }
  ],
