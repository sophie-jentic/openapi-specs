        },
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Solr search query"
          },
          {
            "name": "fq",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter query"
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sort field and direction"
          },
          {
            "name": "rows",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of results"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset"
          },
          {
            "name": "facet.field",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Facet fields (JSON list)"
          }
