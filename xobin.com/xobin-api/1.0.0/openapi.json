{
  "openapi": "3.0.3",
  "info": {
    "title": "Xobin Interact API",
    "version": "1.0.0",
    "description": "Xobin assessment platform API for managing assessments, inviting candidates, and retrieving scores and reports.",
    "x-jentic-source-url": "https://app.xobin.com/docs/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://app.xobin.com"
    }
  ],
  "paths": {
    "/{api_key}/assessment/get/assessments": {
      "get": {
        "operationId": "listAssessments",
        "summary": "List all assessments",
        "tags": [
          "Assessments"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Assessment"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List all assessments"
      }
    },
    "/{api_key}/assessment/send/invite/{candidate_email}/{candidate_name}/getlink/{assessment_id}": {
      "get": {
        "operationId": "sendInvite",
        "summary": "Send assessment invite",
        "tags": [
          "Candidates"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "candidate_email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "candidate_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "assessment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InviteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Send assessment invite"
      }
    },
    "/{api_key}/assessment/get/report/{candidate_id}": {
      "get": {
        "operationId": "getCandidateScore",
        "summary": "Get candidate score",
        "tags": [
          "Reports"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "candidate_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScoreReport"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get candidate score"
      }
    },
    "/{api_key}/assessment/get/candidates/{assessment_id}": {
      "get": {
        "operationId": "listCandidates",
        "summary": "List invited candidates",
        "tags": [
          "Candidates"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "assessment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List invited candidates"
      }
    },
    "/{api_key}/assessment/get/live": {
      "get": {
        "operationId": "getLiveTestTakers",
        "summary": "Get live test-taker count",
        "tags": [
          "Assessments"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "live_test_takers": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get live test-taker count"
      }
    }
  },
  "components": {
    "schemas": {
      "Assessment": {
        "type": "object",
        "properties": {
          "assessment_id": {
            "type": "string"
          },
          "assessment_name": {
            "type": "string"
          }
        }
      },
      "InviteResponse": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "testlink": {
            "type": "string"
          }
        }
      },
      "ScoreReport": {
        "type": "object",
        "properties": {
          "candidate_name": {
            "type": "string"
          },
          "candidate_email": {
            "type": "string"
          },
          "overall_percentage": {
            "type": "number"
          },
          "cutoff": {
            "type": "number"
          },
          "completion_date": {
            "type": "string"
          },
          "sections": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyPath": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key passed as path parameter"
      }
    }
  },
  "security": [
    {
      "apiKeyPath": []
    }
  ],
  "tags": [
    {
      "name": "Assessments"
    },
    {
      "name": "Candidates"
    },
    {
      "name": "Reports"
    }
  ]
}
