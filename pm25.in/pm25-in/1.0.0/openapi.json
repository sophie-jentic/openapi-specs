          "area": {
            "type": "string",
            "description": "City/area name"
          },
          "position_name": {
            "type": "string",
            "description": "Monitoring station name"
          },
          "station_code": {
            "type": "string",
            "description": "Monitoring station code"
          },
          "primary_pollutant": {
            "type": "string",
            "description": "Primary pollutant"
          },
          "quality": {
            "type": "string",
            "description": "Air quality level description"
          },
          "time_point": {
            "type": "string",
            "format": "date-time",
            "description": "Measurement timestamp"
          }
        }
      },
