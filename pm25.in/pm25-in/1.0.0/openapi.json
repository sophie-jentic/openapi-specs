{
  "openapi": "3.0.3",
  "info": {
    "title": "PM25.in Air Quality API",
    "description": "PM25.in provides real-time air quality data for cities across China, including AQI, PM2.5, PM10, CO, NO2, O3, and SO2 readings from monitoring stations. Data is available per city (simplified or detailed), per monitoring station, as a national aggregate, or as a city ranking.",
    "version": "1.0.0",
    "contact": {
      "name": "PM25.in",
      "url": "http://www.pm25.in"
    },
    "x-jentic-source-url": "http://www.pm25.in/api_doc"
  },
  "servers": [
    {
      "url": "http://www.pm25.in/api",
      "description": "PM25.in API"
    }
  ],
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "City Data",
      "description": "Air quality data for all monitoring stations in a city"
    },
    {
      "name": "Pollutants",
      "description": "Individual pollutant readings by city"
    },
    {
      "name": "Station",
      "description": "Data for individual monitoring stations"
    },
    {
      "name": "National",
      "description": "All cities data and rankings"
    }
  ],
  "paths": {
    "/querys/only_aqi.json": {
      "get": {
        "tags": ["City Data"],
        "summary": "Get simplified city AQI data",
        "description": "Returns simplified AQI data for all monitoring stations in a specified city.",
        "operationId": "getCityAqi",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "API authentication token",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "city",
            "in": "query",
            "required": true,
            "description": "City name (Chinese characters, pinyin, or area code e.g. '上海', 'shanghai', '021')",
            "schema": {
              "type": "string"
            },
            "example": "shanghai"
          },
          {
            "name": "avg",
            "in": "query",
            "required": false,
            "description": "If true, return average across all monitoring stations",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "stations",
            "in": "query",
            "required": false,
            "description": "If 'yes', include individual station data; if 'no', return only the average",
            "schema": {
              "type": "string",
              "enum": ["yes", "no"],
              "default": "yes"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SimplifiedAqiRecord"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "City not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
