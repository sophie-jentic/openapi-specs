          },
          "o3_8h": {
            "type": "number",
            "description": "O3 8-hour average (ug/m3)"
          },
          "o3_8h_24h": {
            "type": "number",
            "description": "O3 8-hour sliding average (ug/m3)"
          },
          "so2": {
            "type": "number",
            "description": "SO2 concentration (ug/m3)"
          },
          "so2_24h": {
            "type": "number",
            "description": "SO2 24-hour average (ug/m3)"
          },
          "primary_pollutant": {
            "type": "string",
            "description": "Primary pollutant"
          },
          "quality": {
            "type": "string",
