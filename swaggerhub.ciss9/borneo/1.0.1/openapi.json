{
  "openapi": "3.0.0",
  "info": {
    "description": "Borneo API : interfacing by API between integrated peripherals & http\n",
    "version": "1.0.1",
    "title": "Borneo",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/CISS9/Borneo/1.0.1/swagger.json",
    "contact": {}
  },
  "tags": [
    {
      "name": "tpa",
      "description": "Routes regarding the payment automat"
    },
    {
      "name": "scanneur",
      "description": "Routes regarding scanner"
    },
    {
      "name": "imprimante",
      "description": "Routes regarding printer"
    },
    {
      "name": "paiement",
      "description": "Routes regarding payment itself"
    },
    {
      "name": "impression",
      "description": "Routes regarding printing"
    },
    {
      "name": "lecture",
      "description": "Routes regarding reading from peripherals"
    },
    {
      "name": "maintenance",
      "description": "Routes regarding maintenance"
    }
  ],
  "paths": {
    "/v1/tpa/solvency": {
      "post": {
        "tags": [
          "paiement",
          "tpa"
        ],
        "summary": "Solvency request",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": {
                    "description": "Transaction amount, in cents",
                    "type": "integer",
                    "example": 200
                  },
                  "currency": {
                    "description": "ISO 4217's currency code",
                    "type": "string",
                    "default": "978",
                    "example": "978"
                  },
                  "mock": {
                    "description": "(optional) Mocks (fakes the answer of) a call , contains the wanted return code (e.g. 200 for succes)",
                    "type": "integer",
                    "example": 200
                  }
                },
                "required": [
                  "amount"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authorized payment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SolvencyResponse"
                }
              }
            }
          },
          "401": {
            "description": "Refused payment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SolvencyResponse"
                }
              }
            }
          },
          "402": {
            "description": "Cancelled payment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SolvencyResponse"
                }
              }
            }
          },
          "403": {
            "description": "Invalid licence"
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error50X"
                }
              }
            }
          }
        },
        "description": "Solvency request",
        "operationId": "post-v1-tpa-solvency"
      },
      "delete": {
        "tags": [
          "paiement",
          "tpa"
        ],
        "summary": "Cancel solvency request",
        "responses": {
          "200": {
            "description": "Cancellation accepted"
          },
          "403": {
            "description": "Invalid licence"
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error50X"
                }
              }
            }
          }
        },
        "description": "Cancel solvency request",
        "operationId": "delete-v1-tpa-solvency"
      }
    },
    "/v1/tpa/payment": {
      "post": {
        "tags": [
          "paiement",
          "tpa"
        ],
        "summary": "Validation of payment request",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": {
                    "description": "Real transaction amount, in cents",
                    "type": "integer",
                    "example": 200
                  },
                  "currency": {
                    "description": "ISO 4217's currency code",
                    "type": "string",
                    "default": "978",
                    "example": "978"
                  },
                  "mock": {
                    "description": "(optional) Mocks (fakes the answer of) a call , contains the wanted return code (e.g. 200 for succes)",
                    "type": "integer",
                    "example": 200
                  }
                },
                "required": [
                  "amount"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment validated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "401": {
            "description": "Payment amount request greater than the solvency request"
          },
          "403": {
            "description": "Invalid licence"
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error50X"
                }
              }
            }
          }
        },
        "description": "Validation of payment request",
        "operationId": "post-v1-tpa-payment"
      }
    },
    "/v1/printer/print": {
      "post": {
        "tags": [
          "impression",
          "imprimante"
        ],
        "summary": "Printing request",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "base64": {
                    "description": "File content (Base64) to print",
                    "type": "string",
                    "format": "byte"
                  },
                  "type": {
                    "description": "Sent type\n * 0 => RAW\n * 1 => PDF\n",
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Printing request succeded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "near_end_paper": {
                      "type": "boolean",
                      "description": "End of paper indicator",
                      "default": false
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Invalid licence"
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error50X"
                }
              }
            }
          }
        },
        "description": "Printing request",
        "operationId": "post-v1-printer-print"
      }
    },
    "/v1/scanner/read": {
      "get": {
        "tags": [
          "lecture",
          "scanneur"
        ],
        "summary": "Scanner reading request",
        "responses": {
          "200": {
            "description": "Reading succeeded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "description": "Scanned string",
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Invalid licence"
          },
          "404": {
            "description": "No data emitted by scanner"
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error50X"
                }
              }
            }
          }
        },
        "description": "Scanner reading request",
        "operationId": "get-v1-scanner-read"
      },
      "delete": {
        "tags": [
          "lecture",
          "scanneur"
        ],
        "summary": "Cancellation of the scan request",
        "responses": {
          "200": {
            "description": "Cancellation succeded"
          },
          "403": {
            "description": "Invalid licence"
          }
        },
        "description": "Cancellation of the scan request",
        "operationId": "delete-v1-scanner-read"
      }
    },
    "/v1/tpa/status": {
      "get": {
        "tags": [
          "maintenance",
          "tpa"
        ],
        "summary": "State of the banking hardware",
        "responses": {
          "200": {
            "description": "Request succeeded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cr": {
                      "description": "Payment hardware status\n  * '0' => Hardware is available for requests\n  * '1' => Hardware already processing a request\n  * '2' => Hardware in maintenance mode\n",
                      "type": "string",
                      "enum": [
                        "0",
                        "1",
                        "2"
                      ]
                    },
                    "carte": {
                      "description": "Card insertion status\n  * '0' => No card in the reader\n  * '1' => Card in the reader\n",
                      "type": "string",
                      "enum": [
                        "0",
                        "1"
                      ]
                    },
                    "etat": {
                      "description": "State of communications\n  * '0' => No ongoing calls\n  * '1' => Bank collection on-going\n  * '2' => Parameters download on-going\n",
                      "type": "string",
                      "enum": [
                        "0",
                        "1",
                        "2"
                      ]
                    },
                    "periph": {
                      "description": "Other devices status\n  * '0' => Running OK\n  * '1' => PinPad KO\n  * '2' => Reader KO\n  * '3' => PinPad and Reader KO\n",
                      "type": "string",
                      "enum": [
                        "0",
                        "1",
                        "2",
                        "3"
                      ]
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Invalid licence"
          }
        },
        "description": "State of the banking hardware",
        "operationId": "get-v1-tpa-status"
      }
    },
    "/v1/printer/status": {
      "get": {
        "tags": [
          "maintenance",
          "imprimante"
        ],
        "summary": "Printer status request",
        "responses": {
          "200": {
            "description": "Printer status request succeeded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "offline": {
                      "type": "boolean",
                      "description": "Offline printer ?",
                      "default": false
                    },
                    "no_paper": {
                      "type": "boolean",
                      "description": "Lacking paper ?",
                      "default": false
                    },
                    "near_end_paper": {
                      "type": "boolean",
                      "description": "Next to lack paper ?",
                      "default": false
                    },
                    "ticket_out": {
                      "type": "boolean",
                      "description": "Ticket out ?",
                      "default": false
                    },
                    "no_cover": {
                      "type": "boolean",
                      "description": "Printer cover opened ?",
                      "default": false
                    },
                    "spooling": {
                      "type": "boolean",
                      "description": "Printer currently printing ?",
                      "default": false
                    },
                    "over_temp": {
                      "type": "boolean",
                      "description": "Overheating of the printer ?",
                      "default": false
                    },
                    "hl_volt": {
                      "type": "boolean",
                      "description": "Power supply problem ?",
                      "default": false
                    },
                    "paper_jam": {
                      "type": "boolean",
                      "description": "Paper jam ?",
                      "default": false
                    },
                    "cut_error": {
                      "type": "boolean",
                      "description": "Cutting issue ?",
                      "default": false
                    },
                    "ram_error": {
                      "type": "boolean",
                      "description": "Enough memory ?",
                      "default": false
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Invalid licence"
          }
        },
        "description": "Printer status request",
        "operationId": "get-v1-printer-status"
      }
    },
    "/v1/activate": {
      "post": {
        "tags": [
          "maintenance"
        ],
        "summary": "Borneo activation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "licence": {
                    "description": "Your activation licence",
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Borneo is activated (open the 443 ports to communicated IPs)"
          },
          "404": {
            "description": "Invalid licence"
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error50X"
                }
              }
            }
          }
        },
        "description": "Borneo activation",
        "operationId": "post-v1-activate"
      }
    }
  },
  "components": {
    "schemas": {
      "SolvencyResponse": {
        "type": "object",
        "properties": {
          "receipt": {
            "description": "Ticket sent back by bank automaton (can be void if no ticket sent by automaton)",
            "type": "string"
          }
        }
      },
      "PaymentResponse": {
        "type": "object",
        "properties": {
          "receipt": {
            "description": "Ticket sent back by bank automaton (can be void if no ticket sent by automaton)",
            "type": "string"
          }
        }
      },
      "Error50X": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "msg": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/CISS9/Borneo/1.0.1"
    }
  ]
}
