    "/interface": {
      "post": {
        "summary": "Register a new interface",
        "description": "Request access for a new interface connection, for which Abitari will\nprovide a username and password.\n",
        "tags": [
          "Configuration (External system to Abitari)"
        ],
        "parameters": [
          {
            "name": "integration",
            "in": "body",
            "description": "Integration request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/IntegrationRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {
              "$ref": "#/definitions/IntegrationResponse"
            }
          },
          "401": {
            "description": "Unauthorized -> Invalid APIKey",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        },
        "operationId": "post-interface"
      }
    },
    "/rest-auth/login": {
