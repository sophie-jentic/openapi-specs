  "definitions": {
    "ResortRequest": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier representing the resort."
        },
        "name": {
          "type": "string",
          "description": "Name of the resort."
        },
        "stars": {
          "type": "integer",
          "description": "Number of stars."
        },
        "change_of_sheets_days": {
          "type": "integer",
          "description": "Number of days after which sheets must be changed in a stay over room. Default is 2."
        },
        "inspection_enabled": {
          "type": "boolean",
          "description": "True if rooms are inspected before becoming ready, False if there is no supervision. Default is True."
        },
        "minibar_enabled": {
          "type": "boolean",
          "description": "True if minibar consumptions must be tracked with the app by room attendants."
        },
        "reception_email": {
          "type": "string",
          "description": "The email of the receptionist account."
        },
        "maintenance_email": {
          "type": "string",
          "description": "The email that maintenance issues will be sent to."
        }
      }
    },
    "ResortResponse": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier representing the resort."
        },
        "name": {
          "type": "string",
          "description": "Name of the resort."
        },
        "stars": {
          "type": "integer",
          "description": "Number of stars."
        },
        "change_of_sheets_days": {
          "type": "integer",
          "description": "Number of days after which sheets must be changed in a stay over room. Default is 2."
        },
        "inspection_enabled": {
          "type": "boolean",
          "description": "True if rooms are inspected before becoming ready, False if there is no supervision. Default is True."
        },
        "minibar_enabled": {
          "type": "boolean",
          "description": "True if minibar consumptions must be tracked with the app by room attendants."
        },
        "reception_email": {
          "type": "string",
          "description": "The email of the receptionist account."
        },
        "maintenance_email": {
          "type": "string",
          "description": "The email that maintenance issues will be sent to."
        }
      }
    },
    "IntegrationRequest": {
      "type": "object",
      "required": [
        "username",
        "api_key",
        "url_auth",
        "url_resync"
      ],
      "properties": {
        "username": {
          "type": "string",
          "description": "Username to be used to access to the external system."
        },
        "api_key": {
          "type": "string",
          "description": "Provided api key for the external system. Contact api@abitari.com to get one."
        },
        "url_auth": {
          "type": "string",
          "description": "Url to which Abitari will POST a login request with the provided username and the password entered by the user."
        },
        "url_resync": {
          "type": "string",
          "description": "Url to wich Abitari will POST a resync request so the external system knows it has to resend all the information (i.e. send the status of each room, etc). Triggered automatically the first time the user uses Abitari and by manual request he can perform in the app."
        }
      }
    },
    "IntegrationResponse": {
      "type": "object",
      "required": [
        "username",
        "password"
      ],
      "properties": {
        "username": {
          "type": "string",
          "description": "Username that the external system must use in order to perform a login in Abitari."
        },
        "password": {
          "type": "string",
          "description": "The password that the external system must user in order to perform a login in Abitari."
        }
      }
    },
    "LoginRequest": {
      "type": "object",
      "required": [
        "username",
        "password"
      ],
      "properties": {
        "username": {
          "type": "string",
          "description": "Username that the external system must use in order to perform a login in Abitari. Provided in POST /integration."
        },
        "password": {
          "type": "string",
          "description": "The password that the external system must user in order to perform a login in Abitari. Provided in POST /integration."
        }
      }
    },
    "LoginResponse": {
      "type": "object",
      "required": [
        "token"
      ],
      "properties": {
        "token": {
          "type": "string",
          "description": "Access token to be set in the header of Messaging requests (Authorization, Token k23j\u00f1dflakj21lk3j...)."
        }
      }
    },
    "GuestRequest": {
      "type": "object",
      "required": [
        "id",
        "first_name",
        "last_name",
        "family_name",
        "age_code"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier representing a specific guest."
        },
        "first_name": {
          "type": "string",
          "description": "Guest first name."
        },
        "last_name": {
          "type": "string",
          "description": "Guest last name."
        },
        "family_name": {
          "type": "string",
          "description": "Guest family name (usually same as last name)."
        },
        "age_code": {
          "$ref": "#/definitions/AgeCodeType"
        },
        "phone_number": {
          "type": "string",
          "description": "Guest phone number"
        },
        "vip": {
          "type": "boolean",
          "description": "Guest vip status"
        },
        "preferences": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GuestPreferenceType"
          }
        }
      }
    },
    "GuestResponse": {
      "type": "object",
      "required": [
        "id",
        "first_name",
        "last_name",
        "family_name",
        "age_code"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier representing a specific guest."
        },
        "first_name": {
          "type": "string",
          "description": "Guest first name."
        },
        "last_name": {
          "type": "string",
          "description": "Guest last name."
        },
        "family_name": {
          "type": "string",
          "description": "Guest family name (usually same as last name)."
        },
        "age_code": {
          "$ref": "#/definitions/AgeCodeType"
        },
        "vip": {
          "type": "boolean",
          "description": "Guest vip status"
        },
        "preferences": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GuestPreferenceType"
          }
        }
      }
    },
    "ReservationRequest": {
      "type": "object",
      "required": [
        "id",
        "guest_id",
        "room_id",
        "arrival_date",
        "departure_date",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier representing a specific reservation."
        },
        "guest_id": {
          "type": "string",
          "description": "Unique identifier representing the guest profile."
        },
        "room_id": {
          "type": "string",
          "description": "Unique identifier representing the reserved room."
        },
        "arrival_date": {
          "type": "string",
          "format": "dateTime",
          "description": "Arrival date of the guest. [https://xml2rfc.tools.ietf.org/public/rfc/html/rfc3339.html#anchor14]"
        },
        "departure_date": {
          "type": "string",
          "format": "dateTime",
          "description": "Departure date of the guest. [https://xml2rfc.tools.ietf.org/public/rfc/html/rfc3339.html#anchor14]"
        },
        "guest_comment": {
          "type": "string",
          "description": "Message that must be displayed to the cleaner (additional bed required, etc)"
        },
        "status": {
          "$ref": "#/definitions/ReservationStatusType"
        },
        "guest": {
          "$ref": "#/definitions/GuestRequest"
        },
        "room": {
          "$ref": "#/definitions/RoomRequest"
        },
        "transportation": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TransportationType"
          }
        },
        "accompany_guests": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GuestRequest"
          }
        },
        "guest_counts": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GuestCountType"
          }
        }
      }
    },
    "ReservationResponse": {
      "type": "object",
      "required": [
        "id",
        "guest_id",
        "room_id",
        "arrival_date",
        "departure_date",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier representing a specific reservation."
        },
        "guest_id": {
          "type": "string",
          "description": "Unique identifier representing the guest profile."
        },
        "room_id": {
          "type": "string",
          "description": "Unique identifier representing the reserved room."
        },
        "arrival_date": {
          "type": "string",
          "format": "dateTime",
          "description": "Arrival date of the guest. [https://xml2rfc.tools.ietf.org/public/rfc/html/rfc3339.html#anchor14]"
        },
        "departure_date": {
          "type": "string",
          "format": "dateTime",
          "description": "Departure date of the guest. [https://xml2rfc.tools.ietf.org/public/rfc/html/rfc3339.html#anchor14]"
        },
