            }
          }
        },
        "operationId": "post-rest-auth-login"
      }
    },
    "/webhook": {
      "post": {
        "summary": "Subscribe to a new webhook",
        "description": "Subscribe to a new webhook with details sent in body. When a webhook is created, it provides a way for your application to be notified when some event occurs. For example, if you are subscribed to room, then each time a room is update in Abitari, a POST request will be sent to your specified url with a RoomResponse body. Available event notifications are\n  - room (RoomResponse)\n  - roomrepair (RoomRepairResponse)\n",
        "parameters": [
          {
            "name": "webhook",
            "in": "body",
            "description": "Webhook request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/WebhookRequest"
            }
          }
        ],
        "tags": [
          "Configuration (External system to Abitari)"
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {
              "$ref": "#/definitions/WebhookResponse"
            }
          },
          "409": {
            "description": "Conflict",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "default": {
            "description": "Unexpected error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        },
        "operationId": "post-webhook"
      },
      "delete": {
        "summary": "Unsubscribe from an existing webhook",
        "description": "Unsubscribe from an existing webhook\n",
        "parameters": [
          {
            "name": "id",
            "in": "body",
            "description": "Existing webhook unique identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "tags": [
          "Configuration (External system to Abitari)"
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "default": {
            "description": "Unexpected error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        },
        "operationId": "delete-webhook"
      }
    },
