{
  "swagger": "2.0",
  "info": {
    "title": "Abitari Housekeeping Integration API for Guest Facing",
    "description": "Abitari Housekeeping Integration API for Guest Facing",
    "version": "0.1.0",
    "contact": {
      "email": "eloi@abitari.com"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/EloiHernandezTarrago/abitari-housekeeping_integration_api_for_guest_facing/0.1.0/swagger.json"
  },
  "host": "api.abitari.com",
  "schemes": [
    "https"
  ],
  "produces": [
    "application/json"
  ],
  "securityDefinitions": {
    "accessCode": {
      "type": "oauth2",
      "tokenUrl": "https://identity.abitari.com/o/authorize",
      "authorizationUrl": "https://identity.abitari.com/o/token",
      "flow": "accessCode",
      "scopes": {
        "write": "allows modifying resources",
        "read": "allows reading resources"
      }
    }
  },
  "security": [
    {
      "accessCode": [
        "read",
        "write"
      ]
    }
  ],
  "paths": {
    "/autoinstall/connect": {
      "post": {
        "tags": [
          "Setup"
        ],
        "summary": "Create a new connection to the API",
        "description": "Setting up a Connection allows you to establish a bridge (not working until started) between your external application and the hotelier's account that corresponds to your access token. If this account belongs to Abitari (only possibility right now), you should use AbitariService to connect to it. The creation of the Connection will return a list of the available properties to be integrated.\n",
        "parameters": [
          {
            "name": "connection",
            "in": "body",
            "description": "Connection request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ConnectionRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {
              "$ref": "#/definitions/ConnectionResponse"
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "409": {
            "description": "Conflict",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "default": {
            "description": "Unexpected error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        },
        "operationId": "post-autoinstall-connect"
      }
    },
    "/autoinstall/connect/start": {
      "post": {
        "tags": [
          "Setup"
        ],
        "summary": "Starts a pending connection",
        "description": "Starting a Connection activates the connection bridge between the system and your application, for the property_ids provided.\n",
        "parameters": [
          {
            "name": "start-connection-request",
            "in": "body",
            "description": "Start connection request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/StartConnectionRequest"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Started"
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "default": {
            "description": "Unexpected error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        },
        "operationId": "post-autoinstall-connect-start"
      }
    },
    "/webhooks": {
      "post": {
        "tags": [
          "Setup"
        ],
        "summary": "Subscribe to a new webhook",
        "description": "Subscribe to a new webhook with details sent in body. When a webhook is created, it provides a way for your application to be notified when some event occurs. For example, if you are subscribed to room, then each time a room is updated in Abitari, a POST request will be sent to your specified url with a RoomRepair body. Available event notifications are\n  - room (RoomResponse) \n  - guestpetition (GuestPetitionResponse)\nAn event of type healthcheck will be sent periodically to the endpoint, with empty payload, to check you are alive.\n",
        "parameters": [
          {
            "name": "webhook",
            "in": "body",
            "description": "Webhook request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/WebhookRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {
              "$ref": "#/definitions/WebhookResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "409": {
            "description": "Conflict",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "default": {
            "description": "Unexpected error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        },
        "operationId": "post-webhooks"
      }
    },
    "/webhooks/{topic}": {
      "put": {
        "tags": [
          "Setup"
        ],
        "summary": "Change webhook url",
        "description": "Change webhook url\n",
        "parameters": [
          {
            "name": "topic",
            "in": "path",
            "description": "topic to unsubscribe from",
            "required": true,
            "type": "string"
          },
          {
            "name": "webhook",
            "in": "body",
            "description": "Update webhook request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/UpdateWebhookRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/WebhookResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "default": {
            "description": "Unexpected error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        },
        "operationId": "put-webhooks-by-topic"
      },
      "delete": {
        "tags": [
          "Setup"
        ],
        "summary": "Unsubscribe from an existing webhook",
        "description": "Unsubscribe from an existing webhook\n",
        "parameters": [
          {
            "name": "topic",
            "in": "path",
            "description": "topic to unsubscribe from",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "default": {
            "description": "Unexpected error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        },
        "operationId": "delete-webhooks-by-topic"
      }
    },
    "/api/guestpetition": {
      "post": {
        "tags": [
          "Messaging"
        ],
        "summary": "Create a petition to the hotel made by a guest",
        "parameters": [
          {
            "name": "guestpetition",
            "in": "body",
            "required": true,
            "description": "Guest petition object",
            "schema": {
              "$ref": "#/definitions/GuestPetitionRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {
              "$ref": "#/definitions/GuestPetitionResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "409": {
            "description": "Conflict",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "default": {
            "description": "Unexpected error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        },
        "description": "Create a petition to the hotel made by a guest",
        "operationId": "post-api-guestpetition"
      }
    }
  },
  "definitions": {
    "ConnectionRequest": {
      "type": "object",
      "required": [
        "code",
        "service"
      ],
      "properties": {
        "code": {
          "type": "string",
          "description": "Unique identifier representing a connection"
        },
        "service": {
          "$ref": "#/definitions/ConnectionServiceType"
        }
      }
    },
    "ConnectionResponse": {
      "type": "object",
      "required": [
        "code",
        "service"
      ],
      "properties": {
        "code": {
          "type": "string",
          "description": "Unique identifier representing a connection"
        },
        "service": {
          "$ref": "#/definitions/ConnectionServiceType"
        },
        "status": {
          "$ref": "#/definitions/ConnectionStatusType"
        }
      }
    },
    "StartConnectionRequest": {
      "type": "object",
      "required": [
        "code",
        "property_ids"
      ],
      "properties": {
        "code": {
          "type": "string",
          "description": "Unique identifier representing a connection"
        },
        "property_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "property_callback_url": {
          "type": "string",
          "description": "Url to send the notification of a new IntegratedPropertyNotificationType"
        }
      }
    },
    "GuestPetitionRequest": {
      "type": "object",
      "required": [
        "id",
        "type",
        "room_id",
        "place_id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier representing a specific guest petition."
        },
        "room_id": {
          "type": "string",
          "description": "Unique identifier representing the specific room where the request takes place."
        },
        "place_id": {
          "type": "string",
          "description": "The id of your IntegratedProperty where the guest petition originates."
        },
        "guest_id": {
          "type": "string",
          "description": "Unique identifier representing the guest making the petition."
        },
        "message": {
          "type": "string",
          "description": "Some observations regarding the petition."
        },
        "starts_at": {
          "type": "string",
          "description": "Datetime in which petition starts applying (required for non disturb)."
        },
        "expires_at": {
          "type": "string",
          "description": "Datetime in which petition is no longer applied (although optional, mainly used in non disturb)."
        },
        "status": {
          "$ref": "#/definitions/GuestPetitionStatus"
        },
        "type": {
          "$ref": "#/definitions/GuestPetitionType"
        }
      }
    },
    "GuestPetitionResponse": {
      "type": "object",
      "required": [
        "id",
        "pms_id",
        "room_id",
        "type",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier representing a specific guest petition."
        },
        "pms_id": {
          "type": "string",
          "description": "Unique identifier representing the pms the property works with."
        },
        "room_id": {
          "type": "string",
          "description": "Unique identifier representing the specific room where the request takes place."
        },
        "guest_id": {
          "type": "string",
          "description": "Unique identifier representing the guest making the petition."
        },
        "message": {
          "type": "string",
          "description": "Some observations regarding the petition."
        },
        "starts_at": {
          "type": "string",
          "description": "Datetime in which petition starts applying (required for non disturb)."
        },
        "expires_at": {
          "type": "string",
          "description": "Datetime in which petition is no longer applied (although optional, mainly used in non disturb)."
        },
        "status": {
          "$ref": "#/definitions/GuestPetitionStatus"
        },
        "type": {
          "$ref": "#/definitions/GuestPetitionType"
        }
      }
    },
    "UpdateWebhookRequest": {
      "type": "object",
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string",
          "description": "Consumer endpoint that processes the notification."
        }
      }
    },
    "WebhookRequest": {
      "type": "object",
      "required": [
        "topic",
        "url"
      ],
      "properties": {
        "topic": {
          "$ref": "#/definitions/WebhookEventType"
        },
        "url": {
          "type": "string",
          "description": "Consumer endpoint that processes the notification."
        }
      }
    },
    "WebhookEventType": {
      "type": "string",
      "description": "Topic that triggers the notification",
      "enum": [
        "healthcheck",
        "guestpetition",
        "room"
      ]
    },
    "WebhookResponse": {
      "type": "object",
      "required": [
        "id",
        "topic",
        "url"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "topic": {
          "type": "string",
          "description": "Event that triggers the notification (typicaly resource name, for example room."
        },
        "url": {
          "type": "string",
          "description": "Consumer endpoint that processes the notification."
        }
      }
    },
    "GuestPetitionStatus": {
      "type": "string",
      "description": "Petition done status",
      "enum": [
        "pending",
        "done"
      ]
    },
    "GuestPetitionType": {
      "type": "string",
      "description": "Type of Petition",
      "enum": [
        "incidence-type",
        "make-cleaning-type",
        "notifiable-event-type",
        "non-disturb-type",
        "extra-cleaning-type"
      ]
    },
    "ConnectionServiceType": {
      "type": "string",
      "description": "Service to be used when connecting to the system",
      "enum": [
        "AbitariService"
      ]
    },
    "ConnectionStatusType": {
      "type": "string",
      "description": "Status of the connection",
      "enum": [
        "setup_pending",
        "setup_auth_ok",
        "setup_auth_failed",
        "setup_started",
        "setup_finished",
        "online",
        "offline"
      ]
    },
    "Error": {
      "type": "object",
      "required": [
        "code"
      ],
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "fields": {
          "type": "string"
        }
      }
    }
  },
  "tags": [
    {
      "name": "Messaging"
    },
    {
      "name": "Setup"
    }
  ]
}
