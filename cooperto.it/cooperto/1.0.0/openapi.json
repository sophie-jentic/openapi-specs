{
  "openapi": "3.0.3",
  "info": {
    "title": "Cooperto API",
    "version": "1.0.0",
    "description": "API for managing restaurant reservations, queues, contacts, and loyalty programs through Cooperto.it",
    "x-jentic-source-url": "https://api.cooperto.it/swagger/ui/index",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.cooperto.it"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/api/Coda/ElencoByCodiceSede": {
      "get": {
        "tags": [
          "Queue"
        ],
        "summary": "List queue reservations by location code",
        "operationId": "getQueueList",
        "parameters": [
          {
            "name": "codiceSede",
            "in": "query",
            "description": "Location code",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Number of records to skip",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of records per page",
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueListResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "List queue reservations by location code"
      }
    },
    "/api/Coda/DettagliByCodice": {
      "get": {
        "tags": [
          "Queue"
        ],
        "summary": "Get queue details by code",
        "operationId": "getQueueDetails",
        "parameters": [
          {
            "name": "codiceSede",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "codiceCoda",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueItem"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Get queue details by code"
      }
    },
    "/api/Coda/Crea": {
      "post": {
        "tags": [
          "Queue"
        ],
        "summary": "Create queue entry",
        "operationId": "createQueue",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateQueueRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Queue created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueItem"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Create queue entry"
      }
    },
    "/api/Contatti/Elenco": {
      "get": {
        "tags": [
          "Contacts"
        ],
        "summary": "List contacts",
        "operationId": "getContacts",
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactListResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "List contacts"
      }
    },
    "/api/Contatti/Crea": {
      "post": {
        "tags": [
          "Contacts"
        ],
        "summary": "Create contact",
        "operationId": "createContact",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Create contact"
      }
    },
    "/api/Prenotazioni/ElencoByCodiceSede": {
      "get": {
        "tags": [
          "Reservations"
        ],
        "summary": "List reservations by location code",
        "operationId": "getReservations",
        "parameters": [
          {
            "name": "codiceSede",
            "in": "query",
            "description": "Location code",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dataInizio",
            "in": "query",
            "description": "Start date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "dataFine",
            "in": "query",
            "description": "End date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReservationListResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "List reservations by location code"
      }
    },
    "/api/Prenotazioni/Crea": {
      "post": {
        "tags": [
          "Reservations"
        ],
        "summary": "Create reservation",
        "operationId": "createReservation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateReservationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reservation created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reservation"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "Create reservation"
      }
    },
    "/api/Sedi/Elenco": {
      "get": {
        "tags": [
          "Locations"
        ],
        "summary": "List locations",
        "operationId": "getLocations",
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LocationListResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        },
        "description": "List locations"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication using restaurant API key"
      }
    },
    "schemas": {
      "QueueItem": {
        "type": "object",
        "properties": {
          "CodiceCoda": {
            "type": "string"
          },
          "CodiceSede": {
            "type": "string"
          },
          "DataCoda": {
            "type": "string",
            "format": "date-time"
          },
          "Nome": {
            "type": "string"
          },
          "Cognome": {
            "type": "string"
          },
          "Telefono": {
            "type": "string"
          },
          "Email": {
            "type": "string"
          },
          "Pax": {
            "type": "integer"
          },
          "Note": {
            "type": "string"
          }
        }
      },
      "CreateQueueRequest": {
        "type": "object",
        "required": [
          "CodiceSede",
          "Telefono",
          "Pax"
        ],
        "properties": {
          "CodiceSede": {
            "type": "string"
          },
          "Nome": {
            "type": "string"
          },
          "Cognome": {
            "type": "string"
          },
          "Telefono": {
            "type": "string",
            "description": "Phone number with international prefix (e.g. +39)"
          },
          "Email": {
            "type": "string"
          },
          "Pax": {
            "type": "integer",
            "description": "Number of people"
          },
          "Note": {
            "type": "string"
          }
        }
      },
      "QueueListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QueueItem"
            }
          },
          "total": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "CodiceContatto": {
            "type": "string"
          },
          "Nome": {
            "type": "string"
          },
          "Cognome": {
            "type": "string"
          },
          "Email": {
            "type": "string"
          },
          "Telefono": {
            "type": "string"
          },
          "DataCreazione": {
            "type": "string",
            "format": "date-time"
          },
          "NumeroVisite": {
            "type": "integer"
          }
        }
      },
      "ContactRequest": {
        "type": "object",
        "properties": {
          "Nome": {
            "type": "string"
          },
          "Cognome": {
            "type": "string"
          },
          "Email": {
            "type": "string"
          },
          "Telefono": {
            "type": "string"
          },
          "ConsensoPrivacy": {
            "type": "boolean"
          },
          "ConsensoMarketing": {
            "type": "boolean"
          }
        }
      },
      "ContactListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contact"
            }
          },
          "total": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          }
        }
      },
      "Reservation": {
        "type": "object",
        "properties": {
          "CodicePrenotazione": {
            "type": "string"
          },
          "CodiceSede": {
            "type": "string"
          },
          "DataPrenotazione": {
            "type": "string",
            "format": "date-time"
          },
          "Nome": {
            "type": "string"
          },
          "Cognome": {
            "type": "string"
          },
          "Telefono": {
            "type": "string"
          },
          "Email": {
            "type": "string"
          },
          "Pax": {
            "type": "integer"
          },
          "CodiceStato": {
            "type": "integer",
            "description": "Reservation status code"
          },
          "LabelStato": {
            "type": "string"
          }
        }
      },
      "CreateReservationRequest": {
        "type": "object",
        "required": [
          "CodiceSede",
          "DataPrenotazione",
          "CodiceStato",
          "Pax"
        ],
        "properties": {
          "CodiceSede": {
            "type": "string"
          },
          "DataPrenotazione": {
            "type": "string",
            "format": "date-time",
            "description": "Reservation date and time in W. Europe Standard Time"
          },
          "CodiceStato": {
            "type": "integer",
            "description": "Status: 1 = To Confirm, 2 = Confirmed"
          },
          "Nome": {
            "type": "string"
          },
          "Cognome": {
            "type": "string"
          },
          "Telefono": {
            "type": "string"
          },
          "Email": {
            "type": "string"
          },
          "Pax": {
            "type": "integer"
          },
          "Note": {
            "type": "string"
          }
        }
      },
      "ReservationListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Reservation"
            }
          },
          "total": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "CodiceSede": {
            "type": "string"
          },
          "Nome": {
            "type": "string"
          }
        }
      },
      "LocationListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Location"
            }
          },
          "total": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Authentication information is missing or invalid",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Contacts"
    },
    {
      "name": "Locations"
    },
    {
      "name": "Queue"
    },
    {
      "name": "Reservations"
    }
  ]
}
