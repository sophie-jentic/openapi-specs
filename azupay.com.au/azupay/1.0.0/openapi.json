  "paths": {
    "/createpayidpaymentrequest": {
      "post": {
        "summary": "Create payment request",
        "description": "Create a PayID payment request",
        "operationId": "createPayIdPaymentRequest",
        "tags": [
          "Payment Requests"
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": {
                    "type": "number",
                    "description": "Payment amount"
                  },
                  "description": {
                    "type": "string",
                    "description": "Payment description"
                  },
                  "payId": {
                    "type": "string",
                    "description": "PayID identifier"
                  },
                  "reference": {
                    "type": "string",
                    "description": "Payment reference"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment request created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "requestId": {
                      "type": "string",
                      "description": "Payment request identifier"
                    },
                    "status": {
                      "type": "string",
                      "description": "Request status"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
