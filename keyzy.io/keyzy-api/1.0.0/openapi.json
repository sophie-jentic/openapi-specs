{
  "openapi": "3.0.3",
  "info": {
    "title": "KEYZY API",
    "version": "1.0.0",
    "description": "KEYZY API for key management services",
    "contact": {
      "url": "https://developer.keyzy.io"
    }
  },
  "servers": [
    {
      "url": "https://api.keyzy.io"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/keys": {
      "get": {
        "summary": "List keys",
        "description": "Retrieve a list of keys",
        "operationId": "listKeys",
        "tags": [
          "Keys"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "tags": [
    {
      "name": "Keys"
    }
  ]
}
