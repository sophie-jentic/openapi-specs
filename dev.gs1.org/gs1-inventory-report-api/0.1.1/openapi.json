        "operationId": "QueryProductsbyLocation",
        "parameters": [
          {
            "name": "gln",
            "in": "path",
            "description": "Filter the products from a specific location using Location ID or GLN",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "IntegratorID",
            "in": "header",
            "description": "The IntegratorID is the primary GLN key identifying the Integrator",
