  "paths": {
    "/products": {
      "get": {
        "tags": [
          "Inventory Report"
        ],
        "summary": "Query to obtain inventory data for all products across all inventory locations",
        "description": "Get all products from all available locations. ",
        "operationId": "QueryAllProductsByVersion",
        "parameters": [
          {
            "name": "IntegratorID",
            "in": "header",
            "description": "The IntegratorID is the primary GLN key identifying the Integrator",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of objects containings the product details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Products"
                },
                "example": {
                  "result": [
                    {
                      "gtin": "09355456007136",
                      "productId": "A0001",
                      "gln": "9429000119504",
                      "locationId": "BULK01",
                      "quantityOfUnits": 10,
                      "inventoryDateTime": "2015-10-05T18:26:01.245Z"
                    },
                    {
                      "gtin": "19355456007133",
                      "productId": "A0002",
                      "gln": "9429000119504",
                      "locationId": "BULK01",
                      "quantityOfUnits": 10,
                      "inventoryDateTime": "2015-10-05T18:26:01.245Z"
                    },
                    {
                      "gtin": "05000366121529",
                      "productId": "A0003",
                      "gln": "9429000119504",
                      "locationId": "BULK01",
                      "quantityOfUnits": 10,
                      "inventoryDateTime": "2015-10-05T18:26:01.245Z"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Exception data object returned with code set to either \"2\" for INVALID_ARGUMENT_EXCEPTION, \"3\" for INVALID_REQUEST_EXCEPTION or for complex errors containing aggregated exceptions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Error"
                  }
                },
                "example": {
                  "exception": [
                    {
                      "code": "INVALID_ARGUMENT_EXCEPTION",
                      "reason": "Invalid argument provided"
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Exception data object returned with code set to \"4\" for SECURITY_EXCEPTION",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Error"
                  }
                },
                "example": {
                  "exception": [
                    {
                      "code": "SECURITY_EXCEPTION",
                      "reason": "Invalid API key"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Exception data object returned with code set to \"1\" for NO_DATA_EXCEPTION",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Error"
                  }
                },
                "example": {
                  "exception": [
                    {
                      "code": "NO_DATA_EXCEPTION",
                      "reason": "Missing parameters - storeID"
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Exception data object returned with code set to \"5\" for IMPLEMENTATION_EXCEPTION",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Error"
                  }
                },
                "example": {
                  "exception": [
                    {
                      "code": "IMPLEMENTATION_EXCEPTION",
                      "reason": "Cannot process request at this time"
                    }
                  ]
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/findProductsByLocation/{gln}": {
