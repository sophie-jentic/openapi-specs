  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "exceptions": {
            "minItems": 1,
            "type": "array",
            "description": "One or more exceptions that occurred during processing",
            "items": {
              "required": [
                "code"
              ],
              "type": "object",
              "properties": {
                "code": {
                  "type": "number",
                  "description": "A code number that specifies the type of exception that occurred. 1 = NO_DATA_EXCEPTION No data is available for the GLN/Location ID or Product ID is specified in the request 2 = INVALID_ARGUMENT_OPERATION At least one GLN/Location Id or Product ID/GTIN specified in the request is not properly formatted, or has an incorrect check digit or format. 3 = INVALID_REQUEST_EXCEPTION The request was not formatted correctly, contained an unknown parameter, or specified an unknown operation. 4 = SECURITY_EXCEPTION The operation was not permitted due to an access control violation or other security concern. This includes the case where the service wishes to deny authorization to execute a particular operation based on the authenticated client identity. 5 = IMPLEMENTATION EXCEPTION A generic exception thrown by the implementation for reasons those are implementation-specific, such as a software error.",
                  "format": "integer"
                },
                "message": {
                  "type": "string",
                  "description": "A human readable string providing additional information about the exception.  This is not intended for presentation to end consumer. The content is at the discretion of the responding Validator but SHOULD always be in English."
                }
              },
              "description": "Exception details"
            }
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "gtin": {
            "$ref": "#/components/schemas/gtin"
          },
          "productId": {
            "$ref": "#/components/schemas/productId"
          },
          "gln": {
            "$ref": "#/components/schemas/gln"
          },
          "locationId": {
            "$ref": "#/components/schemas/locationId"
          },
          "quantityOfUnits": {
            "$ref": "#/components/schemas/quantityOfUnits"
          },
          "inventoryDateTime": {
            "$ref": "#/components/schemas/inventoryDateTime"
          }
        },
        "description": "Attributes of Product instance"
      },
      "Products": {
        "type": "array",
        "description": "Array of Product instances",
        "items": {
          "$ref": "#/components/schemas/Product"
        }
      },
      "gtin": {
        "title": "GTIN",
        "maxLength": 14,
        "type": "string",
        "description": "The GTIN/EAN/UPC assigned to the trade item at each level of the packaging hierarchy"
      },
      "gln": {
        "title": "GLN",
        "maxLength": 13,
        "type": "string",
        "description": "A GLN (Global Location Number) is globally unique location identifier.  Identifies the location where inventory is held."
      },
      "productId": {
        "title": "Product ID",
        "maxLength": 14,
        "type": "string",
        "description": "A product identifier other than the GTIN (i.e. Internal Product ID)"
      },
      "locationId": {
        "title": "Location ID",
        "maxLength": 13,
        "type": "string",
        "description": "A location identifier other than a GLN (i.e. Location ID)"
      },
      "inventoryDateTime": {
        "title": "Inventory Date",
        "type": "string",
        "description": "The date and time the inventory for this line item was last assessed.",
        "format": "date-time"
      },
      "quantityOfUnits": {
        "title": "Quantity",
        "type": "number",
        "description": "The number of “Available for Sale” units of the item at the reporting location",
        "format": "float"
      }
    },
    "responses": {
      "200": {
        "description": "Array of objects containings the product details",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Products"
            },
            "example": {
              "result": [
                {
                  "gtin": "09355456007136",
                  "productId": "A0001",
                  "gln": "9429000119504",
                  "locationId": "BULK01",
                  "quantityOfUnits": 10,
                  "inventoryDateTime": "2015-10-05T18:26:01.245Z"
