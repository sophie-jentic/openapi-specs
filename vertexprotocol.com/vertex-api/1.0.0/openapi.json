    "/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Health Check",
        "description": "Returns the health status of the Vertex gateway.",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
