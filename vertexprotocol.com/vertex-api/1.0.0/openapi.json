  },
  "components": {
    "schemas": {
      "QueryRequest": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Query type (e.g. subaccount_info, all_products, market_price, order_book, max_order_size)"
          },
          "product_id": {
            "type": "integer"
          },
          "sender": {
            "type": "string"
          },
          "subaccount": {
            "type": "string"
          }
        }
      },
      "ExecuteRequest": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Transaction type (e.g. place_order, cancel_orders, cancel_product_orders, liquidate_subaccount)"
          },
          "signature": {
            "type": "string"
          },
          "tx": {
            "type": "object"
          }
        }
      },
      "IndexerRequest": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Indexer query type (e.g. candlesticks, trades, funding_rate, subaccount_summary)"
          },
          "product_id": {
            "type": "integer"
          },
          "subaccount": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          },
          "max_time": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "code": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "tags": [
    {
      "name": "Execute"
    },
    {
      "name": "Indexer"
    },
    {
      "name": "Market Data"
    },
    {
      "name": "Query"
    },
    {
      "name": "System"
    }
  ]
}
