{
  "openapi": "3.0.3",
  "info": {
    "title": "Vertex API",
    "version": "1.0.0",
    "description": "Vertex Protocol is a decentralized exchange (DEX) for spot, perpetuals, and money markets. The API provides access to trading, market data, account management, and liquidity pool operations.",
    "x-jentic-source-url": "https://docs.vertexprotocol.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://gateway.prod.vertexprotocol.com/v1"
    }
  ],
  "paths": {
    "/query": {
      "post": {
        "operationId": "query",
        "summary": "Query Engine",
        "description": "Execute read-only queries against the Vertex engine. Supports various query types including subaccount info, market data, and order book state.",
        "tags": [
          "Query"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/execute": {
      "post": {
        "operationId": "execute",
        "summary": "Execute Transaction",
        "description": "Submit signed transactions to the Vertex engine. Supports placing orders, cancelling orders, liquidations, and other state-changing operations.",
        "tags": [
          "Execute"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/indexer": {
      "post": {
        "operationId": "queryIndexer",
        "summary": "Query Indexer",
        "description": "Query the Vertex indexer for historical data including trades, funding rates, candlestick data, and account history.",
        "tags": [
          "Indexer"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IndexerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/symbols": {
      "get": {
        "operationId": "getSymbols",
        "summary": "Get Symbols",
        "description": "Returns all available trading symbols and their product IDs.",
        "tags": [
