            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/contracts": {
      "get": {
        "operationId": "getContracts",
        "summary": "Get Contracts",
        "description": "Returns contract addresses for Vertex protocol on supported chains.",
        "tags": [
          "Market Data"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
