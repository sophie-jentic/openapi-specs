    "x-jentic-source-url": "https://smartcar.com/docs/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.smartcar.com/v2.0",
      "description": "Smartcar API Production Server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Vehicles",
      "description": "Vehicle data and information"
    },
    {
      "name": "Control",
      "description": "Vehicle control commands"
    },
    {
      "name": "EV",
      "description": "Electric vehicle specific endpoints"
    },
    {
      "name": "Users",
      "description": "User and connection management"
    },
    {
      "name": "Webhooks",
      "description": "Webhook subscriptions for vehicle events"
    },
    {
      "name": "Compatibility",
      "description": "Vehicle compatibility checks"
    }
  ],
  "paths": {
    "/vehicles": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "List user vehicles",
        "description": "Retrieve a list of vehicles associated with the authenticated user.",
        "operationId": "listVehicles",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of vehicles to return per page (max 50)",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Index to start the vehicles list at",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of vehicle IDs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VehicleListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or expired access token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
