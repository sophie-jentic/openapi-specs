{
  "openapi": "3.0.3",
  "info": {
    "title": "Smartcar API",
    "description": "Lock and unlock vehicles and get data like odometer reading and location. Works on most new cars. Smartcar provides a unified API to read vehicle data and send commands to vehicles across brands.",
