{
  "openapi": "3.0.3",
  "info": {
    "title": "FireBox API",
    "version": "1.0.0",
    "description": "FireBox Pro JSON API for retrieving forms and their submissions from WordPress sites running the FireBox plugin.",
    "x-jentic-source-url": "https://www.fireplugins.com/docs/firebox/how-to-use-the-json-api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://example.com/wp-json/firebox/v1",
      "description": "WordPress site with FireBox plugin (replace example.com)"
    }
  ],
  "paths": {
    "/forms/{api_key}/get": {
      "get": {
        "operationId": "listForms",
        "summary": "Get all forms",
        "description": "Returns a list of FireBox forms with their IDs, names, creation dates, and states",
        "tags": [
          "Forms"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "List of forms",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FormListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/submissions/{api_key}/get/{form_id}": {
      "get": {
        "operationId": "getFormSubmissions",
        "summary": "Get form submissions",
        "description": "Retrieves submission data for a specific form, including field values and metadata",
        "tags": [
          "Submissions"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key"
          },
          {
            "name": "form_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Form ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Form submissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Form": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "created_date": {
            "type": "string",
            "format": "date-time"
          },
          "state": {
            "type": "string"
          }
        }
      },
      "FormListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Form"
            }
          }
        }
      },
      "Submission": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "form_id": {
            "type": "string"
          },
          "fields": {
            "type": "object"
          },
          "submitted_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SubmissionListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Submission"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyPath": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key passed in URL path"
      }
    }
  },
  "security": [
    {
      "apiKeyPath": []
    }
  ],
  "tags": [
    {
      "name": "Forms"
    },
    {
      "name": "Submissions"
    }
  ]
}
