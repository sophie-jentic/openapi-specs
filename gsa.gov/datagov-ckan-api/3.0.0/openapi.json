      "get": {
        "operationId": "listPackages",
        "summary": "List all dataset packages",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Max results",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Offset",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
