{
  "openapi": "3.0.3",
  "info": {
    "title": "CoderPad Interview API",
    "version": "1.0.0",
    "description": "CoderPad provides a simple API for programmatically creating and managing interview pads. You can use the API to integrate pads with your internal interview scheduling platform or to get a text dump of an interview after the fact. CoderPad provides a standard REST API that returns results in JSON format.",
    "x-jentic-source-url": "https://api.interview.coderpad.io/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://app.coderpad.io/api",
      "description": "CoderPad API server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    },
    {
      "tokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "Pads",
      "description": "Create and manage interview pads"
    },
    {
      "name": "Pad Environments",
      "description": "Retrieve pad environment information"
    },
    {
      "name": "Questions",
      "description": "Manage interview questions"
    },
    {
      "name": "Quota",
      "description": "Retrieve quota information"
    },
    {
      "name": "Organization",
      "description": "Retrieve organization-wide information"
    }
  ],
  "paths": {
    "/pads": {
      "get": {
        "operationId": "listPads",
        "summary": "Retrieve a list of pads",
        "description": "Fetch a list of all pads. Returns everything that an individual Get Pad request does. Field values in the index view may be up to a minute behind real-time.",
        "tags": [
          "Pads"
        ],
        "responses": {
          "200": {
            "description": "List of pads returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PadListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPad",
        "summary": "Create a pad",
        "description": "Create a new pad with optional initial conditions such as title, language, contents, and private notes.",
        "tags": [
          "Pads"
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CreatePadRequest"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pad created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Over quota - exceeded monthly pad limit",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "modifyPad",
        "summary": "Modify a pad",
        "description": "Modify an existing pad. You can specify any of the valid parameters used to create the pad. You may also end the interview by setting ended=true or delete it by setting deleted=true.",
        "tags": [
          "Pads"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/ModifyPadRequest"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ModifyPadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pad modified successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Pad not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/pads/{padId}": {
      "get": {
        "operationId": "getPad",
        "summary": "Retrieve a pad by id",
        "description": "Returns detail about a particular pad including state, language, contents, participants, events link, notes, and timing information.",
        "tags": [
          "Pads"
        ],
        "parameters": [
          {
            "name": "padId",
            "in": "path",
            "required": true,
            "description": "The unique pad identifier (alphanumeric string)",
            "schema": {
              "type": "string"
            },
            "example": "DM32JWG2"
          }
        ],
        "responses": {
          "200": {
            "description": "Pad retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Pad not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
