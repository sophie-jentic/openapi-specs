  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. For Interview API use: Authorization: Bearer <token>"
      },
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token authentication. Format: Token token=\"<api_key>\""
      }
    },
    "schemas": {
      "Pad": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique pad identifier (alphanumeric)",
            "example": "AB12345"
          },
          "title": {
            "type": "string",
            "description": "Pad title",
            "example": "Untitled Pad - AB12345"
          },
          "state": {
            "type": "string",
            "enum": [
              "pending",
              "started",
              "ended"
            ],
            "description": "Current pad state"
          },
          "owner_email": {
            "type": "string",
            "format": "email",
            "description": "Email of the pad owner"
          },
          "language": {
            "type": "string",
            "description": "Programming language",
            "example": "javascript"
          },
          "private": {
            "type": "boolean",
            "description": "Whether the pad is private"
          },
          "execution_enabled": {
            "type": "boolean",
            "description": "Whether code execution is enabled"
          },
          "contents": {
            "type": "string",
            "nullable": true,
            "description": "Current code contents of the pad"
          },
          "participants": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of participant names"
          },
          "events": {
            "type": "string",
            "format": "uri",
            "description": "URL to retrieve pad events"
          },
          "notes": {
            "type": "string",
            "nullable": true,
            "description": "Private interviewer notes"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Pad creation timestamp"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          },
          "ended_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "When the pad was ended"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Web URL for the pad"
          },
          "sandbox_url": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "Sandbox URL for the pad"
          },
          "is_sandbox": {
            "type": "boolean",
            "description": "Whether the pad is a sandbox"
          }
        }
      },
      "PadEvent": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable event message"
          },
          "kind": {
            "type": "string",
            "description": "Event type (e.g., joined, left, auto_ended)",
            "example": "auto_ended"
          },
          "metadata": {
            "type": "object",
            "nullable": true,
            "description": "Additional event metadata"
          },
          "user_name": {
            "type": "string",
            "nullable": true,
            "description": "Name of the user who triggered the event"
          },
          "user_email": {
            "type": "string",
            "nullable": true,
            "description": "Email of the user who triggered the event"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Event timestamp"
          }
        }
      },
      "PadEnvironment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Pad environment ID"
          },
          "pad_id": {
            "type": "integer",
            "description": "Associated pad ID"
          },
          "question_id": {
            "type": "integer",
            "nullable": true,
