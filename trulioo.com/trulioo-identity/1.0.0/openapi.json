  "paths": {
    "/connection/v1/sayhello/{name}": {
      "get": {
        "tags": [
          "Connection"
        ],
        "operationId": "sayHello",
        "summary": "Say Hello",
        "description": "Check if your system can connect to Trulioo.",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful connection",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/connection/v1/testauthentication": {
      "get": {
        "tags": [
          "Connection"
        ],
        "operationId": "testAuthentication",
        "summary": "Test Authentication",
        "description": "Check if your credentials are valid using basic authentication.",
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid credentials"
          }
        }
      }
    },
    "/configuration/v1/countrycodes/{configurationName}": {
