    {
      "url": "https://api.trulioo.com",
      "description": "Trulioo API"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Connection",
      "description": "Connection and health check endpoints"
    },
    {
      "name": "Configuration",
      "description": "Configuration management for verification products"
    },
    {
      "name": "Verifications",
      "description": "Identity and document verification"
    },
    {
      "name": "Business",
