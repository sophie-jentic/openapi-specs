  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication using Trulioo API credentials"
      }
    },
    "schemas": {
      "VerifyRequest": {
        "type": "object",
        "properties": {
          "AcceptTruliooTermsAndConditions": {
            "type": "boolean"
          },
          "ConfigurationName": {
            "type": "string"
          },
          "CallBackUrl": {
            "type": "string",
            "format": "uri"
          },
          "ConsentForDataSources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "CountryCode": {
            "type": "string"
          },
          "DataFields": {
            "$ref": "#/components/schemas/DataFields"
          },
          "VerboseMode": {
            "type": "boolean"
          }
        },
        "required": [
          "AcceptTruliooTermsAndConditions",
          "ConfigurationName",
          "CountryCode",
          "DataFields"
