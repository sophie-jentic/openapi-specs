{
  "openapi": "3.0.3",
  "info": {
    "description": "This is Enables Authentication API which generates access tokens with credentials from Enables Identity and Acceess Management platform. These tokens then provide access to Enable other API offerings.\n</br></br>To read a walkthrough of how to use the API, <a href='https://api-developer.enable.net.nz/hc/en-nz/articles/32166117952409-How-to-use-the-API'>click here.</a>\n",
    "version": "v2.0.0",
    "title": "Auth API",
    "termsOfService": "https://api-developer.enable.net.nz/hc/en-nz/articles/360053801514",
    "contact": {
      "email": "apisupport@enable.net.nz"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Enable-Networks/Auth-API/v2.0.0/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/Enable-Networks/Auth-API/v2.0.0"
    }
  ],
  "paths": {
    "/token": {
      "post": {
        "summary": "Generate an access token",
        "operationId": "createToken",
        "security": [
          {
            "basicAuth": []
          }
        ],
        "parameters": [
          {
            "in": "header",
            "name": "X-Transaction-ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "Authorization",
            "description": "This is a base64 encoded string in the format of 'client_id:client_secret'. The client ID and client secret are found in the clients IAM (Okta) application.",
            "required": true,
            "example": "Basic abc1234567",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "The body of the request contains the scopes the client wants the access token to include.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/createTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token was successfully generated.",
            "headers": {
              "X-Transaction-ID": {
                "$ref": "#/components/headers/X-Transaction-ID"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Authentication"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        },
        "tags": [
          "token"
        ],
        "description": "Generate an access token"
      }
    },
    "/version": {
      "get": {
        "summary": "Get the current version of the Auth API",
        "description": "Returns a JSON object with the current running version of the API.",
        "operationId": "getVersion",
        "parameters": [
          {
            "in": "header",
            "name": "X-Transaction-ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "headers": {
              "X-Transaction-ID": {
                "$ref": "#/components/headers/X-Transaction-ID"
              },
              "Content-Type": {
                "description": "This is the transaction id provided in the initial request.",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Version"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        },
        "tags": [
          "version"
        ]
      }
    }
  },
  "components": {
    "headers": {
      "X-Transaction-ID": {
        "description": "This is the transaction id provided in the initial request.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Authentication": {
        "type": "object",
        "properties": {
          "token_type": {
            "type": "string",
            "example": "Bearer",
            "description": "The type of token returned."
          },
          "expires_in": {
            "type": "integer",
            "format": "int64",
            "example": 43200,
            "description": "The time in seconds when the token will expire."
          },
          "access_token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c",
            "description": "The JWT access token to use in Enables APIs."
          },
          "scopes": {
            "type": "array",
            "minLength": 1,
            "items": {
              "type": "string"
            },
            "example": [
              "RSPCode.ENA",
              "linetest.read"
            ],
            "description": "The scopes included in the access token."
          }
        }
      },
      "createTokenRequest": {
        "type": "object",
        "properties": {
          "scopes": {
            "description": "This is the set of scopes to apply to the access token. If the client does not have access to the scopes, a 403 response will be returned. If the client requests scopes that does not exist, a 404 response will be returned.\n",
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "RSPCode.ENA",
              "linetestAPI.read"
            ]
          }
        }
      },
      "Version": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string",
            "example": "1.2.0"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "cause": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "X-Transaction-ID": {
            "type": "string"
          }
        }
      },
      "RateLimitError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "400 - The request does not meet the API specification.",
        "headers": {
          "X-Transaction-ID": {
            "$ref": "#/components/headers/X-Transaction-ID"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "Bad Request",
              "cause": "Required header X-Transaction-ID not specified",
              "code": "None",
              "X-Transaction-ID": "E4AB9237-776C-44BF-B10A-3466CA5A0849"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "401 - Unable to authorize the request.",
        "headers": {
          "X-Transaction-ID": {
            "$ref": "#/components/headers/X-Transaction-ID"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "Unauthorized",
              "cause": "The credentials are invalid.",
              "code": "None",
              "X-Transaction-ID": "E4AB9237-776C-44BF-B10A-3466CA5A0849"
            }
          }
        }
      },
      "Forbidden": {
        "description": "403 - The client lacks permissions to fulfill the request.",
        "headers": {
          "X-Transaction-ID": {
            "$ref": "#/components/headers/X-Transaction-ID"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "Forbidden",
              "cause": "Client does not have access to the requested scopes.",
              "code": "None",
              "X-Transaction-ID": "E4AB9237-776C-44BF-B10A-3466CA5A0849"
            }
          }
        }
      },
      "NotFound": {
        "description": "404 - Unable to find the requested resource.",
        "headers": {
          "X-Transaction-ID": {
            "$ref": "#/components/headers/X-Transaction-ID"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "Not Found",
              "cause": "Unable to find the requested resource.",
              "code": "None",
              "X-Transaction-ID": "E4AB9237-776C-44BF-B10A-3466CA5A0849"
            }
          }
        }
      },
      "RateLimitExceeded": {
        "description": "429 - The rate limit has been exceeded.",
        "headers": {
          "X-Transaction-ID": {
            "$ref": "#/components/headers/X-Transaction-ID"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/RateLimitError"
            },
            "example": {
              "error": "Quota has been exceeded."
            }
          }
        }
      },
      "ServerError": {
        "description": "500 - Internal server error has occured whilst processing your request.",
        "headers": {
          "X-Transaction-ID": {
            "$ref": "#/components/headers/X-Transaction-ID"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "Internal server error",
              "cause": "Unable to process your request due to an unexpected error.",
              "code": "None",
              "X-Transaction-ID": "E4AB9237-776C-44BF-B10A-3466CA5A0849"
            }
          }
        }
      },
      "ServiceUnavailable": {
        "description": "503 - A downstream error has occured whilst processing your request.",
        "headers": {
          "X-Transaction-ID": {
            "$ref": "#/components/headers/X-Transaction-ID"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "Service unavailable",
              "cause": "The request couldn't be completed successfully because of an error in a downstream system.",
              "code": "None",
              "X-Transaction-ID": "E4AB9237-776C-44BF-B10A-3466CA5A0849"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  },
  "tags": [
    {
      "name": "token"
    },
    {
      "name": "version"
    }
  ]
}
