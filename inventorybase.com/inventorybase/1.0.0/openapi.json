  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://my.inventorybase.com/oauth/authorize",
            "tokenUrl": "https://my.inventorybase.com/oauth/token",
            "scopes": {
              "profile.read": "Read basic profile details",
              "properties.read": "List properties",
              "properties.write": "Manage properties",
              "inspections.read": "List inspections",
              "inspections.write": "Manage inspections",
              "reports.read": "Read inspection reports",
              "reports.write": "Modify inspection reports",
              "clients.read": "List clients",
              "clients.write": "Manage clients",
              "staff.read": "List staff users",
              "staff.write": "Manage staff users",
              "templates.read": "List templates",
              "templates.write": "Manage templates",
              "webhooks.read": "List registered webhooks",
              "webhooks.write": "Manage webhooks",
              "file-share.read": "List file shares",
              "file-share.write": "Manage file shares",
              "configuration.read": "List configurations",
              "configuration.write": "Manage configurations"
            }
          }
        }
      }
    },
    "schemas": {
      "OAuthTokenRequest": {
        "type": "object",
        "required": [
          "grant_type",
          "client_id",
          "client_secret"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "authorization_code",
              "refresh_token"
            ]
          },
          "code": {
            "type": "string",
            "description": "Required when grant_type=authorization_code"
          },
          "refresh_token": {
            "type": "string",
            "description": "Required when grant_type=refresh_token"
          },
          "client_id": {
            "type": "string"
          },
          "client_secret": {
            "type": "string"
          },
          "redirect_uri": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "description": "Space-separated list of scopes"
          }
        }
      },
      "OAuthTokenResponse": {
        "type": "object",
        "properties": {
          "token_type": {
            "type": "string",
            "example": "Bearer"
          },
          "expires_in": {
            "type": "integer",
            "example": 7200
          },
          "access_token": {
            "type": "string"
          },
          "refresh_token": {
            "type": "string"
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "company": {
            "type": "string"
          },
          "role": {
            "type": "integer"
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "line1": {
            "type": "string"
          },
          "line2": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string"
          },
          "county": {
            "type": "string",
            "nullable": true
          },
          "postcode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        }
      },
      "GeoCoords": {
        "type": "object",
        "properties": {
          "lat": {
            "type": "string",
            "nullable": true
          },
          "lng": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Property": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "ref": {
            "type": "string",
            "nullable": true
          },
          "parent_property_id": {
            "type": "integer",
            "nullable": true
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "geocoords": {
            "$ref": "#/components/schemas/GeoCoords"
          },
          "furnished": {
            "type": "string",
            "enum": [
              "Unfurnished",
              "Part Furnished",
              "Fully Furnished"
            ]
          },
          "type": {
            "type": "string"
          },
          "detachment": {
            "type": "string",
            "nullable": true
          },
          "no_of_beds": {
            "type": "integer"
          },
          "no_of_baths": {
            "type": "integer"
          },
          "no_of_garages": {
            "type": "integer"
          },
          "parking": {
            "type": "boolean"
          },
          "garden": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          },
          "uprn": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "client": {
            "$ref": "#/components/schemas/ClientRef"
          },
          "customFields": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "PropertyRequest": {
        "type": "object",
        "required": [
          "address"
        ],
        "properties": {
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "ref": {
            "type": "string"
          },
          "furnished": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "no_of_beds": {
            "type": "integer"
          },
          "no_of_baths": {
            "type": "integer"
          },
          "no_of_garages": {
            "type": "integer"
          },
          "parking": {
            "type": "boolean"
          },
          "garden": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          },
          "uprn": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "client_id": {
            "type": "integer"
          },
          "custom_fields": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "PropertyListResponse": {
        "type": "object",
        "properties": {
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          },
          "links": {
            "$ref": "#/components/schemas/Links"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Property"
            }
          }
        }
      },
      "Inspection": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "type": {
            "type": "string"
          },
          "property_id": {
            "type": "integer"
          },
          "staff_id": {
            "type": "integer",
            "nullable": true
          },
          "scheduled_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
