{
  "openapi": "3.0.3",
  "info": {
    "title": "InventoryBase API",
    "version": "1.0.0",
    "description": "InventoryBase is a UK property inspection and inventory management platform. This API allows you to manage properties, inspections, reports, clients, staff, templates, and webhooks using OAuth 2.0 authentication.",
    "x-jentic-source-url": "https://developer.inventorybase.com/docs",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.inventorybase.com",
      "description": "InventoryBase API"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/oauth/token": {
      "post": {
        "operationId": "getOAuthToken",
        "summary": "Exchange authorization code or refresh token for access token",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/OAuthTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Exchange authorization code or refresh token for access token"
      }
    },
