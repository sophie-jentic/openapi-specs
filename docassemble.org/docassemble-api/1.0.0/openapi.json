{
  "openapi": "3.0.3",
  "info": {
    "title": "Docassemble API",
    "version": "1.0.0",
    "description": "Docassemble is a free, open-source expert system for guided interviews and document assembly. The API provides access to interview sessions, user management, file management, and server administration.",
    "x-jentic-source-url": "https://docassemble.org/docs/api.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Sessions",
      "description": "Interview session management"
    },
    {
      "name": "Users",
      "description": "User management"
    },
    {
      "name": "Files",
      "description": "File operations"
    },
    {
      "name": "Interviews",
      "description": "Interview management"
    },
    {
      "name": "Packages",
      "description": "Package management"
    },
    {
      "name": "Server",
      "description": "Server administration"
    },
    {
      "name": "Playground",
      "description": "Playground operations"
    },
    {
      "name": "Configuration",
      "description": "Server configuration"
    }
  ],
  "paths": {
    "/api/session/new": {
      "get": {
        "tags": [
          "Sessions"
        ],
        "operationId": "newSession",
        "summary": "Start a new interview session",
        "parameters": [
          {
            "name": "i",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Interview YAML filename",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Session created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "session": {
                      "type": "string"
                    },
                    "i": {
                      "type": "string"
                    },
                    "encrypted": {
                      "type": "boolean"
                    },
                    "secret": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Start a new interview session"
      }
    },
    "/api/session/question": {
      "get": {
        "tags": [
          "Sessions"
        ],
        "operationId": "getQuestion",
        "summary": "Get the current question in a session",
        "parameters": [
          {
            "name": "i",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Interview YAML filename",
            "required": true
          },
          {
            "name": "session",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Session ID",
            "required": true
          },
          {
            "name": "secret",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Session secret"
          }
        ],
        "responses": {
          "200": {
            "description": "Current question data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get the current question in a session"
      }
    },
    "/api/session": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "operationId": "setSessionVariables",
        "summary": "Set variables in a session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "i",
                  "session",
                  "variables"
                ],
                "properties": {
                  "i": {
                    "type": "string"
                  },
                  "session": {
                    "type": "string"
                  },
                  "secret": {
                    "type": "string"
                  },
                  "variables": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Variables set",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Set variables in a session"
      },
      "get": {
        "tags": [
          "Sessions"
        ],
        "operationId": "getSessionVariables",
        "summary": "Get variables from a session",
        "parameters": [
          {
            "name": "i",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Interview YAML filename",
            "required": true
          },
          {
            "name": "session",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Session ID",
            "required": true
          },
          {
            "name": "secret",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Session secret"
          },
          {
            "name": "variables",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "JSON array of variable names"
          }
        ],
        "responses": {
          "200": {
            "description": "Variable values",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "variables": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get variables from a session"
      },
      "delete": {
        "tags": [
          "Sessions"
        ],
        "operationId": "deleteSession",
        "summary": "Delete a session",
        "parameters": [
          {
            "name": "i",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Interview YAML filename",
            "required": true
          },
          {
            "name": "session",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Session ID",
            "required": true
          },
          {
            "name": "secret",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Session secret"
          }
        ],
        "responses": {
          "204": {
            "description": "Session deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete a session"
      }
    },
    "/api/session/back": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "operationId": "goBack",
        "summary": "Go back one step in the interview",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "i",
                  "session"
                ],
                "properties": {
                  "i": {
                    "type": "string"
                  },
                  "session": {
                    "type": "string"
                  },
                  "secret": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Went back successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Go back one step in the interview"
      }
    },
    "/api/session/action": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "operationId": "performAction",
        "summary": "Perform a named action in a session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "i",
                  "session",
                  "action"
                ],
                "properties": {
                  "i": {
                    "type": "string"
                  },
                  "session": {
                    "type": "string"
                  },
                  "secret": {
                    "type": "string"
                  },
                  "action": {
                    "type": "string"
                  },
                  "arguments": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Action performed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
