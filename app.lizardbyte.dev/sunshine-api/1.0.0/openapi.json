{
  "openapi": "3.0.3",
  "info": {
    "title": "Sunshine API",
    "version": "1.0.0",
    "description": "Sunshine is a self-hosted game stream host for Moonlight. The API provides local HTTPS endpoints for configuration, session management, client pairing, and system controls.",
    "x-jentic-source-url": "https://docs.lizardbyte.dev/projects/sunshine/latest/md_docs_2api.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://localhost:47990"
    }
  ],
  "paths": {
    "/api/pin": {
      "post": {
        "operationId": "pairClient",
        "summary": "Complete client pairing with PIN",
        "tags": [
          "Pairing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pin": {
                    "type": "string",
                    "description": "4-digit pairing PIN"
                  },
                  "name": {
                    "type": "string",
                    "description": "Client name"
                  }
                },
                "required": [
                  "pin"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pairing result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Complete client pairing with PIN"
      }
    },
    "/api/unpair": {
      "post": {
        "operationId": "unpairClient",
        "summary": "Unpair a client",
        "tags": [
          "Pairing"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "uuid": {
                    "type": "string",
                    "description": "Client UUID to unpair"
                  }
                },
                "required": [
                  "uuid"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Client unpaired"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Unpair a client"
      }
    },
    "/api/clients": {
      "get": {
        "operationId": "listClients",
        "summary": "List paired clients",
        "tags": [
          "Pairing"
        ],
        "responses": {
          "200": {
            "description": "List of paired clients",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "named_certs": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Client"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List paired clients"
      }
    },
    "/api/apps": {
      "get": {
        "operationId": "listApps",
        "summary": "List configured applications",
        "tags": [
          "Applications"
        ],
        "responses": {
          "200": {
            "description": "Application list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "apps": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Application"
                      }
                    },
                    "env": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List configured applications"
      }
    },
    "/api/apps/close": {
      "post": {
        "operationId": "closeApp",
        "summary": "Close the currently running application",
        "tags": [
          "Applications"
        ],
        "responses": {
          "200": {
            "description": "Application closed"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Close the currently running application"
      }
    },
    "/api/config": {
      "get": {
        "operationId": "getConfig",
        "summary": "Get Sunshine configuration",
        "tags": [
          "Configuration"
        ],
        "responses": {
          "200": {
            "description": "Current configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Config"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get Sunshine configuration"
      },
      "post": {
        "operationId": "updateConfig",
        "summary": "Update Sunshine configuration",
        "tags": [
          "Configuration"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Config"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Configuration updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update Sunshine configuration"
      }
    },
    "/api/configLocale": {
      "get": {
        "operationId": "getConfigLocale",
        "summary": "Get localized configuration descriptions",
        "tags": [
          "Configuration"
        ],
        "responses": {
          "200": {
            "description": "Localized config keys and descriptions"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get localized configuration descriptions"
      }
    },
    "/api/restart": {
      "post": {
        "operationId": "restart",
        "summary": "Restart Sunshine",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Restart initiated"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Restart Sunshine"
      }
    },
    "/api/password": {
      "post": {
        "operationId": "changePassword",
        "summary": "Change admin password",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "currentUsername": {
                    "type": "string"
                  },
                  "currentPassword": {
                    "type": "string"
                  },
                  "newUsername": {
                    "type": "string"
                  },
                  "newPassword": {
                    "type": "string"
                  },
                  "confirmNewPassword": {
                    "type": "string"
                  }
                },
                "required": [
                  "currentUsername",
                  "currentPassword",
                  "newPassword",
                  "confirmNewPassword"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password changed"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Change admin password"
      }
    },
    "/api/covers/upload": {
      "post": {
        "operationId": "uploadCover",
        "summary": "Upload an application cover image",
        "tags": [
          "Applications"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "cover": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cover uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Upload an application cover image"
      }
    }
  },
  "components": {
    "schemas": {
      "Client": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "uuid": {
            "type": "string"
          }
        }
      },
      "Application": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "output": {
            "type": "string"
          },
          "cmd": {
            "type": "string"
          },
          "index": {
            "type": "integer"
          },
          "auto-detach": {
            "type": "boolean"
          },
          "wait-all": {
            "type": "boolean"
          },
          "exit-timeout": {
            "type": "integer"
          },
          "image-path": {
            "type": "string"
          }
        }
      },
      "Config": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Key-value configuration map"
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "true",
              "false"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "error": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication with admin credentials"
      }
    }
  },
  "security": [
    {
      "BasicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Applications"
    },
    {
      "name": "Authentication"
    },
    {
      "name": "Configuration"
    },
    {
      "name": "Pairing"
    },
    {
      "name": "System"
    }
  ]
}
