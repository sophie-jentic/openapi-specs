{
  "openapi": "3.0.0",
  "info": {
    "title": "Google Pollen API",
    "description": "Provides up to 5 days of pollen information in more than 65 countries with 1km resolution. Formerly BreezoMeter Pollen API, now part of Google Maps Platform.",
    "version": "1.0.0",
    "contact": {
      "name": "Google Maps Platform",
      "url": "https://developers.google.com/maps/documentation/pollen"
    }
  },
  "servers": [
    {
      "url": "https://pollen.googleapis.com/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/forecast:lookup": {
      "get": {
        "summary": "Get pollen forecast",
        "description": "Returns up to 5 days of daily pollen information for a given location in more than 65 countries, up to 1km resolution.",
        "operationId": "getForecast",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Google Maps API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "location.latitude",
            "in": "query",
            "required": true,
            "description": "Latitude of target location",
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": -90,
              "maximum": 90
            }
          },
          {
            "name": "location.longitude",
            "in": "query",
            "required": true,
            "description": "Longitude of target location",
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": -180,
              "maximum": 180
            }
          },
          {
            "name": "days",
            "in": "query",
            "description": "Number of forecast days (maximum 5)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5,
              "default": 5
            }
          },
          {
            "name": "languageCode",
            "in": "query",
            "description": "Language code for translated fields (e.g., en, es, fr)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "plantsDescription",
            "in": "query",
            "description": "Include plant details in response",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Results per page for pagination",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pageToken",
            "in": "query",
            "description": "Token for next page",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "regionCode": {
                      "type": "string",
                      "description": "Region identifier for requested coordinates"
                    },
                    "dailyInfo": {
                      "type": "array",
                      "description": "Array of daily forecast objects",
                      "items": {
                        "type": "object",
                        "properties": {
                          "date": {
                            "type": "object",
                            "properties": {
                              "year": {
                                "type": "integer"
                              },
                              "month": {
                                "type": "integer"
                              },
                              "day": {
                                "type": "integer"
                              }
                            }
                          },
                          "pollenTypeInfo": {
                            "type": "array",
                            "description": "Pollen data for GRASS, TREE, WEED types",
                            "items": {
                              "type": "object",
                              "properties": {
                                "code": {
                                  "type": "string",
                                  "enum": ["GRASS", "TREE", "WEED"]
                                },
                                "displayName": {
                                  "type": "string"
                                },
                                "inSeason": {
                                  "type": "boolean"
                                },
                                "indexInfo": {
                                  "type": "object",
                                  "description": "Universal Pollen Index (UPI)",
                                  "properties": {
                                    "value": {
                                      "type": "integer",
                                      "minimum": 0,
                                      "maximum": 5
                                    },
                                    "category": {
                                      "type": "string"
                                    },
                                    "indexDescription": {
                                      "type": "string"
                                    },
                                    "color": {
                                      "type": "object",
                                      "properties": {
                                        "red": {
                                          "type": "integer"
                                        },
                                        "green": {
                                          "type": "integer"
                                        },
                                        "blue": {
                                          "type": "integer"
                                        }
                                      }
                                    }
                                  }
                                },
                                "healthRecommendations": {
                                  "type": "array",
                                  "description": "User-actionable health guidance",
                                  "items": {
                                    "type": "string"
                                  }
                                }
                              }
                            }
                          },
                          "plantInfo": {
                            "type": "array",
                            "description": "Specific plant data with descriptions",
                            "items": {
                              "type": "object",
                              "properties": {
                                "code": {
                                  "type": "string"
                                },
                                "displayName": {
                                  "type": "string"
                                },
                                "inSeason": {
                                  "type": "boolean"
                                },
                                "indexInfo": {
                                  "type": "object",
                                  "properties": {
                                    "value": {
                                      "type": "integer"
                                    },
                                    "category": {
                                      "type": "string"
                                    },
                                    "indexDescription": {
                                      "type": "string"
                                    }
                                  }
                                },
                                "plantDescription": {
                                  "type": "object",
                                  "properties": {
                                    "type": {
                                      "type": "string"
                                    },
                                    "family": {
                                      "type": "string"
                                    },
                                    "season": {
                                      "type": "string"
                                    },
                                    "specialColors": {
                                      "type": "string"
                                    },
                                    "specialShapes": {
                                      "type": "string"
                                    },
                                    "crossReaction": {
                                      "type": "string"
                                    },
                                    "picture": {
                                      "type": "string",
                                      "format": "uri"
                                    },
                                    "pictureLicense": {
                                      "type": "string"
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    "nextPageToken": {
                      "type": "string",
                      "description": "Pagination token for multi-page results"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid or missing API key"
          }
        }
      }
    },
    "/mapTypes/{mapType}/heatmapTiles/{zoom}/{x}/{y}": {
      "get": {
        "summary": "Get heatmap tile",
        "description": "Returns a byte array containing the data of the tile PNG image for pollen heatmap visualization.",
        "operationId": "getHeatmapTile",
        "parameters": [
          {
            "name": "mapType",
            "in": "path",
            "required": true,
            "description": "Type of map data",
            "schema": {
              "type": "string",
              "enum": ["TREE_UPI", "GRASS_UPI", "WEED_UPI"]
            }
          },
          {
            "name": "zoom",
            "in": "path",
            "required": true,
            "description": "Zoom level",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 16
            }
          },
          {
            "name": "x",
            "in": "path",
            "required": true,
            "description": "Tile X coordinate",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "y",
            "in": "path",
            "required": true,
            "description": "Tile Y coordinate",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Google Maps API key",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PNG image tile",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid or missing API key"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "Google Maps API key"
      }
    }
  }
}
