  "components": {
    "schemas": {
      "ListClustersResponse": {
        "type": "object",
        "properties": {
          "ClusterInfoList": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ClusterInfo"
            }
          },
          "NextToken": {
            "type": "string"
          }
        }
      },
      "ClusterInfo": {
        "type": "object",
        "properties": {
          "ClusterArn": {
            "type": "string"
          },
          "ClusterName": {
            "type": "string"
          },
          "CreationTime": {
            "type": "string",
            "format": "date-time"
          },
          "CurrentVersion": {
            "type": "string"
          },
          "State": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "CREATING",
              "DELETING",
              "FAILED",
              "MAINTENANCE",
              "REBOOTING_BROKER",
              "UPDATING"
            ]
          },
          "NumberOfBrokerNodes": {
            "type": "integer"
          }
        }
      },
      "CreateClusterInput": {
        "type": "object",
        "required": [
          "ClusterName",
          "KafkaVersion",
          "NumberOfBrokerNodes",
          "BrokerNodeGroupInfo"
        ],
        "properties": {
          "ClusterName": {
            "type": "string"
          },
          "KafkaVersion": {
            "type": "string"
          },
          "NumberOfBrokerNodes": {
            "type": "integer"
          },
          "BrokerNodeGroupInfo": {
            "type": "object",
            "properties": {
              "InstanceType": {
                "type": "string"
              },
              "ClientSubnets": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "SecurityGroups": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "Tags": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "CreateClusterResponse": {
        "type": "object",
        "properties": {
          "ClusterArn": {
            "type": "string"
          },
          "ClusterName": {
            "type": "string"
          },
          "State": {
            "type": "string"
          }
        }
      },
      "CreateConfigurationInput": {
        "type": "object",
        "required": [
          "Name",
          "ServerProperties"
        ],
        "properties": {
          "Name": {
            "type": "string"
          },
          "Description": {
            "type": "string"
          },
          "KafkaVersions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ServerProperties": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "InvalidParameter": {
            "type": "string"
          },
          "Message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "sigv4": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "AWS Signature Version 4"
      }
    }
  },
  "security": [
