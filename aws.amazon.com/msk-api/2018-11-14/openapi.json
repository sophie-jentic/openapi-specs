{
  "openapi": "3.0.3",
  "info": {
    "title": "Amazon Managed Streaming for Apache Kafka (MSK) API",
    "version": "2018-11-14",
    "description": "Amazon Managed Streaming for Apache Kafka (MSK) API for creating, managing, and monitoring Apache Kafka clusters on AWS. Includes cluster management, configuration, monitoring, replicators, and VPC connection management.",
    "x-jentic-source-url": "https://docs.aws.amazon.com/msk/1.0/apireference/what-is-msk.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://kafka.{region}.amazonaws.com",
      "variables": {
        "region": {
          "default": "us-east-1"
        }
      }
    }
  ],
