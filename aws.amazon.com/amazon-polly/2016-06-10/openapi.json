{
  "openapi": "3.0.3",
  "info": {
    "title": "Amazon Polly API",
    "version": "2016-06-10",
    "description": "Amazon Polly is a service that turns text into lifelike speech, allowing you to create applications that talk, and build entirely new categories of speech-enabled products. Polly's Text-to-Speech (TTS) service uses advanced deep learning technologies to synthesize natural sounding human speech. With dozens of lifelike voices across a broad set of languages, you can build speech-enabled applications that work in many different countries.",
    "x-jentic-source-url": "https://docs.aws.amazon.com/polly/latest/dg/what-is.html",
    "contact": {
      "name": "Amazon Web Services",
      "url": "https://aws.amazon.com/polly/"
    }
  },
  "servers": [
    {
      "url": "https://polly.{region}.amazonaws.com",
      "description": "Amazon Polly regional endpoint",
      "variables": {
        "region": {
          "default": "us-east-1",
          "description": "AWS region"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Voices",
      "description": "Operations for discovering available voices"
    },
    {
      "name": "Lexicons",
      "description": "Operations for managing pronunciation lexicons"
    },
    {
      "name": "Speech Synthesis",
      "description": "Operations for synthesizing speech from text"
    },
    {
      "name": "Synthesis Tasks",
      "description": "Operations for managing asynchronous speech synthesis tasks"
    }
  ],
  "security": [
    {
      "AWS4Auth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "AWS4Auth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "AWS Signature Version 4 authentication. The Authorization header contains the AWS access key ID, signature, signed headers, and other metadata."
      }
    },
    "schemas": {
      "Voice": {
        "type": "object",
        "properties": {
          "Gender": {
            "type": "string",
            "enum": [
              "Female",
              "Male"
            ],
            "description": "Gender of the voice."
          },
          "Id": {
            "type": "string",
            "description": "Amazon Polly assigned voice ID."
          },
          "LanguageCode": {
            "type": "string",
            "description": "Language code of the voice."
          },
          "LanguageName": {
            "type": "string",
            "description": "Human readable name of the language in English."
          },
          "Name": {
            "type": "string",
            "description": "Name of the voice."
          },
          "AdditionalLanguageCodes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Additional language codes this voice supports."
          },
          "SupportedEngines": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "standard",
                "neural",
                "long-form",
                "generative"
              ]
            },
            "description": "Specifies which engines are supported by a given voice."
          }
        }
      },
      "Lexicon": {
        "type": "object",
        "properties": {
          "Content": {
            "type": "string",
            "description": "Lexicon content in PLS format."
          },
          "Name": {
            "type": "string",
            "description": "Name of the lexicon."
          }
        }
      },
      "LexiconAttributes": {
        "type": "object",
        "properties": {
          "Alphabet": {
            "type": "string",
            "description": "Phonetic alphabet used in the lexicon (ipa or x-sampa)."
          },
          "LanguageCode": {
            "type": "string"
          },
          "LastModified": {
            "type": "string",
            "format": "date-time"
          },
          "LexemesCount": {
            "type": "integer",
            "description": "Number of lexemes in the lexicon."
          },
          "LexiconArn": {
            "type": "string",
            "description": "ARN of the lexicon."
          },
          "Size": {
            "type": "integer",
            "description": "Total size of the lexicon in characters."
          }
        }
      },
      "LexiconDescription": {
        "type": "object",
        "properties": {
          "Attributes": {
            "$ref": "#/components/schemas/LexiconAttributes"
          },
          "Name": {
            "type": "string"
          }
        }
      },
      "SynthesisTask": {
        "type": "object",
        "properties": {
          "CreationTime": {
            "type": "number",
            "description": "Timestamp when the task was created."
          },
          "Engine": {
            "type": "string",
            "enum": [
              "standard",
              "neural",
              "long-form",
              "generative"
            ]
          },
          "LanguageCode": {
            "type": "string"
          },
          "LexiconNames": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "OutputFormat": {
            "type": "string",
            "enum": [
              "json",
              "mp3",
              "ogg_vorbis",
              "pcm"
            ]
          },
          "OutputUri": {
            "type": "string",
            "description": "S3 URI where the output is stored."
          },
          "RequestCharacters": {
            "type": "integer"
          },
          "SampleRate": {
            "type": "string"
          },
          "SnsTopicArn": {
            "type": "string"
          },
          "SpeechMarkTypes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "sentence",
                "ssml",
                "viseme",
                "word"
              ]
            }
          },
          "TaskId": {
            "type": "string"
          },
          "TaskStatus": {
            "type": "string",
            "enum": [
              "scheduled",
              "inProgress",
              "completed",
              "failed"
            ]
          },
          "TaskStatusReason": {
            "type": "string"
          },
          "TextType": {
            "type": "string",
            "enum": [
              "ssml",
              "text"
            ]
          },
          "VoiceId": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "__type": {
            "type": "string",
            "description": "Error type identifier."
          },
          "message": {
            "type": "string",
            "description": "Error message."
          }
        }
      }
    }
  },
  "paths": {
    "/v1/voices": {
      "get": {
        "operationId": "describeVoices",
        "summary": "Describe available voices",
        "description": "Returns the list of voices that are available for use when requesting speech synthesis. Each voice speaks a specified language, is either male or female, and is identified by an ID.",
        "tags": [
          "Voices"
        ],
        "parameters": [
          {
            "name": "Engine",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "standard",
                "neural",
                "long-form",
                "generative"
              ]
            },
            "description": "Specifies the engine used to list voices."
          },
          {
            "name": "IncludeAdditionalLanguageCodes",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Boolean value indicating whether to return any bilingual voices that use the specified language as an additional language."
          },
          {
            "name": "LanguageCode",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The language identification tag for filtering the list of voices returned."
          },
          {
            "name": "NextToken",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 4096
            },
            "description": "An opaque pagination token returned from the previous request."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved voices list.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "NextToken": {
                      "type": "string"
                    },
                    "Voices": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Voice"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameter value.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid AWS credentials."
          }
        }
      }
    },
    "/v1/lexicons/{LexiconName}": {
      "get": {
        "operationId": "getLexicon",
        "summary": "Get a pronunciation lexicon",
        "description": "Returns the content of the specified pronunciation lexicon stored in an AWS Region.",
        "tags": [
          "Lexicons"
        ],
        "parameters": [
          {
            "name": "LexiconName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "[0-9A-Za-z]{1,20}"
            },
            "description": "Name of the lexicon."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved lexicon.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Lexicon": {
                      "$ref": "#/components/schemas/Lexicon"
                    },
                    "LexiconAttributes": {
                      "$ref": "#/components/schemas/LexiconAttributes"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Lexicon not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "putLexicon",
        "summary": "Store a pronunciation lexicon",
        "description": "Stores a pronunciation lexicon in an AWS Region. If a lexicon with the same name already exists, it is overwritten by the new lexicon.",
        "tags": [
          "Lexicons"
        ],
        "parameters": [
          {
            "name": "LexiconName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "[0-9A-Za-z]{1,20}"
            },
            "description": "Name of the lexicon. Must be an alphanumeric string, max 20 characters."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "Content"
                ],
                "properties": {
                  "Content": {
                    "type": "string",
                    "description": "Content of the PLS lexicon as a string."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lexicon stored successfully."
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          }
        }
      },
      "delete": {
        "operationId": "deleteLexicon",
        "summary": "Delete a pronunciation lexicon",
        "description": "Deletes the specified pronunciation lexicon stored in an AWS Region.",
        "tags": [
          "Lexicons"
        ],
        "parameters": [
          {
            "name": "LexiconName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "[0-9A-Za-z]{1,20}"
            },
            "description": "Name of the lexicon to delete."
          }
        ],
        "responses": {
          "200": {
            "description": "Lexicon deleted successfully."
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Lexicon not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/lexicons": {
      "get": {
        "operationId": "listLexicons",
        "summary": "List pronunciation lexicons",
        "description": "Returns a list of pronunciation lexicons stored in an AWS Region.",
        "tags": [
          "Lexicons"
        ],
        "parameters": [
          {
            "name": "NextToken",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 4096
            },
            "description": "An opaque pagination token returned from previous request."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved lexicons list.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Lexicons": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/LexiconDescription"
                      }
                    },
                    "NextToken": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          }
        }
      }
    },
    "/v1/speech": {
      "post": {
        "operationId": "synthesizeSpeech",
        "summary": "Synthesize speech",
        "description": "Synthesizes UTF-8 input, plain text or SSML, to a stream of bytes. SSML input must be valid, well-formed SSML.",
        "tags": [
          "Speech Synthesis"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "OutputFormat",
                  "Text",
                  "VoiceId"
                ],
                "properties": {
                  "Engine": {
                    "type": "string",
                    "enum": [
                      "standard",
                      "neural",
                      "long-form",
                      "generative"
                    ],
                    "description": "Specifies the engine for Amazon Polly to use."
                  },
                  "LanguageCode": {
                    "type": "string",
                    "description": "Optional language code for bilingual voices."
                  },
                  "LexiconNames": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "[0-9A-Za-z]{1,20}"
                    },
                    "maxItems": 5,
                    "description": "List of one or more pronunciation lexicon names."
                  },
                  "OutputFormat": {
                    "type": "string",
                    "enum": [
                      "json",
                      "mp3",
                      "ogg_vorbis",
                      "pcm"
                    ],
                    "description": "The format in which the returned output will be encoded."
                  },
                  "SampleRate": {
                    "type": "string",
                    "description": "Audio frequency specified in Hz."
                  },
                  "SpeechMarkTypes": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "sentence",
                        "ssml",
                        "viseme",
                        "word"
                      ]
                    },
                    "description": "The type of speech marks returned for the input text."
                  },
                  "Text": {
                    "type": "string",
                    "description": "Input text to synthesize."
                  },
                  "TextType": {
                    "type": "string",
                    "enum": [
                      "ssml",
                      "text"
                    ],
                    "description": "Specifies whether the input text is plain text or SSML."
                  },
                  "VoiceId": {
                    "type": "string",
                    "description": "Voice ID to use for the synthesis."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully synthesized speech.",
            "content": {
              "audio/mpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/x-json-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "audio/ogg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "audio/pcm": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            },
            "headers": {
              "Content-Type": {
                "schema": {
                  "type": "string"
                },
                "description": "The audio content type."
              },
              "x-amzn-RequestCharacters": {
                "schema": {
                  "type": "integer"
                },
                "description": "Number of characters synthesized."
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          }
        }
      }
    },
    "/v1/synthesisTasks": {
      "get": {
        "operationId": "listSpeechSynthesisTasks",
        "summary": "List speech synthesis tasks",
        "description": "Returns a list of SpeechSynthesisTask objects ordered by their creation date.",
        "tags": [
          "Synthesis Tasks"
        ],
        "parameters": [
          {
            "name": "MaxResults",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "description": "Maximum number of speech synthesis tasks returned."
          },
          {
            "name": "NextToken",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 4096
            },
            "description": "Pagination token."
          },
          {
            "name": "Status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "scheduled",
                "inProgress",
                "completed",
                "failed"
              ]
            },
            "description": "Status filter for tasks."
          }
        ],
        "responses": {
          "200": {
            "description": "List of synthesis tasks.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "NextToken": {
                      "type": "string"
                    },
                    "SynthesisTasks": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/SynthesisTask"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          }
        }
      },
      "post": {
        "operationId": "startSpeechSynthesisTask",
        "summary": "Start a speech synthesis task",
        "description": "Creates an asynchronous synthesis task to produce a speech output stored in an Amazon S3 bucket.",
        "tags": [
          "Synthesis Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "OutputFormat",
                  "OutputS3BucketName",
                  "Text",
                  "VoiceId"
                ],
                "properties": {
                  "Engine": {
                    "type": "string",
                    "enum": [
                      "standard",
                      "neural",
                      "long-form",
                      "generative"
                    ]
                  },
                  "LanguageCode": {
                    "type": "string"
                  },
                  "LexiconNames": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "maxItems": 5
                  },
                  "OutputFormat": {
                    "type": "string",
                    "enum": [
                      "json",
                      "mp3",
                      "ogg_vorbis",
                      "pcm"
                    ]
                  },
                  "OutputS3BucketName": {
                    "type": "string",
                    "description": "Amazon S3 bucket name for the output."
                  },
                  "OutputS3KeyPrefix": {
                    "type": "string",
                    "description": "The Amazon S3 key prefix for the output."
                  },
                  "SampleRate": {
                    "type": "string"
                  },
                  "SnsTopicArn": {
                    "type": "string",
                    "description": "ARN for the SNS topic to notify on task completion."
                  },
                  "SpeechMarkTypes": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "sentence",
                        "ssml",
                        "viseme",
                        "word"
                      ]
                    }
                  },
                  "Text": {
                    "type": "string",
                    "description": "The input text to synthesize."
                  },
                  "TextType": {
                    "type": "string",
                    "enum": [
                      "ssml",
                      "text"
                    ]
                  },
                  "VoiceId": {
                    "type": "string",
                    "description": "Voice ID to use."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "SynthesisTask": {
                      "$ref": "#/components/schemas/SynthesisTask"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          }
        }
      }
    },
    "/v1/synthesisTasks/{TaskId}": {
      "get": {
        "operationId": "getSpeechSynthesisTask",
        "summary": "Get a speech synthesis task",
        "description": "Retrieves a specific SpeechSynthesisTask object based on its TaskID.",
        "tags": [
          "Synthesis Tasks"
        ],
        "parameters": [
          {
            "name": "TaskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Amazon Polly generated identifier for the speech synthesis task."
          }
        ],
        "responses": {
          "200": {
            "description": "Task details retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "SynthesisTask": {
                      "$ref": "#/components/schemas/SynthesisTask"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Task not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}