                "type": "string",
                "format": "date-time"
              },
              "requestStatusCode": {
                "type": "object",
                "properties": {
                  "codeValue": {
                    "type": "string"
                  }
                }
              },
              "requestMethodCode": {
                "type": "object",
                "properties": {
                  "codeValue": {
                    "type": "string"
                  }
                }
              },
              "processMessages": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "messageTypeCode": {
                      "type": "object",
                      "properties": {
                        "codeValue": {
                          "type": "string"
                        }
                      }
                    },
                    "userMessage": {
