    "/routing/1/calculateRoute/{locations}/json": {
      "get": {
        "operationId": "calculateRoute",
        "summary": "Calculate Route",
        "description": "Calculates a route between an origin and destination, with optional waypoints.",
        "tags": [
          "Routing"
        ],
        "parameters": [
          {
            "name": "locations",
            "in": "path",
            "required": true,
            "description": "Colon-separated lat,lon pairs (e.g. 52.50931,13.42937:52.50274,13.43872)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "routeType",
            "in": "query",
            "required": false,
            "description": "Type of route",
            "schema": {
              "type": "string",
              "enum": [
                "fastest",
                "shortest",
                "eco",
                "thrilling"
              ]
            }
          },
          {
            "name": "traffic",
            "in": "query",
            "required": false,
            "description": "Consider current traffic",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "travelMode",
            "in": "query",
            "required": false,
            "description": "Mode of travel",
            "schema": {
              "type": "string",
              "enum": [
                "car",
                "truck",
                "taxi",
                "bus",
                "van",
                "motorcycle",
                "bicycle",
                "pedestrian"
              ]
            }
          },
          {
            "name": "avoid",
            "in": "query",
            "required": false,
            "description": "Things to avoid",
            "schema": {
              "type": "string",
              "enum": [
                "tollRoads",
                "motorways",
                "ferries",
                "unpavedRoads",
                "carpools"
              ]
            }
          },
          {
            "name": "departAt",
            "in": "query",
            "required": false,
            "description": "Departure time (ISO 8601)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "arriveAt",
            "in": "query",
            "required": false,
            "description": "Arrival time (ISO 8601)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "instructionsType",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "coded",
                "text",
                "tagged"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful route calculation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RouteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/routing/1/calculateReachableRange/{origin}/json": {
      "get": {
        "operationId": "calculateReachableRange",
        "summary": "Calculate Reachable Range",
        "description": "Calculates the set of locations reachable from the origin within given constraints (time, distance, or fuel budget).",
