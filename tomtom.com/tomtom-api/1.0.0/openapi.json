    "/traffic/services/5/incidentDetails": {
      "get": {
        "operationId": "getTrafficIncidents",
        "summary": "Traffic Incident Details",
        "description": "Returns details of traffic incidents within a specified bounding box.",
        "tags": [
          "Traffic"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bbox",
            "in": "query",
            "required": true,
            "description": "Bounding box as minLon,minLat,maxLon,maxLat",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "description": "Comma-separated fields to include",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "categoryFilter",
            "in": "query",
            "required": false,
            "description": "Comma-separated incident category IDs",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timeValidityFilter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
