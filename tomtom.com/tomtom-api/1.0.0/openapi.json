{
  "openapi": "3.0.3",
  "info": {
    "title": "TomTom API",
    "version": "1.0.0",
    "description": "TomTom provides location-based products including Maps, Search, Routing, and Traffic APIs for developers building applications that need mapping, geocoding, route planning, and real-time traffic data.",
    "x-jentic-source-url": "https://developer.tomtom.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.tomtom.com"
    }
  ],
  "paths": {
    "/search/2/search/{query}.json": {
      "get": {
        "operationId": "fuzzySearch",
        "summary": "Fuzzy Search",
        "description": "Performs a free-form text search for addresses, places, and points of interest (POI). Combines street address, POI, and geographic searches.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "path",
            "required": true,
            "description": "The search query string",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Your TomTom API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of results",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            }
          },
          {
            "name": "ofs",
            "in": "query",
            "required": false,
            "description": "Starting offset for results",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "lat",
            "in": "query",
            "required": false,
            "description": "Latitude for biasing results",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "lon",
            "in": "query",
            "required": false,
            "description": "Longitude for biasing results",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "required": false,
            "description": "Search radius in meters",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "countrySet",
            "in": "query",
            "required": false,
            "description": "Comma-separated ISO 3166-1 alpha-2 country codes to limit results",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "description": "Language for results (e.g. en-US)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "typeahead",
            "in": "query",
            "required": false,
            "description": "Enable typeahead mode for partial queries",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "categorySet",
            "in": "query",
            "required": false,
            "description": "Comma-separated POI category IDs",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search/2/geocode/{query}.json": {
      "get": {
        "operationId": "geocode",
        "summary": "Geocode",
        "description": "Converts a street address into geographic coordinates (latitude/longitude).",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "path",
            "required": true,
            "description": "Address to geocode",
