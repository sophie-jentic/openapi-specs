    "schemas": {
      "Invoice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "dueDate": {
            "type": "string",
            "format": "date"
          },
          "numberTemplate": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "prefix": {
                "type": "string"
              },
              "number": {
                "type": "string"
              }
            }
          },
          "client": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InvoiceItem"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "open",
              "closed",
              "void"
            ]
          },
          "total": {
            "type": "number"
          },
          "totalPaid": {
            "type": "number"
          },
          "balance": {
            "type": "number"
          },
          "currency": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "symbol": {
                "type": "string"
              }
            }
          }
        }
      },
      "InvoiceCreate": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "dueDate": {
            "type": "string",
            "format": "date"
          },
          "client": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              }
            },
            "required": [
              "id"
            ]
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InvoiceItemCreate"
            }
          },
          "observations": {
            "type": "string"
          },
          "anotation": {
            "type": "string"
          },
          "termsConditions": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "open"
            ]
          },
          "numberTemplate": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              }
            }
          }
        },
        "required": [
          "date",
          "dueDate",
          "client",
          "items"
