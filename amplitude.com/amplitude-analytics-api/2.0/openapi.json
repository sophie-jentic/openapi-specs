  "components": {
    "schemas": {
      "AmplitudeEvent": {
        "type": "object",
        "required": [
          "event_type"
        ],
        "properties": {
          "user_id": {
            "type": "string",
            "description": "A readable ID specified by you. Must be 5+ characters.",
            "minLength": 5
          },
          "device_id": {
