{
  "openapi": "3.0.3",
  "info": {
    "title": "Amplitude Analytics API",
    "version": "2.0",
    "description": "Amplitude's HTTP API for event tracking, user identification, and data export. Supports event ingestion, user property updates, and raw data export.",
    "x-jentic-source-url": "https://amplitude.com/docs/apis/analytics",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api2.amplitude.com",
      "description": "Standard server"
    },
    {
      "url": "https://api.eu.amplitude.com",
      "description": "EU residency server"
    }
  ],
  "tags": [
    {
      "name": "Events",
      "description": "Event tracking and ingestion"
    },
    {
      "name": "Identify",
      "description": "User identification and property management"
    },
    {
      "name": "Export",
      "description": "Data export"
    },
    {
      "name": "Batch",
      "description": "Batch event upload"
    }
  ],
  "paths": {
    "/2/httpapi": {
      "post": {
        "operationId": "trackEvents",
        "summary": "HTTP V2 API - Track Events",
        "description": "Send events to Amplitude. Supports single events and batches up to 2000 events per request. Request size must be under 1 MB.",
        "tags": [
          "Events"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HttpV2Request"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Events accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpV2Response"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid events or missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "Payload too large - request exceeds 1 MB or 2000 events"
          },
          "429": {
            "description": "Too many requests - rate limited"
          }
        }
      }
    },
    "/identify": {
      "post": {
        "operationId": "identifyUser",
        "summary": "Identify API - Set user properties",
        "description": "Set the User ID for a particular Device ID or update user properties without sending an event. Supports $set, $setOnce, $add, $append, $prepend, $unset, $preInsert, $postInsert, $remove operations.",
        "tags": [
          "Identify"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/IdentifyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing identification parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "414": {
            "description": "URI too long - use POST instead of GET"
          },
          "429": {
            "description": "Rate limited - too many updates for this device/user"
          }
        }
      }
    },
    "/batch": {
      "post": {
        "operationId": "batchUploadEvents",
        "summary": "Batch Event Upload API",
        "description": "Upload multiple events in a single batch request. Recommended for server-side event tracking.",
        "tags": [
          "Batch"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchUploadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Events accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpV2Response"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "Payload too large"
          },
          "429": {
            "description": "Rate limited"
          }
        }
      }
    },
    "/api/2/export": {
      "get": {
        "operationId": "exportEvents",
        "summary": "Export API - Export raw event data",
        "description": "Export project event data as a zipped archive of JSON files. Data is available for export at minimum 2 hours after server receipt. Max export period is 365 days. Size limit is 4GB.",
        "tags": [
          "Export"
        ],
        "servers": [
          {
            "url": "https://amplitude.com"
          }
        ],
        "parameters": [
          {
            "name": "start",
            "in": "query",
            "required": true,
            "description": "First hour included in data series, formatted YYYYMMDDTHH (e.g., 20220201T05)",
            "schema": {
              "type": "string",
              "pattern": "^\\d{8}T\\d{2}$"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "description": "Last hour included in data series, formatted YYYYMMDDTHH (e.g., 20220201T05)",
            "schema": {
              "type": "string",
              "pattern": "^\\d{8}T\\d{2}$"
            }
          }
        ],
        "security": [
          {
            "BasicAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Zipped archive of JSON files with one event per line",
            "content": {
              "application/zip": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Export file size exceeds 4GB limit"
          },
          "401": {
            "description": "Unauthorized - invalid API key or secret",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "No data available for the requested time range"
          },
          "504": {
            "description": "Timeout - data volume too large, use shorter time range"
          }
        }
      }
    },
