    "/api/2/events/segmentation": {
      "get": {
        "operationId": "getEventSegmentation",
        "summary": "Event Segmentation API",
        "description": "Get event segmentation data - metrics for an event with optional filters.",
        "tags": [
          "Events"
        ],
        "servers": [
          {
            "url": "https://amplitude.com"
          }
        ],
        "security": [
          {
            "BasicAuth": []
          }
        ],
        "parameters": [
          {
            "name": "e",
            "in": "query",
            "required": true,
            "description": "Event definition JSON",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "description": "Start date (YYYYMMDD)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "description": "End date (YYYYMMDD)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "m",
            "in": "query",
            "required": false,
            "description": "Metric type (uniques, totals, avg, etc.)",
            "schema": {
              "type": "string",
              "enum": [
                "uniques",
                "totals",
                "pct_dau",
                "average",
                "formula"
              ]
            }
          },
          {
            "name": "i",
            "in": "query",
            "required": false,
            "description": "Interval (1=daily, 7=weekly, 30=monthly, -300000=real-time)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "g",
            "in": "query",
            "required": false,
            "description": "Group by property",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Segmentation data",
