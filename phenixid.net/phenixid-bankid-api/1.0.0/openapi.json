{
  "openapi": "3.0.3",
  "info": {
    "title": "PhenixID BankID HTTP API",
    "version": "1.0.0",
    "description": "HTTP API for Swedish BankID authentication via PhenixID. Provides endpoints to trigger and check BankID authentication sessions.",
    "x-jentic-source-url": "https://document.phenixid.net/m/90910/l/1138959-using-phenixid-http-api-for-swedish-bankid-authentication",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{server}/api",
      "variables": {
        "server": {
          "default": "demo.phenixid.net"
        }
      }
    }
  ],
  "paths": {
    "/authentication/bankid_start_auth": {
      "put": {
        "operationId": "startBankIdAuth",
        "summary": "Trigger BankID Authentication",
        "description": "Initiates Swedish BankID authentication and returns a transaction ID for polling.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "tenant",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Tenant identifier"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartAuthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartAuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/authentication/bankid_check_auth": {
      "put": {
        "operationId": "checkBankIdAuth",
        "summary": "Poll BankID Authentication Status",
        "description": "Polls the status of an ongoing BankID authentication using the transaction ID.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "tenant",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Tenant identifier"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckAuthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckAuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StartAuthRequest": {
        "type": "object",
        "properties": {
          "pnr": {
            "type": "string",
            "description": "Personal ID number (12 digits)"
          },
          "userVisibleData": {
            "type": "string",
            "description": "Text displayed to user during authentication"
          }
        }
      },
      "StartAuthResponse": {
        "type": "object",
        "properties": {
          "transactionID": {
            "type": "string",
            "format": "uuid"
          },
          "autostarttoken": {
            "type": "string",
            "format": "uuid"
          },
          "qrStartSecret": {
            "type": "string",
            "format": "uuid"
          },
          "qrStartToken": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "CheckAuthRequest": {
        "type": "object",
        "required": [
          "transactionID"
        ],
        "properties": {
          "transactionID": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "CheckAuthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "OK",
              "PENDING",
              "USER_SIGN",
              "ERROR",
              "CANCELLED"
            ]
          },
          "personalNumber": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "givenName": {
            "type": "string"
          },
          "surName": {
            "type": "string"
          },
          "ocspResponse": {
            "type": "string"
          },
          "signature": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication"
    }
  ]
}
