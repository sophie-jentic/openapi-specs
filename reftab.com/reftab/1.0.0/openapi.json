          {
            "name": "status",
            "in": "query",
            "description": "Filter by asset status",
            "schema": {
              "type": "string",
              "enum": [
                "available",
                "checked_out",
                "maintenance",
                "retired"
              ]
            }
          },
          {
            "name": "categoryId",
            "in": "query",
            "description": "Filter by category ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "locationId",
            "in": "query",
            "description": "Filter by location ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
