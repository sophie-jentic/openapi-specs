{
  "openapi": "3.0.3",
  "info": {
    "title": "Exotel API",
    "version": "1.0.0",
    "description": "Exotel cloud communication platform API for voice calls, SMS, and campaign management.",
    "x-jentic-source-url": "https://developer.exotel.com/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.exotel.com/v1/Accounts/{account_sid}",
      "variables": {
        "account_sid": {
          "default": "your_sid",
          "description": "Your Exotel Account SID"
        }
      }
    },
    {
      "url": "https://api.in.exotel.com/v1/Accounts/{account_sid}",
      "variables": {
        "account_sid": {
          "default": "your_sid",
          "description": "Your Exotel Account SID (Mumbai region)"
        }
      }
    }
  ],
  "paths": {
    "/Calls/{CallSid}": {
      "get": {
        "operationId": "getCallDetails",
        "summary": "Get call details",
        "description": "Retrieve comprehensive call information including status, duration, pricing, and recording details.",
        "tags": [
          "Calls"
        ],
        "parameters": [
          {
            "name": "CallSid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique call identifier"
          },
          {
            "name": "details",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Include individual call leg statuses"
          },
          {
            "name": "RecordingUrlValidity",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 5,
              "maximum": 60
            },
            "description": "Pre-signed recording URL validity in minutes"
          }
        ],
        "responses": {
          "200": {
            "description": "Call details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Call"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/Sms/send": {
      "post": {
        "operationId": "sendSms",
        "summary": "Send SMS",
        "description": "Send an SMS to the specified number.",
        "tags": [
          "SMS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "From",
                  "To",
                  "Body"
                ],
                "properties": {
                  "From": {
                    "type": "string",
                    "description": "ExoPhone or Sender ID"
                  },
                  "To": {
                    "type": "string",
                    "description": "Mobile number in E.164 format"
                  },
                  "Body": {
                    "type": "string",
                    "description": "SMS content, max 2000 chars"
                  },
                  "EncodingType": {
                    "type": "string",
                    "enum": [
                      "plain",
                      "unicode"
                    ]
                  },
                  "ShortenUrl": {
                    "type": "boolean"
                  },
                  "StatusCallback": {
                    "type": "string",
                    "format": "uri"
                  },
                  "DltEntityId": {
                    "type": "string"
                  },
                  "DltTemplateId": {
                    "type": "string"
                  },
                  "Priority": {
                    "type": "string",
                    "enum": [
                      "normal",
                      "high"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SmsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/SMS/Messages/{SmsSid}": {
      "get": {
        "operationId": "getSmsDetails",
        "summary": "Get SMS details",
        "description": "Retrieve status and details of a previously sent SMS.",
        "tags": [
          "SMS"
        ],
        "parameters": [
          {
            "name": "SmsSid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SMS details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SmsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/Sms/bulksend": {
      "post": {
        "operationId": "sendBulkSmsDynamic",
        "summary": "Send bulk SMS with dynamic content",
        "description": "Send different SMS messages to different numbers. Max 100 per request.",
        "tags": [
          "SMS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "Messages"
                ],
                "properties": {
                  "Messages": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "To": {
                          "type": "string"
                        },
                        "Body": {
                          "type": "string"
                        },
                        "From": {
                          "type": "string"
                        },
                        "SmsType": {
                          "type": "string"
                        },
                        "DltTemplateId": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "EncodingType": {
                    "type": "string",
                    "enum": [
                      "plain",
                      "unicode"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk SMS sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Call": {
        "type": "object",
        "properties": {
          "Sid": {
            "type": "string"
          },
          "AccountSid": {
            "type": "string"
          },
          "Status": {
            "type": "string",
            "enum": [
              "queued",
              "ringing",
              "in-progress",
              "completed",
              "busy",
              "failed",
              "no-answer",
              "canceled"
            ]
          },
          "Duration": {
            "type": "integer"
          },
          "Price": {
            "type": "number"
          },
          "RecordingUrl": {
            "type": "string"
          },
          "DateCreated": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SmsResponse": {
        "type": "object",
        "properties": {
          "SMSMessage": {
            "type": "object",
            "properties": {
              "Sid": {
                "type": "string"
              },
              "AccountSid": {
                "type": "string"
              },
              "Status": {
                "type": "string"
              },
              "From": {
                "type": "string"
              },
              "To": {
                "type": "string"
              },
              "Body": {
                "type": "string"
              },
              "DateCreated": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Auth with API Key as username and API Token as password"
      }
    }
  },
  "security": [
    {
      "BasicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Calls"
    },
    {
      "name": "SMS"
    }
  ]
}
