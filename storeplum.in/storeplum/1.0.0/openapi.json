{
  "openapi": "3.0.3",
  "info": {
    "title": "Storeplum API",
    "description": "Storeplum API for managing products, webhooks, and e-commerce operations",
    "version": "1.0.0",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.storeplum.in"
    },
    {
      "url": "https://api.dashboard.storeplum.in"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-SP-INTEGRATION",
        "description": "API key for Storeplum integration"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/integration/action/product/save": {
      "post": {
        "summary": "Create or update product",
        "description": "Create or save a product in Storeplum",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Product name"
                  },
                  "description": {
                    "type": "string",
                    "description": "Product description"
                  },
                  "price": {
                    "type": "number",
                    "format": "double",
                    "description": "Product price with two decimal places"
                  },
                  "sku": {
                    "type": "string",
                    "description": "Stock keeping unit"
                  },
                  "customerCode": {
                    "type": "string",
                    "description": "Storeplum customer code from dashboard"
                  },
                  "platform": {
                    "type": "string",
                    "description": "Integration app name (e.g., zapier, pabbly)"
                  }
                },
                "required": [
                  "customerCode",
                  "platform"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product saved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "Product ID"
                    }
                  }
                }
              }
            }
          }
        },
        "servers": [
          {
            "url": "https://api.storeplum.in"
          }
        ],
        "tags": [
          "integration"
        ],
        "operationId": "post-integration-action-product-save"
      }
    },
    "/integration/subscribe": {
      "post": {
        "summary": "Register webhooks",
        "description": "Register webhooks for various events like new customer, new product, new order, and order shipped",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerCode": {
                    "type": "string",
                    "description": "Storeplum customer code from dashboard"
                  },
                  "platform": {
                    "type": "string",
                    "description": "Integration app name (e.g., zapier, pabbly)"
                  },
                  "hookUrl": {
                    "type": "string",
                    "format": "uri",
                    "description": "HTTPS webhook URL (HTTP URLs will be rejected)"
                  },
                  "triggerType": {
                    "type": "string",
                    "enum": [
                      "new_customer",
                      "new_product",
                      "new_order",
                      "order_shipped"
                    ],
                    "description": "Type of event to trigger the webhook"
                  }
                },
                "required": [
                  "customerCode",
                  "platform",
                  "hookUrl",
                  "triggerType"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook registered successfully"
          }
        },
        "servers": [
          {
            "url": "https://api.dashboard.storeplum.in"
          }
        ],
        "tags": [
          "integration"
        ],
        "operationId": "post-integration-subscribe"
      }
    }
  },
  "tags": [
    {
      "name": "integration"
    }
  ]
}
