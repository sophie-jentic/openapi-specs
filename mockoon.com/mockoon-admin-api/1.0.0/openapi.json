{
  "openapi": "3.0.3",
  "info": {
    "title": "Mockoon Admin API",
    "version": "1.0.0",
    "description": "Mockoon Admin API allows you to manage running mock server environments. Each running mock server exposes an admin API at /mockoon-admin that enables state management, global/environment variables, transaction logs, data buckets, and real-time event subscriptions via SSE.",
    "x-jentic-source-url": "https://mockoon.com/docs/latest/admin-api/overview/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000/mockoon-admin",
      "description": "Mockoon Admin API (default port)"
    }
  ],
  "paths": {
    "/state/purge": {
      "post": {
        "operationId": "purgeState",
        "summary": "Purge environment state",
        "description": "Resets the request counter, regenerates data buckets, clears global variables, and clears transaction logs for the running environment.",
        "tags": [
          "Server State"
        ],
        "responses": {
          "200": {
            "description": "State purged successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/global-vars/{key}": {
      "get": {
        "operationId": "getGlobalVariable",
        "summary": "Get a global variable value",
        "description": "Returns the value of a specific global variable by key.",
        "tags": [
          "Global Variables"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "description": "The name of the global variable",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GlobalVariable"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Variable not found"
          }
        }
      }
    },
    "/global-vars": {
      "post": {
        "operationId": "setGlobalVariable",
        "summary": "Set or update a global variable",
        "description": "Creates or updates a global variable with the specified key and value.",
        "tags": [
          "Global Variables"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GlobalVariableInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Variable set successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/global-vars/purge": {
      "post": {
        "operationId": "purgeGlobalVariables",
        "summary": "Delete all global variables",
        "description": "Removes all global variables from the running environment.",
        "tags": [
          "Global Variables"
        ],
        "responses": {
          "200": {
            "description": "Global variables purged successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/env-vars/{key}": {
      "get": {
        "operationId": "getEnvironmentVariable",
        "summary": "Get an environment variable value",
        "description": "Returns the value of a specific environment variable by key, with or without the MOCKOON_ prefix.",
        "tags": [
          "Environment Variables"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "description": "The name of the environment variable (with or without MOCKOON_ prefix)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnvironmentVariable"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Variable not found"
          }
        }
      }
    },
    "/env-vars": {
      "post": {
        "operationId": "setEnvironmentVariable",
        "summary": "Set or update an environment variable",
        "description": "Creates or updates an environment variable. The key should include the MOCKOON_ prefix or custom prefix.",
        "tags": [
          "Environment Variables"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EnvironmentVariableInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Variable set successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/logs": {
      "get": {
        "operationId": "getTransactionLogs",
        "summary": "Retrieve transaction logs",
        "description": "Returns paginated transaction logs including request and response details.",
        "tags": [
          "Transaction Logs"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number to retrieve",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of logs to retrieve per page",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TransactionLog"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/logs/purge": {
      "post": {
        "operationId": "purgeTransactionLogs",
        "summary": "Purge transaction logs",
        "description": "Clears all transaction logs for the running environment.",
        "tags": [
          "Transaction Logs"
        ],
        "responses": {
          "200": {
            "description": "Logs purged successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/data-buckets": {
      "get": {
        "operationId": "listDataBuckets",
        "summary": "Get data buckets status",
        "description": "Returns the status of all data buckets without their values.",
        "tags": [
          "Data Buckets"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DataBucketStatus"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/data-buckets/{nameOrId}": {
      "get": {
        "operationId": "getDataBucket",
        "summary": "Get a data bucket value",
        "description": "Returns the value of a specific data bucket by its name or unique ID.",
        "tags": [
          "Data Buckets"
        ],
        "parameters": [
          {
            "name": "nameOrId",
            "in": "path",
            "required": true,
            "description": "Name or unique ID of the data bucket",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataBucketValue"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Data bucket not found"
          }
        }
      }
    },
    "/data-buckets/purge": {
      "post": {
        "operationId": "resetDataBuckets",
        "summary": "Reset data buckets",
        "description": "Resets all data buckets to their initial state.",
        "tags": [
          "Data Buckets"
        ],
        "responses": {
          "200": {
            "description": "Data buckets reset successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/events": {
      "get": {
        "operationId": "subscribeToEvents",
        "summary": "Subscribe to server-sent events",
        "description": "Opens an SSE connection to receive real-time events including transaction-complete and data-bucket-processed events.",
        "tags": [
          "Events"
        ],
        "parameters": [
          {
            "name": "maxlogs",
            "in": "query",
            "required": false,
            "description": "Maximum number of logs to retrieve upon connection",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SSE stream opened successfully",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GlobalVariable": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Variable name"
          },
          "value": {
            "type": "string",
            "description": "Variable value"
          }
        }
      },
      "GlobalVariableInput": {
        "type": "object",
        "required": [
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string",
            "description": "Variable name"
          },
          "value": {
            "type": "string",
            "description": "Variable value"
          }
        }
      },
      "EnvironmentVariable": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Variable name (with prefix)"
          },
          "value": {
            "type": "string",
            "description": "Variable value"
          }
        }
      },
      "EnvironmentVariableInput": {
        "type": "object",
        "required": [
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string",
            "description": "Variable name (including MOCKOON_ prefix)"
          },
          "value": {
            "type": "string",
            "description": "Variable value"
          }
        }
      },
      "TransactionLog": {
        "type": "object",
        "properties": {
          "request": {
            "type": "object",
            "properties": {
              "method": {
                "type": "string"
              },
              "urlPath": {
                "type": "string"
              },
              "route": {
                "type": "string"
              },
              "params": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    }
                  }
                }
              },
              "query": {
                "type": "string"
              },
              "queryParams": {
                "type": "object"
              },
              "body": {
                "type": "string"
              },
              "headers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "key": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "response": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "statusMessage": {
                "type": "string"
              },
              "headers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "key": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    }
                  }
                }
              },
              "body": {
                "type": "string"
              }
            }
          },
          "routeResponseUUID": {
            "type": "string"
          },
          "routeUUID": {
            "type": "string"
          },
          "proxied": {
            "type": "boolean"
          },
          "timestampMs": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "DataBucketStatus": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique ID of the data bucket"
          },
          "name": {
            "type": "string",
            "description": "Name of the data bucket"
          },
          "parsed": {
            "type": "boolean",
            "description": "Whether the data bucket has been parsed"
          },
          "validJson": {
            "type": "boolean",
            "description": "Whether the content is valid JSON"
          }
        }
      },
      "DataBucketValue": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "value": {
            "type": "object",
            "description": "The data bucket value as a JSON object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Data Buckets"
    },
    {
      "name": "Environment Variables"
    },
    {
      "name": "Events"
    },
    {
      "name": "Global Variables"
    },
    {
      "name": "Server State"
    },
    {
      "name": "Transaction Logs"
    }
  ]
}
