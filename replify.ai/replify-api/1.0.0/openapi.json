{
  "openapi": "3.0.3",
  "info": {
    "title": "Replify.ai API",
    "version": "1.0.0",
    "description": "Replify.ai Campaign Service API allows you to manage campaign contacts programmatically. The API uses bearer token authentication obtained via OAuth2.",
    "x-jentic-source-url": "https://docs.replify.ai/api-reference/campaigns/manage-campaign-contacts",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.heylibby.com/api/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/campaigns/{campaignId}/contacts": {
      "post": {
        "operationId": "manageCampaignContacts",
        "summary": "Create, update, or remove campaign contacts",
        "description": "Creates or updates contacts in a campaign, or removes specific contacts when the action is set to 'remove'.",
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "campaignId",
            "in": "path",
            "description": "The unique campaign identifier (UUID format)",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManageContactsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contacts processed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ManageContactsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request (bad JSON, missing fields)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - missing or invalid API key, unauthorized access",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Campaign not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Contact": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "description": "Contact's first name"
          },
          "lastName": {
            "type": "string",
            "description": "Contact's last name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact email address"
          },
          "phone": {
            "type": "string",
            "description": "Contact phone number"
          },
          "status": {
            "type": "string",
            "description": "Contact status"
          },
          "contactMetadata": {
            "type": "object",
            "description": "Additional metadata for the contact"
          }
        }
      },
      "ManageContactsRequest": {
        "type": "object",
        "required": [
          "contacts"
        ],
        "properties": {
          "contacts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contact"
            },
            "description": "Array of contact objects to create, update, or remove"
          },
          "action": {
            "type": "string",
            "enum": [
              "remove"
            ],
            "description": "Set to 'remove' to delete contacts; omit to create/update"
          }
        }
      },
      "ManageContactsResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Summary of operation results"
          },
          "success": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "contact": {
                  "$ref": "#/components/schemas/Contact"
                },
                "action": {
                  "type": "string",
                  "enum": [
                    "created",
                    "updated"
                  ]
                }
              }
            },
            "description": "Array of successfully processed contacts"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "contact": {
                  "$ref": "#/components/schemas/Contact"
                },
                "reason": {
                  "type": "string"
                }
              }
            },
            "description": "Array of failed contacts with error reasons"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for authentication"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Campaigns"
    }
  ]
}
