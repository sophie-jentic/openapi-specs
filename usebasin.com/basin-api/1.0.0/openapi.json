    "/forms": {
      "get": {
        "tags": [
          "Forms"
        ],
        "summary": "List Forms",
        "operationId": "listForms",
        "description": "Returns a list of all forms associated with the authenticated account.",
        "responses": {
          "200": {
            "description": "List of forms"
          }
        }
      }
    },
    "/forms/{form_id}": {
      "get": {
        "tags": [
          "Forms"
        ],
        "summary": "Get Form",
        "operationId": "getForm",
        "description": "Returns details for a specific form.",
        "parameters": [
          {
            "name": "form_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Form details"
          }
        }
      }
    },
