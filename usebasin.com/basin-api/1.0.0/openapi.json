  "info": {
    "title": "Basin API",
    "version": "1.0.0",
    "description": "Basin is a form backend service that collects form submissions via simple HTML forms or API calls. The API allows you to manage forms, retrieve submissions, create and manage spam filters, configure email notifications, webhooks, and autoresponders.",
