{
  "openapi": "3.0.3",
  "info": {
    "title": "Hirak Translation API",
    "description": "Translation API that supports translating text between 21 of the most used languages.",
    "version": "1.0.0",
    "contact": {
      "name": "Hirak Translation",
      "url": "https://translate.hirak.site/"
    }
  },
  "servers": [
    {
      "url": "https://translate.hirak.site/api"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/translate": {
      "post": {
        "operationId": "translateText",
        "summary": "Translate text",
        "description": "Translates the provided text from a source language to a target language. Supports 21 of the most commonly used languages.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text",
                  "target"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "The text to translate."
                  },
                  "source": {
                    "type": "string",
                    "description": "Source language code (e.g., 'en', 'fr'). If not specified, the language will be auto-detected.",
                    "example": "en"
                  },
                  "target": {
                    "type": "string",
                    "description": "Target language code to translate to (e.g., 'fr', 'de', 'es').",
                    "example": "fr"
                  }
                }
              },
              "example": {
                "text": "Hello, how are you?",
                "source": "en",
                "target": "fr"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful translation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslationResponse"
                },
                "example": {
                  "status": "success",
                  "translated_text": "Bonjour, comment allez-vous?",
                  "source_language": "en",
                  "target_language": "fr"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid parameters or unsupported language"
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "422": {
            "description": "Unprocessable entity - Unable to translate the provided text"
          }
        },
        "tags": [
          "translate"
        ]
      }
    },
    "/languages": {
      "get": {
        "operationId": "listSupportedLanguages",
        "summary": "List supported languages",
        "description": "Returns the list of 21 supported languages available for translation.",
        "responses": {
          "200": {
            "description": "List of supported languages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Language"
                  }
                },
                "example": [
                  {
                    "code": "en",
                    "name": "English"
                  },
                  {
                    "code": "fr",
                    "name": "French"
                  },
                  {
                    "code": "es",
                    "name": "Spanish"
                  },
                  {
                    "code": "de",
                    "name": "German"
                  }
                ]
              }
            }
          }
        },
        "tags": [
          "languages"
        ]
      }
    },
    "/detect": {
      "post": {
        "operationId": "detectLanguage",
        "summary": "Detect language of text",
        "description": "Detects the language of the provided text from the 21 supported languages.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "The text to detect the language of."
                  }
                }
              },
              "example": {
                "text": "Bonjour, comment allez-vous?"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful language detection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetectionResponse"
                },
                "example": {
                  "status": "success",
                  "language": "fr",
                  "confidence": 98.5
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid or empty text"
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        },
        "tags": [
          "detect"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication."
      }
    },
    "schemas": {
      "TranslationResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Status of the translation operation.",
            "enum": [
              "success",
              "error"
            ]
          },
          "translated_text": {
            "type": "string",
            "description": "The translated text."
          },
          "source_language": {
            "type": "string",
            "description": "Source language code."
          },
          "target_language": {
            "type": "string",
            "description": "Target language code."
          }
        }
      },
      "DetectionResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Status of the detection operation.",
            "enum": [
              "success",
              "error"
            ]
          },
          "language": {
            "type": "string",
            "description": "Detected language code."
          },
          "confidence": {
            "type": "number",
            "format": "double",
            "description": "Confidence score of the detection (0-100)."
          }
        }
      },
      "Language": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Language code."
          },
          "name": {
            "type": "string",
            "description": "Language name."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "detect"
    },
    {
      "name": "languages"
    },
    {
      "name": "translate"
    }
  ]
}
