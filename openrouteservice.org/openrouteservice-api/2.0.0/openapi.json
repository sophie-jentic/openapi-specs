  "components": {
    "schemas": {
      "DirectionsRequest": {
        "type": "object",
        "required": [
          "coordinates"
        ],
        "properties": {
          "coordinates": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "number"
              },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "preference": {
            "type": "string",
            "enum": [
              "fastest",
              "shortest",
              "recommended"
            ]
          },
          "units": {
            "type": "string",
            "enum": [
              "m",
              "km",
              "mi"
            ]
          },
          "language": {
            "type": "string"
          },
          "geometry": {
            "type": "boolean",
            "default": true
          },
          "instructions": {
            "type": "boolean",
            "default": true
          },
          "elevation": {
            "type": "boolean",
            "default": false
          },
          "alternatives": {
            "type": "integer",
            "default": 0
          },
          "roundabout_exits": {
            "type": "boolean",
            "default": false
          },
          "attributes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "radiuses": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "bearings": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "number"
              }
            }
          }
        }
      },
      "DirectionsResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "features": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "bbox": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                },
                "properties": {
                  "type": "object",
                  "properties": {
                    "summary": {
                      "type": "object",
                      "properties": {
                        "distance": {
                          "type": "number"
                        },
                        "duration": {
                          "type": "number"
                        }
                      }
                    },
                    "segments": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "way_points": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      }
                    }
                  }
                },
                "geometry": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string"
                    },
                    "coordinates": {
                      "type": "array",
                      "items": {
                        "type": "array",
                        "items": {
                          "type": "number"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "bbox": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "IsochronesRequest": {
        "type": "object",
        "required": [
          "locations",
          "range"
        ],
        "properties": {
          "locations": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "number"
              }
            }
          },
          "range": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "range_type": {
            "type": "string",
            "enum": [
              "time",
              "distance"
            ]
          },
          "interval": {
            "type": "number"
          },
          "units": {
            "type": "string",
            "enum": [
              "m",
              "km",
              "mi"
            ]
          },
          "location_type": {
            "type": "string",
            "enum": [
              "start",
              "destination"
            ]
          },
          "attributes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "IsochronesResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "features": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "bbox": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "MatrixRequest": {
        "type": "object",
        "required": [
          "locations"
        ],
        "properties": {
          "locations": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "number"
              }
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "destinations": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "metrics": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "distance",
                "duration"
              ]
            }
          },
          "units": {
            "type": "string",
            "enum": [
              "m",
              "km",
              "mi"
            ]
          },
          "resolve_locations": {
            "type": "boolean",
            "default": false
          }
