{
  "openapi": "3.0.3",
  "info": {
    "title": "Kontent.ai Delivery API",
    "version": "1.0.0",
    "description": "Kontent.ai headless CMS Delivery REST API for retrieving published content items, content types, languages, and taxonomy groups.",
    "x-jentic-source-url": "https://kontent.ai/learn/docs/apis/delivery-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://deliver.kontent.ai/{environment_id}",
      "variables": {
        "environment_id": {
          "default": "your-environment-id",
          "description": "Your Kontent.ai environment ID"
        }
      }
    }
  ],
  "paths": {
    "/items": {
      "get": {
        "operationId": "listContentItems",
        "summary": "List content items",
        "tags": [
          "Content Items"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List content items"
      }
    },
    "/items/{codename}": {
      "get": {
        "operationId": "getContentItem",
        "summary": "Get content item",
        "tags": [
          "Content Items"
        ],
