    "/messages": {
      "get": {
        "operationId": "getMessages",
        "summary": "Get messages",
        "description": "Returns incoming and outgoing messages from the queue.",
        "tags": [
          "Messaging"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lastMessageNumber",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Get messages after this message number"
          },
          {
            "name": "last",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "If true, return only the last message"
          },
          {
            "name": "chatId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by chat ID"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Maximum number of messages to return"
          },
          {
            "name": "min_time",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Minimum message timestamp"
          },
          {
            "name": "max_time",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Maximum message timestamp"
          }
        ],
        "responses": {
          "200": {
            "description": "Messages retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessagesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
