    "/checkPhone": {
      "post": {
        "operationId": "checkPhone",
        "summary": "Check phone number",
        "description": "Checks if a phone number is registered on WhatsApp.",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phone"
                ],
                "properties": {
                  "phone": {
                    "type": "string",
                    "description": "Phone number to check (with country code)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phone check result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "string",
                      "enum": [
                        "exists",
                        "not exists"
                      ]
                    },
                    "chatId": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
