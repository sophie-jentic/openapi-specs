{
  "openapi": "3.0.3",
  "info": {
    "title": "Listnr Text-to-Speech API",
    "version": "1.0.0",
    "description": "Listnr API for converting text to speech, URL-based article conversion, and voice management.",
    "x-jentic-source-url": "https://github.com/team-listnr/text-to-speech-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://bff.listnr.tech/api/tts/v1"
    }
  ],
  "paths": {
    "/convert-text": {
      "post": {
        "operationId": "convertText",
        "summary": "Convert text to speech",
        "tags": [
          "TTS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TTSRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audio result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TTSResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Convert text to speech"
      }
    },
    "/convert-text-async": {
      "post": {
        "operationId": "convertTextAsync",
        "summary": "Convert text to speech (async)",
        "tags": [
          "TTS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TTSRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Async job created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsyncJobResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Convert text to speech (async)"
      }
    },
    "/convert-text-with-timestamps": {
      "post": {
        "operationId": "convertTextWithTimestamps",
        "summary": "Convert text to speech with word-level timestamps",
        "tags": [
          "TTS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TTSRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audio with timestamps",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Convert text to speech with word-level timestamps"
      }
    },
    "/convert-url": {
      "post": {
        "operationId": "convertUrl",
        "summary": "Convert article URL to audio",
        "tags": [
          "TTS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "voice": {
                    "type": "string"
                  }
                },
                "required": [
                  "url",
                  "voice"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audio result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TTSResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Convert article URL to audio"
      }
    },
    "/convert-url-async": {
      "post": {
        "operationId": "convertUrlAsync",
        "summary": "Convert article URL to audio (async)",
        "tags": [
          "TTS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "voice": {
                    "type": "string"
                  }
                },
                "required": [
                  "url",
                  "voice"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Async job created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsyncJobResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Convert article URL to audio (async)"
      }
    },
    "/available-voices": {
      "get": {
        "operationId": "listAvailableVoices",
        "summary": "List available voices",
        "tags": [
          "Voices"
        ],
        "responses": {
          "200": {
            "description": "List of voices",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Voice"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List available voices"
      }
    },
    "/job-status": {
      "get": {
        "operationId": "getJobStatus",
        "summary": "Check async job status",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "audioUrl": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Check async job status"
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "TTSRequest": {
        "type": "object",
        "properties": {
          "voice": {
            "type": "string",
            "description": "Voice identifier"
          },
          "ssml": {
            "type": "string",
            "description": "Text in SSML format"
          },
          "voiceStyle": {
            "type": "string"
          },
          "globalSpeed": {
            "type": "string"
          },
          "audioFormat": {
            "type": "string"
          },
          "audioSampleRate": {
            "type": "string"
          }
        },
        "required": [
          "voice",
          "ssml"
        ]
      },
      "TTSResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "audioUrl": {
            "type": "string"
          },
          "audioKey": {
            "type": "string"
          }
        }
      },
      "AsyncJobResponse": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string"
          },
          "audioKey": {
            "type": "string"
          }
        }
      },
      "Voice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "gender": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-listnr-token"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Jobs"
    },
    {
      "name": "TTS"
    },
    {
      "name": "Voices"
    }
  ]
}
