    "/route/distance": {
      "get": {
        "operationId": "getRouteDistance",
        "summary": "Get route distance and duration",
        "description": "Calculates distance and estimated travel time between an origin and destination.",
        "tags": [
          "Routing"
        ],
        "parameters": [
          {
            "name": "origin",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Origin coordinates (lat,lng)"
          },
          {
            "name": "destination",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Destination coordinates (lat,lng)"
          },
          {
            "name": "modes",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "foot",
                "bike",
                "car",
                "truck",
                "transit"
              ]
            },
            "description": "Travel mode"
          },
          {
            "name": "units",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "imperial",
                "metric"
              ],
              "default": "imperial"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Route distance",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RouteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
