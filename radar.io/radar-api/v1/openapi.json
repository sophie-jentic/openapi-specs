{
  "openapi": "3.0.3",
  "info": {
    "title": "Radar API",
    "version": "v1",
    "description": "Radar location infrastructure API for tracking, geocoding, search, routing, geofencing, and fraud detection. Use as building blocks for location-based products.",
    "x-jentic-source-url": "https://radar.com/documentation/api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.radar.io/v1"
    }
  ],
  "paths": {
    "/track": {
      "post": {
        "operationId": "trackLocation",
        "summary": "Track a location update",
        "description": "Tracks a user location update. Returns the user and events generated based on project settings.",
        "tags": [
          "Track"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "deviceId",
                  "latitude",
                  "longitude",
                  "accuracy"
                ],
                "properties": {
                  "deviceId": {
                    "type": "string",
                    "description": "Device ID for the user"
                  },
                  "userId": {
                    "type": "string",
                    "description": "Stable unique user ID"
                  },
                  "latitude": {
                    "type": "number",
                    "minimum": -90,
                    "maximum": 90
                  },
                  "longitude": {
                    "type": "number",
                    "minimum": -180,
                    "maximum": 180
                  },
                  "accuracy": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Location accuracy in meters"
                  },
                  "foreground": {
                    "type": "boolean"
                  },
                  "stopped": {
                    "type": "boolean"
                  },
                  "description": {
                    "type": "string"
                  },
                  "metadata": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "deviceType": {
                    "type": "string",
                    "enum": [
                      "iOS",
                      "Android",
                      "Web"
                    ]
                  },
                  "updatedAt": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tracking response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/geocode/forward": {
      "get": {
        "operationId": "forwardGeocode",
        "summary": "Forward geocode",
        "description": "Converts an address to coordinates.",
        "tags": [
          "Geocoding"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Address to geocode"
          },
          {
            "name": "layers",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated layer filters (place, address, postalCode, locality, county, state, country, coarse, fine)"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated country codes filter"
          },
          {
            "name": "lang",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "ar",
                "de",
                "en",
                "es",
                "fr",
                "ja",
                "ko",
                "pt",
                "ru",
                "zh"
              ],
              "default": "en"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Geocoding results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeocodeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
