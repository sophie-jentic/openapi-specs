{
  "openapi": "3.0.3",
  "info": {
    "title": "KEYVOX API",
    "description": "KEYVOX API for smart lock, smart locker, and reservation management for accommodations, rental spaces, and coworking facilities",
    "version": "1.0.0",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://eco.blockchainlock.io/api/eagle-pms"
    }
  ],
  "components": {
    "securitySchemes": {
      "HmacSignature": {
        "type": "apiKey",
        "in": "header",
        "name": "authorization",
        "description": "HMAC-SHA256 signature authentication"
      }
    },
    "parameters": {
      "XTargetHost": {
        "name": "x-target-host",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "default": "default.pms"
        },
        "description": "Target host header (fixed value)"
      },
      "Date": {
        "name": "date",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "RFC-1123 format date (e.g., Mon, 20 Sep 2021 13:16:39 GMT)"
      },
      "Digest": {
        "name": "digest",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "SHA-256 hash of request body (base64 encoded)"
      }
    }
  },
  "security": [
    {
      "HmacSignature": []
    }
  ],
  "paths": {
    "/v1/getUnits": {
      "post": {
        "summary": "Retrieve room/door list",
        "description": "Get list of units (rooms/doors) for smart locks",
        "tags": [
          "Smart Lock"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/XTargetHost"
          },
          {
            "$ref": "#/components/parameters/Date"
          },
          {
            "$ref": "#/components/parameters/Digest"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of units retrieved successfully"
          }
        },
        "operationId": "post-v1-getunits"
      }
    },
    "/v1/createLockPin": {
      "post": {
        "summary": "Issue PIN/QR code",
        "description": "Create PIN or QR code for smart lock access",
        "tags": [
          "Smart Lock"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/XTargetHost"
          },
          {
            "$ref": "#/components/parameters/Date"
          },
          {
            "$ref": "#/components/parameters/Digest"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PIN/QR code created successfully"
          }
        },
        "operationId": "post-v1-createlockpin"
      }
    },
    "/v1/unlock": {
      "post": {
        "summary": "Lock/unlock control",
        "description": "Control smart lock to lock or unlock",
        "tags": [
          "Smart Lock"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/XTargetHost"
          },
          {
            "$ref": "#/components/parameters/Date"
          },
          {
            "$ref": "#/components/parameters/Digest"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lock operation completed successfully"
          }
        },
        "operationId": "post-v1-unlock"
      }
    },
    "/v1/locks/events": {
      "post": {
        "summary": "Get lock event history",
        "description": "Retrieve historical lock events",
        "tags": [
          "Smart Lock"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/XTargetHost"
          },
          {
            "$ref": "#/components/parameters/Date"
          },
          {
            "$ref": "#/components/parameters/Digest"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lock event history retrieved"
          }
        },
        "operationId": "post-v1-locks-events"
      }
    },
    "/v1/getLockers": {
      "post": {
        "summary": "Retrieve locker devices",
        "description": "Get list of smart locker devices",
        "tags": [
          "Smart Locker"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/XTargetHost"
          },
          {
            "$ref": "#/components/parameters/Date"
          },
          {
            "$ref": "#/components/parameters/Digest"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Locker list retrieved successfully"
          }
        },
        "operationId": "post-v1-getlockers"
      }
    },
    "/v1/createLockerPin": {
      "post": {
        "summary": "Issue locker PIN/QR",
        "description": "Create PIN or QR code for smart locker access",
        "tags": [
          "Smart Locker"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/XTargetHost"
          },
          {
            "$ref": "#/components/parameters/Date"
          },
          {
            "$ref": "#/components/parameters/Digest"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Locker PIN/QR created successfully"
          }
        },
        "operationId": "post-v1-createlockerpin"
      }
    },
    "/v1/getBookingOrders": {
      "post": {
        "summary": "Fetch reservations",
        "description": "Retrieve booking orders and reservations",
        "tags": [
          "Booking"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/XTargetHost"
          },
          {
            "$ref": "#/components/parameters/Date"
          },
          {
            "$ref": "#/components/parameters/Digest"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reservations retrieved successfully"
          }
        },
        "operationId": "post-v1-getbookingorders"
      }
    }
  },
  "tags": [
    {
      "name": "Booking"
    },
    {
      "name": "Smart Lock"
    },
    {
      "name": "Smart Locker"
    }
  ]
}
