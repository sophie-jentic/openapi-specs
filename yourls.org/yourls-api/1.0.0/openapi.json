{
  "openapi": "3.0.3",
  "info": {
    "title": "YOURLS API",
    "version": "1.0.0",
    "description": "YOURLS (Your Own URL Shortener) is a self-hosted URL shortening service. The API allows you to create short URLs, retrieve URL statistics, expand short URLs, and manage your link database.",
    "x-jentic-source-url": "https://yourls.org/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{domain}/yourls-api.php",
      "variables": {
        "domain": {
          "default": "yourls.example.com",
          "description": "Your YOURLS instance domain"
        }
      }
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "shorturl",
        "summary": "Create a short URL",
        "description": "Create a new short URL. Supports custom keyword, title, and format options.",
        "tags": [
          "URLs"
        ],
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "shorturl"
              ]
            }
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "The URL to shorten",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "description": "Custom short URL keyword",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "title",
            "in": "query",
            "description": "Title for the URL",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Response format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "simple"
              ]
            }
          },
          {
            "name": "signature",
            "in": "query",
            "description": "API signature token",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timestamp",
            "in": "query",
            "description": "Timestamp for signature auth",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Short URL created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShortUrlResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "apiAction",
        "summary": "Execute API action via POST",
        "description": "Execute any YOURLS API action via POST. Actions: shorturl, expand, url-stats, stats, db-stats.",
        "tags": [
          "URLs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "action"
                ],
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "shorturl",
                      "expand",
                      "url-stats",
                      "stats",
                      "db-stats"
                    ]
                  },
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to shorten (for shorturl action)"
                  },
                  "keyword": {
                    "type": "string",
                    "description": "Custom keyword (for shorturl) or short URL keyword (for expand/url-stats)"
                  },
                  "shorturl": {
                    "type": "string",
                    "description": "Full short URL (for expand/url-stats)"
                  },
                  "title": {
                    "type": "string",
                    "description": "Title for the URL"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "json",
                      "xml",
                      "simple"
                    ]
                  },
                  "filter": {
                    "type": "string",
                    "enum": [
                      "top",
                      "bottom",
                      "rand",
                      "last"
                    ],
                    "description": "Filter for stats action"
                  },
                  "limit": {
                    "type": "integer",
                    "description": "Number of results for stats action"
                  },
                  "start": {
                    "type": "integer",
                    "description": "Offset for stats action"
                  },
                  "signature": {
                    "type": "string"
                  },
                  "timestamp": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Action completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShortUrlResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/?action=expand": {
      "get": {
        "operationId": "expand",
        "summary": "Expand a short URL",
        "description": "Get the long URL from a short URL keyword.",
        "tags": [
          "URLs"
        ],
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "expand"
              ]
            }
          },
          {
            "name": "shorturl",
            "in": "query",
            "required": true,
            "description": "The short URL or keyword to expand",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "simple"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Short URL expanded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExpandResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/?action=url-stats": {
      "get": {
        "operationId": "urlStats",
        "summary": "Get stats for a short URL",
        "description": "Get click statistics for a specific short URL.",
        "tags": [
          "Stats"
        ],
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "url-stats"
              ]
            }
          },
          {
            "name": "shorturl",
            "in": "query",
            "required": true,
            "description": "The short URL or keyword",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "simple"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "URL statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/?action=stats": {
      "get": {
        "operationId": "stats",
        "summary": "Get global link stats",
        "description": "Get statistics about all links, with optional filtering.",
        "tags": [
          "Stats"
        ],
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "stats"
              ]
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Filter type",
            "schema": {
              "type": "string",
              "enum": [
                "top",
                "bottom",
                "rand",
                "last"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of links to return",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Offset",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "simple"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Global statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UrlListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/?action=db-stats": {
      "get": {
        "operationId": "dbStats",
        "summary": "Get database stats",
        "description": "Get overall database statistics (total links and clicks).",
        "tags": [
          "Stats"
        ],
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "db-stats"
              ]
            }
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml",
                "simple"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Database statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DbStatsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "errorCode": {
            "type": "integer"
          }
        }
      },
      "ShortUrlResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "shorturl": {
            "type": "string",
            "format": "uri"
          },
          "url": {
            "type": "object",
            "properties": {
              "keyword": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "title": {
                "type": "string"
              },
              "date": {
                "type": "string",
                "format": "date-time"
              },
              "ip": {
                "type": "string"
              }
            }
          }
        }
      },
      "ExpandResponse": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string"
          },
          "shorturl": {
            "type": "string",
            "format": "uri"
          },
          "longurl": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "statusCode": {
            "type": "integer"
          }
        }
      },
      "StatsResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "link": {
            "type": "object",
            "properties": {
              "shorturl": {
                "type": "string",
                "format": "uri"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "title": {
                "type": "string"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "ip": {
                "type": "string"
              },
              "clicks": {
                "type": "integer"
              }
            }
          }
        }
      },
      "DbStatsResponse": {
        "type": "object",
        "properties": {
          "db-stats": {
            "type": "object",
            "properties": {
              "total_links": {
                "type": "integer"
              },
              "total_clicks": {
                "type": "integer"
              }
            }
          },
          "statusCode": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "UrlListResponse": {
        "type": "object",
        "properties": {
          "links": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "shorturl": {
                  "type": "string",
                  "format": "uri"
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "title": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time"
                },
                "ip": {
                  "type": "string"
                },
                "clicks": {
                  "type": "integer"
                }
              }
            }
          },
          "stats": {
            "type": "object",
            "properties": {
              "total_links": {
                "type": "integer"
              },
              "total_clicks": {
                "type": "integer"
              }
            }
          },
          "statusCode": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "SignatureAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "signature",
        "description": "HMAC signature-based passwordless API authentication"
      },
      "UsernamePassword": {
        "type": "apiKey",
        "in": "query",
        "name": "username",
        "description": "Username + password query params (username & password)"
      }
    }
  },
  "security": [
    {
      "SignatureAuth": []
    }
  ],
  "tags": [
    {
      "name": "URLs",
      "description": "URL shortening and management"
    },
    {
      "name": "Stats",
      "description": "Statistics and analytics"
    }
  ]
}
