{
  "openapi": "3.0.3",
  "info": {
    "title": "PinePods API",
    "version": "1.0.0",
    "description": "PinePods is a self-hosted podcast management system. The API provides endpoints for podcast management, episode playback, user preferences, search, and downloads.",
    "x-jentic-source-url": "https://www.pinepods.online/docs/API/pinepods_api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8040/api"
    }
  ],
  "paths": {
    "/data/get_user": {
      "get": {
        "operationId": "getUser",
        "summary": "Get current user info",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "User info"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get current user info"
      }
    },
    "/data/check_episode_playback": {
      "get": {
        "operationId": "checkPlayback",
        "summary": "Check episode playback status",
        "tags": [
          "Playback"
        ],
        "parameters": [
          {
            "name": "episode_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Playback status"
          }
        },
        "description": "Check episode playback status"
      }
    },
    "/data/record_podcast_history": {
      "post": {
        "operationId": "recordHistory",
        "summary": "Record podcast listen history",
        "tags": [
          "Playback"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "episode_id": {
                    "type": "integer"
                  },
                  "listen_duration": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "History recorded"
          }
        },
        "description": "Record podcast listen history"
      }
    },
    "/data/get_podcasts": {
      "get": {
        "operationId": "getPodcasts",
        "summary": "List subscribed podcasts",
        "tags": [
          "Podcasts"
        ],
        "responses": {
          "200": {
            "description": "Podcast list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Podcast"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List subscribed podcasts"
      }
    },
    "/data/add_podcast": {
      "post": {
        "operationId": "addPodcast",
        "summary": "Subscribe to a podcast by RSS URL",
        "tags": [
          "Podcasts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "podcast_url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "podcast_name": {
                    "type": "string"
                  }
                },
                "required": [
                  "podcast_url"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Podcast added"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Subscribe to a podcast by RSS URL"
      }
    },
    "/data/remove_podcast": {
      "delete": {
        "operationId": "removePodcast",
        "summary": "Unsubscribe from a podcast",
        "tags": [
          "Podcasts"
        ],
        "parameters": [
          {
            "name": "podcast_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Podcast removed"
          }
        },
        "description": "Unsubscribe from a podcast"
      }
    },
    "/data/get_episodes": {
      "get": {
        "operationId": "getEpisodes",
        "summary": "Get episodes for a podcast",
        "tags": [
          "Episodes"
        ],
        "parameters": [
          {
            "name": "podcast_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Episode list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Episode"
                  }
                }
              }
            }
          }
        },
        "description": "Get episodes for a podcast"
      }
    },
    "/data/get_episode": {
      "get": {
        "operationId": "getEpisode",
        "summary": "Get episode details",
        "tags": [
          "Episodes"
        ],
        "parameters": [
          {
            "name": "episode_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Episode details"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get episode details"
      }
    },
    "/data/download_episode": {
      "post": {
        "operationId": "downloadEpisode",
        "summary": "Download an episode for offline playback",
        "tags": [
          "Downloads"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "episode_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Download started"
          }
        },
        "description": "Download an episode for offline playback"
      }
    },
    "/data/get_downloads": {
      "get": {
        "operationId": "getDownloads",
        "summary": "List downloaded episodes",
        "tags": [
          "Downloads"
        ],
        "responses": {
          "200": {
            "description": "Download list"
          }
        },
        "description": "List downloaded episodes"
      }
    },
    "/data/search_podcasts": {
      "get": {
        "operationId": "searchPodcasts",
        "summary": "Search for podcasts",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "title": {
                        "type": "string"
                      },
                      "url": {
                        "type": "string"
                      },
                      "image": {
                        "type": "string"
                      },
                      "author": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Search for podcasts"
      }
    },
    "/data/save_episode": {
      "post": {
        "operationId": "saveEpisode",
        "summary": "Save/bookmark an episode",
        "tags": [
          "Episodes"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "episode_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Episode saved"
          }
        },
        "description": "Save/bookmark an episode"
      }
    },
    "/data/get_saved_episodes": {
      "get": {
        "operationId": "getSavedEpisodes",
        "summary": "List saved episodes",
        "tags": [
          "Episodes"
        ],
        "responses": {
          "200": {
            "description": "Saved episode list"
          }
        },
        "description": "List saved episodes"
      }
    },
    "/data/get_listen_history": {
      "get": {
        "operationId": "getListenHistory",
        "summary": "Get listen history",
        "tags": [
          "Playback"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Listen history"
          }
        },
        "description": "Get listen history"
      }
    },
    "/data/get_queue": {
      "get": {
        "operationId": "getQueue",
        "summary": "Get playback queue",
        "tags": [
          "Playback"
        ],
        "responses": {
          "200": {
            "description": "Queue list"
          }
        },
        "description": "Get playback queue"
      }
    },
    "/data/add_to_queue": {
      "post": {
        "operationId": "addToQueue",
        "summary": "Add episode to queue",
        "tags": [
          "Playback"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "episode_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Added to queue"
          }
        },
        "description": "Add episode to queue"
      }
    },
    "/data/get_user_settings": {
      "get": {
        "operationId": "getUserSettings",
        "summary": "Get user settings",
        "tags": [
          "Settings"
        ],
        "responses": {
          "200": {
            "description": "User settings"
          }
        },
        "description": "Get user settings"
      }
    },
    "/data/update_user_settings": {
      "put": {
        "operationId": "updateUserSettings",
        "summary": "Update user settings",
        "tags": [
          "Settings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings updated"
          }
        },
        "description": "Update user settings"
      }
    }
  },
  "components": {
    "schemas": {
      "Podcast": {
        "type": "object",
        "properties": {
          "PodcastID": {
            "type": "integer"
          },
          "PodcastName": {
            "type": "string"
          },
          "ArtworkURL": {
            "type": "string"
          },
          "Author": {
            "type": "string"
          },
          "Description": {
            "type": "string"
          },
          "EpisodeCount": {
            "type": "integer"
          },
          "FeedURL": {
            "type": "string"
          },
          "WebsiteURL": {
            "type": "string"
          }
        }
      },
      "Episode": {
        "type": "object",
        "properties": {
          "EpisodeID": {
            "type": "integer"
          },
          "EpisodeTitle": {
            "type": "string"
          },
          "EpisodeDescription": {
            "type": "string"
          },
          "EpisodeURL": {
            "type": "string"
          },
          "EpisodePubDate": {
            "type": "string",
            "format": "date-time"
          },
          "EpisodeDuration": {
            "type": "integer"
          },
          "EpisodeArtwork": {
            "type": "string"
          },
          "ListenedTo": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Api-Key",
        "description": "PinePods API key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Downloads"
    },
    {
      "name": "Episodes"
    },
    {
      "name": "Playback"
    },
    {
      "name": "Podcasts"
    },
    {
      "name": "Search"
    },
    {
      "name": "Settings"
    },
    {
      "name": "Users"
    }
  ]
}
