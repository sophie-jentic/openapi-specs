{
  "openapi": "3.0.3",
  "info": {
    "title": "Enrichley API",
    "version": "1.0.0",
    "description": "Enrichley API for email validation and LinkedIn profile enrichment.",
    "x-jentic-source-url": "https://enrichley.readme.io/reference/getting-started-with-your-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.enrichley.io"
    }
  ],
  "paths": {
    "/validate-single-email": {
      "post": {
        "operationId": "validateSingleEmail",
        "summary": "Validate a single email",
        "description": "Validates a single email address and returns validation results.",
        "tags": [
          "Email Validation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email address to validate"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmailValidationResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/me": {
      "get": {
        "operationId": "getApiKeyDetails",
        "summary": "Get API key details",
        "description": "Retrieve details about the authenticated API key.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "API key details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKeyDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/profile-enrichment": {
      "post": {
        "operationId": "enrichProfile",
        "summary": "Profile enrichment",
        "description": "Obtain information about a LinkedIn profile URL.",
        "tags": [
          "Enrichment"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "LinkedIn profile URL"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Enrichment result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileEnrichmentResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "EmailValidationResult": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "valid": {
            "type": "boolean"
          },
          "status": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "ApiKeyDetails": {
        "type": "object",
        "properties": {
          "api_key": {
            "type": "string"
          },
          "plan": {
            "type": "string"
          },
          "credits_remaining": {
            "type": "integer"
          }
        }
      },
      "ProfileEnrichmentResult": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "headline": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "profile_url": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Api-Key"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Account"
    },
    {
      "name": "Email Validation"
    },
    {
      "name": "Enrichment"
    }
  ]
}
