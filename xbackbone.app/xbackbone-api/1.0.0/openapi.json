{
  "openapi": "3.0.3",
  "info": {
    "title": "XBackBone API",
    "version": "1.0.0",
    "description": "XBackBone is a simple and lightweight ShareX/screenshot upload server. The API provides file upload, management, and user management endpoints.",
    "x-jentic-source-url": "https://xbackbone.app/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/upload": {
      "post": {
        "operationId": "uploadFile",
        "summary": "Upload a file",
        "tags": [
          "Upload"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User upload token"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid token"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Upload a file"
      }
    },
    "/upload/{id}": {
      "delete": {
        "operationId": "deleteUpload",
        "summary": "Delete an uploaded file",
        "tags": [
          "Upload"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Media ID"
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Delete an uploaded file"
      }
    },
    "/user/login": {
      "post": {
        "operationId": "login",
        "summary": "Authenticate and get session",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": [
                  "username",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "401": {
            "description": "Invalid credentials"
          }
        },
        "description": "Authenticate and get session"
      }
    },
    "/system/themes": {
      "get": {
        "operationId": "listThemes",
        "summary": "List available themes",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Theme list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List available themes"
      }
    },
    "/system/upgrade": {
      "post": {
        "operationId": "checkUpgrade",
        "summary": "Check for system upgrades",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Upgrade status"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Check for system upgrades"
      }
    }
  },
  "components": {
    "schemas": {
      "UploadResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "description": "Public URL of uploaded file"
          },
          "delete_url": {
            "type": "string",
            "description": "URL to delete the file"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "TokenAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "User upload token from account settings"
      }
    }
  },
  "security": [
    {
      "TokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication"
    },
    {
      "name": "System"
    },
    {
      "name": "Upload"
    }
  ]
}
