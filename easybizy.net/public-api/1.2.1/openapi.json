{
  "openapi": "3.0.3",
  "info": {
    "title": "Easybizy Public API Documentation",
    "version": "1.2.1",
    "description": "This is the public API documentation for <b>Easybizy</b>.<br/>\nAll requests must contain of both <b>x-api-key</b> and <b>x-api-secret</b> headers.\nThe API also has to be enabled on your account. To enable the API, please contact <a href=\"mailto:info@easybizy.net\">Easybizy Support</a>.\n",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.easybizy.net/"
    }
  ],
  "paths": {
    "/api/v1/ping": {
      "get": {
        "summary": "Validates the request is authenticated and server is up and running.",
        "description": "This request simply validates the authentication and server is up and running by going through\nthe authentication process and returning the pong if successful.",
        "operationId": "getApiV1Ping",
        "tags": [
          "api"
        ],
        "responses": {
          "200": {
            "description": "Successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/definitions/Response%20Pong%20On%20Success"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/public-ping": {
      "get": {
        "summary": "Validates the request is authenticated and server is up and running.",
        "description": "This request simply validates the authentication and server is up and running by going through\nthe authentication process and returning the pong if successful.",
        "operationId": "getApiV1Publicping",
        "tags": [
          "api"
        ],
        "responses": {
          "200": {
            "description": "Successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/definitions/Response Pong On Success"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/call-logs": {
      "post": {
        "summary": "Log an incoming/answered call to the system.",
        "description": "Creates a new incoming call log on Easybizy.<br/>If current logged-in user on Easybizy is not blocked to receive incoming calls, a popup screen will be displayed on easybizy.<br/><br/>A simple body might be: ``{ \"phoneNumber\": \"0504445554\"}``<br/><br/>A body with extension: ``{ \"phoneNumber\": \"0504445554\", \"extension\": \"255\"}``<br/><br/>A body with uid, that is the external unique id: ``{ \"phoneNumber\": \"0504445554\", \"extension\": \"255\", \"uid\": \"33fdbee4-6512-4a48-8eb2-68000e8a962a\"}``<br/><br/>A body with extension and status: ``{ \"phoneNumber\": \"0504445554\", \"extension\": \"255\", \"status\": \"ANSWER\"}`` - Default status ``NEWCALL``<br/><br/>For a more descripitive model, have a look at the <b>Model</b> section on the description - following example.",
        "operationId": "postApiV1Calllogs",
        "tags": [
          "api"
        ],
        "responses": {
          "200": {
            "description": "Successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/definitions/Response%20Call%20logs%20id"
                }
              }
            }
          }
        },
        "parameters": [],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/definitions/Call%20log%20details"
              }
            }
          }
        }
      }
    },
    "/api/v1/gift-cards": {
      "post": {
        "summary": "Creates a gift card payable link.",
        "description": "\nReturns a payment link for a gift card or directly creates and sends a gift card based on the `priceAfterDiscount` value. <br/> \nIf `priceAfterDiscount` is `null` or `0`, the gift card will be <b>immediately</b> created and sent (if sending has been requested on the `recipient` field), and the response will include the generated gift card details. In this case, the `ignorePayment` field <b>must be set</b> to `true`. <br/>\nIf `priceAfterDiscount` is greater than `0`, a payment link will be generated, and upon successful payment, the gift card will be created. <br/>\nThis method is highly flexible yet can be simplified. The minimum required fields for an immediate gift card issuance can be as simple as: <br/>\n``{\"giftCardCreditAmount\": 500, \"buyer\": {\"name\": \"John Doe\", \"phoneNumber\": \"0508116811\"}, \"ignorePayment\": true}`` <br/>\n<br/>\nIf a successful payment <b>webhook</b> is required, the `paymentSuccessWebhook` (see the model for a description) field should be set.\nThe webhook supports both `get` and `post` methods, if a method is not provided, it will default to `post`.\nWhen `get` is used, the payload will be appended to the URL as query parameters.\nSupported fields are: `paymentLinkId`, `giftCardUsageAmount`, `amountCharged`, and `cardLastFourDigits`, and any additional `constants` that are required (that will be simply attached to the payload/url).\nIf a different field mapping is required, it can be provided in the `fieldsMap` field. As and example `{\"fieldsMap\": {\"paymentLinkId\": \"paymentId\"}}` will map the easybizy's field `paymentLinkId` to your `paymentId` field in the payload/url.\nIf unsupported fields are provided, they will be <b>ignored</b>.\n<br/>\nFor a more detailed model, refer to the <b>Model</b> section in the description, following the example below.<br/><br/>\n⚠️ **Important Notice:** If `priceAfterDiscount` is `null` or `0`, the system will **immediately create and send** a gift card. This effectively means issuing real money, so extra caution must be taken to ensure correctness and prevent unintended issuance.\n Using this direct method, <b>requires</b> CREATE permission for the gift-card entity.<br/><br/>\n            ",
        "operationId": "postApiV1Giftcards",
        "tags": [
          "api"
        ],
        "responses": {
          "200": {
            "description": "Successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/definitions/Response%20Model"
                }
              }
            }
          }
        },
        "parameters": [],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/definitions/Gift%20Card%20Model"
              }
            }
          }
        }
      }
    },
    "/api/v1/leads": {
      "post": {
        "summary": "Creates a new lead.",
        "description": "Creates a new lead on Easybizy.<br/>In case of similar mobile phone, details will be added to the existing lead.<br/> A lead request <b>must have</b> either or <i>mobile</i> | <i>email</i> (if none the request will not pass through).<br/><br/>A simple example might be: ``{ \"Name\": \"Haim Cohen\", \"Mobile\":\"0506655441\" ,\"ArrivalSource\": \"Facebook\", \"TagsStr\":\"Facial-Campign,Ad 1332344\"}``<br/><br/>For a more descripitive model, have a look at the <b>Model</b> section on the description - following example.",
        "operationId": "postApiV1Leads",
        "tags": [
          "api"
        ],
        "responses": {
          "200": {
            "description": "Successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/definitions/Response%20Lead%20Model"
                }
              }
            }
          }
        },
        "parameters": [],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/definitions/Lead%20details"
              }
            }
          }
        }
      }
    }
  },
