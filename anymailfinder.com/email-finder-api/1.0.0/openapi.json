{
  "openapi": "3.0.3",
  "info": {
    "title": "Anymail Finder API",
    "version": "1.0.0",
    "description": "Anymail Finder is an email finding and verification API. Find verified email addresses for people, companies, and decision makers. Supports single lookups, bulk operations, LinkedIn URL lookups, and email verification.",
    "x-jentic-source-url": "https://anymailfinder.com/email-finder-api/docs",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.anymailfinder.com",
      "description": "Anymail Finder Production API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Email Search",
      "description": "Find email addresses for individuals and companies"
    },
    {
      "name": "Verification",
      "description": "Verify email addresses and report bad emails"
    },
    {
      "name": "Bulk",
      "description": "Bulk email search operations"
    },
    {
      "name": "Account",
      "description": "Account information"
    }
  ],
  "paths": {
    "/v5/search/person.json": {
      "post": {
        "operationId": "searchPersonEmail",
        "summary": "Find person email",
        "description": "Find a verified email address for a specific person at a company. Requires full name and company domain.",
        "tags": [
          "Email Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PersonSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email found successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersonSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing required parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v5/search/company.json": {
      "post": {
        "operationId": "searchCompanyEmails",
        "summary": "Find company emails",
        "description": "Find all email addresses associated with a company domain.",
        "tags": [
          "Email Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompanySearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Emails found successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanySearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v5/search/decision_maker.json": {
      "post": {
        "operationId": "searchDecisionMakerEmail",
        "summary": "Find decision maker email",
        "description": "Find the email of a decision maker at a company. Returns the most relevant decision maker's email without needing to know their name.",
        "tags": [
          "Email Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DecisionMakerSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Decision maker email found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersonSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v5/search/linkedin.json": {
      "post": {
        "operationId": "searchLinkedInEmail",
        "summary": "Find email from LinkedIn URL",
        "description": "Find a verified email address using a LinkedIn profile URL.",
        "tags": [
          "Email Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LinkedInSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersonSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v5/verify.json": {
      "post": {
        "operationId": "verifyEmail",
        "summary": "Verify an email address",
        "description": "Verify whether a given email address is valid and deliverable.",
        "tags": [
          "Verification"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyEmailRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyEmailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v5/report_bad.json": {
      "post": {
        "operationId": "reportBadEmail",
        "summary": "Report a bad email",
        "description": "Report an email address that was returned by the API but is incorrect or bounced. Credits may be refunded.",
        "tags": [
          "Verification"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportBadEmailRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Report submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportBadEmailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v5/bulk/upload.json": {
      "post": {
        "operationId": "bulkUpload",
        "summary": "Upload bulk search file",
        "description": "Upload a CSV file for bulk email search. The file should contain columns for full_name and domain.",
        "tags": [
          "Bulk"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/BulkUploadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk job created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v5/bulk/status.json": {
      "get": {
        "operationId": "bulkStatus",
        "summary": "Get bulk job status",
        "description": "Get the status and results of a bulk email search job.",
        "tags": [
          "Bulk"
        ],
        "parameters": [
          {
            "name": "job_id",
            "in": "query",
            "required": true,
            "description": "The ID of the bulk job to check",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bulk job status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v5/account.json": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get account information",
        "description": "Retrieve information about your account, including remaining credits and plan details.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Account information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key passed as Bearer token. Get your API key from your Anymail Finder dashboard."
      }
    },
    "schemas": {
      "PersonSearchRequest": {
        "type": "object",
        "required": [
          "full_name",
          "domain"
        ],
        "properties": {
          "full_name": {
            "type": "string",
            "description": "Full name of the person to search for",
            "example": "John Smith"
          },
          "domain": {
            "type": "string",
            "description": "Company domain to search within",
            "example": "example.com"
          }
        }
      },
      "CompanySearchRequest": {
        "type": "object",
        "required": [
          "domain"
        ],
        "properties": {
          "domain": {
            "type": "string",
            "description": "Company domain to find emails for",
            "example": "example.com"
          }
        }
      },
      "DecisionMakerSearchRequest": {
        "type": "object",
        "required": [
          "domain"
        ],
        "properties": {
          "domain": {
            "type": "string",
            "description": "Company domain to find a decision maker for",
            "example": "example.com"
          }
        }
      },
      "LinkedInSearchRequest": {
        "type": "object",
        "required": [
          "linkedin_url"
        ],
        "properties": {
          "linkedin_url": {
            "type": "string",
            "description": "LinkedIn profile URL of the person",
            "example": "https://www.linkedin.com/in/johndoe"
          }
        }
      },
      "VerifyEmailRequest": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address to verify",
            "example": "john@example.com"
          }
        }
      },
      "ReportBadEmailRequest": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "The bad email address to report",
            "example": "john@example.com"
          }
        }
      },
      "BulkUploadRequest": {
        "type": "object",
        "required": [
          "file"
        ],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "CSV file containing full_name and domain columns"
          }
        }
      },
      "PersonSearchResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the search was successful"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "The found email address"
          },
          "email_class": {
            "type": "string",
            "enum": [
              "verified",
              "guessed",
              "not_found"
            ],
            "description": "Classification of the email result"
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "email"
            },
            "description": "Alternative email addresses found"
          },
          "full_name": {
            "type": "string",
            "description": "Full name of the person"
          },
          "domain": {
            "type": "string",
            "description": "Domain searched"
          }
        }
      },
      "CompanySearchResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "domain": {
            "type": "string"
          },
          "emails": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompanyEmail"
            }
          },
          "total_count": {
            "type": "integer",
            "description": "Total number of emails found"
          }
        }
      },
      "CompanyEmail": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "email_class": {
            "type": "string",
            "enum": [
              "verified",
              "guessed"
            ]
          },
          "full_name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      },
      "VerifyEmailResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "email_class": {
            "type": "string",
            "enum": [
              "valid",
              "invalid",
              "unknown"
            ],
            "description": "Verification result classification"
          }
        }
      },
      "ReportBadEmailResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string",
            "description": "Confirmation message"
          }
        }
      },
      "BulkUploadResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "job_id": {
            "type": "string",
            "description": "ID of the created bulk job"
          },
          "row_count": {
            "type": "integer",
            "description": "Number of rows in the uploaded file"
          }
        }
      },
      "BulkStatusResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "job_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "description": "Current status of the bulk job"
          },
          "total_rows": {
            "type": "integer"
          },
          "processed_rows": {
            "type": "integer"
          },
          "download_url": {
            "type": "string",
            "description": "URL to download results when completed"
          }
        }
      },
      "AccountResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Account email"
          },
          "credits_remaining": {
            "type": "integer",
            "description": "Number of credits remaining"
          },
          "plan": {
            "type": "string",
            "description": "Current plan name"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "error_code": {
            "type": "string",
            "description": "Machine-readable error code"
          }
        }
      }
    }
  }
}
