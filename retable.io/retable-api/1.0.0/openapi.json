        "operationId": "getRows",
        "summary": "Get rows from a table",
        "description": "Retrieve all rows or specific rows from a table",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "retable_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Table ID"
          },
          {
            "name": "row_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated row IDs (max 50)"
          }
        ],
        "responses": {
          "200": {
            "description": "Rows retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RowListResponse"
                }
              }
