                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "CSV or XLS file"
                  },
                  "group_id": {
                    "type": "integer"
                  },
                  "duplicates": {
                    "type": "string"
                  },
                  "no_headings": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import successful"
