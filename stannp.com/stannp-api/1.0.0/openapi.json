        "description": "Get a single recipient"
      }
    },
    "/recipients/new": {
      "post": {
        "tags": [
          "Recipients"
        ],
        "summary": "Create a new recipient",
        "operationId": "createRecipient",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "group_id",
                  "address1",
                  "city",
                  "postcode",
                  "country"
                ],
                "properties": {
                  "group_id": {
                    "type": "integer",
                    "description": "Target group ID"
                  },
                  "firstname": {
                    "type": "string"
                  },
                  "lastname": {
                    "type": "string"
                  },
                  "address1": {
                    "type": "string"
                  },
                  "address2": {
                    "type": "string"
                  },
                  "address3": {
                    "type": "string"
                  },
                  "city": {
                    "type": "string"
                  },
                  "postcode": {
                    "type": "string"
                  },
                  "country": {
                    "type": "string",
                    "description": "ISO 3166-1 Alpha 2 code"
                  },
                  "email": {
                    "type": "string"
                  },
                  "phone_number": {
                    "type": "string"
                  },
                  "on_duplicate": {
                    "type": "string",
                    "enum": [
                      "update",
                      "ignore",
                      "duplicate"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recipient created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a new recipient"
      }
    },
    "/recipients/delete": {
      "post": {
        "tags": [
          "Recipients"
        ],
        "summary": "Delete a recipient",
        "operationId": "deleteRecipient",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
