    "/postcards/create": {
      "post": {
        "tags": [
          "Postcards"
        ],
        "summary": "Create and send a single postcard",
        "operationId": "createPostcard",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "size",
                  "recipient"
                ],
                "properties": {
                  "test": {
                    "type": "boolean",
                    "description": "Generate sample PDF without dispatch"
                  },
                  "size": {
                    "type": "string",
                    "enum": [
                      "A6",
                      "A5",
                      "A5-ENV"
                    ]
                  },
                  "recipient": {
                    "type": "string",
                    "description": "Existing recipient ID or JSON object with recipient details"
                  },
                  "template": {
                    "type": "integer",
                    "description": "Pre-configured template ID"
                  },
                  "message": {
                    "type": "string",
                    "description": "Back-of-card message"
                  },
                  "front": {
                    "type": "string",
                    "format": "binary",
                    "description": "Front image (JPG or PDF)"
                  },
                  "back": {
                    "type": "string",
                    "format": "binary",
                    "description": "Back image (JPG or PDF)"
                  },
                  "padding": {
                    "type": "integer",
                    "description": "Border control (0 removes default white border)"
                  },
                  "post_unverified": {
                    "type": "boolean"
                  },
                  "clearzone": {
                    "type": "boolean"
                  },
                  "tags": {
                    "type": "string",
                    "description": "Comma-separated reference tags"
                  },
                  "addons": {
                    "type": "string",
                    "description": "Upgrade codes e.g. FIRST_CLASS"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Postcard created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MailpieceResponse"
                }
              }
            }
          }
        },
        "description": "Create and send a single postcard"
      }
    },
    "/postcards/get/{id}": {
      "get": {
        "tags": [
          "Postcards"
        ],
        "summary": "Get a single postcard",
