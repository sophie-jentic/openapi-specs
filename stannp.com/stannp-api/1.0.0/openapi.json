    "/letters/create": {
      "post": {
        "tags": [
          "Letters"
        ],
        "summary": "Create and send a single letter",
        "operationId": "createLetter",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "recipient"
                ],
                "properties": {
