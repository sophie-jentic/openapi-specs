    "contact": {
      "name": "Stannp",
      "url": "https://www.stannp.com"
    },
    "x-jentic-source-url": "https://www.stannp.com/uk/direct-mail-api"
  },
  "servers": [
    {
      "url": "https://api-eu1.stannp.com/v1",
      "description": "Stannp EU Production API"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    },
    {
      "basicAuth": []
    }
  ],
