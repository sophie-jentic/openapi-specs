                  "template": {
                    "type": "integer",
                    "description": "Pre-configured template ID"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "PDF/DOC file (max 10 pages)"
                  },
                  "duplex": {
                    "type": "boolean",
                    "description": "Double-sided printing",
                    "default": true
                  },
                  "clearzone": {
                    "type": "boolean",
                    "default": true
                  },
                  "post_unverified": {
                    "type": "boolean",
                    "default": true
                  },
                  "tags": {
                    "type": "string"
                  },
                  "addons": {
                    "type": "string"
                  }
                }
              }
            }
          }
