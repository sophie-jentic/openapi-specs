{
  "openapi": "3.0.3",
  "info": {
    "title": "DigitalOcean Spaces API",
    "version": "2.0",
    "description": "DigitalOcean Spaces is an S3-compatible object storage service. Uses AWS Signature Version 4 for authentication. Supports bucket management, object operations, multipart uploads, ACLs, CORS, and lifecycle configuration.",
    "x-jentic-source-url": "https://docs.digitalocean.com/reference/api/spaces/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{region}.digitaloceanspaces.com",
      "variables": {
        "region": {
          "default": "nyc3",
          "description": "DigitalOcean region",
          "enum": [
            "nyc3",
            "sfo3",
            "ams3",
            "sgp1",
            "fra1",
            "syd1"
          ]
        }
      }
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "listBuckets",
        "summary": "List all Spaces",
        "description": "Returns a list of all Spaces (buckets) owned by the authenticated sender of the request.",
        "tags": [
          "Buckets"
        ],
        "responses": {
          "200": {
            "description": "List of buckets",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/ListAllMyBucketsResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid credentials"
          },
          "403": {
            "description": "Forbidden - access denied"
          }
        }
      }
    },
    "/{Bucket}": {
      "put": {
        "operationId": "createBucket",
        "summary": "Create a Space",
        "tags": [
          "Buckets"
        ],
        "parameters": [
          {
            "name": "Bucket",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the Space to create"
          }
        ],
        "requestBody": {
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/CreateBucketConfiguration"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Space created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "409": {
            "description": "Space already exists"
          }
        },
        "description": "Create a Space"
      },
      "delete": {
        "operationId": "deleteBucket",
        "summary": "Delete a Space",
        "tags": [
          "Buckets"
        ],
        "parameters": [
          {
            "name": "Bucket",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Space deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Space not found"
          },
          "409": {
            "description": "Space not empty"
          }
        },
        "description": "Delete a Space"
      },
      "head": {
        "operationId": "headBucket",
        "summary": "Check if a Space exists",
        "tags": [
          "Buckets"
        ],
        "parameters": [
          {
            "name": "Bucket",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Space exists"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Space not found"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Check if a Space exists"
      }
    },
    "/{Bucket}?list-type=2": {
      "get": {
        "operationId": "listObjectsV2",
        "summary": "List objects in a Space",
        "description": "Returns some or all objects in a Space. Uses list-type=2 for the v2 listing API.",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "Bucket",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "list-type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "enum": [
                2
              ]
            }
          },
          {
            "name": "prefix",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Limits results to keys beginning with the prefix"
          },
          {
            "name": "delimiter",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "A delimiter for grouping keys"
          },
          {
            "name": "max-keys",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1000
            },
            "description": "Maximum number of keys to return"
          },
          {
            "name": "continuation-token",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Token from previous truncated response"
          },
          {
            "name": "start-after",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Start listing after this key"
          },
          {
            "name": "encoding-type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "url"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/ListBucketResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/{Bucket}/{Key}": {
      "get": {
        "operationId": "getObject",
        "summary": "Get an object",
        "description": "Retrieves an object from a Space.",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "Bucket",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Range",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "description": "Byte range to retrieve"
          },
          {
            "name": "If-Modified-Since",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "If-None-Match",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "response-content-type",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "response-content-disposition",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "304": {
            "description": "Not modified"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Object not found"
          }
        }
      },
      "put": {
        "operationId": "putObject",
        "summary": "Upload an object",
        "description": "Adds an object to a Space.",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "Bucket",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Content-Type",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Content-MD5",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Cache-Control",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Content-Disposition",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Content-Encoding",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-amz-acl",
            "in": "header",
            "schema": {
              "type": "string",
              "enum": [
                "private",
                "public-read"
              ]
            }
          },
          {
            "name": "x-amz-meta-*",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "description": "Custom metadata headers"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Object uploaded"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteObject",
        "summary": "Delete an object",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "Bucket",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Object deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete an object"
      },
      "head": {
        "operationId": "headObject",
        "summary": "Get object metadata",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "Bucket",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object metadata headers"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Object not found"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "description": "Get object metadata"
      }
    },
