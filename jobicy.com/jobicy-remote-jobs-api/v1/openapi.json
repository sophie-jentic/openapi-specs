{
  "openapi": "3.0.3",
  "info": {
    "title": "Jobicy Remote Jobs API",
    "version": "2.2.13",
    "description": "The Jobicy API provides access to remote job listings. It returns job data including title, company, industry, type, location, and job descriptions. No authentication required for public endpoints.",
    "x-jentic-source-url": "https://jobicy.com/api/v2/remote-jobs",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://jobicy.com/api/v2"
    }
  ],
  "paths": {
    "/remote-jobs": {
      "get": {
        "operationId": "listRemoteJobs",
        "tags": [
          "Jobs"
        ],
        "summary": "List remote jobs",
        "description": "Returns a list of remote job listings, optionally filtered by count, industry, tag, location, and other criteria.",
        "parameters": [
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "description": "Number of listings to return (default: 10, max: 50)"
          },
          {
            "name": "industry",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by job industry category"
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by job tag or keyword"
          },
          {
            "name": "geo",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by geographic location/region code (e.g. USA, UK, Anywhere)"
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by job type (Full-Time, Part-Time, Contract, etc.)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized or access restricted"
          },
          "429": {
            "description": "Too many requests"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "noAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "access_token",
        "description": "Public endpoints require no authentication"
      }
    },
    "schemas": {
      "JobListResponse": {
        "type": "object",
        "properties": {
          "apiVersion": {
            "type": "string"
          },
          "documentationUrl": {
            "type": "string"
          },
          "friendlyNotice": {
            "type": "string"
          },
          "jobCount": {
            "type": "integer"
          },
          "xRayCache": {
            "type": "string"
          },
          "clientKey": {
            "type": "string"
          },
          "lastUpdate": {
            "type": "string",
            "format": "date-time"
          },
          "appliedFilters": {
            "type": "object"
          },
          "jobs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Job"
            }
          }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "jobSlug": {
            "type": "string"
          },
          "jobTitle": {
            "type": "string"
          },
          "companyName": {
            "type": "string"
          },
          "companyLogo": {
            "type": "string",
            "format": "uri"
          },
          "jobIndustry": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "jobType": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "jobGeo": {
            "type": "string"
          },
          "jobLevel": {
            "type": "string"
          },
          "jobExcerpt": {
            "type": "string"
          },
          "jobDescription": {
            "type": "string"
          },
          "pubDate": {
            "type": "string"
          },
          "annualSalaryMin": {
            "type": "number"
          },
          "annualSalaryMax": {
            "type": "number"
          },
          "salaryCurrency": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "response_code": {
            "type": "integer"
          },
          "response": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Jobs"
    }
  ]
}
