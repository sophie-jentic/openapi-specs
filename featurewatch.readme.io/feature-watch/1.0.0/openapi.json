{
  "openapi": "3.0.3",
  "info": {
    "title": "Feature Watch API",
    "description": "Feature Watch API for managing boards, features, comments, likes, states, and webhooks",
    "version": "1.0.0",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://featurewatch.readme.io"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      },
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API Key authentication"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    },
    {
      "ApiKey": []
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "summary": "User authentication",
        "description": "Authenticate user with email, password, and subdomain",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  },
                  "subdomain": {
                    "type": "string"
                  }
                },
                "required": [
                  "email",
                  "password",
                  "subdomain"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful"
          }
        },
        "security": [],
        "operationId": "post-login"
      }
    },
    "/me": {
      "get": {
        "summary": "Current user info",
        "description": "Get information about the currently authenticated user",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "User information"
          }
        },
        "operationId": "get-me"
      }
    },
    "/boards": {
      "get": {
        "summary": "List all boards",
        "description": "Retrieve list of all boards",
        "tags": [
          "Boards"
        ],
        "responses": {
          "200": {
            "description": "List of boards"
          }
        },
        "operationId": "get-boards"
      }
    },
    "/board/{id}": {
      "get": {
        "summary": "Retrieve specific board",
        "description": "Get details of a specific board by ID",
        "tags": [
          "Boards"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Board details"
          }
        },
        "operationId": "get-board-by-id"
      }
    },
    "/board/{id}/features": {
      "get": {
        "summary": "Get features for a board",
        "description": "Retrieve all features associated with a board",
        "tags": [
          "Boards"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of features for the board"
          }
        },
        "operationId": "get-board-by-id-features"
      }
    },
    "/features": {
      "get": {
        "summary": "List all features",
        "description": "Retrieve list of all features",
        "tags": [
          "Features"
        ],
        "responses": {
          "200": {
            "description": "List of features"
          }
        },
        "operationId": "get-features"
      },
      "post": {
        "summary": "Create feature",
        "description": "Create a new feature",
        "tags": [
          "Features"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "board_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Feature created"
          }
        },
        "operationId": "post-features"
      }
    },
    "/feature/{id}": {
      "get": {
        "summary": "Retrieve specific feature",
        "description": "Get details of a specific feature by ID",
        "tags": [
          "Features"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Feature details"
          }
        },
        "operationId": "get-feature-by-id"
      }
    },
    "/add_feature": {
      "post": {
        "summary": "Add new feature",
        "description": "Add a new feature with board_id, name, and description",
        "tags": [
          "Features"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "board_id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                },
                "required": [
                  "board_id",
                  "name",
                  "description"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Feature added"
          }
        },
        "operationId": "post-add-feature"
      }
    },
    "/comments": {
      "get": {
        "summary": "Retrieve comments",
        "description": "Get list of comments",
        "tags": [
          "Activity"
        ],
        "responses": {
          "200": {
            "description": "List of comments"
          }
        },
        "operationId": "get-comments"
      }
    },
    "/likes": {
      "get": {
        "summary": "Retrieve likes",
        "description": "Get list of likes",
        "tags": [
          "Activity"
        ],
        "responses": {
          "200": {
            "description": "List of likes"
          }
        },
        "operationId": "get-likes"
      }
    },
    "/states": {
      "get": {
        "summary": "Retrieve states",
        "description": "Get list of states",
        "tags": [
          "Activity"
        ],
        "responses": {
          "200": {
            "description": "List of states"
          }
        },
        "operationId": "get-states"
      }
    },
    "/statuses": {
      "get": {
        "summary": "List all statuses",
        "description": "Retrieve list of all statuses",
        "tags": [
          "Status Management"
        ],
        "responses": {
          "200": {
            "description": "List of statuses"
          }
        },
        "operationId": "get-statuses"
      }
    },
    "/status/{id}": {
      "get": {
        "summary": "Retrieve specific status",
        "description": "Get details of a specific status by ID",
        "tags": [
          "Status Management"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Status details"
          }
        },
        "operationId": "get-status-by-id"
      }
    },
    "/change_state": {
      "post": {
        "summary": "Modify feature state",
        "description": "Change the state of a feature",
        "tags": [
          "Status Management"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "feature_id": {
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "feature_id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "State changed successfully"
          }
        },
        "operationId": "post-change-state"
      }
    },
    "/hook/subscribe": {
      "post": {
        "summary": "Subscribe to webhooks",
        "description": "Create a webhook subscription",
        "tags": [
          "Webhooks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook subscription created"
          }
        },
        "operationId": "post-hook-subscribe"
      }
    },
    "/hook/unsubscribe/{id}": {
      "delete": {
        "summary": "Unsubscribe from webhooks",
        "description": "Remove a webhook subscription",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook unsubscribed"
          }
        },
        "operationId": "delete-hook-unsubscribe-by-id"
      }
    }
  },
  "tags": [
    {
      "name": "Activity"
    },
    {
      "name": "Authentication"
    },
    {
      "name": "Boards"
    },
    {
      "name": "Features"
    },
    {
      "name": "Status Management"
    },
    {
      "name": "Webhooks"
    }
  ]
}
