              }
            }
          },
          "from": { "type": "string", "format": "date-time", "description": "Start of billing period" },
          "to": { "type": "string", "format": "date-time", "description": "Current date/time" },
          "limit": { "type": "integer", "description": "Monthly conversion quota" },
