          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "appToken": []
          }
        ]
      },
      "put": {
        "operationId": "updateQuote",
        "summary": "Update a quote",
        "description": "Update a quote. Requires pro user session.",
        "tags": [
          "quotes"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/QuoteId"
          }
        ],
        "requestBody": {
          "required": true,
