{
  "openapi": "3.0.3",
  "info": {
    "title": "FavQs API",
    "description": "FavQs.com API provides access to a curated collection of quotes. Supports browsing, searching, favoriting, voting, and managing quotes with user accounts. Rate limited to 30 requests per 20-second interval.",
    "version": "2.0.0",
    "contact": {
      "name": "FavQs",
      "url": "https://favqs.com/api"
    },
    "x-jentic-source-url": "https://favqs.com/api"
  },
  "servers": [
    {
      "url": "https://favqs.com/api",
      "description": "FavQs API v2 production server"
    }
  ],
  "tags": [
    {
      "name": "quotes",
      "description": "Quote browsing, searching, and management"
    },
    {
      "name": "users",
      "description": "User registration and profile management"
    },
    {
      "name": "sessions",
      "description": "User session management"
    },
    {
      "name": "activities",
      "description": "Follow/unfollow and activity feeds"
    },
    {
      "name": "typeahead",
      "description": "Autocomplete suggestions"
    }
  ],
  "paths": {
    "/qotd": {
      "get": {
        "operationId": "getQuoteOfTheDay",
        "summary": "Get Quote of the Day",
        "description": "Returns the current Quote of the Day. No authentication required.",
        "tags": [
          "quotes"
        ],
        "responses": {
          "200": {
            "description": "Quote of the Day",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteOfTheDay"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/quotes": {
      "get": {
        "operationId": "listQuotes",
        "summary": "List quotes",
        "description": "Retrieve a paginated list of quotes with optional filtering by keyword, tag, author, or other criteria.",
        "tags": [
          "quotes"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Search keyword to filter quotes",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter type: tag, author, or user",
            "schema": {
              "type": "string",
              "enum": [
                "tag",
                "author",
                "user"
              ]
            }
          },
          {
            "name": "hidden",
            "in": "query",
            "description": "Include hidden quotes (requires user session)",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of quotes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteList"
                }
              }
            },
            "headers": {
              "Rate-Limit-Remaining": {
                "description": "Number of requests remaining in current window",
                "schema": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "security": [
          {
            "appToken": []
          }
        ]
      },
      "post": {
        "operationId": "createQuote",
        "summary": "Add a new quote",
        "description": "Add a new quote. Requires user session token.",
        "tags": [
          "quotes"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuoteCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quote created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quote"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "security": [
          {
            "appToken": [],
            "userToken": []
          }
        ]
      }
    },
    "/quotes/{quote_id}": {
      "get": {
        "operationId": "getQuote",
        "summary": "Get a specific quote",
        "description": "Retrieve a single quote by its ID.",
