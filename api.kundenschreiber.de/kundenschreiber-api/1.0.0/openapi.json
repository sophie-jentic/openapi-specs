{
  "openapi": "3.0.3",
  "info": {
    "title": "Kundenschreiber Public API",
    "version": "1.0.0",
    "description": "API for creating handwritten letters and postcards",
    "contact": {
      "name": "Kundenschreiber Support",
      "email": "support@kundenschreiber.de"
    }
  },
  "servers": [
    {
      "url": "https://api.kundenschreiber.de/functions/v1/public-api/v1",
      "description": "Production (Custom Domain)"
    },
    {
      "url": "https://ysxsxtpdlhyxmslabwhk.supabase.co/functions/v1/public-api/v1",
      "description": "Production (Supabase)"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "schemas": {
      "Recipient": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "street",
          "zip",
          "city",
          "country"
        ],
        "properties": {
          "company_name": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "street": {
            "type": "string"
          },
          "zip": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string",
            "default": "Deutschland"
          }
        }
      },
      "QrCodeCreate": {
        "type": "object",
        "required": [
          "campaign_id",
          "target_url"
        ],
        "description": "Erstellt einen individuellen QR-Code. Jeder QR-Code erh\u00e4lt eine eindeutige URL. Ideal f\u00fcr personalisierte Sendungen, bei denen jeder Empf\u00e4nger einen eigenen QR-Code bekommt.",
        "properties": {
          "campaign_id": {
            "type": "string",
            "format": "uuid",
            "description": "ID der QR-Kampagne (erforderlich). Kampagnen k\u00f6nnen \u00fcber POST /v1/qr/campaigns erstellt werden."
          },
          "target_url": {
            "type": "string",
            "format": "uri",
            "description": "Ziel-URL, zu der der QR-Code weiterleitet (erforderlich)"
          },
          "name": {
            "type": "string",
            "description": "Optionaler Name f\u00fcr diesen QR-Code (n\u00fctzlich zur internen Referenzierung)"
          }
        },
        "example": {
          "campaign_id": "123e4567-e89b-12d3-a456-426614174000",
          "target_url": "https://example.com/product/123"
        }
      },
      "RecipientFull": {
        "type": "object",
        "description": "Complete recipient object with all fields",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "company_name": {
            "type": "string"
          },
          "street": {
            "type": "string"
          },
          "zip": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SignatureVariation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "svg_path_data": {
            "type": "string",
            "description": "SVG path data for the handwritten signature"
          },
          "width_mm": {
            "type": "number",
            "description": "Width in millimeters"
          },
          "height_mm": {
            "type": "number",
            "description": "Height in millimeters"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Signature": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "is_active": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "variations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SignatureVariation"
            },
            "description": "Handwritten signature variations (SVG paths)"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "paths": {
    "/shipment-balance": {
      "get": {
        "summary": "Get shipment credit balance",
        "description": "Returns the current shipment credit balance. Each credit equals one letter (card + envelope).",
        "tags": [
          "Credits"
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current shipment balance",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "shipment_credits": {
                      "type": "integer",
                      "description": "Number of available shipment credits (1 credit = 1 letter)"
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "active",
                        "trialing",
                        "inactive"
                      ],
                      "description": "Subscription status"
                    }
                  }
                },
                "example": {
                  "shipment_credits": 142,
                  "status": "active"
                }
              }
            }
          }
        },
        "operationId": "get-shipment-balance"
      }
    },
    "/orders": {
      "get": {
        "summary": "List orders",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of orders"
          }
        },
        "description": "List orders",
        "operationId": "get-orders"
      },
      "post": {
        "summary": "Create order",
        "description": "Creates a single letter order. Multiple API calls can be combined into one order if made on the same day with the same format/envelope/QR configuration.",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "template_id"
                ],
                "properties": {
                  "template_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "ID of the template to use"
                  },
                  "recipient_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "ID of an existing recipient (alternative to recipient object)"
                  },
                  "recipient": {
                    "$ref": "#/components/schemas/Recipient"
                  },
                  "sender_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "ID of an existing sender"
                  },
                  "personalization": {
                    "type": "object",
                    "additionalProperties": true,
                    "description": "Template variables for personalization"
                  },
                  "qr_code_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "ID of an existing QR code to link"
                  },
                  "envelope_template_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "ID einer Umschlag-Vorlage (siehe GET /v1/templates/envelopes). Optional -- wenn nicht angegeben, wird der Standard-Umschlag verwendet."
                  },
                  "customer_insert_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "ID einer eigenen Beilage (Brosch\u00fcre, Flyer etc.). Muss vorab im Dashboard angelegt und mit Lagerbestand versehen sein. Siehe GET /v1/customer-inserts."
                  },
                  "metadata": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created"
          }
        },
        "operationId": "post-orders"
      }
    },
