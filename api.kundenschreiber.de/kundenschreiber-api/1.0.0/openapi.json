    "/enrich-company": {
      "post": {
        "summary": "Enrich company data",
        "description": "Searches for a German company by name, website domain, or email address and returns official address data, management (CEO/directors), and contact information from the German trade register (Handelsregister). Ideal for CRM enrichment workflows.",
        "tags": [
          "Enrichment"
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "company_name": {
                    "type": "string",
                    "description": "Company name to search for (highest priority)"
                  },
                  "website": {
                    "type": "string",
                    "description": "Website URL or domain (e.g. 'example.de' or 'https://www.example.de')"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email address - domain will be extracted for search"
                  }
                }
              },
              "examples": {
                "by_name": {
                  "summary": "Search by company name",
                  "value": {
                    "company_name": "Kundenschreiber GmbH"
                  }
                },
                "by_website": {
                  "summary": "Search by website",
                  "value": {
                    "website": "kundenschreiber.de"
                  }
                },
                "by_email": {
                  "summary": "Search by email",
                  "value": {
                    "email": "info@kundenschreiber.de"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Company data found or not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "found": {
                      "type": "boolean"
                    },
                    "company": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "legal_form": {
                          "type": "string"
                        },
                        "register_number": {
                          "type": "string"
                        },
                        "register_court": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string"
                        },
                        "address": {
                          "type": "object",
                          "properties": {
                            "street": {
                              "type": "string"
                            },
                            "zip": {
                              "type": "string"
                            },
                            "city": {
                              "type": "string"
                            },
                            "country": {
                              "type": "string"
                            }
                          }
                        },
                        "management": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "first_name": {
                                "type": "string"
                              },
                              "last_name": {
                                "type": "string"
                              },
                              "role": {
                                "type": "string"
                              }
                            }
                          }
                        },
                        "contact": {
                          "type": "object",
                          "properties": {
                            "email": {
                              "type": "string"
                            },
                            "phone": {
                              "type": "string"
                            },
                            "website": {
                              "type": "string"
                            }
                          }
                        },
                        "incorporated_at": {
                          "type": "string",
                          "format": "date"
                        }
                      }
                    },
                    "openregister_id": {
                      "type": "string"
                    },
                    "confidence": {
                      "type": "string",
                      "enum": [
                        "high",
                        "medium",
                        "low"
                      ]
                    },
                    "message": {
                      "type": "string",
                      "description": "Only present when found=false"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields"
          },
          "403": {
            "description": "Missing enrichment:read scope"
          }
        },
        "operationId": "post-enrich-company"
      }
    }
