              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "campaign_id": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "short_code": {
