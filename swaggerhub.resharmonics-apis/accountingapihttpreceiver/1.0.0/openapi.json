{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "HTTP Accounting Export Receiver",
    "description": "The HTTP Accounting link in res:harmonics will send financial items to an HTTP endpoint. \n\nA Postman collection with example data can be viewed here - \n\n[Example post man collection](https://documenter.getpostman.com/view/9059/UzQuP5uE)\n",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/resharmonics-apis/AccountingAPIHTTPReceiver/1.0.0/swagger.json",
    "contact": {}
  },
  "paths": {
    "/": {
      "post": {
        "summary": "Receive items: receive finance items from res:harmonics",
        "description": "The HTTP Accounting link in res:harmonics will send financial items to an HTTP endpoint, the following describes the data model sent.",
        "operationId": "receiveItems",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FinanceExportDto"
              }
            }
          }
        },
        "tags": [
          "Finance Items"
        ],
        "responses": {
          "200": {
            "description": "Successful receipt of object: The payload has been successfully received for processing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FinanceExportDto": {
        "type": "object",
        "required": [
          "generatedDate",
          "outboundDto",
          "outboundType",
          "messageId",
          "accountCodeLookup",
          "organisationId",
          "tenant"
        ],
        "properties": {
          "generatedDate": {
            "type": "string",
            "description": "Date time when created"
          },
          "outboundDto": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "the type of object being received, representing invoices, payments or finance accounts",
                "enum": [
                  "invoicesOutboundDto",
                  "paymentsOutboundDto",
                  "financeAccountsOutboundDto"
                ]
              },
              "invoicePrefix": {
                "type": "string",
                "description": "The proposed prefix to be used on the invoices in the remote system, Can be ignored if not needed"
              },
              "invoices": {
                "type": "array",
                "description": "collection of the invoices to be exported. This will be populated for invoicesOutboundDto.",
                "items": {
                  "type": "object",
                  "properties": {
                    "financeAccount": {
                      "$ref": "#/components/schemas/FinanceAccount"
                    },
                    "invoiceNumber": {
                      "type": "string",
                      "description": "The invoice number"
                    },
                    "id": {
                      "type": "object",
                      "description": "Identifier object, reflecting the internal id in res:harmonics, and the external id from business central",
                      "properties": {
                        "type": {
                          "type": "string"
                        },
                        "id": {
                          "type": "number"
                        },
                        "externalId": {
                          "type": "string"
                        }
                      }
                    },
                    "totalNet": {
                      "type": "number",
                      "description": "The net amount of the invoice"
                    },
                    "totalTax": {
                      "type": "number",
                      "description": "The tax amount of the invoice"
                    },
                    "currencyCode": {
                      "type": "string",
                      "description": "the currency code"
                    },
                    "invoiceDate": {
                      "type": "string",
                      "description": "the invoice date"
                    },
                    "invoiceDueDate": {
                      "type": "string",
                      "description": "the invoice due date"
                    },
                    "invoiceReference": {
                      "type": "string",
                      "description": "the customer reference on the invoice"
                    },
                    "lineItems": {
                      "type": "array",
                      "description": "collection of the invoice lines on the invoice",
                      "items": {
                        "type": "object",
                        "properties": {
                          "itemId": {
                            "type": "number",
                            "description": "The product id from the PMS"
                          },
                          "description": {
                            "type": "string",
                            "description": "line item"
                          },
                          "itemCode": {
                            "type": "string",
                            "description": "The product code from the PMS, this should match a product code in the target finance system"
                          },
                          "taxType": {
                            "type": "string",
                            "description": "The tax code / type from the PMS."
                          },
                          "chargeFrom": {
                            "type": "string",
                            "description": "the start of the period of accommodation / service"
                          },
                          "chargeTo": {
                            "type": "string",
                            "description": "the end of the period of accommodation / service"
                          },
                          "quantity": {
                            "type": "number",
                            "description": "the quantity on the line"
                          },
                          "unitPriceNet": {
                            "type": "number",
                            "description": "the unit price net figure"
                          },
                          "totalNet": {
                            "type": "number",
                            "description": "the invoice line total net (in the base currency)"
                          },
                          "totalTax": {
                            "type": "number",
                            "description": "the invoice line total tax (in the base currency)"
                          },
                          "reportingNet": {
                            "type": "number",
                            "description": "the invoice line total net (in the invoice currency)"
                          },
                          "reportingTax": {
                            "type": "number",
                            "description": "the invoice line total tax (in the invoice currency)"
                          },
                          "taxRate": {
                            "type": "number",
                            "description": "the tax rate"
                          },
                          "trackingCategories": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "description": "the cost centre from the PMS used for additional layer of reporting"
                            }
                          }
                        }
                      }
                    },
                    "referralUrl": {
                      "type": "string",
                      "description": "The url to the invoice in res:harmonic"
                    },
                    "paymentTerm": {
                      "type": "number",
                      "description": "the number of days payment terms for the account"
                    }
                  }
                }
              },
              "accounts": {
                "type": "array",
                "description": "list of finance accounts to be exported. This is populated if the type is financeAccountsOutboundDto",
                "items": {
                  "$ref": "#/components/schemas/FinanceAccount"
                }
              },
              "payments": {
                "type": "array",
                "description": "list of payments",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "description": "type of payment"
                        },
                        "id": {
                          "type": "number",
                          "description": "the payment id in the PMS"
                        },
                        "externalId": {
                          "type": "string",
                          "description": "the external payment id in the finance system"
                        }
                      }
                    },
                    "financeAccount": {
                      "$ref": "#/components/schemas/FinanceAccount"
                    },
                    "financialDate": {
                      "type": "string"
                    },
                    "reference": {
                      "type": "string"
                    },
                    "amount": {
                      "type": "number"
                    },
                    "paymentType": {
                      "type": "string"
                    },
                    "sourceFinancialId": {
                      "type": "string"
                    },
                    "targetFinancialId": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": [
                            "INVOICE"
                          ]
                        },
                        "id": {
                          "type": "number"
                        },
                        "externalId": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "outboundType": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "The type of the object to be exported, the first object in the array will always be xeroRequestType. The second object is the type of DTO depending on the whether the object is a Finance Account / Invoice / Payments",
              "enum": [
                "EXPORT_CONTACTS",
                "EXPORT_INVOICES",
                "EXPORT_PAYMENTS",
                "xeroRequestType"
              ]
            }
          },
          "messageId": {
            "type": "string"
          },
          "pem": {
            "type": "string",
            "nullable": true
          },
          "consumerKey": {
            "type": "string",
            "nullable": true
          },
          "consumerSecretKey": {
            "type": "string",
            "nullable": true
          },
          "accountCodeLookup": {
            "type": "boolean"
          },
          "organisationId": {
            "type": "number"
          },
          "deferralAccountName": {
            "type": "string",
            "nullable": true
          },
          "clientAppId": {
            "type": "string",
            "nullable": true
          },
          "clientSecretId": {
            "type": "string",
            "nullable": true
          },
          "accessToken": {
            "type": "string",
            "nullable": true
          },
          "refreshToken": {
            "type": "string",
            "nullable": true
          },
          "realmId": {
            "type": "string",
            "nullable": true
          },
          "tenant": {
            "type": "string"
          }
        }
      },
      "Result": {
        "type": "object",
        "required": [
          "success",
          "message"
        ],
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string",
            "description": "The message for success / failure"
          }
        }
      },
      "FinanceAccount": {
        "type": "object",
        "description": "The resharmonics Finance Account, this is the CRM account / debtor / creditor for the financial item",
        "properties": {
          "type": {
            "type": "string",
            "description": "The type of finance account - Contact or company",
            "enum": [
              "CONTACT",
              "COMAPNY"
            ]
          },
          "accountNumber": {
            "type": "string",
            "description": "The unique account number in res:harmonics"
          },
          "accountId": {
            "type": "number",
            "description": "The unique account id in res:harmonics"
          },
          "externalId": {
            "type": "string",
            "description": "The unique external identifier in the remote system, Business Central. This is populated during the export to BC."
          },
          "emailAddress": {
            "type": "string",
            "description": "Email address of the finance account"
          },
          "accountName": {
            "type": "string",
            "description": "The name on the account - company name or firstname / last name for a contact"
          },
          "paymentTerm": {
            "type": "number",
            "description": "number of days for payment due date from invoice date"
          },
          "firstName": {
            "type": "string",
            "description": "first name of contact if not a company"
          },
          "lastName": {
            "type": "string",
            "description": "last name of contact if not a company"
          },
          "addressLine1": {
            "type": "string",
            "description": "Address line 1"
          },
          "addressLine2": {
            "type": "string",
            "description": "Address line 2"
          },
          "addressLine3": {
            "type": "string",
            "description": "Address line 3"
          },
          "city": {
            "type": "string",
            "description": "City"
          },
          "postCode": {
            "type": "string",
            "description": "Postcode"
          },
          "countryCode": {
            "type": "string",
            "description": "ISO country code of debtor"
          },
          "telephoneNumber": {
            "type": "string",
            "description": "Telephone number"
          }
        }
      }
    },
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  },
  "security": [
    {
      "BasicAuth": []
    }
  ],
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/resharmonics-apis/AccountingAPIHTTPReceiver/1.0.0"
    },
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/resharmonics-apis/tester/1.0.0"
    }
  ],
  "tags": [
    {
      "name": "Finance Items"
    }
  ]
}
