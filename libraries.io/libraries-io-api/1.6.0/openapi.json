{
  "openapi": "3.0.3",
  "info": {
    "title": "Libraries.io API",
    "version": "1.6.0",
    "description": "Libraries.io API for searching open source packages, their versions, dependencies, and repository metadata across multiple package managers.",
    "x-jentic-source-url": "https://libraries.io/api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://libraries.io/api"
    }
  ],
  "tags": [
    {
      "name": "Platforms",
      "description": "Package manager platforms"
    },
    {
      "name": "Projects",
      "description": "Package/project information"
    },
    {
      "name": "Repositories",
      "description": "Source code repositories"
    },
    {
      "name": "Users",
      "description": "User information and subscriptions"
    },
    {
      "name": "Subscriptions",
      "description": "Package subscription management"
    },
    {
      "name": "Search",
      "description": "Search for projects"
    }
  ],
  "paths": {
    "/platforms": {
      "get": {
        "operationId": "listPlatforms",
        "summary": "Get list of supported package managers",
        "tags": [
          "Platforms"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your API key"
          }
        ],
        "responses": {
          "200": {
            "description": "List of platforms",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Platform"
                  }
                }
              }
            }
          }
        },
        "description": "Get list of supported package managers"
      }
    },
    "/{platform}/{name}": {
      "get": {
        "operationId": "getProject",
        "summary": "Get information about a package",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "name": "platform",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Package manager (e.g. NPM, Pypi, Maven)"
          },
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Project name"
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your API key"
          }
        ],
        "responses": {
          "200": {
            "description": "Project details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          }
        },
        "description": "Get information about a package"
      }
    },
