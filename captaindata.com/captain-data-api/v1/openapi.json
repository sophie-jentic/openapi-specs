      "post": {
        "operationId": "launchWorkflow",
        "summary": "Launch a workflow",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "inputs": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "account_uid": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workflow launched"
