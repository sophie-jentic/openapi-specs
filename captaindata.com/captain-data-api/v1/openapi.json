    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Workflows",
      "description": "Workflow management"
    },
    {
      "name": "Jobs",
      "description": "Job management"
    },
    {
      "name": "Results",
      "description": "Result retrieval"
    },
    {
      "name": "Accounts",
      "description": "Account management"
    },
    {
      "name": "Webhooks",
      "description": "Webhook management"
    }
