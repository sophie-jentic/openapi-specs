{
  "openapi": "3.0.3",
  "info": {
    "title": "Synthetix API",
    "version": "2.0.0",
    "description": "Synthetix is a decentralized derivatives liquidity protocol on Ethereum. The API provides access to market data, exchange rates, and trading information for synthetic assets (Synths). Supports perpetual futures, spot synths, and staking data.",
    "x-jentic-source-url": "https://docs.synthetix.io/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.synthetix.io/v2"
    }
  ],
  "paths": {
    "/markets": {
      "get": {
        "operationId": "getMarkets",
        "summary": "List Markets",
        "description": "Returns a list of available perpetual futures markets.",
        "tags": [
          "Markets"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/markets/{market}": {
      "get": {
        "operationId": "getMarket",
        "summary": "Get Market",
        "description": "Returns details for a specific market.",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "market",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Market symbol (e.g. sETH, sBTC)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
