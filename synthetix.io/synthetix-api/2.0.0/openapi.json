    "/volume": {
      "get": {
        "operationId": "getVolume",
        "summary": "Get Trading Volume",
        "description": "Returns trading volume statistics.",
        "tags": [
          "Volume"
        ],
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "24h",
                "7d",
                "30d"
              ]
            },
            "description": "Time period"
          }
        ],
        "responses": {
          "200": {
