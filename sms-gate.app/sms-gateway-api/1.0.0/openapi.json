{
  "openapi": "3.0.3",
  "info": {
    "title": "SMS Gateway API",
    "version": "1.0.0",
    "description": "A secure, open-source REST API for sending and receiving SMS messages via Android devices. Supports text messages, data SMS, encrypted messages, message tracking, device management, webhooks, and settings configuration.",
    "x-jentic-source-url": "https://sms-gate.app/docs/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.sms-gate.app/3rdparty/v1"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Health check",
        "description": "Returns overall health status of the gateway",
        "tags": [
          "Health"
        ],
        "responses": {
          "200": {
            "description": "Service is healthy"
          },
          "503": {
            "description": "Service unavailable"
          }
        },
        "security": []
      }
    },
    "/health/startup": {
      "get": {
        "operationId": "getHealthStartup",
        "summary": "Startup health check",
        "description": "Returns startup health status",
        "tags": [
          "Health"
        ],
        "responses": {
          "200": {
            "description": "Service started"
          },
          "503": {
            "description": "Service not yet started"
          }
        },
        "security": []
      }
    },
    "/health/ready": {
      "get": {
        "operationId": "getHealthReady",
        "summary": "Readiness check",
        "description": "Returns readiness status",
        "tags": [
          "Health"
        ],
        "responses": {
          "200": {
            "description": "Service is ready"
          },
          "503": {
            "description": "Service not ready"
          }
        },
        "security": []
      }
    },
    "/health/live": {
      "get": {
        "operationId": "getHealthLive",
        "summary": "Liveness check",
        "description": "Returns liveness status",
        "tags": [
          "Health"
        ],
        "responses": {
          "200": {
            "description": "Service is alive"
          },
          "503": {
            "description": "Service not alive"
          }
        },
        "security": []
      }
    },
    "/messages": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send SMS message",
        "description": "Send an SMS message to one or more phone numbers. Supports text messages, data messages, and encrypted messages.",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "skipPhoneValidation",
            "in": "query",
            "description": "Skip phone number validation",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "deviceActiveWithin",
            "in": "query",
            "description": "Only use devices active within this many seconds",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listMessages",
        "summary": "List messages",
        "description": "Retrieve a list of messages with optional filters",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "Filter messages from this date",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "to",
            "in": "query",
            "description": "Filter messages until this date",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "Filter by message state",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Pending",
                "Sent",
                "Delivered",
                "Failed"
              ]
            }
          },
          {
            "name": "deviceId",
            "in": "query",
            "description": "Filter by device ID",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Offset for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of messages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageResponse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/messages/{id}": {
      "get": {
        "operationId": "getMessage",
        "summary": "Get message by ID",
        "description": "Retrieve a specific message by its ID",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Message ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Message details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
