            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Message not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/messages/inbox/export": {
      "post": {
        "operationId": "exportInboxMessages",
        "summary": "Export inbox messages",
        "description": "Export received inbox messages for a given time range and optional device",
        "tags": [
