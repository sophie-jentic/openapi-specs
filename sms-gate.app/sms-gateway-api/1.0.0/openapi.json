                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SendMessageRequest": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Text message content"
          },
          "textMessage": {
            "type": "object",
            "description": "Text message object",
            "properties": {
              "text": {
                "type": "string"
              }
            }
          },
          "dataMessage": {
            "type": "object",
            "description": "Data SMS message",
            "properties": {
              "data": {
                "type": "string",
                "description": "Base64-encoded data"
              },
              "port": {
                "type": "integer",
                "description": "Port number"
              }
            }
          },
          "phoneNumbers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of phone numbers to send to"
          },
          "ttl": {
            "type": "integer",
            "description": "Time to live in seconds"
          },
          "withDeliveryReport": {
            "type": "boolean",
            "description": "Request delivery report",
            "default": false
          },
          "priority": {
            "type": "integer",
            "description": "Message priority (0-127)"
          },
          "simNumber": {
            "type": "integer",
            "description": "SIM card number to use"
          },
          "isEncrypted": {
            "type": "boolean",
            "description": "Whether the message is encrypted",
            "default": false
          }
        },
        "required": [
          "phoneNumbers"
        ]
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Message ID"
          },
          "state": {
            "type": "string",
            "enum": [
              "Pending",
              "Sent",
              "Delivered",
              "Failed"
            ],
            "description": "Message state"
          },
          "message": {
            "type": "string",
            "description": "Message text"
          },
          "phoneNumbers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "InboxExportRequest": {
        "type": "object",
        "properties": {
          "since": {
            "type": "string",
            "format": "date-time",
            "description": "Start date for export"
          },
          "until": {
            "type": "string",
            "format": "date-time",
            "description": "End date for export"
          },
          "deviceId": {
            "type": "string",
            "description": "Device ID to filter by"
          }
        },
        "required": [
          "since",
          "until"
        ]
      },
      "Device": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Device ID"
          },
          "name": {
            "type": "string",
            "description": "Device name"
          },
          "lastSeen": {
            "type": "string",
            "format": "date-time",
            "description": "Last activity timestamp"
          }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Webhook ID"
          },
          "url": {
            "type": "string",
            "description": "Webhook URL"
          },
          "event": {
            "type": "string",
            "description": "Event type",
            "enum": [
              "sms:received"
            ]
          }
        }
      },
      "WebhookCreateRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Optional webhook ID"
          },
          "url": {
            "type": "string",
            "description": "Webhook callback URL"
          },
          "event": {
            "type": "string",
            "description": "Event to subscribe to",
            "enum": [
              "sms:received"
            ]
          }
        },
        "required": [
          "url",
          "event"
        ]
      },
      "LogEntry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "level": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
