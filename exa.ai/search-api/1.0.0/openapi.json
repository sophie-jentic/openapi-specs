{
  "openapi": "3.0.3",
  "info": {
    "title": "Exa Search API",
    "version": "1.0.0",
    "description": "Exa is an AI-powered search engine designed for use by AI agents and applications. The API provides neural and keyword search, content retrieval, and similar-link discovery. Exa understands natural language queries and returns clean, structured results.",
    "x-jentic-source-url": "https://exa.ai/docs/reference/search",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.exa.ai",
      "description": "Exa API"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Search",
      "description": "Search the web"
    },
    {
      "name": "Contents",
      "description": "Get page contents"
    },
    {
      "name": "Similar",
      "description": "Find similar pages"
    }
  ],
  "paths": {
    "/search": {
      "post": {
        "operationId": "search",
        "summary": "Search the web",
        "description": "Performs a neural or keyword search and returns a list of results with URLs, titles, and optional content. Use 'neural' type for natural language queries and 'keyword' for traditional keyword matching.",
        "tags": [
          "Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/contents": {
      "post": {
        "operationId": "getContents",
        "summary": "Get page contents",
        "description": "Retrieves the content of pages given their URLs or IDs. Returns clean text, HTML, or highlights from the pages.",
        "tags": [
          "Contents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContentsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Page contents",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/findSimilar": {
      "post": {
        "operationId": "findSimilar",
        "summary": "Find similar pages",
        "description": "Finds web pages similar to a given URL. Useful for finding competitors, related content, or similar products.",
        "tags": [
          "Similar"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindSimilarRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Similar results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Exa API key passed as Bearer token"
      }
    },
    "schemas": {
      "SearchRequest": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "The search query (natural language for neural, keywords for keyword search)"
          },
          "type": {
            "type": "string",
            "enum": [
              "neural",
              "keyword",
              "auto"
            ],
            "default": "auto",
            "description": "Search type"
          },
          "useAutoprompt": {
            "type": "boolean",
            "default": false,
            "description": "Let Exa rephrase the query for better results"
          },
          "numResults": {
            "type": "integer",
            "default": 10,
            "description": "Number of results to return (max 100)"
          },
          "includeDomains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Only include results from these domains"
          },
          "excludeDomains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Exclude results from these domains"
          },
          "startCrawlDate": {
            "type": "string",
            "format": "date-time",
            "description": "Only return pages crawled after this date"
          },
          "endCrawlDate": {
            "type": "string",
            "format": "date-time",
            "description": "Only return pages crawled before this date"
          },
          "startPublishedDate": {
            "type": "string",
            "format": "date-time",
            "description": "Only return pages published after this date"
          },
          "endPublishedDate": {
            "type": "string",
            "format": "date-time",
            "description": "Only return pages published before this date"
          },
          "category": {
            "type": "string",
            "description": "Filter by category (e.g. company, research_paper, news, pdf, github, tweet, etc.)"
          },
          "contents": {
            "$ref": "#/components/schemas/ContentsOptions"
          }
        }
      },
      "ContentsOptions": {
        "type": "object",
        "properties": {
          "text": {
            "type": "object",
            "properties": {
              "maxCharacters": {
                "type": "integer",
                "description": "Max characters of text to return"
              },
              "includeHtmlTags": {
                "type": "boolean",
                "default": false
              }
            }
          },
          "highlights": {
            "type": "object",
            "properties": {
              "numSentences": {
                "type": "integer",
                "description": "Number of highlight sentences"
              },
              "highlightsPerUrl": {
                "type": "integer",
                "description": "Number of highlights per URL"
              },
              "query": {
                "type": "string",
                "description": "Custom query for highlights"
              }
            }
          },
          "summary": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string",
                "description": "Custom query for summary"
              }
            }
          }
        }
      },
      "ContentsRequest": {
        "type": "object",
        "required": [
          "ids"
        ],
        "properties": {
          "ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of document IDs or URLs to retrieve content for"
          },
          "text": {
            "type": "object",
            "properties": {
              "maxCharacters": {
                "type": "integer"
              },
              "includeHtmlTags": {
                "type": "boolean",
                "default": false
              }
            }
          },
          "highlights": {
            "type": "object",
            "properties": {
              "numSentences": {
                "type": "integer"
              },
              "highlightsPerUrl": {
                "type": "integer"
              },
              "query": {
                "type": "string"
              }
            }
          },
          "summary": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string"
              }
            }
          }
        }
      },
      "FindSimilarRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "description": "The URL to find similar pages for"
          },
          "numResults": {
            "type": "integer",
            "default": 10
          },
          "includeDomains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "excludeDomains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "startCrawlDate": {
            "type": "string",
            "format": "date-time"
          },
          "endCrawlDate": {
            "type": "string",
            "format": "date-time"
          },
          "startPublishedDate": {
            "type": "string",
            "format": "date-time"
          },
          "endPublishedDate": {
            "type": "string",
            "format": "date-time"
          },
          "category": {
            "type": "string"
          },
          "excludeSourceDomain": {
            "type": "boolean",
            "description": "Exclude results from the source domain"
          },
          "contents": {
            "$ref": "#/components/schemas/ContentsOptions"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchResult"
            }
          },
          "autopromptString": {
            "type": "string",
            "description": "The autoprompted query if useAutoprompt was True"
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "publishedDate": {
            "type": "string",
            "format": "date-time"
          },
          "author": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "description": "Relevance score"
          },
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string",
            "description": "Page text content (if requested)"
          },
          "highlights": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Highlighted sentences (if requested)"
          },
          "highlightScores": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "summary": {
            "type": "string",
            "description": "AI summary (if requested)"
          }
        }
      },
      "ContentsResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchResult"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
