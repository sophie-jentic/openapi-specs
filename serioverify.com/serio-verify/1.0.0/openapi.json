      "delete": {
        "operationId": "deleteZapierHookUrl",
        "tags": [
          "Webhooks"
        ],
        "summary": "Delete a Zapier webhook URL",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook URL deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
