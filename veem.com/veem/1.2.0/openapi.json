    "/exchange-rate": {
      "post": {
        "summary": "Get exchange rate",
        "description": "Get current exchange rates",
        "operationId": "getExchangeRate",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "fromCurrency",
                  "toCurrency",
                  "amount"
                ],
                "properties": {
                  "fromCurrency": {
                    "type": "string",
                    "description": "Source currency code"
                  },
                  "toCurrency": {
                    "type": "string",
                    "description": "Target currency code"
                  },
                  "amount": {
                    "type": "number",
                    "description": "Amount to convert"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Exchange rate information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fromCurrency": {
                      "type": "string"
                    },
                    "toCurrency": {
                      "type": "string"
                    },
                    "rate": {
                      "type": "number"
                    },
                    "amount": {
                      "type": "number"
                    },
                    "convertedAmount": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "exchange-rate"
        ]
      }
    }
