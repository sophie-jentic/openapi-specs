{
  "openapi": "3.0.3",
  "info": {
    "title": "Vuala API",
    "version": "1.0.0",
    "description": "Vuala (Vualapp) API for managing invoices and webhook destinations for business card and invoice processing.",
    "x-jentic-source-url": "https://docs.google.com/document/d/e/2PACX-1vSN8DHicBq8kkgSqUNtU-zQHMyc4wimhFSaLpp2NFeTWEv7X9fk0KiqyFBo2bYgOFPyWe-6NZiPxIT9/pub",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://business-api.vualapp.com"
    }
  ],
  "paths": {
    "/hello": {
      "get": {
        "operationId": "hello",
        "summary": "Verify API connectivity",
        "tags": [
          "General"
        ],
        "responses": {
          "200": {
            "description": "Hello response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Verify API connectivity"
      }
    },
    "/zapier/latest": {
      "get": {
        "operationId": "getLatestInvoice",
        "summary": "Get the latest invoice",
        "tags": [
          "Invoices"
        ],
        "responses": {
          "200": {
            "description": "Latest invoice",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Invoice"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get the latest invoice"
      }
    },
    "/zapier/new": {
      "post": {
        "operationId": "registerWebhook",
        "summary": "Register a webhook destination",
        "tags": [
          "Webhooks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "webhook_url"
                ],
                "properties": {
                  "webhook_url": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook registered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    },
                    "webhook_url": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Register a webhook destination"
      }
    },
    "/zapier/{id}": {
      "delete": {
        "operationId": "deleteWebhook",
        "summary": "Delete a webhook destination",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete a webhook destination"
      }
    }
  },
  "components": {
    "schemas": {
      "Invoice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "file_name": {
            "type": "string"
          },
          "hosted_file_url": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "General"
    },
    {
      "name": "Invoices"
    },
    {
      "name": "Webhooks"
    }
  ]
}
