{
  "openapi": "3.0.3",
  "info": {
    "title": "Plate Recognizer API",
    "version": "1.0.0",
    "description": "Automatic license plate recognition API. Read number plates from images and get vehicle information.",
    "x-jentic-source-url": "https://guides.platerecognizer.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.platerecognizer.com/v1"
    }
  ],
  "paths": {
    "/plate-reader": {
      "post": {
        "operationId": "readPlate",
        "summary": "Read number plates from an image",
        "tags": [
          "Recognition"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "upload": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image file"
                  },
                  "upload_url": {
                    "type": "string",
                    "description": "URL of image to process"
                  },
                  "regions": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Country/state codes for plate pattern matching"
                  },
                  "camera_id": {
                    "type": "string",
                    "description": "Unique camera identifier"
                  },
                  "timestamp": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 UTC timestamp"
                  },
                  "mmc": {
                    "type": "boolean",
                    "description": "Enable make/model/color prediction"
                  },
                  "config": {
                    "type": "string",
                    "description": "JSON engine configuration"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Plates recognized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlateReaderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Read number plates from an image"
      }
    },
    "/statistics": {
      "get": {
        "operationId": "getStatistics",
        "summary": "Get API usage statistics",
        "tags": [
          "Statistics"
        ],
        "responses": {
          "200": {
            "description": "Usage statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Statistics"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get API usage statistics"
      }
    }
  },
  "components": {
    "schemas": {
      "PlateReaderResponse": {
        "type": "object",
        "properties": {
          "processing_time": {
            "type": "number"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PlateResult"
            }
          },
          "filename": {
            "type": "string"
          },
          "version": {
            "type": "integer"
          },
          "camera_id": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        }
      },
      "PlateResult": {
        "type": "object",
        "properties": {
          "box": {
            "type": "object",
            "properties": {
              "xmin": {
                "type": "integer"
              },
              "ymin": {
                "type": "integer"
              },
              "xmax": {
                "type": "integer"
              },
              "ymax": {
                "type": "integer"
              }
            }
          },
          "plate": {
            "type": "string"
          },
          "region": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "score": {
                "type": "number"
              }
            }
          },
          "score": {
            "type": "number"
          },
          "candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "score": {
                  "type": "number"
                },
                "plate": {
                  "type": "string"
                }
              }
            }
          },
          "dscore": {
            "type": "number"
          },
          "vehicle": {
            "type": "object",
            "properties": {
              "score": {
                "type": "number"
              },
              "type": {
                "type": "string"
              },
              "box": {
                "type": "object"
              }
            }
          }
        }
      },
      "Statistics": {
        "type": "object",
        "properties": {
          "usage": {
            "type": "object",
            "properties": {
              "month": {
                "type": "integer"
              },
              "calls": {
                "type": "integer"
              },
              "year": {
                "type": "integer"
              },
              "resets_on": {
                "type": "string"
              },
              "total_calls": {
                "type": "integer"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token YOUR_API_TOKEN"
      }
    }
  },
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "Recognition"
    },
    {
      "name": "Statistics"
    }
  ]
}
