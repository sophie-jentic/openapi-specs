{
  "openapi": "3.0.0",
  "info": {
    "version": "1.02",
    "title": "Order Status Update",
    "description": "**Overview**\n\nCustomer will need to implement this API specification in order to receive updates as orders are fulfilled. Please provide the finished endpoint(s) to APA for integration.\n\nIdeally customer will provide a development/sandbox version of this API as well that can be used during development without interrupting services for the customer.\n\n**Security**\n\nTransport security shall use TLS (HTTPS requests).  Securing access to the api will be handled by the api key being sent in the header.\n",
    "contact": {},
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/apa/apipostback.divvy.systems/1.02/swagger.json"
  },
  "paths": {
    "/printing/{orderKey1}": {
      "put": {
        "description": "Receive updated statuses for the specified order",
        "summary": "Updateprintingstatus",
        "tags": [
          "Printing"
        ],
        "operationId": "PrintingByOrderKey1Put",
        "parameters": [
          {
            "name": "orderKey1",
            "in": "path",
            "required": true,
            "description": "key sent in original request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK (success)"
          }
        },
        "security": [
          {
            "API-KEY": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StatusUpdate"
              }
            }
          }
        }
      }
    },
    "/shipped/{orderKey1}": {
      "put": {
        "description": "Shipments that was created for the order.",
        "summary": "OrderShipped",
        "tags": [
          "Shipped"
        ],
        "operationId": "ShippedByOrderKey1Put",
        "parameters": [
          {
            "name": "orderKey1",
            "in": "path",
            "required": true,
            "description": "Order key sent in original request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "API-KEY": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Shipment"
              }
            }
          }
        }
      }
    },
    "/error/{orderKey1}": {
      "put": {
        "description": "Error",
        "summary": "Error",
        "tags": [
          "Error"
        ],
        "operationId": "ErrorByOrderKey1Put",
        "parameters": [
          {
            "name": "orderKey1",
            "in": "path",
            "required": true,
            "description": "key sent in original request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "API-KEY": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Error"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Printing",
      "description": ""
    },
    {
      "name": "Shipped",
      "description": ""
    },
    {
      "name": "Error",
      "description": ""
    }
  ],
  "servers": [
    {
      "url": "https://virtserver.swaggerhub.com/apa/apipostback.divvy.systems/1.0.0"
    },
    {
      "url": "http://virtserver.swaggerhub.com/apa/apipostback.divvy.systems/1.0.0"
    }
  ],
  "components": {
    "securitySchemes": {
      "API-KEY": {
        "type": "apiKey",
        "description": "Partner API key provided by Alexanders. Used in header to authorize.",
        "name": "X-API-KEY",
        "in": "header"
      }
    },
    "schemas": {
      "StatusUpdate": {
        "title": "StatusUpdate",
        "type": "object",
        "properties": {
          "dueDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Shipment": {
        "title": "Shipment",
        "type": "object",
        "properties": {
          "shipMethod": {
            "example": "1st class ground",
            "type": "string"
          },
          "carrier": {
            "example": "UPS",
            "type": "string"
          },
          "trackingNumber": {
            "type": "string"
          },
          "dateShipped": {
            "type": "string",
            "format": "date-time"
          },
          "cost": {
            "description": "This is in cents, so $11.50 = 1150",
            "example": 1150,
            "type": "number",
            "format": "double"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ShipmentItem"
            }
          }
        }
      },
      "ShipmentItem": {
        "title": "ShipmentItem",
        "type": "object",
        "properties": {
          "itemKey": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "format": "integer"
          }
        }
      },
      "Error": {
        "title": "Error",
        "type": "object",
        "properties": {
          "itemKey": {
            "description": "Unique item identifier (for the order), may not be set if error applies to the entire order",
            "type": "string"
          },
          "message": {
            "description": "Message",
            "example": "Failed to download item",
            "type": "string"
          }
        }
      }
    }
  }
}
