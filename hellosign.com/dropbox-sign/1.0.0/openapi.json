          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/signature_request/{signature_request_id}": {
      "get": {
        "summary": "Get signature request",
        "description": "Fetch specific signature request details",
        "operationId": "getSignatureRequest",
        "tags": [
          "Signature Requests"
        ],
        "parameters": [
          {
            "name": "signature_request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the signature request"
          }
        ],
        "responses": {
          "200": {
            "description": "Signature request retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignatureRequest"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/signature_request/list": {
      "get": {
        "summary": "List signature requests",
        "description": "List all signature requests",
        "operationId": "listSignatureRequests",
        "tags": [
          "Signature Requests"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Signature requests retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "signature_requests": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/SignatureRequest"
                      }
                    }
                  }
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/signature_request/send": {
      "post": {
        "summary": "Send signature request",
        "description": "Initiate a new signature request",
        "operationId": "sendSignatureRequest",
        "tags": [
          "Signature Requests"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "files",
                  "signers"
                ],
                "properties": {
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  },
                  "file_urls": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "uri"
                    }
                  },
                  "title": {
                    "type": "string"
                  },
                  "subject": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  },
                  "signers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "email_address": {
                          "type": "string",
                          "format": "email"
                        },
                        "name": {
                          "type": "string"
                        },
                        "order": {
                          "type": "integer"
                        }
                      }
                    }
                  },
                  "cc_email_addresses": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "email"
                    }
                  },
                  "use_text_tags": {
                    "type": "boolean"
                  },
                  "test_mode": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signature request sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignatureRequest"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/signature_request/send_with_template": {
      "post": {
        "summary": "Send signature request with template",
        "description": "Send a signature request using a template",
        "operationId": "sendSignatureRequestWithTemplate",
        "tags": [
          "Signature Requests"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "template_id",
                  "signers"
                ],
                "properties": {
                  "template_id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "subject": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  },
                  "signers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": {
                          "type": "string"
                        },
                        "email_address": {
                          "type": "string",
                          "format": "email"
                        },
                        "name": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "custom_fields": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "test_mode": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signature request sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignatureRequest"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/signature_request/bulk_send_with_template": {
      "post": {
        "summary": "Bulk send with template",
        "description": "Send multiple signature requests using a template",
        "operationId": "bulkSendWithTemplate",
        "tags": [
          "Signature Requests"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "template_id",
                  "signer_list"
                ],
                "properties": {
                  "template_id": {
                    "type": "string"
                  },
                  "signer_list": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "test_mode": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk send initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkSendJob"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/signature_request/files/{signature_request_id}": {
      "get": {
        "summary": "Download signature request files",
        "description": "Download completed documents for a signature request",
        "operationId": "downloadSignatureRequestFiles",
        "tags": [
          "Signature Requests"
        ],
        "parameters": [
          {
            "name": "signature_request_id",
            "in": "path",
