{
  "openapi": "3.0.3",
  "info": {
    "title": "Azure AI Vision API",
    "description": "Azure AI Vision (Computer Vision) provides AI algorithms for processing images and returning information. Features include image analysis (captions, tags, objects, people), OCR/text extraction, smart cropping, and background removal. Part of Azure Cognitive Services.",
    "version": "2024-02-01",
    "contact": {
      "name": "Microsoft Azure Support",
      "url": "https://azure.microsoft.com/support"
    },
    "x-jentic-source-url": "https://learn.microsoft.com/en-us/azure/ai-services/computer-vision/overview"
  },
  "externalDocs": {
    "description": "Azure AI Vision Documentation",
    "url": "https://learn.microsoft.com/en-us/azure/ai-services/computer-vision/"
  },
  "servers": [
    {
      "url": "https://{endpoint}/computervision",
      "description": "Azure AI Vision endpoint",
      "variables": {
        "endpoint": {
          "default": "{your-resource-name}.cognitiveservices.azure.com",
          "description": "Your Azure Cognitive Services resource endpoint"
        }
      }
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    },
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Image Analysis",
      "description": "Analyze images to extract visual features"
    },
    {
      "name": "OCR",
      "description": "Optical character recognition for text extraction"
    },
    {
      "name": "Spatial Analysis",
      "description": "Spatial analysis and smart cropping"
    }
  ],
  "paths": {
    "/imageanalysis:analyze": {
      "post": {
        "operationId": "analyzeImage",
        "summary": "Analyze Image",
        "description": "Analyze an image to extract visual features including captions, dense captions, tags, objects, people, smart crops, and text (OCR). Image Analysis 4.0 API.",
        "tags": [
          "Image Analysis"
        ],
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "description": "API version",
            "schema": {
              "type": "string",
              "default": "2024-02-01"
            }
          },
          {
            "name": "features",
            "in": "query",
            "required": true,
            "description": "Visual features to extract (comma-separated)",
            "schema": {
              "type": "string"
            },
            "example": "caption,tags,objects,read"
          },
          {
            "name": "language",
            "in": "query",
            "description": "Language for results (e.g., en, ja, pt)",
            "schema": {
              "type": "string",
              "default": "en"
            }
          },
          {
            "name": "gender-neutral-caption",
            "in": "query",
            "description": "Use gender-neutral terms in captions",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "smartcrops-aspect-ratios",
            "in": "query",
            "description": "Aspect ratios for smart cropping (comma-separated decimals)",
            "schema": {
              "type": "string"
            },
            "example": "0.9,1.33"
          },
          {
            "name": "model-version",
            "in": "query",
            "description": "Model version to use",
            "schema": {
              "type": "string",
              "default": "latest"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Publicly accessible URL of the image"
                  }
                }
              }
            },
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary",
                "description": "Raw image binary data"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Analysis results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageAnalysisResult"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Resource not found"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/models": {
      "get": {
        "operationId": "listModels",
        "summary": "List Models",
        "description": "List available domain-specific models for image analysis.",
        "tags": [
          "Image Analysis"
        ],
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "default": "2024-02-01"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Available models",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "models": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "categories": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/retrieval:vectorizeImage": {
      "post": {
        "operationId": "vectorizeImage",
        "summary": "Vectorize Image",
        "description": "Generate a feature vector (embedding) for an image for use in image retrieval and similarity search.",
        "tags": [
          "Image Analysis"
        ],
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "default": "2024-02-01"
            }
          },
          {
            "name": "model-version",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "latest"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              }
            },
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image vector",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "modelVersion": {
                      "type": "string"
                    },
                    "vector": {
                      "type": "array",
                      "items": {
                        "type": "number",
                        "format": "float"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/retrieval:vectorizeText": {
      "post": {
        "operationId": "vectorizeText",
        "summary": "Vectorize Text",
        "description": "Generate a feature vector (embedding) for text for use in image retrieval via text-to-image search.",
        "tags": [
          "Image Analysis"
        ],
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "default": "2024-02-01"
            }
          },
          {
            "name": "model-version",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "latest"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Text to vectorize"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text vector",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "modelVersion": {
                      "type": "string"
                    },
                    "vector": {
                      "type": "array",
                      "items": {
                        "type": "number",
                        "format": "float"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/imageanalysis:segment": {
      "post": {
        "operationId": "segmentImage",
        "summary": "Segment Image (Background Removal)",
        "description": "Segment an image to separate foreground from background. Supports returning a foreground matte or the image with background removed.",
        "tags": [
          "Spatial Analysis"
        ],
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "default": "2024-02-01"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "required": true,
            "description": "Segmentation mode",
            "schema": {
              "type": "string",
              "enum": [
                "backgroundRemoval",
                "foregroundMatting"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              }
            },
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Segmented image",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Ocp-Apim-Subscription-Key",
        "description": "Azure Cognitive Services subscription key"
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Azure Active Directory bearer token"
      }
    },
    "schemas": {
      "ImageAnalysisResult": {
        "type": "object",
        "properties": {
          "modelVersion": {
            "type": "string"
          },
          "captionResult": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string",
                "description": "Generated caption text"
              },
              "confidence": {
                "type": "number",
                "format": "float"
              }
            }
          },
          "denseCaptionsResult": {
            "type": "object",
            "properties": {
              "values": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string"
                    },
                    "confidence": {
                      "type": "number",
                      "format": "float"
                    },
                    "boundingBox": {
                      "$ref": "#/components/schemas/BoundingBox"
                    }
                  }
                }
              }
            }
          },
          "tagsResult": {
            "type": "object",
            "properties": {
              "values": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "confidence": {
                      "type": "number",
                      "format": "float"
                    }
                  }
                }
              }
            }
          },
          "objectsResult": {
            "type": "object",
            "properties": {
              "values": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "boundingBox": {
                      "$ref": "#/components/schemas/BoundingBox"
                    },
                    "tags": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "confidence": {
                            "type": "number",
                            "format": "float"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "peopleResult": {
            "type": "object",
            "properties": {
              "values": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "boundingBox": {
                      "$ref": "#/components/schemas/BoundingBox"
                    },
                    "confidence": {
                      "type": "number",
                      "format": "float"
                    }
                  }
                }
              }
            }
          },
          "readResult": {
            "type": "object",
            "description": "OCR/text extraction results",
            "properties": {
              "blocks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "lines": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "text": {
                            "type": "string"
                          },
                          "boundingPolygon": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "x": {
                                  "type": "integer"
                                },
                                "y": {
                                  "type": "integer"
                                }
                              }
                            }
                          },
                          "words": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "text": {
                                  "type": "string"
                                },
                                "boundingPolygon": {
                                  "type": "array",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "x": {
                                        "type": "integer"
                                      },
                                      "y": {
                                        "type": "integer"
                                      }
                                    }
                                  }
                                },
                                "confidence": {
                                  "type": "number",
                                  "format": "float"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "smartCropsResult": {
            "type": "object",
            "properties": {
              "values": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "aspectRatio": {
                      "type": "number",
                      "format": "float"
                    },
                    "boundingBox": {
                      "$ref": "#/components/schemas/BoundingBox"
                    }
                  }
                }
              }
            }
          },
          "metadata": {
            "type": "object",
            "properties": {
              "width": {
                "type": "integer"
              },
              "height": {
                "type": "integer"
              }
            }
          }
        }
      },
      "BoundingBox": {
        "type": "object",
        "properties": {
          "x": {
            "type": "integer"
          },
          "y": {
            "type": "integer"
          },
          "w": {
            "type": "integer"
          },
          "h": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "innererror": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}