            "$ref": "#/components/parameters/xMsDate"
          },
          {
            "$ref": "#/components/parameters/xMsVersion"
          },
          {
            "name": "collId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dbId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Container deleted"
          }
        },
        "description": "Delete Container"
      }
    },
