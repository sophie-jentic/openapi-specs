{
  "openapi": "3.0.3",
  "info": {
    "title": "Azure Cosmos DB REST API",
    "description": "Azure Cosmos DB is a globally distributed, multi-model database service. This REST API provides CRUD operations for databases, containers (collections), documents, stored procedures, triggers, user-defined functions, users, and permissions. Supports SQL, MongoDB, Cassandra, Gremlin, and Table APIs.",
    "version": "2018-12-31",
    "contact": {
      "name": "Microsoft Azure Support",
      "url": "https://azure.microsoft.com/support"
    },
    "x-jentic-source-url": "https://learn.microsoft.com/en-us/rest/api/cosmos-db"
  },
  "externalDocs": {
    "description": "Azure Cosmos DB REST API Reference",
    "url": "https://learn.microsoft.com/en-us/rest/api/cosmos-db/"
  },
  "servers": [
    {
      "url": "https://{accountName}.documents.azure.com",
      "description": "Azure Cosmos DB endpoint",
      "variables": {
        "accountName": {
          "default": "{your-account-name}",
          "description": "Your Cosmos DB account name"
        }
      }
    }
  ],
  "security": [
    {
      "AuthorizationToken": []
    }
  ],
  "tags": [
    {
      "name": "Databases",
      "description": "Manage Cosmos DB databases"
    },
    {
      "name": "Containers",
      "description": "Manage containers (collections)"
    },
    {
      "name": "Documents",
      "description": "CRUD operations on documents (items)"
    },
    {
      "name": "Stored Procedures",
      "description": "Manage stored procedures"
    },
    {
      "name": "User Defined Functions",
      "description": "Manage UDFs"
    },
    {
      "name": "Triggers",
      "description": "Manage triggers"
    }
  ],
  "paths": {
    "/dbs": {
      "get": {
        "operationId": "listDatabases",
        "summary": "List Databases",
        "description": "List all databases in the account.",
        "tags": [
          "Databases"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/xMsDate"
          },
          {
            "$ref": "#/components/parameters/xMsVersion"
          }
        ],
        "responses": {
          "200": {
            "description": "List of databases",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_rid": {
                      "type": "string"
                    },
                    "Databases": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Database"
                      }
                    },
                    "_count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createDatabase",
        "summary": "Create Database",
        "description": "Create a new database.",
        "tags": [
          "Databases"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/xMsDate"
          },
          {
            "$ref": "#/components/parameters/xMsVersion"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Unique database name"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Database created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Database"
                }
              }
            }
          },
          "409": {
            "description": "Database already exists"
          }
        }
      }
    },
    "/dbs/{dbId}": {
      "get": {
        "operationId": "getDatabase",
        "summary": "Get Database",
        "description": "Get a database by ID.",
        "tags": [
          "Databases"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/dbId"
          },
          {
            "$ref": "#/components/parameters/xMsDate"
          },
          {
            "$ref": "#/components/parameters/xMsVersion"
          },
          {
            "name": "dbId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Database details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Database"
                }
              }
            }
          },
          "404": {
            "description": "Database not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteDatabase",
        "summary": "Delete Database",
        "description": "Delete a database.",
        "tags": [
          "Databases"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/dbId"
          },
          {
            "$ref": "#/components/parameters/xMsDate"
          },
          {
            "$ref": "#/components/parameters/xMsVersion"
          },
          {
            "name": "dbId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Database deleted"
          },
          "404": {
            "description": "Database not found"
          }
        }
      }
    },
    "/dbs/{dbId}/colls": {
      "get": {
        "operationId": "listContainers",
        "summary": "List Containers",
        "description": "List all containers in a database.",
        "tags": [
          "Containers"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/dbId"
          },
          {
            "$ref": "#/components/parameters/xMsDate"
          },
          {
            "$ref": "#/components/parameters/xMsVersion"
          },
          {
            "name": "dbId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of containers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_rid": {
                      "type": "string"
                    },
                    "DocumentCollections": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Container"
                      }
                    },
                    "_count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createContainer",
        "summary": "Create Container",
        "description": "Create a new container (collection) in a database.",
        "tags": [
          "Containers"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/dbId"
          },
          {
            "$ref": "#/components/parameters/xMsDate"
          },
          {
            "$ref": "#/components/parameters/xMsVersion"
          },
          {
            "name": "x-ms-offer-throughput",
            "in": "header",
            "description": "Provisioned throughput in RU/s",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "dbId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id",
                  "partitionKey"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Unique container name"
                  },
                  "partitionKey": {
                    "type": "object",
                    "required": [
                      "paths",
                      "kind"
                    ],
                    "properties": {
                      "paths": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "kind": {
                        "type": "string",
                        "enum": [
                          "Hash",
                          "Range",
                          "MultiHash"
                        ]
                      },
                      "version": {
                        "type": "integer"
                      }
                    }
                  },
                  "indexingPolicy": {
                    "type": "object",
                    "properties": {
                      "automatic": {
                        "type": "boolean"
                      },
                      "indexingMode": {
                        "type": "string",
                        "enum": [
                          "consistent",
                          "lazy",
                          "none"
                        ]
                      },
                      "includedPaths": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "path": {
                              "type": "string"
                            }
                          }
                        }
                      },
                      "excludedPaths": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "path": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  },
                  "defaultTtl": {
                    "type": "integer",
                    "description": "Default TTL in seconds (-1 for no expiry)"
                  },
                  "uniqueKeyPolicy": {
                    "type": "object",
                    "properties": {
                      "uniqueKeys": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "paths": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Container created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Container"
                }
              }
            }
          },
          "409": {
            "description": "Container already exists"
          }
        }
      }
    },
