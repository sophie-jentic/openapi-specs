{
  "openapi": "3.0.3",
  "info": {
    "title": "Azure API for FHIR",
    "description": "Azure API for FHIR (Fast Healthcare Interoperability Resources) is a managed, standards-based healthcare data solution. It implements the HL7 FHIR standard for exchanging healthcare data. Supports FHIR R4 with CRUD operations on all FHIR resource types, search, batch/transaction bundles, and SMART on FHIR.",
    "version": "R4",
    "contact": {
      "name": "Microsoft Azure Health Data Services",
      "url": "https://azure.microsoft.com/services/health-data-services/"
    },
    "x-jentic-source-url": "https://learn.microsoft.com/en-us/azure/healthcare-apis/fhir/rest-api-capabilities"
  },
  "externalDocs": {
    "description": "Azure API for FHIR Documentation",
    "url": "https://learn.microsoft.com/en-us/azure/healthcare-apis/fhir/"
  },
  "servers": [
    {
      "url": "https://{fhirServiceName}.azurehealthcareapis.com",
      "description": "Azure API for FHIR endpoint",
      "variables": {
        "fhirServiceName": {
          "default": "{your-fhir-service}",
          "description": "Your FHIR service name"
        }
      }
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "FHIR Resources",
      "description": "CRUD operations on FHIR resources"
    },
    {
      "name": "Search",
      "description": "Search for FHIR resources"
    },
    {
      "name": "System",
      "description": "System-level operations"
    },
    {
      "name": "Bundle",
      "description": "Batch and transaction bundles"
    }
  ],
  "paths": {
    "/metadata": {
      "get": {
        "operationId": "getCapabilityStatement",
        "summary": "Get Capability Statement",
        "description": "Returns the server's CapabilityStatement (conformance) resource.",
        "tags": [
          "System"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "FHIR CapabilityStatement",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "resourceType": {
                      "type": "string",
                      "example": "CapabilityStatement"
                    },
                    "status": {
                      "type": "string"
                    },
                    "fhirVersion": {
                      "type": "string",
                      "example": "4.0.1"
                    },
                    "rest": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/{resourceType}": {
      "get": {
        "operationId": "searchResources",
        "summary": "Search Resources",
        "description": "Search for resources of the given type. Supports standard FHIR search parameters including _id, _lastUpdated, _count, _include, _revinclude, and resource-specific search parameters.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/resourceType"
          },
          {
            "name": "_id",
            "in": "query",
            "description": "Resource ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_lastUpdated",
            "in": "query",
            "description": "Date resource was last updated",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_count",
            "in": "query",
            "description": "Maximum number of results per page",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "_sort",
            "in": "query",
            "description": "Sort order (prefix with - for descending)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_include",
            "in": "query",
            "description": "Include referenced resources",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_revinclude",
            "in": "query",
            "description": "Include resources referencing the results",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_summary",
            "in": "query",
            "description": "Summary level",
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "text",
                "data",
                "count",
                "false"
              ]
            }
          },
          {
            "name": "_total",
            "in": "query",
            "description": "Whether to return total count",
            "schema": {
              "type": "string",
              "enum": [
                "none",
                "estimate",
                "accurate"
              ]
            }
          },
          {
            "name": "resourceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "FHIR Bundle containing search results",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/Bundle"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createResource",
        "summary": "Create Resource",
        "description": "Create a new FHIR resource (server assigns ID).",
        "tags": [
          "FHIR Resources"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/resourceType"
          },
          {
            "name": "resourceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/fhir+json": {
              "schema": {
                "type": "object",
                "required": [
                  "resourceType"
                ],
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Resource created",
            "headers": {
              "Location": {
                "description": "URL of the created resource",
                "schema": {
                  "type": "string"
                }
              },
              "ETag": {
                "description": "Version ID of the resource",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Invalid resource",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable entity",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                }
              }
            }
          }
        }
      }
    },
    "/{resourceType}/{id}": {
      "get": {
        "operationId": "readResource",
        "summary": "Read Resource",
        "description": "Read a specific FHIR resource by ID.",
        "tags": [
          "FHIR Resources"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/resourceType"
          },
          {
            "$ref": "#/components/parameters/resourceId"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "resourceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "FHIR resource",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                }
              }
            }
          },
          "410": {
            "description": "Resource deleted"
          }
        }
      },
      "put": {
        "operationId": "updateResource",
        "summary": "Update Resource",
        "description": "Update a FHIR resource by ID (full replacement). Creates if not existing.",
        "tags": [
          "FHIR Resources"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/resourceType"
          },
          {
            "$ref": "#/components/parameters/resourceId"
          },
          {
            "name": "If-Match",
            "in": "header",
            "description": "Version-aware update (ETag)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "resourceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/fhir+json": {
              "schema": {
                "type": "object",
                "required": [
                  "resourceType",
                  "id"
                ],
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resource updated",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "201": {
            "description": "Resource created (upsert)"
          },
          "400": {
            "description": "Invalid resource",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                }
              }
            }
          },
          "409": {
            "description": "Version conflict"
          },
          "412": {
            "description": "Precondition failed (If-Match mismatch)"
          }
        }
      },
      "patch": {
        "operationId": "patchResource",
        "summary": "Patch Resource",
        "description": "Partially update a FHIR resource using JSON Patch or FHIR Patch.",
        "tags": [
          "FHIR Resources"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/resourceType"
          },
          {
            "$ref": "#/components/parameters/resourceId"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "resourceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json-patch+json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "op",
                    "path"
                  ],
                  "properties": {
                    "op": {
                      "type": "string",
                      "enum": [
                        "add",
                        "remove",
                        "replace",
                        "move",
                        "copy",
                        "test"
                      ]
                    },
                    "path": {
                      "type": "string"
                    },
                    "value": {}
                  }
                }
              }
            },
            "application/fhir+json": {
              "schema": {
                "type": "object",
                "properties": {
                  "resourceType": {
                    "type": "string",
                    "example": "Parameters"
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resource patched",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteResource",
        "summary": "Delete Resource",
        "description": "Delete a FHIR resource by ID (soft delete).",
        "tags": [
          "FHIR Resources"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/resourceType"
          },
          {
            "$ref": "#/components/parameters/resourceId"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "resourceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Resource deleted"
          },
          "404": {
            "description": "Resource not found"
          }
        }
      }
    },
    "/{resourceType}/{id}/_history": {
      "get": {
        "operationId": "getResourceHistory",
        "summary": "Get Resource History",
        "description": "Retrieve the version history of a specific resource.",
        "tags": [
          "FHIR Resources"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/resourceType"
          },
          {
            "$ref": "#/components/parameters/resourceId"
          },
          {
            "name": "_count",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "_since",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "resourceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bundle containing version history",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/Bundle"
                }
              }
            }
          }
        }
      }
    },
    "/{resourceType}/{id}/_history/{vid}": {
      "get": {
        "operationId": "readResourceVersion",
        "summary": "Read Resource Version",
        "description": "Read a specific version of a resource.",
        "tags": [
          "FHIR Resources"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/resourceType"
          },
          {
            "$ref": "#/components/parameters/resourceId"
          },
          {
            "name": "vid",
            "in": "path",
            "required": true,
            "description": "Version ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "resourceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Versioned FHIR resource",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "post": {
        "operationId": "processBundle",
        "summary": "Process Bundle (Batch/Transaction)",
        "description": "Submit a FHIR Bundle for batch or transaction processing. Batch bundles process entries independently; transaction bundles are all-or-nothing.",
        "tags": [
          "Bundle"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/fhir+json": {
              "schema": {
                "type": "object",
                "required": [
                  "resourceType",
                  "type"
                ],
                "properties": {
                  "resourceType": {
                    "type": "string",
                    "example": "Bundle"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "batch",
                      "transaction"
                    ]
                  },
                  "entry": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "resource": {
                          "type": "object",
                          "additionalProperties": true
                        },
                        "request": {
                          "type": "object",
                          "required": [
                            "method",
                            "url"
                          ],
                          "properties": {
                            "method": {
                              "type": "string",
                              "enum": [
                                "GET",
                                "POST",
                                "PUT",
                                "PATCH",
                                "DELETE"
                              ]
                            },
                            "url": {
                              "type": "string"
                            },
                            "ifNoneExist": {
                              "type": "string"
                            },
                            "ifMatch": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bundle response",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/Bundle"
                }
              }
            }
          }
        }
      }
    },
    "/$export": {
      "get": {
        "operationId": "exportData",
        "summary": "Export Data ($export)",
        "description": "Initiate a bulk data export (FHIR Bulk Data Access).",
        "tags": [
          "System"
        ],
        "parameters": [
          {
            "name": "_type",
            "in": "query",
            "description": "Comma-separated list of resource types to export",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_since",
            "in": "query",
            "description": "Export resources updated after this date",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "_outputFormat",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "application/fhir+ndjson"
            }
          },
          {
            "name": "Accept",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "application/fhir+json"
            }
          },
          {
            "name": "Prefer",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "respond-async"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Export accepted",
            "headers": {
              "Content-Location": {
                "description": "URL to poll for export status",
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Azure AD bearer token with audience set to the FHIR service URL (e.g., https://{fhirServiceName}.azurehealthcareapis.com)"
      }
    },
    "parameters": {
      "resourceType": {
        "name": "resourceType",
        "in": "path",
        "required": true,
        "description": "FHIR resource type (e.g., Patient, Observation, Condition, Encounter, MedicationRequest, DiagnosticReport, Procedure, etc.)",
        "schema": {
          "type": "string"
        }
      },
      "resourceId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Resource ID",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Bundle": {
        "type": "object",
        "properties": {
          "resourceType": {
            "type": "string",
            "example": "Bundle"
          },
          "type": {
            "type": "string",
            "enum": [
              "searchset",
              "batch-response",
              "transaction-response",
              "history"
            ]
          },
          "total": {
            "type": "integer"
          },
          "link": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "relation": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                }
              }
            }
          },
          "entry": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fullUrl": {
                  "type": "string"
                },
                "resource": {
                  "type": "object",
                  "additionalProperties": true
                },
                "search": {
                  "type": "object",
                  "properties": {
                    "mode": {
                      "type": "string",
                      "enum": [
                        "match",
                        "include",
                        "outcome"
                      ]
                    }
                  }
                },
                "response": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "location": {
                      "type": "string"
                    },
                    "etag": {
                      "type": "string"
                    },
                    "lastModified": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "OperationOutcome": {
        "type": "object",
        "properties": {
          "resourceType": {
            "type": "string",
            "example": "OperationOutcome"
          },
          "issue": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "fatal",
                    "error",
                    "warning",
                    "information"
                  ]
                },
                "code": {
                  "type": "string"
                },
                "diagnostics": {
                  "type": "string"
                },
                "details": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
