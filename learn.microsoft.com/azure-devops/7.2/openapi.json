              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Work item details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkItem"
                }
              }
            }
          }
        },
        "description": "Get Work Item"
      },
      "patch": {
        "operationId": "updateWorkItem",
        "summary": "Update Work Item",
        "tags": [
          "Work Items"
        ],
        "parameters": [
          {
            "name": "project",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "#/components/parameters/apiVersion"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json-patch+json": {
              "schema": {
                "type": "array",
