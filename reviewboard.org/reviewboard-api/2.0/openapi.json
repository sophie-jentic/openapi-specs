{
  "openapi": "3.0.3",
  "info": {
    "title": "Review Board API",
    "version": "2.0",
    "description": "Review Board is a web-based collaborative code review tool. Its REST API (version 2.0) allows you to programmatically interact with review requests, reviews, diffs, comments, repositories, and users.",
    "x-jentic-source-url": "https://www.reviewboard.org/docs/manual/latest/webapi/2.0/resources/resource-tree/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{instance}/api",
      "variables": {
        "instance": {
          "default": "instance"
        }
      }
    }
  ],
  "paths": {
    "/review-requests/": {
      "get": {
        "operationId": "listReviewRequests",
        "summary": "List review requests",
        "description": "Returns a list of review requests, optionally filtered by various criteria.",
        "tags": [
          "Review Requests"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "submitted",
                "discarded",
                "all"
              ]
            },
            "description": "Filter by status"
          },
          {
            "name": "to-users",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of usernames to filter by target reviewers"
          },
          {
            "name": "from-user",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by the submitter username"
          },
          {
            "name": "repository",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by repository ID"
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset for pagination"
          },
          {
            "name": "max-results",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25
            },
            "description": "Maximum number of results to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewRequestListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createReviewRequest",
        "summary": "Create a review request",
        "tags": [
          "Review Requests"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "repository": {
                    "type": "string",
                    "description": "Repository path or ID"
                  },
                  "submit_as": {
                    "type": "string",
                    "description": "Username to submit on behalf of (admin only)"
                  },
                  "commit_id": {
                    "type": "string",
                    "description": "Commit ID for the review request"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewRequestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create a review request"
      }
    },
