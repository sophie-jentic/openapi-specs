  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "AirOps API key. Generate at https://app.airops.com/settings/api-keys"
      }
    },
    "schemas": {
      "WorkflowExecuteRequest": {
        "type": "object",
        "required": [
          "inputs"
        ],
        "properties": {
          "inputs": {
            "type": "object",
            "description": "Input parameters for the workflow"
          },
          "stream": {
            "type": "boolean",
            "default": false,
            "description": "Enable streaming response"
          },
          "webhook_url": {
            "type": "string",
            "description": "URL to receive execution result via webhook"
          }
        }
      },
      "AgentExecuteRequest": {
        "type": "object",
        "required": [
          "inputs"
        ],
        "properties": {
          "inputs": {
            "type": "object",
            "description": "Input parameters for the agent"
          },
          "stream": {
            "type": "boolean",
            "default": false
          },
          "webhook_url": {
            "type": "string"
          }
        }
      },
      "ExecutionResponse": {
        "type": "object",
        "properties": {
          "execution_id": {
            "type": "string",
            "description": "Unique execution identifier"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "running",
              "completed",
              "failed",
              "cancelled"
            ]
          },
          "result": {
            "type": "object",
            "description": "Execution result (if completed synchronously)"
          }
        }
      },
      "ExecutionStatusResponse": {
        "type": "object",
        "properties": {
          "execution_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "running",
              "completed",
              "failed",
              "cancelled"
            ]
          },
          "result": {
            "type": "object",
            "description": "Execution output"
          },
          "error": {
            "type": "string",
            "description": "Error message if failed"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
