      "get": {
        "operationId": "getWorkflowExecution",
        "summary": "Get workflow execution status",
        "description": "Retrieve the status and result of a workflow execution.",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
