{
  "openapi": "3.0.3",
  "info": {
    "title": "AirOps API",
    "version": "1.0.0",
    "description": "AirOps is an AI workflow and agent platform. The API allows execution and management of AI workflows, agents, and legacy apps. Supports synchronous and streaming execution modes, conversation-based agent chat, and execution status tracking.",
    "x-jentic-source-url": "https://docs.airops.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.airops.com"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Workflows",
      "description": "AI workflow execution and management"
    },
    {
      "name": "Agents",
      "description": "AI agent execution, chat, and management"
    },
    {
      "name": "Apps",
      "description": "Legacy app execution"
    },
    {
      "name": "Executions",
      "description": "Execution management"
    }
  ],
  "paths": {
    "/v1/workflows/{workflow_id}/execute": {
      "post": {
        "operationId": "executeWorkflow",
        "summary": "Execute a workflow",
        "description": "Triggers execution of an AirOps workflow. Returns an execution ID for tracking progress.",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The workflow ID or slug"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowExecuteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecutionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
