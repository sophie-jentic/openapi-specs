                "properties": {
                  "to": {
                    "type": "string"
                  },
                  "template_code": {
                    "type": "string"
                  },
                  "variables": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Alimtalk message sent successfully"
