{
  "openapi": "3.0.3",
  "info": {
    "title": "Sendon API",
    "description": "Sendon SDK API for sending SMS, Kakao Alimtalk, RCS messages, and managing messaging channels and templates.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://sdk.sendon.io/reference",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://sdk.sendon.io",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BasicAuth": []
    }
  ],
  "tags": [
    {
      "name": "SMS",
      "description": "SMS/Text message operations"
    },
    {
      "name": "Alimtalk",
      "description": "Kakao Alimtalk notification messages"
    },
    {
      "name": "Brand Message",
      "description": "Kakao brand messages"
    },
    {
      "name": "RCS",
      "description": "Rich Communication Services messages"
    },
    {
      "name": "Channel",
      "description": "Channel management"
    },
    {
      "name": "Template",
      "description": "Message template management"
    },
    {
      "name": "Account",
      "description": "Account and billing operations"
    }
  ],
  "paths": {
    "/msg/send": {
      "post": {
        "tags": [
          "SMS"
        ],
        "summary": "Send text message",
        "description": "Send SMS/text messages to recipients",
        "operationId": "sendSMS",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "to",
                  "from",
                  "text"
                ],
                "properties": {
                  "to": {
                    "type": "string",
                    "description": "Recipient phone number"
                  },
                  "from": {
                    "type": "string",
                    "description": "Sender phone number"
                  },
                  "text": {
                    "type": "string",
                    "description": "Message content"
                  },
                  "scheduled_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Schedule message for future delivery"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "created_at": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/msg/groups": {
      "get": {
        "tags": [
          "SMS"
        ],
        "summary": "List message groups",
        "description": "Retrieve list of message groups",
        "operationId": "listMessageGroups",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "count": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/msg/{id}": {
      "get": {
        "tags": [
          "SMS"
        ],
        "summary": "Get message details",
        "description": "Retrieve details of a specific message",
        "operationId": "getMessage",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "to": {
                      "type": "string"
                    },
                    "from": {
                      "type": "string"
                    },
                    "text": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "created_at": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        }
      }
    },
    "/msg/group/{id}/send": {
      "post": {
        "tags": [
          "SMS"
        ],
        "summary": "Send reserved messages",
        "description": "Send reserved/scheduled messages immediately",
        "operationId": "sendReservedMessages",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Messages sent successfully"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/msg/group/{id}/cancel": {
      "post": {
        "tags": [
          "SMS"
        ],
        "summary": "Cancel reserved messages",
        "description": "Cancel scheduled messages before they are sent",
        "operationId": "cancelReservedMessages",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Messages cancelled successfully"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/alimtalk/send": {
      "post": {
        "tags": [
