{
  "openapi": "3.0.3",
  "info": {
    "title": "Eyefinity EHR FHIR API",
    "version": "R4",
    "description": "Eyefinity Electronic Health Records FHIR API providing patient demographics, clinical data access through the FHIR R4 standard. Connects to Encompass EHR.",
    "x-jentic-source-url": "https://help.eyefinity.com/eehr/infoblocking/api/eehr.htm",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://fhirapi.eyefinity.com/fhir/eyefinity/base/r4"
    }
  ],
  "paths": {
    "/Patient": {
      "get": {
        "operationId": "searchPatients",
        "summary": "Search patients",
        "tags": [
          "FHIR"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "identifier",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bundle"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Search patients"
      }
    },
    "/Patient/{id}": {
      "get": {
        "operationId": "getPatient",
        "summary": "Get patient by ID",
        "tags": [
          "FHIR"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patient"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get patient by ID"
      }
    },
    "/Condition": {
      "get": {
        "operationId": "searchConditions",
        "summary": "Search conditions",
        "tags": [
          "FHIR"
        ],
        "parameters": [
          {
            "name": "patient",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bundle"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Search conditions"
      }
    },
    "/metadata": {
      "get": {
        "operationId": "getMetadata",
        "summary": "Get capability statement",
        "tags": [
          "FHIR"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CapabilityStatement"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get capability statement"
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Bundle": {
        "type": "object",
        "properties": {
          "resourceType": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "total": {
            "type": "integer"
          },
          "entry": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Patient": {
        "type": "object",
        "properties": {
          "resourceType": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "CapabilityStatement": {
        "type": "object",
        "properties": {
          "resourceType": {
            "type": "string"
          },
          "fhirVersion": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://fhirauthority.eyefinity.com/core/connect/authorize",
            "tokenUrl": "https://fhirauthority.eyefinity.com/core/connect/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "FHIR"
    }
  ]
}
