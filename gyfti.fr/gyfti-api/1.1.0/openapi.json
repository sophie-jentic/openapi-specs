{
  "openapi": "3.0.3",
  "info": {
    "title": "Gyfti API",
    "version": "1.1.0",
    "description": "Gyfti API for managing items in the Gyfti platform. Provides CRUD operations on various entity types with filtering and pagination.",
    "x-jentic-source-url": "https://robinnox.gitbook.io/gyfti/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://app.gyfti.fr/api/1.1/obj"
    }
  ],
  "paths": {
    "/{typename}": {
      "get": {
        "operationId": "listThings",
        "summary": "List things with search",
        "description": "Retrieves a list of items of a specified type with optional filtering",
        "tags": [
          "Things"
        ],
        "parameters": [
          {
            "name": "typename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Entity type name"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 100
            },
            "description": "Items per response"
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Pagination starting point"
          },
          {
            "name": "constraints",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter criteria array (JSON)"
          },
          {
            "name": "sort_field",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Field for sorting or _random_sorting"
          },
          {
            "name": "descending",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false"
              ]
            },
            "description": "Sort direction"
          }
        ],
        "responses": {
          "200": {
            "description": "List of items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThingListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{typename}/{unique_id}": {
      "get": {
        "operationId": "getThing",
        "summary": "Retrieve thing by ID",
        "tags": [
          "Things"
        ],
        "parameters": [
          {
            "name": "typename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "unique_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Thing"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Retrieve thing by ID"
      },
      "delete": {
        "operationId": "deleteThing",
        "summary": "Delete thing by ID",
        "tags": [
          "Things"
        ],
        "parameters": [
          {
            "name": "typename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "unique_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete thing by ID"
      }
    }
  },
  "components": {
    "schemas": {
      "Thing": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "Created Date": {
            "type": "string",
            "format": "date-time"
          },
          "Modified Date": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ThingListResponse": {
        "type": "object",
        "properties": {
          "cursor": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Thing"
            }
          },
          "remaining": {
            "type": "integer"
          },
          "count": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token in Authorization header"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Things"
    }
  ]
}
