    "/accounts/{slug}/invoices/{id}/fire.json": {
      "post": {
        "operationId": "fireInvoiceEvent",
        "summary": "Fire invoice event",
        "description": "Trigger actions like mark_as_sent, deliver, pay, pay_proforma, pay_partial_proforma, remove_payment, deliver_reminder, cancel, undo_cancel, lock, unlock, mark_as_uncollectible, undo_uncollectible",
        "tags": [
          "Invoices"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "event",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "mark_as_sent",
                "deliver",
                "pay",
                "pay_proforma",
                "pay_partial_proforma",
                "remove_payment",
                "deliver_reminder",
                "cancel",
                "undo_cancel",
                "lock",
                "unlock",
                "mark_as_uncollectible",
                "undo_uncollectible"
              ]
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "paid_on": {
                    "type": "string",
                    "format": "date"
                  },
                  "paid_amount": {
                    "type": "number"
                  },
                  "variable_symbol": {
                    "type": "string"
                  },
                  "bank_account_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event fired"
          },
          "422": {
            "description": "Invalid event"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
