      "description": "Invoice management"
    },
    {
      "name": "Subjects",
      "description": "Client/supplier subjects"
    },
    {
      "name": "Expenses",
      "description": "Expense tracking"
    },
    {
      "name": "Generators",
      "description": "Invoice generators/templates"
    },
    {
      "name": "Todos",
      "description": "Todo tasks"
    },
    {
      "name": "Events",
      "description": "Account events/activity log"
    },
    {
      "name": "Bank Accounts",
