{
  "openapi": "3.0.3",
  "info": {
    "title": "Plus AI Presentations API",
    "version": "0.1.0",
    "description": "Plus AI API for generating presentations from text prompts using AI.",
    "x-jentic-source-url": "https://guide.plusai.com/ai-for-presentations/presentations-api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.plusdocs.com/r"
    }
  ],
  "paths": {
    "/v0/presentation": {
      "post": {
        "operationId": "createPresentation",
        "summary": "Create a presentation",
        "tags": [
          "Presentations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePresentationInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Presentation creation started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresentationStatus"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Create a presentation"
      }
    },
    "/v0/presentation/{presentationId}": {
      "get": {
        "operationId": "getPresentation",
        "summary": "Poll presentation status",
        "tags": [
          "Presentations"
        ],
        "parameters": [
          {
            "name": "presentationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresentationStatus"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Poll presentation status"
      }
    },
    "/v0/presentations": {
      "get": {
        "operationId": "listPresentations",
        "summary": "List all presentations",
        "tags": [
          "Presentations"
        ],
        "responses": {
          "200": {
            "description": "List of presentations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PresentationStatus"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List all presentations"
      }
    }
  },
  "components": {
    "schemas": {
      "CreatePresentationInput": {
        "type": "object",
        "required": [
          "prompt"
        ],
        "properties": {
          "prompt": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "numberOfSlides": {
            "type": "integer",
            "maximum": 30
          },
          "includeUserTips": {
            "type": "boolean"
          },
          "templateId": {
            "type": "string"
          },
          "textHandling": {
            "type": "string",
            "enum": [
              "DEFAULT",
              "PRESERVE",
              "STRICT"
            ]
          }
        }
      },
      "PresentationStatus": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "pollingUrl": {
            "type": "string"
          },
          "downloadUrl": {
            "type": "string"
          },
          "slides": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Presentations"
    }
  ]
}
