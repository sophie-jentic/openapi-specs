            }
          },
          "continuation_key": {
            "type": "string"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "transaction_id": {
            "type": "string"
          },
          "entry_reference": {
            "type": "string"
          },
          "transaction_amount": {
            "type": "object",
            "properties": {
              "amount": {
                "type": "string"
              },
              "currency": {
                "type": "string"
              }
            }
          },
          "status": {
            "type": "string"
          },
          "booking_date": {
            "type": "string",
            "format": "date"
          },
          "value_date": {
            "type": "string",
            "format": "date"
          },
          "creditor_name": {
            "type": "string"
          },
          "debtor_name": {
            "type": "string"
          },
          "remittance_information": {
            "type": "string"
          }
        }
      },
      "CreatePaymentRequest": {
        "type": "object",
        "properties": {
          "credit_transfers": {
            "type": "array",
