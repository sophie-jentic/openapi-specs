{
  "openapi": "3.0.3",
  "info": {
    "title": "API Ninjas City API",
    "description": "Retrieve city data including population, coordinates, country, and capital status. Covers over 50,000 cities on the free plan and over 5,000,000 cities, towns, and villages on premium.",
    "version": "1.0.0",
    "contact": {
      "name": "API Ninjas",
      "url": "https://api-ninjas.com"
    }
  },
  "servers": [
    {
      "url": "https://api.api-ninjas.com/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/city": {
      "get": {
        "operationId": "getCities",
        "summary": "Search for cities",
        "description": "Retrieve a list of cities matching the given search criteria. At least one of the query parameters must be provided.",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "City name to search for.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "London"
          },
          {
            "name": "country",
            "in": "query",
            "description": "Country filter, ISO-3166 alpha-2 country code (e.g. US, GB, JP).",
            "required": false,
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            },
            "example": "GB"
          },
          {
            "name": "min_lat",
            "in": "query",
            "description": "Minimum latitude coordinate for bounding-box search.",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": -90,
              "maximum": 90
            }
          },
          {
            "name": "max_lat",
            "in": "query",
            "description": "Maximum latitude coordinate for bounding-box search.",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": -90,
              "maximum": 90
            }
          },
          {
            "name": "min_lon",
            "in": "query",
            "description": "Minimum longitude coordinate for bounding-box search.",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": -180,
              "maximum": 180
            }
          },
          {
            "name": "max_lon",
            "in": "query",
            "description": "Maximum longitude coordinate for bounding-box search.",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": -180,
              "maximum": 180
            }
          },
          {
            "name": "min_population",
            "in": "query",
            "description": "Minimum city population filter.",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "max_population",
            "in": "query",
            "description": "Maximum city population filter.",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results to return per request. Must be between 1 and 30. Default is 1. Premium feature.",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30,
              "default": 1
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset for results. Premium feature.",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response returning an array of matching cities.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/City"
                  }
                },
                "example": [
                  {
                    "name": "London",
                    "latitude": 51.5074,
                    "longitude": -0.1278,
                    "country": "GB",
                    "population": 8982000,
                    "is_capital": true
                  }
                ]
              }
            }
          },
          "400": {
            "description": "Bad request. At least one search parameter must be provided."
          },
          "401": {
            "description": "Unauthorized. Invalid or missing API key."
          },
          "429": {
            "description": "Too many requests. Rate limit exceeded."
          }
        },
        "tags": [
          "city"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Api-Key",
        "description": "API key for authentication. Obtain from your API Ninjas account."
      }
    },
    "schemas": {
      "City": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "City name.",
            "example": "London"
          },
          "latitude": {
            "type": "number",
            "format": "double",
            "description": "Latitude coordinate of the city.",
            "example": 51.5074
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "description": "Longitude coordinate of the city.",
            "example": -0.1278
          },
          "country": {
            "type": "string",
            "description": "ISO-3166 alpha-2 country code.",
            "example": "GB"
          },
          "population": {
            "type": "integer",
            "description": "City population count.",
            "example": 8982000
          },
          "is_capital": {
            "type": "boolean",
            "description": "Whether the city is a national capital.",
            "example": true
          }
        },
        "required": [
          "name",
          "latitude",
          "longitude",
          "country",
          "population",
          "is_capital"
        ]
      }
    }
  },
  "tags": [
    {
      "name": "city"
    }
  ]
}
