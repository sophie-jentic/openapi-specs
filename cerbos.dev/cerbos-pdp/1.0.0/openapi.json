{
  "openapi": "3.0.3",
  "info": {
    "title": "Cerbos PDP API",
    "version": "1.0.0",
    "description": "Cerbos Policy Decision Point (PDP) API for authorization. Evaluates access control policies for resources using attribute-based access control (ABAC).",
    "x-jentic-source-url": "https://docs.cerbos.dev/cerbos/latest/index.html",
    "contact": {
      "name": "Cerbos",
      "url": "https://cerbos.dev"
    }
  },
  "servers": [
    {
      "url": "https://localhost:3592",
      "description": "Cerbos PDP (default port)"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authorization",
      "description": "Authorization check endpoints"
    },
    {
      "name": "Admin",
      "description": "Admin and policy management"
    },
    {
      "name": "Health",
      "description": "Health and readiness"
    }
  ],
  "paths": {
    "/api/check/resources": {
      "post": {
        "tags": [
          "Authorization"
        ],
        "operationId": "checkResources",
        "summary": "Check resource access",
        "description": "Check authorization for one or more resources.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckResourcesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authorization results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckResourcesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/plan/resources": {
      "post": {
        "tags": [
          "Authorization"
        ],
        "operationId": "planResources",
        "summary": "Plan resource query",
        "description": "Get a query plan for filtering resources based on policies.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlanResourcesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/check": {
      "post": {
        "tags": [
          "Authorization"
        ],
        "operationId": "check",
        "summary": "Check authorization (legacy)",
        "description": "Legacy check endpoint. Use /api/check/resources instead.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/admin/policy": {
      "get": {
        "tags": [
          "Admin"
        ],
        "operationId": "listPolicies",
        "summary": "List all policies",
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all policies"
      },
      "put": {
        "tags": [
          "Admin"
        ],
        "operationId": "addOrUpdatePolicy",
        "summary": "Add or update policies",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "policies": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Add or update policies"
      }
    },
    "/admin/policy/{policyId}": {
      "get": {
        "tags": [
          "Admin"
        ],
        "operationId": "getPolicy",
        "summary": "Get a policy by ID",
        "parameters": [
          {
            "name": "policyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a policy by ID"
      },
      "delete": {
        "tags": [
          "Admin"
        ],
        "operationId": "deletePolicy",
        "summary": "Delete a policy",
        "parameters": [
          {
            "name": "policyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Delete a policy"
      }
    },
    "/admin/schema": {
      "get": {
        "tags": [
          "Admin"
        ],
        "operationId": "listSchemas",
        "summary": "List schemas",
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List schemas"
      },
      "put": {
        "tags": [
          "Admin"
        ],
        "operationId": "addOrUpdateSchema",
        "summary": "Add or update schemas",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Add or update schemas"
      }
    },
    "/admin/schema/{schemaId}": {
      "get": {
        "tags": [
          "Admin"
        ],
        "operationId": "getSchema",
        "summary": "Get a schema",
        "parameters": [
          {
            "name": "schemaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a schema"
      },
      "delete": {
        "tags": [
          "Admin"
        ],
        "operationId": "deleteSchema",
        "summary": "Delete a schema",
        "parameters": [
          {
            "name": "schemaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete a schema"
      }
    },
    "/admin/store/export": {
      "get": {
        "tags": [
          "Admin"
        ],
        "operationId": "exportStore",
        "summary": "Export all store data",
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Export all store data"
      }
    },
    "/admin/store/import": {
      "post": {
        "tags": [
          "Admin"
        ],
        "operationId": "importStore",
        "summary": "Import store data",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Import store data"
      }
    },
    "/_cerbos/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "operationId": "healthCheck",
        "summary": "Health check",
        "security": [],
        "responses": {
          "200": {
            "description": "Healthy"
          },
          "503": {
            "description": "Unhealthy"
          }
        },
        "description": "Health check"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "CheckResourcesRequest": {
        "type": "object",
        "required": [
          "principal",
          "resources"
        ],
        "properties": {
          "requestId": {
            "type": "string"
          },
          "principal": {
            "$ref": "#/components/schemas/Principal"
          },
          "resources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ResourceEntry"
            }
          },
          "auxData": {
            "type": "object"
          }
        }
      },
      "Principal": {
        "type": "object",
        "required": [
          "id",
          "roles"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "attr": {
            "type": "object"
          },
          "policyVersion": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          }
        }
      },
      "ResourceEntry": {
        "type": "object",
        "required": [
          "resource",
          "actions"
        ],
        "properties": {
          "resource": {
            "type": "object",
            "required": [
              "kind",
              "id"
            ],
            "properties": {
              "kind": {
                "type": "string"
              },
              "id": {
                "type": "string"
              },
              "attr": {
                "type": "object"
              },
              "policyVersion": {
                "type": "string"
              },
              "scope": {
                "type": "string"
              }
            }
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CheckResourcesResponse": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "resource": {
                  "type": "object"
                },
                "actions": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string",
                    "enum": [
                      "EFFECT_ALLOW",
                      "EFFECT_DENY"
                    ]
                  }
                }
              }
            }
          }
        }
      },
      "PlanResourcesRequest": {
        "type": "object",
        "required": [
          "principal",
          "resource",
          "action"
        ],
        "properties": {
          "requestId": {
            "type": "string"
          },
          "principal": {
            "$ref": "#/components/schemas/Principal"
          },
          "resource": {
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string"
              },
              "attr": {
                "type": "object"
              },
              "policyVersion": {
                "type": "string"
              },
              "scope": {
                "type": "string"
              }
            }
          },
          "action": {
            "type": "string"
          }
        }
      }
    }
  }
}
