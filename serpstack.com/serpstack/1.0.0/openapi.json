{
  "openapi": "3.0.0",
  "info": {
    "title": "serpstack API",
    "version": "1.0.0",
    "description": "Real-Time & Accurate Google Search Results API with JSON REST responses for SERP data",
    "contact": {
      "name": "serpstack Support",
      "url": "https://serpstack.com"
    }
  },
  "servers": [
    {
      "url": "https://api.serpstack.com",
      "description": "Production server (HTTPS)"
    },
    {
      "url": "http://api.serpstack.com",
      "description": "Production server (HTTP - free tier)"
    }
  ],
  "security": [
    {
      "accessKey": []
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "summary": "Execute Google search",
        "description": "Performs a Google search and returns structured SERP data including organic results, ads, knowledge graphs, and more",
        "operationId": "executeSearch",
        "parameters": [
          {
            "name": "access_key",
            "in": "query",
            "required": true,
            "description": "Your unique API access key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "The search term to execute",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "engine",
            "in": "query",
            "description": "Search engine to use",
            "schema": {
              "type": "string",
              "default": "google"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Search category type",
            "schema": {
              "type": "string",
              "enum": [
                "web",
                "images",
                "videos",
                "news",
                "shopping"
              ],
              "default": "web"
            }
          },
          {
            "name": "device",
            "in": "query",
            "description": "Device type for search results",
            "schema": {
              "type": "string",
              "enum": [
                "desktop",
                "mobile",
                "tablet"
              ],
              "default": "desktop"
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Geographic location for results",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "google_domain",
            "in": "query",
            "description": "Specific Google domain to use",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "gl",
            "in": "query",
            "description": "Country code (two-letter ISO code)",
            "schema": {
              "type": "string",
              "pattern": "^[A-Z]{2}$"
            }
          },
          {
            "name": "hl",
            "in": "query",
            "description": "Language preference (two-letter ISO code)",
            "schema": {
              "type": "string",
              "pattern": "^[a-z]{2}$"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Result page number",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "num",
            "in": "query",
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            }
          },
          {
            "name": "output",
            "in": "query",
            "description": "Response output format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv"
              ],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "request": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        },
                        "processed_timestamp": {
                          "type": "integer"
                        },
                        "total_time_taken": {
                          "type": "number"
                        }
                      }
                    },
                    "search_parameters": {
                      "type": "object",
                      "properties": {
                        "engine": {
                          "type": "string"
                        },
                        "query": {
                          "type": "string"
                        },
                        "domain": {
                          "type": "string"
                        },
                        "device": {
                          "type": "string"
                        }
                      }
                    },
                    "search_information": {
                      "type": "object",
                      "properties": {
                        "total_results": {
                          "type": "integer"
                        },
                        "time_taken": {
                          "type": "number"
                        },
                        "query_displayed": {
                          "type": "string"
                        }
                      }
                    },
                    "ads": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "organic_results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "position": {
                            "type": "integer"
                          },
                          "title": {
                            "type": "string"
                          },
                          "link": {
                            "type": "string"
                          },
                          "displayed_link": {
                            "type": "string"
                          },
                          "snippet": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "local_results": {
                      "type": "object"
                    },
                    "knowledge_graph": {
                      "type": "object"
                    },
                    "answer_box": {
                      "type": "object"
                    },
                    "related_searches": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "related_questions": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "current": {
                          "type": "integer"
                        },
                        "next": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid access key"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "tags": [
          "search"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "accessKey": {
        "type": "apiKey",
        "in": "query",
        "name": "access_key",
        "description": "API access key obtained upon registration"
      }
    }
  },
  "tags": [
    {
      "name": "search"
    }
  ]
}
