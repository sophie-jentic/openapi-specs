    "title": "Iconfinder API",
    "version": "4.0.0",
    "description": "Search, browse, and download high-quality icons and icon sets. Access millions of icons via REST API.",
    "x-jentic-source-url": "https://developer.iconfinder.com",
    "contact": {
      "name": "API Support"
    }
