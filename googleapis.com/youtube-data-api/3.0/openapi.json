      },
      "post": {
        "operationId": "playlistsInsert",
        "summary": "Create a playlist",
        "tags": [
          "Playlists"
        ],
        "security": [
          {
            "oauth2": [
              "https://www.googleapis.com/auth/youtube"
            ]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/part"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Playlist"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created playlist.",
            "content": {
