  "paths": {
    "/search": {
      "get": {
        "operationId": "searchList",
        "summary": "Search for videos, channels, and playlists",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/part"
          },
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query."
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Restrict to video, channel, or playlist."
          },
          {
            "name": "channelId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "date",
                "rating",
                "relevance",
                "title",
                "videoCount",
                "viewCount"
              ]
            }
          },
          {
            "name": "publishedAfter",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "publishedBefore",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "regionCode",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "videoCategoryId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "videoDuration",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "any",
                "long",
                "medium",
                "short"
              ]
            }
          },
          {
            "name": "videoDefinition",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "any",
                "high",
                "standard"
              ]
            }
          },
          {
            "name": "safeSearch",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "moderate",
                "none",
                "strict"
              ]
            }
          },
          {
            "$ref": "#/components/parameters/maxResults"
          },
          {
            "$ref": "#/components/parameters/pageToken"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchListResponse"
                }
              }
            }
          }
        },
        "description": "Search for videos, channels, and playlists"
      }
    },
    "/videos": {
      "get": {
        "operationId": "videosList",
        "summary": "List videos",
        "tags": [
          "Videos"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/part"
          },
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated video IDs."
          },
          {
            "name": "chart",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "mostPopular"
              ]
            }
          },
          {
            "name": "myRating",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "like",
                "dislike"
              ]
            }
          },
          {
            "name": "regionCode",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "videoCategoryId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/maxResults"
          },
          {
            "$ref": "#/components/parameters/pageToken"
          }
        ],
        "responses": {
          "200": {
            "description": "Video list.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoListResponse"
                }
              }
            }
          }
        },
        "description": "List videos"
      }
    },
    "/videos/rate": {
      "post": {
        "operationId": "videosRate",
        "summary": "Rate a video (like/dislike)",
        "tags": [
          "Videos"
        ],
        "security": [
          {
            "oauth2": [
              "https://www.googleapis.com/auth/youtube"
            ]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rating",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "like",
                "dislike",
                "none"
              ]
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Rated successfully."
          }
        },
        "description": "Rate a video (like/dislike)"
      }
    },
    "/channels": {
      "get": {
