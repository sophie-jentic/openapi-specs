      },
      "maxResults": {
        "name": "maxResults",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 5,
          "minimum": 0,
          "maximum": 50
        }
      },
      "pageToken": {
        "name": "pageToken",
        "in": "query",
        "schema": {
          "type": "string"
        }
