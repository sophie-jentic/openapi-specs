{
  "openapi": "3.1.0",
  "info": {
    "title": "YouTube Data API",
    "version": "3.0",
    "description": "The YouTube Data API v3 lets you incorporate YouTube functionality into your application. You can use the API to search for videos, retrieve channel and playlist information, manage subscriptions, and more.",
    "contact": {
      "name": "Google",
      "url": "https://developers.google.com/youtube/v3"
    },
    "x-apisguru-categories": [
      "media"
    ],
    "x-logo": {
      "url": "https://www.youtube.com/s/desktop/favicon.ico"
    }
  },
  "servers": [
    {
      "url": "https://www.googleapis.com/youtube/v3"
    }
  ],
  "security": [
