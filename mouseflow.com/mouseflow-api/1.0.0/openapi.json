        "operationId": "createWebsite",
        "summary": "Create a website",
        "tags": [
          "Websites"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "domain"
