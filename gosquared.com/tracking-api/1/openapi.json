{
  "openapi": "3.0.3",
  "info": {
    "title": "GoSquared Tracking API",
    "description": "The GoSquared Tracking API allows you to track user interactions, events, pageviews, and visitor identification across any platform or device. The API supports real-time visitor tracking, event recording, and integration with GoSquared's People CRM.",
    "version": "1",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.gosquared.com/tracking/v1"
    }
  ],
  "paths": {
    "/event": {
      "post": {
        "summary": "Track Custom Event",
        "description": "Records a custom event with optional context data. Maximum 1,000 unique custom event names per project.",
        "operationId": "trackEvent",
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "description": "Your GoSquared API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "site_token",
            "in": "query",
            "description": "Your GoSquared site token (format: GSN-XXXXXX-X)",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^GSN-[0-9]+-[A-Z]$"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EventRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event tracked successfully"
          },
          "400": {
            "description": "Bad Request - Invalid parameters"
          },
          "401": {
            "description": "Unauthorized - Invalid API key or site token"
          }
        },
        "tags": [
          "event"
        ]
      }
    },
    "/pageview": {
      "post": {
        "summary": "Track Pageview",
        "description": "Records a pageview event to track what pages a visitor is browsing across your site.",
        "operationId": "trackPageview",
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "description": "Your GoSquared API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "site_token",
            "in": "query",
            "description": "Your GoSquared site token (format: GSN-XXXXXX-X)",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^GSN-[0-9]+-[A-Z]$"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PageviewRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pageview tracked successfully"
          },
          "400": {
            "description": "Bad Request - Invalid parameters"
          },
          "401": {
            "description": "Unauthorized - Invalid API key or site token"
          }
        },
        "tags": [
          "pageview"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "EventRequest": {
        "type": "object",
        "required": [
          "event"
        ],
        "properties": {
          "event": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Event identifier name"
              },
              "data": {
                "type": "object",
                "description": "Additional event context data",
                "additionalProperties": true
              },
              "timestamp": {
                "type": "string",
                "format": "date-time",
                "description": "ISO 8601 formatted timestamp"
              },
              "person_id": {
                "type": "string",
                "description": "People CRM identifier (prefix emails with 'email:')"
              },
              "visitor_id": {
                "type": "string",
                "description": "Anonymous visitor identifier"
              },
              "page": {
                "$ref": "#/components/schemas/PageContext"
              },
              "screen": {
                "$ref": "#/components/schemas/ScreenContext"
              },
              "campaign": {
                "$ref": "#/components/schemas/CampaignContext"
              },
              "location": {
                "type": "object",
                "description": "Geolocation data"
              },
              "ip": {
                "type": "string",
                "description": "Visitor IP address for location detection"
              },
              "language": {
                "type": "string",
                "description": "Language preference"
              },
              "user_agent": {
                "type": "string",
                "description": "Browser user agent string"
              },
              "returning": {
                "type": "boolean",
                "description": "Repeat visitor indicator"
              }
            }
          }
        }
      },
      "PageviewRequest": {
        "type": "object",
        "required": [
          "visitor_id",
          "page"
        ],
        "properties": {
          "visitor_id": {
            "type": "string",
            "description": "Anonymous visitor identifier"
          },
          "page": {
            "type": "object",
            "required": [
              "url",
              "title"
            ],
            "properties": {
              "url": {
                "type": "string",
                "description": "Page URL"
              },
              "title": {
                "type": "string",
                "description": "Page title"
              },
              "previous": {
                "type": "integer",
                "description": "Index of previous page being unloaded"
              },
              "referrer": {
                "type": "string",
                "description": "Referring page"
              },
              "ip": {
                "type": "string",
                "description": "Visitor IP address for location detection"
              },
              "character_set": {
                "type": "string",
                "description": "Character encoding"
              },
              "language": {
                "type": "string",
                "description": "Page language"
              },
              "user_agent": {
                "type": "string",
                "description": "Browser user agent"
              },
              "returning": {
                "type": "boolean",
                "description": "Whether visitor is returning"
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 formatted timestamp"
          },
          "screen": {
            "$ref": "#/components/schemas/ScreenContext"
          },
          "campaign": {
            "$ref": "#/components/schemas/CampaignContext"
          },
          "location": {
            "type": "object",
            "properties": {
              "timezone_offset": {
                "type": "integer",
                "description": "Timezone offset in minutes"
              },
              "last_pageview": {
                "type": "string",
                "format": "date-time",
                "description": "Timestamp of last pageview"
              }
            }
          },
          "total": {
            "type": "object",
            "properties": {
              "visits": {
                "type": "integer",
                "description": "Total number of visits"
              },
              "pageviews": {
                "type": "integer",
                "description": "Total number of pageviews"
              }
            }
          }
        }
      },
      "PageContext": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "Page URL"
          },
          "title": {
            "type": "string",
            "description": "Page title"
          },
          "index": {
            "type": "integer",
            "description": "Page index in session"
          },
          "referrer": {
            "type": "string",
            "description": "Referrer URL"
          }
        }
      },
      "ScreenContext": {
        "type": "object",
        "properties": {
          "height": {
            "type": "integer",
            "description": "Screen height in pixels"
          },
          "width": {
            "type": "integer",
            "description": "Screen width in pixels"
          },
          "pixel_ratio": {
            "type": "number",
            "description": "Device pixel ratio"
          },
          "depth": {
            "type": "integer",
            "description": "Color depth in bits"
          }
        }
      },
      "CampaignContext": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Campaign name"
          },
          "source": {
            "type": "string",
            "description": "Campaign source (UTM parameter)"
          },
          "medium": {
            "type": "string",
            "description": "Campaign medium (UTM parameter)"
          },
          "content": {
            "type": "string",
            "description": "Campaign content (UTM parameter)"
          },
          "term": {
            "type": "string",
            "description": "Campaign term (UTM parameter)"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "event"
    },
    {
      "name": "pageview"
    }
  ]
}
