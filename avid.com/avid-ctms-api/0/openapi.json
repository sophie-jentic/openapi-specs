    "/{serviceType};version={version};realm={realm}/export/{objectId}": {
      "post": {
        "operationId": "exportAsset",
        "summary": "Export an asset",
        "tags": [
          "Export"
        ],
        "parameters": [
          {
            "name": "serviceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "realm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "format": {
                    "type": "string"
                  },
                  "profile": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Export started"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Export an asset"
      }
    }
  },
  "components": {
    "schemas": {
      "CommonObject": {
        "type": "object",
        "properties": {
          "base": {
            "type": "object",
            "properties": {
              "systemType": {
                "type": "string"
              },
              "systemID": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "id": {
                "type": "string"
              }
            }
          },
          "common": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "creator": {
                "type": "string"
              },
              "created": {
                "type": "string",
                "format": "date-time"
              },
              "modifier": {
                "type": "string"
              },
              "modified": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "_links": {
            "type": "object"
          }
        }
      },
      "Item": {
        "type": "object",
        "properties": {
          "base": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "systemType": {
                "type": "string"
              },
              "systemID": {
                "type": "string"
              }
            }
          },
          "common": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "creator": {
                "type": "string"
              },
              "created": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "_links": {
            "type": "object"
          },
          "_embedded": {
            "type": "object"
          }
        }
      },
      "ItemCollection": {
        "type": "object",
        "properties": {
          "_embedded": {
            "type": "object",
            "properties": {
              "loc:item": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "_links": {
            "type": "object"
          },
          "totalResults": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          }
        }
      },
      "SearchResults": {
        "type": "object",
        "properties": {
          "_embedded": {
            "type": "object",
            "properties": {
              "results": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CommonObject"
                }
              }
            }
          },
          "totalResults": {
            "type": "integer"
          },
          "_links": {
            "type": "object"
          }
        }
      },
      "ServiceRootsResponse": {
        "type": "object",
        "properties": {
          "_embedded": {
            "type": "object",
            "properties": {
              "aa:service-root": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2.0 Bearer token obtained from /auth/v0/token"
      },
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "/auth/v0/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
