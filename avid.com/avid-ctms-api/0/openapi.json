          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "realm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object metadata"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get metadata for an object"
      },
      "put": {
        "operationId": "updateObjectMetadata",
        "summary": "Update metadata for an object",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "serviceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
