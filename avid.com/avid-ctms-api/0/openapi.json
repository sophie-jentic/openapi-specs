{
  "openapi": "3.0.3",
  "info": {
    "title": "Avid CTMS API",
    "version": "0",
    "description": "The Avid Platform CTMS (Common Type and Method System) API provides a HAL-based REST interface for querying and managing media assets (video, audio, metadata, folder structures) in Avid MediaCentral. Assets are organized in a common object hierarchy with folder structures, supporting operations like browse, search, export, and metadata management across different system types (Interplay MAM, Interplay Production, MediaCentral UX).",
    "x-jentic-source-url": "https://developer.avid.com/ctms/api/index.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}/apis",
      "variables": {
        "host": {
          "default": "mediacentral.example.com",
          "description": "MediaCentral host"
        }
      }
    }
  ],
  "paths": {
    "/avid.ctms.registry;version=0/serviceroots": {
      "get": {
        "operationId": "getServiceRoots",
        "summary": "Get all service roots",
        "description": "Returns all registered service roots across all system types and realms",
        "tags": [
          "Registry"
        ],
        "responses": {
          "200": {
            "description": "HAL resource with embedded service roots",
            "content": {
              "application/hal+json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceRootsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/avid.ctms.registry;version=0/serviceroots/{systemType}": {
      "get": {
        "operationId": "getServiceRootsByType",
        "summary": "Get service roots by system type",
        "tags": [
          "Registry"
        ],
        "parameters": [
          {
            "name": "systemType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "System type (e.g., avid.mam.assets.access, interplay-pam)"
          }
        ],
        "responses": {
          "200": {
            "description": "Service roots for the system type",
            "content": {
              "application/hal+json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceRootsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get service roots by system type"
      }
    },
    "/{serviceType};version={version};realm={realm}/locations/items": {
      "get": {
        "operationId": "listItems",
        "summary": "List items in a location",
        "tags": [
          "Locations"
        ],
        "parameters": [
          {
            "name": "serviceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "realm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Pagination offset"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of items to return"
          },
          {
            "name": "attributes",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of attribute names to include"
          }
        ],
        "responses": {
          "200": {
            "description": "Collection of items",
            "content": {
              "application/hal+json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemCollection"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List items in a location"
      }
    },
    "/{serviceType};version={version};realm={realm}/locations/items/{itemId}": {
      "get": {
        "operationId": "getItemById",
        "summary": "Get a single item by ID",
        "tags": [
          "Locations"
        ],
        "parameters": [
          {
            "name": "serviceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "realm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attributes",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated attribute names"
          }
        ],
        "responses": {
          "200": {
            "description": "Item resource",
            "content": {
              "application/hal+json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Item not found"
          }
        },
        "description": "Get a single item by ID"
      }
    },
    "/{serviceType};version={version};realm={realm}/locations/root-item": {
      "get": {
        "operationId": "getRootItem",
        "summary": "Get the root item of a folder structure",
        "tags": [
          "Locations"
        ],
        "parameters": [
          {
            "name": "serviceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "realm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Root item",
            "content": {
              "application/hal+json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get the root item of a folder structure"
      }
    },
    "/{serviceType};version={version};realm={realm}/search": {
      "get": {
        "operationId": "searchAssets",
        "summary": "Search for assets",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "serviceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "realm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query string"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "attributes",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/hal+json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Search for assets"
      }
    },
    "/{serviceType};version={version};realm={realm}/search/filters": {
      "get": {
        "operationId": "getSearchFilters",
        "summary": "Get available search filters",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "serviceType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "realm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Available filters"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get available search filters"
      }
    },
    "/auth/v0/token": {
      "post": {
        "operationId": "getAccessToken",
        "summary": "Obtain an access token",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "client_credentials",
                      "password"
                    ]
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_secret": {
                    "type": "string"
                  },
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid credentials"
          }
        },
        "description": "Obtain an access token"
      }
    },
