{
  "openapi": "3.0.3",
  "info": {
    "title": "Chronosphere API",
    "version": "1.0.0",
    "description": "The Chronosphere API enables programmatic management of observability configurations including collections, monitors, and metric queries.",
    "x-jentic-source-url": "https://docs.chronosphere.io/tooling/api-info",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{tenant}.chronosphere.io",
      "variables": {
        "tenant": {
          "default": "your-tenant"
        }
      }
    }
  ],
  "paths": {
    "/api/v1/config/collections": {
      "get": {
        "operationId": "listCollections",
        "summary": "List all collections",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "page.token",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all collections"
      },
      "post": {
        "operationId": "createCollection",
        "summary": "Create a new collection",
        "tags": [
          "Collections"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a new collection"
      }
    },
    "/api/v1/config/monitors": {
      "get": {
        "operationId": "listMonitors",
        "summary": "List all monitors",
        "tags": [
          "Monitors"
        ],
        "parameters": [
          {
            "name": "page.token",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all monitors"
      }
    },
    "/data/metrics/api/v1/query": {
      "get": {
        "operationId": "queryMetrics",
        "summary": "Execute metric queries",
        "tags": [
          "Metrics"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Execute metric queries"
      }
    }
  },
  "security": [
    {
      "apiToken": []
    }
  ],
  "tags": [
    {
      "name": "Collections"
    },
    {
      "name": "Metrics"
    },
    {
      "name": "Monitors"
    }
  ],
  "components": {
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "header",
        "name": "apiToken"
      }
    }
  }
}
