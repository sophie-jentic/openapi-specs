{
  "openapi": "3.0.3",
  "info": {
    "title": "Tallyfy REST API",
    "version": "1.0.0",
    "description": "Tallyfy API for workflow and process management",
    "contact": {
      "url": "https://go.tallyfy.com/api/"
    }
  },
  "servers": [
    {
      "url": "https://api.tallyfy.com"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/processes": {
      "get": {
        "summary": "List processes",
        "description": "Retrieve a list of processes",
        "operationId": "listProcesses",
        "tags": [
          "Processes"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "description": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks": {
      "get": {
        "summary": "List tasks",
        "description": "Retrieve a list of tasks",
        "operationId": "listTasks",
        "tags": [
          "Tasks"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "title": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "tags": [
    {
      "name": "Processes"
    },
    {
      "name": "Tasks"
    }
  ]
}
