  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Obtain your access token from the Spyse dashboard."
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "description": "Response data payload"
          },
          "error": {
            "type": "string",
            "nullable": true,
            "description": "Error message if applicable"
          }
        }
      },
      "SearchRequest": {
        "type": "object",
        "required": [
          "search_params"
        ],
        "properties": {
          "search_params": {
            "type": "array",
            "description": "Array of search parameter groups",
            "items": {
              "type": "object",
              "properties": {
                "operator": {
                  "type": "string",
                  "description": "Search operator",
                  "enum": [
                    "eq",
                    "not_eq",
                    "contains",
                    "not_contains",
                    "starts",
                    "ends",
                    "exists",
                    "not_exists",
                    "gt",
                    "gte",
                    "lt",
                    "lte"
                  ]
                },
                "field": {
                  "type": "string",
                  "description": "Field to search on"
                },
                "value": {
                  "type": "string",
                  "description": "Value to match"
                }
              }
            }
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of results",
            "default": 100
          },
          "offset": {
            "type": "integer",
            "description": "Offset for pagination",
            "default": 0
          }
        }
      },
      "ScrollSearchRequest": {
        "type": "object",
        "required": [
          "search_params"
        ],
        "properties": {
          "search_params": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "operator": {
                  "type": "string"
                },
                "field": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          },
          "scroll_id": {
            "type": "string",
            "description": "Scroll cursor ID from previous response (omit for first request)"
          }
        }
      },
      "BulkSearchRequest": {
        "type": "object",
        "required": [
          "search_params"
        ],
        "properties": {
          "search_params": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "operator": {
                  "type": "string"
                },
                "field": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "total_count": {
                "type": "integer"
              }
            }
          }
        }
      },
      "ScrollSearchResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "scroll_id": {
                "type": "string",
                "description": "Cursor ID for the next page"
              }
            }
          }
        }
      },
      "CountResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "total_count": {
                "type": "integer",
                "description": "Total number of matching results"
              }
            }
          }
        }
      },
      "DownloadResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Download job ID"
              },
              "status": {
                "type": "string",
                "description": "Download status"
              }
            }
          }
        }
      },
      "AccountInfo": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "start_at": {
                "type": "string",
                "format": "date-time"
              },
              "end_at": {
                "type": "string",
                "format": "date-time"
              },
              "api_requests_remaining": {
                "type": "integer"
              },
              "api_requests_limit": {
                "type": "integer"
              },
              "downloads_limit_remaining": {
                "type": "integer"
              },
              "is_scroll_search_enabled": {
                "type": "boolean"
              },
              "search_params_limit": {
                "type": "integer"
              },
              "on_demand_scans_remaining": {
                "type": "integer"
              }
            }
          }
        }
      }
    }
  }
}
