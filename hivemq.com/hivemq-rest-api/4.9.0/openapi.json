            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/management/retained-messages/{topic}": {
      "get": {
        "operationId": "getRetainedMessage",
        "summary": "Get a specific retained message by topic",
        "tags": [
          "Retained Messages"
        ],
        "parameters": [
          {
            "name": "topic",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Topic of the retained message"
          }
        ],
        "responses": {
          "200": {
            "description": "Retained message",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RetainedMessage"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get a specific retained message by topic"
      },
      "delete": {
        "operationId": "deleteRetainedMessage",
        "summary": "Delete a retained message by topic",
        "tags": [
          "Retained Messages"
        ],
        "parameters": [
          {
            "name": "topic",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Topic of the retained message to delete"
          }
        ],
        "responses": {
          "204": {
            "description": "Retained message deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete a retained message by topic"
      }
    },
    "/management/trace-recordings": {
      "get": {
        "operationId": "listTraceRecordings",
        "summary": "List all trace recordings",
        "tags": [
          "Trace Recordings"
        ],
        "responses": {
          "200": {
            "description": "List of trace recordings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TraceRecordingListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
