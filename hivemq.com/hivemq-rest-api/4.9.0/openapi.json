    "/management/backups": {
      "get": {
        "operationId": "listBackups",
        "summary": "List all backups",
        "description": "Get a list of all available backups on the HiveMQ cluster.",
        "tags": [
          "Backups"
        ],
        "responses": {
          "200": {
            "description": "List of backups",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackupListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createBackup",
        "summary": "Create a new backup",
        "description": "Initiate a cluster-wide backup of all persistent session data.",
        "tags": [
          "Backups"
        ],
        "responses": {
          "202": {
            "description": "Backup creation started"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Another backup or restore operation is in progress",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/management/backups/{backupId}": {
      "get": {
        "operationId": "getBackup",
        "summary": "Get backup details",
        "tags": [
          "Backups"
        ],
        "parameters": [
          {
            "name": "backupId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Backup details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Backup"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Backup not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get backup details"
      }
    },
    "/management/backups/{backupId}/download": {
      "get": {
        "operationId": "downloadBackup",
        "summary": "Download a backup file",
        "tags": [
          "Backups"
        ],
        "parameters": [
          {
            "name": "backupId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Backup file",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Backup not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Download a backup file"
      }
    },
    "/management/backups/{backupId}/restore": {
      "post": {
        "operationId": "restoreBackup",
        "summary": "Restore from a backup",
        "description": "Initiate a cluster-wide restore from a specific backup.",
        "tags": [
          "Backups"
        ],
        "parameters": [
          {
            "name": "backupId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Restore started"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Another backup or restore is in progress",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ClientListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ClientSummary"
            }
          },
          "_links": {
            "$ref": "#/components/schemas/PaginationLinks"
          }
        }
      },
      "ClientSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "MQTT client identifier"
          }
        }
      },
      "ClientDetailsResponse": {
        "type": "object",
        "properties": {
          "client": {
            "$ref": "#/components/schemas/ClientDetails"
          }
        }
      },
      "ClientDetails": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "connected": {
            "type": "boolean"
          },
          "sessionExpiryInterval": {
            "type": "integer"
          },
          "connectedAt": {
            "type": "string",
            "format": "date-time"
          },
          "messageQueueSize": {
            "type": "integer"
          },
          "willPresent": {
            "type": "boolean"
          }
        }
      },
      "ConnectionDetailsResponse": {
        "type": "object",
        "properties": {
          "connection": {
            "type": "object",
            "properties": {
              "sourceIp": {
                "type": "string"
              },
              "mqttVersion": {
                "type": "string",
                "enum": [
                  "3.1",
                  "3.1.1",
                  "5.0"
                ]
              },
              "connectedListenerId": {
                "type": "string"
              },
              "connectedNodeId": {
                "type": "string"
              },
              "keepAlive": {
                "type": "integer"
              },
              "cleanStart": {
                "type": "boolean"
              },
              "connectedAt": {
                "type": "string",
                "format": "date-time"
              },
              "tlsInformation": {
                "type": "object",
                "properties": {
                  "cipherSuite": {
                    "type": "string"
                  },
                  "tlsVersion": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "SubscriptionListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
