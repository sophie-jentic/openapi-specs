{
  "openapi": "3.0.3",
  "info": {
    "title": "HiveMQ REST API",
    "version": "4.9.0",
    "description": "HiveMQ MQTT broker REST API for managing MQTT clients, subscriptions, retained messages, trace recordings, and backups. The API is disabled by default and binds to 127.0.0.1:8888 when enabled.",
    "x-jentic-source-url": "https://docs.hivemq.com/hivemq/4.9/rest-api/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://{hivemq-host}:8888/api/v1",
      "description": "HiveMQ REST API"
    }
  ],
  "tags": [
    {
      "name": "MQTT Clients",
      "description": "Manage connected MQTT clients"
    },
    {
      "name": "Client Details",
      "description": "View detailed client session information"
    },
    {
      "name": "Subscriptions",
      "description": "View and manage MQTT subscriptions"
    },
    {
      "name": "Retained Messages",
      "description": "Manage retained messages"
    },
    {
      "name": "Trace Recordings",
      "description": "Manage trace recordings for debugging"
    },
    {
      "name": "Backups",
      "description": "Create and manage HiveMQ backups"
    }
  ],
  "paths": {
    "/mqtt/clients": {
      "get": {
        "operationId": "listMqttClients",
        "summary": "List all connected MQTT clients",
        "description": "Returns a paginated list of all connected MQTT client identifiers.",
        "tags": [
          "MQTT Clients"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            },
            "description": "Maximum number of clients to return"
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Cursor for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "List of clients",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/mqtt/clients/{clientId}": {
      "get": {
        "operationId": "getMqttClient",
        "summary": "Get details of a specific MQTT client",
        "description": "Returns detailed information about a specific MQTT client including connection state, session information, and message statistics.",
        "tags": [
          "Client Details"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "MQTT client identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Client details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientDetailsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Client not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "disconnectMqttClient",
        "summary": "Disconnect an MQTT client",
        "description": "Forcefully disconnect the specified MQTT client from the broker.",
        "tags": [
          "MQTT Clients"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "MQTT client identifier"
          },
          {
            "name": "preventWillMessage",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Whether to prevent the last will message from being sent"
          }
        ],
        "responses": {
          "204": {
            "description": "Client disconnected"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Client not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/mqtt/clients/{clientId}/subscriptions": {
      "get": {
        "operationId": "getClientSubscriptions",
        "summary": "List subscriptions of a specific client",
