                }
              }
            }
          }
        }
      }
    },
    "/v2/account/portfolio/history": {
      "get": {
        "operationId": "getPortfolioHistory",
        "summary": "Get portfolio history",
        "description": "Returns timeseries data about equity and profit/loss of the account.",
        "tags": [
          "Account"
        ],
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
