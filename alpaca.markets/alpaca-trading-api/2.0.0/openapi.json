      "delete": {
        "operationId": "closePosition",
        "summary": "Close a position",
        "description": "Closes (liquidates) the account's open position for the given symbol or asset_id.",
        "tags": [
          "Positions"
        ],
        "parameters": [
          {
            "name": "symbol_or_asset_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Symbol or asset ID"
          },
          {
            "name": "qty",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Number of shares to liquidate"
          },
          {
            "name": "percentage",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Percentage of position to liquidate"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
