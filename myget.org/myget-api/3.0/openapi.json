{
  "openapi": "3.0.3",
  "info": {
    "title": "MyGet API",
    "version": "3.0",
    "description": "MyGet is a hosted package repository service supporting NuGet, npm, Bower, Maven, PHP Composer, VSIX, Python (PyPI), and Symbols packages. The API provides feed management, package operations, and gallery functionality.",
    "x-jentic-source-url": "https://docs.myget.org/docs/reference/feed-endpoints",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://www.myget.org"
    }
  ],
  "paths": {
    "/F/{feedName}/api/v3/index.json": {
      "get": {
        "operationId": "getFeedIndex",
        "summary": "Get NuGet V3 feed index",
        "tags": [
          "NuGet Feed"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "NuGet V3 service index",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NuGetServiceIndex"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Feed not found"
          }
        },
        "description": "Get NuGet V3 feed index"
      }
    },
    "/F/{feedName}/api/v2/Packages": {
      "get": {
        "operationId": "listPackages",
        "summary": "List packages (NuGet V2 OData)",
        "tags": [
          "NuGet Feed"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$filter",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "OData filter"
          },
          {
            "name": "$orderby",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$top",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "$skip",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Package list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List packages (NuGet V2 OData)"
      }
    },
    "/F/{feedName}/api/v2/package/{packageId}/{version}": {
      "get": {
        "operationId": "downloadPackage",
        "summary": "Download a package",
        "tags": [
          "NuGet Feed"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "packageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Package file",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "Package not found"
          }
        },
        "description": "Download a package"
      },
      "put": {
        "operationId": "pushPackage",
        "summary": "Push a package to feed",
        "tags": [
          "NuGet Feed"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "packageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "package": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Package pushed"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "409": {
            "description": "Package already exists"
          }
        },
        "description": "Push a package to feed"
      },
      "delete": {
        "operationId": "deletePackage",
        "summary": "Delete a package",
        "tags": [
          "NuGet Feed"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "packageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Package deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Delete a package"
      }
    },
    "/F/{feedName}/api/v2/Search()": {
      "get": {
        "operationId": "searchPackages",
        "summary": "Search packages",
        "tags": [
          "NuGet Feed"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchTerm",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "targetFramework",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includePrerelease",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Search packages"
      }
    },
    "/F/{feedName}/npm": {
      "get": {
        "operationId": "getNpmFeedRoot",
        "summary": "npm feed root",
        "tags": [
          "npm Feed"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "npm registry info"
          }
        },
        "description": "npm feed root"
      }
    },
    "/F/{feedName}/npm/{packageName}": {
      "get": {
        "operationId": "getNpmPackage",
        "summary": "Get npm package metadata",
        "tags": [
          "npm Feed"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "packageName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Package metadata"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get npm package metadata"
      }
    },
    "/F/{feedName}/maven/{groupPath}/{artifactId}/{version}/{fileName}": {
      "get": {
        "operationId": "getMavenArtifact",
        "summary": "Download Maven artifact",
        "tags": [
          "Maven Feed"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "groupPath",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "artifactId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fileName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Artifact file"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Download Maven artifact"
      }
    },
    "/F/{feedName}/auth/token": {
      "get": {
        "operationId": "getApiToken",
        "summary": "Get API access token",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Access token"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get API access token"
      }
    },
    "/api/v1/feeds": {
      "get": {
        "operationId": "listFeeds",
        "summary": "List all feeds",
        "tags": [
          "Feed Management"
        ],
        "responses": {
          "200": {
            "description": "List of feeds",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Feed"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all feeds"
      },
      "post": {
        "operationId": "createFeed",
        "summary": "Create a new feed",
        "tags": [
          "Feed Management"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFeedRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Feed created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Create a new feed"
      }
    },
    "/api/v1/feeds/{feedName}": {
      "get": {
        "operationId": "getFeed",
        "summary": "Get feed details",
        "tags": [
          "Feed Management"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Feed details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feed"
                }
              }
            }
          },
          "404": {
            "description": "Feed not found"
          }
        },
        "description": "Get feed details"
      },
      "put": {
        "operationId": "updateFeed",
        "summary": "Update feed settings",
        "tags": [
          "Feed Management"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateFeedRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Feed updated"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update feed settings"
      },
      "delete": {
        "operationId": "deleteFeed",
        "summary": "Delete a feed",
        "tags": [
          "Feed Management"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Feed deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Delete a feed"
      }
    },
    "/api/v1/feeds/{feedName}/packages": {
      "get": {
        "operationId": "listFeedPackages",
        "summary": "List packages in a feed",
        "tags": [
          "Feed Management"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Package list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List packages in a feed"
      }
    },
    "/api/v1/feeds/{feedName}/privileges": {
      "get": {
        "operationId": "listFeedPrivileges",
        "summary": "List feed privileges",
        "tags": [
          "Feed Management"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Privileges list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List feed privileges"
      },
      "post": {
        "operationId": "addFeedPrivilege",
        "summary": "Add feed privilege",
        "tags": [
          "Feed Management"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "privilege": {
                    "type": "string",
                    "enum": [
                      "FeedContributor",
                      "FeedOwner"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Privilege added"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Add feed privilege"
      }
    },
    "/F/{feedName}/pypi": {
      "get": {
        "operationId": "getPyPIIndex",
        "summary": "PyPI simple index",
        "tags": [
          "PyPI Feed"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PyPI simple index"
          }
        },
        "description": "PyPI simple index"
      }
    },
    "/F/{feedName}/vsix": {
      "get": {
        "operationId": "getVsixFeed",
        "summary": "VSIX feed endpoint",
        "tags": [
          "VSIX Feed"
        ],
        "parameters": [
          {
            "name": "feedName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "VSIX feed"
          }
        },
        "description": "VSIX feed endpoint"
      }
    },
    "/api/v1/gallery": {
      "get": {
        "operationId": "getGallery",
        "summary": "Get public gallery",
        "tags": [
          "Gallery"
        ],
        "responses": {
          "200": {
            "description": "Public gallery feeds"
          }
        },
        "description": "Get public gallery"
      }
    }
  },
  "components": {
    "schemas": {
      "NuGetServiceIndex": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string"
          },
          "resources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "@id": {
                  "type": "string"
                },
                "@type": {
                  "type": "string"
                },
                "comment": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Feed": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "feedType": {
            "type": "string"
          },
          "isListed": {
            "type": "boolean"
          },
          "packageCount": {
            "type": "integer"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateFeedRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "feedType": {
            "type": "string",
            "enum": [
              "nuget",
              "npm",
              "bower",
              "maven",
              "vsix",
              "pypi",
              "php-composer"
            ]
          }
        }
      },
      "UpdateFeedRequest": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "isListed": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "name": "X-NuGet-ApiKey",
        "in": "header",
        "description": "MyGet API key"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication with MyGet credentials"
      }
    }
  },
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Authentication"
    },
    {
      "name": "Feed Management"
    },
    {
      "name": "Gallery"
    },
    {
      "name": "Maven Feed"
    },
    {
      "name": "NuGet Feed"
    },
    {
      "name": "PyPI Feed"
    },
    {
      "name": "VSIX Feed"
    },
    {
      "name": "npm Feed"
    }
  ]
}
