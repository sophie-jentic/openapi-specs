{
  "openapi": "3.0.3",
  "info": {
    "title": "Oil Price API",
    "version": "1",
    "description": "Provides real-time and historical commodity price data for oil, gas, and related energy products. Supports WTI, Brent Crude, Natural Gas, Diesel, Heating Oil, Jet Fuel, Gasoline, Coal and 50+ other commodities.",
    "x-jentic-source-url": "https://docs.oilpriceapi.com/api-reference/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.oilpriceapi.com/v1"
    }
  ],
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "paths": {
    "/prices/latest": {
      "get": {
        "operationId": "getPricesLatest",
        "tags": [
          "Prices"
        ],
        "summary": "Get latest commodity prices",
        "description": "Returns the latest price for a specific commodity or all commodities.",
        "parameters": [
          {
            "name": "by_code",
            "in": "query",
            "description": "Filter by commodity code (e.g. WTI_USD, BRENT_CRUDE_USD)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "WTI_USD"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "Specific fields to return (comma-separated)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "price,timestamp"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Latest price data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request (e.g., invalid commodity code)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key"
          }
        }
      }
    },
    "/prices/past_day": {
      "get": {
        "operationId": "getPricesPastDay",
        "tags": [
          "Prices"
        ],
        "summary": "Get hourly prices for the past 24 hours",
        "parameters": [
          {
            "name": "by_code",
            "in": "query",
            "description": "Filter by commodity code",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hourly price data for the past 24 hours",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceHistoryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get hourly prices for the past 24 hours"
      }
    },
    "/prices/past_week": {
      "get": {
        "operationId": "getPricesPastWeek",
        "tags": [
          "Prices"
        ],
        "summary": "Get daily prices for the past 7 days",
        "parameters": [
          {
            "name": "by_code",
            "in": "query",
            "description": "Filter by commodity code",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily price data for the past 7 days",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceHistoryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get daily prices for the past 7 days"
      }
    },
    "/prices/past_month": {
      "get": {
        "operationId": "getPricesPastMonth",
        "tags": [
          "Prices"
        ],
        "summary": "Get daily prices for the past 30 days",
        "parameters": [
          {
            "name": "by_code",
            "in": "query",
            "description": "Filter by commodity code",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily price data for the past 30 days",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceHistoryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get daily prices for the past 30 days"
      }
    },
    "/prices/past_year": {
      "get": {
        "operationId": "getPricesPastYear",
        "tags": [
          "Prices"
        ],
        "summary": "Get weekly prices for the past year",
        "parameters": [
          {
            "name": "by_code",
            "in": "query",
            "description": "Filter by commodity code",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Weekly price data for the past year",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceHistoryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get weekly prices for the past year"
      }
    },
    "/commodities": {
      "get": {
        "operationId": "listCommodities",
        "tags": [
          "Commodities"
        ],
        "summary": "List all available commodities",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Pagination page number",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page (max 100)",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of all available commodities",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommodityListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all available commodities"
      }
    },
    "/commodities/{code}": {
      "get": {
        "operationId": "getCommodityDetails",
        "tags": [
          "Commodities"
        ],
        "summary": "Get details for a specific commodity",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "description": "Commodity code (e.g. WTI_USD)",
            "required": true,
            "schema": {
              "type": "string",
              "example": "WTI_USD"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Commodity details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommodityDetailsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get details for a specific commodity"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token-based authentication. Format: 'Token YOUR_API_KEY'"
      }
    },
    "schemas": {
      "PriceData": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number",
            "description": "Price value",
            "example": 74.52
          },
          "formatted": {
            "type": "string",
            "description": "Formatted price string",
            "example": "$74.52"
          },
          "currency": {
            "type": "string",
            "description": "Currency code",
            "example": "USD"
          },
          "code": {
            "type": "string",
            "description": "Commodity code",
            "example": "WTI_USD"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of when the price was recorded"
          },
          "type": {
            "type": "string",
            "description": "Price type",
            "example": "spot_price"
          },
          "source": {
            "type": "string",
            "description": "Data source",
            "example": "oilprice.business_insider"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string"
              },
              "source_description": {
                "type": "string"
              }
            }
          }
        }
      },
      "PriceResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "error"
            ]
          },
          "data": {
            "$ref": "#/components/schemas/PriceData"
          },
          "meta": {
            "$ref": "#/components/schemas/MetaData"
          }
        }
      },
      "PriceHistoryResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "error"
            ]
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PriceData"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/MetaData"
          }
        }
      },
      "CommodityListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "error"
            ]
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CommodityData"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/MetaData"
          }
        }
      },
      "CommodityDetailsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "error"
            ]
          },
          "data": {
            "$ref": "#/components/schemas/CommodityData"
          },
          "meta": {
            "$ref": "#/components/schemas/MetaData"
          }
        }
      },
      "CommodityData": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Commodity code",
            "example": "WTI_USD"
          },
          "description": {
            "type": "string",
            "description": "Commodity description",
            "example": "West Texas Intermediate Crude Oil"
          },
          "category": {
            "type": "string",
            "description": "Commodity category",
            "example": "Crude Oil"
          },
          "update_frequency": {
            "type": "string",
            "description": "Update frequency",
            "example": "Every 5 min"
          }
        }
      },
      "MetaData": {
        "type": "object",
        "properties": {
          "request_id": {
            "type": "string",
            "description": "Unique request identifier"
          },
          "response_time_ms": {
            "type": "integer",
            "description": "Response time in milliseconds"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Request timestamp"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code",
                "example": "INVALID_COMMODITY"
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              },
              "request_id": {
                "type": "string",
                "description": "Request ID for debugging"
              },
              "docs": {
                "type": "string",
                "description": "URL to error documentation"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Commodities"
    },
    {
      "name": "Prices"
    }
  ]
}
