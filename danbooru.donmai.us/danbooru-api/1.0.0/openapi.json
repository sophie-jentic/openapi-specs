                "properties": {
                  "comment[post_id]": {
                    "type": "integer"
                  },
                  "comment[body]": {
                    "type": "string"
                  },
                  "comment[do_not_bump_post]": {
                    "type": "boolean"
                  }
                }
              }
            }
