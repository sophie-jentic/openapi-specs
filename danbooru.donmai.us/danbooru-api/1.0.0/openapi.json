          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Upload a new file"
      }
    },
    "/tags.json": {
      "get": {
        "operationId": "list_tags",
        "summary": "List tags",
        "tags": [
          "Tags"
        ],
        "parameters": [
          {
            "name": "search[name_matches]",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search[category]",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1,
                3,
                4,
                5
              ]
            },
            "description": "0=general, 1=artist, 3=copyright, 4=character, 5=meta"
          },
          {
            "name": "search[order]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "name",
                "date",
                "count"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Tag"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List tags"
      }
    },
