{
  "openapi": "3.0.3",
  "info": {
    "title": "Danbooru API",
    "version": "1.0.0",
    "description": "Danbooru image board REST API. Provides access to posts, tags, comments, users, pools, artists, notes, wiki pages, and favorites. All endpoints support JSON responses by appending .json.",
    "x-jentic-source-url": "https://danbooru.donmai.us/wiki_pages/help:api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://danbooru.donmai.us"
    }
  ],
  "paths": {
    "/posts.json": {
      "get": {
        "operationId": "list_posts",
        "summary": "List posts",
        "description": "Get a paginated list of posts matching search criteria.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "tags",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Space-separated tag search"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 200
            }
          },
          {
            "name": "random",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Post"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/posts/{id}.json": {
      "get": {
        "operationId": "get_post",
        "summary": "Get post by ID",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Post"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Post not found"
          }
        },
        "description": "Get post by ID"
      },
      "patch": {
        "operationId": "update_post",
        "summary": "Update a post",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "post[tag_string]": {
                    "type": "string"
                  },
                  "post[rating]": {
                    "type": "string",
                    "enum": [
                      "g",
                      "s",
                      "q",
                      "e"
                    ]
                  },
                  "post[source]": {
                    "type": "string"
                  },
                  "post[parent_id]": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Post"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Update a post"
      }
    },
    "/uploads.json": {
      "post": {
        "operationId": "create_upload",
        "summary": "Upload a new file",
        "tags": [
          "Uploads"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "upload[file]": {
                    "type": "string",
                    "format": "binary"
                  },
                  "upload[source]": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Upload"
