{
  "openapi": "3.0.3",
  "info": {
    "title": "Azure Speech to Text REST API",
    "description": "The Azure Cognitive Services Speech to Text REST API provides batch transcription capabilities, allowing you to submit audio files for transcription, monitor transcription status, and retrieve results. Supports word-level timestamps, speaker diarization, language identification, custom models, and profanity filtering.",
    "version": "2024-11-15",
    "contact": {
      "name": "Microsoft Azure Support",
      "url": "https://learn.microsoft.com/en-us/azure/ai-services/speech-service/"
    },
    "x-categories": [
      "AI",
      "Speech Recognition"
    ],
    "x-logo": {
      "url": "https://learn.microsoft.com/favicon.ico"
    }
  },
  "servers": [
    {
      "url": "https://{region}.api.cognitive.microsoft.com",
      "description": "Azure Cognitive Services regional endpoint",
      "variables": {
        "region": {
          "default": "westus",
          "description": "Azure region (e.g., westus, eastus, westeurope)"
        }
      }
    }
  ],
  "security": [
    {
      "OcpApimSubscriptionKey": []
    }
  ],
  "paths": {
    "/speechtotext/transcriptions:submit": {
      "post": {
        "operationId": "submitTranscription",
        "summary": "Submit a new transcription job",
        "description": "Submits a new batch transcription job using audio content URLs or a blob container URL. The transcription is processed asynchronously.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranscriptionSubmitRequest"
              },
              "example": {
                "displayName": "Transcription using default model for en-US",
                "locale": "en-US",
                "contentUrls": [
                  "https://contoso.com/mystoragelocation"
                ],
                "properties": {
                  "wordLevelTimestampsEnabled": false,
                  "displayFormWordLevelTimestampsEnabled": false,
                  "punctuationMode": "DictatedAndAutomatic",
                  "profanityFilterMode": "Masked",
                  "timeToLiveHours": 48
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Transcription job created successfully",
            "headers": {
              "Location": {
                "description": "URL of the created transcription resource",
                "schema": {
                  "type": "string",
                  "format": "uri"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transcription"
                }
              }
            }
          },
          "default": {
            "description": "An error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "Transcriptions"
        ]
      }
    },
    "/speechtotext/transcriptions": {
      "get": {
        "operationId": "listTranscriptions",
        "summary": "List transcriptions",
        "description": "Gets a list of transcriptions for the authenticated subscription.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Number of transcriptions to skip",
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "top",
            "in": "query",
            "description": "Maximum number of transcriptions to return",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of transcriptions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptionList"
                }
              }
            }
          },
          "default": {
            "description": "An error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "Transcriptions"
        ]
      }
    },
    "/speechtotext/transcriptions/{id}": {
      "get": {
        "operationId": "getTranscription",
        "summary": "Get a transcription",
        "description": "Gets the transcription identified by the given ID.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "$ref": "#/components/parameters/TranscriptionId"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transcription details",
            "headers": {
              "Retry-After": {
                "description": "Suggested retry interval in seconds",
                "schema": {
                  "type": "integer"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transcription"
                }
              }
            }
          },
          "default": {
            "description": "An error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "Transcriptions"
        ]
      },
      "patch": {
        "operationId": "updateTranscription",
        "summary": "Update a transcription",
        "description": "Updates the mutable details of the transcription identified by its ID.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "$ref": "#/components/parameters/TranscriptionId"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranscriptionUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transcription updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transcription"
                }
              }
            }
          },
          "default": {
            "description": "An error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "Transcriptions"
        ]
      },
      "delete": {
        "operationId": "deleteTranscription",
        "summary": "Delete a transcription",
        "description": "Deletes the specified transcription task.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "$ref": "#/components/parameters/TranscriptionId"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Transcription deleted successfully"
          },
          "default": {
            "description": "An error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "Transcriptions"
        ]
      }
    },
    "/speechtotext/transcriptions/{id}/files": {
      "get": {
        "operationId": "listTranscriptionFiles",
        "summary": "List transcription files",
        "description": "Gets the files of the transcription identified by the given ID.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "$ref": "#/components/parameters/TranscriptionId"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of transcription files",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptionFileList"
                }
              }
            }
          },
          "default": {
            "description": "An error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "Transcriptions"
        ]
      }
    },
    "/speechtotext/transcriptions/{id}/files/{fileId}": {
      "get": {
        "operationId": "getTranscriptionFile",
        "summary": "Get a transcription file",
        "description": "Gets one specific file from a transcription.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "$ref": "#/components/parameters/TranscriptionId"
          },
          {
            "name": "fileId",
            "in": "path",
            "required": true,
            "description": "The identifier of the file",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transcription file details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptionFile"
                }
              }
            }
          },
          "default": {
            "description": "An error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "Transcriptions"
        ]
      }
    },
    "/speechtotext/transcriptions:transcribe": {
      "post": {
        "operationId": "transcribeAudio",
        "summary": "Synchronous transcription",
        "description": "Synchronous transcription of an audio file.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "locale": {
                    "type": "string",
                    "description": "The locale of the audio",
                    "example": "en-US"
                  },
                  "contentUrls": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "uri"
                    },
                    "description": "URLs to audio files"
                  }
                },
                "required": [
                  "locale"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transcription result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "default": {
            "description": "An error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "Transcriptions"
        ]
      }
    },
    "/speechtotext/transcriptions/locales": {
      "get": {
        "operationId": "listSupportedLocales",
        "summary": "List supported locales",
        "description": "Gets a list of supported locales for offline transcriptions.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          }
        ],
        "responses": {
          "200": {
            "description": "List of supported locales",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "en-US",
                    "fr-FR",
                    "de-DE"
                  ]
                }
              }
            }
          },
          "default": {
            "description": "An error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "Transcriptions"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "OcpApimSubscriptionKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Ocp-Apim-Subscription-Key",
        "description": "Azure Cognitive Services subscription key"
      }
    },
    "parameters": {
      "ApiVersion": {
        "name": "api-version",
        "in": "query",
        "required": true,
        "description": "API version",
        "schema": {
          "type": "string",
          "default": "2024-11-15"
        }
      },
      "TranscriptionId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "The identifier of the transcription",
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "schemas": {
      "TranscriptionSubmitRequest": {
        "type": "object",
        "required": [
          "displayName",
          "locale",
          "properties"
        ],
        "properties": {
          "displayName": {
            "type": "string",
            "minLength": 1,
            "description": "Display name of the transcription"
          },
          "description": {
            "type": "string",
            "description": "Description of the transcription"
          },
          "locale": {
            "type": "string",
            "minLength": 1,
            "description": "Locale of the contained data. If Language Identification is used, this is used as fallback locale.",
            "example": "en-US"
          },
          "contentUrls": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "List of content URLs to audio files (up to 1000)"
          },
          "contentContainerUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL for an Azure blob container containing audio files"
          },
          "properties": {
            "$ref": "#/components/schemas/TranscriptionProperties"
          },
          "customProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Custom key-value properties (max 10 entries)"
          },
          "model": {
            "$ref": "#/components/schemas/EntityReference"
          },
          "dataset": {
            "$ref": "#/components/schemas/EntityReference"
          }
        }
      },
      "TranscriptionUpdate": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "description": "Updated display name"
          },
          "description": {
            "type": "string",
            "description": "Updated description"
          },
          "customProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "Transcription": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string",
            "format": "uri",
            "description": "The location of this entity"
          },
          "displayName": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          },
          "customProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "lastActionDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "$ref": "#/components/schemas/Status"
          },
          "model": {
            "$ref": "#/components/schemas/EntityReference"
          },
          "links": {
            "$ref": "#/components/schemas/TranscriptionLinks"
          },
          "properties": {
            "$ref": "#/components/schemas/TranscriptionResponseProperties"
          }
        }
      },
      "TranscriptionProperties": {
        "type": "object",
        "properties": {
          "wordLevelTimestampsEnabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable word-level timestamps"
          },
          "displayFormWordLevelTimestampsEnabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable display form word-level timestamps"
          },
          "punctuationMode": {
            "$ref": "#/components/schemas/PunctuationMode"
          },
          "profanityFilterMode": {
            "$ref": "#/components/schemas/ProfanityFilterMode"
          },
          "timeToLiveHours": {
            "type": "integer",
            "description": "How long to keep the transcription after completion",
            "example": 48
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Audio channels to transcribe"
          },
          "diarization": {
            "$ref": "#/components/schemas/DiarizationProperties"
          },
          "languageIdentification": {
            "$ref": "#/components/schemas/LanguageIdentificationProperties"
          }
        }
      },
      "TranscriptionResponseProperties": {
        "allOf": [
          {
            "$ref": "#/components/schemas/TranscriptionProperties"
          },
          {
            "type": "object",
            "properties": {
              "durationMilliseconds": {
                "type": "integer",
                "format": "int64",
                "description": "Duration of the audio in milliseconds"
              },
              "error": {
                "$ref": "#/components/schemas/EntityError"
              }
            }
          }
        ]
      },
      "TranscriptionLinks": {
        "type": "object",
        "properties": {
          "files": {
            "type": "string",
            "format": "uri",
            "description": "URL to the transcription files"
          }
        }
      },
      "TranscriptionList": {
        "type": "object",
        "properties": {
          "values": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transcription"
            }
          },
          "@nextLink": {
            "type": "string",
            "format": "uri",
            "description": "Link to the next page of results"
          }
        }
      },
      "TranscriptionFile": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string",
            "format": "uri"
          },
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "TranscriptionReport",
              "Transcription"
            ]
          },
          "properties": {
            "type": "object",
            "properties": {
              "size": {
                "type": "integer",
                "format": "int64"
              }
            }
          }
        }
      },
      "TranscriptionFileList": {
        "type": "object",
        "properties": {
          "values": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TranscriptionFile"
            }
          },
          "@nextLink": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "EntityReference": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string",
            "format": "uri",
            "description": "The location of the referenced entity"
          }
        }
      },
      "DiarizationProperties": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Whether speaker diarization is enabled"
          },
          "maxSpeakers": {
            "type": "integer",
            "format": "int32",
            "minimum": 2,
            "maximum": 35,
            "description": "Hint for maximum number of speakers"
          }
        }
      },
      "LanguageIdentificationProperties": {
        "type": "object",
        "properties": {
          "candidateLocales": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of candidate locales for language identification"
          },
          "speechModelMapping": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/EntityReference"
            },
            "description": "Mapping of locale to custom speech model"
          },
          "mode": {
            "$ref": "#/components/schemas/LanguageIdentificationMode"
          }
        }
      },
      "LanguageIdentificationMode": {
        "type": "string",
        "enum": [
          "Single",
          "Continuous"
        ],
        "description": "Mode for language identification"
      },
      "PunctuationMode": {
        "type": "string",
        "enum": [
          "None",
          "Dictated",
          "Automatic",
          "DictatedAndAutomatic"
        ]
      },
      "ProfanityFilterMode": {
        "type": "string",
        "enum": [
          "None",
          "Removed",
          "Tags",
          "Masked"
        ]
      },
      "Status": {
        "type": "string",
        "enum": [
          "NotStarted",
          "Running",
          "Succeeded",
          "Failed"
        ]
      },
      "EntityError": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "High-level error code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "innerError": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          },
          "details": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Transcriptions",
      "description": "Batch transcription operations for Azure Speech to Text"
    }
  ]
}
