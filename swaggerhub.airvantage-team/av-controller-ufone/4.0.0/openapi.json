                }
              }
            }
          }
        }
      }
    },
    "/sendSMS": {
      "get": {
        "operationId": "GET_sendSMS",
        "summary": "This endpoint can be used to send a SMS.",
        "tags": [
          "Internal"
        ],
        "description": "This endpoint includes a call to be made to av_microservice_messagingmatrix/getPhrase and to av_microservice_sms/doSendSMS. \nThis call is mostly used for collection messages. ",
        "parameters": [
          {
            "name": "msisdn",
            "in": "query",
            "description": "The subscriber's MSISDN.\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "messageId",
            "in": "query",
            "description": "The messageId that needs to be fetched.\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "messageType",
            "in": "query",
            "description": "The type of message sent 1 - operational 2 - marketing.\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "initiativeId",
            "in": "query",
            "description": "The initiativeId that is passed for a message.\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "messagePriority",
            "in": "query",
            "description": "This will be set to a default of 5 if not specified. The range in which a messagePriority can be specified is 1 - 10. 1 is the highest priority.\n",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "boolean"
                        },
                        "comment": {
                          "type": "string"
                        },
                        "responseCode": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "Success": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "SMS sent.",
                        "responseCode": "01"
                      }
                    }
                  },
                  "Validation error": {
                    "value": {
                      "success": false,
                      "detail": {
                        "message": "Missing parameter for msisdn.",
                        "responseCode": "03"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
