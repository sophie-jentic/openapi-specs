  "paths": {
    "/canGetAdvance": {
      "get": {
        "operationId": "GET_canGetAdvance",
        "summary": "This endpoint is used to check if a subscriber actually qualifies for a advance.",
        "tags": [
          "External"
        ],
        "description": "This endpoint is used to check if the subscriber qualifies for a loan to be granted. This response should be interpreted before assuming that a /processAdvance call can be made. The response will indicate the different denominations that a subscriber qualifies for.  ",
        "parameters": [
          {
            "name": "msisdn",
            "in": "query",
            "description": "The subscriber's MSISDN.\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "channelId",
            "in": "query",
            "description": "1- UNKNOWN\n2 - USSD\n3 - SMS\n4 - ZERO FUNDS\n5 - FACEBOOK\n6 - UFONE WEB\n7 - APP\n8 - IVR\n9 - IBA (Insufficient Balance Assist)\n\ndefault: 1\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entityType",
            "in": "query",
            "description": "Which entity type do we want to check eligibility for? 1 = mobile money, 2 = airtime, 3 = Data",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "denomListId",
            "in": "query",
            "description": "'Which denomination list should be used? (Will be provided by Airvantage)'",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        },
                        "loanamount": {
                          "type": "string"
                        },
                        "repaydays": {
                          "type": "string"
                        },
                        "profiletierid": {
                          "type": "string"
                        },
                        "profilingcode": {
                          "type": "string"
                        },
                        "totalAdvanceBalance": {
                          "type": "string"
                        },
                        "totalServiceFeeBalance": {
                          "type": "string"
                        },
                        "totalOutstandingBalance": {
                          "type": "string"
                        },
                        "overDue": {
                          "type": "boolean"
                        }
                      }
                    },
                    "denominationList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "denominationListWithCurrency": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "rechargeList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "serviceFeeList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "examples": {
                  "Eligible": {
                    "value": {
                      "result": {
                        "success": true,
                        "profilingcode": "1",
                        "loanamount": "100",
                        "repaydays": "30",
                        "profiletierid": "32",
                        "totalAdvanceBalance": "Rs0.00",
                        "totalServiceFeeBalance": "Rs0.00",
                        "totalOutstandingBalance": "Rs0.00",
                        "overdue": false
                      },
                      "denominationList": [
                        "5",
                        "10",
                        "20",
                        "50"
                      ],
                      "denominationListWithCurrency": [
                        "Rs5",
                        "Rs10",
                        "Rs20",
                        "Rs50"
                      ],
                      "rechargeList": [
                        "6",
                        "11",
                        "22",
                        "55"
                      ],
                      "serviceFeeList": [
                        "1",
                        "1",
                        "2",
                        "5"
                      ],
                      "otherList": [
                        "Simple Airtime",
                        "Once-off Airtime",
                        "Once-off Airtime",
                        "Simple Airtime"
                      ],
                      "serviceIdList": [
                        "1",
                        "2",
                        "3",
                        "3"
                      ]
                    }
                  },
                  "Ineligible": {
                    "value": {
                      "result": {
                        "success": false,
                        "profilingcode": "2",
                        "comment": "Subscriber not eligible for an advance.",
                        "totalAdvanceBalance": "Rs0.00",
                        "totalServiceFeeBalance": "Rs0.00",
                        "totalOutstandingBalance": "Rs0.00",
                        "overdue": false
                      }
                    }
                  },
                  "Banned": {
                    "value": {
                      "result": {
                        "success": false,
                        "profilingcode": "3",
                        "comment": "Banned from using this service for another 30 days",
                        "totalAdvanceBalance": "Rs0.00",
                        "totalServiceFeeBalance": "Rs0.00",
                        "totalOutstandingBalance": "Rs0.00",
                        "overdue": false
                      }
                    }
                  },
                  "Already existing loan": {
                    "value": {
                      "result": {
                        "success": true,
                        "profilingcode": "2",
                        "comment": "The subscriber already has an open advance.",
                        "totalAdvanceBalance": "Rs10.00",
                        "totalServiceFeeBalance": "Rs1.00",
                        "totalOutstandingBalance": "Rs11.00",
                        "overdue": false
                      }
                    }
                  },
                  "Technical issue": {
                    "value": {
                      "result": {
                        "success": true,
                        "profilingcode": "2",
                        "comment": "An error occurred.",
                        "totalAdvanceBalance": "Rs0.00",
                        "totalServiceFeeBalance": "Rs0.00",
                        "totalOutstandingBalance": "Rs0.00",
                        "overdue": false
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/processAdvance": {
      "get": {
        "operationId": "GET_processAdvance",
        "summary": "This endpoint is used to add and process an advance for a subscriber.",
        "tags": [
          "External"
        ],
        "description": "The process advance endpoint can be called by UFone to add an advance on Airvantage's side. ",
        "parameters": [
          {
            "name": "msisdn",
            "in": "query",
            "description": "The MSISDN unique to the subscrier.\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "loanAmount",
            "in": "query",
            "description": "The amount the subscriber wants to borrow. Should be indicated in Rupees.\n",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "serviceAmount",
            "in": "query",
            "description": "The service fee amount that is allocated to AV for granting the loan amount. Usually dynamic. Should be indicated in Rupees. ",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "profileTierId",
            "in": "query",
            "description": "The profileTierId retrieved from the response as received from canGetAdvance.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "qualifiedAmount",
            "in": "query",
            "description": "The loanamount that has been received in the canGetAdvance endpoint call.",
            "required": false,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "channelId",
            "in": "query",
            "description": "1- UNKNOWN\n2 - USSD\n3 - SMS\n4 - ZERO FUNDS\n5 - FACEBOOK\n6 - UFONE WEB\n7 - APP\n8 - IVR\n9 - IBA (Insufficient Balance Assist)\n\ndefault: 1\n",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "entityType",
            "in": "query",
            "description": "This is the type of recharge being made. \n1 - MoMo \n2 - Airtime\n3 - Data ",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "languageId",
            "in": "query",
            "description": "This is the preferred language of the subscriber.  1- English 2 - Urdu <br/> default: 1",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "boolean"
                        },
                        "comment": {
                          "type": "string"
                        },
                        "responseCode": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "Success": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "Advance was successfully processed.",
                        "responseCode": "01"
                      }
                    }
                  },
                  "Validation error": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "Missing parameter for msisdn.",
                        "responseCode": "03"
                      }
                    }
                  },
                  "Loan consumption below Rs150.00 error": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "Please consume Rs150 on the network.",
                        "responseCode": "00"
                      }
                    }
                  },
                  "Balance above Rs11.95 error": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "This service is available for the users with balance less than Rs11.95.",
                        "responseCode": "00"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/sendDetailedBalanceSMS": {
      "get": {
        "operationId": "GET_sendDetailedBalanceSMS",
        "summary": "This endpoint is used to send a detailed balance SMS to the subscriber and is used internally by Airvantage.",
        "tags": [
          "Internal"
        ],
        "description": "The send detailed balance endpoint is used internally by Airvantage. ",
        "parameters": [
          {
            "name": "msisdn",
            "in": "query",
            "description": "The MSISDN unique to the subscrier.\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "encoded",
            "in": "query",
            "description": "This states if the URL should be encoded when sent.<br/> encode = 1 then the returned message will be URL encoded. <br/>\ndefault: 0",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "languageId",
            "in": "query",
            "description": "This is the preferred language of the subscriber.  1- English 2 - Urdu <br/> default: 1",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "boolean"
                        },
                        "comment": {
                          "type": "string"
                        },
                        "responseCode": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "Success": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "Detailed balance SMS will be sent to subscriber.",
