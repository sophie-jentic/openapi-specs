{
  "openapi": "3.0.0",
  "info": {
    "version": "5.0",
    "title": "av_integration_mtc_api",
    "description": "This integration provides endpoints to check subscriber eligibility and to add advances for subscribers on the AV advance system</br>",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/airvantage-team/av_integration_mtc_api/5.0/swagger.json",
    "contact": {}
  },
  "paths": {
    "/canGetAdvance": {
      "get": {
        "operationId": "GET_canGetAdvance",
        "summary": "This endpoint is used to check if a subscriber is eligible for an advance.",
        "tags": [
          "Endpoints"
        ],
        "description": "When a client/partner calls <b></i>/canGetAdvance</i></b>, this service will check if the subscriber qualifies for an advance and for how much the subscriber qualifies for. A list of possible denominations will be returned in the response along with associated lists and values that are needed for when /processAdvance is called.",
        "parameters": [
          {
            "name": "msisdn",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "channelId",
            "in": "query",
            "description": "Id of the channel that is calling this endpoint (Will be provided by Airvantage)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entityType",
            "in": "query",
            "description": "Which entity type do we want to check eligibility for? 1 = mobile money, 2 = airtime, 3 = Data",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "denomListId",
            "in": "query",
            "description": "'Which denomination list should be used? (Will be provided by Airvantage)'",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "queryParameterB",
            "in": "query",
            "description": "'Value of offer minus the current balance of the subscriber, i.e \"shortfall\" or amount needed to complete the bundle'",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "description": "the tag is optional (for future implementation)",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        },
                        "loanamount": {
                          "type": "string"
                        },
                        "repaydays": {
                          "type": "string"
                        },
                        "profiletierid": {
                          "type": "string"
                        },
                        "profilingcode": {
                          "type": "string"
                        }
                      }
                    },
                    "denominationList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "denominationListWithCurrency": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "rechargeList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "serviceFeeList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "examples": {
                  "Eligible": {
                    "value": {
                      "result": {
                        "success": true,
                        "profilingcode": "1",
                        "loanamount": "100",
                        "repaydays": "30",
                        "profiletierid": "32"
                      },
                      "denominationList": [
                        "5"
                      ],
                      "denominationListWithCurrency": [
                        "R5"
                      ],
                      "rechargeList": [
                        "6"
                      ],
                      "serviceFeeList": [
                        "1"
                      ],
                      "otherList": [
                        "Simple Airtime"
                      ],
                      "serviceIdList": [
                        "1"
                      ]
                    }
                  },
                  "Ineligible": {
                    "value": {
                      "result": {
                        "success": false,
                        "profilingcode": "2",
                        "comment": "Subscriber not eligible"
                      }
                    }
                  },
                  "Banned": {
                    "value": {
                      "result": {
                        "success": false,
                        "profilingcode": "3",
                        "comment": "Banned from using this service for another 30 days"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/processAdvance": {
      "get": {
        "operationId": "GET_processAdvance",
        "summary": "This endpoint is used to register and process an advance for a subscriber.",
        "tags": [
          "Endpoints"
        ],
        "description": "The service/partner calls <b><i>/canGetAdvance</i></b>.  </br></br> If the response is affirmative, that response would be accompanied by a list of denominations that the subscriber can choose from. </br></br> Subsequently, depending on the subscriber's choice, <b></i>/processAdvance</i></b> gets called to register the advance with Airvantage. ",
        "parameters": [
          {
            "name": "msisdn",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "channelId",
            "in": "query",
            "description": "Id of the channel calling this endpoint\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "denomListId",
            "in": "query",
            "description": "The denomination list id that was used in the /canGetAdvance call (Will be provided by Airvantage)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entityType",
            "in": "query",
            "description": "Type of advance (1=MoMo, 2=Airtime, 3=Data)\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "serviceId",
            "in": "query",
            "description": "Id of the service (option from /canGetAdvance serviceIdList)\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "loanAmount",
            "in": "query",
            "description": "Amount to advance the subscriber with (option selected from /canGetAdvance denomList)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "serviceAmount",
            "in": "query",
            "description": "Service fee (option from /canGetAdvance serviceFeeList)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "profileTierId",
            "in": "query",
            "description": "From the /canGetAdvance response",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repayDays",
            "in": "query",
            "description": "From the /canGetAdvance response",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "qualifiedAmount",
            "in": "query",
            "description": "Amount the person qualified to borrow (loanAmount from /canGetAdvance)",
            "required": true,
            "schema": {
              "type": "string",
              "default": "loanAmount"
            }
          },
          {
            "name": "rechargeAmount",
            "in": "query",
            "description": "Typically the same as \"loanAmount\". (option from /canGetAdvance rechargeList)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "chosenAmount",
            "in": "query",
            "description": "Amount person chose to borrow",
            "schema": {
              "type": "string",
              "default": "loanAmount"
            }
          },
          {
            "name": "sync",
            "in": "query",
            "description": "If sync=1 value is passed, then the request will be synchronous, otherwise, if\nthis parameter is omitted or the value is not 1, the request will be asynchronous\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "Success": {
                    "value": {
                      "result": {
                        "success": true
                      }
                    }
                  },
                  "Failure": {
                    "value": {
                      "result": {
                        "success": false
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Endpoints"
    }
  ],
