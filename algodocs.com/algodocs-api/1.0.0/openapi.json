{
  "openapi": "3.0.3",
  "info": {
    "title": "Algodocs API",
    "version": "1.0.0",
    "description": "Algodocs is an intelligent document data extraction service. The REST API provides endpoints for managing extractors, uploading documents, retrieving extracted data, managing folders, and querying document processing results.",
    "x-jentic-source-url": "https://algodocs.com",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://app.algodocs.com/api"
    }
  ],
  "tags": [
    {
      "name": "Extractors",
      "description": "Document extractor management"
    },
    {
      "name": "Documents",
      "description": "Document upload and management"
    },
    {
      "name": "Extracted Data",
      "description": "Retrieve extracted data from documents"
    },
    {
      "name": "Folders",
      "description": "Folder management"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/extractors": {
      "get": {
        "operationId": "listExtractors",
        "summary": "List all extractors",
        "description": "Get a list of all document extractors in the account.",
        "tags": [
          "Extractors"
        ],
        "responses": {
          "200": {
            "description": "List of extractors",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Extractor"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/extractors/{id}": {
      "get": {
        "operationId": "getExtractor",
        "summary": "Get an extractor",
        "tags": [
          "Extractors"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Extractor ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Extractor details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Extractor"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get an extractor"
      }
    },
    "/extractors/{id}/folders": {
      "get": {
        "operationId": "listExtractorFolders",
        "summary": "List folders for an extractor",
        "tags": [
          "Folders"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of folders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Folder"
                  }
                }
              }
            }
          }
        },
        "description": "List folders for an extractor"
      }
    },
    "/documents/upload": {
      "post": {
        "operationId": "uploadDocument",
        "summary": "Upload a document",
        "description": "Upload a document file for extraction processing.",
        "tags": [
          "Documents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Document file to upload"
                  },
                  "extractor_id": {
                    "type": "string",
                    "description": "Extractor ID to process with"
                  },
                  "folder_id": {
                    "type": "string",
                    "description": "Target folder ID"
                  }
                },
                "required": [
                  "file",
                  "extractor_id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Document"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/documents/upload-base64": {
      "post": {
        "operationId": "uploadDocumentBase64",
        "summary": "Upload a document as base64",
        "description": "Upload a base64-encoded document for extraction.",
        "tags": [
          "Documents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "file_name": {
                    "type": "string",
                    "description": "File name with extension"
                  },
                  "file_content": {
                    "type": "string",
                    "description": "Base64-encoded file content"
                  },
                  "extractor_id": {
                    "type": "string"
                  },
                  "folder_id": {
                    "type": "string"
                  }
                },
                "required": [
                  "file_name",
                  "file_content",
                  "extractor_id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Document"
                }
              }
            }
          }
        }
      }
    },
    "/documents": {
      "get": {
        "operationId": "listDocuments",
        "summary": "List documents",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "name": "extractor_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by extractor"
          },
          {
            "name": "folder_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by folder"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "processing",
                "processed",
                "failed"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of documents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Document"
                  }
                }
              }
            }
          }
        },
        "description": "List documents"
      }
    },
    "/documents/{id}": {
      "get": {
        "operationId": "getDocument",
        "summary": "Get a document",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Document"
                }
              }
            }
          }
        },
        "description": "Get a document"
      },
      "delete": {
        "operationId": "deleteDocument",
        "summary": "Delete a document",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document deleted"
          }
        },
        "description": "Delete a document"
      }
    },
    "/documents/{id}/extracted-data": {
      "get": {
        "operationId": "getExtractedData",
        "summary": "Get extracted data for a document",
        "description": "Retrieve the data extracted from a processed document.",
        "tags": [
          "Extracted Data"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Document ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Extracted data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExtractedData"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/extractors/{extractorId}/extracted-data": {
      "get": {
        "operationId": "getExtractorExtractedData",
        "summary": "Get all extracted data for an extractor",
        "tags": [
          "Extracted Data"
        ],
        "parameters": [
          {
            "name": "extractorId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "folder_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of extracted data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ExtractedData"
                  }
                }
              }
            }
          }
        },
        "description": "Get all extracted data for an extractor"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key prefixed with 'Basic ' and base64-encoded email:apikey"
      }
    },
    "schemas": {
      "Extractor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Folder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "extractor_id": {
            "type": "string"
          },
          "document_count": {
            "type": "integer"
          }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "file_name": {
            "type": "string"
          },
          "extractor_id": {
            "type": "string"
          },
          "folder_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "processing",
              "processed",
              "failed"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "page_count": {
            "type": "integer"
          }
        }
      },
      "ExtractedData": {
        "type": "object",
        "properties": {
          "document_id": {
            "type": "string"
          },
          "extractor_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                },
                "confidence": {
                  "type": "number"
                },
                "page_number": {
                  "type": "integer"
                }
              }
            }
          },
          "tables": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "rows": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
