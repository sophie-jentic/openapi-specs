              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Delete elevate word"
      }
    },
    "/api/admin/badword": {
      "post": {
        "tags": [
          "Admin"
