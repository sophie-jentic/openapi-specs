{
  "openapi": "3.0.3",
  "info": {
    "title": "Fess API",
    "version": "14.18.0",
    "description": "Fess is an open-source enterprise search server. It provides REST APIs for search, label management, popular words, favorites, health check, and admin operations.",
    "x-jentic-source-url": "https://fess.codelibs.org/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "variables": {
        "host": {
          "default": "localhost:8080"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Search",
      "description": "Search operations"
    },
    {
      "name": "Labels",
      "description": "Label management"
    },
    {
      "name": "Popular Words",
      "description": "Popular search words"
    },
    {
      "name": "Favorites",
      "description": "User favorites"
    },
    {
      "name": "Health",
      "description": "Health check"
    },
    {
      "name": "Suggest",
      "description": "Search suggestions"
    },
    {
      "name": "Admin",
      "description": "Administration APIs"
    }
  ],
  "paths": {
    "/api/v1/search": {
      "get": {
        "tags": [
          "Search"
        ],
        "operationId": "search",
        "summary": "Search documents",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query string",
            "required": true
          },
          {
            "name": "num",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of results (default 20)"
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Start offset"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sort field (e.g. created.asc, content_length.desc)"
          },
          {
            "name": "lang",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Language filter"
          },
          {
            "name": "fields.label",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by label value"
          },
          {
            "name": "facet.field",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Facet field name"
          },
          {
            "name": "facet.size",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of facet values"
          },
          {
            "name": "facet.query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Facet query"
          },
          {
            "name": "highlight.fragment_size",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Highlight fragment size"
          },
          {
            "name": "geo.location.point",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Geo location point (lat,lon)"
          },
          {
            "name": "geo.location.distance",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Geo distance (e.g. 10km)"
          },
          {
            "name": "track_total_hits",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Track total hits"
          },
          {
            "name": "preference",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search preference for routing"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Search documents"
      },
      "post": {
        "tags": [
          "Search"
        ],
        "operationId": "searchPost",
        "summary": "Search documents (POST)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "q": {
                    "type": "string"
                  },
                  "num": {
                    "type": "integer"
                  },
                  "start": {
                    "type": "integer"
                  },
                  "sort": {
                    "type": "string"
                  },
                  "lang": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Search documents (POST)"
      }
    },
    "/api/v1/suggest": {
      "get": {
        "tags": [
          "Suggest"
        ],
        "operationId": "suggest",
        "summary": "Get search suggestions",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Partial query for suggestions",
            "required": true
          },
          {
            "name": "num",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of suggestions"
          }
        ],
        "responses": {
          "200": {
            "description": "Suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "object",
                      "properties": {
                        "num": {
                          "type": "integer"
                        },
                        "result": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "text": {
                                "type": "string"
                              },
                              "labels": {
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get search suggestions"
      }
    },
    "/api/v1/labels": {
      "get": {
        "tags": [
          "Labels"
        ],
        "operationId": "listLabels",
        "summary": "List all labels",
        "responses": {
          "200": {
            "description": "Labels",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "integer"
                        },
                        "result": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Label"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List all labels"
      }
    },
    "/api/v1/popular-words": {
      "get": {
        "tags": [
          "Popular Words"
        ],
        "operationId": "listPopularWords",
        "summary": "List popular search words",
        "parameters": [
          {
            "name": "seed",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Random seed"
          },
          {
            "name": "num",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of words"
          }
        ],
        "responses": {
          "200": {
            "description": "Popular words",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "integer"
                        },
                        "result": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "word": {
                                "type": "string"
                              },
                              "count": {
                                "type": "integer"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List popular search words"
      }
    },
    "/api/v1/favorites": {
      "get": {
        "tags": [
          "Favorites"
        ],
        "operationId": "listFavorites",
        "summary": "List user favorites",
        "parameters": [
          {
            "name": "num",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Max results"
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Favorites",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "integer"
                        },
                        "result": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/SearchResult"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "List user favorites"
      },
      "post": {
        "tags": [
          "Favorites"
        ],
        "operationId": "addFavorite",
        "summary": "Add a favorite",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Favorite added",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Add a favorite"
      },
      "delete": {
        "tags": [
          "Favorites"
        ],
        "operationId": "removeFavorite",
        "summary": "Remove a favorite",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "URL to unfavorite",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Favorite removed"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Remove a favorite"
      }
    },
    "/api/v1/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "operationId": "healthCheck",
        "summary": "Get system health status",
        "responses": {
          "200": {
            "description": "Health status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "cluster_name": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "green",
                            "yellow",
                            "red"
                          ]
                        },
                        "timed_out": {
                          "type": "boolean"
                        },
                        "number_of_nodes": {
                          "type": "integer"
                        },
                        "active_primary_shards": {
                          "type": "integer"
                        },
                        "active_shards": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get system health status"
      }
    },
    "/api/admin/searchlist/setting": {
