      "post": {
        "tags": [
          "Admin"
        ],
        "operationId": "startCrawler",
        "summary": "Start crawler",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Crawler configuration name"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Crawler started"
          },
          "400": {
            "description": "Bad request",
