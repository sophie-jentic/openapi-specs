          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Add dictionary entry"
      },
      "delete": {
        "tags": [
          "Admin"
        ],
        "operationId": "deleteDictEntry",
        "summary": "Delete dictionary entry",
