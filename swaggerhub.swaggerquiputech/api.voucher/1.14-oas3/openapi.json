{
  "openapi": "3.0.0",
  "info": {
    "description": "**API Voucher**\n\n*Version 1.0*\n- Mockup store voucher image.\n\n*Version 1.1*\n- GET voucher by id\n- GET voucher by external\n- POST voucher\n\n*Version 1.2*\n- Added merchantImage to voucher (required)\n- Added traceId to voucher (required)\n- Added transactionId to voucher (required)\n- POST report\n\n*Version 1.6*\n- Added voucher type to voucherImageRequest\n\n*Version 1.7*\n- Added brand to voucherImageRequest\n\n*Version 1.8*\n- Changed brand to enum (visa, mastercard, amex, diners, discovery) in voucherImageRequest\n- Added batchNumber to reportImageRequest\n\n*Version 1.10*\n- Added TOTAL_SALES_BY_CARD, POS_SERVICES_DETAIL to reportType enum\n\n*Version 1.12*\n- Added terminalDateTime in apis Store Voucher and Store Report\n\n*Version 1.14*\n- Minor changes and fixes",
    "version": "1.14-oas3",
    "title": "API Voucher",
    "termsOfService": "http://www.visanet.com.pe",
    "contact": {
      "name": "VisaNet",
      "url": "http://www.visanet.com.pe",
      "email": "visanet@gmail.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/swaggerquiputech/api.voucher/1.14-oas3/swagger.json"
  },
  "tags": [
    {
      "name": "Report API",
      "description": "RESTful API for digital report operations"
    },
    {
      "name": "Voucher API"
    }
  ],
  "paths": {
    "/report/store": {
      "post": {
        "tags": [
          "Report API"
        ],
        "summary": "Store image generated for report",
        "description": "Store image generated for report",
        "operationId": "storeReportImage",
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportImageResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportImageRequest"
              }
            }
          },
          "description": "Report image request contains image in base64 format to be stored on database. No validation is performed for image.",
          "required": true
        }
      }
    },
    "/voucher/queryByExternal/{externalId}": {
      "get": {
        "tags": [
          "Voucher API"
        ],
        "summary": "Retrieve voucher info by externalId",
        "description": "Retrieve voucher info by externalId",
        "operationId": "getVoucherByExternal",
        "parameters": [
          {
            "name": "externalId",
            "in": "path",
            "description": "Unique external Id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VoucherImageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/voucher/store": {
      "post": {
        "tags": [
          "Voucher API"
        ],
        "summary": "Store image generated for voucher",
        "description": "Store image generated for voucher",
        "operationId": "storeVoucherImage",
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VoucherImageResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VoucherImageRequest"
              }
            }
          },
          "description": "Voucher image request contains image in base64 format to be stored on database. No validation is performed for image.",
          "required": true
        }
      }
    },
    "/voucher/{voucherId}": {
      "get": {
        "tags": [
          "Voucher API"
        ],
        "summary": "Retrieve voucher info by voucherId",
        "description": "Retrieve voucher info by voucherId",
        "operationId": "getVoucherById",
        "parameters": [
          {
            "name": "voucherId",
            "in": "path",
            "description": "Unique Voucher Id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VoucherImageResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "https://apitestenv.vnforapps.com/api.voucher/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "schemas": {
      "ReportImageRequest": {
        "type": "object",
        "required": [
          "externalId",
          "merchantId",
          "reportImageBase64",
          "reportType",
          "terminalId"
        ],
        "properties": {
          "reportImageBase64": {
            "type": "string"
          },
          "merchantId": {
            "type": "string",
            "example": "341198210"
          },
          "terminalId": {
            "type": "string",
            "example": "10203040"
          },
          "externalId": {
            "type": "string",
            "example": "ba6ec58f-a5f1-49e2-bf77-0766eb75d7b1"
          },
          "reportType": {
            "type": "string",
            "enum": [
              "OPERATIONS_DETAIL",
              "TIPS_DETAIL",
              "TIPS_SUMMARY",
              "BATCH_CLOSURE"
            ]
          },
          "batchNumber": {
            "type": "string"
          },
          "terminalDateTime": {
            "type": "string"
          }
        }
      },
      "ReportImageResponse": {
        "type": "object",
        "required": [
          "creationTime",
          "reportId"
        ],
        "properties": {
          "reportId": {
            "type": "string",
            "example": "fd0ef029-fd37-4d53-9702-3fba210d1496"
          },
          "creationTime": {
            "type": "integer",
            "format": "int64",
            "example": 1540624529143
          }
        }
      },
      "VoucherImageRequest": {
        "type": "object",
        "required": [
          "amount",
          "currency",
          "externalId",
          "merchantId",
          "merchantVoucherImageBase64",
          "terminalId",
          "traceId",
          "transactionId",
          "voucherImageBase64"
        ],
        "properties": {
          "brand": {
            "type": "string",
            "enum": [
              "visa",
              "mastercard",
              "amex",
              "diners",
              "discovery"
            ]
          },
          "voucherType": {
            "type": "string",
            "enum": [
              "SALES",
              "REFUND",
              "POS_SERVICES"
            ]
          },
          "voucherImageBase64": {
            "type": "string"
          },
          "merchantId": {
            "type": "string",
            "example": "341198210"
          },
          "terminalId": {
            "type": "string",
            "example": "10203040"
          },
          "traceId": {
            "type": "string",
            "example": "102030"
          },
          "transactionId": {
            "type": "string",
            "example": "991182970233810"
          },
          "merchantVoucherImageBase64": {
            "type": "string"
          },
          "externalId": {
            "type": "string",
            "example": "89e8d5a3-4d5d-4bc8-82ff-55091176e800"
          },
          "amount": {
            "type": "number",
            "example": 123.45
          },
          "email": {
            "type": "string"
          },
          "currency": {
            "type": "string",
            "enum": [
              "PEN",
              "USD"
            ]
          },
          "terminalDateTime": {
            "type": "string"
          }
        }
      },
      "VoucherImageResponse": {
        "type": "object",
        "required": [
          "creationTime",
          "voucherId"
        ],
        "properties": {
          "voucherId": {
            "type": "string",
            "example": "fd0ef029-fd37-4d53-9702-3fba210d1496"
          },
          "creationTime": {
            "type": "integer",
            "format": "int64",
            "example": 1540624557140
          }
        }
      }
    }
  }
}
