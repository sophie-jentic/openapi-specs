    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/swaggerquiputech/api.authorization/v3/swagger.json"
  },
  "tags": [
    {
      "name": "Authorization Api",
      "description": "RESTful API to authorize transactions."
    },
    {
      "name": "Void Api",
      "description": "RESTful API to void transactions."
    }
  ],
  "schemes": [
    "https"
  ],
  "paths": {
    "/authorization/{product}/{merchantId}": {
      "post": {
        "tags": [
          "Authorization Api"
        ],
        "summary": "Authorization",
        "description": "RESTful API to authorizate transactions.",
        "operationId": "authorize",
        "consumes": [
          "application/json; charset=utf-8"
        ],
        "produces": [
          "application/json; charset=utf-8"
        ],
        "parameters": [
          {
            "name": "product",
            "in": "path",
            "description": "Identificador del producto",
            "required": true,
            "type": "string",
            "x-example": "ecommerce",
            "enum": [
              "recurrence",
              "ecommerce"
            ]
          },
          {
            "name": "merchantId",
            "in": "path",
            "description": "Identificador del comercio",
            "required": true,
            "type": "string",
            "x-example": "341198210"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Authorization request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/AuthorizationRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/AuthorizationResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Request is not valid"
          }
        },
        "security": [
          {
            "accessToken": []
          }
        ]
      }
    },
    "/void/{merchantId}": {
      "post": {
        "tags": [
          "Void Api"
        ],
        "summary": "VoidMerchantTrx",
        "description": "RESTful API to void transactions by Merchant Identifier.",
        "operationId": "voidMerchantTrx",
        "consumes": [
          "application/json; charset=utf-8"
        ],
        "produces": [
          "application/json; charset=utf-8"
        ],
        "parameters": [
          {
            "name": "merchantId",
            "in": "path",
            "description": "Identificador del comercio",
            "required": true,
            "type": "string",
            "x-example": "341198210"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Void transaction request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/VoidRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/AuthorizationResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Request is not valid"
          }
        },
        "security": [
          {
            "accessToken": []
          }
        ]
      }
    },
    "/void/{product}/{merchantId}": {
      "post": {
        "tags": [
          "Void Api"
        ],
        "summary": "Void",
        "description": "RESTful API to void transactions.",
        "operationId": "voidTransaction",
        "consumes": [
          "application/json; charset=utf-8"
        ],
        "produces": [
          "application/json; charset=utf-8"
        ],
        "parameters": [
          {
            "name": "product",
            "in": "path",
            "description": "Identificador del producto",
            "required": true,
            "type": "string",
            "x-example": "ecommerce",
            "enum": [
              "recurrence",
              "pos",
              "mpos",
              "ecommerce"
            ]
          },
          {
            "name": "merchantId",
            "in": "path",
            "description": "Identificador del comercio",
            "required": true,
            "type": "string",
            "x-example": "341198210"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Void transaction request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/AuthorizationRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/AuthorizationResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Request is not valid"
          }
        },
        "security": [
          {
            "accessToken": []
          }
        ]
      }
    },
    "/void/{product}/{merchantId}/{backofficeId}": {
      "post": {
        "tags": [
          "Void Api"
        ],
        "summary": "VoidBackOffice",
        "description": "RESTful API to void transactions.",
        "operationId": "voidBackoffice",
        "consumes": [
          "application/json; charset=utf-8"
        ],
        "produces": [
          "application/json; charset=utf-8"
        ],
        "parameters": [
          {
            "name": "product",
            "in": "path",
            "description": "Identificador del producto",
            "required": true,
            "type": "string",
            "x-example": "ecommerce",
            "enum": [
              "recurrence",
              "pos",
              "mpos",
              "ecommerce"
            ]
          },
          {
            "name": "merchantId",
            "in": "path",
            "description": "Identificador del comercio",
            "required": true,
            "type": "string",
            "x-example": "341198210"
          },
          {
            "name": "backofficeId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Void transaction request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/VoidRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/AuthorizationResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Request is not valid"
          }
        },
        "security": [
          {
            "accessToken": []
          }
        ]
      }
    }
  },
  "securityDefinitions": {
    "accessToken": {
      "description": "Access token obtained from api.security",
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "definitions": {
    "Address": {
      "type": "object",
      "properties": {
        "street1": {
          "type": "string",
          "example": "Calle Astorga 827",
          "description": "Direccion"
        },
        "street2": {
          "type": "string",
          "example": "Calle Astorga 831",
          "description": "Direccion"
        },
        "postalCode": {
          "type": "string",
          "example": "Lima 30",
          "description": "Codigo Postal"
        },
        "city": {
          "type": "string",
          "example": "Lima",
          "description": "Ciudad"
        },
        "state": {
          "type": "string",
          "example": "LI",
          "description": "Departamento / Estado"
        },
        "country": {
          "type": "string",
          "example": "PE",
          "description": "Pais"
        }
      },
      "description": "Entidad que representa informacion de direccion"
    },
    "Antifraud": {
      "type": "object",
      "required": [
        "clientIp"
      ],
      "properties": {
        "billingAddress": {
          "$ref": "#/definitions/Address"
        },
        "shippingAddress": {
          "$ref": "#/definitions/Address"
        },
        "clientIp": {
          "type": "string",
          "example": "24.212.107.30",
          "description": "Direccion IP del cliente"
        },
        "deviceFingerprintId": {
          "type": "string",
          "description": "Device Finger Print Id"
        },
        "merchantDefineData": {
          "type": "object",
          "description": "Datos adicionales definidos por el comercio",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "description": "Entidad que representa informacion de antifraude"
    },
    "Authentication": {
      "type": "object",
      "properties": {
        "eci": {
          "type": "string",
          "description": "Valor eci del proceso de validacion de la marca"
        },
        "xid": {
          "type": "string",
          "description": "Valor xid del proceso de validacion de la marca"
        },
        "cavv": {
          "type": "string",
          "description": "Valor cavv del proceso de validacion de la marca"
        }
      },
      "description": "Entidad que representa los datos de validacion de la marca"
    },
    "AuthorizationRequest": {
      "type": "object",
      "required": [
        "captureType",
        "card",
        "channel",
        "order",
        "terminalId"
      ],
      "properties": {
        "terminalId": {
          "type": "string",
          "example": "12345678",
          "description": "Numero de Terminal"
        },
        "channel": {
          "type": "string",
          "example": "web",
          "description": "Canal desde donde se origino la transaccion",
          "enum": [
            "mobile",
            "web",
            "mpos",
            "host",
            "pos",
            "kiosk",
            "callcenter"
          ]
        },
        "countable": {
          "type": "boolean",
          "description": "Flag que determina si la autorizacion es contable o no"
        },
        "terminalUnattended": {
          "type": "boolean",
          "description": "Flag para indicar si la transaccion vino desde canal desatendido"
        },
        "captureType": {
          "type": "string",
          "example": "manual",
          "description": "Tipo de captura en el canal",
          "enum": [
            "manual",
            "chip",
            "band",
            "contactless",
            "cardOnFile"
          ]
        },
        "lon": {
          "type": "string",
          "description": "Coordenadas de longitud"
        },
        "lat": {
          "type": "string",
          "description": "Coordenadas de latitud"
        },
        "order": {
          "$ref": "#/definitions/Order"
        },
        "card": {
          "$ref": "#/definitions/Card"
        },
        "cardHolder": {
          "$ref": "#/definitions/CardHolder"
        },
        "sponsored": {
          "$ref": "#/definitions/Sponsored"
        },
        "antifraud": {
          "$ref": "#/definitions/Antifraud"
        },
        "authentication": {
          "$ref": "#/definitions/Authentication"
        },
        "recurrence": {
          "$ref": "#/definitions/Recurrence"
        },
        "dataMap": {
          "type": "object",
          "description": "Informacion complementaria de la transaccion",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "description": "Authorize transaction request"
    },
    "AuthorizationResponse": {
      "type": "object",
      "required": [
        "header",
        "order"
      ],
      "properties": {
        "header": {
          "$ref": "#/definitions/Header"
        },
        "order": {
          "$ref": "#/definitions/Order"
        },
        "dataMap": {
          "type": "object",
          "description": "Informacion complementaria de la operacion",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "Card": {
      "type": "object",
      "properties": {
        "cardNumber": {
          "type": "string",
          "example": "4551478422045511",
          "description": "Numero de tarjeta"
        },
        "expirationMonth": {
          "type": "integer",
          "format": "int32",
          "example": 12,
          "description": "Mes de expiracion"
        },
        "expirationYear": {
          "type": "integer",
          "format": "int32",
          "example": 2029,
          "description": "Expiration year"
        },
        "cvv2": {
          "type": "string",
          "example": "329",
          "description": "CVV2"
        },
        "sequenceNumber": {
          "type": "string",
          "example": "001",
          "description": "Numero de secuencia de la tarjeta"
        },
        "cardHolderName": {
          "type": "string",
          "example": "Pedro Galdamez",
          "description": "Nombre del tarjethabiente"
        },
        "tokenId": {
          "type": "string",
          "example": "7000100000002553",
          "description": "Identificador de tarjeta tokenizada, opcional y reemplaza los datos de la tarjeta"
        },
        "cardAliasName": {
          "type": "string",
          "example": "Debito 1",
          "description": "Dato opcional solo si se quiere tokenizar la tarjeta. Solo habilitado para comercios con el servicio de tokenizacion activo."
        },
        "verify": {
          "type": "boolean",
          "description": "Flag para activar verificaciones adicionales"
        },
        "track2": {
          "type": "string",
          "description": "Identificador de pista 2 obtenido via lector"
        },
        "emv": {
          "type": "string",
          "description": "Valor adicional para tarjetas con circuito integrado"
        },
        "cardNumberEnc": {
          "type": "string",
          "description": "Numero de tarjeta encriptado, reemplaza al numero de tarjeta en claro"
        },
        "track2Enc": {
          "type": "string",
          "description": "Datos de la pista 2 encriptados, reemplaza al campo en claro"
        },
        "emvEnc": {
          "type": "string",
          "description": "Datos del EMV encriptados, reemplaza al campo en claro"
        },
        "pinBlockEnc": {
          "type": "string",
          "description": "Pin de la tarjeta encriptado"
        },
        "ksnDukpt": {
          "type": "string",
          "description": "Clave unica derivada para la transaccion"
        },
        "visaCheckout": {
          "type": "boolean",
          "description": "Flag que indica si es visa checkout"
        },
        "registerCardFrecuent": {
          "type": "boolean",
          "description": "Flag que indica si debe registrarse como tarjeta frecuente"
        },
        "useCardFrecuent": {
          "type": "boolean",
          "description": "Flag que indica si debe usarse como tarjeta frecuente"
        }
      },
      "description": "Informacion de la tarejta"
    },
    "CardHolder": {
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "example": "Pedro",
          "description": "Nombre"
        },
        "lastName": {
          "type": "string",
          "example": "Galdamez",
          "description": "Apellido"
        },
        "email": {
          "type": "string",
          "example": "info@quiputech.com",
          "description": "Correo electronico"
        },
        "phoneNumber": {
          "type": "string",
          "example": "+51 1 2223333",
          "description": "Telefono"
        },
        "documentType": {
          "type": "string",
          "example": "DNI",
          "description": "Tipo de documento",
          "enum": [
            "DNI",
            "CE",
            "PAS"
          ]
        },
        "documentNumber": {
          "type": "string",
          "example": "E065199",
          "description": "Numero de documento"
        }
      },
      "description": "Informacion del tarjethabiente"
    },
    "Header": {
      "type": "object",
      "properties": {
        "ecoreTransactionUUID": {
          "type": "string",
          "description": "Identificador unico de transaccion para ecore"
        },
        "ecoreTransactionDate": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha de la operacion"
        },
        "millis": {
          "type": "integer",
          "format": "int32",
          "description": "Tiempo de ejecucion"
        }
      },
      "description": "Encabezado de la transaccion"
    },
    "Order": {
      "type": "object",
      "required": [
        "amount",
        "currency",
        "purchaseNumber"
      ],
      "properties": {
        "tokenId": {
          "type": "string",
          "example": "e29df880fb458dff08f16b891b21aa8b2b005e9028e59edcdb4320e1d98d91be",
          "description": "Id del token de transaccion para autorizacion en dos etapas"
        },
        "purchaseNumber": {
          "type": "string",
          "example": "1234567890",
          "description": "Numero del pedido"
        },
        "productId": {
          "type": "string",
          "example": "102",
          "description": "Id del producto para la orden"
        },
        "amount": {
          "type": "number",
          "format": "double",
          "example": 1,
          "description": "Importe del pedido"
        },
        "installment": {
          "type": "integer",
          "format": "int32",
          "example": 1,
          "description": "Cuotas"
        },
        "currency": {
          "type": "string",
          "example": "PEN",
          "description": "Moneda",
          "enum": [
            "PEN",
            "USD"
          ]
        },
        "externalTransactionId": {
          "type": "string",
          "description": "Identificador unico de la transaccion enviado por el comercio"
        },
        "authorizedAmount": {
          "type": "number",
          "format": "double",
          "description": "Importe de la autorizacion",
          "readOnly": true
        },
        "authorizationCode": {
          "type": "string",
          "description": "Numero de la autorizacion",
          "readOnly": true
        },
        "traceNumber": {
          "type": "string",
          "example": "00004",
          "description": "Identificador unico de la transaccion generado en la autorizacion",
          "readOnly": true
        },
        "transactionDate": {
          "type": "string",
          "example": "170720231016",
          "description": "Fecha de la transaccion",
          "readOnly": true
        },
        "transactionId": {
          "type": "string",
          "example": "990172014359425",
          "description": "Identificador de la transaccion",
          "readOnly": true
        },
        "originalTraceNumber": {
          "type": "string",
          "description": "Identificador de la transaccion original a anular"
        },
        "originalDateTime": {
          "type": "string",
          "description": "Fecha de la transaccion original a anular"
        },
        "billingAddress": {
          "$ref": "#/definitions/Address"
        },
        "shippingAddress": {
          "$ref": "#/definitions/Address"
        }
      },
      "description": "Entidad que representa la informacion del pedido"
    },
    "Recurrence": {
      "type": "object",
      "properties": {
        "beneficiaryId": {
          "type": "string",
          "description": "Identificador del beneficiario"
        },
        "beneficiaryFirstName": {
          "type": "string",
          "description": "Nombre del beneficiario"
        },
        "beneficiaryLastName": {
          "type": "string",
          "description": "Apellido del beneficiario"
        },
        "frequency": {
          "type": "string",
          "example": "monthly",
          "description": "Frecuencia de pago programado",
          "enum": [
            "annual",
            "biannual",
            "monthly",
            "quarterly"
          ]
        },
        "amount": {
          "type": "number",
          "format": "double",
          "example": 1,
          "description": "Importe del pago programado"
        },
        "maxAmount": {
          "type": "number",
          "format": "double",
          "example": 100,
          "description": "Valor maximo a aplicar del pago programado"
        },
        "type": {
          "type": "string",
          "example": "fixed",
          "description": "Tipo de pago programado",
          "enum": [
            "fixed",
            "fixedinitial",
            "variable",
            "variableinitial"
          ]
        }
      },
      "description": "Informacion para transacciones recurrentes"
    },
    "Sponsored": {
      "type": "object",
      "properties": {
        "merchantId": {
          "type": "string",
          "example": "10101010199",
          "description": "Codigo del comercio"
        },
        "mcci": {
          "type": "string",
          "example": "5211",
          "description": "MCCI Internacional"
        },
        "name": {
          "type": "string",
          "example": "Comercio Internacional",
          "description": "Nombre del comercio"
        },
        "address": {
          "type": "string",
          "example": "Calle Garrido y Bermejo 4, Piso 4C, Salamanca, Peru",
          "description": "Direccion del comercio"
        },
        "phoneNumber": {
          "type": "string",
          "example": "876789876",
          "description": "Numero de telefono"
        }
      },
      "description": "Entidad que representa al comercio patrocinado"
    },
    "VoidRequest": {
      "type": "object",
      "required": [
        "captureType",
        "card",
        "channel",
        "order",
        "terminalId"
      ],
      "properties": {
        "terminalId": {
          "type": "string",
          "example": "12345678",
          "description": "Numero de Terminal"
        },
        "channel": {
          "type": "string",
          "example": "web",
          "description": "Canal desde donde se origino la transaccion",
          "enum": [
            "mobile",
            "web",
            "mpos",
            "host",
            "pos",
            "kiosk",
            "callcenter"
          ]
        },
        "countable": {
          "type": "boolean",
          "description": "Flag que determina si la autorizacion es contable o no"
        },
        "terminalUnattended": {
          "type": "boolean",
          "description": "Flag para indicar si la transaccion vino desde canal desatendido"
        },
        "captureType": {
          "type": "string",
          "example": "manual",
          "description": "Tipo de captura en el canal",
          "enum": [
            "manual",
            "chip",
            "band",
            "contactless",
            "cardOnFile"
          ]
        },
        "lon": {
          "type": "string",
          "description": "Coordenadas de longitud"
        },
        "lat": {
          "type": "string",
          "description": "Coordenadas de latitud"
        },
        "order": {
          "$ref": "#/definitions/Order"
        },
        "card": {
          "$ref": "#/definitions/Card"
        },
        "cardHolder": {
          "$ref": "#/definitions/CardHolder"
        },
        "sponsored": {
          "$ref": "#/definitions/Sponsored"
        },
        "antifraud": {
          "$ref": "#/definitions/Antifraud"
        },
        "authentication": {
          "$ref": "#/definitions/Authentication"
        },
        "recurrence": {
          "$ref": "#/definitions/Recurrence"
        },
        "dataMap": {
          "type": "object",
          "description": "Informacion complementaria de la transaccion",
          "additionalProperties": {
            "type": "string"
          }
        },
        "annulationReason": {
          "type": "string",
          "description": "Motivo por el que se desea anular la transaccion"
        }
      },
      "description": "Void transaction request"
    }
  },
