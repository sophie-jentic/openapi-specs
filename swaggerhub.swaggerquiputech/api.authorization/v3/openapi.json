{
  "swagger": "2.0",
  "info": {
    "description": "Api encargada de la autorizacion de transacciones",
    "version": "v3",
    "title": "API Authorization",
    "termsOfService": "http://www.quiputech.com",
    "contact": {
      "name": "QuipuTech",
      "url": "http://www.quiputech.com",
      "email": "info@quiputech.com"
    },
    "license": {
      "name": "Apache 2.0",
