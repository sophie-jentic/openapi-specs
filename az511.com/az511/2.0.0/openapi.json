{
  "openapi": "3.0.3",
  "info": {
    "title": "AZ511 Traffic Data API",
    "description": "Access traffic data from the Arizona Department of Transportation (ADOT) API. Provides real-time information about traffic cameras, weather stations, message signs, events, alerts, and rest areas across Arizona.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://www.az511.com/developers/doc",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://az511.com/api/v2",
      "description": "AZ511 API v2 server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Cameras",
      "description": "Traffic camera data"
    },
    {
      "name": "Weather Stations",
      "description": "Weather station data"
    },
    {
      "name": "Message Signs",
      "description": "Variable message sign data"
    },
    {
      "name": "Events",
      "description": "Traffic events and incidents"
    },
    {
      "name": "Alerts",
      "description": "Traffic alert notifications"
    },
    {
      "name": "Rest Areas",
      "description": "Rest area information"
    }
  ],
  "paths": {
    "/get/cameras": {
      "get": {
        "tags": [
          "Cameras"
        ],
        "summary": "Get all traffic cameras",
        "operationId": "getCameras",
        "parameters": [
          {
            "$ref": "#/components/parameters/Format"
          }
        ],
        "responses": {
          "200": {
            "description": "List of traffic cameras",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Camera"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get all traffic cameras"
      }
    },
    "/get/weatherstations": {
      "get": {
        "tags": [
          "Weather Stations"
        ],
        "summary": "Get all weather stations",
        "operationId": "getWeatherStations",
        "parameters": [
          {
            "$ref": "#/components/parameters/Format"
          }
        ],
        "responses": {
          "200": {
            "description": "List of weather stations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherStation"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get all weather stations"
      }
    },
    "/get/messagesigns": {
      "get": {
        "tags": [
          "Message Signs"
        ],
        "summary": "Get all variable message signs",
        "operationId": "getMessageSigns",
        "parameters": [
          {
            "$ref": "#/components/parameters/Format"
          }
        ],
        "responses": {
          "200": {
            "description": "List of message signs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageSign"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get all variable message signs"
      }
    },
    "/get/event": {
      "get": {
        "tags": [
          "Events"
        ],
        "summary": "Get all traffic events",
        "operationId": "getEvents",
        "parameters": [
          {
            "$ref": "#/components/parameters/Format"
          }
        ],
        "responses": {
          "200": {
            "description": "List of traffic events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Event"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get all traffic events"
      }
    },
    "/get/alerts": {
      "get": {
        "tags": [
          "Alerts"
        ],
        "summary": "Get all traffic alerts",
        "operationId": "getAlerts",
        "parameters": [
          {
            "$ref": "#/components/parameters/Format"
          }
        ],
        "responses": {
          "200": {
            "description": "List of alerts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Alert"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get all traffic alerts"
      }
    },
    "/get/restareas": {
      "get": {
        "tags": [
          "Rest Areas"
        ],
        "summary": "Get all rest areas",
        "operationId": "getRestAreas",
        "parameters": [
          {
            "$ref": "#/components/parameters/Format"
          }
        ],
        "responses": {
          "200": {
            "description": "List of rest areas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RestArea"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get all rest areas"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "Developer API key obtained by registering an account. Rate limited to 10 calls per 60 seconds."
      }
    },
    "parameters": {
      "Format": {
        "name": "format",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "json",
            "xml"
          ],
          "default": "json"
        },
        "description": "Response format (json or xml, defaults to json)"
      }
    },
    "schemas": {
      "Camera": {
        "type": "object",
        "properties": {
          "Id": {
            "type": "integer",
            "description": "Unique identifier"
          },
          "Source": {
            "type": "string",
            "description": "Name of the data source"
          },
          "SourceId": {
            "type": "string",
            "description": "Source camera identifier"
          },
          "Roadway": {
            "type": "string",
            "description": "Road or highway name"
          },
          "Direction": {
            "type": "string",
            "description": "Cardinal direction the camera faces"
          },
          "Latitude": {
            "type": "number",
            "format": "double",
            "description": "Location latitude (-90 to 90)"
          },
          "Longitude": {
            "type": "number",
            "format": "double",
            "description": "Location longitude (-180 to 180)"
          },
          "Location": {
            "type": "string",
            "description": "Human-readable location description"
          },
          "SortOrder": {
            "type": "integer",
            "description": "Display sort order"
          },
          "Views": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CameraView"
            },
            "description": "Camera view details"
          }
        }
      },
      "CameraView": {
        "type": "object",
        "properties": {
          "Id": {
            "type": "integer",
            "description": "View identifier"
          },
          "Url": {
            "type": "string",
            "description": "URL of the camera image"
          },
          "Status": {
            "type": "string",
            "description": "Camera view status"
          },
          "Description": {
            "type": "string",
            "description": "Description of the camera view"
          }
        }
      },
      "WeatherStation": {
        "type": "object",
        "properties": {
          "Id": {
            "type": "integer",
            "description": "Unique identifier"
          },
          "CameraSource": {
            "type": "string",
            "description": "Associated camera source name"
          },
          "CameraSourceId": {
            "type": "string",
            "description": "Source ID of associated camera"
          },
          "Latitude": {
            "type": "number",
            "format": "double",
            "description": "Location latitude"
          },
          "Longitude": {
            "type": "number",
            "format": "double",
            "description": "Location longitude"
          },
          "AirTemperature": {
            "type": "string",
            "description": "Air temperature in Fahrenheit"
          },
          "SurfaceTemperature": {
            "type": "string",
            "description": "Surface temperature in Fahrenheit"
          },
          "WindSpeed": {
            "type": "string",
            "description": "Current wind speed"
          },
          "WindDirection": {
            "type": "string",
            "description": "Wind direction"
          },
          "RelativeHumidity": {
            "type": "string",
            "description": "Humidity percentage"
          },
          "LevelOfGrip": {
            "type": "string",
            "description": "Surface grip level"
          },
          "MaxWindSpeed": {
            "type": "string",
            "description": "Maximum wind speed recorded"
          },
          "LastUpdated": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp of last update"
          }
        }
      },
      "MessageSign": {
        "type": "object",
        "properties": {
          "Id": {
            "type": "string",
            "description": "Unique identifier"
          },
          "Name": {
            "type": "string",
            "description": "Location description of the sign"
          },
          "Roadway": {
            "type": "string",
            "description": "Roadway where deployed"
          },
          "DirectionOfTravel": {
            "type": "string",
            "description": "Direction of travel (e.g., Northbound, Southbound)"
          },
          "Messages": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Currently rotating messages"
          },
          "Latitude": {
            "type": "number",
            "format": "double",
            "description": "Location latitude"
          },
          "Longitude": {
            "type": "number",
            "format": "double",
            "description": "Location longitude"
          },
          "LastUpdated": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp of last update"
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "integer",
            "description": "Unique identifier"
          },
          "SourceId": {
            "type": "string",
            "description": "Source identifier"
          },
          "Organization": {
            "type": "string",
            "description": "Providing organization name"
          },
          "RoadwayName": {
            "type": "string",
            "description": "Affected roadway"
          },
          "DirectionOfTravel": {
            "type": "string",
            "description": "Direction of travel"
          },
          "Description": {
            "type": "string",
            "description": "Summary of event details"
          },
          "Reported": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp when reported"
          },
          "LastUpdated": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp of last update"
          },
          "StartDate": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp of event start"
          },
          "PlannedEndDate": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp of planned end"
          },
          "Latitude": {
            "type": "number",
            "format": "double",
            "description": "Event latitude"
          },
          "Longitude": {
            "type": "number",
            "format": "double",
            "description": "Event longitude"
          },
          "EventType": {
            "type": "string",
            "enum": [
              "roadwork",
              "closures",
              "accidentsAndIncidents"
            ],
            "description": "Type of event"
          },
          "IsFullClosure": {
            "type": "boolean",
            "description": "Whether all lanes are blocked"
          },
          "Restrictions": {
            "$ref": "#/components/schemas/EventRestrictions"
          },
          "EncodedPolyline": {
            "type": "string",
            "description": "Google-encoded polyline coordinates"
          }
        }
      },
      "EventRestrictions": {
        "type": "object",
        "properties": {
          "Width": {
            "type": "number",
            "description": "Width restriction"
          },
          "Height": {
            "type": "number",
            "description": "Height restriction"
          },
          "Length": {
            "type": "number",
            "description": "Length restriction"
          },
          "Weight": {
            "type": "number",
            "description": "Weight restriction"
          },
          "Speed": {
            "type": "number",
            "description": "Speed restriction"
          }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "Id": {
            "type": "integer",
            "description": "Unique identifier"
          },
          "Message": {
            "type": "string",
            "description": "Alert summary"
          },
          "Notes": {
            "type": "string",
            "description": "Additional alert details"
          },
          "StartTime": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp for alert start"
          },
          "EndTime": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp for alert end"
          },
          "Regions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Affected regions"
          },
          "HighImportance": {
            "type": "boolean",
            "description": "Priority flag"
          },
          "SendNotification": {
            "type": "boolean",
            "description": "Whether notification is sent via SMS, Email, IVR"
          }
        }
      },
      "RestArea": {
        "type": "object",
        "properties": {
          "Id": {
            "type": "integer",
            "description": "Unique identifier"
          },
          "Latitude": {
            "type": "number",
            "format": "double",
            "description": "Location latitude"
          },
          "Longitude": {
            "type": "number",
            "format": "double",
            "description": "Location longitude"
          },
          "Name": {
            "type": "string",
            "description": "Rest area name"
          },
          "Status": {
            "type": "string",
            "description": "Operational status"
          },
          "Location": {
            "type": "string",
            "description": "Highway/milepost location"
          },
          "City": {
            "type": "string",
            "description": "City name"
          },
          "Restroom": {
            "type": "string",
            "description": "Restroom availability"
          },
          "Ramada": {
            "type": "string",
            "description": "Ramada availability"
          },
          "VisitorCenter": {
            "type": "string",
            "description": "Visitor center availability"
          },
          "TravelInformation": {
            "type": "string",
            "description": "Travel information availability"
          },
          "VendingMachine": {
            "type": "string",
            "description": "Vending machine availability"
          },
          "TotalTruckSpaces": {
            "type": "string",
            "description": "Total truck parking spaces"
          },
          "AvailableTruckSpaces": {
            "type": "string",
            "description": "Currently available truck spaces"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  }
}
