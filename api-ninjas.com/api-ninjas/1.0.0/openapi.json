          "AI/Computer Vision"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text_1",
                  "text_2"
                ],
                "properties": {
                  "text_1": {
                    "type": "string",
                    "description": "First text"
                  },
                  "text_2": {
                    "type": "string",
