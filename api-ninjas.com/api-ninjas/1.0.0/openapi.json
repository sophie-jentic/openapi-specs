    "title": "API Ninjas",
    "version": "1.0.0",
    "description": "API Ninjas provides a collection of 100+ high-quality REST APIs across finance, technology, entertainment, health, AI, places, text processing, and transportation. All APIs use a simple GET pattern with API key authentication via the X-Api-Key header. Base URL: https://api.api-ninjas.com",
    "x-jentic-source-url": "https://api-ninjas.com/api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.api-ninjas.com",
      "description": "API Ninjas Production Server"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Finance",
      "description": "Financial data APIs"
    },
    {
      "name": "Internet/Technology",
      "description": "Internet and technology tools"
    },
    {
      "name": "AI/Computer Vision",
      "description": "AI and computer vision APIs"
    },
    {
      "name": "Entertainment",
      "description": "Fun and entertainment APIs"
    },
    {
      "name": "Health/Wellness",
      "description": "Health, fitness and food APIs"
    },
    {
      "name": "Places",
      "description": "Location-based data APIs"
    },
    {
      "name": "Text",
      "description": "Text processing APIs"
    },
    {
      "name": "Transportation",
