{
  "openapi": "3.0.3",
  "info": {
    "title": "i-TRAFFIC API",
    "version": "1.0.0",
    "description": "South Africa traffic data API providing access to traffic events, roadways, cameras, variable message signs, and alerts.",
    "x-jentic-source-url": "https://www.i-traffic.co.za/developers/help",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.i-traffic.co.za"
    }
  ],
  "paths": {
    "/api/GetEvents": {
      "get": {
        "operationId": "getEvents",
        "summary": "Get all traffic events",
        "description": "Returns all event types.",
        "tags": [
          "Traffic"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Developer API key"
          },
          {
            "name": "format",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "xml",
                "json"
              ]
            },
            "description": "Response format"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
