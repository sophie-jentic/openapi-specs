{
  "openapi": "3.0.3",
  "info": {
    "title": "Merriam-Webster Dictionary API",
    "description": "Access comprehensive dictionary and thesaurus content from Merriam-Webster, including definitions, etymologies, audio pronunciations, synonyms, and antonyms. Includes multiple reference products: Collegiate Dictionary, Learner's Dictionary, Thesaurus, Medical Dictionary, and Spanish-English Dictionary.",
    "version": "3.0.0",
    "contact": {
      "url": "https://dictionaryapi.com/"
    }
  },
  "servers": [
    {
      "url": "https://www.dictionaryapi.com/api/v3/references"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/collegiate/json/{word}": {
      "get": {
        "summary": "Look up a word in Merriam-Webster's Collegiate Dictionary",
        "description": "Retrieve comprehensive dictionary information including definitions, examples, etymologies, synonyms, pronunciation, and audio for a given word.",
        "operationId": "getCollegiateDictionaryEntry",
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "description": "The word to look up (headword or stem)",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "voluminous"
          },
          {
            "name": "key",
            "in": "query",
            "description": "Your API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with dictionary entry data",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DictionaryEntry"
                      }
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Array of spelling suggestions when exact match not found"
                    }
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "collegiate"
        ]
      }
    },
    "/learners/json/{word}": {
      "get": {
        "summary": "Look up a word in Merriam-Webster's Learner's Dictionary",
        "description": "Retrieve learner-focused dictionary information designed for advanced English learners, covering nearly 100,000 words and phrases with audio pronunciations.",
        "operationId": "getLearnersDictionaryEntry",
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "description": "The word to look up (headword or stem)",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "apple"
          },
          {
            "name": "key",
            "in": "query",
            "description": "Your API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with learner's dictionary entry data",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DictionaryEntry"
                      }
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Array of spelling suggestions"
                    }
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "learners"
        ]
      }
    },
    "/thesaurus/json/{word}": {
      "get": {
        "summary": "Look up a word in Merriam-Webster's Thesaurus",
        "description": "Retrieve thesaurus information including synonyms and antonyms for a given word.",
        "operationId": "getThesaurusEntry",
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "description": "The word to look up",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "description": "Your API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with thesaurus entry data",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DictionaryEntry"
                      }
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "thesaurus"
        ]
      }
    },
    "/medical/json/{word}": {
      "get": {
        "summary": "Look up a word in Merriam-Webster's Medical Dictionary",
        "description": "Retrieve medical terminology definitions and information.",
        "operationId": "getMedicalDictionaryEntry",
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "description": "The medical term to look up",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "description": "Your API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with medical dictionary entry data",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DictionaryEntry"
                      }
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "medical"
        ]
      }
    },
    "/spanish/json/{word}": {
      "get": {
        "summary": "Look up a word in Merriam-Webster's Spanish-English Dictionary",
        "description": "Retrieve Spanish-English translation and dictionary information.",
        "operationId": "getSpanishDictionaryEntry",
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "description": "The word to look up (English or Spanish)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "description": "Your API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with Spanish-English dictionary entry data",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DictionaryEntry"
                      }
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "spanish"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key required for authentication. Free tier: 1000 queries per day, limited to two reference APIs for non-commercial use."
      }
    },
    "schemas": {
      "DictionaryEntry": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "description": "Entry metadata",
            "properties": {
              "id": {
                "type": "string",
                "description": "Entry ID"
              },
              "uuid": {
                "type": "string",
                "description": "Unique identifier"
              },
              "stems": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Related word forms"
              },
              "offensive": {
                "type": "boolean",
                "description": "Whether the word is considered offensive"
              }
            }
          },
          "hwi": {
            "type": "object",
            "description": "Headword information",
            "properties": {
              "hw": {
                "type": "string",
                "description": "Headword"
              },
              "prs": {
                "type": "array",
                "description": "Pronunciations",
                "items": {
                  "type": "object",
                  "properties": {
                    "mw": {
                      "type": "string",
                      "description": "Merriam-Webster pronunciation"
                    },
                    "sound": {
                      "type": "object",
                      "properties": {
                        "audio": {
                          "type": "string",
                          "description": "Audio filename"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "fl": {
            "type": "string",
            "description": "Functional label (part of speech)"
          },
          "def": {
            "type": "array",
            "description": "Definitions",
            "items": {
              "type": "object",
              "properties": {
                "sseq": {
                  "type": "array",
                  "description": "Sense sequence"
                }
              }
            }
          },
          "et": {
            "type": "array",
            "description": "Etymology",
            "items": {
              "type": "array"
            }
          },
          "date": {
            "type": "string",
            "description": "First known use date"
          },
          "shortdef": {
            "type": "array",
            "description": "Short definitions",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "collegiate"
    },
    {
      "name": "learners"
    },
    {
      "name": "medical"
    },
    {
      "name": "spanish"
    },
    {
      "name": "thesaurus"
    }
  ]
}
