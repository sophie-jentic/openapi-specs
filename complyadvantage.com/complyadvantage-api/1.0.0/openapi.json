{
  "openapi": "3.0.3",
  "info": {
    "title": "ComplyAdvantage API",
    "description": "The ComplyAdvantage API enables you to integrate your systems with ComplyAdvantage services to automate AML/compliance functions. The API follows REST convention and accepts and returns JSON data. All requests must be made over HTTPS. Authentication uses API keys provided in the Authorization header as 'Token YOUR_API_KEY'.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.complyadvantage.com/api-docs",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.complyadvantage.com",
      "description": "EU endpoint"
    },
    {
      "url": "https://api.us.complyadvantage.com",
      "description": "US endpoint"
    },
    {
      "url": "https://api.ap.complyadvantage.com",
      "description": "APAC endpoint"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "operationId": "getUsers",
        "tags": [
          "Users"
        ],
        "summary": "Get users",
        "description": "Get a list of users in your account",
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsersResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/searches": {
      "get": {
        "operationId": "listSearches",
        "tags": [
          "Searches"
        ],
        "summary": "List searches",
        "description": "Get a list of your previous searches",
        "parameters": [
          {
            "name": "client_ref",
            "in": "query",
            "description": "Filter searches by client reference",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results to return (default 100, max 100)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset (default 0)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of searches",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createSearch",
        "tags": [
          "Searches"
        ],
        "summary": "Create a new search",
        "description": "Create a new search by POSTing search terms, parameters and filters. By default creating a search will pull the first 100 results from the database.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Too many requests - rate limit exceeded"
          }
        }
      }
    },
    "/searches/{id}": {
      "get": {
        "operationId": "getSearch",
        "tags": [
          "Searches"
        ],
        "summary": "Get a search overview",
        "description": "Get an overview of one of your searches",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Search ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Search details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Search not found"
          }
        }
      },
      "patch": {
        "operationId": "updateSearch",
        "tags": [
          "Searches"
        ],
        "summary": "Update a search",
        "description": "Update details of one of your searches (e.g., assigned user, status)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/searches/{id}/details": {
      "get": {
        "operationId": "getSearchDetails",
        "tags": [
          "Searches"
        ],
        "summary": "Get full search results",
        "description": "Get full search results of one of your searches",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Full search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/searches/{id}/entities": {
      "patch": {
        "operationId": "updateSearchEntities",
        "tags": [
          "Searches"
        ],
        "summary": "Update search entities",
        "description": "Update entities details (e.g., is_whitelisted, risk_level, match_status) of one of your searches",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateEntitiesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entities updated"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/searches/{id}/monitors": {
      "get": {
        "operationId": "getSearchMonitors",
        "tags": [
          "Monitoring"
        ],
        "summary": "Get monitored search details",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Monitor details"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get monitored search details"
      },
      "patch": {
        "operationId": "updateSearchMonitors",
        "tags": [
          "Monitoring"
        ],
        "summary": "Update monitored search details (start/stop monitoring)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateMonitorRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Monitor updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Update monitored search details (start/stop monitoring)"
      }
    },
    "/searches/{id}/monitor/acknowledge": {
      "post": {
        "operationId": "acknowledgeMonitorChanges",
        "tags": [
          "Monitoring"
        ],
        "summary": "Acknowledge changes to a monitored search",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Acknowledged"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Acknowledge changes to a monitored search"
      }
    },
    "/searches/{id}/comments": {
      "post": {
        "operationId": "createComment",
        "tags": [
          "Comments"
        ],
        "summary": "Create a comment",
        "description": "Create a comment (comment on search or comment on entity)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCommentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comment created"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "get": {
        "operationId": "listComments",
        "tags": [
          "Comments"
        ],
        "summary": "Retrieve comments for a specific search",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of comments"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Retrieve comments for a specific search"
      }
    },
    "/searches/{id}/tags/{tagName}": {
      "delete": {
        "operationId": "detachTag",
        "tags": [
          "Tags"
        ],
        "summary": "Detach tags from search",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "tagName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tag detached"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Detach tags from search"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Provide as: 'Token YOUR_API_KEY'"
      }
    },
    "schemas": {
      "CreateSearchRequest": {
        "type": "object",
        "required": [
          "search_term"
        ],
        "properties": {
          "search_term": {
            "description": "A string representing the name of the entity or an object with first_name, middle_names, last_name",
            "oneOf": [
              {
                "type": "string",
                "maxLength": 255
              },
              {
                "type": "object",
                "properties": {
                  "first_name": {
                    "type": "string"
                  },
                  "middle_names": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  }
                }
              }
            ]
          },
          "client_ref": {
            "type": "string",
            "maxLength": 255
          },
          "search_profile": {
            "type": "string"
          },
          "fuzziness": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "maximum": 1
          },
          "offset": {
            "type": "integer",
            "default": 0
          },
          "limit": {
            "type": "integer",
            "default": 100,
            "maximum": 100
          },
          "filters": {
            "$ref": "#/components/schemas/SearchFilters"
          },
          "tags": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "share_url": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          },
          "exact_match": {
            "type": "boolean"
          }
        }
      },
      "SearchFilters": {
        "type": "object",
        "properties": {
          "types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "One or more of: sanction, warning, fitness-probity, pep, pep-class-1, pep-class-2, pep-class-3, pep-class-4, adverse-media, etc."
          },
          "birth_year": {
            "type": "integer"
          },
          "remove_deceased": {
            "type": "string",
            "enum": [
              "0",
              "1"
            ]
          },
          "country_codes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "ISO 3166-1 alpha-2 country codes"
          },
          "entity_type": {
            "type": "string",
            "enum": [
              "person",
              "company",
              "organisation",
              "vessel",
              "aircraft"
            ]
          }
        }
      },
      "UpdateSearchRequest": {
        "type": "object",
        "properties": {
          "assignee_id": {
            "type": "integer"
          },
          "match_status": {
            "type": "string",
            "enum": [
              "no_match",
              "potential_match",
              "false_positive",
              "true_positive",
              "true_positive_approve",
              "true_positive_reject"
            ]
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "unknown",
              "low",
              "medium",
              "high"
            ]
          },
          "tags": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "UpdateEntitiesRequest": {
        "type": "object",
        "properties": {
          "is_whitelisted": {
            "type": "boolean"
          },
          "risk_level": {
            "type": "string"
          },
          "match_status": {
            "type": "string"
          }
        }
      },
      "UpdateMonitorRequest": {
        "type": "object",
        "properties": {
          "is_monitored": {
            "type": "boolean"
          }
        }
      },
      "CreateCommentRequest": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "entity_id": {
            "type": "string"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "content": {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/SearchData"
              }
            }
          }
        }
      },
      "SearchListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "content": {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/SearchData"
                }
              }
            }
          }
        }
      },
      "SearchData": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "ref": {
            "type": "string"
          },
          "searcher_id": {
            "type": "integer"
          },
          "assignee_id": {
            "type": "integer"
          },
          "filters": {
            "$ref": "#/components/schemas/SearchFilters"
          },
          "match_status": {
            "type": "string"
          },
          "risk_level": {
            "type": "string"
          },
          "search_term": {
            "type": "string"
          },
          "total_hits": {
            "type": "integer"
          },
          "total_matches": {
            "type": "integer"
          },
          "updated_at": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "tags": {
            "type": "object"
          },
          "hits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Hit"
            }
          },
          "share_url": {
            "type": "string"
          },
          "client_ref": {
            "type": "string"
          }
        }
      },
      "Hit": {
        "type": "object",
        "properties": {
          "doc": {
            "$ref": "#/components/schemas/Entity"
          },
          "is_whitelisted": {
            "type": "boolean"
          },
          "match_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "match_types_details": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "score": {
            "type": "number"
          }
        }
      },
      "Entity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "entity_type": {
            "type": "string"
          },
          "last_updated_utc": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "middle_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aka": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            }
          },
          "associates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "association": {
                  "type": "string"
                }
              }
            }
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "tag": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                },
                "source": {
                  "type": "string"
                }
              }
            }
          },
          "media": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string",
                  "format": "date-time"
                },
                "snippet": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "UsersResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "content": {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
