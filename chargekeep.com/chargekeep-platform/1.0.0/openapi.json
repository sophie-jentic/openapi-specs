      }
    },
    "/charges/{charge_id}": {
      "get": {
        "operationId": "getCharge",
        "summary": "Get a charge",
        "tags": [
          "Charges"
        ],
        "parameters": [
          {
            "name": "charge_id",
            "in": "path",
