{
  "openapi": "3.0.3",
  "info": {
    "title": "AbuseIPDB API",
    "version": "2.0.0",
    "description": "The AbuseIPDB API allows you to utilize the AbuseIPDB database programmatically. Check IP addresses, report abuse, retrieve blacklists, and more.",
    "x-jentic-source-url": "https://docs.abuseipdb.com/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.abuseipdb.com/api/v2"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Check",
      "description": "Check IP addresses and network blocks"
    },
    {
      "name": "Reports",
      "description": "Query and submit abuse reports"
    },
    {
      "name": "Blacklist",
      "description": "Retrieve blacklisted IP addresses"
    },
    {
      "name": "Management",
      "description": "Manage reported addresses"
    }
  ],
  "paths": {
    "/check": {
      "get": {
        "operationId": "checkIpAddress",
        "summary": "Check an IP address",
        "description": "Accepts a single IP address (v4 or v6). Returns details regarding the IP address queried, such as version, country of origin, usage type, ISP, domain name, and abuse reports.",
        "tags": [
          "Check"
        ],
        "parameters": [
          {
            "name": "ipAddress",
            "in": "query",
            "required": true,
            "description": "A valid IPv4 or IPv6 address to check. Should be URL-encoded for IPv6.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "maxAgeInDays",
            "in": "query",
            "required": false,
            "description": "Maximum age of reports to return, in days. Default is 30.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 30
            }
          },
          {
            "name": "verbose",
            "in": "query",
            "required": false,
            "description": "When set, includes reports and country name in the response.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful check response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests - rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reports": {
      "get": {
        "operationId": "getReports",
        "summary": "Get reports for an IP address",
        "description": "Returns paginated reports for a single IP address (v4 or v6). Not to be confused with the REPORT endpoint which submits new reports.",
        "tags": [
          "Reports"
        ],
        "parameters": [
          {
            "name": "ipAddress",
            "in": "query",
            "required": true,
            "description": "A valid IPv4 or IPv6 address.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "maxAgeInDays",
            "in": "query",
            "required": false,
            "description": "Maximum age of reports to return, in days.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 30
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "perPage",
            "in": "query",
            "required": false,
            "description": "Number of results per page.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful reports response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/blacklist": {
      "get": {
        "operationId": "getBlacklist",
        "summary": "Get blacklisted IP addresses",
        "description": "Returns a list of the most reported IP addresses, ordered by abuseConfidenceScore descending.",
        "tags": [
          "Blacklist"
        ],
        "parameters": [
          {
            "name": "confidenceMinimum",
            "in": "query",
            "required": false,
            "description": "Minimum abuse confidence score (subscriber feature).",
            "schema": {
              "type": "integer",
              "minimum": 25,
              "maximum": 100,
              "default": 100
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of IPs to return. Capped by subscription tier (Standard: 10000, Basic: 100000, Premium: 500000).",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 10000
            }
          },
          {
            "name": "plaintext",
            "in": "query",
            "required": false,
            "description": "When set, returns a plaintext newline-separated list of IPs.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "onlyCountries",
            "in": "query",
            "required": false,
            "description": "Comma-separated ISO 3166 alpha-2 country codes to include (subscriber feature).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "exceptCountries",
            "in": "query",
            "required": false,
            "description": "Comma-separated ISO 3166 alpha-2 country codes to exclude (subscriber feature).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ipVersion",
            "in": "query",
            "required": false,
            "description": "Filter by IP version. Accepts 4 or 6. Default returns both.",
            "schema": {
              "type": "integer",
              "enum": [
                4,
                6
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful blacklist response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlacklistResponse"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "Newline-separated list of IP addresses"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Payment required - subscription upgrade needed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/report": {
      "post": {
        "operationId": "reportIpAddress",
        "summary": "Report an abusive IP address",
        "description": "Submit a report for an abusive IP address. At least one category is required. Strip any personally identifiable information (PII).",
        "tags": [
          "Reports"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/ReportRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful report submission",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests - same IP can only be reported once per 15 minutes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/check-block": {
      "get": {
        "operationId": "checkBlock",
        "summary": "Check a network block",
        "description": "Accepts a subnet (v4 or v6) denoted with CIDR notation. Returns details about the network and any reported addresses within it.",
        "tags": [
          "Check"
        ],
        "parameters": [
          {
            "name": "network",
            "in": "query",
            "required": true,
            "description": "A subnet in CIDR notation (e.g., 127.0.0.1/24). Should be URL-encoded.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "maxAgeInDays",
            "in": "query",
            "required": false,
            "description": "Maximum age of reports to return, in days.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "default": 30
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful check-block response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckBlockResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Payment required - exceeding parameter limits for subscription tier",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bulk-report": {
      "post": {
        "operationId": "bulkReport",
        "summary": "Submit bulk IP reports via CSV",
        "description": "Upload a CSV file containing multiple IP abuse reports. Allows reporting many IPs in one request.",
        "tags": [
          "Reports"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "csv"
                ],
                "properties": {
                  "csv": {
                    "type": "string",
                    "format": "binary",
                    "description": "CSV file containing IP abuse reports"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful bulk report submission",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkReportResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/clear-address": {
      "delete": {
        "operationId": "clearAddress",
        "summary": "Clear reports for an IP address",
        "description": "Deletes all reports for a single IP address (v4 or v6) that were submitted by the authenticated user.",
        "tags": [
          "Management"
        ],
        "parameters": [
          {
            "name": "ipAddress",
            "in": "query",
            "required": true,
            "description": "A valid IPv4 or IPv6 address to clear reports for.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful clear response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClearAddressResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Key",
        "description": "AbuseIPDB API key passed in the Key header"
      }
    },
    "schemas": {
      "CheckResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "ipAddress": {
                "type": "string",
                "description": "The queried IP address"
              },
              "isPublic": {
                "type": "boolean",
                "description": "Whether the IP is public"
              },
              "ipVersion": {
                "type": "integer",
                "description": "IP version (4 or 6)"
              },
              "isWhitelisted": {
                "type": "boolean",
                "nullable": true,
                "description": "Whether the IP appears in any whitelists"
              },
              "abuseConfidenceScore": {
                "type": "integer",
                "description": "Calculated abuse confidence score (0-100)"
              },
              "countryCode": {
                "type": "string",
                "description": "ISO 3166 alpha-2 country code"
              },
              "countryName": {
                "type": "string",
                "description": "Country name (only included with verbose flag)"
              },
              "usageType": {
                "type": "string",
                "description": "General usage type of the address (e.g., Commercial, Data Center/Web Hosting/Transit, Fixed Line ISP)"
              },
              "isp": {
                "type": "string",
                "description": "Internet Service Provider"
              },
              "domain": {
                "type": "string",
                "description": "Domain associated with the IP"
              },
              "hostnames": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Hostnames associated with the IP"
              },
              "isTor": {
                "type": "boolean",
                "description": "Whether the IP is a known Tor exit node"
              },
              "totalReports": {
                "type": "integer",
                "description": "Total number of reports within maxAgeInDays"
              },
              "numDistinctUsers": {
                "type": "integer",
                "description": "Number of distinct users who reported this IP"
              },
              "lastReportedAt": {
                "type": "string",
                "format": "date-time",
                "description": "Timestamp of the last report"
              },
              "reports": {
                "type": "array",
                "description": "Array of reports (only included with verbose flag, limited to 10,000)",
                "items": {
                  "$ref": "#/components/schemas/Report"
                }
              }
            }
          }
        }
      },
      "Report": {
        "type": "object",
        "properties": {
          "reportedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the report"
          },
          "comment": {
            "type": "string",
            "description": "Description of the attack"
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Array of category IDs"
          },
          "reporterId": {
            "type": "integer",
            "description": "Reporter user ID"
          },
          "reporterCountryCode": {
            "type": "string",
            "description": "Reporter's country code"
          },
          "reporterCountryName": {
            "type": "string",
            "description": "Reporter's country name"
          }
        }
      },
      "ReportsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer",
                "description": "Total number of reports"
              },
              "page": {
                "type": "integer",
                "description": "Current page number"
              },
              "count": {
                "type": "integer",
                "description": "Number of results on this page"
              },
              "perPage": {
                "type": "integer",
                "description": "Results per page"
              },
              "lastPage": {
                "type": "integer",
                "description": "Last page number"
              },
              "nextPageUrl": {
                "type": "string",
                "nullable": true,
                "description": "URL for the next page"
              },
              "previousPageUrl": {
                "type": "string",
                "nullable": true,
                "description": "URL for the previous page"
              },
              "results": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Report"
                }
              }
            }
          }
        }
      },
      "BlacklistResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "generatedAt": {
                "type": "string",
                "format": "date-time",
                "description": "Timestamp when the list was generated"
              }
            }
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ipAddress": {
                  "type": "string"
                },
                "abuseConfidenceScore": {
                  "type": "integer"
                },
                "lastReportedAt": {
                  "type": "string",
                  "format": "date-time"
                },
                "countryCode": {
                  "type": "string",
                  "description": "Included when country filtering is used"
                }
              }
            }
          }
        }
      },
      "ReportRequest": {
        "type": "object",
        "required": [
          "ip",
          "categories"
        ],
        "properties": {
          "ip": {
            "type": "string",
            "description": "A valid IPv4 or IPv6 address to report"
          },
          "categories": {
            "type": "string",
            "description": "Comma-separated category IDs (max 30)"
          },
          "comment": {
            "type": "string",
            "description": "Descriptive text of the attack (server logs, port numbers, etc). Strip any PII."
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 datetime of the attack or earliest observance. Defaults to current time."
          }
        }
      },
      "ReportResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "ipAddress": {
                "type": "string"
              },
              "abuseConfidenceScore": {
                "type": "integer"
              }
            }
          }
        }
      },
      "CheckBlockResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "networkAddress": {
                "type": "string",
                "description": "Network address"
              },
              "netmask": {
                "type": "string",
                "description": "Subnet mask"
              },
              "minAddress": {
                "type": "string",
                "description": "First usable address in the block"
              },
              "maxAddress": {
                "type": "string",
                "description": "Last usable address in the block"
              },
              "numPossibleHosts": {
                "type": "integer",
                "description": "Number of possible hosts in the block"
              },
              "addressSpaceDesc": {
                "type": "string",
                "description": "Description of the address space"
              },
              "reportedAddress": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "ipAddress": {
                      "type": "string"
                    },
                    "numReports": {
                      "type": "integer"
                    },
                    "mostRecentReport": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "abuseConfidenceScore": {
                      "type": "integer"
                    },
                    "countryCode": {
                      "type": "string",
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      },
      "BulkReportResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "savedReports": {
                "type": "integer",
                "description": "Number of reports successfully saved"
              },
              "invalidReports": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "input": {
                      "type": "string"
                    },
                    "rowNumber": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ClearAddressResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "numReportsDeleted": {
                "type": "integer",
                "description": "Number of reports deleted"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "detail": {
                  "type": "string"
                },
                "status": {
                  "type": "integer"
                },
                "source": {
                  "type": "object",
                  "properties": {
                    "parameter": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
