{
  "openapi": "3.0.3",
  "info": {
    "title": "Html2PDF API",
    "description": "High-quality HTML to PDF conversion API service. Convert HTML content or URLs to PDF documents with a browser-based PDF rendering engine. Supports asynchronous request processing, custom page formats, headers/footers, and extensive styling options.",
    "version": "1.0.0",
    "contact": {
      "name": "Html2PDF",
      "url": "https://html2pdf.app/"
    },
    "x-jentic-source-url": "https://html2pdf.app/"
  },
  "servers": [
    {
      "url": "https://api.html2pdf.app",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "PDF Generation",
      "description": "Endpoints for generating PDF documents from HTML content or URLs"
    },
    {
      "name": "Account",
      "description": "Endpoints for managing account and usage information"
    }
  ],
  "paths": {
    "/v1/generate": {
      "post": {
        "tags": ["PDF Generation"],
        "summary": "Generate PDF from HTML or URL",
        "description": "Convert HTML content or a URL to a PDF document. Supports synchronous and asynchronous modes. In synchronous mode, the PDF binary is returned directly. In asynchronous mode, a URL to download the PDF is returned.",
        "operationId": "generatePdf",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GeneratePdfRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PDF generated successfully (synchronous mode)",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeneratePdfAsyncResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "402": {
            "description": "Payment required - account quota exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests - rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/generate/url": {
      "post": {
        "tags": ["PDF Generation"],
        "summary": "Generate PDF from URL",
        "description": "Convert a web page at the specified URL to a PDF document. The page is rendered in a headless browser before conversion.",
        "operationId": "generatePdfFromUrl",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GeneratePdfFromUrlRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PDF generated successfully",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeneratePdfAsyncResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid URL or parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests - rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/generate/async": {
      "post": {
        "tags": ["PDF Generation"],
        "summary": "Generate PDF asynchronously",
        "description": "Submit an HTML-to-PDF conversion request for asynchronous processing. Returns a job ID that can be used to check status and retrieve the result.",
        "operationId": "generatePdfAsync",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GeneratePdfRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "PDF generation request accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsyncJobResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/status/{jobId}": {
      "get": {
        "tags": ["PDF Generation"],
        "summary": "Get async job status",
        "description": "Check the status of an asynchronous PDF generation job and retrieve the download URL when complete.",
        "operationId": "getJobStatus",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The job ID returned from the async generation endpoint"
          }
        ],
        "responses": {
          "200": {
            "description": "Job status retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobStatusResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Job not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/account": {
      "get": {
        "tags": ["Account"],
        "summary": "Get account information",
        "description": "Retrieve current account information including usage statistics and remaining quota.",
        "operationId": "getAccount",
        "responses": {
          "200": {
            "description": "Account information retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountInfo"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authentication",
        "description": "API key for authentication. Format: 'Token <api-key>'"
      }
    },
    "schemas": {
      "GeneratePdfRequest": {
        "type": "object",
        "properties": {
          "html": {
            "type": "string",
            "description": "HTML content to convert to PDF"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the webpage to convert to PDF (alternative to html)"
          },
          "fileName": {
            "type": "string",
            "description": "Name of the generated PDF file"
          },
          "async": {
            "type": "boolean",
            "default": false,
            "description": "Whether to process the request asynchronously"
          },
          "options": {
            "$ref": "#/components/schemas/PdfOptions"
          }
        }
      },
      "GeneratePdfFromUrlRequest": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the webpage to convert to PDF"
          },
          "fileName": {
            "type": "string",
            "description": "Name of the generated PDF file"
          },
          "waitFor": {
            "type": "integer",
            "description": "Time in milliseconds to wait for page to load before conversion"
          },
          "waitForSelector": {
            "type": "string",
            "description": "CSS selector to wait for before conversion"
          },
          "options": {
            "$ref": "#/components/schemas/PdfOptions"
          }
        }
      },
      "PdfOptions": {
        "type": "object",
        "description": "PDF generation options",
        "properties": {
          "format": {
            "type": "string",
            "enum": ["A0", "A1", "A2", "A3", "A4", "A5", "A6", "Letter", "Legal", "Tabloid", "Ledger"],
            "default": "A4",
            "description": "Page format"
          },
          "width": {
            "type": "string",
            "description": "Page width (overrides format). Accepts CSS units like '8.5in', '210mm'"
          },
          "height": {
            "type": "string",
            "description": "Page height (overrides format). Accepts CSS units"
          },
          "printBackground": {
            "type": "boolean",
            "default": true,
            "description": "Print background graphics and colors"
          },
          "landscape": {
            "type": "boolean",
            "default": false,
            "description": "Set paper orientation to landscape"
          },
          "scale": {
            "type": "number",
            "minimum": 0.1,
            "maximum": 2.0,
            "default": 1,
            "description": "Scale of the webpage rendering"
          },
          "margin": {
            "type": "object",
            "description": "Page margins",
            "properties": {
              "top": {
                "type": "string",
                "default": "0",
                "description": "Top margin (CSS units)"
              },
              "right": {
                "type": "string",
                "default": "0",
                "description": "Right margin (CSS units)"
              },
              "bottom": {
                "type": "string",
                "default": "0",
                "description": "Bottom margin (CSS units)"
              },
              "left": {
                "type": "string",
                "default": "0",
                "description": "Left margin (CSS units)"
              }
            }
          },
          "headerTemplate": {
            "type": "string",
            "description": "HTML template for the page header. Supports special classes: date, title, url, pageNumber, totalPages"
          },
          "footerTemplate": {
            "type": "string",
            "description": "HTML template for the page footer. Supports same special classes as header"
          },
          "displayHeaderFooter": {
            "type": "boolean",
            "default": false,
            "description": "Display header and footer templates"
          },
          "pageRanges": {
            "type": "string",
            "description": "Paper ranges to print, e.g., '1-5, 8, 11-13'"
          },
          "preferCSSPageSize": {
            "type": "boolean",
            "default": false,
            "description": "Give any CSS @page size declared in the page priority over format option"
          }
        }
      },
      "GeneratePdfAsyncResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to download the generated PDF"
          },
          "expires": {
            "type": "string",
            "format": "date-time",
            "description": "Expiration time of the download URL"
          }
        }
      },
      "AsyncJobResponse": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string",
            "description": "Unique identifier for the async job"
          },
          "status": {
            "type": "string",
            "enum": ["queued", "processing"],
            "description": "Current status of the job"
          }
        }
      },
      "JobStatusResponse": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string",
            "description": "Unique identifier for the job"
          },
          "status": {
            "type": "string",
            "enum": ["queued", "processing", "completed", "failed"],
            "description": "Current status of the job"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to download the generated PDF (available when status is completed)"
          },
          "error": {
            "type": "string",
            "description": "Error message (available when status is failed)"
          },
          "expires": {
            "type": "string",
            "format": "date-time",
            "description": "Expiration time of the download URL"
          }
        }
      },
      "AccountInfo": {
        "type": "object",
        "properties": {
          "plan": {
            "type": "string",
            "description": "Current subscription plan"
          },
          "creditsUsed": {
            "type": "integer",
            "description": "Number of credits used in the current billing period"
          },
          "creditsRemaining": {
            "type": "integer",
            "description": "Number of credits remaining in the current billing period"
          },
          "creditsTotal": {
            "type": "integer",
            "description": "Total credits available in the current billing period"
          },
          "billingPeriodEnd": {
            "type": "string",
            "format": "date-time",
            "description": "End of the current billing period"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error type or code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          }
        }
      }
    }
  }
}
