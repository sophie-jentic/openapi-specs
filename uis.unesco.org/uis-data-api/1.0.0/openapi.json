    },
    "/api/data-browser/versions/default": {
      "get": {
        "operationId": "getDataBrowserDefaultVersion",
        "summary": "Get default version for data browser",
        "tags": [
          "Data Browser"
        ],
        "responses": {
          "200": {
            "description": "Data browser default version"
          }
        },
        "description": "Get default version for data browser"
      }
    },
    "/api/data-browser/resources/{version}/indicators/indicator-definitions-{language}.json": {
      "get": {
        "operationId": "getIndicatorDefinitionsByLanguage",
        "summary": "Get indicator definitions for a specific version and language",
        "tags": [
          "Data Browser"
        ],
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Data version identifier."
          },
          {
            "name": "language",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Language code (e.g. en, fr, es)."
          }
        ],
        "responses": {
          "200": {
            "description": "Indicator definitions in specified language",
            "content": {
              "application/json": {}
            }
          }
        },
        "description": "Get indicator definitions for a specific version and language"
      }
    },
    "/api/data-browser/resources/{version}/frameworks/frameworks-list-{language}.json": {
