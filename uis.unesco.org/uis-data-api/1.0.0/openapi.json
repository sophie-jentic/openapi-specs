{
  "openapi": "3.0.3",
  "info": {
    "title": "UNESCO Institute for Statistics (UIS) Data API",
    "version": "1.0.0",
    "description": "The UIS Data API provides programmatic access to UNESCO Institute for Statistics data covering education, science, technology, innovation, culture, and demographic/socioeconomic indicators. Supports querying indicator data by geo-units and indicators, with export capabilities in CSV, Excel, and JSON formats. Data is versioned and organized by themes including Education, Science/Technology/Innovation, Culture, and Demographic/Socioeconomic statistics.",
    "x-jentic-source-url": "https://databrowser.uis.unesco.org",
    "contact": {
      "email": "webmaster@uis.unesco.org"
    },
    "license": {
      "name": "Creative Commons Attribution-ShareAlike 3.0 IGO",
      "url": "http://creativecommons.org/licenses/by-sa/3.0/igo/"
    }
  },
  "servers": [
    {
      "url": "https://api.uis.unesco.org",
      "description": "UIS Data API Production"
    }
  ],
  "paths": {
    "/api/public/versions/default": {
      "get": {
        "operationId": "getDefaultVersion",
        "summary": "Get the default (latest) data version",
        "description": "Returns information about the current default data version including publication date, description, and last update timestamps per theme.",
        "tags": [
          "Versions"
        ],
        "responses": {
          "200": {
            "description": "Default version details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataVersion"
                }
              }
            }
          }
        }
      }
    },
    "/api/public/versions": {
      "get": {
        "operationId": "listVersions",
        "summary": "List all data versions",
        "description": "Returns a list of all available data versions with their publication dates and theme status.",
        "tags": [
          "Versions"
        ],
        "responses": {
          "200": {
            "description": "List of data versions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DataVersion"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/public/definitions/geounits": {
      "get": {
        "operationId": "listGeoUnits",
        "summary": "List all geographic units",
        "description": "Returns the list of all geographic units (countries, regions) with their codes, names, and types.",
        "tags": [
          "Definitions"
        ],
        "responses": {
          "200": {
            "description": "List of geographic units",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GeoUnit"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/public/definitions/geounits/export": {
      "get": {
        "operationId": "exportGeoUnits",
        "summary": "Export geographic units definitions",
        "description": "Export all geographic unit definitions in the specified format.",
        "tags": [
          "Definitions"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/exportFormat"
          }
        ],
        "responses": {
          "200": {
            "description": "Exported geo-unit data",
            "content": {
              "application/json": {},
              "text/csv": {},
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {}
            }
          },
          "400": {
            "description": "Invalid format parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/public/definitions/indicators": {
      "get": {
        "operationId": "listIndicators",
        "summary": "List all indicator definitions",
        "description": "Returns a list of all available indicators with their codes, names, themes, last update dates, and data availability metadata.",
        "tags": [
          "Definitions"
        ],
        "responses": {
          "200": {
            "description": "List of indicators",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IndicatorDefinition"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/public/definitions/indicators/export": {
      "get": {
        "operationId": "exportIndicators",
        "summary": "Export indicator definitions",
        "description": "Export all indicator definitions in the specified format.",
        "tags": [
          "Definitions"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/exportFormat"
          }
        ],
        "responses": {
          "200": {
            "description": "Exported indicator definitions",
            "content": {
              "application/json": {},
              "text/csv": {},
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {}
            }
          },
          "400": {
            "description": "Invalid format parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/public/data/indicators": {
      "get": {
        "operationId": "queryIndicatorData",
        "summary": "Query indicator data",
        "description": "Retrieve indicator data filtered by geographic units and/or indicator codes. At least one geoUnit or indicator query parameter must be provided.",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "indicator",
            "in": "query",
            "description": "Indicator code(s) to query. Can be repeated for multiple indicators.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "geoUnit",
            "in": "query",
            "description": "ISO 3166-1 alpha-3 geographic unit code(s) to query. Can be repeated for multiple geo-units.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Indicator data records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndicatorDataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - at least one geoUnit or indicator must be provided",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/public/data/indicators/export": {
      "get": {
        "operationId": "exportIndicatorData",
        "summary": "Export indicator data",
        "description": "Export indicator data as a downloadable file in the specified format (CSV, Excel, or JSON). Returns a ZIP archive.",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "indicator",
            "in": "query",
            "description": "Indicator code(s) to export.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "geoUnit",
            "in": "query",
            "description": "Geographic unit code(s) to export.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/exportFormat"
          }
        ],
        "responses": {
          "200": {
            "description": "ZIP archive containing exported data",
            "content": {
              "application/zip": {}
            }
          },
          "400": {
            "description": "Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/public/export/indicators/csv": {
      "get": {
        "operationId": "exportIndicatorsCsv",
        "summary": "Export indicators as CSV",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "indicator",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "geoUnit",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CSV export",
            "content": {
              "text/csv": {}
            }
          }
        },
        "description": "Export indicators as CSV"
      }
    },
    "/api/public/export/indicators/excel": {
      "get": {
        "operationId": "exportIndicatorsExcel",
        "summary": "Export indicators as Excel",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "indicator",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "geoUnit",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Excel export",
            "content": {
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {}
            }
          }
        },
        "description": "Export indicators as Excel"
      }
    },
    "/api/data-browser/statistics/themes": {
      "get": {
        "operationId": "getThemeStatistics",
        "summary": "Get statistics by theme",
        "description": "Returns theme-level statistics for the data browser.",
        "tags": [
          "Data Browser"
