  },
  "components": {
    "parameters": {
      "exportFormat": {
        "name": "format",
        "in": "query",
        "required": true,
        "description": "Export format.",
        "schema": {
          "type": "string",
          "enum": [
            "csv",
            "excel",
            "json"
          ]
        }
      }
    },
    "schemas": {
      "DataVersion": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string",
            "description": "Version identifier (e.g. '20260311-78618c3e')."
          },
          "publicationDate": {
            "type": "string",
            "format": "date-time",
            "description": "Publication date of this version."
          },
          "description": {
            "type": "string",
            "description": "Description of this version/release."
          },
          "themeDataStatus": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ThemeDataStatus"
            }
          }
        }
      },
      "ThemeDataStatus": {
        "type": "object",
        "properties": {
          "theme": {
            "type": "string",
            "enum": [
              "EDUCATION",
              "SCIENCE_TECHNOLOGY_INNOVATION",
              "CULTURE",
              "DEMOGRAPHIC_SOCIOECONOMIC"
            ],
            "description": "Theme identifier."
          },
          "lastUpdate": {
            "type": "string",
            "description": "Date of last data update for this theme (DD/MM/YYYY)."
          },
          "description": {
            "type": "string",
            "description": "Description of the data release."
          }
        }
      },
      "GeoUnit": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ISO 3166-1 alpha-3 country/region code."
          },
          "name": {
            "type": "string",
            "description": "English name of the geographic unit."
          },
          "type": {
            "type": "string",
            "enum": [
              "NATIONAL",
              "REGIONAL"
            ],
            "description": "Type of geographic unit."
          }
        }
      },
      "IndicatorDefinition": {
        "type": "object",
        "properties": {
          "indicatorCode": {
            "type": "string",
            "description": "Unique indicator code."
          },
          "name": {
            "type": "string",
            "description": "Indicator name/description."
          },
          "theme": {
            "type": "string",
            "enum": [
              "EDUCATION",
              "SCIENCE_TECHNOLOGY_INNOVATION",
              "CULTURE",
              "DEMOGRAPHIC_SOCIOECONOMIC"
            ],
            "description": "Theme this indicator belongs to."
          },
          "lastDataUpdate": {
            "type": "string",
            "description": "Date of last data update."
          },
          "lastDataUpdateDescription": {
            "type": "string",
            "description": "Description of the last data update."
          },
          "dataAvailability": {
            "$ref": "#/components/schemas/DataAvailability"
          }
        }
      },
      "DataAvailability": {
        "type": "object",
        "properties": {
          "totalRecordCount": {
            "type": "integer",
            "description": "Total number of data records."
          },
          "timeLine": {
            "type": "object",
            "properties": {
              "min": {
                "type": "integer",
                "description": "Earliest year with data."
              },
              "max": {
                "type": "integer",
                "description": "Latest year with data."
              }
            }
          },
          "geoUnits": {
            "type": "object",
            "properties": {
              "types": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Types of geo-units with data."
              }
            }
          }
        }
      },
      "IndicatorDataResponse": {
        "type": "object",
        "properties": {
          "hints": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Any hints or notices about the response."
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IndicatorDataRecord"
            },
            "description": "Data records matching the query."
          }
        }
      },
      "IndicatorDataRecord": {
        "type": "object",
        "properties": {
          "indicatorId": {
            "type": "string",
            "description": "Indicator code."
          },
          "geoUnit": {
            "type": "string",
            "description": "Geographic unit code (ISO 3166-1 alpha-3)."
          },
          "year": {
            "type": "integer",
            "description": "Year of the observation."
          },
          "value": {
            "type": "number",
            "nullable": true,
            "description": "Indicator value."
          },
          "magnitude": {
            "type": "string",
            "nullable": true,
            "description": "Magnitude qualifier (e.g. 'NIL')."
          },
          "qualifier": {
            "type": "string",
            "nullable": true,
            "description": "Data qualifier."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ],
            "description": "Error message(s)."
          },
          "error": {
            "type": "string",
            "description": "Error type (e.g. 'Bad Request')."
          },
          "statusCode": {
            "type": "integer",
            "description": "HTTP status code."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Data"
    },
    {
      "name": "Data Browser"
    },
    {
      "name": "Definitions"
    },
    {
      "name": "Versions"
    }
  ]
}
