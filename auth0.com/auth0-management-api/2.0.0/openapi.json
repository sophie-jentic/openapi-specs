{
  "openapi": "3.0.3",
  "info": {
    "title": "Auth0 Management API",
    "version": "2.0.0",
    "description": "Auth0 Management API v2 allows you to manage your Auth0 account programmatically. Control users, connections, clients, APIs, rules, logs, roles, and more.",
    "x-jentic-source-url": "https://auth0.com/docs/api/management/v2",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{domain}/api/v2",
      "description": "Auth0 Management API",
      "variables": {
        "domain": {
          "default": "YOUR_DOMAIN.auth0.com",
          "description": "Your Auth0 tenant domain"
        }
      }
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "User management"
    },
    {
      "name": "Connections",
      "description": "Connection management"
    },
    {
      "name": "Clients",
      "description": "Application (client) management"
    },
    {
      "name": "Resource Servers",
      "description": "API (resource server) management"
    },
    {
      "name": "Roles",
      "description": "Role management"
    },
    {
      "name": "Organizations",
      "description": "Organization management"
    },
    {
      "name": "Logs",
      "description": "Log event retrieval"
    },
    {
      "name": "Rules",
      "description": "Rules management"
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "List or search users",
        "operationId": "getUsers",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100
            }
          },
          {
            "name": "include_totals",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "connection",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include_fields",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Lucene query string for user search",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search_engine",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Users list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List or search users"
      },
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Create a user",
        "operationId": "createUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "409": {
            "description": "Conflict - user already exists"
          }
        },
        "description": "Create a user"
      }
    },
