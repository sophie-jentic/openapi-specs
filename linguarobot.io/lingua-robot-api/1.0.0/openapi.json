{
  "openapi": "3.0.3",
  "info": {
    "title": "Lingua Robot API",
    "description": "Text processing and dictionary API providing access to over 800,000 English lexical entries including words, phrasal verbs, and multi-word expressions. Features include word definitions, lemmatization, audio pronunciations, IPA transcriptions, inflection data, and morphemic analysis.",
    "version": "1.0.0",
    "contact": {
      "url": "https://www.linguarobot.io"
    }
  },
  "servers": [
    {
      "url": "https://lingua-robot.p.rapidapi.com"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/language/v1/entries/en/{word}": {
      "get": {
        "summary": "Get word entry",
        "description": "Retrieve comprehensive information about an English word including definitions, pronunciations, inflections, and morphemic analysis.",
        "operationId": "getWordEntry",
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "description": "The word to look up",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "example"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with word entry data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/WordEntry"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Word not found"
          }
        },
        "tags": [
          "language"
        ]
      }
    },
    "/language/v1/entries/en": {
      "post": {
        "summary": "Lemmatize text",
        "description": "Convert words to their base form (lemma) for text processing.",
        "operationId": "lemmatizeText",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Text to lemmatize"
                  }
                },
                "required": [
                  "text"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful lemmatization",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "lemmas": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "word": {
                            "type": "string"
                          },
                          "lemma": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "language"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-RapidAPI-Key",
        "description": "API key for authentication. Available via RapidAPI platform. Free tier: 2,500 requests/day."
      }
    },
    "schemas": {
      "WordEntry": {
        "type": "object",
        "properties": {
          "entry": {
            "type": "string",
            "description": "The word entry"
          },
          "pronunciations": {
            "type": "array",
            "description": "Pronunciation information",
            "items": {
              "type": "object",
              "properties": {
                "transcriptions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "transcription": {
                        "type": "string",
                        "description": "IPA transcription"
                      },
                      "notation": {
                        "type": "string",
                        "description": "Notation type (e.g., IPA)"
                      }
                    }
                  }
                },
                "audio": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string",
                      "description": "Audio file URL"
                    }
                  }
                }
              }
            }
          },
          "interpretations": {
            "type": "array",
            "description": "Word meanings and definitions",
            "items": {
              "type": "object",
              "properties": {
                "lemma": {
                  "type": "string",
                  "description": "Base form of the word"
                },
                "partOfSpeech": {
                  "type": "string",
                  "description": "Part of speech"
                },
                "inflections": {
                  "type": "array",
                  "description": "Inflected forms",
                  "items": {
                    "type": "object"
                  }
                },
                "senses": {
                  "type": "array",
                  "description": "Word senses/meanings",
                  "items": {
                    "type": "object",
                    "properties": {
                      "definition": {
                        "type": "string",
                        "description": "Definition of this sense"
                      },
                      "usageExamples": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "lexemes": {
            "type": "array",
            "description": "Morphemic analysis",
            "items": {
              "type": "object",
              "properties": {
                "lemma": {
                  "type": "string"
                },
                "partOfSpeech": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "language"
    }
  ]
}
