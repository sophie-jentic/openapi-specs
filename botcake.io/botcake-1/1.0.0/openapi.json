              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total_messages": {
                      "type": "integer"
                    },
                    "bot_messages": {
                      "type": "integer"
                    },
                    "human_messages": {
                      "type": "integer"
                    },
                    "by_date": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Get message analytics"
      }
    }
