                }
              }
            }
          }
        },
        "description": "List bots"
      },
      "post": {
        "tags": [
          "Bots"
        ],
        "summary": "Create bot",
        "operationId": "createBot",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name"
