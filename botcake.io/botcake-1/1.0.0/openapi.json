  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Customers",
      "description": "Customer management"
    },
    {
      "name": "Conversations",
      "description": "Conversation management"
    },
    {
      "name": "Messages",
      "description": "Message sending and retrieval"
    },
    {
      "name": "Bots",
      "description": "Bot configuration"
    },
    {
      "name": "Analytics",
      "description": "Analytics and reporting"
