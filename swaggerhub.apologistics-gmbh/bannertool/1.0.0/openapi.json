              "type": "integer",
              "minimum": 0,
              "maximum": 2
            },
            "required": false,
            "description": "Art des Banners - 0 = Zeitgesteuert, 1 = F\u00fcllbanner, 2 = Infobanner"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "$ref": "#/components/schemas/LIMIT"
            },
            "required": false,
            "description": "Anzahl an Bannern, die abgerufen werden sollen"
          }
        ],
        "responses": {
          "200": {
            "description": "Alle Banner",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "result": {
                      "$ref": "#/components/schemas/SuccessResultType"
                    },
                    "entries": {
                      "description": "Array mit allen Eintr\u00e4gen",
