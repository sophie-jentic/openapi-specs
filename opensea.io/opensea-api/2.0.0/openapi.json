  "components": {
    "schemas": {
      "ChainIdentifier": {
        "type": "string",
        "default": "ethereum",
        "description": "Blockchain chain identifier",
        "enum": [
          "blast",
          "base",
          "ethereum",
          "zora",
          "arbitrum",
          "sei",
          "avalanche",
          "polygon",
          "optimism",
          "ape_chain",
          "flow",
          "b3",
          "soneium",
          "ronin",
          "bera_chain",
          "solana",
          "shape",
          "unichain",
          "gunzilla",
          "abstract",
          "animechain",
          "hyperevm",
          "somnia",
          "monad",
          "hyperliquid"
        ],
        "example": "ethereum"
      },
      "V1ErrorWrapper": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "errors"
        ]
      },
      "Trait": {
        "type": "object",
        "properties": {
          "trait_type": {
            "type": "string"
          },
          "display_type": {
            "type": "string"
          },
          "max_value": {
            "type": "string"
          },
          "value": {}
