        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": {
                    "type": "string",
                    "description": "new password to set"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/user"
                }
              }
            }
          }
        },
        "x-codegen-request-body-name": "body",
        "description": "Changes the password of a user",
        "operationId": "put-user-by-uuid"
      },
      "delete": {
        "tags": [
          "users"
        ],
        "summary": "Deletes a user",
