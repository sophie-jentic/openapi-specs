    "/users/{uuid}/tokens": {
      "post": {
        "tags": [
          "users"
        ],
        "summary": "Crates a API token for a user with a given scope, please keep in\nmind that the reply to this request is THE ONLY TIME the bearer\ntoken can be accessed!\n",
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "description": "uuid of the user",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "comment": {
                    "type": "string",
                    "description": "A comment for the token"
                  },
                  "scopes": {
                    "type": "array",
                    "description": "A list of scopes for the token",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/apikey"
                }
              }
            }
          }
        },
        "x-codegen-request-body-name": "body",
        "description": "Crates a API token for a user with a given scope, please keep in\nmind that the reply to this request is THE ONLY TIME the bearer\ntoken can be accessed!\n",
        "operationId": "post-users-by-uuid-tokens"
      }
    },
