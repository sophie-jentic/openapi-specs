          },
          {
            "name": "permission",
            "in": "path",
            "description": "the permission to grant as path i.e. 'some/funky/permission'\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {}
          }
        },
        "description": "Grants a permission to a user",
        "operationId": "put-user-by-uuid-permissions-by-permission"
      },
      "delete": {
        "tags": [
          "users"
        ],
        "summary": "Revokes a permission from a user",
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "description": "UUID of the user",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "permission",
            "in": "path",
            "description": "the permission to grant as path i.e. 'some/funky/permission'\n",
