            "name": "token-id",
            "in": "path",
            "description": "ID of the token to delete (not the token itself!)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {}
