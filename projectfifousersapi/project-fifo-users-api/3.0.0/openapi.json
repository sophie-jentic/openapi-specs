        ],
        "summary": "Adds a user to an Organisation. The first joined Organisation\nwill automatically be set as active. Any further Organisations\nneed to be selected as active by passing the 'active' parameter\nin a JSON.\n",
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "description": "uuid of the user",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "org",
            "in": "path",
            "description": "UUID of the org to join",
            "required": true,
            "schema": {
              "type": "string"
