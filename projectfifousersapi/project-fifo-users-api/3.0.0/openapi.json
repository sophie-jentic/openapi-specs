        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {}
          }
        },
        "description": "Deletes a user",
        "operationId": "delete-user-by-uuid"
      }
    },
    "/user/{uuid}/permissions/{permission}": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "Tests if a user has is allowed to perform an action.\nPlease note that 403 here does not mean the user is not allowed\nbut that the requesting token was not allowed to test for the client!\n",
