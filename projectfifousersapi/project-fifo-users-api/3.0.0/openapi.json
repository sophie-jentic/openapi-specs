        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "active": {
                    "type": "boolean",
                    "description": "used to set an org"
                  }
                }
              }
            }
          },
          "required": false
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {}
          }
        },
        "x-codegen-request-body-name": "body",
        "description": "Adds a user to an Organisation. The first joined Organisation\nwill automatically be set as active. Any further Organisations\nneed to be selected as active by passing the 'active' parameter\nin a JSON.\n",
        "operationId": "put-users-by-uuid-orgs-by-org"
