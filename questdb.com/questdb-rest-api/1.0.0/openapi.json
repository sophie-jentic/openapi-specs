{
  "openapi": "3.0.3",
  "info": {
    "title": "QuestDB REST API",
    "version": "1.0.0",
    "description": "QuestDB is a high-performance open-source time-series database. Its REST API provides SQL query execution, CSV import/export, health monitoring, and table management via HTTP.",
    "x-jentic-source-url": "https://questdb.com/docs/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:9000"
    }
  ],
  "paths": {
    "/exec": {
      "get": {
        "operationId": "executeSqlGet",
        "summary": "Execute SQL query (GET)",
        "description": "Execute a SQL query and return results as JSON. Supports SELECT, INSERT, CREATE TABLE, and other DDL/DML statements.",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "SQL query to execute"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Limit rows e.g., 10,20 (offset,count)"
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include total row count"
          },
          {
            "name": "nm",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Skip metadata in response"
          },
          {
            "name": "timings",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include query timing"
          }
        ],
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Query error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "executeSqlPost",
        "summary": "Execute SQL query (POST)",
        "description": "Execute a SQL query via POST. Use for long queries that exceed URL length limits.",
        "tags": [
          "Query"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "limit": {
                    "type": "string"
                  },
                  "count": {
                    "type": "boolean"
                  },
                  "nm": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Query error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/imp": {
      "post": {
        "operationId": "importCsv",
        "summary": "Import CSV data",
        "description": "Import CSV data into a table. Creates the table if it doesn't exist. Supports multipart/form-data upload.",
        "tags": [
          "Import"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Table name"
          },
          {
            "name": "timestamp",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Designated timestamp column"
          },
          {
            "name": "partitionBy",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "NONE",
                "HOUR",
                "DAY",
                "WEEK",
                "MONTH",
                "YEAR"
              ]
            },
            "description": "Partition strategy"
          },
          {
            "name": "overwrite",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Overwrite existing data"
          },
          {
            "name": "durable",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Ensure data is committed to disk"
          },
          {
            "name": "atomicity",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "strict",
                "skipRow"
              ]
            },
            "description": "Error handling mode"
          },
          {
            "name": "fmt",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "tab"
              ]
            },
            "description": "Response format"
          },
          {
            "name": "maxUncommittedRows",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportResponse"
                }
              }
            }
          },
          "400": {
            "description": "Import error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/exp": {
      "get": {
        "operationId": "exportCsv",
        "summary": "Export data as CSV",
        "description": "Export query results as CSV. Runs a SELECT query and returns results in CSV format.",
        "tags": [
          "Export"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "SQL SELECT query"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CSV export",
            "content": {
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Query error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chk": {
      "get": {
        "operationId": "healthCheck",
        "summary": "Health check",
        "description": "Simple health check endpoint. Returns 200 if server is healthy.",
        "tags": [
          "Health"
        ],
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/table-columns": {
      "get": {
        "operationId": "getTableColumns",
        "summary": "Get table columns",
        "description": "Returns column metadata for a specific table.",
        "tags": [
          "Tables"
        ],
        "parameters": [
          {
            "name": "table",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Table name"
          }
        ],
        "responses": {
          "200": {
            "description": "Column metadata",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ColumnInfo"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QueryResponse": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              }
            }
          },
          "dataset": {
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "count": {
            "type": "integer"
          },
          "timings": {
            "type": "object",
            "properties": {
              "compiler": {
                "type": "number"
              },
              "execute": {
                "type": "number"
              },
              "count": {
                "type": "number"
              }
            }
          }
        }
      },
      "QueryErrorResponse": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "error": {
            "type": "string"
          },
          "position": {
            "type": "integer"
          }
        }
      },
      "ImportResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "rowsRejected": {
            "type": "integer"
          },
          "rowsImported": {
            "type": "integer"
          },
          "header": {
            "type": "boolean"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "size": {
                  "type": "integer"
                },
                "errors": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "ColumnInfo": {
        "type": "object",
        "properties": {
          "column": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "indexed": {
            "type": "boolean"
          },
          "indexBlockCapacity": {
            "type": "integer"
          },
          "symbolCached": {
            "type": "boolean"
          },
          "symbolCapacity": {
            "type": "integer"
          },
          "designated": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Auth (when QuestDB auth is enabled)"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Export"
    },
    {
      "name": "Health"
    },
    {
      "name": "Import"
    },
    {
      "name": "Query"
    },
    {
      "name": "Tables"
    }
  ]
}
