{
  "openapi": "3.0.3",
  "info": {
    "title": "Zamzar API",
    "version": "v1",
    "description": "File conversion API supporting 1000+ file formats",
    "x-jentic-source-url": "https://developers.zamzar.com/docs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.zamzar.com/v1",
      "description": "Production server"
    },
    {
      "url": "https://sandbox.zamzar.com/v1",
      "description": "Sandbox server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "formats",
      "description": "Supported file formats"
    },
    {
      "name": "jobs",
      "description": "Conversion jobs"
    },
    {
      "name": "files",
      "description": "File management"
    }
  ],
  "paths": {
    "/formats": {
      "get": {
        "summary": "List all supported file formats",
        "operationId": "listFormats",
        "tags": [
          "formats"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "paging": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "List all supported file formats"
      }
    },
    "/formats/{format}": {
      "get": {
        "summary": "Get details for specific format",
        "operationId": "getFormat",
        "tags": [
          "formats"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Format identifier (e.g., pdf, docx)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "description": "Get details for specific format"
      }
    },
    "/jobs": {
      "post": {
        "summary": "Create new conversion job",
        "operationId": "createJob",
        "tags": [
          "jobs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "source_file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "target_format": {
                    "type": "string"
                  }
                },
                "required": [
                  "source_file",
                  "target_format"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Job created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Create new conversion job"
      }
    },
    "/jobs/{id}": {
      "get": {
        "summary": "Retrieve job status",
        "operationId": "getJob",
        "tags": [
          "jobs"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "description": "Retrieve job status"
      }
    },
    "/files/{id}": {
      "get": {
        "summary": "Get file information",
        "operationId": "getFile",
        "tags": [
          "files"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "description": "Get file information"
      },
      "delete": {
        "summary": "Delete file from servers",
        "operationId": "deleteFile",
        "tags": [
          "files"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "File deleted successfully"
          }
        },
        "description": "Delete file from servers"
      }
    },
    "/files/{id}/content": {
      "get": {
        "summary": "Download converted file",
        "operationId": "downloadFile",
        "tags": [
          "files"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        },
        "description": "Download converted file"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  }
}
