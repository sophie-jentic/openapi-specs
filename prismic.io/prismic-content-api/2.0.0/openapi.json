{
  "openapi": "3.0.3",
  "info": {
    "title": "Prismic Content API",
    "version": "2.0.0",
    "description": "Prismic Content API for querying headless CMS content. Search documents with filters, retrieve by ID/UID/type, and access repository metadata, refs, tags, and types.",
    "x-jentic-source-url": "https://prismic.io/docs/api",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{repository}.cdn.prismic.io/api/v2",
      "variables": {
        "repository": {
          "default": "your-repo-name",
          "description": "Prismic repository name"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Repository",
      "description": "Repository metadata and refs"
    },
    {
      "name": "Documents",
      "description": "Document search and retrieval"
    },
    {
      "name": "Tags",
      "description": "Document tags"
    },
    {
      "name": "Types",
      "description": "Custom type definitions"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getRepository",
        "summary": "Get repository metadata",
        "description": "Returns repository info including refs, types, tags, languages, bookmarks, and OAuth endpoints. The master ref is required for all document queries.",
        "tags": [
          "Repository"
        ],
        "parameters": [
          {
            "name": "access_token",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Access token for private repos"
          }
        ],
        "responses": {
          "200": {
            "description": "Repository metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Repository"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/documents/search": {
      "get": {
        "operationId": "searchDocuments",
        "summary": "Search documents",
        "description": "Query documents using Prismic's predicate-based filters. Supports filtering, sorting, pagination, field selection, and relationship resolution.",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "name": "ref",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Content ref (version identifier)"
          },
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "URL-encoded predicate filters (e.g. [[at(document.type,\"blog_post\")]])"
          },
          {
            "name": "access_token",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          },
          {
            "name": "after",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Document ID for cursor-based pagination"
          },
          {
            "name": "fetch",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated field paths to include (e.g. blog_post.title,blog_post.body)"
          },
          {
            "name": "fetchLinks",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Fields to fetch from linked documents"
          },
          {
            "name": "graphQuery",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "GraphQuery for granular field selection"
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "*"
            },
            "description": "Language code filter"
          },
          {
            "name": "orderings",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sort order (e.g. [document.first_publication_date desc])"
          },
          {
            "name": "routes",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "URL-encoded route resolver JSON"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/documents/search?q=[[at(document.id,\"{documentId}\")]]": {
      "get": {
        "operationId": "getDocumentById",
        "summary": "Get document by ID",
        "description": "Retrieve a single document by its unique ID using the at(document.id) filter.",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "name": "ref",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "documentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tags": {
      "get": {
        "operationId": "getTags",
        "summary": "List tags",
        "description": "Returns all tags used across documents in the repository.",
        "tags": [
          "Tags"
        ],
        "parameters": [
          {
            "name": "access_token",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tag list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/types": {
      "get": {
        "operationId": "getTypes",
        "summary": "List custom types",
        "description": "Returns all custom types defined in the repository.",
        "tags": [
          "Types"
        ],
        "parameters": [
          {
            "name": "access_token",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Type map",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Repository": {
        "type": "object",
        "properties": {
          "refs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Ref"
            }
          },
          "bookmarks": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "types": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "languages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "oauth_initiate": {
            "type": "string",
            "format": "uri"
          },
          "oauth_token": {
            "type": "string",
            "format": "uri"
          },
          "experiments": {
            "type": "object"
          },
          "integrationFieldsRef": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Ref": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "isMasterRef": {
            "type": "boolean"
          },
          "scheduledAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "results_per_page": {
            "type": "integer"
          },
          "results_size": {
            "type": "integer"
          },
          "total_results_size": {
            "type": "integer"
          },
          "total_pages": {
            "type": "integer"
          },
          "next_page": {
            "type": "string",
            "nullable": true
          },
          "prev_page": {
            "type": "string",
            "nullable": true
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Document"
            }
          }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "uid": {
            "type": "string",
            "nullable": true
          },
          "url": {
            "type": "string",
            "nullable": true
          },
          "type": {
            "type": "string"
          },
          "href": {
            "type": "string",
            "format": "uri"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "first_publication_date": {
            "type": "string",
            "format": "date-time"
          },
          "last_publication_date": {
            "type": "string",
            "format": "date-time"
          },
          "slugs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "linked_documents": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "lang": {
            "type": "string"
          },
          "alternate_languages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "uid": {
                  "type": "string",
                  "nullable": true
                },
                "type": {
                  "type": "string"
                },
                "lang": {
                  "type": "string"
                }
              }
            }
          },
          "data": {
            "type": "object",
            "description": "Document fields and slices"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "accessToken": {
        "type": "apiKey",
        "name": "access_token",
        "in": "query",
        "description": "Repository access token (required for private repos)"
      }
    }
  },
  "security": [
    {
      "accessToken": []
    }
  ]
}
