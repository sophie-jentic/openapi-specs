  "components": {
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object"
          },
          "statusCode": {
            "type": "integer"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "CreateRecordRequest": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object"
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "CreateTokenRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "fungible",
              "nft"
            ]
          }
        }
      },
      "CreateWalletRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "chain": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "statusCode": {
            "type": "integer"
          },
          "success": {
            "type": "boolean",
            "enum": [
              false
            ]
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key generated via Layer4 web app"
