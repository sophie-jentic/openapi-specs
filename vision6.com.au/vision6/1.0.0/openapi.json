              "unsubscribeContact"
            ]
          },
          "params": {
            "type": "array",
            "description": "[api_key, list_id, contact_id_or_email]"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "AddListRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string",
            "enum": [
              "addList"
            ]
          },
          "params": {
            "type": "array",
            "description": "[api_key, list_array]"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "SearchRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string"
          },
          "params": {
            "type": "array",
            "description": "[api_key, search_array, limit, offset]"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "SendTransactionalEmailRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string",
            "enum": [
              "sendTransactionalEmail"
            ]
          },
          "params": {
            "type": "array",
            "description": "[api_key, list_id, message_id, contact_id_or_email]"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "SendTransactionalMessageRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string",
            "enum": [
              "sendTransactionalMessage"
            ]
          },
          "params": {
            "type": "array",
            "description": "[api_key, list_id, message_id, contact_id_or_mobile]"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "ContactsResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object"
          },
          "error": {
            "$ref": "#/components/schemas/RpcError"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "ListResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object"
          },
          "error": {
            "$ref": "#/components/schemas/RpcError"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "TransactionalResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object"
          },
          "error": {
            "$ref": "#/components/schemas/RpcError"
          },
          "id": {
