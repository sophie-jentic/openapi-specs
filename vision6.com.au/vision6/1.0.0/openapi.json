  "components": {
    "securitySchemes": {
      "apiKeyParam": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Api-Key",
        "description": "Vision6 API key passed in request body as the first parameter"
      }
    },
    "schemas": {
      "JsonRpcRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string",
            "description": "JSON-RPC method name"
          },
          "params": {
            "type": "array",
            "description": "Method parameters array starting with API key"
          },
          "id": {
            "type": "integer",
            "description": "Request ID"
          }
        }
      },
      "JsonRpcResponse": {
        "type": "object",
        "properties": {
          "result": {
            "description": "Method result"
          },
          "error": {
            "$ref": "#/components/schemas/RpcError"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "RpcError": {
        "type": "object",
        "nullable": true,
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "BaseRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string"
          },
          "params": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "First element is the API key"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "AddContactsRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string",
            "enum": [
              "addContacts"
            ]
          },
          "params": {
            "type": "array",
            "description": "[api_key, list_id, contacts_array]"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "SearchContactsRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string",
            "enum": [
              "searchContacts"
            ]
          },
          "params": {
            "type": "array",
            "description": "[api_key, list_id, search_array, limit, offset]"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "EditContactsRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string",
            "enum": [
              "editContacts"
            ]
          },
          "params": {
            "type": "array",
            "description": "[api_key, list_id, contacts_array]"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "DeleteContactsRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string",
            "enum": [
              "deleteContacts"
            ]
          },
          "params": {
            "type": "array",
            "description": "[api_key, list_id, contact_ids_array]"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "GetByIdRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string"
          },
          "params": {
            "type": "array",
            "description": "[api_key, list_id, id]"
          },
          "id": {
            "type": "integer"
          }
        }
      },
      "UnsubscribeRequest": {
        "type": "object",
        "required": [
          "method",
          "params"
        ],
        "properties": {
          "method": {
            "type": "string",
