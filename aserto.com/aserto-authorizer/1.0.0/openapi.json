        ],
        "operationId": "checkRelation",
        "summary": "Check if a relation exists",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "object_type": {
                    "type": "string"
                  },
                  "object_id": {
                    "type": "string"
                  },
