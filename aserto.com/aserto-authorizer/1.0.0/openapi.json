        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a specific relation"
      },
      "post": {
        "tags": [
          "Directory"
        ],
        "operationId": "setRelation",
        "summary": "Create or update a relation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
