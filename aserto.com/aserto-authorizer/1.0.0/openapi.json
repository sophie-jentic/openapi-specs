  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "IsRequest": {
        "type": "object",
        "properties": {
          "identity_context": {
            "type": "object",
            "properties": {
              "identity": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "IDENTITY_TYPE_NONE",
                  "IDENTITY_TYPE_SUB",
                  "IDENTITY_TYPE_JWT",
                  "IDENTITY_TYPE_MANUAL"
                ]
              }
            }
          },
          "policy_context": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "decisions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "resource_context": {
            "type": "object"
          }
        }
      }
    }
  }
}
