{
  "openapi": "3.0.3",
  "info": {
    "title": "Aserto Authorizer API",
    "version": "1.0.0",
    "description": "Aserto authorization API based on Topaz/OPA. Provides fine-grained authorization decisions, policy management, and directory services.",
    "x-jentic-source-url": "https://docs.aserto.com/docs/overview/introduction",
    "contact": {
      "name": "Aserto",
      "url": "https://www.aserto.com"
    }
  },
  "servers": [
    {
      "url": "https://authorizer.prod.aserto.com",
      "description": "Aserto Authorizer"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authorization",
      "description": "Authorization decision endpoints"
    },
    {
      "name": "Directory",
      "description": "Directory object and relation management"
    },
    {
      "name": "Policy",
      "description": "Policy management"
    }
  ],
  "paths": {
    "/api/v2/authz/is": {
      "post": {
        "tags": [
          "Authorization"
        ],
        "operationId": "is",
        "summary": "Authorization decision",
        "description": "Evaluate an authorization decision for a given identity, resource, and policy.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/v2/authz/decisiontree": {
      "post": {
        "tags": [
          "Authorization"
        ],
        "operationId": "decisionTree",
        "summary": "Get decision tree",
        "description": "Evaluate multiple authorization decisions and return the full decision tree.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/v2/authz/query": {
      "post": {
        "tags": [
          "Authorization"
        ],
        "operationId": "query",
        "summary": "Query policies",
        "description": "Execute a policy query using OPA/Rego.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "input": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/v2/policies": {
      "get": {
        "tags": [
          "Policy"
        ],
        "operationId": "listPolicies",
        "summary": "List policies",
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List policies"
      }
    },
    "/api/v2/policies/{id}": {
      "get": {
        "tags": [
          "Policy"
        ],
        "operationId": "getPolicy",
        "summary": "Get a policy",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        },
        "description": "Get a policy"
      }
    },
    "/api/v3/directory/objects": {
      "get": {
        "tags": [
          "Directory"
        ],
        "operationId": "listObjects",
        "summary": "List directory objects",
        "parameters": [
          {
            "name": "object_type",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page.size",
