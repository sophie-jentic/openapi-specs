{
  "openapi": "3.0.3",
  "info": {
    "title": "Webull OpenAPI",
    "version": "1.0.0",
    "description": "Webull OpenAPI provides programmatic access to trading, account management, and market data on the Webull platform. Supports stock, options, futures, and crypto trading. Authentication uses app_key and app_secret with HMAC signing.",
    "x-jentic-source-url": "https://developer.webull.com/apis/docs/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://api.webull.com",
      "description": "Webull API (US)"
    }
  ],
  "paths": {
    "/openapi/account/list": {
      "get": {
        "operationId": "getAccountList",
        "summary": "Get account list",
        "description": "Query the account list and return account information. Rate limit: 10 requests every 30 seconds.",
        "tags": [
          "Accounts"
        ],
        "responses": {
          "200": {
            "description": "Account list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Account"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/openapi/assets/balance": {
      "get": {
        "operationId": "getAccountBalance",
        "summary": "Get account balance",
        "description": "Query account details by account ID. Rate limit: 2 requests every 2 seconds.",
        "tags": [
          "Accounts"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Account balance",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountBalance"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/openapi/assets/positions": {
      "get": {
        "operationId": "getAccountPositions",
        "summary": "Get account positions",
        "description": "Query positions according to the account ID. Rate limit: 2 requests every 2 seconds.",
        "tags": [
          "Accounts"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Positions list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Position"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/openapi/trade/order/place": {
      "post": {
        "operationId": "placeOrder",
        "summary": "Place an order",
        "description": "Submit a new order for stocks, options, or other instruments.",
        "tags": [
          "Trading"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order placed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/openapi/trade/order/cancel": {
      "post": {
        "operationId": "cancelOrder",
        "summary": "Cancel an order",
        "description": "Cancel a pending order.",
        "tags": [
          "Trading"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "account_id",
                  "order_id"
                ],
                "properties": {
                  "account_id": {
                    "type": "string"
                  },
                  "order_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order cancelled"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/openapi/trade/order/replace": {
      "post": {
        "operationId": "replaceOrder",
        "summary": "Replace/modify an order",
        "tags": [
          "Trading"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReplaceOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order replaced"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Replace/modify an order"
      }
    },
    "/openapi/trade/order/list": {
      "get": {
        "operationId": "getOrderList",
        "summary": "Get order list",
        "description": "Query order history for an account.",
        "tags": [
          "Trading"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "Pending",
                "Cancelled",
                "Filled",
                "Failed",
                "PartialFilled"
              ]
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "last_order_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Order"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/openapi/trade/order/detail": {
      "get": {
        "operationId": "getOrderDetail",
        "summary": "Get order detail",
        "tags": [
          "Trading"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get order detail"
      }
    },
    "/openapi/market/history-bar": {
      "get": {
        "operationId": "getHistoryBar",
        "summary": "Get historical bars/candlesticks",
        "description": "Fetch historical OHLCV bar data for a symbol.",
        "tags": [
          "Market Data"
        ],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "US_STOCK",
                "HK_STOCK",
                "CN_STOCK",
                "CRYPTO",
                "FUTURES",
                "OPTIONS"
              ]
            }
          },
          {
            "name": "timespan",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "M1",
                "M5",
                "M15",
                "M30",
                "H1",
                "H2",
                "H4",
                "D1",
                "W1",
                "MN1"
              ]
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 200
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Historical bars",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Bar"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/openapi/market/batch-history-bar": {
      "get": {
        "operationId": "getBatchHistoryBar",
        "summary": "Get batch historical bars",
        "description": "Fetch historical bars for multiple symbols.",
        "tags": [
          "Market Data"
        ],
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated symbols"
          },
          {
            "name": "category",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timespan",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Batch historical bars"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/openapi/market/snapshot": {
      "get": {
        "operationId": "getSnapshot",
        "summary": "Get market snapshot/quote",
        "tags": [
          "Market Data"
        ],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Market snapshot",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Snapshot"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get market snapshot/quote"
      }
    },
    "/openapi/market/ticker": {
      "get": {
        "operationId": "getTicker",
        "summary": "Get ticker information",
        "tags": [
          "Market Data"
        ],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ticker info"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get ticker information"
      }
    },
    "/openapi/transfer/list": {
      "get": {
        "operationId": "getTransferList",
        "summary": "Get transfer history",
        "tags": [
          "Transfers"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transfer list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get transfer history"
      }
    }
  },
  "components": {
    "schemas": {
      "Account": {
        "type": "object",
        "properties": {
          "account_id": {
            "type": "string"
          },
          "account_type": {
            "type": "string",
            "enum": [
              "STOCK",
              "OPTIONS",
              "FUTURES",
              "CRYPTO"
            ]
          },
          "currency": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "AccountBalance": {
        "type": "object",
        "properties": {
          "account_id": {
            "type": "string"
          },
          "total_market_value": {
            "type": "string"
          },
          "cash_balance": {
            "type": "string"
          },
          "buying_power": {
            "type": "string"
          },
          "day_profit_loss": {
            "type": "string"
          },
          "unrealized_profit_loss": {
            "type": "string"
          }
        }
      },
      "Position": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "quantity": {
            "type": "string"
          },
          "avg_cost": {
            "type": "string"
          },
          "market_value": {
            "type": "string"
          },
          "unrealized_pnl": {
            "type": "string"
          },
          "side": {
            "type": "string"
          }
        }
      },
      "PlaceOrderRequest": {
        "type": "object",
        "required": [
          "account_id",
          "symbol",
          "side",
          "order_type",
          "qty"
        ],
        "properties": {
          "account_id": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "side": {
            "type": "string",
            "enum": [
              "BUY",
              "SELL"
            ]
          },
          "order_type": {
            "type": "string",
            "enum": [
              "MARKET",
              "LIMIT",
              "STOP",
              "STOP_LIMIT"
            ]
          },
          "qty": {
            "type": "string"
          },
          "price": {
            "type": "string"
          },
          "stop_price": {
            "type": "string"
          },
          "time_in_force": {
            "type": "string",
            "enum": [
              "DAY",
              "GTC",
              "IOC",
              "FOK"
            ]
          },
          "extended_hours": {
            "type": "boolean"
          }
        }
      },
      "ReplaceOrderRequest": {
        "type": "object",
        "required": [
          "account_id",
          "order_id"
        ],
        "properties": {
          "account_id": {
            "type": "string"
          },
          "order_id": {
            "type": "string"
          },
          "qty": {
            "type": "string"
          },
          "price": {
            "type": "string"
          },
          "stop_price": {
            "type": "string"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "order_id": {
            "type": "string"
          },
          "account_id": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "side": {
            "type": "string"
          },
          "order_type": {
            "type": "string"
          },
          "qty": {
            "type": "string"
          },
          "filled_qty": {
            "type": "string"
          },
          "price": {
            "type": "string"
          },
          "avg_fill_price": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "time_in_force": {
            "type": "string"
          },
          "created_time": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "order_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Bar": {
        "type": "object",
        "properties": {
          "time": {
            "type": "string"
          },
          "open": {
            "type": "string"
          },
          "high": {
            "type": "string"
          },
          "low": {
            "type": "string"
          },
          "close": {
            "type": "string"
          },
          "volume": {
            "type": "string"
          }
        }
      },
      "Snapshot": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "last_price": {
            "type": "string"
          },
          "open": {
            "type": "string"
          },
          "high": {
            "type": "string"
          },
          "low": {
            "type": "string"
          },
          "close": {
            "type": "string"
          },
          "volume": {
            "type": "string"
          },
          "change": {
            "type": "string"
          },
          "change_percent": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "appKeyAuth": {
        "type": "apiKey",
        "name": "app_key",
        "in": "header",
        "description": "Webull app key"
      },
      "signatureAuth": {
        "type": "apiKey",
        "name": "sign",
        "in": "header",
        "description": "HMAC signature using app_secret"
      }
    }
  },
  "security": [
    {
      "appKeyAuth": [],
      "signatureAuth": []
    }
  ],
  "tags": [
    {
      "name": "Accounts"
    },
    {
      "name": "Market Data"
    },
    {
      "name": "Trading"
    },
    {
      "name": "Transfers"
    }
  ]
}
