{
  "openapi": "3.0.3",
  "info": {
    "title": "Adopt-a-Pet.com Pet List API",
    "description": "The Adopt-a-Pet.com Pet List API allows partners and shelters to retrieve pet listing data from Adopt-a-Pet.com, including available pets, shelter/rescue information, and search functionality. Authentication is required via an API key provided by Adopt-a-Pet.com.",
    "version": "1.0.0",
    "contact": {
      "name": "Adopt-a-Pet.com",
      "url": "https://www.adoptapet.com"
    }
  },
  "servers": [
    {
      "url": "https://api.adoptapet.com/search",
      "description": "Adopt-a-Pet.com API server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/pet_search": {
      "get": {
        "operationId": "searchPets",
        "summary": "Search for adoptable pets",
        "description": "Search for adoptable pets based on various criteria such as species, breed, location, age, and size.",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "v",
            "in": "query",
            "required": true,
            "description": "API version",
            "schema": {
              "type": "string",
              "default": "3"
            }
          },
          {
            "name": "output",
            "in": "query",
            "required": false,
            "description": "Output format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml"
              ],
              "default": "json"
            }
          },
          {
            "name": "species",
            "in": "query",
            "required": false,
            "description": "Species of pet to search for",
            "schema": {
              "type": "string",
              "enum": [
                "dog",
                "cat",
                "rabbit",
                "bird",
                "horse",
                "reptile",
                "small_animal",
                "barnyard",
                "pig"
              ]
            }
          },
          {
            "name": "breed_id",
            "in": "query",
            "required": false,
            "description": "Breed ID to filter by",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "city_or_zip",
            "in": "query",
            "required": false,
            "description": "City name or ZIP code for location-based search",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "geo_range",
            "in": "query",
            "required": false,
            "description": "Search radius in miles from the specified location",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "sex",
            "in": "query",
            "required": false,
            "description": "Sex of pet",
            "schema": {
              "type": "string",
              "enum": [
                "m",
                "f"
              ]
            }
          },
          {
            "name": "age",
            "in": "query",
            "required": false,
            "description": "Age category of pet",
            "schema": {
              "type": "string",
              "enum": [
                "baby",
                "young",
                "adult",
                "senior"
              ]
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "description": "Size category of pet",
            "schema": {
              "type": "string",
              "enum": [
                "s",
                "m",
                "l",
                "xl"
              ]
            }
          },
          {
            "name": "color_id",
            "in": "query",
            "required": false,
            "description": "Color ID to filter by",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "start_number",
            "in": "query",
            "required": false,
            "description": "Starting record number for pagination",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "end_number",
            "in": "query",
            "required": false,
            "description": "Ending record number for pagination",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PetSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        },
        "tags": [
          "pet_search"
        ]
      }
    },
    "/pet_details": {
      "get": {
        "operationId": "getPetDetails",
        "summary": "Get details for a specific pet",
        "description": "Retrieve detailed information about a specific adoptable pet by its ID.",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "v",
            "in": "query",
            "required": true,
            "description": "API version",
            "schema": {
              "type": "string",
              "default": "3"
            }
          },
          {
            "name": "output",
            "in": "query",
            "required": false,
            "description": "Output format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml"
              ],
              "default": "json"
            }
          },
          {
            "name": "pet_id",
            "in": "query",
            "required": true,
            "description": "The unique ID of the pet",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful pet details response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PetDetailsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          },
          "404": {
            "description": "Pet not found"
          }
        },
        "tags": [
          "pet_details"
        ]
      }
    },
    "/pet_list": {
      "get": {
        "operationId": "getPetList",
        "summary": "Get pet listings for a shelter or rescue",
        "description": "Retrieve a list of pets available at a specific shelter or rescue organization.",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "v",
            "in": "query",
            "required": true,
            "description": "API version",
            "schema": {
              "type": "string",
              "default": "3"
            }
          },
          {
            "name": "output",
            "in": "query",
            "required": false,
            "description": "Output format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "xml"
              ],
              "default": "json"
            }
          },
          {
            "name": "shelter_id",
            "in": "query",
            "required": true,
            "description": "The unique ID of the shelter or rescue",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "species",
            "in": "query",
            "required": false,
            "description": "Filter by species",
            "schema": {
              "type": "string",
              "enum": [
                "dog",
                "cat",
                "rabbit",
                "bird",
                "horse",
                "reptile",
                "small_animal",
                "barnyard",
                "pig"
              ]
            }
          },
          {
            "name": "start_number",
            "in": "query",
            "required": false,
            "description": "Starting record number for pagination",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "end_number",
            "in": "query",
            "required": false,
            "description": "Ending record number for pagination",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful pet list response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PetListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          },
          "404": {
            "description": "Shelter not found"
          }
        },
        "tags": [
          "pet_list"
        ]
      }
    },
    "/shelter_list": {
      "get": {
        "operationId": "getShelterList",
