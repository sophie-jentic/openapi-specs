                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        },
        "tags": [
          "breed_list"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key provided by Adopt-a-Pet.com"
      }
    },
    "schemas": {
      "Pet": {
        "type": "object",
        "properties": {
          "pet_id": {
            "type": "integer",
            "description": "Unique pet identifier"
          },
          "pet_name": {
            "type": "string",
            "description": "Name of the pet"
          },
          "species": {
            "type": "string",
            "description": "Species (e.g., dog, cat)"
          },
          "primary_breed": {
            "type": "string",
            "description": "Primary breed"
          },
          "secondary_breed": {
            "type": "string",
            "description": "Secondary breed, if mixed"
          },
          "sex": {
            "type": "string",
            "description": "Sex of the pet"
          },
          "age": {
            "type": "string",
            "description": "Age category"
          },
          "size": {
            "type": "string",
            "description": "Size category"
          },
          "color": {
            "type": "string",
            "description": "Color of the pet"
          },
          "description": {
            "type": "string",
            "description": "Description of the pet"
          },
          "photo_url": {
            "type": "string",
            "description": "URL to primary photo"
          },
          "pet_details_url": {
            "type": "string",
            "description": "URL to the pet's listing page"
          },
          "shelter_id": {
            "type": "integer",
            "description": "ID of the shelter housing this pet"
          },
          "shelter_name": {
            "type": "string",
            "description": "Name of the shelter"
          },
          "addr_city": {
            "type": "string",
            "description": "City of the shelter"
          },
          "addr_state_code": {
            "type": "string",
            "description": "State code of the shelter"
          },
          "addr_zip": {
            "type": "string",
            "description": "ZIP code of the shelter"
          },
          "photos": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of photo URLs"
          },
          "act_quickly": {
            "type": "boolean",
            "description": "Whether the pet needs to be adopted quickly"
          },
          "special_needs": {
            "type": "boolean",
            "description": "Whether the pet has special needs"
          },
          "purebred": {
            "type": "boolean",
            "description": "Whether the pet is purebred"
          },
          "good_with_kids": {
            "type": "string",
            "description": "Whether the pet is good with kids"
          },
          "good_with_cats": {
            "type": "string",
            "description": "Whether the pet is good with cats"
          },
          "good_with_dogs": {
            "type": "string",
            "description": "Whether the pet is good with dogs"
          },
          "spayed_neutered": {
            "type": "boolean",
            "description": "Whether the pet is spayed/neutered"
          },
          "housetrained": {
            "type": "boolean",
            "description": "Whether the pet is housetrained"
          }
        }
      },
      "Shelter": {
        "type": "object",
        "properties": {
          "shelter_id": {
            "type": "integer",
            "description": "Unique shelter identifier"
          },
          "shelter_name": {
            "type": "string",
            "description": "Name of the shelter"
          },
          "address": {
            "type": "string",
            "description": "Street address"
          },
          "city": {
            "type": "string",
            "description": "City"
          },
          "state": {
            "type": "string",
            "description": "State code"
          },
          "zip": {
            "type": "string",
            "description": "ZIP code"
          },
          "phone": {
            "type": "string",
            "description": "Phone number"
          },
          "email": {
            "type": "string",
            "description": "Email address"
          },
          "website": {
            "type": "string",
            "description": "Website URL"
          },
          "latitude": {
            "type": "number",
            "format": "double",
            "description": "Latitude coordinate"
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "description": "Longitude coordinate"
          },
          "total_pets": {
            "type": "integer",
            "description": "Total number of pets at the shelter"
          }
        }
      },
      "Breed": {
        "type": "object",
        "properties": {
          "breed_id": {
            "type": "integer",
            "description": "Unique breed identifier"
          },
          "breed_name": {
            "type": "string",
            "description": "Name of the breed"
          }
        }
      },
      "PetSearchResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Response status"
          },
          "total_results": {
            "type": "integer",
            "description": "Total number of matching results"
          },
          "pets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Pet"
            }
          }
        }
      },
      "PetDetailsResponse": {
        "type": "object",
        "properties": {
          "status": {
