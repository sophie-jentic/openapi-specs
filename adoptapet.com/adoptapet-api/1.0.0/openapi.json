        "responses": {
          "200": {
            "description": "Successful shelter list response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShelterListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        },
        "tags": [
          "shelter_list"
        ]
      }
    },
