          }
        },
        "tags": [
          "shelter_details"
        ]
      }
    },
    "/breed_list": {
      "get": {
        "operationId": "getBreedList",
        "summary": "Get list of breeds",
        "description": "Retrieve a list of breeds for a given species.",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "v",
