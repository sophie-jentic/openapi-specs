      "ShelterListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Response status"
          },
          "total_results": {
            "type": "integer",
            "description": "Total number of matching shelters"
          },
          "shelters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Shelter"
            }
          }
        }
      },
      "ShelterDetailsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Response status"
          },
          "shelter": {
