    "/getTemplateClientPasses": {
      "post": {
        "operationId": "getTemplateClientPasses",
        "tags": [
          "Templates"
        ],
        "summary": "Get card status information for a template",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
