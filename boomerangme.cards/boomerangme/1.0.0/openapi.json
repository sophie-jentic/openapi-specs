  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "x-access-token",
        "description": "Boomerangme API access token"
      }
    },
    "schemas": {
      "TemplateListResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/TemplateListItem"
        }
      },
      "TemplateListItem": {
        "type": "object",
        "properties": {
          "result": {
            "type": "integer"
          },
          "templates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Template"
            }
          }
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "description": "0=stamps, 1=cashback, 2=subscription, 3=coupon, 4=discount, 5=certificate, 6=membership"
          }
        }
      },
      "CreateClientRequest": {
        "type": "object",
        "required": [
          "sName",
          "fName",
          "idTemplate"
        ],
        "properties": {
          "sName": {
            "type": "string",
            "description": "Surname"
          },
          "fName": {
            "type": "string",
            "description": "First name"
          },
          "phone": {
            "type": "integer",
            "description": "Phone number (required if no email)"
          },
          "email": {
            "type": "string",
            "description": "Email (required if no phone)"
          },
          "idTemplate": {
            "type": "integer",
            "description": "Card template ID"
          }
        }
      },
      "CreateClientResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "result": {
              "type": "integer"
            },
            "userID": {
              "type": "integer"
            }
          }
        }
      },
      "SearchClientRequest": {
        "type": "object",
        "required": [
          "idTemplate"
        ],
        "properties": {
          "phone": {
            "type": "integer",
            "description": "Phone number (required if no email)"
          },
          "email": {
            "type": "string",
            "description": "Email (required if no phone)"
          },
          "idTemplate": {
            "type": "integer"
          }
        }
      },
      "ClientIdResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "result": {
              "type": "integer"
            },
            "userID": {
              "type": "integer"
            }
          }
        }
      },
      "UpdateClientRequest": {
        "type": "object",
        "required": [
          "userID",
          "sName",
          "fName",
          "idTemplate"
        ],
        "properties": {
          "userID": {
            "type": "integer"
          },
          "sName": {
            "type": "string"
          },
          "fName": {
            "type": "string"
          },
          "phone": {
            "type": "integer"
          },
          "email": {
            "type": "string"
          },
          "idTemplate": {
            "type": "integer"
          }
        }
      },
      "ResultResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "result": {
              "type": "integer"
            }
          }
        }
      },
      "CreatePassRequest": {
        "type": "object",
        "required": [
          "idTemplate",
          "userID"
        ],
        "properties": {
          "idTemplate": {
            "type": "integer"
          },
          "userID": {
            "type": "integer"
          }
        }
      },
      "CreatePassResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "result": {
              "type": "integer"
            },
            "serialNumber": {
              "type": "string"
            },
            "installURL": {
              "type": "string"
            },
            "installQR": {
              "type": "string"
            }
          }
        }
      },
      "PassSerialRequest": {
        "type": "object",
        "required": [
          "passSerialNumber"
        ],
        "properties": {
          "passSerialNumber": {
            "type": "string"
          }
        }
      },
      "CheckPassByPhoneRequest": {
        "type": "object",
        "required": [
          "idTemplate",
          "phone"
        ],
        "properties": {
          "idTemplate": {
            "type": "integer"
          },
          "phone": {
            "type": "integer"
          }
        }
      },
      "PassInfoResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "result": {
              "type": "integer"
            },
            "type": {
              "type": "string"
            },
            "template": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "installed",
                "deleted",
                "not installed"
              ]
            },
            "serialNumber": {
              "type": "string"
            },
            "maxStamps": {
              "type": "string"
            },
            "activeStamps": {
              "type": "string"
            },
            "totalStamps": {
              "type": "string"
            },
            "unusedRewards": {
              "type": "string"
            },
            "image": {
              "type": "string"
            },
            "rewards": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "amountMoneySpentTotal": {
              "type": "string"
            },
            "currentPersentBonus": {
              "type": "string"
            },
            "amountMoneyBonus": {
              "type": "string"
            }
          }
        }
      },
      "PhoneRequest": {
        "type": "object",
        "required": [
          "phone"
        ],
        "properties": {
          "phone": {
            "type": "integer"
          }
        }
      },
      "EmailRequest": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "ClientPassesResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "result": {
              "type": "integer"
            },
            "sName": {
              "type": "string"
            },
            "fName": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "passes": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/PassSummary"
              }
            }
          }
        }
      },
      "PassSummary": {
        "type": "object",
        "properties": {
          "serialNumber": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "template": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "SendPushRequest": {
        "type": "object",
        "required": [
          "pushSegment",
          "messageText"
        ],
        "properties": {
          "pushSegment": {
            "type": "string",
            "enum": [
              "oneClient",
              "allClients"
            ],
            "description": "oneClient or allClients"
          },
          "passSerialNumber": {
            "type": "string",
            "description": "Required when pushSegment=oneClient"
          },
          "idTemplate": {
            "type": "integer",
            "description": "Required when pushSegment=allClients"
          },
          "messageText": {
            "type": "string",
            "description": "Push notification text. Supports variables like {{clientFName}}"
          },
          "page": {
            "type": "integer",
            "description": "Page number for allClients (10 messages per page)"
          }
        }
      },
      "PushResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "result": {
              "type": "integer"
            },
            "numberOfRowsSelected": {
              "type": "integer"
            }
          }
        }
      },
      "PushHistoryRequest": {
        "type": "object",
        "required": [
          "passSerialNumber"
        ],
        "properties": {
          "passSerialNumber": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "description": "Page number (max 10 per page)"
          }
        }
      },
      "PushHistoryResponse": {
