    "/bestbets/v1/BestBets": {
      "get": {
        "operationId": "getBestBets",
        "summary": "Get best bets",
        "description": "Retrieve best bets (promoted search results) for a given term.",
        "tags": [
          "Search"
        ],
        "servers": [
          {
            "url": "https://webapis.cancer.gov"
          }
        ],
        "parameters": [
          {
            "name": "term",
            "in": "query",
            "description": "Search term",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "url": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
