    "/sitewidesearch/v1/Search": {
      "get": {
        "operationId": "sitewideSearch",
        "summary": "Sitewide search",
        "description": "Search across the cancer.gov website content.",
        "tags": [
          "Search"
        ],
        "servers": [
          {
            "url": "https://webapis.cancer.gov"
          }
        ],
        "parameters": [
          {
