  "components": {
    "schemas": {
      "TrialSearchResponse": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "trials": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Trial"
            }
          }
        }
      },
      "Trial": {
        "type": "object",
        "properties": {
          "nci_id": {
            "type": "string"
          },
          "nct_id": {
            "type": "string"
          },
          "brief_title": {
            "type": "string"
          },
          "official_title": {
            "type": "string"
          },
          "brief_summary": {
            "type": "string"
          },
          "current_trial_status": {
            "type": "string"
          },
          "phase": {
            "type": "object",
            "properties": {
              "phase": {
                "type": "string"
              }
            }
          },
          "principal_investigator": {
            "type": "string"
          }
        }
      },
      "GlossaryResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "totalResults": {
                "type": "integer"
              },
              "from": {
                "type": "integer"
              }
            }
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "termId": {
                  "type": "integer"
                },
                "termName": {
                  "type": "string"
                },
                "definition": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "DrugDictionaryResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "totalResults": {
                "type": "integer"
              },
              "from": {
                "type": "integer"
              }
            }
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "termId": {
                  "type": "integer"
                },
                "name": {
                  "type": "string"
                },
                "definition": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "SearchResultsResponse": {
        "type": "object",
        "properties": {
          "totalResults": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "API key for authentication"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Clinical Trials"
    },
    {
      "name": "Drug Dictionary"
    },
    {
      "name": "Glossary"
    },
    {
      "name": "R4R"
    },
    {
      "name": "Search"
    }
  ]
}
