{
  "openapi": "3.0.3",
  "info": {
    "title": "Tookan API",
    "version": "1.0.0",
    "description": "Tookan is a delivery management and logistics platform. The API provides access to tasks, agents, customers, and delivery operations.",
    "x-jentic-source-url": "http://docs.tookanapiv1.apiary.io/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.tookanapp.com/v2"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/create_task": {
      "post": {
        "summary": "Create Task",
        "description": "Create a new delivery or pickup task",
        "operationId": "createTask",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/get_task_details": {
      "post": {
        "summary": "Get Task Details",
        "description": "Retrieve details of a specific task",
        "operationId": "getTaskDetails",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "job_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/get_job_list": {
      "post": {
        "summary": "List Tasks",
        "description": "Retrieve a list of tasks",
        "operationId": "listTasks",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "requested_page": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Task"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/update_task": {
      "post": {
        "summary": "Update Task",
        "description": "Update an existing task",
        "operationId": "updateTask",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      }
    },
    "/delete_task": {
      "post": {
        "summary": "Delete Task",
        "description": "Delete a task",
        "operationId": "deleteTask",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "job_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Task deleted"
          }
        }
      }
    },
    "/add_agent": {
      "post": {
        "summary": "Create Agent",
        "description": "Create a new delivery agent",
        "operationId": "createAgent",
        "tags": [
          "Agents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Agent created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            }
          }
        }
      }
    },
    "/view_all_agents": {
      "post": {
        "summary": "List Agents",
        "description": "Retrieve a list of agents",
        "operationId": "listAgents",
        "tags": [
          "Agents"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Agent"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/edit_agent": {
      "post": {
        "summary": "Update Agent",
        "description": "Update an agent's details",
        "operationId": "updateAgent",
        "tags": [
          "Agents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            }
          }
        }
      }
    },
    "/get_agent_location": {
      "post": {
        "summary": "Get Agent Location",
        "description": "Get real-time location of an agent",
        "operationId": "getAgentLocation",
        "tags": [
          "Agents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fleet_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Location"
                }
              }
            }
          }
        }
      }
    },
    "/add_customer": {
      "post": {
        "summary": "Create Customer",
        "description": "Create a new customer",
        "operationId": "createCustomer",
        "tags": [
          "Customers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomerRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Customer created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Customer"
                }
              }
            }
          }
        }
      }
    },
    "/get_customers": {
      "post": {
        "summary": "List Customers",
        "description": "Retrieve a list of customers",
        "operationId": "listCustomers",
        "tags": [
          "Customers"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Customer"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "api_key",
        "description": "API key authentication"
      }
    },
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "string"
          },
          "job_status": {
            "type": "integer"
          },
          "job_address": {
            "type": "string"
          },
          "job_description": {
            "type": "string"
          },
          "job_type": {
            "type": "integer"
          },
          "customer_email": {
            "type": "string"
          },
          "customer_phone": {
            "type": "string"
          },
          "fleet_id": {
            "type": "string"
          }
        }
      },
      "TaskRequest": {
        "type": "object",
        "required": [
          "job_address",
          "customer_email",
          "job_type"
        ],
        "properties": {
          "job_address": {
            "type": "string"
          },
          "customer_email": {
            "type": "string"
          },
          "customer_phone": {
            "type": "string"
          },
          "customer_username": {
            "type": "string"
          },
          "job_description": {
            "type": "string"
          },
          "job_type": {
            "type": "integer"
          }
        }
      },
      "TaskUpdateRequest": {
        "type": "object",
        "required": [
          "job_id"
        ],
        "properties": {
          "job_id": {
            "type": "string"
          },
          "job_address": {
            "type": "string"
          },
          "job_description": {
            "type": "string"
          }
        }
      },
      "Agent": {
        "type": "object",
        "properties": {
          "fleet_id": {
            "type": "string"
          },
          "fleet_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          }
        }
      },
      "AgentRequest": {
        "type": "object",
        "required": [
          "fleet_name",
          "phone",
          "email"
        ],
        "properties": {
          "fleet_name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "AgentUpdateRequest": {
        "type": "object",
        "required": [
          "fleet_id"
        ],
        "properties": {
          "fleet_id": {
            "type": "string"
          },
          "fleet_name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "CustomerRequest": {
        "type": "object",
        "required": [
          "name",
          "email",
          "phone"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "ErrorResponse": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Tasks",
      "description": "Delivery task management"
    },
    {
      "name": "Agents",
      "description": "Delivery agent management"
    },
    {
      "name": "Customers",
      "description": "Customer management"
    }
  ]
}
