{
  "openapi": "3.0.3",
  "info": {
    "title": "Keep'em API",
    "version": "1.0.0",
    "description": "Keep'em API for managing event registrations and viewer identification.",
    "x-jentic-source-url": "https://keepem.io/docs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.keepem.io/v1"
    }
  ],
  "paths": {
    "/events/{eventID}/register": {
      "post": {
        "operationId": "registerForEvent",
        "summary": "Register for event",
        "description": "Register a viewer for an event.",
        "tags": [
          "Events"
        ],
        "parameters": [
          {
            "name": "eventID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/events/{eventID}/identify": {
      "post": {
        "operationId": "identifyViewer",
        "summary": "Identify viewer",
        "description": "Identify a viewer with custom attributes.",
        "tags": [
          "Events"
        ],
        "parameters": [
          {
            "name": "eventID",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IdentifyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IdentifyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "external_id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "RegisterResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "viewer": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "external_id": {
                "type": "string"
              }
            }
          }
        }
      },
      "IdentifyRequest": {
        "type": "object",
        "properties": {
          "external_id": {
            "type": "string"
          },
          "attributes": {
            "type": "object"
          }
        }
      },
      "IdentifyResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "registered": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Secret API key (sk_live_*)."
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Events"
    }
  ]
}
