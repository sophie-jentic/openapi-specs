                    "type": "string"
                  },
                  "status": {
                    "type": "integer",
                    "enum": [
                      0,
                      1,
                      2,
                      3
                    ],
                    "description": "0=Active, 1=Done, 2=Archive, 3=Closed"
                  },
                  "severity": {
                    "type": "integer",
                    "enum": [
                      0,
                      1,
                      2,
                      3,
                      4
                    ]
                  },
                  "owner": {
                    "type": "string"
                  },
