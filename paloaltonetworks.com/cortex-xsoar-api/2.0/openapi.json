  "components": {
    "schemas": {
      "Incident": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "description": "0=Active, 1=Done, 2=Archive, 3=Closed"
          },
          "severity": {
            "type": "integer",
            "description": "0=Unknown, 1=Low, 2=Medium, 3=High, 4=Critical"
          },
          "owner": {
            "type": "string"
          },
          "phase": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "modified": {
            "type": "string",
            "format": "date-time"
          },
