{
  "openapi": "3.0.3",
  "info": {
    "title": "Panopto Public API",
    "version": "1.0.0",
    "description": "Panopto video platform API for managing remote recorders, sessions, live monitoring, and authentication.",
    "x-jentic-source-url": "http://demo.hosted.panopto.com/Panopto/api/docs/index.html",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://{server}/Panopto",
      "variables": {
        "server": {
          "default": "demo.hosted.panopto.com",
          "description": "Panopto server hostname"
        }
      }
    }
  ],
  "paths": {
    "/api/v1/auth/legacyLogin": {
      "post": {
        "operationId": "legacyLogin",
        "summary": "Legacy login authentication",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Legacy login authentication"
      }
    },
    "/api/v1/remoteRecorderAPI/remoteRecorder": {
      "post": {
        "operationId": "registerRemoteRecorder",
        "summary": "Register remote recorder",
        "tags": [
          "Remote Recorder"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recorder registered"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Register remote recorder"
      }
    },
    "/api/v1/remoteRecorderAPI/remoteRecorder/{remoteRecorderPublicId}/connect": {
      "post": {
        "operationId": "connectRemoteRecorder",
        "summary": "Connect remote recorder",
        "tags": [
          "Remote Recorder"
        ],
        "parameters": [
          {
            "name": "remoteRecorderPublicId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Connected"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Connect remote recorder"
      }
    },
    "/api/v1/remoteRecorderAPI/remoteRecorder/{remoteRecorderPublicId}/disconnect": {
      "post": {
        "operationId": "disconnectRemoteRecorder",
        "summary": "Disconnect remote recorder",
        "tags": [
          "Remote Recorder"
        ],
        "parameters": [
          {
            "name": "remoteRecorderPublicId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Disconnected"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Disconnect remote recorder"
      }
    },
    "/api/v1/remoteRecorderAPI/remoteRecorder/{remoteRecorderPublicId}/heartbeat": {
      "post": {
        "operationId": "recorderHeartbeat",
        "summary": "Remote recorder heartbeat",
        "tags": [
          "Remote Recorder"
        ],
        "parameters": [
          {
            "name": "remoteRecorderPublicId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Heartbeat received"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Remote recorder heartbeat"
      }
    },
    "/api/v1/remoteRecorderAPI/remoteRecorder/{remoteRecorderPublicId}/schedule": {
      "get": {
        "operationId": "getRecorderSchedule",
        "summary": "Get recorder schedule",
        "tags": [
          "Remote Recorder"
        ],
        "parameters": [
          {
            "name": "remoteRecorderPublicId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Schedule data"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Get recorder schedule"
      }
    },
    "/api/v1/remoteRecorderAPI/session/{sessionId}/pause": {
      "post": {
        "operationId": "pauseSession",
        "summary": "Pause recording session",
        "tags": [
          "Sessions"
        ],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Session paused"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Pause recording session"
      }
    },
    "/api/v1/remoteRecorderAPI/session/{sessionId}/resume": {
      "post": {
        "operationId": "resumeSession",
        "summary": "Resume recording session",
        "tags": [
          "Sessions"
        ],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Session resumed"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "Resume recording session"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication"
    },
    {
      "name": "Remote Recorder"
    },
    {
      "name": "Sessions"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
