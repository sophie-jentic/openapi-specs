{
  "openapi": "3.0.3",
  "info": {
    "title": "WHMCS Client Management API",
    "description": "The WHMCS API allows you to perform operations and actions within WHMCS from external third party and custom code. This includes managing clients, domains, invoices, tickets, orders, and more. All API requests are made via POST to the api.php endpoint with authentication credentials and action parameters.",
    "version": "1.0",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://www.example.com/includes",
      "description": "Replace with your WHMCS installation URL"
    }
  ],
  "paths": {
    "/api.php": {
      "post": {
        "summary": "Execute API Action",
        "description": "Main endpoint for all WHMCS API operations. The 'action' parameter determines which operation to perform.",
        "operationId": "executeAction",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/GetClientsDetailsRequest"
                  },
                  {
                    "$ref": "#/components/schemas/AddClientRequest"
                  },
                  {
                    "$ref": "#/components/schemas/UpdateClientRequest"
                  },
                  {
                    "$ref": "#/components/schemas/GetInvoiceRequest"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "API response",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/GetClientsDetailsResponse"
                    },
                    {
                      "$ref": "#/components/schemas/SuccessResponse"
                    },
                    {
                      "$ref": "#/components/schemas/ErrorResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "api.php"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "BaseRequest": {
        "type": "object",
        "required": [
          "identifier",
          "secret",
          "action"
        ],
        "properties": {
          "identifier": {
            "type": "string",
            "description": "API identifier for authentication"
          },
          "secret": {
            "type": "string",
            "description": "API secret for authentication"
          },
          "action": {
            "type": "string",
            "description": "The API action to perform"
          },
          "responsetype": {
            "type": "string",
            "description": "Response format (json or xml)",
            "enum": [
              "json",
              "xml"
            ],
            "default": "json"
          }
        }
      },
      "GetClientsDetailsRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseRequest"
          },
          {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "GetClientsDetails"
                ]
              },
              "clientid": {
                "type": "integer",
                "description": "The client's ID number. Either clientid or email is required."
              },
              "email": {
                "type": "string",
                "format": "email",
                "description": "Client's email address. Either clientid or email is required."
              },
              "stats": {
                "type": "boolean",
                "description": "Returns additional client statistics",
                "default": false
              }
            }
          }
        ]
      },
      "AddClientRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseRequest"
          },
          {
            "type": "object",
            "required": [
              "firstname",
              "lastname",
              "email",
              "address1",
              "city",
              "state",
              "postcode",
              "country",
              "phonenumber",
              "password2"
            ],
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "AddClient"
                ]
              },
              "firstname": {
                "type": "string"
              },
              "lastname": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              },
              "address1": {
                "type": "string"
              },
              "address2": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "state": {
                "type": "string"
              },
              "postcode": {
                "type": "string"
              },
              "country": {
                "type": "string",
                "description": "2 character ISO country code"
              },
              "phonenumber": {
                "type": "string"
              },
              "password2": {
                "type": "string",
                "format": "password"
              },
              "companyname": {
                "type": "string"
              },
              "currency": {
                "type": "integer",
                "description": "Currency ID"
              }
            }
          }
        ]
      },
      "UpdateClientRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseRequest"
          },
          {
            "type": "object",
            "required": [
              "clientid"
            ],
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "UpdateClient"
                ]
              },
              "clientid": {
                "type": "integer",
                "description": "The client ID to update"
              },
              "firstname": {
                "type": "string"
              },
              "lastname": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              },
              "address1": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "state": {
                "type": "string"
              },
              "postcode": {
                "type": "string"
              },
              "country": {
                "type": "string"
              },
              "phonenumber": {
                "type": "string"
              }
            }
          }
        ]
      },
      "GetInvoiceRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseRequest"
          },
          {
            "type": "object",
            "required": [
              "invoiceid"
            ],
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "GetInvoice"
                ]
              },
              "invoiceid": {
                "type": "integer",
                "description": "The invoice ID to retrieve"
              }
            }
          }
        ]
      },
      "GetClientsDetailsResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "client": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "firstname": {
                "type": "string"
              },
              "lastname": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              },
              "address1": {
                "type": "string"
              },
              "address2": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "state": {
                "type": "string"
              },
              "postcode": {
                "type": "string"
              },
              "country": {
                "type": "string"
              },
              "phonenumber": {
                "type": "string"
              },
              "companyname": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "currency": {
                "type": "string"
              },
              "credit": {
                "type": "string"
              }
            }
          },
          "stats": {
            "type": "object",
            "properties": {
              "numdueinvoices": {
                "type": "integer"
              },
              "dueinvoicesbalance": {
                "type": "string"
              },
              "income": {
                "type": "string"
              },
              "incredit": {
                "type": "string"
              }
            }
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string",
            "enum": [
              "success"
            ]
          },
          "clientid": {
            "type": "integer",
            "description": "Returned for client creation/update operations"
          },
          "message": {
            "type": "string",
            "description": "Success message"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "message": {
            "type": "string",
            "description": "Error description"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "api.php"
    }
  ]
}
