{
  "openapi": "3.0.3",
  "info": {
    "title": "WHMCS API",
    "version": "1.0.0",
    "description": "WHMCS (Web Host Manager Complete Solution) API allows you to programmatically manage clients, orders, invoices, support tickets, products, domains, and more. All requests are made via POST to a single endpoint with an action parameter.",
    "x-jentic-source-url": "https://developers.whmcs.com/api-reference/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{your_whmcs_domain}/includes",
      "description": "Your WHMCS installation",
      "variables": {
        "your_whmcs_domain": {
          "default": "example.com/whmcs",
          "description": "Your WHMCS installation domain and path"
        }
      }
    }
  ],
  "security": [
    {
      "apiCredentials": []
    }
  ],
  "paths": {
    "/api.php": {
      "post": {
        "operationId": "whmcsApiCall",
        "summary": "WHMCS API endpoint",
        "description": "All WHMCS API calls are made via POST to this endpoint with the 'action' parameter specifying which action to perform. API credentials (identifier + secret) or username + password are required. Available actions include AddClient, GetClients, UpdateClient, DeleteClient, AddOrder, GetOrders, AcceptOrder, CancelOrder, AddInvoicePayment, GetInvoices, CreateInvoice, OpenTicket, GetTickets, GetTicket, AddTicketReply, ValidateLogin, SendEmail, GetStats, and many more.",
        "tags": [
          "WHMCS API"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/ApiRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "API response (always 200; check 'result' field for success/error)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiCredentials": {
        "type": "apiKey",
        "in": "header",
        "name": "identifier",
        "description": "WHMCS API Credentials. Pass 'identifier' and 'secret' fields in the request body along with 'accesskey' (optional). Alternatively, use 'username' and 'password' with MD5 or API token authentication."
      }
    },
    "schemas": {
      "ApiRequest": {
        "type": "object",
        "required": [
          "identifier",
          "secret",
          "action",
          "responsetype"
        ],
        "properties": {
          "identifier": {
            "type": "string",
            "description": "API Credential Identifier (from WHMCS Admin > Setup > API Credentials)"
          },
          "secret": {
            "type": "string",
            "description": "API Credential Secret"
          },
          "accesskey": {
            "type": "string",
            "description": "Optional server-side access key for additional security"
          },
          "action": {
            "type": "string",
            "description": "The API action to perform (e.g., AddClient, GetClients, AddOrder, etc.)",
            "example": "GetClients"
          },
          "responsetype": {
            "type": "string",
            "enum": [
              "json",
              "xml"
            ],
            "default": "json",
            "description": "Response format"
          },
          "limitstart": {
            "type": "integer",
            "default": 0,
            "description": "Record offset (for paginated results)"
          },
          "limitnum": {
            "type": "integer",
            "default": 25,
            "description": "Number of records to return"
          }
        },
        "additionalProperties": {
          "type": "string",
          "description": "Additional action-specific parameters"
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string",
            "enum": [
              "success",
              "error"
            ],
            "description": "Result of the API call"
          },
          "message": {
            "type": "string",
            "description": "Human-readable message (present on error or some success responses)"
          },
          "totalresults": {
            "type": "integer",
            "description": "Total number of results for listing operations"
          },
          "startnumber": {
            "type": "integer",
            "description": "Starting record number"
          }
        },
        "additionalProperties": true
      },
      "ClientsResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string"
          },
          "totalresults": {
            "type": "integer"
          },
          "startnumber": {
            "type": "integer"
          },
          "numreturned": {
            "type": "integer"
          },
          "clients": {
            "type": "object",
            "properties": {
              "client": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          }
        }
      },
      "Client": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "firstname": {
            "type": "string"
          },
          "lastname": {
            "type": "string"
          },
          "companyname": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "address1": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "postcode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "phonenumber": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "currency": {
            "type": "integer"
          },
          "datecreated": {
            "type": "string"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "ordernum": {
            "type": "integer"
          },
          "userid": {
            "type": "integer"
          },
          "date": {
            "type": "string"
          },
          "total": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "paymentmethod": {
            "type": "string"
          }
        }
      },
      "Invoice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "userid": {
            "type": "integer"
          },
          "date": {
            "type": "string"
          },
          "duedate": {
            "type": "string"
          },
          "total": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "paymentmethod": {
            "type": "string"
          }
        }
      },
      "SupportTicket": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "tid": {
            "type": "string"
          },
          "deptid": {
            "type": "integer"
          },
          "userid": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "cc": {
            "type": "string"
          },
          "c": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string",
            "example": "error"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "WHMCS API"
    }
  ]
}
