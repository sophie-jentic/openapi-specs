              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EstimateRequest": {
        "type": "object",
        "properties": {
          "emission_factor": {
            "type": "object",
            "properties": {
              "activity_id": {
                "type": "string",
                "description": "The activity ID of the emission factor"
              },
              "id": {
                "type": "string",
                "description": "UUID of the emission factor"
              },
              "region": {
                "type": "string",
                "description": "Region code"
              },
              "year": {
                "type": "integer",
                "description": "Year of the emission factor"
              },
              "source": {
                "type": "string",
                "description": "Data source"
              },
              "data_version": {
                "type": "string"
              }
            }
          },
          "parameters": {
            "type": "object",
            "properties": {
              "money": {
                "type": "number",
                "description": "Monetary amount"
              },
              "money_unit": {
                "type": "string",
                "description": "Currency code"
              },
              "weight": {
                "type": "number",
                "description": "Weight amount"
              },
              "weight_unit": {
                "type": "string",
                "description": "Weight unit (kg, t, lb)"
              },
              "energy": {
                "type": "number",
                "description": "Energy amount"
              },
              "energy_unit": {
                "type": "string",
                "description": "Energy unit (kWh, MWh)"
              },
              "distance": {
                "type": "number",
                "description": "Distance amount"
              },
              "distance_unit": {
                "type": "string",
                "description": "Distance unit (km, mi)"
              },
              "volume": {
                "type": "number",
                "description": "Volume amount"
              },
              "volume_unit": {
                "type": "string",
                "description": "Volume unit (l, m3)"
              }
            }
          }
        }
      },
      "EstimateResponse": {
        "type": "object",
        "properties": {
          "co2e": {
            "type": "number",
            "description": "CO2 equivalent emissions in kg"
          },
          "co2e_unit": {
            "type": "string",
            "description": "Unit of CO2e (kg)"
          },
          "co2e_calculation_method": {
            "type": "string",
            "description": "Calculation method (ar4, ar5, ar6)"
          },
          "co2": {
            "type": "number",
            "description": "CO2 emissions in kg"
          },
          "ch4": {
            "type": "number",
            "description": "CH4 emissions in kg"
          },
          "n2o": {
            "type": "number",
            "description": "N2O emissions in kg"
          },
          "emission_factor": {
            "$ref": "#/components/schemas/EmissionFactor"
          },
          "constituent_gases": {
            "type": "object",
            "properties": {
              "co2e_total": {
                "type": "number"
              },
              "co2e_other": {
                "type": "number"
              },
              "co2": {
                "type": "number"
              },
              "ch4": {
                "type": "number"
              },
              "n2o": {
                "type": "number"
              }
            }
          }
        }
      },
      "EmissionFactor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "UUID"
          },
          "activity_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          },
          "unit_type": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "factor": {
            "type": "number"
          },
          "factor_calculation_method": {
            "type": "string"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EmissionFactor"
            }
          },
          "current_page": {
            "type": "integer"
          },
          "last_page": {
            "type": "integer"
          },
          "total_results": {
            "type": "integer"
          }
        }
      },
      "TravelRequest": {
        "type": "object",
        "properties": {
          "legs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "from": {
                  "type": "string",
                  "description": "Origin (IATA code or address)"
                },
                "to": {
                  "type": "string",
                  "description": "Destination (IATA code or address)"
                },
                "passengers": {
                  "type": "integer"
                },
                "class": {
                  "type": "string",
                  "enum": [
                    "economy",
                    "premium_economy",
                    "business",
                    "first"
                  ]
                }
              }
            }
          }
        }
      },
      "TravelResponse": {
        "type": "object",
        "properties": {
          "co2e": {
            "type": "number",
            "description": "Total CO2e in kg"
          },
          "co2e_unit": {
            "type": "string"
          },
          "legs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EstimateResponse"
            }
          },
          "distance_km": {
            "type": "number"
          }
        }
      },
      "EnergyRequest": {
        "type": "object",
        "properties": {
          "energy": {
            "type": "number",
            "description": "Energy amount"
          },
          "energy_unit": {
            "type": "string",
            "description": "Energy unit (kWh, MWh, etc.)"
          },
          "region": {
            "type": "string",
            "description": "Region code"
          }
        }
      },
      "FreightRequest": {
        "type": "object",
        "properties": {
          "route": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "from": {
                  "type": "string"
                },
                "to": {
                  "type": "string"
                },
                "transport_mode": {
                  "type": "string",
                  "enum": [
                    "road",
                    "rail",
                    "sea",
                    "air",
                    "inland_waterway"
                  ]
                }
              }
            }
          },
          "cargo": {
            "type": "object",
            "properties": {
              "weight": {
                "type": "number"
              },
              "weight_unit": {
                "type": "string"
              }
            }
          }
        }
      },
      "FreightResponse": {
        "type": "object",
        "properties": {
          "co2e": {
            "type": "number"
          },
          "co2e_unit": {
            "type": "string"
          },
          "legs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EstimateResponse"
            }
          },
          "distance_km": {
            "type": "number"
          }
        }
      },
      "ProcurementRequest": {
        "type": "object",
        "properties": {
          "spend": {
            "type": "number",
            "description": "Amount spent"
          },
          "spend_unit": {
            "type": "string",
            "description": "Currency code"
          },
          "category": {
            "type": "string",
            "description": "Procurement category"
          },
          "region": {
            "type": "string",
            "description": "Region code"
          }
        }
      },
      "Classification": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "AutopilotRequest": {
        "type": "object",
        "properties": {
          "activity_description": {
            "type": "string",
            "description": "Natural language description of the activity"
          },
          "parameters": {
            "type": "object",
            "description": "Activity parameters (amount, unit, etc.)"
          }
        }
      },
      "PcfRequest": {
        "type": "object",
        "properties": {
          "product_description": {
            "type": "string"
          },
          "lifecycle_stages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "stage": {
                  "type": "string"
                },
                "activity_id": {
                  "type": "string"
                },
                "parameters": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "PcfResponse": {
        "type": "object",
        "properties": {
          "co2e": {
            "type": "number",
            "description": "Total product carbon footprint in kg CO2e"
          },
          "co2e_unit": {
            "type": "string"
          },
          "lifecycle_stages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "stage": {
                  "type": "string"
                },
                "co2e": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "error_code": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Pass your API key as a Bearer token."
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Autopilot"
    },
    {
      "name": "Classifications"
    },
    {
      "name": "Energy"
    },
    {
      "name": "Estimates"
    },
    {
      "name": "Freight"
    },
    {
      "name": "PCF"
    },
    {
