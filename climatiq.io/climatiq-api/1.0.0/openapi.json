              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/classifications": {
      "get": {
        "operationId": "listClassifications",
        "summary": "List classifications",
        "description": "Retrieve the list of available emission factor classifications.",
        "tags": [
          "Classifications"
        ],
        "responses": {
          "200": {
            "description": "List of classifications",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Classification"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/autopilot": {
      "post": {
        "operationId": "autopilotEstimate",
        "summary": "Autopilot emission estimate",
        "description": "Automatically match an activity description to the best emission factor and calculate emissions.",
        "tags": [
          "Autopilot"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AutopilotRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Autopilot estimate result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EstimateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/pcf": {
      "post": {
        "operationId": "estimateProductCarbonFootprint",
        "summary": "Product Carbon Footprint",
        "description": "Estimate the product carbon footprint (PCF) based on product details and lifecycle stages.",
        "tags": [
          "PCF"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
