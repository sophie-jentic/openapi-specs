          },
          "buyer_id": {
            "type": "integer"
          },
          "shop_id": {
            "type": "integer"
          },
          "payment_id": {
            "type": "integer"
          },
          "status": {
            "type": "integer"
          },
          "products": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
