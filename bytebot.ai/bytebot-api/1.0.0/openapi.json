{
  "openapi": "3.0.3",
  "info": {
    "title": "Bytebot API",
    "version": "1.0.0",
    "description": "Bytebot is an open-source AI desktop agent. The API provides a unified endpoint for controlling a virtual desktop environment including mouse actions, keyboard input, screenshots, file operations, and application switching. It also provides a data extraction endpoint.",
    "x-jentic-source-url": "https://docs.bytebot.ai/",
    "contact": {}
  },
  "servers": [
    {
      "url": "http://localhost:9990",
      "description": "Bytebot local server"
    }
  ],
  "tags": [
    {
      "name": "Computer Use",
      "description": "Unified computer actions for desktop control"
    },
    {
      "name": "Extract",
      "description": "Data extraction from screen"
    }
  ],
  "paths": {
    "/computer-use/computer": {
      "post": {
        "operationId": "executeComputerAction",
        "tags": [
          "Computer Use"
        ],
        "summary": "Execute a computer action in the virtual desktop",
        "description": "Unified endpoint for all computer actions: move_mouse, trace_mouse, click_mouse, press_mouse, drag_mouse, scroll, type_keys, press_keys, type_text, paste_text, wait, screenshot, cursor_position, application, write_file, read_file.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ComputerActionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Action executed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ComputerActionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/extract": {
      "post": {
        "operationId": "extractData",
        "tags": [
          "Extract"
        ],
        "summary": "Extract structured data from the screen",
        "description": "Takes a screenshot and extracts data based on a provided schema or prompt.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExtractRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Extracted data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExtractResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string"
          }
        }
      },
      "Coordinates": {
        "type": "object",
        "required": [
          "x",
          "y"
        ],
        "properties": {
          "x": {
            "type": "number",
            "description": "X coordinate"
          },
          "y": {
            "type": "number",
            "description": "Y coordinate"
          }
        }
      },
      "ComputerActionRequest": {
        "type": "object",
        "required": [
          "action"
        ],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "move_mouse",
              "trace_mouse",
              "click_mouse",
              "press_mouse",
              "drag_mouse",
              "scroll",
              "type_keys",
              "press_keys",
              "type_text",
              "paste_text",
              "wait",
              "screenshot",
              "cursor_position",
              "application",
              "write_file",
              "read_file"
            ],
            "description": "The action to perform"
          },
          "coordinates": {
            "$ref": "#/components/schemas/Coordinates"
          },
          "path": {
            "oneOf": [
              {
                "type": "string",
                "description": "File path for write_file/read_file"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Coordinates"
                },
                "description": "Array of coordinates for trace_mouse/drag_mouse"
              }
            ]
          },
          "button": {
            "type": "string",
            "enum": [
              "left",
              "right",
              "middle"
            ],
            "description": "Mouse button for click/press/drag actions"
          },
          "clickCount": {
            "type": "integer",
            "description": "Number of clicks for click_mouse"
          },
          "press": {
            "type": "string",
            "enum": [
              "up",
              "down"
            ],
            "description": "Press direction for press_mouse/press_keys"
          },
          "holdKeys": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Keys to hold during mouse actions"
          },
          "direction": {
            "type": "string",
            "enum": [
              "up",
              "down",
              "left",
              "right"
            ],
            "description": "Scroll direction"
          },
          "scrollCount": {
            "type": "integer",
            "description": "Number of scroll steps"
          },
          "keys": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of keys for type_keys/press_keys"
          },
          "delay": {
            "type": "number",
            "description": "Delay in milliseconds between key presses or characters"
          },
          "text": {
            "type": "string",
            "description": "Text string for type_text/paste_text"
          },
          "duration": {
            "type": "number",
            "description": "Wait duration in milliseconds"
          },
          "application": {
            "type": "string",
            "enum": [
              "firefox",
              "1password",
              "thunderbird",
              "vscode",
              "terminal",
              "desktop",
              "directory"
            ],
            "description": "Application to switch to"
          },
          "data": {
            "type": "string",
            "description": "Base64 encoded file content for write_file"
          }
        }
      },
      "ComputerActionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "description": "Response data (varies by action)",
            "properties": {
              "image": {
                "type": "string",
                "description": "Base64 encoded screenshot image (screenshot action)"
              },
              "x": {
                "type": "number",
                "description": "Cursor X position (cursor_position action)"
              },
              "y": {
                "type": "number",
                "description": "Cursor Y position (cursor_position action)"
              }
            }
          },
          "message": {
            "type": "string",
            "description": "Success message (write_file action)"
          },
          "name": {
            "type": "string",
            "description": "File name (read_file action)"
          },
          "size": {
            "type": "integer",
            "description": "File size in bytes (read_file action)"
          },
          "mediaType": {
            "type": "string",
            "description": "MIME type (read_file action)"
          }
        }
      },
      "ExtractRequest": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Natural language description of what to extract"
          },
          "schema": {
            "type": "object",
            "description": "JSON schema defining the expected output structure"
          }
        }
      },
      "ExtractResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "description": "Extracted data matching the requested schema"
          }
        }
      }
    }
  }
}
