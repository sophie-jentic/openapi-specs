              "type": "integer",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of redemptions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RedemptionListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid limit parameter"
          }
        }
      }
    },
    "/v1/redemptions/{id}": {
      "get": {
        "operationId": "getRedemption",
        "summary": "Retrieve a redemption",
