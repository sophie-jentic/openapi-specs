    "/storing/profiles": {
      "get": {
        "tags": [
          "Profiles"
        ],
        "summary": "Find profiles",
        "description": "Search and retrieve profiles with advanced filtering",
        "operationId": "findProfiles",
        "parameters": [
          {
            "name": "source_keys",
            "in": "query",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Array of source keys to search"
          },
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by name"
          },
          {
            "name": "key",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by profile key"
          },
          {
            "name": "reference",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by reference"
          },
          {
            "name": "location_lat",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Location latitude for geo filtering"
          },
          {
            "name": "location_lon",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Location longitude for geo filtering"
          },
          {
            "name": "location_distance",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Distance in km for geo filtering"
          },
          {
            "name": "return_profile",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Include full profile data in response"
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          },
          {
            "$ref": "#/components/parameters/OrderByParam"
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Field to sort by"
          },
          {
            "name": "created_at_min",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Minimum creation date"
          },
          {
            "name": "created_at_max",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Maximum creation date"
          }
        ],
        "responses": {
          "200": {
            "description": "Profiles retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfilesListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
