{
  "openapi": "3.0.3",
  "info": {
    "title": "HotStoks API",
    "version": "1.0.0",
    "description": "HotStoks provides stock market data powered by SQL. The API allows users to query financial data including stock prices, market statistics, and company information using a SQL-like query interface. HotStoks offers real-time and historical stock market data accessible through a simple REST API.",
    "contact": {
      "name": "HotStoks",
      "url": "https://hotstoks.com"
    },
    "x-jentic-source-url": "https://hotstoks.com"
  },
  "servers": [
    {
      "url": "https://api.hotstoks.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Query",
      "description": "SQL-powered data query endpoints"
    },
    {
      "name": "Stocks",
      "description": "Stock market data"
    },
    {
      "name": "Markets",
      "description": "Market overview and statistics"
    }
  ],
  "paths": {
    "/v1/query": {
      "post": {
        "summary": "Execute SQL query",
        "description": "Execute a SQL query against the HotStoks financial database. Supports standard SQL syntax for querying stock prices, company data, and market statistics.",
        "operationId": "executeQuery",
        "tags": [
          "Query"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query executed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid SQL query",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/stocks": {
      "get": {
        "summary": "List stocks",
        "description": "Returns a paginated list of available stocks",
        "operationId": "listStocks",
        "tags": [
          "Stocks"
        ],
        "parameters": [
          {
            "name": "exchange",
            "in": "query",
            "description": "Filter by stock exchange (e.g., NYSE, NASDAQ)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sector",
            "in": "query",
            "description": "Filter by sector",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 1000
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of stocks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StockList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/stocks/{symbol}": {
      "get": {
        "summary": "Get stock details",
        "description": "Returns detailed information for a specific stock symbol",
        "operationId": "getStock",
        "tags": [
          "Stocks"
        ],
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "description": "Stock ticker symbol",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stock details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Stock"
                }
              }
            }
          },
          "404": {
            "description": "Stock not found"
          }
        }
      }
    },
    "/v1/stocks/{symbol}/prices": {
      "get": {
        "summary": "Get stock prices",
        "description": "Returns historical price data for a specific stock",
        "operationId": "getStockPrices",
        "tags": [
          "Stocks"
        ],
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "interval",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "1d",
                "1w",
                "1m"
              ],
              "default": "1d"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Price data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceList"
                }
              }
            }
          },
          "404": {
            "description": "Stock not found"
          }
        }
      }
    },
    "/v1/stocks/{symbol}/quote": {
      "get": {
        "summary": "Get real-time quote",
        "description": "Returns the latest real-time quote for a stock",
        "operationId": "getStockQuote",
        "tags": [
          "Stocks"
        ],
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Real-time quote",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quote"
                }
              }
            }
          },
          "404": {
            "description": "Stock not found"
          }
        }
      }
    },
    "/v1/markets": {
      "get": {
        "summary": "Get market overview",
        "description": "Returns an overview of major market indices and statistics",
        "operationId": "getMarketOverview",
        "tags": [
          "Markets"
        ],
        "responses": {
          "200": {
            "description": "Market overview",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketOverview"
                }
              }
            }
          }
        }
      }
    },
    "/v1/markets/movers": {
      "get": {
        "summary": "Get market movers",
        "description": "Returns top gainers, losers, and most active stocks",
        "operationId": "getMarketMovers",
        "tags": [
          "Markets"
        ],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "gainers",
                "losers",
                "active"
              ],
              "default": "gainers"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Market movers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketMoversList"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tables": {
      "get": {
        "summary": "List available tables",
        "description": "Returns the list of available database tables that can be queried via SQL",
        "operationId": "listTables",
        "tags": [
          "Query"
        ],
        "responses": {
          "200": {
            "description": "List of tables",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TableList"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tables/{table_name}/schema": {
      "get": {
        "summary": "Get table schema",
        "description": "Returns the column definitions for a specific table",
        "operationId": "getTableSchema",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "table_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Table schema",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TableSchema"
                }
              }
            }
          },
          "404": {
            "description": "Table not found"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "QueryRequest": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "SQL query to execute",
            "example": "SELECT symbol, close, volume FROM prices WHERE date = '2024-01-15' ORDER BY volume DESC LIMIT 10"
          },
          "format": {
            "type": "string",
            "enum": [
              "json",
              "csv"
            ],
            "default": "json"
          }
        }
      },
      "QueryResponse": {
        "type": "object",
        "properties": {
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {}
            }
          },
          "row_count": {
            "type": "integer"
          },
          "execution_time_ms": {
            "type": "number"
          }
        }
      },
      "Stock": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "exchange": {
            "type": "string"
          },
          "sector": {
            "type": "string"
          },
          "industry": {
            "type": "string"
          },
          "market_cap": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "StockList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Stock"
            }
          },
          "total": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          }
        }
      },
      "Price": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "open": {
            "type": "number"
          },
          "high": {
            "type": "number"
          },
          "low": {
            "type": "number"
          },
          "close": {
            "type": "number"
          },
          "volume": {
            "type": "integer"
          },
          "adjusted_close": {
            "type": "number"
          }
        }
      },
      "PriceList": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "prices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Price"
            }
          }
        }
      },
      "Quote": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "change": {
            "type": "number"
          },
          "change_percent": {
            "type": "number"
          },
          "volume": {
            "type": "integer"
          },
          "open": {
            "type": "number"
          },
          "high": {
            "type": "number"
          },
          "low": {
            "type": "number"
          },
          "previous_close": {
            "type": "number"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MarketOverview": {
        "type": "object",
        "properties": {
          "indices": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "value": {
                  "type": "number"
                },
                "change": {
                  "type": "number"
                },
                "change_percent": {
                  "type": "number"
                }
              }
            }
          },
          "market_status": {
            "type": "string",
            "enum": [
              "open",
              "closed",
              "pre-market",
              "after-hours"
            ]
          }
        }
      },
      "MarketMoversList": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "movers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "symbol": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "price": {
                  "type": "number"
                },
                "change": {
                  "type": "number"
                },
                "change_percent": {
                  "type": "number"
                },
                "volume": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "TableList": {
        "type": "object",
        "properties": {
          "tables": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "row_count": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "TableSchema": {
        "type": "object",
        "properties": {
          "table_name": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "nullable": {
                  "type": "boolean"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "string"
          }
        }
      }
    }
  }
}
