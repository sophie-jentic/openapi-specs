    "/buckets": {
      "get": {
        "operationId": "listBuckets",
        "summary": "List all buckets",
        "tags": [
          "Buckets"
        ],
        "parameters": [
          {
            "name": "_sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sort field(s)"
          },
          {
            "name": "_limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Max results"
          },
          {
            "name": "_token",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Pagination token"
          },
          {
            "name": "_since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by last_modified timestamp"
          },
          {
            "name": "_before",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter records modified before timestamp"
          }
        ],
        "responses": {
          "200": {
            "description": "List of buckets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Bucket"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "description": "List all buckets"
      },
      "post": {
        "operationId": "createBucket",
        "summary": "Create a new bucket",
        "tags": [
          "Buckets"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "$ref": "#/components/schemas/BucketInput"
                  },
                  "permissions": {
                    "$ref": "#/components/schemas/Permissions"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bucket created",
