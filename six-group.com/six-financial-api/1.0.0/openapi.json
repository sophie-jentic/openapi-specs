            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get current prices"
      }
    },
    "/api/v1/prices/{id}": {
      "get": {
        "operationId": "getPrice",
        "summary": "Get price for instrument",
        "tags": [
          "Pricing"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Price data",
            "content": {
              "application/json": {
                "schema": {
