{
  "openapi": "3.0.0",
  "info": {
    "title": "Tradier Brokerage API",
    "description": "Tradier Brokerage API provides a comprehensive REST API for US-based equities and options trading. Access market data, place trades, manage accounts, and stream real-time data for building trading applications.",
    "version": "1.1.0",
    "contact": {
      "name": "Tradier API Support",
      "url": "https://docs.tradier.com"
    },
    "termsOfService": "https://tradier.com/terms"
  },
  "servers": [
    {
      "url": "https://api.tradier.com/v1",
      "description": "Production server"
    },
    {
      "url": "https://sandbox.tradier.com/v1",
      "description": "Sandbox server for testing"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/user/profile": {
      "get": {
        "summary": "Get User Profile",
        "description": "Retrieve the user's profile information.",
        "operationId": "getUserProfile",
        "tags": ["User Data"],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "profile": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        },
                        "account": {
                          "type": "object",
                          "properties": {
                            "account_number": {
                              "type": "string"
                            },
                            "classification": {
                              "type": "string"
                            },
                            "date_created": {
                              "type": "string",
                              "format": "date-time"
                            },
                            "day_trader": {
                              "type": "boolean"
                            },
                            "option_level": {
                              "type": "integer"
                            },
                            "status": {
                              "type": "string"
                            },
                            "type": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/balances": {
      "get": {
        "summary": "Get Account Balances",
        "description": "Retrieve balance information for a specific account.",
        "operationId": "getAccountBalances",
        "tags": ["Account Data"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account number"
          }
        ],
        "responses": {
          "200": {
            "description": "Account balances",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "balances": {
                      "type": "object",
                      "properties": {
                        "option_short_value": {
                          "type": "number"
                        },
                        "total_equity": {
                          "type": "number"
                        },
                        "account_number": {
                          "type": "string"
                        },
                        "account_type": {
                          "type": "string"
                        },
                        "close_pl": {
                          "type": "number"
                        },
                        "current_requirement": {
                          "type": "number"
                        },
                        "equity": {
                          "type": "number"
                        },
                        "long_market_value": {
                          "type": "number"
                        },
                        "market_value": {
                          "type": "number"
                        },
                        "open_pl": {
                          "type": "number"
                        },
                        "option_long_value": {
                          "type": "number"
                        },
                        "option_requirement": {
                          "type": "number"
                        },
                        "pending_orders_count": {
                          "type": "integer"
                        },
                        "short_market_value": {
                          "type": "number"
                        },
                        "stock_long_value": {
                          "type": "number"
                        },
                        "total_cash": {
                          "type": "number"
                        },
                        "uncleared_funds": {
                          "type": "number"
                        },
                        "pending_cash": {
                          "type": "number"
                        },
                        "margin": {
                          "type": "object",
                          "properties": {
                            "fed_call": {
                              "type": "number"
                            },
                            "maintenance_call": {
                              "type": "number"
                            },
                            "option_buying_power": {
                              "type": "number"
                            },
                            "stock_buying_power": {
                              "type": "number"
                            },
                            "stock_short_value": {
                              "type": "number"
                            },
                            "sweep": {
                              "type": "number"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/positions": {
      "get": {
        "summary": "Get Positions",
        "description": "Retrieve current positions for a specific account.",
        "operationId": "getPositions",
        "tags": ["Account Data"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Account positions"
          }
        }
      }
    },
    "/accounts/{account_id}/history": {
      "get": {
        "summary": "Get Account History",
        "description": "Retrieve account transaction history.",
        "operationId": "getAccountHistory",
        "tags": ["Account Data"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 10000
            }
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["trade", "option", "ach", "wire", "dividend", "fee", "tax", "journal", "check", "transfer", "adjustment", "interest"]
            }
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Account history"
          }
        }
      }
    },
    "/accounts/{account_id}/gainloss": {
      "get": {
        "summary": "Get Gain/Loss",
        "description": "Retrieve cost basis information for a specific account.",
        "operationId": "getGainLoss",
        "tags": ["Account Data"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Gain/loss information"
          }
        }
      }
    },
    "/accounts/{account_id}/orders": {
      "get": {
        "summary": "Get Orders",
        "description": "Retrieve orders for a specific account.",
        "operationId": "getOrders",
        "tags": ["Trading"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "includeTags",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Orders list"
          }
        }
      },
      "post": {
        "summary": "Place Order",
        "description": "Submit an equity or options order to the market.",
        "operationId": "placeOrder",
        "tags": ["Trading"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["class", "symbol", "side", "quantity", "type", "duration"],
                "properties": {
                  "class": {
                    "type": "string",
                    "enum": ["equity", "option", "multileg", "combo"],
                    "description": "Order class"
                  },
                  "symbol": {
                    "type": "string",
                    "description": "Ticker symbol"
                  },
                  "side": {
                    "type": "string",
                    "enum": ["buy", "buy_to_cover", "sell", "sell_short"],
                    "description": "Order side"
                  },
                  "quantity": {
                    "type": "integer",
                    "description": "Number of shares"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["market", "limit", "stop", "stop_limit"],
                    "description": "Order type"
                  },
                  "duration": {
                    "type": "string",
                    "enum": ["day", "gtc", "pre", "post"],
                    "description": "Order duration"
                  },
                  "price": {
                    "type": "number",
                    "description": "Limit price (required for limit and stop_limit orders)"
                  },
                  "stop": {
                    "type": "number",
                    "description": "Stop price (required for stop and stop_limit orders)"
                  },
                  "tag": {
                    "type": "string",
                    "description": "Custom order tag"
                  },
                  "option_symbol": {
                    "type": "string",
                    "description": "OCC option symbol (for option orders)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order placed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer"
                        },
                        "status": {
                          "type": "string"
                        },
                        "partner_id": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/orders/{order_id}": {
      "get": {
        "summary": "Get Order",
        "description": "Retrieve an individual order.",
        "operationId": "getOrder",
        "tags": ["Trading"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "includeTags",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order details"
          }
        }
      },
      "put": {
        "summary": "Modify Order",
        "description": "Modify an existing order.",
        "operationId": "modifyOrder",
        "tags": ["Trading"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["market", "limit", "stop", "stop_limit"]
                  },
                  "duration": {
                    "type": "string",
                    "enum": ["day", "gtc", "pre", "post"]
                  },
                  "price": {
                    "type": "number"
                  },
                  "stop": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order modified successfully"
          }
        }
      },
      "delete": {
        "summary": "Cancel Order",
        "description": "Cancel an existing order.",
        "operationId": "cancelOrder",
        "tags": ["Trading"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order cancelled successfully"
          }
        }
      }
    },
    "/markets/quotes": {
      "get": {
        "summary": "Get Quotes",
        "description": "Get real-time or delayed quotes for one or more symbols.",
        "operationId": "getQuotes",
        "tags": ["Market Data"],
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of symbols (e.g., 'AAPL,MSFT,SPY')"
          },
          {
            "name": "greeks",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include option greeks (for options)"
          }
        ],
        "responses": {
          "200": {
            "description": "Quote data"
          }
        }
      },
      "post": {
        "summary": "Post Quotes",
        "description": "Get quotes using POST method for large symbol lists.",
        "operationId": "postQuotes",
        "tags": ["Market Data"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["symbols"],
                "properties": {
                  "symbols": {
                    "type": "string"
                  },
                  "greeks": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quote data"
          }
        }
      }
    },
    "/markets/options/chains": {
      "get": {
        "summary": "Get Options Chains",
        "description": "Get all options chains for a given underlying symbol.",
        "operationId": "getOptionsChains",
        "tags": ["Market Data"],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Underlying symbol"
          },
          {
            "name": "expiration",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Expiration date (YYYY-MM-DD)"
          },
          {
            "name": "greeks",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Options chain data"
          }
        }
      }
    },
    "/markets/options/expirations": {
      "get": {
        "summary": "Get Options Expirations",
