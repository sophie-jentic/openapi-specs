                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Watchlist created"
          }
        }
      }
    },
    "/watchlists/{watchlist_id}": {
      "get": {
        "summary": "Get Watchlist",
        "description": "Retrieve a specific watchlist.",
        "operationId": "getWatchlist",
        "tags": ["Watchlists"],
        "parameters": [
          {
            "name": "watchlist_id",
