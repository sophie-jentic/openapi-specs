{
  "openapi": "3.0.3",
  "info": {
    "title": "SnapEngage API",
    "version": "2.0.0",
    "description": "SnapEngage is a live chat platform. The API provides agent status management, bot integration, and chat log retrieval.",
    "x-jentic-source-url": "https://developer.snapengage.com/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://www.snapengage.com/api/v2"
    }
  ],
  "security": [
    {
      "apiToken": []
    }
  ],
  "components": {
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API Token from Admin Dashboard"
      }
    },
    "schemas": {
      "AgentStatusRequest": {
        "type": "object",
        "required": [
          "agent_id",
          "status"
        ],
        "properties": {
          "agent_id": {
            "type": "string",
            "description": "Agent email address"
          },
          "status": {
            "type": "string",
            "enum": [
              "online",
              "pause"
            ],
            "description": "Agent status"
          },
          "sub_status": {
            "type": "string",
            "description": "Additional status info e.g. 'Gone to lunch'"
          }
        }
      },
      "AgentStatusEvent": {
        "type": "object",
        "properties": {
          "org": {
            "type": "integer",
            "description": "SnapEngage organization ID"
          },
          "agent_id": {
            "type": "string",
            "description": "Agent email (prepended with 'wc:')"
          },
          "status": {
            "type": "string",
            "enum": [
              "online",
              "pause",
              "offline"
            ]
          },
          "sub_status": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer",
            "description": "Unix epoch timestamp"
          }
        }
      },
      "BotMessage": {
        "type": "object",
        "properties": {
          "widget_id": {
            "type": "string"
          },
          "case_id": {
            "type": "string"
          },
          "event": {
            "type": "string",
            "enum": [
              "chatStarted",
              "chatClosed",
              "message",
              "systemMessage"
            ]
          },
          "text": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer"
          }
        }
      },
      "BotResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Text to send back"
          },
          "command": {
            "type": "string",
            "description": "Bot command (transfer, ban, goto, endChat)"
          },
          "displayResponse": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DisplayResponse"
            }
          },
          "delayInSeconds": {
            "type": "integer"
          }
        }
      },
      "DisplayResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      },
      "ChatLog": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "widget_id": {
            "type": "string"
          },
          "case_number": {
            "type": "string"
          },
          "visitor_name": {
            "type": "string"
          },
          "visitor_email": {
            "type": "string"
          },
          "chat_agent": {
            "type": "string"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "from": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      },
      "ChatLogList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatLog"
            }
          },
          "pagination": {
            "type": "object",
            "properties": {
              "page": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              }
            }
          }
        }
      },
      "ChatStartedEvent": {
        "type": "object",
        "properties": {
          "widget_id": {
            "type": "string"
          },
          "case_id": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer"
          },
          "event": {
            "type": "string",
            "enum": [
              "chatStarted"
            ]
          },
          "email": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "tags": {
            "type": "string"
          },
          "geo": {
            "type": "object",
            "properties": {
              "city": {
                "type": "string"
              },
              "region": {
                "type": "string"
              },
              "country_code": {
                "type": "string"
              }
            }
          },
          "user_agent": {
            "type": "string"
          },
          "entry_url": {
            "type": "string"
          },
          "referrer_url": {
            "type": "string"
          },
          "page_url": {
            "type": "string"
          },
          "ip_address": {
            "type": "string"
          },
          "jsVariables": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/agentstatus": {
      "post": {
        "summary": "Send agent status to SnapEngage",
        "operationId": "agentStatus_post",
        "tags": [
          "Agent Status"
        ],
        "description": "Update an agent's status in SnapEngage",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentStatusRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/logs": {
      "get": {
        "summary": "Retrieve chat logs",
        "operationId": "logs_list",
        "tags": [
          "Chat Logs"
        ],
        "parameters": [
          {
            "name": "widgetId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time",
              "description": "Start date for log retrieval"
            }
          },
          {
            "name": "end",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time",
              "description": "End date for log retrieval"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "perPage",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chat logs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatLogList"
                }
              }
            }
          }
        },
        "description": "Retrieve chat logs"
      }
    },
    "/logs/{caseId}": {
      "get": {
        "summary": "Retrieve a single chat log",
        "operationId": "logs_get",
        "tags": [
          "Chat Logs"
        ],
        "parameters": [
          {
            "name": "caseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chat log",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatLog"
                }
              }
            }
          }
        },
        "description": "Retrieve a single chat log"
      }
    },
    "/bot/message": {
      "post": {
        "summary": "Send a bot message",
        "operationId": "bot_sendMessage",
        "tags": [
          "Bot"
        ],
        "description": "Send a message or command from a bot agent to a chat",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "widget_id",
                  "case_id"
                ],
                "properties": {
                  "widget_id": {
                    "type": "string"
                  },
                  "case_id": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  },
                  "command": {
                    "type": "string",
                    "enum": [
                      "transfer",
                      "ban",
                      "goto",
                      "endChat"
                    ]
                  },
                  "displayResponse": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/DisplayResponse"
                    }
                  },
                  "delayInSeconds": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent"
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/bot/typing": {
      "post": {
        "summary": "Send bot typing indicator",
        "operationId": "bot_typing",
        "tags": [
          "Bot"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "widget_id",
                  "case_id"
                ],
                "properties": {
                  "widget_id": {
                    "type": "string"
                  },
                  "case_id": {
                    "type": "string"
                  },
                  "typing": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Typing indicator sent"
          }
        },
        "description": "Send bot typing indicator"
      }
    }
  },
  "tags": [
    {
      "name": "Agent Status"
    },
    {
      "name": "Bot"
    },
    {
      "name": "Chat Logs"
    }
  ]
}
