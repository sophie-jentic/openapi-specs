{
  "openapi": "3.0.3",
  "info": {
    "title": "CosmoLex API",
    "description": "CosmoLex is a cloud-based legal practice management platform. The CosmoLex API provides programmatic access to manage legal practice operations including contacts, matters, billing, time entries, trust accounting, and calendar events.",
