{
  "openapi": "3.0.3",
  "info": {
    "title": "Gelato API",
    "version": "1.0.0",
    "description": "Gelato print-on-demand API for creating and managing print orders, products, and shipments.",
    "x-jentic-source-url": "https://dashboard.gelato.com/docs/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.gelato.com/v4"
    }
  ],
