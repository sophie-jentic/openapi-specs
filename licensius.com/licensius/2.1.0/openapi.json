{
  "openapi": "3.0.1",
  "info": {
    "title": "Licensius",
    "description": "Licensing related services",
    "license": {
      "name": "cc-by-4.0",
      "url": "http://purl.org/NET/rdflicense/cc-by3.0"
    },
    "version": "2.1.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/vroddon/Licensius/2.1.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://licensius.com/api"
    }
  ],
  "paths": {
    "/test": {
      "get": {
        "summary": "A test",
        "description": "Nothing more than a test call.",
        "responses": {
          "200": {
            "description": "A hello world string to test the service availability",
            "content": {}
          }
        },
        "operationId": "get_test",
        "tags": [
          "test"
        ]
      }
    },
    "/license/list": {
      "get": {
        "tags": [
          "license"
        ],
        "summary": "Obtains a list of licenses",
        "description": "Obtains a list of well-known licenses to be used for general works and data, together with the RDF equivalent.",
        "responses": {
          "200": {
            "description": "An array of licenses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/license"
                  }
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_license_list"
      }
    },
    "/license/findlicenseinrdf": {
      "get": {
        "tags": [
          "license"
        ],
        "summary": "Guesses the license in an ontology or dataset.",
        "description": "Obtains a list guessed licenses in the Linked Data resource. Triples with the property dct:license etc. are scanned.",
        "parameters": [
          {
            "name": "uri",
            "in": "query",
            "description": "URI to the RDF document where the license will be scanned",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An array of licenses guesses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/licenseguess"
                  }
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_license_findlicenseinrdf"
      }
    },
    "/license/findlicenseintxt": {
      "get": {
        "tags": [
          "license"
        ],
        "summary": "Guesses the license in a text fragment.",
        "description": "Obtains a list guessed licenses in a text document. Known text fragments are searched.",
        "parameters": [
          {
            "name": "uri",
            "in": "query",
            "description": "URI to the textdocument where the license will be scanned",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An array of licenses guesses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/licenseguess"
                  }
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "operationId": "get_license_findlicenseintxt"
      }
    },
    "/odrl/validate": {
      "get": {
        "tags": [
          "odrl"
        ],
        "summary": "Validates a ODRL fragment",
        "description": "Determines whether an RDF document conforms or not to the ODRL specification",
        "parameters": [
          {
            "name": "odrl",
            "in": "query",
            "description": "Fragment of RDF to be parsed",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "True or false",
            "content": {}
          }
        },
        "operationId": "get_odrl_validate"
      }
    }
  },
  "components": {
    "schemas": {
      "license": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string",
            "description": "URI of the RDFlicense."
          },
          "title": {
            "type": "string",
            "description": "Common name of a License"
          },
          "source": {
            "type": "string",
            "description": "URI of the original text (if any)."
          }
        }
      },
      "licenseguess": {
        "type": "object",
        "properties": {
          "license": {
            "type": "object",
            "properties": {},
            "description": ""
          },
          "evidence": {
            "type": "string",
            "description": "Evidence of the result"
          },
          "confidence": {
            "type": "string",
            "description": "Confidence value in the range 0-100"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "fields": {
            "type": "string"
          }
        }
      }
    }
  },
  "x-original-swagger-version": "2.0",
  "tags": [
    {
      "name": "license"
    },
    {
      "name": "odrl"
    },
    {
      "name": "test"
    }
  ]
}
