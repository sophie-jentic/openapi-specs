{
  "openapi": "3.0.0",
  "info": {
    "title": "Gitter API",
    "description": "REST API for Gitter chat platform (now migrated to Matrix). This API allows you to interact with Gitter rooms, messages, and user data.",
    "version": "1.0.0",
    "contact": {
      "name": "Gitter API Support",
      "url": "https://gitter.im"
    }
  },
  "servers": [
    {
      "url": "https://api.gitter.im/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/user": {
      "get": {
        "summary": "Get current user",
        "description": "Returns information about the currently authenticated user",
        "operationId": "getCurrentUser",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/user/{userId}": {
      "get": {
        "summary": "Get user by ID",
        "description": "Returns information about a specific user",
        "operationId": "getUserById",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "description": "ID of the user",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    },
    "/rooms": {
      "get": {
        "summary": "List rooms",
        "description": "Returns list of rooms the authenticated user has access to",
        "operationId": "listRooms",
        "tags": [
          "Rooms"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Room"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rooms/{roomId}": {
      "get": {
        "summary": "Get room by ID",
        "description": "Returns information about a specific room",
        "operationId": "getRoomById",
        "tags": [
          "Rooms"
        ],
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "description": "ID of the room",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Room"
                }
              }
            }
          },
          "404": {
            "description": "Room not found"
          }
        }
      }
    },
    "/rooms/{roomId}/chatMessages": {
      "get": {
        "summary": "List messages in room",
        "description": "Returns messages from a specific room",
        "operationId": "listMessages",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "description": "ID of the room",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of messages to return",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "beforeId",
            "in": "query",
            "description": "Get messages before this message ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Message"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Send message",
        "description": "Sends a message to a specific room",
        "operationId": "sendMessage",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "description": "ID of the room",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Message text"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          }
        }
      }
    },
    "/rooms/{roomId}/users": {
      "get": {
        "summary": "List room users",
        "description": "Returns list of users in a specific room",
        "operationId": "listRoomUsers",
        "tags": [
          "Rooms"
        ],
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "description": "ID of the room",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID"
          },
          "username": {
            "type": "string",
            "description": "Username"
          },
          "displayName": {
            "type": "string",
            "description": "Display name"
          },
          "url": {
            "type": "string",
            "description": "Profile URL"
          },
          "avatarUrl": {
            "type": "string",
            "description": "Avatar image URL"
          },
          "avatarUrlSmall": {
            "type": "string",
            "description": "Small avatar image URL"
          },
          "avatarUrlMedium": {
            "type": "string",
            "description": "Medium avatar image URL"
          }
        }
      },
      "Room": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Room ID"
          },
          "name": {
            "type": "string",
            "description": "Room name"
          },
          "topic": {
            "type": "string",
            "description": "Room topic"
          },
          "uri": {
            "type": "string",
            "description": "Room URI"
          },
          "oneToOne": {
            "type": "boolean",
            "description": "Whether this is a one-to-one room"
          },
          "userCount": {
            "type": "integer",
            "description": "Number of users in the room"
          },
          "unreadItems": {
            "type": "integer",
            "description": "Number of unread items"
          },
          "url": {
            "type": "string",
            "description": "Room URL"
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Message ID"
          },
          "text": {
            "type": "string",
            "description": "Message text"
          },
          "html": {
            "type": "string",
            "description": "Rendered HTML"
          },
          "sent": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when message was sent"
          },
          "fromUser": {
            "$ref": "#/components/schemas/User"
          },
          "unread": {
            "type": "boolean",
            "description": "Whether message is unread"
          },
          "readBy": {
            "type": "integer",
            "description": "Number of users who read the message"
          },
          "urls": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "URLs mentioned in the message"
          },
          "mentions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            },
            "description": "Users mentioned in the message"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Messages"
    },
    {
      "name": "Rooms"
    },
    {
      "name": "Users"
    }
  ]
}
