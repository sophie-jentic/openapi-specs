{
  "openapi": "3.0.3",
  "info": {
    "title": "Netsmart CareConnect FHIR API",
    "version": "2.0.0",
    "description": "Netsmart CareConnect provides comprehensive FHIR R4 APIs for secure, standards-based access to healthcare data. Supports Patient Access, Practitioner Access, System Access (Bulk Data), and Provider Directory APIs. Implements US Core 6.1.0, SMART on FHIR 2.0, and Bulk Data 2.0.0 specifications. Compliant with the 21st Century Cures Act and CMS Interoperability Rules.",
    "x-jentic-source-url": "https://careconnect.netsmartcloud.com/docs/api/fhir/index.html",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://fhir.netsmartcloud.com",
      "description": "Production environment"
    },
    {
      "url": "https://fhirtest.netsmartcloud.com",
      "description": "Preview/test environment"
    }
  ],
  "paths": {
    "/provider/patient-access/v2/{tenantId}/metadata": {
      "get": {
        "operationId": "getProviderPatientAccessCapabilityStatement",
        "summary": "Get Provider Patient Access CapabilityStatement",
        "description": "Retrieves the CapabilityStatement describing supported FHIR resources and operations for Provider Patient Access API.",
        "tags": [
          "Provider - Patient Access"
        ],
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "description": "Tenant identifier for the healthcare organization",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CapabilityStatement resource",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/CapabilityStatement"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                }
              }
            }
          }
        }
      }
    },
    "/provider/patient-access/v2/{tenantId}/Patient": {
      "get": {
        "operationId": "searchProviderPatients",
        "summary": "Search patients (Provider Patient Access)",
        "description": "Search for Patient resources. Supports US Core Patient profile search parameters.",
        "tags": [
          "Provider - Patient Access"
        ],
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_id",
            "in": "query",
            "description": "Patient resource ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "identifier",
            "in": "query",
            "description": "Patient identifier (system|value)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "Patient name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "birthdate",
            "in": "query",
            "description": "Patient date of birth",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "gender",
            "in": "query",
            "description": "Patient gender",
            "schema": {
              "type": "string",
              "enum": [
                "male",
                "female",
                "other",
                "unknown"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bundle of Patient resources",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/Bundle"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                }
              }
            }
          }
        },
        "security": [
          {
            "OAuth2": [
              "patient/Patient.read"
            ]
          }
        ]
      }
    },
