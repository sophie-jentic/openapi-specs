    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "description": "SMART on FHIR OAuth 2.0 Authorization Code flow with PKCE for patient-facing applications",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://fhir.netsmartcloud.com/auth/{tenant-id}/oauth2/v1/authorize",
            "tokenUrl": "https://fhir.netsmartcloud.com/auth/{tenant-id}/oauth2/v1/token",
            "scopes": {
              "patient/Patient.read": "Read patient demographics",
              "patient/Condition.read": "Read conditions",
              "patient/Observation.read": "Read observations",
              "patient/MedicationRequest.read": "Read medication requests",
              "patient/Encounter.read": "Read encounters",
              "patient/Procedure.read": "Read procedures",
              "patient/AllergyIntolerance.read": "Read allergy intolerances",
              "patient/CarePlan.read": "Read care plans",
              "patient/DocumentReference.read": "Read document references",
              "patient/Coverage.read": "Read insurance coverage"
            }
          }
        }
      },
      "OAuth2ClientCredentials": {
        "type": "oauth2",
        "description": "OAuth 2.0 Client Credentials flow for system-to-system access",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://fhir.netsmartcloud.com/auth/{tenant-id}/oauth2/v1/token",
            "scopes": {
              "system/Patient.read": "Read patient data in bulk",
              "system/*.read": "Read all resources"
            }
          }
        }
      }
    }
