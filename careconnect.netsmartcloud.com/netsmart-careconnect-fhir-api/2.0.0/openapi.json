    "/provider/system-access/v2/{tenantId}/Patient/$export": {
      "get": {
        "operationId": "bulkExportPatients",
        "summary": "Initiate bulk patient data export",
        "description": "Initiates a FHIR Bulk Data Export for Patient resources. Returns a Content-Location header with the export status URL.",
        "tags": [
          "Provider - System Access"
        ],
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_type",
            "in": "query",
            "description": "FHIR resource types to export (comma-separated)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_since",
            "in": "query",
            "description": "Only include resources updated after this date",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "Prefer",
            "in": "header",
            "required": true,
            "description": "Must be respond-async",
            "schema": {
              "type": "string",
              "enum": [
                "respond-async"
              ]
            }
          },
          {
            "name": "Accept",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "application/fhir+json"
              ]
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Export accepted. Check Content-Location header for status URL.",
            "headers": {
              "Content-Location": {
                "description": "URL to poll for export status",
                "schema": {
