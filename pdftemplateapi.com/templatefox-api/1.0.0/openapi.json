{
  "openapi": "3.0.3",
  "info": {
    "title": "TemplateFox API",
    "version": "1.0.0",
    "description": "Generate beautiful PDFs from HTML/CSS templates with Jinja2 via API.",
    "x-jentic-source-url": "https://api.pdftemplateapi.com/docs",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.pdftemplateapi.com"
    }
  ],
  "paths": {
    "/v1/pdf/create": {
      "post": {
        "operationId": "createPdf",
        "summary": "Create PDF synchronously",
        "description": "Synchronous PDF generation with URL or binary export.",
        "tags": [
          "PDF Generation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePdfRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePdfResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/pdf/create-async": {
      "post": {
        "operationId": "createPdfAsync",
        "summary": "Create PDF asynchronously",
        "description": "Asynchronous PDF generation with job queuing.",
