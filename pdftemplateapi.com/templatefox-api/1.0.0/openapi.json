  "components": {
    "schemas": {
      "CreatePdfRequest": {
        "type": "object",
        "required": [
          "template_id",
          "data"
        ],
        "properties": {
          "template_id": {
            "type": "string"
          },
          "data": {
            "type": "object"
          },
          "export_type": {
            "type": "string",
            "enum": [
              "url",
              "binary"
            ]
          },
          "expiration": {
            "type": "integer"
          },
          "filename": {
            "type": "string"
          },
          "s3": {
            "type": "boolean"
          }
        }
      },
      "CreatePdfResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "remaining_credits": {
            "type": "integer"
          },
          "expiration": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateAsyncPdfRequest": {
        "type": "object",
        "required": [
          "template_id",
          "data"
        ],
        "properties": {
          "template_id": {
            "type": "string"
          },
          "data": {
            "type": "object"
          },
          "webhook_url": {
            "type": "string"
          },
          "export_type": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          }
        }
      },
      "CreateAsyncPdfResponse": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending"
            ]
          },
          "remaining_credits": {
            "type": "integer"
          }
        }
      },
      "JobStatusResponse": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ]
          },
          "result_url": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "JobListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/JobStatusResponse"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "TemplateListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "TemplateFieldsResponse": {
        "type": "object",
        "properties": {
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "required": {
                  "type": "boolean"
                },
                "help_text": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "AccountInfoResponse": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "credits": {
            "type": "integer"
          }
        }
      },
      "TransactionListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "reference": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "template_id": {
                  "type": "string"
                },
                "credits": {
                  "type": "integer"
                },
                "created_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "S3ConfigRequest": {
        "type": "object",
        "properties": {
          "endpoint": {
            "type": "string"
          },
          "access_key": {
            "type": "string"
          },
          "secret_key": {
            "type": "string"
          },
          "bucket": {
            "type": "string"
          },
          "prefix": {
            "type": "string"
          }
        }
      },
      "S3ConfigResponse": {
        "type": "object",
        "properties": {
          "endpoint": {
            "type": "string"
          },
          "bucket": {
            "type": "string"
          },
          "prefix": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for authentication."
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Account"
    },
    {
      "name": "Integrations"
    },
    {
      "name": "Jobs"
    },
    {
      "name": "PDF Generation"
    },
    {
      "name": "Templates"
    }
  ]
}
