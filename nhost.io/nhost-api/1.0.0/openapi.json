{
  "openapi": "3.0.3",
  "info": {
    "title": "Nhost API",
    "version": "1.0.0",
    "description": "Nhost is an open-source Firebase alternative providing authentication, storage, GraphQL (Hasura), and serverless functions. This spec covers the REST Auth and Storage APIs.",
    "x-jentic-source-url": "https://docs.nhost.io/",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://{subdomain}.auth.{region}.nhost.run/v1",
      "variables": {
        "subdomain": {
          "default": "xxx"
        },
        "region": {
          "default": "eu-central-1"
        }
      }
    }
  ],
  "paths": {
    "/signup/email-password": {
      "post": {
        "operationId": "signUpEmailPassword",
        "summary": "Sign up with email and password",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  },
                  "options": {
                    "type": "object",
                    "properties": {
                      "displayName": {
                        "type": "string"
                      },
                      "locale": {
                        "type": "string"
                      },
                      "defaultRole": {
                        "type": "string"
                      },
                      "allowedRoles": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "metadata": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User signed up",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSession"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Sign up with email and password"
      }
    },
