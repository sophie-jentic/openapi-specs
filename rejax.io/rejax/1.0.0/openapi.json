{
  "openapi": "3.0.0",
  "info": {
    "title": "Rejax API",
    "description": "Rejax API provides HTTP request services and testing capabilities.",
    "version": "1.0.0",
    "contact": {
      "name": "Rejax",
      "url": "https://rejax.io"
    }
  },
  "servers": [
    {
      "url": "https://api.rejax.io/v1",
      "description": "Production API Server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "RequestLog": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Request ID"
          },
          "method": {
            "type": "string",
            "description": "HTTP method"
          },
          "url": {
            "type": "string",
            "description": "Request URL"
          },
          "headers": {
            "type": "object",
            "description": "Request headers"
          },
          "body": {
            "type": "string",
            "description": "Request body"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Request timestamp"
          }
        }
      },
      "ProxyRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Target URL"
          },
          "method": {
            "type": "string",
            "enum": [
              "GET",
              "POST",
              "PUT",
              "DELETE",
              "PATCH"
            ],
            "default": "GET",
            "description": "HTTP method"
          },
          "headers": {
            "type": "object",
            "description": "Custom headers"
          },
          "body": {
            "type": "string",
            "description": "Request body"
          },
          "timeout": {
            "type": "integer",
            "description": "Request timeout in milliseconds"
          }
        }
      },
      "ProxyResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "headers": {
            "type": "object",
            "description": "Response headers"
          },
          "body": {
            "type": "string",
            "description": "Response body"
          },
          "duration": {
            "type": "integer",
            "description": "Request duration in milliseconds"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  },
  "paths": {
    "/requests": {
      "get": {
        "operationId": "listRequests",
        "summary": "List requests",
        "description": "Get a list of logged requests",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            },
            "description": "Number of requests to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Pagination offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "requests": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/RequestLog"
                      }
                    },
                    "total": {
                      "type": "integer",
                      "description": "Total number of requests"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "requests"
        ]
      }
    },
    "/requests/{id}": {
      "get": {
        "operationId": "getRequest",
        "summary": "Get request details",
        "description": "Get details of a specific request",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Request ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestLog"
                }
              }
            }
          },
          "404": {
            "description": "Request not found"
          }
        },
        "tags": [
          "requests"
        ]
      }
    },
    "/proxy": {
      "post": {
        "operationId": "proxyRequest",
        "summary": "Proxy HTTP request",
        "description": "Make an HTTP request through Rejax proxy",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProxyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProxyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "tags": [
          "proxy"
        ]
      }
    },
    "/status": {
      "get": {
        "operationId": "getStatus",
        "summary": "Get API status",
        "description": "Check API status and health",
        "security": [],
        "responses": {
          "200": {
            "description": "API is operational",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "logged"
                    },
                    "version": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "status"
        ]
      }
    }
  },
  "tags": [
    {
      "name": "proxy"
    },
    {
      "name": "requests"
    },
    {
      "name": "status"
    }
  ]
}
