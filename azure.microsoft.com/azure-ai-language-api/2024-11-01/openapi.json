  "components": {
    "schemas": {
      "AnalyzeTextRequest": {
        "type": "object",
        "required": [
          "kind",
          "analysisInput"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "description": "The kind of analysis to perform.",
            "enum": [
              "SentimentAnalysis",
              "EntityRecognition",
              "PiiEntityRecognition",
              "KeyPhraseExtraction",
              "LanguageDetection",
              "EntityLinking"
            ]
          },
          "analysisInput": {
            "type": "object",
            "properties": {
              "documents": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/TextDocumentInput"
                }
              }
            }
          },
          "parameters": {
            "type": "object",
            "properties": {
              "modelVersion": {
                "type": "string"
              },
              "loggingOptOut": {
                "type": "boolean"
              }
            }
          }
        }
      },
      "AnalyzeTextResponse": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string"
          },
          "results": {
            "type": "object",
            "properties": {
              "documents": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "errors": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/DocumentError"
                }
              },
              "modelVersion": {
                "type": "string"
              }
            }
          }
        }
      },
      "TextDocumentInput": {
        "type": "object",
        "required": [
          "id",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique document identifier."
          },
          "text": {
            "type": "string",
            "description": "Document text content."
          },
          "language": {
            "type": "string",
            "description": "ISO 639-1 language code."
          }
        }
      },
      "MultiLanguageBatchInput": {
        "type": "object",
        "required": [
          "documents"
        ],
        "properties": {
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TextDocumentInput"
            }
          }
        }
      },
      "LanguageDetectionInput": {
        "type": "object",
        "required": [
          "documents"
        ],
        "properties": {
          "documents": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "text"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                },
                "countryHint": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "SentimentAnalysisResponse": {
        "type": "object",
        "properties": {
          "documents": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "sentiment": {
                  "type": "string",
                  "enum": [
                    "positive",
                    "neutral",
                    "negative",
                    "mixed"
                  ]
                },
                "confidenceScores": {
                  "$ref": "#/components/schemas/SentimentConfidenceScores"
                },
                "sentences": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "text": {
                        "type": "string"
                      },
                      "sentiment": {
                        "type": "string"
                      },
                      "confidenceScores": {
                        "$ref": "#/components/schemas/SentimentConfidenceScores"
                      },
                      "offset": {
                        "type": "integer"
                      },
                      "length": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentError"
            }
          },
          "modelVersion": {
            "type": "string"
          }
        }
      },
      "SentimentConfidenceScores": {
        "type": "object",
        "properties": {
          "positive": {
            "type": "number"
          },
          "neutral": {
            "type": "number"
          },
          "negative": {
            "type": "number"
          }
        }
      },
      "LanguageDetectionResponse": {
        "type": "object",
        "properties": {
          "documents": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "detectedLanguage": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "iso6391Name": {
                      "type": "string"
                    },
                    "confidenceScore": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentError"
            }
          },
          "modelVersion": {
            "type": "string"
          }
        }
      },
      "EntityRecognitionResponse": {
        "type": "object",
        "properties": {
          "documents": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "entities": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AzureEntity"
                  }
                }
              }
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentError"
            }
          },
          "modelVersion": {
            "type": "string"
          }
        }
      },
      "AzureEntity": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "subcategory": {
            "type": "string"
          },
          "offset": {
            "type": "integer"
          },
          "length": {
            "type": "integer"
          },
          "confidenceScore": {
            "type": "number"
          }
        }
      },
      "EntityLinkingResponse": {
        "type": "object",
        "properties": {
          "documents": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "entities": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "matches": {
                        "type": "array",
                        "items": {
                          "type": "object"
                        }
                      },
                      "language": {
                        "type": "string"
                      },
                      "id": {
                        "type": "string"
                      },
                      "url": {
                        "type": "string"
                      },
                      "dataSource": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentError"
            }
          },
          "modelVersion": {
            "type": "string"
          }
        }
      },
      "KeyPhraseExtractionResponse": {
        "type": "object",
        "properties": {
          "documents": {
            "type": "array",
